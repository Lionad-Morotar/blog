[{"data":1,"prerenderedAt":674},["ShallowReactive",2],{"navigation":3,"/books/_isbn-9787572610912":170,"/books/_isbn-9787572610912-surround":667},[4,35,92,98,125,131,155,161],{"title":5,"_path":6,"children":7},"心流思绪 / Heart Flows","/flows",[8,11,14,17,20,23,26,29,32],{"title":9,"_path":10},"📕 狮子的书单推荐","/flows/books",{"title":12,"_path":13},"🚝 四十二篇系列","/flows/forty-two",{"title":15,"_path":16},"🌃 长夜梦","/flows/long-night-dream",{"title":18,"_path":19},"🌌 万物联结与幸福感","/flows/everything",{"title":21,"_path":22},"⌛ 偷取时间","/flows/stealing-time-from-god",{"title":24,"_path":25},"🌆 表达和孤独","/flows/expression-and-loneliness",{"title":27,"_path":28},"🌧️ 我的腼腆","/flows/shy",{"title":30,"_path":31},"🥛 新工作，喝新饮料","/flows/drinking-while-thinking",{"title":33,"_path":34},"📝 心流归档","/flows/archive",{"title":36,"_path":37,"children":38},"技术博客 / Coder","/articles",[39,41,44,47,50,53,56,59,62,65,68,71,74,77,80,83,86,89],{"title":40,"_path":37},"🦁 欢迎",{"title":42,"_path":43},"📦 一个简单有效的端口命名策略：","/articles/simple-naming-method",{"title":45,"_path":46},"🌪️ Tailwind v4 如何兼容预处理器","/articles/tailwind4-with-sass",{"title":48,"_path":49},"🥞 在 tailwind 中使用现代化 CSS Layers","/articles/tailwind-sass-and-css-layer",{"title":51,"_path":52},"💻 本地部署 Qwen 翻译网页","/articles/local-translator",{"title":54,"_path":55},"🧊 模板解析器轻考古","/articles/micro-templating",{"title":57,"_path":58},"Ⓜ️ Mini CSS Parser","/articles/mini-css-parser",{"title":60,"_path":61},"🚩 向AI咨询前端问题","/articles/use-gpt-learn-complex-frontend",{"title":63,"_path":64},"⛸️ 怎样定制复杂组件的自定义滚动条？","/articles/use-scrollbars",{"title":66,"_path":67},"⚖️ 统一多组件库的层叠顺序","/articles/zindex-manager",{"title":69,"_path":70},"🕷️ 滑动验证码破解思路","/articles/crack-the-slider",{"title":72,"_path":73},"🌟 探秘 CSS 光影效果","/articles/css-light-travel",{"title":75,"_path":76},"🍲 设计模式与 JS 魔法锅","/articles/design-patterns-and-js-magic-pot",{"title":78,"_path":79},"🌐 Anysort：灵活、优雅的多属性排序","/articles/anysort-2th",{"title":81,"_path":82},"💫 CSS 幻术 | 抗锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133,"children":134},"造物 / Make","/tools",[135,137,140,143,146,149,152],{"title":136,"_path":133},"🧰 工具收集",{"title":138,"_path":139},"📕 博客","/tools/blog",{"title":141,"_path":142},"🥥 Coconut","/tools/coconut",{"title":144,"_path":145},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":147,"_path":148},"🌐 AnySort","/tools/anysort",{"title":150,"_path":151},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":153,"_path":154},"👓 Crapto","/tools/crypto-inline",{"title":156,"_path":157,"children":158},"我 / About","/hire",[159],{"title":160,"_path":157},"📬 技术简历",{"title":162,"_path":163,"children":164},"En","/en",[165],{"title":166,"_path":167,"children":168},"🦁 Welcome","/en/articles",[169],{"title":166,"_path":167},{"_path":171,"_dir":172,"_draft":173,"_partial":174,"_locale":175,"title":176,"description":177,"body":178,"_type":661,"_id":662,"_source":663,"_file":664,"_stem":665,"_extension":666},"/books/_isbn-9787572610912","books",false,true,"","《太白金星有点烦》","ISBN 9787572610912",{"type":179,"children":180,"toc":647},"root",[181,189,201,206,214,219,229,234,239,249,254,259,264,269,277,282,287,292,300,305,310,322,327,335,340,345,350,360,365,370,378,383,388,392,402,407,412,416,421,429,434,439,447,452,457,465,470,475,485,490,500,505,510,518,523,528,533,541,546,556,561,571,576,581,585,590,598,608,613,618],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"第一章",[187],{"type":188,"value":185},"text",{"type":182,"tag":190,"props":191,"children":192},"p",{},[193,195],{"type":188,"value":194},"李长庚不置可否：“甭管人家什么出身，毕竟是有真本事的。",{"type":182,"tag":196,"props":197,"children":198},"mark",{},[199],{"type":188,"value":200},"这一世是大唐数得着的高僧，主持过长安水陆大会，大唐皇帝亲封的御弟。往前九世转生，每一世都是大善人，至今一点元阳未泄。”",{"type":182,"tag":190,"props":202,"children":203},{},[204],{"type":188,"value":205},"听到“一点元阳未泄”六个字，织女扑哧一乐：“这也算优点啊？”“怎么不算？说明人家一心扑在弘法大业上，要不西天取经怎么就选中了他呢？”",{"type":182,"tag":190,"props":207,"children":208},{},[209],{"type":182,"tag":196,"props":210,"children":211},{},[212],{"type":188,"value":213},"“那直接接引成佛不好吗？何必非要从大唐走一趟？”",{"type":182,"tag":190,"props":215,"children":216},{},[217],{"type":188,"value":218},"“将帅必起于卒伍，宰相必起于州部。不在红尘洗礼一番，你成佛了也不能服众——佛祖这是用心良苦啊！”李长庚语重心长，见织女还没明白，不由得轻叹了一声。...",{"type":182,"tag":190,"props":220,"children":221},{},[222,224],{"type":188,"value":223},"织女当初私奔之后，生了一对龙凤胎。后来她被西王母抓回来，孩子是男方在带。如今牛郎与丈母娘关系缓和，西王母就用资助乞巧节的名义，特批了几十万只喜鹊，让他们每年聚一次。",{"type":182,"tag":196,"props":225,"children":226},{},[227],{"type":188,"value":228},"天上一日，凡间一年，织女每天都准点下班，去和老公、孩子相会，小日子过得美满充实。",{"type":182,"tag":190,"props":230,"children":231},{},[232],{"type":188,"value":233},"启明殿里变得静悄悄的，就剩下他一个人。李长庚把剩下的仙露茶一饮而尽，织女能准点下班，他可不能。",{"type":182,"tag":183,"props":235,"children":237},{"id":236},"第二章",[238],{"type":188,"value":236},{"type":182,"tag":190,"props":240,"children":241},{},[242,244],{"type":188,"value":243},"观音大惊：“这使不得，使不得，怎么能让玄奘收妖精做徒弟呢？”李长庚不解道：“孙悟空不也收了吗？猴子和黑熊，能有多大区别？”观音头摇得像一个转经筒：",{"type":182,"tag":196,"props":245,"children":246},{},[247],{"type":188,"value":248},"“玄奘取经，收多少徒弟皆有定数。黑熊精造化够了，可惜缘分未至。”",{"type":182,"tag":190,"props":250,"children":251},{},[252],{"type":188,"value":253},"李长庚冷笑起来。三千大道，只这两个词最为缥缈玄妙，说你造化上本来可以，其实是没缘分；说你造化上本不可以，反倒是缘分到了。所以满天神佛都爱用这词来推搪敷衍。",{"type":182,"tag":190,"props":255,"children":256},{},[257],{"type":188,"value":258},"他也不言语，端起茶碗，笑眯眯看着观音。观音脸色变了变，一咬牙，说：“灵山我做不了主，落伽山的差事行不行？”李长庚咳了一声，说黑熊精一心向佛，在哪里做事都是修行。",{"type":182,"tag":183,"props":260,"children":262},{"id":261},"第四章",[263],{"type":188,"value":261},{"type":182,"tag":190,"props":265,"children":266},{},[267],{"type":188,"value":268},"再者说，黄风怪之所以突然发疯，还不是因为二徒弟的名额被八戒给占了？如此推算下来，李长庚才是崩盘的初始之因。",{"type":182,"tag":190,"props":270,"children":271},{},[272],{"type":182,"tag":196,"props":273,"children":274},{},[275],{"type":188,"value":276},"李长庚暗自感叹，世间的因果，真是修仙者最难摆脱的东西，只要稍微沾上一点，便如藤蔓一样缠绕上来，不得解脱。",{"type":182,"tag":190,"props":278,"children":279},{},[280],{"type":188,"value":281},"回想起玉帝画的那个先天太极，圆融循环，周围干干净净，一点因果和业力不沾，这才是金仙境界。可惜李长庚修为不够，不能像玉帝那样甩脱因果。",{"type":182,"tag":183,"props":283,"children":285},{"id":284},"第五章",[286],{"type":188,"value":284},{"type":182,"tag":190,"props":288,"children":289},{},[290],{"type":188,"value":291},"诉状里还是那一套说法，只是补充了一点细节，也没什么实质帮助。六耳这事，除非是叫孙悟空来当面对质，否则没法可解。但孙悟空在取经途中，天庭根本无法传唤，等取经结束……人家就修成正果了，你更没办法。",{"type":182,"tag":190,"props":293,"children":294},{},[295],{"type":182,"tag":196,"props":296,"children":297},{},[298],{"type":188,"value":299},"李长庚也是一路修炼上来的，深知飞升得越高，离人间越远，因果就越少。没了因果牵扯，对人间的事情也便看淡了。六耳这种堵门闹事的偏执，易生妄念、成心魔，最为金仙们所不取。",{"type":182,"tag":190,"props":301,"children":302},{},[303],{"type":188,"value":304},"所以他劝六耳放弃，真的是出于善意。",{"type":182,"tag":183,"props":306,"children":308},{"id":307},"第六章",[309],{"type":188,"value":307},{"type":182,"tag":190,"props":311,"children":312},{},[313,315,320],{"type":188,"value":314},"李长庚“呃”了一声，这两个菩萨果然难对付，一个扮黑脸一个扮红脸，假意围着沙悟净转。他千防万防，尽量只说废话，可还是被设了一个埋伏，绕入",{"type":182,"tag":196,"props":316,"children":317},{},[318],{"type":188,"value":319},"彀",{"type":188,"value":321},"中。",{"type":182,"tag":190,"props":323,"children":324},{},[325],{"type":188,"value":326},"耳热时，观音忽然把玉净瓶往桌上一拍，满脸涨红：“我可太难了！本来护法就不是好干的活，还惹来一堆嫌弃。他们上回挑唆玄奘，这次是试炼八戒，下回是什么？天天变着法子防着自己人，太累了，还不如辞了算了！”",{"type":182,"tag":190,"props":328,"children":329},{},[330],{"type":182,"tag":196,"props":331,"children":332},{},[333],{"type":188,"value":334},"李长庚端起酒杯：“大士你这就不对了。道法自然，什么是自然之法？就是斗，就是争，大道争锋，你退一尺，他们就会进一丈。你以为辞了麻烦就少了吗？错了，人家觉得你弱，以后麻烦会源源不断。”",{"type":182,"tag":190,"props":336,"children":337},{},[338],{"type":188,"value":339},"“老李你看着谦冲随和，想不到骨子里这么狠。”",{"type":182,"tag":183,"props":341,"children":343},{"id":342},"第七章",[344],{"type":188,"value":342},{"type":182,"tag":190,"props":346,"children":347},{},[348],{"type":188,"value":349},"...",{"type":182,"tag":190,"props":351,"children":352},{},[353,355],{"type":188,"value":354},"镇元子不乐意了：“老李，我好意招待你，你何必老是拆我的台？我要不说得这么玄乎，人家办瑶池会怎么会用我的果品做特供？",{"type":182,"tag":196,"props":356,"children":357},{},[358],{"type":188,"value":359},"道经有云，大成若缺，一样东西想要大成，必须让人觉得稀缺。”",{"type":182,"tag":190,"props":361,"children":362},{},[363],{"type":188,"value":364},"观音隐隐觉得这话似乎不该这么理解，镇元子又道：“再说了，现在各路神仙都托关系来问我要，谁的面子都不能落。我少报一点产量，私下里再给他们多分，这人情不是做得更大了吗？”...",{"type":182,"tag":190,"props":366,"children":367},{},[368],{"type":188,"value":369},"九难，这就又有两难了嘛。”观音伸出两个指头，比画了一下，一脸喜色。这活轻轻松松，好不舒服。她抬头看看人参果树的青青冠盖，不由得发出感慨：“这么干活多好，大家劲往一处使，不藏着掖着，也不用提防谁。”",{"type":182,"tag":190,"props":371,"children":372},{},[373],{"type":182,"tag":196,"props":374,"children":375},{},[376],{"type":188,"value":377},"“其实单纯干活啊，真不累。累的是，咱们一半的脑子都用在提防自己人上了。”",{"type":182,"tag":190,"props":379,"children":380},{},[381],{"type":188,"value":382},"“唉，天道如此，这也是机缘难得。”",{"type":182,"tag":183,"props":384,"children":386},{"id":385},"第十章",[387],{"type":188,"value":385},{"type":182,"tag":190,"props":389,"children":390},{},[391],{"type":188,"value":349},{"type":182,"tag":190,"props":393,"children":394},{},[395,397],{"type":188,"value":396},"“嗐，我在启明殿谨小慎微了几千年，难得陪你们疯一次，也没什么不好。再说了，我也想明白了：",{"type":182,"tag":196,"props":398,"children":399},{},[400],{"type":188,"value":401},"谁能做到人人都不得罪？至少得守住正理本心！”",{"type":182,"tag":190,"props":403,"children":404},{},[405],{"type":188,"value":406},"猪八戒在一旁忽然问道：“那俩娃娃怎么办？”观音和李长庚这才想起来，还有两个遗留问题在这里。沙僧看向百花羞：“你想如何处理他们？”百花羞决绝道：“我不想再见到他们了。”猪八戒看了沙僧一眼，说：“那我",{"type":182,"tag":183,"props":408,"children":410},{"id":409},"第十一章",[411],{"type":188,"value":409},{"type":182,"tag":190,"props":413,"children":414},{},[415],{"type":188,"value":349},{"type":182,"tag":190,"props":417,"children":418},{},[419],{"type":188,"value":420},"他犹恐李长庚不信，手起斧落，又狠狠劈下去。只见“咔嚓”一声，桂树裂隙四开，竟勾勒出一张苦闷疲惫、心事重重的老人面孔，与李长庚神似。",{"type":182,"tag":190,"props":422,"children":423},{},[424],{"type":182,"tag":196,"props":425,"children":426},{},[427],{"type":188,"value":428},"这确实是神乎其技，李长庚啧啧称赞了一阵，突地又涌起一股同情：“这又有什么意义？桂树原来什么样，还是什么样，有你不多，无你不少。你自以为精通了伐木之技，到头来却连一丝裂隙都留不下来。”吴刚挠挠头，沉思片刻方道：“好像是没什么意义。不过……”他拎起斧子，“哪个人不是如此？”",{"type":182,"tag":190,"props":430,"children":431},{},[432],{"type":188,"value":433},"他这句看似无意的反诘，却让李长庚为之一怔，呆在原地哑口无言。吴刚见他半天不吭声，自顾自挥动斧子，又叮叮咣咣地砍起来。",{"type":182,"tag":190,"props":435,"children":436},{},[437],{"type":188,"value":438},"李长庚搞明白这其中曲折之后，总算松了口气。",{"type":182,"tag":190,"props":440,"children":441},{},[442],{"type":182,"tag":196,"props":443,"children":444},{},[445],{"type":188,"value":446},"他在启明殿干得最多最熟的活是协调，协调的关键是，不怕你提的要求奇怪，就怕不知你要什么。只要掌握了各方的真实诉求，东哄哄，西劝劝，怎么都能协调出一个多方都能接受的方案。",{"type":182,"tag":190,"props":448,"children":449},{},[450],{"type":188,"value":451},"他沉思片刻，伸出两个指头：“你劝劝金蟾，让他不要跟天蓬较劲了。我给你两个保证：一保金蟾有个前程；二保天蓬就算回天庭，也绝不会来骚扰你。”...",{"type":182,"tag":190,"props":453,"children":454},{},[455],{"type":188,"value":456},"“哦，那倒不用，不用，我随口问问。”李长庚赶紧放她下班去了，然后推门进了启明殿。",{"type":182,"tag":190,"props":458,"children":459},{},[460],{"type":182,"tag":196,"props":461,"children":462},{},[463],{"type":188,"value":464},"说来也怪，他此时坐在堆积如山的桌案之前，第一次有了想做造销的意愿。原因无他，因为他现在有更不想做的事情，所以迫不及待想要沉浸在造销里逃避。",{"type":182,"tag":190,"props":466,"children":467},{},[468],{"type":188,"value":469},"李长庚心如止水，沉神下去，一口气把之前积压的造销全部做完，心中怅然若失。他看看时辰，把造销玉简收入袖中，亲自送去了财神殿。",{"type":182,"tag":190,"props":471,"children":472},{},[473],{"type":188,"value":474},"李长庚回到启明殿，决定好好修行一阵。可脑子里却杂事缠绕，无论如何也静不下心来。广寒宫那次意外的闯入、兜率宫无中生有的金丹失窃、莫名其妙的花果山灵保专款……种种蹊跷之处，似乎被隐隐的一条线串联起来。",{"type":182,"tag":190,"props":476,"children":477},{},[478,483],{"type":182,"tag":196,"props":479,"children":480},{},[481],{"type":188,"value":482},"李长庚在启明殿干了那么久，太熟悉仙界的运作逻辑了，一切不合理的事情背后，都有一个合理的理由，只是你不知道罢了。",{"type":188,"value":484},"他反复告诫自己，不要去想这种事，却无论如何也没法把这浊念赶出灵台，修行效果可想而知。",{"type":182,"tag":190,"props":486,"children":487},{},[488],{"type":188,"value":489},"李长庚为难地揉了揉太阳穴。沙僧是，六耳也是，他最怕的就是这种只要个说法的愣头青，要别的还可以协调交换，一说讨个说法，就几乎没有转圜的余地了。",{"type":182,"tag":190,"props":491,"children":492},{},[493,498],{"type":182,"tag":196,"props":494,"children":495},{},[496],{"type":188,"value":497},"仙界有些事可以说但不必做，有些事则可以做但绝对不能说。你让对方私下里怎么赔偿都行，但要逼对方公开表态，性质就截然不同了。",{"type":188,"value":499},"之前在广寒宫，李长庚宁可让猪八戒受一回怀胎的罪，也没提让他公开致歉的事情，就是这个道理。",{"type":182,"tag":183,"props":501,"children":503},{"id":502},"第十三章",[504],{"type":188,"value":502},{"type":182,"tag":190,"props":506,"children":507},{},[508],{"type":188,"value":509},"李长庚敏锐地捕捉到了西王母话里的关键——“借调”。既然是借，自然有还，也就是说，他只是临时来帮衬一下罢了，根脚还是落在启明殿。",{"type":182,"tag":190,"props":511,"children":512},{},[513],{"type":182,"tag":196,"props":514,"children":515},{},[516],{"type":188,"value":517},"西王母见他明悟，满意地端起茶杯啜了一口，眼神变得深邃：“我看你头顶三花形体清晰，境界应该是临近突破了。我作为过来人，送你两句忠告：超脱因果，太上忘情。”",{"type":182,"tag":190,"props":519,"children":520},{},[521],{"type":188,"value":522},"直到离开瑶池，李长庚还是晕晕乎乎的。",{"type":182,"tag":183,"props":524,"children":526},{"id":525},"第十四章",[527],{"type":188,"value":525},{"type":182,"tag":190,"props":529,"children":530},{},[531],{"type":188,"value":532},"可惜的是，揭帖公布出来，他非但没讨回身份，自己反倒被说成是孙悟空的心魔，又一次背上被替代的命运。",{"type":182,"tag":190,"props":534,"children":535},{},[536],{"type":182,"tag":196,"props":537,"children":538},{},[539],{"type":188,"value":540},"李长庚回顾至此，忍不住想，倘若当初自己查实了这桩小事——不，哪怕自己态度只是稍微用心一些，也许结局便大为不同。",{"type":182,"tag":190,"props":542,"children":543},{},[544],{"type":188,"value":545},"不对，不对。当初如果自己硬着心肠不管，赶六耳下界，他早早失望，也就没这事了。正是自己偶发善心，给了他虚假的希望，却又没办法解决，才导致这一场悲剧。",{"type":182,"tag":190,"props":547,"children":548},{},[549,554],{"type":182,"tag":196,"props":550,"children":551},{},[552],{"type":188,"value":553},"不要去学吴刚伐桂，徒劳地砍了那么久，却一丝痕迹也没留下，到头来都是一场空。这……这不正是太上忘情的真意吗？",{"type":188,"value":555},"李长庚陡然感到一丝灵光乍现，俯身把茶杯从地上捡起来，连忙坐回到蒲团上修炼。体内的正念元婴“嗷”了一声，飞扑过去把浊念元婴压住。浊念元婴灵力虚弱，动弹不得，只是嘴里还在聒噪不已。",{"type":182,"tag":190,"props":557,"children":558},{},[559],{"type":188,"value":560},"李长庚心里堵得厉害，...",{"type":182,"tag":190,"props":562,"children":563},{},[564,566],{"type":188,"value":565},"李长庚“呃”了一声。悟空道：“你如此做派，想必还没修到太上忘情的境界吧？",{"type":182,"tag":196,"props":567,"children":568},{},[569],{"type":188,"value":570},"我教你个乖：超脱因果，不是不沾因果；太上忘情，不是无情无欲。”",{"type":182,"tag":190,"props":572,"children":573},{},[574],{"type":188,"value":575},"李长庚一怔，这和自己想的好像有点差异，连忙请教。孙悟空却无意讲解，只是摆了摆手：“莫问莫问，还得你自家领悟才好。不要像我一样，太早想透这个道理，却比渡劫还痛苦呢。”",{"type":182,"tag":183,"props":577,"children":579},{"id":578},"第十五章",[580],{"type":188,"value":578},{"type":182,"tag":190,"props":582,"children":583},{},[584],{"type":188,"value":349},{"type":182,"tag":190,"props":586,"children":587},{},[588],{"type":188,"value":589},"与各种因果牵绊，便统统被抛却。那一桩不可言说的大秘密便可彻底消失，再无任何隐患。而对灵山来说，一个天庭顽妖皈依我佛，成了正途之外的佛陀，又是何等绝妙的揄扬素材——毕竟那可是天上地下独一个的孙悟空。",{"type":182,"tag":190,"props":591,"children":592},{},[593],{"type":182,"tag":196,"props":594,"children":595},{},[596],{"type":188,"value":597},"天庭消了隐患，灵山得了揄扬，悟空有了前途，可谓皆大欢喜。这……这才是太上忘情的妙旨真意啊。",{"type":182,"tag":190,"props":599,"children":600},{},[601,603],{"type":188,"value":602},"他原先一直卡在悟道的边缘，试过淡泊心性，试过清静无为，却始终不能理解那八字的精髓。眼见那些金仙明明一个个沾起因果来争先恐后，七情六欲也丰沛得很，与“超脱因果，太上忘情”八字岂不矛盾？",{"type":182,"tag":196,"props":604,"children":605},{},[606],{"type":188,"value":607},"如今见证了孙悟空抛却凡躯，想透了玉帝与佛祖的用意，李长庚这才想透了那段提点的真解：超脱因果，不是不沾因果，而是只存己念；太上忘情，也不是无情无欲，而是唯修自身。",{"type":182,"tag":190,"props":609,"children":610},{},[611],{"type":188,"value":612},"一切以自身修行为念，不为下界之事动摇心旌。如此一来，因果可以沾而不染，情欲也可以挂而不碍，境界截然不同。",{"type":182,"tag":190,"props":614,"children":615},{},[616],{"type":188,"value":617},"两人且聊且行。远处取经队伍已经收拾好了经文，驾起祥云喜气洋洋地朝着东土而去。但见满天瑞霭、阵阵香风，前方眼见到了长安。李长庚趁观音一时不察，到底还是朗声吟出来：",{"type":182,"tag":190,"props":619,"children":620},{},[621],{"type":182,"tag":196,"props":622,"children":623},{},[624,626,630,632,635,637,640,642,645],{"type":188,"value":625},"当年清宴乐升平，文武安然显俊英。",{"type":182,"tag":627,"props":628,"children":629},"br",{},[],{"type":188,"value":631},"水陆场中僧演法，金銮殿上主差卿。",{"type":182,"tag":627,"props":633,"children":634},{},[],{"type":188,"value":636},"关文敕赐唐三藏，经卷原因配五行。",{"type":182,"tag":627,"props":638,"children":639},{},[],{"type":188,"value":641},"苦炼凶魔种种灭，功成今喜上朝京。",{"type":182,"tag":627,"props":643,"children":644},{},[],{"type":188,"value":646},"全文完",{"title":175,"searchDepth":648,"depth":648,"links":649},2,[650,651,652,653,654,655,656,657,658,659,660],{"id":185,"depth":648,"text":185},{"id":236,"depth":648,"text":236},{"id":261,"depth":648,"text":261},{"id":284,"depth":648,"text":284},{"id":307,"depth":648,"text":307},{"id":342,"depth":648,"text":342},{"id":385,"depth":648,"text":385},{"id":409,"depth":648,"text":409},{"id":502,"depth":648,"text":502},{"id":525,"depth":648,"text":525},{"id":578,"depth":648,"text":578},"markdown","content:4.books:_isbn-9787572610912:index.md","content","4.books/_isbn-9787572610912/index.md","4.books/_isbn-9787572610912/index","md",[668,672],{"_path":669,"title":670,"description":671},"/books/_isbn-9787553815268","简读日本史","ISBN 9787553815268",{"_path":94,"title":97,"description":673},"读书笔记以及短评。希望能逐步摆脱豆瓣。",1771214184409]