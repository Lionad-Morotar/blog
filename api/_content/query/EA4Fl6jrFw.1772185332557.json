hildren":[{"type":"text","value":"steps"}]},{"type":"text","value":"、"},{"type":"element","tag":"code","props":{"className":[]},"children":[{"type":"text","value":"passes"}]},{"type":"text","value":" 字段。Coding Agent 只能修改 "},{"type":"element","tag":"code","props":{"className":[]},"children":[{"type":"text","value":"passes"}]},{"type":"text","value":" 字段，强烈措辞约束：\"删除或编辑测试是不可接受的，这会导致功能缺失或 bug\"。"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"端到端测试的必要性"}]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"Agent 容易\"未经充分测试就标记功能完成\"。显式提示使用浏览器自动化工具（如 Puppeteer MCP），像人类用户一样测试。这能发现仅从代码看不出的 bug，但注意 Claude 无法看到浏览器原生 alert 弹窗。"}]},{"type":"element","tag":"table","props":{},"children":[{"type":"element","tag":"thead","props":{},"children":[{"type":"element","tag":"tr","props":{},"children":[{"type":"element","tag":"th","props":{},"children":[{"type":"text","value":"常见失败模式"}]},{"type":"element","tag":"th","props":{},"children":[{"type":"text","value":"Initializer 解决方案"}]},{"type":"element","tag":"th","props":{},"children":[{"type":"text","value":"Coding Agent 解决方案"}]}]}]},{"type":"element","tag":"tbody","props":{},"children":[{"type":"element","tag":"tr","props":{},"children":[{"type":"element","tag":"td","props":{},"children":[{"type":"text","value":"过早宣布整个项目完成"}]},{"type":"element","tag":"td","props":{},"children":[{"type":"text","value":"设置详细功能清单"}]},{"type":"element","tag":"td","props":{},"children":[{"type":"text","value":"每次只选一个功能开发"}]}]},{"type":"element","tag":"tr","props":{},"children":[{"type":"element","tag":"td","props":{},"children":[{"type":"text","value":"留下 bug 或未记录的进度"}]},{"type":"element","tag":"td","props":{},"children":[{"type":"text","value":"初始化 git 和进度文件"}]},{"type":"element","tag":"td","props":{},"children":[{"type":"text","value":"开始读进度/git log，结束写 commit"}]}]},{"type":"element","tag":"tr","props":{},"children":[{"type":"element","tag":"td","props":{},"children":[{"type":"text","value":"过早标记功能完成"}]},{"type":"element","tag":"td","props":{},"children":[{"type":"text","value":"设置功能清单文件"}]},{"type":"element","tag":"td","props":{},"children":[{"type":"text","value":"自验证所有功能，仔细测试后才标记 passing"}]}]},{"type":"element","tag":"tr","props":{},"children":[{"type":"element","tag":"td","props":{},"children":[{"type":"text","value":"花时间摸索如何运行应用"}]},{"type":"element","tag":"td","props":{},"children":[{"type":"text","value":"编写 "},{"type":"element","tag":"code","props":{"className":[]},"children":[{"type":"text","value":"init.sh"}]},{"type":"text","value":" 脚本"}]},{"type":"element","tag":"td","props":{},"children":[{"type":"text","value":"会话开始就读 "},{"type":"element","tag":"code","props":{"className":[]},"children":[{"type":"text","value":"init.sh"}]}]}]}]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"见："},{"type":"element","tag":"a","props":{"href":"https://www.anthropic.com/engineering/effective-harnesses-for-long-running-agents","rel":["nofollow"]},"children":[{"type":"text","value":"Effective harnesses for long-running agents"}]},{"type":"text","value":"（Anthropic Engineering）"}]},{"type":"element","tag":"h4","props":{"id":"claude-agent-sdk-的核心设计原则"},"children":[{"type":"text","value":"Claude Agent SDK 的核心设计原则？"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"Claude Agent SDK（原 Claude Code SDK）的设计哲学是"},{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"给 Claude 一台计算机"}]},{"type":"text","value":"——让它能够使用程序员日常使用的工具（终端、文件系统、代码执行），从而像人类一样工作。"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"这不仅让 Claude 擅长编码，还能处理各种非编码任务：读取 CSV、搜索网页、构建可视化、解释指标等。核心反馈循环是："},{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"收集上下文 → 采取行动 → 验证工作 → 重复"}]},{"type":"text","value":"。"}]},{"type":"element","tag":"blockquote","props":{},"children":[{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"Over the past several months, Claude Code has become far more than a coding tool. At Anthropic, we've been using it for deep research, video creation, and note-taking, among countless other non-coding applications. In fact, it has begun to power almost all of our major agent loops.\n—— Anthropic"}]}]},{"type":"element","tag":"h4","props":{"id":"agent-如何有效收集上下文"},"children":[{"type":"text","value":"Agent 如何有效收集上下文？"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Agentic Search（代理式搜索）"}]},{"type":"text","value":"\n文件系统代表\"可能被拉入上下文\"的信息。Agent 使用 "},{"type":"element","tag":"code","props":{"className":[]},"children":[{"type":"text","value":"grep"}]},{"type":"text","value":"、"},{"type":"element","tag":"code","props":{"className":[]},"children":[{"type":"text","value":"tail"}]},{"type":"text","value":" 等 bash 脚本自主决定如何加载大文件（如日志）。文件夹结构本身成为一种上下文工程。"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Semantic Search（语义搜索）"}]},{"type":"text","value":"\n通常比代理式搜索更快，但准确性较低、维护更困难、透明度更低。建议先使用代理式搜索，仅在需要更快结果或更多变体时添加语义搜索。"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Subagents（子代理）"}]},{"type":"text","value":"\nSDK 默认支持子代理，有两个主要用途："}]},{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"并行化"}]},{"type":"text","value":"：同时启动多个子代理处理不同任务"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"上下文管理"}]},{"type":"text","value":"：子代理使用独立的上下文窗口，只返回相关信息给编排器"}]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Compaction（上下文压缩）"}]},{"type":"text","value":"\n当 Agent 长时间运行时，自动总结之前的消息以避免上下文耗尽。这是 Claude Code "},{"type":"element","tag":"code","props":{"className":[]},"children":[{"type":"text","value":"/compact"}]},{"type":"text","value":" 命令的底层能力。"}]},{"type":"element","tag":"h4","props":{"id":"agent-采取行动的关键方式"},"children":[{"type":"text","value":"Agent 采取行动的关键方式？"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Tools（工具）"}]},{"type":"text","value":"\n工具是 Agent 执行的主要构建块，在 Claude 的上下文窗口中非常突出。设计工具时要考虑上下文效率，将最频繁的操作定义为工具。"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Bash & Scripts"}]},{"type":"text","value":"\nBash 作为通用工具，让 Agent 能够灵活地使用计算机完成各种任务。例如：下载 PDF、转换为文本、搜索内容。"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Code Generation（代码生成）"}]},{"type":"text","value":"\n代码精确、可组合、无限复用，是 Agent 执行复杂操作的理想输出。Claude.AI 的文件创建功能完全依赖代码生成——用 Python 脚本创建 Excel、PPT、Word 文档。"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"MCPs（Model Context Protocol）"}]},{"type":"text","value":"\n提供与外部服务的标准化集成，自动处理认证和 API 调用。可快速连接 Slack、GitHub、Google Drive、Asana 等，无需编写自定义集成代码。"}]},{"type":"element","tag":"h4","props":{"id":"agent-如何验证工作质量"},"children":[{"type":"text","value":"Agent 如何验证工作质量？"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Defining Rules（定义规则）"}]},{"type":"text","value":"\n最佳反馈形式是提供清晰的输出规则，然后解释哪些规则失败及原因。代码 linting 是优秀的规则反馈——生成 TypeScript 比纯 JavaScript 更好，因为提供了额外的反馈层。"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Visual Feedback（视觉反馈）"}]},{"type":"text","value":"\n对于 UI 生成或测试等视觉任务，截图或渲染可以提供有价值的验证。检查布局、样式、内容层次、响应式表现等。使用 Playwright MCP 可以自动化此反馈循环。"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"LLM as a Judge"}]},{"type":"text","value":"\n让另一个语言模型基于模糊规则评判输出。这不是非常稳健的方法，且有较高的延迟代价，但在追求性能提升的应用中可能有帮助。"}]},{"type":"element","tag":"h4","props":{"id":"测试和改进-agent-的关键问题"},"children":[{"type":"text","value":"测试和改进 Agent 的关键问题？"}]},{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"如果 Agent 误解任务，是否缺少关键信息？能否调整搜索 API 结构？"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"如果 Agent 反复失败，能否在工具调用中添加正式规则来识别和修复？"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"如果 Agent 无法修复错误，能否提供更有用或更有创意的工具？"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"如果性能随功能增加而变化，能否基于客户使用构建代表性的测试集进行程序化评估？"}]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"见："},{"type":"element","tag":"a","props":{"href":"https://claude.com/blog/building-agents-with-the-claude-agent-sdk","rel":["nofollow"]},"children":[{"type":"text","value":"Building agents with the Claude Agent SDK"}]},{"type":"text","value":"（Claude 官方博客）"}]},{"type":"element","tag":"h2","props":{"id":"参考"},"children":[{"type":"text","value":"参考"}]},{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"a","props":{"href":"https://www.anthropic.com/engineering/building-effective-agents","rel":["nofollow"]},"children":[{"type":"text","value":"Building effective agents @Anthropic"}]}]},{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"a","props":{"href":"https://www.anthropic.com/engineering/multi-agent-research-system","rel":["nofollow"]},"children":[{"type":"text","value":"How we built our multi-agent research system"}]}]}]}],"toc":{"title":"","searchDepth":2,"depth":2,"links":[{"id":"domain","depth":2,"text":"Domain"},{"id":"deep-research","depth":2,"text":"Deep Research"},{"id":"protocol","depth":2,"text":"Protocol"},{"id":"goose","depth":2,"text":"Goose"},{"id":"多智能体框架","depth":2,"text":"多智能体框架"},{"id":"agent-sdk","depth":2,"text":"Agent SDK"},{"id":"agent-架构第一性原理","depth":2,"text":"Agent 架构第一性原理"},{"id":"参考","depth":2,"text":"参考"}]}},"_type":"markdown","_id":"content:6.maps:_ai:agents:agents.md","_source":"content","_file":"6.maps/_ai/agents/agents.md","_stem":"6.maps/_ai/agents/agents","_extension":"md"}