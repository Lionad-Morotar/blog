","props":{},"children":[{"type":"text","value":"Routing（路由）"}]},{"type":"text","value":"\n输入分类后路由到专门下游任务，分离关注点，构建更专业的提示。"}]},{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"适用：复杂任务有明确类别，分类可由 LLM 或传统模型处理"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"示例：客服查询按类型（一般问题/退款/技术支持）路由到不同流程"}]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Parallelization（并行化）"}]}]},{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Sectioning（分段）"}]},{"type":"text","value":"：任务拆分为独立子任务并行处理"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Voting（投票）"}]},{"type":"text","value":"：同一任务多次运行，聚合多样输出"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"适用：可并行提速，或需多视角/多次尝试提高置信度"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"示例：代码漏洞审查（多提示并行审查）、内容安全评估"}]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Orchestrator-workers（编排器-工作者）"}]},{"type":"text","value":"\n中心 LLM 动态分解任务，委派给工作 LLM，再综合结果。与并行的关键区别：子任务不是预定义的，而是由编排器根据输入动态决定。"}]},{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"适用：复杂任务无法预测子任务（如编码需修改的文件数量和性质取决于任务）"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"示例：多文件复杂代码修改、多源信息搜集分析"}]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Evaluator-optimizer（评估-优化）"}]},{"type":"text","value":"\n一个 LLM 生成响应，另一个提供评估反馈，循环迭代。"}]},{"type":"element","tag":"ul","props"