","depth":2,"text":"AutoGen"},{"id":"deepagents","depth":2,"text":"DeepAgents"},{"id":"crewai","depth":2,"text":"CrewAI"},{"id":"三框架对比","depth":2,"text":"三框架对比"},{"id":"elizaos","depth":2,"text":"ElizaOS"},{"id":"openai-swarm-agents-sdk","depth":2,"text":"OpenAI Swarm / Agents SDK"},{"id":"agentscope","depth":2,"text":"AgentScope"},{"id":"langgraph","depth":2,"text":"LangGraph"},{"id":"参考","depth":2,"text":"参考"}]}},"_type":"markdown","_id":"content:6.maps:_ai:agents:multi-agent-frameworks.md","_source":"content","_file":"6.maps/_ai/agents/multi-agent-frameworks.md","_stem":"6.maps/_ai/agents/multi-agent-frameworks","_extension":"md"}