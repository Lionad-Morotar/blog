/pricing/details/azure-openai/","rel":["nofollow"]},"children":[{"type":"text","value":"Azure OpenAI Service - Pricing"}]}]},{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"a","props":{"href":"https://aws.amazon.com/bedrock/pricing/","rel":["nofollow"]},"children":[{"type":"text","value":"Amazon Bedrock Pricing"}]}]},{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"a","props":{"href":"https://platform.openai.com/tokenizer","rel":["nofollow"]},"children":[{"type":"text","value":"OpenAI Tokenizer（估算 token / 成本）"}]}]},{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"a","props":{"href":"https://console.volcengine.com/ark/region:ark+cn-beijing/openManagement","rel":["nofollow"]},"children":[{"type":"text","value":"火山引擎 Ark 控制台"}]},{"type":"text","value":"：国内 LLM API 用量与订阅管理"}]}]},{"type":"element","tag":"h4","props":{"id":"benchmark"},"children":[{"type":"text","value":"Benchmark"}]},{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"a","props":{"href":"/maps/_ai/benchmark/benchmark"},"children":[{"type":"text","value":"LLM Benchmark"}]}]},{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"a","props":{"href":"/maps/_ai/benchmark/simple"},"children":[{"type":"text","value":"simple-benchmark"}]}]}]},{"type":"element","tag":"h4","props":{"id":"prompt"},"children":[{"type":"text","value":"Prompt"}]},{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"a","props":{"href":"/maps/_ai/prompt/prompt"},"children":[{"type":"text","value":"Prompt"}]}]},{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"a","props":{"href":"/maps/_ai/prompt/prompt-collections"},"children":[{"type":"text","value":"Prompt Collections"}]}]},{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"a","props":{"href":"/maps/_ai/image/stable-diffusion"},"children":[{"type":"text","value":"Stable Diffusion Prompt"}]}]}]},{"type":"element","tag":"h2","props":{"id":"核心概念"},"children":[{"type":"text","value":"核心概念"}]},{"type":"element","tag":"h4","props":{"id":"llm-训练的三阶段流程"},"children":[{"type":"text","value":"LLM 训练的三阶段流程？"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"预训练（Pre-training）"}]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"从互联网大规模获取知识，将海量文本压缩到神经网络参数中。使用 FineWeb 等数据集，通过\"预测下一个词\"的任务迫使模型学习世界知识。这是一个有损压缩过程——模型学到的是文本的\"格式塔\"而非精确复制。"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"监督微调（SFT）"}]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"通过人工标注的指令-回复对，教模型如何以助手的方式回应。OpenAI 等公司雇佣数据标注员，编写理想的助手回复示例。这是模型\"个性\"形成的关键阶段——模型本质上是数据标注员的神经网络模拟。"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"强化学习（RL）"}]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"思考型模型（如 o3-mini、o1）通过强化学习发现新的思考策略。在可验证领域（数学、代码）中练习时，模型可能发展出人类从未想过的解法，类似 AlphaGo 的\"第37手\"。这是模型超越单纯模仿、展现涌现能力的关键阶段。"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"见："},{"type":"element","tag":"a","props":{"href":"https://www.youtube.com/watch?v=bZQun8Y4L2A","rel":["nofollow"]},"children":[{"type":"text","value":"State of GPT - Andrej Karpathy"}]}]},{"type":"element","tag":"h4","props":{"id":"瑞士奶酪能力模型"},"children":[{"type":"text","value":"瑞士奶酪能力模型？"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"LLM 的能力分布像瑞士奶酪一样有洞——某些方面表现惊艳（写作、翻译、知识问答），却会在出人意料的简单任务上失败（计数字母、比较小数大小、简单算术）。"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"这种不均匀性源于："}]},{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"有限计算预算"}]},{"type":"text","value":"：每次生成 token 只能进行固定量的计算"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"有损压缩"}]},{"type":"text","value":"：模型学到的是统计模式而非精确规则"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"训练分布偏差"}]},{"type":"text","value":"：互联网文本中某些技能被过度/不足代表"}]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"这意味着不应盲目信任模型输出，尤其在需要精确性的场景。建议将 LLM 视为\"工具箱中的一员\"，用于灵感启发和初稿生成，但始终需要人工验证。"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"见："},{"type":"element","tag":"a","props":{"href":"https://www.youtube.com/watch?v=EWvNQjAaOHw","rel":["nofollow"]},"children":[{"type":"text","value":"How I use LLM - Andrej Karpathy"}]}]},{"type":"element","tag":"h2","props":{"id":"使用反思"},"children":[{"type":"text","value":"使用反思"}]},{"type":"element","tag":"h4","props":{"id":"即时知识获取的浅薄化代价"},"children":[{"type":"text","value":"即时知识获取的\"浅薄化\"代价"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"通过 LLM 获取知识消除了传统学习的\"摩擦\"——无需翻阅资料、无需追踪引用、无需建立知识间的连接。但这种便利带来了知识的\"零食化\"特质：从电池原理跳到汽车稳定杆再到加州公路，浅尝辄止，知识变得像社交媒体动态一样可丢弃。"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"学习的努力本是深度理解的必要过程。与花数周研究安倍晋三遇刺案、通过维基百科和日文资料层层追踪的体验相比——尽管没有获得明确答案，但建立了远更丰富的理解。品格和专业知识来自\"寻找信息的 hunt\"，而非摘要。"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"此外，一个根本性的使用困境是：你几乎无法发现幻觉，除非它涉及你已经掌握知识的领域。"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"见："},{"type":"element","tag":"a","props":{"href":"https://idiallo.com/blog/access-to-knowledge-is-no-longer-a-limitation","rel":["nofollow"]},"children":[{"type":"text","value":"When access to knowledge is no longer the limitation"}]}]}],"toc":{"title":"","searchDepth":2,"depth":2,"links":[{"id":"tour","depth":2,"text":"Tour"},{"id":"domain","depth":2,"text":"Domain"},{"id":"日志审计","depth":2,"text":"日志审计"},{"id":"常见问题","depth":2,"text":"常见问题"},{"id":"核心概念","depth":2,"text":"核心概念"},{"id":"使用反思","depth":2,"text":"使用反思"}]}},"_type":"markdown","_id":"content:6.maps:_ai:llm:llm.md","_source":"content","_file":"6.maps/_ai/llm/llm.md","_stem":"6.maps/_ai/llm/llm","_extension":"md"}