":"a","props":{"href":"/maps/_ai/framework/saif"},"children":[{"type":"text","value":"SAIF"}]}]}]},{"type":"element","tag":"h2","props":{"id":"workflow"},"children":[{"type":"text","value":"Workflow"}]},{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"a","props":{"href":"/maps/_ai/workflow/0.index"},"children":[{"type":"text","value":"开发工作流"}]}]}]},{"type":"element","tag":"h2","props":{"id":"training"},"children":[{"type":"text","value":"Training"}]},{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"a","props":{"href":"/maps/_ai/training/training"},"children":[{"type":"text","value":"AI Training"}]}]}]},{"type":"element","tag":"h2","props":{"id":"ai-的下半场"},"children":[{"type":"text","value":"AI 的下半场"}]},{"type":"element","tag":"h4","props":{"id":"从训练到评估的范式转移"},"children":[{"type":"text","value":"从训练到评估的范式转移"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"AI 发展进入\"下半场\"，核心特征是从\"训练大于评估\"转向\"评估大于训练\"。上半场通过反向传播、AlexNet、DQN、Transformer、GPT-3 等方法创新不断刷分；下半场需要重新定义问题，构建能衡量真实世界效用的评估体系。OpenAI 前研究员姚顺雨（Shunyu Yao）提出这一框架，认为当前 AI 在 MMLU、Codeforces 等基准上达到博士水平，却未能显著改变 GDP——核心矛盾在于评估设定追求\"难题\"，而真实价值在于\"实用\"。"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"见："},{"type":"element","tag":"a","props":{"href":"https://ysymyth.github.io/The-Second-Half/","rel":["nofollow"]},"children":[{"type":"text","value":"The Second Half - Shunyu Yao"}]}]},{"type":"element","tag":"h4","props":{"id":"ai-训练的标准配方"},"children":[{"type":"text","value":"AI 训练的标准配方"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"强化学习的通用配方由三要素构成：强大的语言先验（LLM）、支持推理的行动空间（将思考作为动作）、简单可扩展的算法。这一配方在数学推理（o1/o3）、计算机操作（Operator）等领域都被验证有效，意味着\"创造新基准比解决旧基准更有价值\"。"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"见："},{"type":"element","tag":"a","props":{"href":"https://arxiv.org/abs/2210.03629","rel":["nofollow"]},"children":[{"type":"text","value":"ReAct: Synergizing Reasoning and Acting in Language Models"}]}]},{"type":"element","tag":"h2","props":{"id":"行业动态"},"children":[{"type":"text","value":"行业动态"}]},{"type":"element","tag":"h4","props":{"id":"科技巨头的-ai-军备竞赛规模有多大"},"children":[{"type":"text","value":"科技巨头的 AI 军备竞赛规模有多大？"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"2026 年，亚马逊、谷歌、微软、Meta 和 Oracle 五大科技巨头的 AI 相关资本支出预计达 "},{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"7000 亿美元"}]},{"type":"text","value":"，相当于美国军费的约四分之三。如此巨额投入导致电工人才短缺，部分建筑项目被迫暂停。这一数据直观展示了 AI 热潮对实体经济的资源虹吸效应——AI 竞争已从技术竞争升级为国家级基础设施竞争。"}]},{"type":"element","tag":"blockquote","props":{},"children":[{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"#周刊摘录 见："},{"type":"element","tag":"a","props":{"href":"https://www.ruanyifeng.com/blog/2026/02/weekly-issue-385.html","rel":["nofollow"]},"children":[{"type":"text","value":"科技周刊第385期"}]}]}]},{"type":"element","tag":"h4","props":{"id":"知识产权的因果循环"},"children":[{"type":"text","value":"知识产权的因果循环"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"OpenAI 长期被指控未经授权使用艺术家和作家的作品训练模型，如今却反过来控诉 DeepSeek 通过「模型蒸馏」技术窃取自己的知识产权。这种「偷数据者抱怨被偷」的戏剧性反转，揭示了科技行业一个古老规律：当技术霸权者打破规则时，往往忘了规则也可能被用来对付自己。讽刺的是，OpenAI 曾游说政府要求版权豁免，如今却成为了自己最痛恨的「免费搭车者」的受害者。"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"见："},{"type":"element","tag":"a","props":{"href":"https://www.fdd.org/analysis/2026/02/13/openai-alleges-chinas-deepseek-stole-its-intellectual-property-to-train-its-own-models/","rel":["nofollow"]},"children":[{"type":"text","value":"OpenAI Alleges China's DeepSeek Stole its Intellectual Property"}]},{"type":"text","value":"、"},{"type":"element","tag":"a","props":{"href":"https://www.theguardian.com/books/2025/apr/04/us-authors-copyright-lawsuits-against-openai-and-microsoft-combined-in-new-york-with-newspaper-actions","rel":["nofollow"]},"children":[{"type":"text","value":"US authors' copyright lawsuits against OpenAI"}]}]},{"type":"element","tag":"h4","props":{"id":"远程操作的信任困境"},"children":[{"type":"text","value":"远程操作的信任困境"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"AI 行业将远程操作（teleoperation）包装成\"AI\"的现象正在侵蚀公众信任："}]},{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Amazon \"Just Walk Out\""}]},{"type":"text","value":"：号称 AI 驱动的无人收银，实际是印度团队手动审核监控录像完成结账"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Tesla Optimus"}]},{"type":"text","value":"：发布会展示机器人端酒、跳舞，Elon Musk 声称全自主 AI，后被揭露为远程操作"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"1X 机器人"}]},{"type":"text","value":"：$20,000 家用机器人 demo 中，操作者就在隔壁房间"}]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"远程操作本身的技术难度被忽视——实时控制双足机器人在人群中行走、完成精细动作需要低延迟通信、精准电机控制和优秀的操作界面，这些都是多年工程积累的成果。然而一旦被贴上\"AI\"标签，远程操作就变成了\"骗局\"的同义词，甚至 Waymo 也不得不公开辩护否认使用远程操作员。"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"远程操作在医疗（跨洲手术）、工业（危险环境作业）等领域本身就是核心价值，而非过渡方案。"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"见："},{"type":"element","tag":"a","props":{"href":"https://idiallo.com/blog/teleoperation-is-the-butt-of-the-joke","rel":["nofollow"]},"children":[{"type":"text","value":"Teleoperation is Always the Butt of the Joke"}]}]},{"type":"element","tag":"h2","props":{"id":"推荐系统"},"children":[{"type":"text","value":"推荐系统"}]},{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"a","props":{"href":"/maps/_ai/recommendation/recommendation-system"},"children":[{"