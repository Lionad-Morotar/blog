es/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133,"children":134},"造物 / Make","/tools",[135,137,140,143,146,149,152],{"title":136,"_path":133},"🧰 工具收集",{"title":138,"_path":139},"📕 博客","/tools/blog",{"title":141,"_path":142},"🥥 Coconut","/tools/coconut",{"title":144,"_path":145},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":147,"_path":148},"🌐 AnySort","/tools/anysort",{"title":150,"_path":151},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":153,"_path":154},"👓 Crapto","/tools/crypto-inline",{"title":156,"_path":157,"children":158},"我 / About","/hire",[159],{"title":160,"_path":157},"📬 技术简历",{"title":162,"_path":163,"children":164},"En","/en",[165],{"title":166,"_path":167,"children":168},"🦁 Welcome","/en/articles",[169],{"title":166,"_path":167},{"_path":171,"_dir":172,"_draft":173,"_partial":174,"_locale":175,"title":176,"description":175,"body":177,"_type":882,"_id":883,"_source":884,"_file":885,"_stem":886,"_extension":887},"/_achieved/2021-01/escape-from-mysticism","2021-01",false,true,"","💖 逃离虚无，再拥抱它",{"type":178,"children":179,"toc":871},"root",[180,201,207,213,219,224,229,234,239,244,249,254,259,264,269,274,279,284,289,294,299,304,320,325,330,335,340,345,350,356,362,367,376,381,496,501,506,511,516,521,526,536,541,559,564,577,590,603,608,613,618,623,628,639,644,777,782,800,805,813,818,861,866],{"type":181,"tag":182,"props":183,"children":184},"element","center",{},[185],{"type":181,"tag":186,"props":187,"children":189},"div",{"style":188},"margin-top: 1.5em; text-align: center;",[190,193],{"type":191,"value":192},"text","\n  ",{"type":181,"tag":194,"props":195,"children":200},"iframe",{"frameBorder":196,"border":197,"marginWidth":197,"marginHeight":197,"height":198,"src":199},"no",0,86,"//music.163.com/outchain/player?type=2&id=1391144474&auto=0&height=66",[],{"type":181,"tag":202,"props":203,"children":205},"h2",{"id":204},"虚无蛇环",[206],{"type":191,"value":204},{"type":181,"tag":208,"props":209,"children":210},"p",{},[211],{"type":191,"value":212},"许多人都说 2020 年非常魔幻，我也认同，不过在我距疫情时隔一年后，坐在书桌前静静思索在 20 年 2 月底时的裸辞，恍然觉得自己才是魔幻本幻呐！那时候，年终奖买了一些大件，支付宝里就剩了二月份的工资。于是过上了点外卖都要抢着红包精打细算一番的日子。钱自然是一分不多，时间倒是挺自由的，这种时间自由的空档期，一空，就空到了九月份。",{"type":181,"tag":214,"props":215,"children":217},"h3",{"id":216},"交易",[218],{"type":191,"value":216},{"type":181,"tag":208,"props":220,"children":221},{},[222],{"type":191,"value":223},"一切还得从 19 年 7 月份说起。",{"type":181,"tag":208,"props":225,"children":226},{},[227],{"type":191,"value":228},"19 年 7 月，我从实习公司离开，开始了我的“完美暑假计划”。读书弹琴打豆豆，吃好喝好睡觉觉。不过好日子不长久，八月份钱包就见空了，被迫提前结束暑假。那会儿我还在吃技术老本找工作，海投了一波，找了一家薪资靠谱的公司就想入职了。",{"type":181,"tag":208,"props":230,"children":231},{},[232],{"type":191,"value":233},"面试的时候，我问主管：“这边上下班一般几点钟呀？”",{"type":181,"tag":208,"props":235,"children":236},{},[237],{"type":191,"value":238},"他回答我的时候眼睛都没眨一下，“我们这早上不打卡，反正大家相差那二十分钟没啥关系，晚上没事儿七点就下班了，要是有啥事儿你下午四五点可以直接走，和我说声就好。”",{"type":181,"tag":208,"props":240,"children":241},{},[242],{"type":191,"value":243},"嚯，听起来还不错哈？原本我一直认为七点下班算是挺晚的，但是冲着早上不打卡这个制度就可以冲了！就算七点下班不太能准时走，不过我卖时间，拿钱，学技术，缺失也没啥不好的。",{"type":181,"tag":208,"props":245,"children":246},{},[247],{"type":191,"value":248},"本以为接这个 offer 是个不错的决定，后来啊，心态慢慢发生了变化。..",{"type":181,"tag":214,"props":250,"children":252},{"id":251},"代价",[253],{"type":191,"value":251},{"type":181,"tag":208,"props":255,"children":256},{},[257],{"type":191,"value":258},"我是一个有技术崇拜倾向的人，但同时也是一个活在真空里的人。换句话说，我相信技术能解决一切问题，并从中获得充足的成就感，前提是要先找到做事的意义。",{"type":181,"tag":208,"props":260,"children":261},{},[262],{"type":191,"value":263},"很遗憾，在这家公司我并没有找到我的价值。绝对的业务导向没有留给开发人员安排任何思考时间，每天 10：00 - 21：00 持续的代码堆量没有给我带来技术成长。同时，疲软的产品经理和设计十分让我灰心，页面三天两头就推倒重来，委实令人难过。不能找到价值，更不可能能找到工作的成就感。我满载了技术崇拜的小心脏中，热情在迅速冷却。",{"type":181,"tag":208,"props":265,"children":266},{},[267],{"type":191,"value":268},"个人价值上亦然，每天晚上九点才能走的软加班制度耗尽了我的个人时间，我满心鄙夷软件行业不为大众所知地暗面。",{"type":181,"tag":208,"props":270,"children":271},{},[272],{"type":191,"value":273},"钱和个人时间相较，我逐渐意识到，钱只是钱，个人时间却是财富。我需要用个人时间，而不是工作时间，去塑造自我。个人时间可以短暂地把“自我”从“世界”中划开，并在两者间建一座桥，又不中断其联系。作为独立的人，我们都会有自己的个性、追求和理想。这些东西并不刻在基因里，可以通过行为改变，但需要时间积累。",{"type":181,"tag":208,"props":275,"children":276},{},[277],{"type":191,"value":278},"年后，公司正式迁址到浦东，我每天需要花费更多通勤时间。要么搬迁，要么离开。愉快地二选一。带着一点小小的报复心理，提离职时，我也是眼睛都没眨一下。",{"type":181,"tag":214,"props":280,"children":282},{"id":281},"堕入",[283],{"type":191,"value":281},{"type":181,"tag":208,"props":285,"children":286},{},[287],{"type":191,"value":288},"假使潜伏在 QQ 群摸鱼不算社交的话，那辞职后的六个月我约等于零社交。",{"type":181,"tag":208,"props":290,"children":291},{},[292],{"type":191,"value":293},"零社交状态应该怎么形容呢？我想起前阵子有人和我说他想做一个小程序，用来看看附近有什么聚会呀活动啊之类的东西，然后用户可以选择性报名参与。我第一反应居然是觉得奇怪，“参与聚会是一件让你兴奋的事儿么？”",{"type":181,"tag":208,"props":295,"children":296},{},[297],{"type":191,"value":298},"“当然啦，你不觉得和人交流非常愉快吗？”",{"type":181,"tag":208,"props":300,"children":301},{},[302],{"type":191,"value":303},"“我喜欢安静点吧。可能大部分人都能从与人交流中获得乐趣，我也能，但交流本身需要消耗精力。我可能更愿意把自己投射到网络中，一个虚拟的载体里，用载体展示自我以及与人交流。载体不用与人建立过分亲密的关系，这很好，因为我可能随时因为社交精力耗尽，网络连接被迫中断。”",{"type":181,"tag":208,"props":305,"children":306},{},[307,309,318],{"type":191,"value":308},"总之第二个“完美暑假计划”开始了。在这个“暑假”，我的载体去了美国，此外，我把所有自由时间都投入到 ",{"type":181,"tag":310,"props":311,"children":315},"a",{"href":312,"rel":313},"https://search.bilibili.com/all?keyword=%E9%80%83%E7%A6%BB%E5%A1%94%E7%A7%91%E5%A4%AB&from_source=nav_suggest_new&order=dm&duration=0&tids_1=0",[314],"nofollow",[316],{"type":191,"value":317},"《逃离塔科夫》",{"type":191,"value":319}," 中，估摸着六个月有超过了 500 小时游玩记录。",{"type":181,"tag":208,"props":321,"children":322},{},[323],{"type":191,"value":324},"这简直是一种自断后路的生活方式。不出意外的话，我终究会被沉重的现实物理暴击后回到三次元来，不过这次打断我暑期计划的不是没钱了，而是一次半夜睡醒，想爬起来打开落地窗透透气的时候，直接两眼一黑，摔在了地上。",{"type":181,"tag":208,"props":326,"children":327},{},[328],{"type":191,"value":329},"醒来时第一件事是确认自己有没有变傻，这之后脑海里只剩下“虚无”两个大字。",{"type":181,"tag":214,"props":331,"children":333},{"id":332},"和解",[334],{"type":191,"value":332},{"type":181,"tag":208,"props":336,"children":337},{},[338],{"type":191,"value":339},"逃离，我称之为跳脱，其实非常简单。每个人的生活都存在惯性，只要意识到这种惯性，你就能开始着手改变。一旦车辙的角度发生微妙变化，马车就会带着人们跳脱出现有的圈子。马车会一直跑，跑出新的轨迹，使得生活绕进一种新的惯性里。",{"type":181,"tag":208,"props":341,"children":342},{},[343],{"type":191,"value":344},"我并不厌恶虚无，只是需要找到如何定义个人时间价值的答案。我退出了接单的 QQ 群，尝试把所有技术都捡起来，一边在重构自己的博客，也一边重整一下自己的知识体系。又是一年八月，我重新开始了找工作的旅途，一如既往地写简历以及海投；九月初，终于有了合适的坑。",{"type":181,"tag":208,"props":346,"children":347},{},[348],{"type":191,"value":349},"我从来不会因为喜好孤独而愧疚，我反而觉得这是一种极大的优势，让自己能花时间做想做的事。虚无感正是用来检验自己前进方向是否正确的指南针。我相信大部分人欠缺的不是天赋，也不是努力，而是一种方向，一种自省力，一种让自己找到和地球、和宇宙万物共鸣的频率。",{"type":181,"tag":202,"props":351,"children":353},{"id":352},"_2021",[354],{"type":191,"value":355},"2021",{"type":181,"tag":357,"props":358,"children":360},"h4",{"id":359},"技术写作",[361],{"type":191,"value":359},{"type":181,"tag":208,"props":363,"children":364},{},[365],{"type":191,"value":366},"19 年 3 月份左右，我开始有意识的把自己写的代码和平时的思考整理为博客。",{"type":181,"tag":208,"props":368,"children":369},{},[370],{"type":181,"tag":371,"props":372,"children":375},"img",{"alt":373,"src":374},"橙色心脏","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20210104021646.png",[],{"type":181,"tag":208,"props":377,"children":378},{},[379],{"type":191,"value":380},"19 年时不知道应该怎么找题材，只写了零散的几篇。20 年时，逐渐写开了，除了技术博客，还写小诗、碎碎念、议论文之类的东西，基本每个月都有输出：",{"type":181,"tag":382,"props":383,"children":384},"ul",{},[385,397,407,417,427,438,447,457,467,477,487],{"type":181,"tag":386,"props":387,"children":388},"li",{},[389,395],{"type":181,"tag":310,"props":390,"children":392},{"href":391},"/_achieved/2020-04/9-css-chart",[393],{"type":191,"value":394},"《🍥 9 种纯 CSS 图案》",{"type":191,"value":396},"（⭐⭐）",{"type":181,"tag":386,"props":398,"children":399},{},[400,405],{"type":181,"tag":310,"props":401,"children":402},{"href":85},[403],{"type":191,"value":404},"《❓ 你可以用纯 CSS 判断鼠标进入的方向吗？》",{"type":191,"value":406},"（⭐⭐⭐⭐）",{"type":181,"tag":386,"props":408,"children":409},{},[410,415],{"type":181,"tag":310,"props":411,"children":412},{"href":82},[413],{"type":191,"value":414},"《💫 CSS 幻术 | 抗锯齿》",{"type":191,"value":416},"（⭐⭐⭐⭐⭐）",{"type":181,"tag":386,"props":418,"children":419},{},[420,426],{"type":181,"tag":310,"props":421,"children":423},{"href":422},"/_achieved/2020-06/zebra-puzzle",[424],{"type":191,"value":425},"《🎉 斑马难题解法》",{"type":191,"value":396},{"type":181,"tag":386,"props":428,"children":429},{},[430,436],{"type":181,"tag":310,"props":431,"children":433},{"href":432},"/maps/_frontend/css/css-mind-map",[434],{"type":191,"value":435},"《🎉 CSS Mind Map》",{"type":191,"value":437},"（⭐⭐⭐）",{"type":181,"tag":386,"props":439,"children":440},{},[441,446],{"type":181,"tag":310,"props":442,"children":443},{"href":76},[444],{"type":191,"value":445},"《🍲 设计模式与 JS 魔法锅》",{"type":191,"value":406},{"type":181,"tag":386,"props":448,"children":449},{},[450,456],{"type":181,"tag":310,"props":451,"children":453},{"href":452},"/maps/_frontend/javascript/javascript-mind-map",[454],{"type":191,"value":455},"《🎉 JavaScript Mind Map》",{"type":191,"value":437},{"type":181,"tag":386,"props":458,"children":459},{},[460,466],{"type":181,"tag":310,"props":461,"children":463},{"href":462},"/_achieved/2020-08/helmet-and-security",[464],{"type":191,"value":465},"《👑 Helmet & Security》",{"type":191,"value":437},{"type":181,"tag":386,"props":468,"children":469},{},[470,476],{"type":181,"tag":310,"props":471,"children":473},{"href":472},"/flows/_forty-two/dark-room",[474],{"type":191,"value":475},"《📕 四十二篇 | 有关新项目的方法论》",{"type":191,"value":406},{"type":181,"tag":386,"props":478,"children":479},{},[480,486],{"type":181,"tag":310,"props":481,"children":483},{"href":482},"/_achieved/2020-12/js-100",[484],{"type":191,"value":485},"《🏆 学习 JS，从忍者到杀手》",{"type":191,"value":416},{"type":181,"tag":386,"props":488,"children":489},{},[490,495],{"type":181,"tag":310,"props":491,"children":492},{"href":31},[493],{"type":191,"value":494},"《🥛 新工作，喝新饮料》",{"type":191,"value":406},{"type":181,"tag":208,"props":497,"children":498},{},[499],{"type":191,"value":500},"2021 年希望能在写作方面常写、常进步吧。以前听别人说，“写作其实是与读者的交流，所以你需要用简单直接的语言”，我也找来几本写作技巧的书学习，书中也表达了类似的观点。2021 年的新目标是在写技术博客的同时，用目前所学的内容改一遍以前写的内容，修正错误，精进表达。",{"type":181,"tag":208,"props":502,"children":503},{},[504],{"type":191,"value":505},"我的技术写作的最终目标是为了写“严肃的作品”，实话说打心底我并不喜欢口语化的表达，并认同习惯口语化的表达后会丢失原有的风格，所以并没有刻意练习向口语化的文风靠拢。至于这样到底好不好，有待验证。",{"type":181,"tag":357,"props":507,"children":509},{"id":508},"基础技术",[510],{"type":191,"value":508},{"type":181,"tag":208,"props":512,"children":513},{},[514],{"type":191,"value":515},"主要说三个点。第一是今年我找到了一个长期的乐子——看规范——ECMAScript 规范。由于 2020 年学习内容有限，输出也很有限。目前来看，看规范对提升我的技术深度或广度都没有很直接的帮助，但它是我的兴趣点，是我的个人选择，也是我以后突破技术瓶颈的（部分）切入点，所以我不在乎投入的时间和当前的投入产出比。",{"type":181,"tag":208,"props":517,"children":518},{},[519],{"type":191,"value":520},"七月份整理 JS 基础知识时，我比较浅显的读过 ES6 规范部分章节，了解了 JS 这门语言是怎么被“描述的”。看规范那会儿花了很多时间找资料，靠肝，把问题熬过去，简直是心力交瘁。后面也意识到需要找一个稳定的、高质量的前端交流圈，来帮自己借力。也许加入头部公司、参加线下活动、参与开源项目都是不错的方法。",{"type":181,"tag":208,"props":522,"children":523},{},[524],{"type":191,"value":525},"以下是一篇用于测试你了解多少 JavaScript 语言细节熟练度的博客，仅供娱乐：",{"type":181,"tag":382,"props":527,"children":528},{},[529],{"type":181,"tag":386,"props":530,"children":531},{},[532],{"type":181,"tag":310,"props":533,"children":534},{"href":482},[535],{"type":191,"value":485},{"type":181,"tag":208,"props":537,"children":538},{},[539],{"type":191,"value":540},"在此列一下 2021 相关语言规范能力的新年目标：",{"type":181,"tag":382,"props":542,"children":543},{},[544,549,554],{"type":181,"tag":386,"props":545,"children":546},{},[547],{"type":191,"value":548},"钻研绿宝书，即《JS 语言精髓与编程实践》，这是头等大事。",{"type":181,"tag":386,"props":550,"children":551},{},[552],{"type":191,"value":553},"通读 ES6 规范，使用脑图加深印象，并尝试理解语言细节背后的原理。",{"type":181,"tag":386,"props":555,"children":556},{},[557],{"type":191,"value":558},"通过 RSS 逛 TC39 相关社区，保持关注。",{"type":181,"tag":208,"props":560,"children":561},{},[562],{"type":191,"value":563},"二是年中的时候浅显地过过一遍 CSS 基础，但感觉不过瘾。21 年需要系统地重新学习一下。",{"type":181,"tag":382,"props":565,"children":566},{},[567,572],{"type":181,"tag":386,"props":568,"children":569},{},[570],{"type":191,"value":571},"《CSS 权威指南第四版》",{"type":181,"tag":386,"props":573,"children":574},{},[575],{"type":191,"value":576},"《浏览器工作原理与实践》，由于内容太多了，不打算全部看完，主要看相关 HTML、CSS 的部分。",{"type":181,"tag":208,"props":578,"children":579},{},[580,582,588],{"type":191,"value":581},"三是今年习惯了阅读源码。总结来看，由于缺乏规划，一些教大型的库没有办法坚持看下去。再是受能力限制，看源码还停留在“语义”和“解决问题”层面，没能有效输出 ",{"type":181,"tag":310,"props":583,"children":585},{"href":584},"/source-code",[586],{"type":191,"value":587},"笔记",{"type":191,"value":589},"，更别说博客了。暂时没有啥解决方法，目前也几乎是瞎摸前进。",{"type":181,"tag":382,"props":591,"children":592},{},[593,598],{"type":181,"tag":386,"props":594,"children":595},{},[596],{"type":191,"value":597},"读完 ElementUI 库源码，从项目架构到组件写法都要做到“掌握”。",{"type":181,"tag":386,"props":599,"children":600},{},[601],{"type":191,"value":602},"配合《深入浅出 VueJS》通读 Vue2 核心代码，仿造一个小模型。",{"type":181,"tag":208,"props":604,"children":605},{},[606],{"type":191,"value":607},"其它和前端水平相关的技术在此略过，不期望有太多进展，所以不下放精力。",{"type":181,"tag":357,"props":609,"children":611},{"id":610},"阅读消遣",[612],{"type":191,"value":610},{"type":181,"tag":208,"props":614,"children":615},{},[616],{"type":191,"value":617},"阅读是从去年开始我就一直在坚持做的事儿，并且是将它放到了所有 Todo List 的开头。无论是技术还是非技术，我都尝试通过阅读来打开自己的边界。",{"type":181,"tag":208,"props":619,"children":620},{},[621],{"type":191,"value":622},"大致有两种形式的阅读，一种是碎片化阅读，用 RSS 订阅喜欢的源，五分钟十分钟就能看完一篇文章；另一种则较传统，比如纸书电子书这种。",{"type":181,"tag":208,"props":624,"children":625},{},[626],{"type":191,"value":627},"后者这种形式，我会使用豆瓣跟踪我的阅读进度。2020 年纸书的进度基本上保持每周一本，总阅读数量 52，和去年持平。年末的时候，我整理了一下五星推荐书目，并写了简短的几行推荐，可以参考这篇博客：",{"type":181,"tag":382,"props":629,"children":630},{},[631],{"type":181,"tag":386,"props":632,"children":633},{},[634],{"type":181,"tag":310,"props":635,"children":636},{"href":10},[637],{"type":191,"value":638},"《📕 2020 | 仿生狮子荐书五本》",{"type":181,"tag":208,"props":640,"children":641},{},[642],{"type":191,"value":643},"完整的五星推荐列表见下，各位可以取自己需要的加书单啦。",{"type":181,"tag":382,"props":645,"children":646},{},[647,657,667,677,687,697,707,717,727,737,747,757,767],{"type":181,"tag":386,"props":648,"children":649},{},[650],{"type":181,"tag":310,"props":651,"children":654},{"href":652,"rel":653},"https://book.douban.com/subject/28524769/",[314],[655],{"type":191,"value":656},"《JavaScript 之美》",{"type":181,"tag":386,"props":658,"children":659},{},[660],{"type":181,"tag":310,"props":661,"children":664},{"href":662,"rel":663},"https://book.douban.com/subject/24760695/",[314],[665],{"type":191,"value":666},"《奔跑吧，梅勒斯》",{"type":181,"tag":386,"props":668,"children":669},{},[670],{"type":181,"tag":310,"props":671,"children":674},{"href":672,"rel":673},"https://book.douban.com/subject/34995610/",[314],[675],{"type":191,"value":676},"《八百万种死法》",{"type":181,"tag":386,"props":678,"children":679},{},[680],{"type":181,"tag":310,"props":681,"children":684},{"href":682,"rel":683},"https://book.douban.com/subject/25881855/",[314],[685],{"type":191,"value":686},"《大教堂与集市》",{"type":181,"tag":386,"props":688,"children":689},{},[690],{"type":181,"tag":310,"props":691,"children":694},{"href":692,"rel":693},"https://book.douban.com/subject/27115714/",[314],[695],{"type":191,"value":696},"《大雪将至》",{"type":181,"tag":386,"props":698,"children":699},{},[700],{"type":181,"tag":310,"props":701,"children":704},{"href":702,"rel":703},"https://book.douban.com/subject/27624039/",[314],[705],{"type":191,"value":706},"《田中一光自传》",{"type":181,"tag":386,"props":708,"children":709},{},[710],{"type":181,"tag":310,"props":711,"children":714},{"href":712,"rel":713},"https://book.douban.com/subject/24872498/",[314],[715],{"type":191,"value":716},"《乞力马扎罗山的雪》",{"type":181,"tag":386,"props":718,"children":719},{},[720],{"type":181,"tag":310,"props":721,"children":724},{"href":722,"rel":723},"https://book.douban.com/subject/26319730/",[314],[725],{"type":191,"value":726},"《娱乐至死》",{"type":181,"tag":386,"props":728,"children":729},{},[730],{"type":181,"tag":310,"props":731,"children":734},{"href":732,"rel":733},"https://book.douban.com/subject/26905096/",[314],[735],{"type":191,"value":736},"《治字百方》",{"type":181,"tag":386,"props":738,"children":739},{},[740],{"type":181,"tag":310,"props":741,"children":744},{"href":742,"rel":743},"https://book.douban.com/subject/27109961/",[314],[745],{"type":191,"value":746},"《瓦尔登湖》",{"type":181,"tag":386,"props":748,"children":749},{},[750],{"type":181,"tag":310,"props":751,"children":754},{"href":752,"rel":753},"https://book.douban.com/subject/10749924/",[314],[755],{"type":191,"value":756},"《天真的和感伤的小说家》",{"type":181,"tag":386,"props":758,"children":759},{},[760],{"type":181,"tag":310,"props":761,"children":764},{"href":762,"rel":763},"https://book.douban.com/subject/27114628/",[314],[765],{"type":191,"value":766},"《巴黎评论•短篇小说课堂》",{"type":181,"tag":386,"props":768,"children":769},{},[770],{"type":181,"tag":310,"props":771,"children":774},{"href":772,"rel":773},"https://book.douban.com/subject/27002046/",[314],[775],{"type":191,"value":776},"《美丽新世界》",{"type":181,"tag":208,"props":778,"children":779},{},[780],{"type":191,"value":781},"可能和常人不同，我没啥功利心，只是单纯把读书当作消遣（这样也好骗骗自己多看几本书）。话是这么说，内心老是怀疑这样看书浪费资源，所以希望 2021 年能探索一下如何提高知识的利用率。比方说，看技术书肯定是要边看边实践，同时输出笔记，方面以后快速参考；文学类书那就是查查资料，写写书评咯。.. 才疏学浅，没啥可说的，直接立目标吧：",{"type":181,"tag":382,"props":783,"children":784},{},[785,790,795],{"type":181,"tag":386,"props":786,"children":787},{},[788],{"type":191,"value":789},"学习《金字塔原理》，这本书倒是挺多人推荐的，相关思考本身的方法论。",{"type":181,"tag":386,"props":791,"children":792},{},[793],{"type":191,"value":794},"看完主流神话及圣经，了解“神秘主义”。",{"type":181,"tag":386,"props":796,"children":797},{},[798],{"type":191,"value":799},"形成一种固定的记笔记的方式。要先固定下方式来才能做出“记笔记是否能提高知识利用率”的对比。",{"type":181,"tag":208,"props":801,"children":802},{},[803],{"type":191,"value":804},"至于 RSS，经过一年多的积累，逐渐形成了极具个人风格的订阅内容。",{"type":181,"tag":208,"props":806,"children":807},{},[808],{"type":181,"tag":371,"props":809,"children":812},{"alt":810,"src":811},"我的订阅","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20210104154225.png",[],{"type":181,"tag":208,"props":814,"children":815},{},[816],{"type":191,"value":817},"这里简单推荐介绍一下我的分类思路，也推荐一些质量不错的源：",{"type":181,"tag":382,"props":819,"children":820},{},[821,826,831,836,841,846,851,856],{"type":181,"tag":386,"props":822,"children":823},{},[824],{"type":191,"value":825},"🚀 新鲜玩意：我的 GitHub 动态、CSS current work、ECMAScript Daily...",{"type":181,"tag":386,"props":827,"children":828},{},[829],{"type":191,"value":830},"💻 技术博客：奇舞周刊、前端早读课、前端之巅、张鑫旭的博客。..",{"type":181,"tag":386,"props":832,"children":833},{},[834],{"type":191,"value":835},"🎨 设计体验：HeyDesigner、优设网、Awwwards...",{"type":181,"tag":386,"props":837,"children":838},{},[839],{"type":191,"value":840},"🛸 游戏玩家：游研社、触乐、Indienova...",{"type":181,"tag":386,"props":842,"children":843},{},[844],{"type":191,"value":845},"📚 书和豆瓣：豆瓣最受欢迎的书评、图灵教育、mLook...",{"type":181,"tag":386,"props":847,"children":848},{},[849],{"type":191,"value":850},"🃏 软件分享：少数派、小众软件、数码荔枝。..",{"type":181,"tag":386,"props":852,"children":853},{},[854],{"type":191,"value":855},"🌮 生活日常：丁香医生、知乎日报。..",{"type":181,"tag":386,"props":857,"children":858},{},[859],{"type":191,"value":860},"...",{"type":181,"tag":208,"props":862,"children":863},{},[864],{"type":191,"value":865},"总共一百五十个源，目前每天只能看完 50% 左右的新文章，看不完的只有周末晚上找个时间全部倒进垃圾箱咯。",{"type":181,"tag":208,"props":867,"children":868},{},[869],{"type":191,"value":870},"说到这里吧，祝万事胜意。",{"title":175,"searchDepth":872,"depth":872,"links":873},2,[874,881],{"id":204,"depth":872,"text":204,"children":875},[876,878,879,880],{"id":216,"depth":877,"text":216},3,{"id":251,"depth":877,"text":251},{"id":281,"depth":877,"text":281},{"id":332,"depth":877,"text":332},{"id":352,"depth":872,"text":355},"markdown","content:_achieved:2021-01:escape-from-mysticism.md","content","_achieved/2021-01/escape-from-mysticism.md","_achieved/2021-01/escape-from-mysticism","md",[889,893],{"_path":890,"title":891,"description":892},"/_achieved/2021-01/anysort-1th","🌐 Anysort：灵活、优雅、无依赖的排序库","网易云音乐的歌单排序功能比较弱，本文介绍了使用函数式JS代码搭建一个自定义排序库的思路，以支持对歌单进行任意排序。",{"_path":894,"title":895,"description":896},"/_achieved/2021-01/the-art-of-mysticism","🎨 神秘主义的艺术","阿兰﹒德波顿在《艺术的慰藉》中把艺术视作一种用于弥补人的弱点的工具。他认为人能通过艺术作品找到作品与自我的相关性，从而进一步认识自己；艺术给人带来精神上慰藉，使人学会欣赏爱与美德，并驱使他们不断向这种不流于世俗的更高的精神层次靠拢。",1771214919431]