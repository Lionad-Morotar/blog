es/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":178,"body":180,"_type":885,"_id":886,"_source":887,"_file":888,"_stem":889,"_extension":890},"/_achieved/2021-01/escape-from-mysticism","2021-01",false,true,"","💖 逃离虚无，再拥抱它",{"type":181,"children":182,"toc":874},"root",[183,204,210,216,222,227,232,237,242,247,252,257,262,267,272,277,282,287,292,297,302,307,323,328,333,338,343,348,353,359,365,370,379,384,499,504,509,514,519,524,529,539,544,562,567,580,593,606,611,616,621,626,631,642,647,780,785,803,808,816,821,864,869],{"type":184,"tag":185,"props":186,"children":187},"element","center",{},[188],{"type":184,"tag":189,"props":190,"children":192},"div",{"style":191},"margin-top: 1.5em; text-align: center;",[193,196],{"type":194,"value":195},"text","\n  ",{"type":184,"tag":197,"props":198,"children":203},"iframe",{"frameBorder":199,"border":200,"marginWidth":200,"marginHeight":200,"height":201,"src":202},"no",0,86,"//music.163.com/outchain/player?type=2&id=1391144474&auto=0&height=66",[],{"type":184,"tag":205,"props":206,"children":208},"h2",{"id":207},"虚无蛇环",[209],{"type":194,"value":207},{"type":184,"tag":211,"props":212,"children":213},"p",{},[214],{"type":194,"value":215},"许多人都说 2020 年非常魔幻，我也认同，不过在我距疫情时隔一年后，坐在书桌前静静思索在 20 年 2 月底时的裸辞，恍然觉得自己才是魔幻本幻呐！那时候，年终奖买了一些大件，支付宝里就剩了二月份的工资。于是过上了点外卖都要抢着红包精打细算一番的日子。钱自然是一分不多，时间倒是挺自由的，这种时间自由的空档期，一空，就空到了九月份。",{"type":184,"tag":217,"props":218,"children":220},"h3",{"id":219},"交易",[221],{"type":194,"value":219},{"type":184,"tag":211,"props":223,"children":224},{},[225],{"type":194,"value":226},"一切还得从 19 年 7 月份说起。",{"type":184,"tag":211,"props":228,"children":229},{},[230],{"type":194,"value":231},"19 年 7 月，我从实习公司离开，开始了我的“完美暑假计划”。读书弹琴打豆豆，吃好喝好睡觉觉。不过好日子不长久，八月份钱包就见空了，被迫提前结束暑假。那会儿我还在吃技术老本找工作，海投了一波，找了一家薪资靠谱的公司就想入职了。",{"type":184,"tag":211,"props":233,"children":234},{},[235],{"type":194,"value":236},"面试的时候，我问主管：“这边上下班一般几点钟呀？”",{"type":184,"tag":211,"props":238,"children":239},{},[240],{"type":194,"value":241},"他回答我的时候眼睛都没眨一下，“我们这早上不打卡，反正大家相差那二十分钟没啥关系，晚上没事儿七点就下班了，要是有啥事儿你下午四五点可以直接走，和我说声就好。”",{"type":184,"tag":211,"props":243,"children":244},{},[245],{"type":194,"value":246},"嚯，听起来还不错哈？原本我一直认为七点下班算是挺晚的，但是冲着早上不打卡这个制度就可以冲了！就算七点下班不太能准时走，不过我卖时间，拿钱，学技术，缺失也没啥不好的。",{"type":184,"tag":211,"props":248,"children":249},{},[250],{"type":194,"value":251},"本以为接这个 offer 是个不错的决定，后来啊，心态慢慢发生了变化。..",{"type":184,"tag":217,"props":253,"children":255},{"id":254},"代价",[256],{"type":194,"value":254},{"type":184,"tag":211,"props":258,"children":259},{},[260],{"type":194,"value":261},"我是一个有技术崇拜倾向的人，但同时也是一个活在真空里的人。换句话说，我相信技术能解决一切问题，并从中获得充足的成就感，前提是要先找到做事的意义。",{"type":184,"tag":211,"props":263,"children":264},{},[265],{"type":194,"value":266},"很遗憾，在这家公司我并没有找到我的价值。绝对的业务导向没有留给开发人员安排任何思考时间，每天 10：00 - 21：00 持续的代码堆量没有给我带来技术成长。同时，疲软的产品经理和设计十分让我灰心，页面三天两头就推倒重来，委实令人难过。不能找到价值，更不可能能找到工作的成就感。我满载了技术崇拜的小心脏中，热情在迅速冷却。",{"type":184,"tag":211,"props":268,"children":269},{},[270],{"type":194,"value":271},"个人价值上亦然，每天晚上九点才能走的软加班制度耗尽了我的个人时间，我满心鄙夷软件行业不为大众所知地暗面。",{"type":184,"tag":211,"props":273,"children":274},{},[275],{"type":194,"value":276},"钱和个人时间相较，我逐渐意识到，钱只是钱，个人时间却是财富。我需要用个人时间，而不是工作时间，去塑造自我。个人时间可以短暂地把“自我”从“世界”中划开，并在两者间建一座桥，又不中断其联系。作为独立的人，我们都会有自己的个性、追求和理想。这些东西并不刻在基因里，可以通过行为改变，但需要时间积累。",{"type":184,"tag":211,"props":278,"children":279},{},[280],{"type":194,"value":281},"年后，公司正式迁址到浦东，我每天需要花费更多通勤时间。要么搬迁，要么离开。愉快地二选一。带着一点小小的报复心理，提离职时，我也是眼睛都没眨一下。",{"type":184,"tag":217,"props":283,"children":285},{"id":284},"堕入",[286],{"type":194,"value":284},{"type":184,"tag":211,"props":288,"children":289},{},[290],{"type":194,"value":291},"假使潜伏在 QQ 群摸鱼不算社交的话，那辞职后的六个月我约等于零社交。",{"type":184,"tag":211,"props":293,"children":294},{},[295],{"type":194,"value":296},"零社交状态应该怎么形容呢？我想起前阵子有人和我说他想做一个小程序，用来看看附近有什么聚会呀活动啊之类的东西，然后用户可以选择性报名参与。我第一反应居然是觉得奇怪，“参与聚会是一件让你兴奋的事儿么？”",{"type":184,"tag":211,"props":298,"children":299},{},[300],{"type":194,"value":301},"“当然啦，你不觉得和人交流非常愉快吗？”",{"type":184,"tag":211,"props":303,"children":304},{},[305],{"type":194,"value":306},"“我喜欢安静点吧。可能大部分人都能从与人交流中获得乐趣，我也能，但交流本身需要消耗精力。我可能更愿意把自己投射到网络中，一个虚拟的载体里，用载体展示自我以及与人交流。载体不用与人建立过分亲密的关系，这很好，因为我可能随时因为社交精力耗尽，网络连接被迫中断。”",{"type":184,"tag":211,"props":308,"children":309},{},[310,312,321],{"type":194,"value":311},"总之第二个“完美暑假计划”开始了。在这个“暑假”，我的载体去了美国，此外，我把所有自由时间都投入到 ",{"type":184,"tag":313,"props":314,"children":318},"a",{"href":315,"rel":316},"https://search.bilibili.com/all?keyword=%E9%80%83%E7%A6%BB%E5%A1%94%E7%A7%91%E5%A4%AB&from_source=nav_suggest_new&order=dm&duration=0&tids_1=0",[317],"nofollow",[319],{"type":194,"value":320},"《逃离塔科夫》",{"type":194,"value":322}," 中，估摸着六个月有超过了 500 小时游玩记录。",{"type":184,"tag":211,"props":324,"children":325},{},[326],{"type":194,"value":327},"这简直是一种自断后路的生活方式。不出意外的话，我终究会被沉重的现实物理暴击后回到三次元来，不过这次打断我暑期计划的不是没钱了，而是一次半夜睡醒，想爬起来打开落地窗透透气的时候，直接两眼一黑，摔在了地上。",{"type":184,"tag":211,"props":329,"children":330},{},[331],{"type":194,"value":332},"醒来时第一件事是确认自己有没有变傻，这之后脑海里只剩下“虚无”两个大字。",{"type":184,"tag":217,"props":334,"children":336},{"id":335},"和解",[337],{"type":194,"value":335},{"type":184,"tag":211,"props":339,"children":340},{},[341],{"type":194,"value":342},"逃离，我称之为跳脱，其实非常简单。每个人的生活都存在惯性，只要意识到这种惯性，你就能开始着手改变。一旦车辙的角度发生微妙变化，马车就会带着人们跳脱出现有的圈子。马车会一直跑，跑出新的轨迹，使得生活绕进一种新的惯性里。",{"type":184,"tag":211,"props":344,"children":345},{},[346],{"type":194,"value":347},"我并不厌恶虚无，只是需要找到如何定义个人时间价值的答案。我退出了接单的 QQ 群，尝试把所有技术都捡起来，一边在重构自己的博客，也一边重整一下自己的知识体系。又是一年八月，我重新开始了找工作的旅途，一如既往地写简历以及海投；九月初，终于有了合适的坑。",{"type":184,"tag":211,"props":349,"children":350},{},[351],{"type":194,"value":352},"我从来不会因为喜好孤独而愧疚，我反而觉得这是一种极大的优势，让自己能花时间做想做的事。虚无感正是用来检验自己前进方向是否正确的指南针。我相信大部分人欠缺的不是天赋，也不是努力，而是一种方向，一种自省力，一种让自己找到和地球、和宇宙万物共鸣的频率。",{"type":184,"tag":205,"props":354,"children":356},{"id":355},"_2021",[357],{"type":194,"value":358},"2021",{"type":184,"tag":360,"props":361,"children":363},"h4",{"id":362},"技术写作",[364],{"type":194,"value":362},{"type":184,"tag":211,"props":366,"children":367},{},[368],{"type":194,"value":369},"19 年 3 月份左右，我开始有意识的把自己写的代码和平时的思考整理为博客。",{"type":184,"tag":211,"props":371,"children":372},{},[373],{"type":184,"tag":374,"props":375,"children":378},"img",{"alt":376,"src":377},"橙色心脏","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20210104021646.png",[],{"type":184,"tag":211,"props":380,"children":381},{},[382],{"type":194,"value":383},"19 年时不知道应该怎么找题材，只写了零散的几篇。20 年时，逐渐写开了，除了技术博客，还写小诗、碎碎念、议论文之类的东西，基本每个月都有输出：",{"type":184,"tag":385,"props":386,"children":387},"ul",{},[388,400,410,420,430,441,450,460,470,480,490],{"type":184,"tag":389,"props":390,"children":391},"li",{},[392,398],{"type":184,"tag":313,"props":393,"children":395},{"href":394},"/_achieved/2020-04/9-css-chart",[396],{"type":194,"value":397},"《🍥 9 种纯 CSS 图案》",{"type":194,"value":399},"（⭐⭐）",{"type":184,"tag":389,"props":401,"children":402},{},[403,408],{"type":184,"tag":313,"props":404,"children":405},{"href":85},[406],{"type":194,"value":407},"《❓ 你可以用纯 CSS 判断鼠标进入的方向吗？》",{"type":194,"value":409},"（⭐⭐⭐⭐）",{"type":184,"tag":389,"props":411,"children":412},{},[413,418],{"type":184,"tag":313,"props":414,"children":415},{"href":82},[416],{"type":194,"value":417},"《💫 CSS 幻术 | 抗锯齿》",{"type":194,"value":419},"（⭐⭐⭐⭐⭐）",{"type":184,"tag":389,"props":421,"children":422},{},[423,429],{"type":184,"tag":313,"props":424,"children":426},{"href":425},"/_achieved/2020-06/zebra-puzzle",[427],{"type":194,"value":428},"《🎉 斑马难题解法》",{"type":194,"value":399},{"type":184,"tag":389,"props":431,"children":432},{},[433,439],{"type":184,"tag":313,"props":434,"children":436},{"href":435},"/maps/_frontend/css/css-mind-map",[437],{"type":194,"value":438},"《🎉 CSS Mind Map》",{"type":194,"value":440},"（⭐⭐⭐）",{"type":184,"tag":389,"props":442,"children":443},{},[444,449],{"type":184,"tag":313,"props":445,"children":446},{"href":76},[447],{"type":194,"value":448},"《🍲 设计模式与 JS 魔法锅》",{"type":194,"value":409},{"type":184,"tag":389,"props":451,"children":452},{},[453,459],{"type":184,"tag":313,"props":454,"children":456},{"href":455},"/maps/_frontend/javascript/javascript-mind-map",[457],{"type":194,"value":458},"《🎉 JavaScript Mind Map》",{"type":194,"value":440},{"type":184,"tag":389,"props":461,"children":462},{},[463,469],{"type":184,"tag":313,"props":464,"children":466},{"href":465},"/_achieved/2020-08/helmet-and-security",[467],{"type":194,"value":468},"《👑 Helmet & Security》",{"type":194,"value":440},{"type":184,"tag":389,"props":471,"children":472},{},[473,479],{"type":184,"tag":313,"props":474,"children":476},{"href":475},"/flows/_forty-two/dark-room",[477],{"type":194,"value":478},"《📕 四十二篇 | 有关新项目的方法论》",{"type":194,"value":409},{"type":184,"tag":389,"props":481,"children":482},{},[483,489],{"type":184,"tag":313,"props":484,"children":486},{"href":485},"/_achieved/2020-12/js-100",[487],{"type":194,"value":488},"《🏆 学习 JS，从忍者到杀手》",{"type":194,"value":419},{"type":184,"tag":389,"props":491,"children":492},{},[493,498],{"type":184,"tag":313,"props":494,"children":495},{"href":31},[496],{"type":194,"value":497},"《🥛 新工作，喝新饮料》",{"type":194,"value":409},{"type":184,"tag":211,"props":500,"children":501},{},[502],{"type":194,"value":503},"2021 年希望能在写作方面常写、常进步吧。以前听别人说，“写作其实是与读者的交流，所以你需要用简单直接的语言”，我也找来几本写作技巧的书学习，书中也表达了类似的观点。2021 年的新目标是在写技术博客的同时，用目前所学的内容改一遍以前写的内容，修正错误，精进表达。",{"type":184,"tag":211,"props":505,"children":506},{},[507],{"type":194,"value":508},"我的技术写作的最终目标是为了写“严肃的作品”，实话说打心底我并不喜欢口语化的表达，并认同习惯口语化的表达后会丢失原有的风格，所以并没有刻意练习向口语化的文风靠拢。至于这样到底好不好，有待验证。",{"type":184,"tag":360,"props":510,"children":512},{"id":511},"基础技术",[513],{"type":194,"value":511},{"type":184,"tag":211,"props":515,"children":516},{},[517],{"type":194,"value":518},"主要说三个点。第一是今年我找到了一个长期的乐子——看规范——ECMAScript 规范。由于 2020 年学习内容有限，输出也很有限。目前来看，看规范对提升我的技术深度或广度都没有很直接的帮助，但它是我的兴趣点，是我的个人选择，也是我以后突破技术瓶颈的（部分）切入点，所以我不在乎投入的时间和当前的投入产出比。",{"type":184,"tag":211,"props":520,"children":521},{},[522],{"type":194,"value":523},"七月份整理 JS 基础知识时，我比较浅显的读过 ES6 规范部分章节，了解了 JS 这门语言是怎么被“描述的”。看规范那会儿花了很多时间找资料，靠肝，把问题熬过去，简直是心力交瘁。后面也意识到需要找一个稳定的、高质量的前端交流圈，来帮自己借力。也许加入头部公司、参加线下活动、参与开源项目都是不错的方法。",{"type":184,"tag":211,"props":525,"children":526},{},[527],{"type":194,"value":528},"以下是一篇用于测试你了解多少 JavaScript 语言细节熟练度的博客，仅供娱乐：",{"type":184,"tag":385,"props":530,"children":531},{},[532],{"type":184,"tag":389,"props":533,"children":534},{},[535],{"type":184,"tag":313,"props":536,"children":537},{"href":485},[538],{"type":194,"value":488},{"type":184,"tag":211,"props":540,"children":541},{},[542],{"type":194,"value":543},"在此列一下 2021 相关语言规范能力的新年目标：",{"type":184,"tag":385,"props":545,"children":546},{},[547,552,557],{"type":184,"tag":389,"props":548,"children":549},{},[550],{"type":194,"value":551},"钻研绿宝书，即《JS 语言精髓与编程实践》，这是头等大事。",{"type":184,"tag":389,"props":553,"children":554},{},[555],{"type":194,"value":556},"通读 ES6 规范，使用脑图加深印象，并尝试理解语言细节背后的原理。",{"type":184,"tag":389,"props":558,"children":559},{},[560],{"type":194,"value":561},"通过 RSS 逛 TC39 相关社区，保持关注。",{"type":184,"tag":211,"props":563,"children":564},{},[565],{"type":194,"value":566},"二是年中的时候浅显地过过一遍 CSS 基础，但感觉不过瘾。21 年需要系统地重新学习一下。",{"type":184,"tag":385,"props":568,"children":569},{},[570,575],{"type":184,"tag":389,"props":571,"children":572},{},[573],{"type":194,"value":574},"《CSS 权威指南第四版》",{"type":184,"tag":389,"props":576,"children":577},{},[578],{"type":194,"value":579},"《浏览器工作原理与实践》，由于内容太多了，不打算全部看完，主要看相关 HTML、CSS 的部分。",{"type":184,"tag":211,"props":581,"children":582},{},[583,585,591],{"type":194,"value":584},"三是今年习惯了阅读源码。总结来看，由于缺乏规划，一些教大型的库没有办法坚持看下去。再是受能力限制，看源码还停留在“语义”和“解决问题”层面，没能有效输出 ",{"type":184,"tag":313,"props":586,"children":588},{"href":587},"/404",[589],{"type":194,"value":590},"笔记",{"type":194,"value":592},"，更别说博客了。暂时没有啥解决方法，目前也几乎是瞎摸前进。",{"type":184,"tag":385,"props":594,"children":595},{},[596,601],{"type":184,"tag":389,"props":597,"children":598},{},[599],{"type":194,"value":600},"读完 ElementUI 库源码，从项目架构到组件写法都要做到“掌握”。",{"type":184,"tag":389,"props":602,"children":603},{},[604],{"type":194,"value":605},"配合《深入浅出 VueJS》通读 Vue2 核心代码，仿造一个小模型。",{"type":184,"tag":211,"props":607,"children":608},{},[609],{"type":194,"value":610},"其它和前端水平相关的技术在此略过，不期望有太多进展，所以不下放精力。",{"type":184,"tag":360,"props":612,"children":614},{"id":613},"阅读消遣",[615],{"type":194,"value":613},{"type":184,"tag":211,"props":617,"children":618},{},[619],{"type":194,"value":620},"阅读是从去年开始我就一直在坚持做的事儿，并且是将它放到了所有 Todo List 的开头。无论是技术还是非技术，我都尝试通过阅读来打开自己的边界。",{"type":184,"tag":211,"props":622,"children":623},{},[624],{"type":194,"value":625},"大致有两种形式的阅读，一种是碎片化阅读，用 RSS 订阅喜欢的源，五分钟十分钟就能看完一篇文章；另一种则较传统，比如纸书电子书这种。",{"type":184,"tag":211,"props":627,"children":628},{},[629],{"type":194,"value":630},"后者这种形式，我会使用豆瓣跟踪我的阅读进度。2020 年纸书的进度基本上保持每周一本，总阅读数量 52，和去年持平。年末的时候，我整理了一下五星推荐书目，并写了简短的几行推荐，可以参考这篇博客：",{"type":184,"tag":385,"props":632,"children":633},{},[634],{"type":184,"tag":389,"props":635,"children":636},{},[637],{"type":184,"tag":313,"props":638,"children":639},{"href":10},[640],{"type":194,"value":641},"《📕 2020 | 仿生狮子荐书五本》",{"type":184,"tag":211,"props":643,"children":644},{},[645],{"type":194,"value":646},"完整的五星推荐列表见下，各位可以取自己需要的加书单啦。",{"type":184,"tag":385,"props":648,"children":649},{},[650,660,670,680,690,700,710,720,730,740,750,760,770],{"type":184,"tag":389,"props":651,"children":652},{},[653],{"type":184,"tag":313,"props":654,"children":657},{"href":655,"rel":656},"https://book.douban.com/subject/28524769/",[317],[658],{"type":194,"value":659},"《JavaScript 之美》",{"type":184,"tag":389,"props":661,"children":662},{},[663],{"type":184,"tag":313,"props":664,"children":667},{"href":665,"rel":666},"https://book.douban.com/subject/24760695/",[317],[668],{"type":194,"value":669},"《奔跑吧，梅勒斯》",{"type":184,"tag":389,"props":671,"children":672},{},[673],{"type":184,"tag":313,"props":674,"children":677},{"href":675,"rel":676},"https://book.douban.com/subject/34995610/",[317],[678],{"type":194,"value":679},"《八百万种死法》",{"type":184,"tag":389,"props":681,"children":682},{},[683],{"type":184,"tag":313,"props":684,"children":687},{"href":685,"rel":686},"https://book.douban.com/subject/25881855/",[317],[688],{"type":194,"value":689},"《大教堂与集市》",{"type":184,"tag":389,"props":691,"children":692},{},[693],{"type":184,"tag":313,"props":694,"children":697},{"href":695,"rel":696},"https://book.douban.com/subject/27115714/",[317],[698],{"type":194,"value":699},"《大雪将至》",{"type":184,"tag":389,"props":701,"children":702},{},[703],{"type":184,"tag":313,"props":704,"children":707},{"href":705,"rel":706},"https://book.douban.com/subject/27624039/",[317],[708],{"type":194,"value":709},"《田中一光自传》",{"type":184,"tag":389,"props":711,"children":712},{},[713],{"type":184,"tag":313,"props":714,"children":717},{"href":715,"rel":716},"https://book.douban.com/subject/24872498/",[317],[718],{"type":194,"value":719},"《乞力马扎罗山的雪》",{"type":184,"tag":389,"props":721,"children":722},{},[723],{"type":184,"tag":313,"props":724,"children":727},{"href":725,"rel":726},"https://book.douban.com/subject/26319730/",[317],[728],{"type":194,"value":729},"《娱乐至死》",{"type":184,"tag":389,"props":731,"children":732},{},[733],{"type":184,"tag":313,"props":734,"children":737},{"href":735,"rel":736},"https://book.douban.com/subject/26905096/",[317],[738],{"type":194,"value":739},"《治字百方》",{"type":184,"tag":389,"props":741,"children":742},{},[743],{"type":184,"tag":313,"props":744,"children":747},{"href":745,"rel":746},"https://book.douban.com/subject/27109961/",[317],[748],{"type":194,"value":749},"《瓦尔登湖》",{"type":184,"tag":389,"props":751,"children":752},{},[753],{"type":184,"tag":313,"props":754,"children":757},{"href":755,"rel":756},"https://book.douban.com/subject/10749924/",[317],[758],{"type":194,"value":759},"《天真的和感伤的小说家》",{"type":184,"tag":389,"props":761,"children":762},{},[763],{"type":184,"tag":313,"props":764,"children":767},{"href":765,"rel":766},"https://book.douban.com/subject/27114628/",[317],[768],{"type":194,"value":769},"《巴黎评论•短篇小说课堂》",{"type":184,"tag":389,"props":771,"children":772},{},[773],{"type":184,"tag":313,"props":774,"children":777},{"href":775,"rel":776},"https://book.douban.com/subject/27002046/",[317],[778],{"type":194,"value":779},"《美丽新世界》",{"type":184,"tag":211,"props":781,"children":782},{},[783],{"type":194,"value":784},"可能和常人不同，我没啥功利心，只是单纯把读书当作消遣（这样也好骗骗自己多看几本书）。话是这么说，内心老是怀疑这样看书浪费资源，所以希望 2021 年能探索一下如何提高知识的利用率。比方说，看技术书肯定是要边看边实践，同时输出笔记，方面以后快速参考；文学类书那就是查查资料，写写书评咯。.. 才疏学浅，没啥可说的，直接立目标吧：",{"type":184,"tag":385,"props":786,"children":787},{},[788,793,798],{"type":184,"tag":389,"props":789,"children":790},{},[791],{"type":194,"value":792},"学习《金字塔原理》，这本书倒是挺多人推荐的，相关思考本身的方法论。",{"type":184,"tag":389,"props":794,"children":795},{},[796],{"type":194,"value":797},"看完主流神话及圣经，了解“神秘主义”。",{"type":184,"tag":389,"props":799,"children":800},{},[801],{"type":194,"value":802},"形成一种固定的记笔记的方式。要先固定下方式来才能做出“记笔记是否能提高知识利用率”的对比。",{"type":184,"tag":211,"props":804,"children":805},{},[806],{"type":194,"value":807},"至于 RSS，经过一年多的积累，逐渐形成了极具个人风格的订阅内容。",{"type":184,"tag":211,"props":809,"children":810},{},[811],{"type":184,"tag":374,"props":812,"children":815},{"alt":813,"src":814},"我的订阅","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20210104154225.png",[],{"type":184,"tag":211,"props":817,"children":818},{},[819],{"type":194,"value":820},"这里简单推荐介绍一下我的分类思路，也推荐一些质量不错的源：",{"type":184,"tag":385,"props":822,"children":823},{},[824,829,834,839,844,849,854,859],{"type":184,"tag":389,"props":825,"children":826},{},[827],{"type":194,"value":828},"🚀 新鲜玩意：我的 GitHub 动态、CSS current work、ECMAScript Daily...",{"type":184,"tag":389,"props":830,"children":831},{},[832],{"type":194,"value":833},"💻 技术博客：奇舞周刊、前端早读课、前端之巅、张鑫旭的博客。..",{"type":184,"tag":389,"props":835,"children":836},{},[837],{"type":194,"value":838},"🎨 设计体验：HeyDesigner、优设网、Awwwards...",{"type":184,"tag":389,"props":840,"children":841},{},[842],{"type":194,"value":843},"🛸 游戏玩家：游研社、触乐、Indienova...",{"type":184,"tag":389,"props":845,"children":846},{},[847],{"type":194,"value":848},"📚 书和豆瓣：豆瓣最受欢迎的书评、图灵教育、mLook...",{"type":184,"tag":389,"props":850,"children":851},{},[852],{"type":194,"value":853},"🃏 软件分享：少数派、小众软件、数码荔枝。..",{"type":184,"tag":389,"props":855,"children":856},{},[857],{"type":194,"value":858},"🌮 生活日常：丁香医生、知乎日报。..",{"type":184,"tag":389,"props":860,"children":861},{},[862],{"type":194,"value":863},"...",{"type":184,"tag":211,"props":865,"children":866},{},[867],{"type":194,"value":868},"总共一百五十个源，目前每天只能看完 50% 左右的新文章，看不完的只有周末晚上找个时间全部倒进垃圾箱咯。",{"type":184,"tag":211,"props":870,"children":871},{},[872],{"type":194,"value":873},"说到这里吧，祝万事胜意。",{"title":178,"searchDepth":875,"depth":875,"links":876},2,[877,884],{"id":207,"depth":875,"text":207,"children":878},[879,881,882,883],{"id":219,"depth":880,"text":219},3,{"id":254,"depth":880,"text":254},{"id":284,"depth":880,"text":284},{"id":335,"depth":880,"text":335},{"id":355,"depth":875,"text":358},"markdown","content:_achieved:2021-01:escape-from-mysticism.md","content","_achieved/2021-01/escape-from-mysticism.md","_achieved/2021-01/escape-from-mysticism","md",[892,896],{"_path":893,"title":894,"description":895},"/_achieved/2021-01/anysort-1th","🌐 Anysort：灵活、优雅、无依赖的排序库","网易云音乐的歌单排序功能比较弱，本文介绍了使用函数式JS代码搭建一个自定义排序库的思路，以支持对歌单进行任意排序。",{"_path":897,"title":898,"description":899},"/_achieved/2021-01/the-art-of-mysticism","🎨 神秘主义的艺术","阿兰﹒德波顿在《艺术的慰藉》中把艺术视作一种用于弥补人的弱点的工具。他认为人能通过艺术作品找到作品与自我的相关性，从而进一步认识自己；艺术给人带来精神上慰藉，使人学会欣赏爱与美德，并驱使他们不断向这种不流于世俗的更高的精神层次靠拢。",1771695784806]