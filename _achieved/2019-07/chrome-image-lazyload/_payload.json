rue,"","听说你还在手写懒加载?","过去, 我们对含有大量图片的网站进行优化无外乎要依靠 JS 逻辑或是相关插件来完成, 比如懒加载技术. 而现在(至少在不久的将来), Chrome 75 版本将增加原生懒加载功能.",{"type":182,"children":183,"toc":467},"root",[184,209,217,223,244,252,257,270,290,310,315,320,328,348,356,362,375,397,402,420,425],{"type":185,"tag":186,"props":187,"children":188},"element","p",{},[189,192,199,201,207],{"type":190,"value":191},"text","过去, 我们对含有大量图片的网站进行优化无外乎要依靠 JS 逻辑或是相关插件来完成, 比如",{"type":185,"tag":193,"props":194,"children":196},"code",{"className":195},[],[197],{"type":190,"value":198},"懒加载",{"type":190,"value":200},"技术. 而现在(至少在不久的将来), Chrome 75 版本将增加",{"type":185,"tag":193,"props":202,"children":204},{"className":203},[],[205],{"type":190,"value":206},"原生懒加载",{"type":190,"value":208},"功能.",{"type":185,"tag":186,"props":210,"children":211},{},[212],{"type":185,"tag":213,"props":214,"children":216},"img",{"alt":206,"src":215},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/chrome-image-lazyload/2019-04-23-01-30-25.png",[],{"type":185,"tag":218,"props":219,"children":221},"h3",{"id":220},"直接开始使用",[222],{"type":190,"value":220},{"type":185,"tag":186,"props":224,"children":225},{},[226,228,234,236,242],{"type":190,"value":227},"当然, 你也可以现在就开始体验这一功能, 在浏览器的标签栏输入",{"type":185,"tag":193,"props":229,"children":231},{"className":230},[],[232],{"type":190,"value":233},"browser://flags/#enable-lazy-image-loading",{"type":190,"value":235},"并进入页面, 找到",{"type":185,"tag":193,"props":237,"children":239},{"className":238},[],[240],{"type":190,"value":241},"enable-lazy-image-loading",{"type":190,"value":243},"这一项打开它, 重启后即可使用.",{"type":185,"tag":186,"props":245,"children":246},{},[247],{"type":185,"tag":213,"props":248,"children":251},{"alt":249,"src":250},"如何开启","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/chrome-image-lazyload/2019-04-23-00-45-26.png",[],{"type":185,"tag":218,"props":253,"children":255},{"id":254},"标准之下",[256],{"type":190,"value":254},{"type":185,"tag":186,"props":258,"children":259},{},[260,262,268],{"type":190,"value":261},"有关",{"type":185,"tag":193,"props":263,"children":265},{"className":264},[],[266],{"type":190,"value":267},"loading",{"type":190,"value":269},"的使用, 我相信你想知道更多, 你可以使用以下三个属性来定义浏览器加载行为:",{"type":185,"tag":271,"props":272,"children":273},"ul",{},[274,280,285],{"type":185,"tag":275,"props":276,"children":277},"li",{},[278],{"type":190,"value":279},"lazy: 使用懒加载, 当屏幕滚动到图片附近时",{"type":185,"tag":275,"props":281,"children":282},{},[283],{"type":190,"value":284},"eager: 立即加载图片",{"type":185,"tag":275,"props":286,"children":287},{},[288],{"type":190,"value":289},"auto: 由浏览器自行决定",{"type":185,"tag":186,"props":291,"children":292},{},[293,295,308],{"type":190,"value":294},"有关懒加载的讨论, 你可以通过这个",{"type":185,"tag":296,"props":297,"children":301},"a",{"href":298,"rel":299},"https://github.com/whatwg/html/pull/3752",[300],"nofollow",[302],{"type":185,"tag":193,"props":303,"children":305},{"className":304},[],[306],{"type":190,"value":307},"issue",{"type":190,"value":309},"进一步探索.",{"type":185,"tag":218,"props":311,"children":313},{"id":312},"开始使用新代码",[314],{"type":190,"value":312},{"type":185,"tag":186,"props":316,"children":317},{},[318],{"type":190,"value":319},"也许你想把这一特征立即运用到你的项目中, 但是你别忘了至少目前为止他还是实验性的功能, 所以需要做功能检测, 对不支持的浏览器进行兼容:",{"type":185,"tag":186,"props":321,"children":322},{},[323],{"type":185,"tag":213,"props":324,"children":327},{"alt":325,"src":326},"功能检测","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/chrome-image-lazyload/2019-04-23-01-37-31.png",[],{"type":185,"tag":186,"props":329,"children":330},{},[331,333,338,340,346],{"type":190,"value":332},"仅仅这样还不够, 为了不使你的 Image 标签被不支持",{"type":185,"tag":193,"props":334,"children":336},{"className":335},[],[337],{"type":190,"value":267},{"type":190,"value":339},"属性的浏览器立即加载出来, 你还需要把",{"type":185,"tag":193,"props":341,"children":343},{"className":342},[],[344],{"type":190,"value":345},"src",{"type":190,"value":347},"属性替换为其它属性, 同时还得考虑浏览器不支持 JS 的情况, 比如像这样做:",{"type":185,"tag":186,"props":349,"children":350},{},[351],{"type":185,"tag":213,"props":352,"children":355},{"alt":353,"src":354},"兼容","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/chrome-image-lazyload/2019-04-23-01-31-00.png",[],{"type":185,"tag":218,"props":357,"children":359},{"id":358},"抛弃非原生懒加载",[360],{"type":190,"value":361},"抛弃非原生懒加载?",{"type":185,"tag":186,"props":363,"children":364},{},[365,367,373],{"type":190,"value":366},"抛弃非原生懒加载? 答案在任何情况下都是",{"type":185,"tag":193,"props":368,"children":370},{"className":369},[],[371],{"type":190,"value":372},"否",{"type":190,"value":374},".",{"type":185,"tag":186,"props":376,"children":377},{},[378,380,387,389,395],{"type":190,"value":379},"如果未来浏览器都支持懒加载, 并且标准较现在没有改变的话, 它只适用于一些简单的网页浏览场景, 比如像掘金这种文本和图片混排的页面.对于特殊场景下, 比如",{"type":185,"tag":296,"props":381,"children":384},{"href":382,"rel":383},"https://juejin.im/post/5cbd30e7e51d456e803516ba",[300],[385],{"type":190,"value":386},"这位老哥",{"type":190,"value":388},"的这篇文章里描绘的问题, 我们还是得需要根据需求, 书写大量原生 JS 逻辑.除非问题本质得到解决, 否者",{"type":185,"tag":390,"props":391,"children":392},"strong",{},[393],{"type":190,"value":394},"任何在体验上的优化, 都是优化一部分场景的性能, 而放弃另一部分场景的性能",{"type":190,"value":396},"(甚至负优化)",{"type":185,"tag":218,"props":398,"children":400},{"id":399},"最后",[401],{"type":190,"value":399},{"type":185,"tag":186,"props":403,"children":404},{},[405,407,418],{"type":190,"value":406},"文中代码图片是使用",{"type":185,"tag":296,"props":408,"children":411},{"href":409,"rel":410},"https://carbon.now.sh",[300],[412],{"type":185,"tag":193,"props":413,"children":415},{"className":414},[],[416],{"type":190,"value":417},"Carbon",{"type":190,"value":419},"合成的, 掘金的代码高亮实在是... 么得办法~~",{"type":185,"tag":218,"props":421,"children":423},{"id":422},"阅读更多",[424],{"type":190,"value":422},{"type":185,"tag":271,"props":426,"children":427},{},[428,438,447,457],{"type":185,"tag":275,"props":429,"children":430},{},[431],{"type":185,"tag":296,"props":432,"children":435},{"href":433,"rel":434},"https://addyosmani.com/blog/lazy-loading/",[300],[436],{"type":190,"value":437},"Nati