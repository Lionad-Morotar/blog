或是相关插件来完成, 比如懒加载技术. 而现在(至少在不久的将来), Chrome 75 版本将增加原生懒加载功能.",{"type":179,"children":180,"toc":464},"root",[181,206,214,220,241,249,254,267,287,307,312,317,325,345,353,359,372,394,399,417,422],{"type":182,"tag":183,"props":184,"children":185},"element","p",{},[186,189,196,198,204],{"type":187,"value":188},"text","过去, 我们对含有大量图片的网站进行优化无外乎要依靠 JS 逻辑或是相关插件来完成, 比如",{"type":182,"tag":190,"props":191,"children":193},"code",{"className":192},[],[194],{"type":187,"value":195},"懒加载",{"type":187,"value":197},"技术. 而现在(至少在不久的将来), Chrome 75 版本将增加",{"type":182,"tag":190,"props":199,"children":201},{"className":200},[],[202],{"type":187,"value":203},"原生懒加载",{"type":187,"value":205},"功能.",{"type":182,"tag":183,"props":207,"children":208},{},[209],{"type":182,"tag":210,"props":211,"children":213},"img",{"alt":203,"src":212},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/chrome-image-lazyload/2019-04-23-01-30-25.png",[],{"type":182,"tag":215,"props":216,"children":218},"h3",{"id":217},"直接开始使用",[219],{"type":187,"value":217},{"type":182,"tag":183,"props":221,"children":222},{},[223,225,231,233,239],{"type":187,"value":224},"当然, 你也可以现在就开始体验这一功能, 在浏览器的标签栏输入",{"type":182,"tag":190,"props":226,"children":228},{"className":227},[],[229],{"type":187,"value":230},"browser://flags/#enable-lazy-image-loading",{"type":187,"value":232},"并进入页面, 找到",{"type":182,"tag":190,"props":234,"children":236},{"className":235},[],[237],{"type":187,"value":238},"enable-lazy-image-loading",{"type":187,"value":240},"这一项打开它, 重启后即可使用.",{"type":182,"tag":183,"props":242,"children":243},{},[244],{"type":182,"tag":210,"props":245,"children":248},{"alt":246,"src":247},"如何开启","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/chrome-image-lazyload/2019-04-23-00-45-26.png",[],{"type":182,"tag":215,"props":250,"children":252},{"id":251},"标准之下",[253],{"type":187,"value":251},{"type":182,"tag":183,"props":255,"children":256},{},[257,259,265],{"type":187,"value":258},"有关",{"type":182,"tag":190,"props":260,"children":262},{"className":261},[],[263],{"type":187,"value":264},"loading",{"type":187,"value":266},"的使用, 我相信你想知道更多, 你可以使用以下三个属性来定义浏览器加载行为:",{"type":182,"tag":268,"props":269,"children":270},"ul",{},[271,277,282],{"type":182,"tag":272,"props":273,"children":274},"li",{},[275],{"type":187,"value":276},"lazy: 使用懒加载, 当屏幕滚动到图片附近时",{"type":182,"tag":272,"props":278,"children":279},{},[280],{"type":187,"value":281},"eager: 立即加载图片",{"type":182,"tag":272,"props":283,"children":284},{},[285],{"type":187,"value":286},"auto: 由浏览器自行决定",{"type":182,"tag":183,"props":288,"children":289},{},[290,292,305],{"type":187,"value":291},"有关懒加载的讨论, 你可以通过这个",{"type":182,"tag":293,"props":294,"children":298},"a",{"href":295,"rel":296},"https://github.com/whatwg/html/pull/3752",[297],"nofollow",[299],{"type":182,"tag":190,"props":300,"children":302},{"className":301},[],[303],{"type":187,"value":304},"issue",{"type":187,"value":306},"进一步探索.",{"type":182,"tag":215,"props":308,"children":310},{"id":309},"开始使用新代码",[311],{"type":187,"value":309},{"type":182,"tag":183,"props":313,"children":314},{},[315],{"type":187,"value":316},"也许你想把这一特征立即运用到你的项目中, 但是你别忘了至少目前为止他还是实验性的功能, 所以需要做功能检测, 对不支持的浏览器进行兼容:",{"type":182,"tag":183,"props":318,"children":319},{},[320],{"type":182,"tag":210,"props":321,"children":324},{"alt":322,"src":323},"功能检测","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/chrome-image-lazyload/2019-04-23-01-37-31.png",[],{"type":182,"tag":183,"props":326,"children":327},{},[328,330,335,337,343],{"type":187,"value":329},"仅仅这样还不够, 为了不使你的 Image 标签被不支持",{"type":182,"tag":190,"props":331,"children":333},{"className":332},[],[334],{"type":187,"value":264},{"type":187,"value":336},"属性的浏览器立即加载出来, 你还需要把",{"type":182,"tag":190,"props":338,"children":340},{"className":339},[],[341],{"type":187,"value":342},"src",{"type":187,"value":344},"属性替换为其它属性, 同时还得考虑浏览器不支持 JS 的情况, 比如像这样做:",{"type":182,"tag":183,"props":346,"children":347},{},[348],{"type":182,"tag":210,"props":349,"children":352},{"alt":350,"src":351},"兼容","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/chrome-image-lazyload/2019-04-23-01-31-00.png",[],{"type":182,"tag":215,"props":354,"children":356},{"id":355},"抛弃非原生懒加载",[357],{"type":187,"value":358},"抛弃非原生懒加载?",{"type":182,"tag":183,"props":360,"children":361},{},[362,364,370],{"type":187,"value":363},"抛弃非原生懒加载? 答案在任何情况下都是",{"type":182,"tag":190,"props":365,"children":367},{"className":366},[],[368],{"type":187,"value":369},"否",{"type":187,"value":371},".",{"type":182,"tag":183,"props":373,"children":374},{},[375,377,384,386,392],{"type":187,"value":376},"如果未来浏览器都支持懒加载, 并且标准较现在没有改变的话, 它只适用于一些简单的网页浏览场景, 比如像掘金这种文本和图片混排的页面.对于特殊场景下, 比如",{"type":182,"tag":293,"props":378,"children":381},{"href":379,"rel":380},"https://juejin.im/post/5cbd30e7e51d456e803516ba",[297],[382],{"type":187,"value":383},"这位老哥",{"type":187,"value":385},"的这篇文章里描绘的问题, 我们还是得需要根据需求, 书写大量原生 JS 逻辑.除非问题本质得到解决, 否者",{"type":182,"tag":387,"props":388,"children":389},"strong",{},[390],{"type":187,"value":391},"任何在体验上的优化, 都是优化一部分场景的性能, 而放弃另一部分场景的性能",{"type":187,"value":393},"(甚至负优化)",{"type":182,"tag":215,"props":395,"children":397},{"id":396},"最后",[398],{"type":187,"value":396},{"type":182,"tag":183,"props":400,"children":401},{},[402,404,415],{"type":187,"value":403},"文中代码图片是使用",{"type":182,"tag":293,"props":405,"children":408},{"href":406,"rel":407},"https://carbon.now.sh",[297],[409],{"type":182,"tag":190,"props":410,"children":412},{"className":411},[],[413],{"type":187,"value":414},"Carbon",{"type":187,"value":416},"合成的, 掘金的代码高亮实在是... 么得办法~~",{"type":182,"tag":215,"props":418,"children":420},{"id":419},"阅读更多",[421],{"type":187,"value":419},{"type":182,"tag":268,"props":423,"children":424},{},[425,435,444,454],{"type":182,"tag":272,"props":426,"children":427},{},[428],{"type":182,"tag":293,"props":429,"children":432},{"href":430,"rel":431},"https://addyosmani.com/blog/lazy-loading/",[297],[433],{"type":187,"value":434},"Native image lazy-loading for the web!",{"type":182,"tag":