style":384},[922],{"type":190,"value":479},{"type":184,"tag":346,"props":924,"children":926},{"class":348,"line":925},25,[927],{"type":184,"tag":346,"props":928,"children":929},{"emptyLinePlaceholder":177},[930],{"type":190,"value":365},{"type":184,"tag":346,"props":932,"children":934},{"class":348,"line":933},26,[935,941],{"type":184,"tag":346,"props":936,"children":938},{"style":937},"--shiki-light:#E53935;--shiki-default:#22863A;--shiki-dark:#85E89D;--shiki-sepia:#F92672",[939],{"type":190,"value":940},"article",{"type":184,"tag":346,"props":942,"children":943},{"style":384},[944],{"type":190,"value":397},{"type":184,"tag":346,"props":946,"children":948},{"class":348,"line":947},27,[949,953,957,962,966,971],{"type":184,"tag":346,"props":950,"children":951},{"style":644},[952],{"type":190,"value":778},{"type":184,"tag":346,"props":954,"children":955},{"style":378},[956],{"type":190,"value":652},{"type":184,"tag":346,"props":958,"children":959},{"style":372},[960],{"type":190,"value":961}," var",{"type":184,"tag":346,"props":963,"children":964},{"style":378},[965],{"type":190,"value":381},{"type":184,"tag":346,"props":967,"children":968},{"style":404},[969],{"type":190,"value":970},"--font-text",{"type":184,"tag":346,"props":972,"children":973},{"style":378},[974],{"type":190,"value":975},");\n",{"type":184,"tag":346,"props":977,"children":979},{"class":348,"line":978},28,[980],{"type":184,"tag":346,"props":981,"children":982},{"style":384},[983],{"type":190,"value":479},{"type":184,"tag":985,"props":986,"children":987},"hr",{},[],{"type":184,"tag":185,"props":989,"children":991},{"id":990},"使用英文点号",[992],{"type":190,"value":990},{"type":184,"tag":203,"props":994,"children":996},{"id":995},"增订-2020年6月20日",[997],{"type":190,"value":998},"增订 | 2020年6月20日",{"type":184,"tag":192,"props":1000,"children":1001},{},[1002,1004,1010],{"type":190,"value":1003},"《使用英文点号》是我建立博客时写的第二篇随笔，现修正了",{"type":184,"tag":1005,"props":1006,"children":1007},"del",{},[1008],{"type":190,"value":1009},"部分",{"type":190,"value":1011},"很多语意不通的地方。",{"type":184,"tag":192,"props":1013,"children":1014},{},[1015],{"type":190,"value":1016},"关于文末的疑惑，我已经找到了答案：我现在已经习惯在中文输入时使用中文标点，而编码工作中尽量不使用中文。",{"type":184,"tag":203,"props":1018,"children":1020},{"id":1019},"正文",[1021],{"type":190,"value":1019},{"type":184,"tag":192,"props":1023,"children":1024},{},[1025],{"type":190,"value":1026},"有人发现我喜欢使用英文的点号来写中文的句子，其实是我刻意为之。",{"type":184,"tag":192,"props":1028,"children":1029},{},[1030],{"type":190,"value":1031},"起初，是因为打代码时，由于代码中夹杂的一些中文词汇，导致编程时并不能全程使用英文输入法输入。为了省去切换输入法的麻烦，我想，干脆就把中文键盘的中文标点禁用就好了。经过实践，我发现代码输入时的幸福感提升的非常明显。",{"type":184,"tag":192,"props":1033,"children":1034},{},[1035],{"type":190,"value":1036},"再者，另一个习惯问题迫使我决定开始在所有设备上——无论是电脑或是手机——使用英文点号。",{"type":184,"tag":192,"props":1038,"children":1039},{},[1040],{"type":190,"value":1041},"某个悠哉游哉喝着饮料看博客的下午，我照常点开一大片网址乱逛。偶然间，我看到一篇排版糟糕，样式混乱的文章。最可恶的是文中的中文与英文、数字之间居然没有空格！真是一阵头皮发麻！汉字是全型字，和字母或数字等半型字间哪能混沌不分？我恨不得手持“盘古之白”的巨斧，把这些懵懂混乱的全型字和半型字们统统劈开。",{"type":184,"tag":192,"props":1043,"children":1044},{},[1045],{"type":190,"value":1046},"眼下混沌四起，所以我需要做更多的宣传工作，比如，开始在中文中使用英文点号。由于英文点号只占半格字宽，所以不得不在点号后加一个空格保证正常的版式节奏。这样一来，其它看到这种写法的人（尤其和我一样偷懒仅仅使用英文标点的程序员们）潜意识里就会将“劈开盘古直白”的理念内化了，美哉~",{"type":184,"tag":1048,"props":1049,"children":1050},"blockquote",{},[1051],{"type":184,"tag":192,"props":1052,"children":1053},{},[1054,1056],{"type":190,"value":1055},"没有研究显示，打字的时候不喜欢在中文和英文之间加空格的人，感情路都走得很辛苦，有七成的比例会在 34 岁前和自己不爱的人结婚，而其余三成的人最后只能把遗产留给自己的猫。毕竟爱情跟书写都需要适时地留白。\n",{"type":184,"tag":1057,"props":1058,"children":1059},"name",{},[1060],{"type":190,"value":1061},"盘古之白",{"type":184,"tag":192,"props":1063,"children":1064},{},[1065],{"type":184,"tag":276,"props":1066,"children":1067},{},[1068],{"type":190,"value":1069},"不过出乎意料的是，对于培养使用英文点号这习惯的态度，最近我有些动摇了。",{"type":184,"tag":192,"props":1071,"children":1072},{},[1073],{"type":190,"value":1074},"首先是使用英文点号的美观性不够，再者是它并不适合中文语意。全型点号的字宽比英文点号加一个空格还多，所以无论是表达节奏感，还是在分割语意等功能上而言都更加适合。中文标点本身就是中文的一部分。也就是说，我也许没有理由去放弃语意而选择偷懒。同时，劈开“盘古之白”的巨斧应该用在正确的场景，如中文与英文词组夹杂的时候，而不是中文与英文标点夹杂的时候。",{"type":184,"tag":192,"props":1076,"children":1077},{},[1078,1080,1085],{"type":190,"value":1079},"我现在陷入了反复尝试和挣扎中。",{"type":184,"tag":276,"props":1081,"children":1082},{},[1083],{"type":190,"value":1084},"有没有必要改变保持使用英文点号的书写习惯？或能不能寻找更适合编程的输入法？能不能通过改善工作流的方式解决部分问题？",{"type":190,"value":1086}," 我还想知道其他人是怎么解决这个问题的，难道说自然而然就习惯了？总之，“我们要怎么愉快地处理英文编程中的中文输入”这个问题亟需讨论与解决。",{"type":184,"tag":185,"props":1088,"children":1090},{"id":1089},"阅读更多",[1091],{"type":190,"value":1089},{"type":184,"tag":1093,"props":1094,"children":1095},"ul",{},[1096,1109,1119,1129],{"type":184,"tag":1097,"props":1098,"children":1099},"li",{},[1100],{"type":184,"tag":1101,"props":1102,"children":1106},"a",{"href":1103,"rel":1104},"https://zhuanlan.zhihu.com/p/20151625",[1105],"nofollow",[1107],{"type":190,"value":1108},"请正确使用直角引号与西文引号",{"type":184,"tag":1097,"props":1110,"children":1111},{},[1112],{"type":184,"tag":1101,"props":1113,"children":1116},{"href":1114,"rel":1115},"https://www.zhihu.com/question/19867627",[1105],[1117],{"type":190,"value":1118},"中文的直角引号 「」、『』 源自哪里? - 知乎",{"type":184,"tag":1097,"props":1120,"children":1121},{},[1122],{"type":184,"tag":1101,"props":1123,"children":1126},{"href":1124,"rel":1125},"https://sspai.com/post/33549",[1105],[1127],{"type":190,"value":1128},"为什么你们就是不能加个空格呢？",{"type":184,"tag":1097,"props":1130,"children":1131},{},[1132],{"type":184,"tag":1101,"props":1133,"children":1136},{"href":1134,"rel":1135},"https://fonts.google.com/specimen/Noto+Serif+SC?query=Noto",[1105],[1137],{"type":190,"value":1138},"Google Fonts - Noto Serif SC",{"type":184,"tag":192,"props":1140,"children":1141},{},[1142,1144,1151],{"type":190,"value":1143},"本文首发于我的博客，",{"type":184,"tag":1101,"props":1145,"children":1148},{"href":1146,"rel":1147},"http://www.lionad.art/flows/%E5%85%B3%E4%BA%8E%E6%A0%87%E7%82%B9%E7%9A%84%E9%82%A3%E4%BA%9B%E4%BA%8B%E5%84%BF",[1105],[1149],{"type":190,"value":1150},"《关于标点的那些事儿》",{"type":190,"value":1152},"，欢迎来我的博客玩耍，里面能看源码。",{"type":184,"tag":1154,"props":1155,"children":1156},"style",{},[1157],{"type":190,"value":1158},"html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html .sepia .shiki span {color: var(--shiki-sepia);background: var(--shiki-sepia-bg);font-style: var(--shiki-sepia-font-style);font-weight: var(--shiki-sepia-font-weight);text-decoration: var(--shiki-sepia-text-decoration);}html.sepia .shiki span {color: var(--shiki-sepia);background: var(--shiki-sepia-bg);font-style: var(--shiki-sepia-font-style);font-weight: var(--shiki-sepia-font-weight);text-decoration: var(--shiki-sepia-text-decoration);}",{"title":178,"searchDepth":359,"depth":359,"links":1160},[1161,1165,1169],{"id":187,"depth":359,"text":187,"children":1162},[1163,1164],{"id":205,"depth":368,"text":205},{"id":285,"depth":368,"text":288},{"id":990,"depth":359,"text":990,"children":1166},[1167,1168],{"id":995,"depth":368,"text":998},{"id":1019,"depth":368,"text":1019},{"id":1089,"depth":359,"text":1089},"markdown","content:_achieved:2020-06:punctuations.md","content","_achieved/2020-06/punctuations.md","_achieved/2020-06/punctuations","md",[1177,1180],{"_path":1178,"title":1179,"description":178},"/_achieved/2020-05/type-check","🎫 常用类型判断方法的优势及缺陷",{"_path":1181,"title":1182,"description":1183},"/_achieved/2020-06/zebra-puzzle","🎃 斑马难题","好了，不卖关子了，我说的就是“斑马难题”。网传斑马难题是爱因斯坦设下的一道谜题，世界上只有 2% 的人能解。不过，对此我深表怀疑... 我们直接看看题目吧，如果实在毫无头绪的话，可以直接跳到文末视频（BiliBili 干杯~ (￣ ▽ ￣)*）。",1771521489509]