188,194,199,205,210,216,221,229,234,239,247,252,257,262,267,280,286,299,318,326,331,981,985,990,996,1009,1014,1019,1024,1029,1034,1039,1044,1059,1067,1072,1084,1089,1136,1150],{"type":181,"tag":182,"props":183,"children":185},"element","h2",{"id":184},"使用直排引号",[186],{"type":187,"value":184},"text",{"type":181,"tag":189,"props":190,"children":191},"p",{},[192],{"type":187,"value":193},"打代码的时候，频繁的中英文切换会导致输入效率降低，若一致使用英文标点（一个英文标点加一个空格）则可以增加编码速度。不过，习惯在编程时持续使用英文标点后，写博客时自然会保持这种惯性，这导致了我前期的博客页面崩坏——尽管版面的节奏要流畅许多，但英文标点在中文版面上的美观程度远远不及中文标点。",{"type":181,"tag":189,"props":195,"children":196},{},[197],{"type":187,"value":198},"以上是我去年因为“使用英文标点”而产生的疑惑。现在来说，这个问题几乎已经算解决了：我现在已经习惯在中文输入时使用中文标点，而编码工作中尽量不使用中文。不过，现在，我又发现了一个新的问题，关于博客中的中文引号不美观的问题。",{"type":181,"tag":200,"props":201,"children":203},"h3",{"id":202},"起因",[204],{"type":187,"value":202},{"type":181,"tag":189,"props":206,"children":207},{},[208],{"type":187,"value":209},"应该有读者已经发现，我博客中引用的思源宋中的映射少了中文引号。这也就意味着，页面上所有中文引号，都会回退成其它字体引号的形态。见下图最后一行文字。",{"type":181,"tag":211,"props":212,"children":215},"img",{"src":213,"alt":214},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/200619/browser_06_20_003.png","页面上所有中文引号，都会回退成其它字体的引号",[],{"type":181,"tag":189,"props":217,"children":218},{},[219],{"type":187,"value":220},"这个引号可能来自某种英文非衬线体字体，看起来圆溜溜的，实在和思源宋不搭。接着我将博客中缺失的字体引用补充完整，界面成了这个样子：",{"type":181,"tag":189,"props":222,"children":223},{},[224],{"type":181,"tag":211,"props":225,"children":228},{"alt":226,"src":227},"逗号加弯引号","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/200619/browser_06_20_012.png",[],{"type":181,"tag":189,"props":230,"children":231},{},[232],{"type":187,"value":233},"引号依旧圆溜溜的。于是，我想着能不能换种特殊的字体，专门用来显示中文引号。",{"type":181,"tag":189,"props":235,"children":236},{},[237],{"type":187,"value":238},"一番探索之后，我找到了“直角引号”这货。我决定把博客中所有的中文引号都替换成直角引号，以增加美观度。尽管两个邻接的逗号和直角引号间有空白过多之嫌，但比起逗号加弯引号要好多了。",{"type":181,"tag":189,"props":240,"children":241},{},[242],{"type":181,"tag":211,"props":243,"children":246},{"alt":244,"src":245},"直排引号","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/200619/browser_06_20_013.png",[],{"type":181,"tag":189,"props":248,"children":249},{},[250],{"type":187,"value":251},"“为什么在你的博客中要使用直排引号排版？”",{"type":181,"tag":189,"props":253,"children":254},{},[255],{"type":187,"value":256},"“因为好看。”",{"type":181,"tag":189,"props":258,"children":259},{},[260],{"type":187,"value":261},"“可是这样并不规范...”",{"type":181,"tag":189,"props":263,"children":264},{},[265],{"type":187,"value":266},"“可是好看。”",{"type":181,"tag":189,"props":268,"children":269},{},[270,272,278],{"type":187,"value":271},"关于直角引号使用的规范，一般资料表示：",{"type":181,"tag":273,"props":274,"children":275},"strong",{},[276],{"type":187,"value":277},"“竖排中文使用直角引号，横排文字使用弯引号”",{"type":187,"value":279},"。不过在我个人的博客里，放弃使用弯引号并没什么可追究的。就像我喜欢用三点省略号作为全省略号的替代，直角引号配合中文方块字，也纯属喜好。",{"type":181,"tag":200,"props":281,"children":283},{"id":282},"hacker",[284],{"type":187,"value":285},"Hacker",{"type":181,"tag":189,"props":287,"children":288},{},[289,291,297],{"type":187,"value":290},"其实，为了不更正我在中文输入中，从使用英文标点加空格到改为使用中文标点一贯以来的习惯。我在博客项目里，通过技术手段给弯引号加了魔法，使博客页面上的弯引号看起来是直角引号，而打字时，不用特意输入直角引号，直接 ",{"type":181,"tag":292,"props":293,"children":294},"keyboard",{},[295],{"type":187,"value":296},"Shift + \"",{"type":187,"value":298}," 打弯引号即可。",{"type":181,"tag":189,"props":300,"children":301},{},[302,304,309,311,316],{"type":187,"value":303},"你可以在浏览器中按下 ",{"type":181,"tag":292,"props":305,"children":306},{},[307],{"type":187,"value":308},"Ctrl + Shift + C",{"type":187,"value":310}," 打开浏览器的控制台，再点击这段带有直接引号的 Hello World 查看页面原文：",{"type":181,"tag":273,"props":312,"children":313},{},[314],{"type":187,"value":315},"“Hello World”",{"type":187,"value":317},"，如果不会操作的话，可以参考下图。",{"type":181,"tag":189,"props":319,"children":320},{},[321],{"type":181,"tag":211,"props":322,"children":325},{"alt":323,"src":324},"查看原文步骤","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/200619/06_20_007.gif",[],{"type":181,"tag":189,"props":327,"children":328},{},[329],{"type":187,"value":330},"我给博客页面新增了一种字体，叫做“Quote”。这种字体内部只有“300C”、“300D”、“201C”、“201D”四种 Unicode 编码的字体图形映射，分别对应前直角引号，后直角引号，前弯引号和后弯引号。我通过工具把字体内部的弯引号的映射修改为映射到直角引号上，然后在页面中引用字体，所以页面上所有弯引号都渲染成了直角引号。对应的 CSS 样式见下：",{"type":181,"tag":332,"props":333,"children":337},"pre",{"className":334,"code":335,"language":336,"meta":175,"style":175},"language-stylus shiki shiki-themes material-theme-lighter github-light github-dark monokai","/**************** 字体定义 */\n\nuseFontBaseURL(path) {\n    $font-url = 'https://mgear-image.oss-cn-shanghai.aliyuncs.com/fonts/';\n    return url($font-url + path);\n}\n\n@font-face {\n    font-family: 'Quote';\n    src: useFontBaseURL('Noto_CJK_Quote/NotoQuote.woff2') format('woff2'), useFontBaseURL('Noto_CJK_Quote/NotoQuote.woff') format('woff'), useFontBaseURL('Noto_CJK_Quote/NotoQuote.ttf');\n    unicode-range: U+201c, U+201d, U+300C, U+300D;\n    font-display: block;\n}\n\n@font-face {\n    font-family: 'Noto Serif CJK';\n    src: ...\n}\n\n/**************** 字体引用 */\n\n:root {\n    --font-text: 'Quote', 'Noto Serif CJK';\n}\n\narticle {\n    font-family: var(--font-text);\n}\n","stylus",[338],{"type":181,"tag":339,"props":340,"children":341},"code",{"__ignoreMap":175},[342,354,363,395,433,468,477,485,494,503,635,715,738,746,754,767,797,815,823,831,840,848,866,912,920,928,942,973],{"type":181,"tag":343,"props":344,"children":347},"span",{"class":345,"line":346},"line",1,[348],{"type":181,"tag":343,"props":349,"children":351},{"style":350},"--shiki-light:#90A4AE;--shiki-light-font-style:italic;--shiki-default:#6A737D;--shiki-default-font-style:inherit;--shiki-dark:#6A737D;--shiki-dark-font-style:inherit;--shiki-sepia:#88846F;--shiki-sepia-font-style:inherit",[352],{"type":187,"value":353},"/**************** 字体定义 */\n",{"type":181,"tag":343,"props":355,"children":357},{"class":345,"line":356},2,[358],{"type":181,"tag":343,"props":359,"children":360},{"emptyLinePlaceholder":174},[361],{"type":187,"value":362},"\n",{"type":181,"tag":343,"props":364,"children":366},{"class"