,"tag":343,"props":921,"children":923},{"class":345,"line":922},25,[924],{"type":181,"tag":343,"props":925,"children":926},{"emptyLinePlaceholder":174},[927],{"type":187,"value":362},{"type":181,"tag":343,"props":929,"children":931},{"class":345,"line":930},26,[932,938],{"type":181,"tag":343,"props":933,"children":935},{"style":934},"--shiki-light:#E53935;--shiki-default:#22863A;--shiki-dark:#85E89D;--shiki-sepia:#F92672",[936],{"type":187,"value":937},"article",{"type":181,"tag":343,"props":939,"children":940},{"style":381},[941],{"type":187,"value":394},{"type":181,"tag":343,"props":943,"children":945},{"class":345,"line":944},27,[946,950,954,959,963,968],{"type":181,"tag":343,"props":947,"children":948},{"style":641},[949],{"type":187,"value":775},{"type":181,"tag":343,"props":951,"children":952},{"style":375},[953],{"type":187,"value":649},{"type":181,"tag":343,"props":955,"children":956},{"style":369},[957],{"type":187,"value":958}," var",{"type":181,"tag":343,"props":960,"children":961},{"style":375},[962],{"type":187,"value":378},{"type":181,"tag":343,"props":964,"children":965},{"style":401},[966],{"type":187,"value":967},"--font-text",{"type":181,"tag":343,"props":969,"children":970},{"style":375},[971],{"type":187,"value":972},");\n",{"type":181,"tag":343,"props":974,"children":976},{"class":345,"line":975},28,[977],{"type":181,"tag":343,"props":978,"children":979},{"style":381},[980],{"type":187,"value":476},{"type":181,"tag":982,"props":983,"children":984},"hr",{},[],{"type":181,"tag":182,"props":986,"children":988},{"id":987},"使用英文点号",[989],{"type":187,"value":987},{"type":181,"tag":200,"props":991,"children":993},{"id":992},"增订-2020年6月20日",[994],{"type":187,"value":995},"增订 | 2020年6月20日",{"type":181,"tag":189,"props":997,"children":998},{},[999,1001,1007],{"type":187,"value":1000},"《使用英文点号》是我建立博客时写的第二篇随笔，现修正了",{"type":181,"tag":1002,"props":1003,"children":1004},"del",{},[1005],{"type":187,"value":1006},"部分",{"type":187,"value":1008},"很多语意不通的地方。",{"type":181,"tag":189,"props":1010,"children":1011},{},[1012],{"type":187,"value":1013},"关于文末的疑惑，我已经找到了答案：我现在已经习惯在中文输入时使用中文标点，而编码工作中尽量不使用中文。",{"type":181,"tag":200,"props":1015,"children":1017},{"id":1016},"正文",[1018],{"type":187,"value":1016},{"type":181,"tag":189,"props":1020,"children":1021},{},[1022],{"type":187,"value":1023},"有人发现我喜欢使用英文的点号来写中文的句子，其实是我刻意为之。",{"type":181,"tag":189,"props":1025,"children":1026},{},[1027],{"type":187,"value":1028},"起初，是因为打代码时，由于代码中夹杂的一些中文词汇，导致编程时并不能全程使用英文输入法输入。为了省去切换输入法的麻烦，我想，干脆就把中文键盘的中文标点禁用就好了。经过实践，我发现代码输入时的幸福感提升的非常明显。",{"type":181,"tag":189,"props":1030,"children":1031},{},[1032],{"type":187,"value":1033},"再者，另一个习惯问题迫使我决定开始在所有设备上——无论是电脑或是手机——使用英文点号。",{"type":181,"tag":189,"props":1035,"children":1036},{},[1037],{"type":187,"value":1038},"某个悠哉游哉喝着饮料看博客的下午，我照常点开一大片网址乱逛。偶然间，我看到一篇排版糟糕，样式混乱的文章。最可恶的是文中的中文与英文、数字之间居然没有空格！真是一阵头皮发麻！汉字是全型字，和字母或数字等半型字间哪能混沌不分？我恨不得手持“盘古之白”的巨斧，把这些懵懂混乱的全型字和半型字们统统劈开。",{"type":181,"tag":189,"props":1040,"children":1041},{},[1042],{"type":187,"value":1043},"眼下混沌四起，所以我需要做更多的宣传工作，比如，开始在中文中使用英文点号。由于英文点号只占半格字宽，所以不得不在点号后加一个空格保证正常的版式节奏。这样一来，其它看到这种写法的人（尤其和我一样偷懒仅仅使用英文标点的程序员们）潜意识里就会将“劈开盘古直白”的理念内化了，美哉~",{"type":181,"tag":1045,"props":1046,"children":1047},"blockquote",{},[1048],{"type":181,"tag":189,"props":1049,"children":1050},{},[1051,1053],{"type":187,"value":1052},"没有研究显示，打字的时候不喜欢在中文和英文之间加空格的人，感情路都走得很辛苦，有七成的比例会在 34 岁前和自己不爱的人结婚，而其余三成的人最后只能把遗产留给自己的猫。毕竟爱情跟书写都需要适时地留白。\n",{"type":181,"tag":1054,"props":1055,"children":1056},"name",{},[1057],{"type":187,"value":1058},"盘古之白",{"type":181,"tag":189,"props":1060,"children":1061},{},[1062],{"type":181,"tag":273,"props":1063,"children":1064},{},[1065],{"type":187,"value":1066},"不过出乎意料的是，对于培养使用英文点号这习惯的态度，最近我有些动摇了。",{"type":181,"tag":189,"props":1068,"children":1069},{},[1070],{"type":187,"value":1071},"首先是使用英文点号的美观性不够，再者是它并不适合中文语意。全型点号的字宽比英文点号加一个空格还多，所以无论是表达节奏感，还是在分割语意等功能上而言都更加适合。中文标点本身就是中文的一部分。也就是说，我也许没有理由去放弃语意而选择偷懒。同时，劈开“盘古之白”的巨斧应该用在正确的场景，如中文与英文词组夹杂的时候，而不是中文与英文标点夹杂的时候。",{"type":181,"tag":189,"props":1073,"children":1074},{},[1075,1077,1082],{"type":187,"value":1076},"我现在陷入了反复尝试和挣扎中。",{"type":181,"tag":273,"props":1078,"children":1079},{},[1080],{"type":187,"value":1081},"有没有必要改变保持使用英文点号的书写习惯？或能不能寻找更适合编程的输入法？能不能通过改善工作流的方式解决部分问题？",{"type":187,"value":1083}," 我还想知道其他人是怎么解决这个问题的，难道说自然而然就习惯了？总之，“我们要怎么愉快地处理英文编程中的中文输入”这个问题亟需讨论与解决。",{"type":181,"tag":182,"props":1085,"children":1087},{"id":1086},"阅读更多",[1088],{"type":187,"value":1086},{"type":181,"tag":1090,"props":1091,"children":1092},"ul",{},[1093,1106,1116,1126],{"type":181,"tag":1094,"props":1095,"children":1096},"li",{},[1097],{"type":181,"tag":1098,"props":1099,"children":1103},"a",{"href":1100,"rel":1101},"https://zhuanlan.zhihu.com/p/20151625",[1102],"nofollow",[1104],{"type":187,"value":1105},"请正确使用直角引号与西文引号",{"type":181,"tag":1094,"props":1107,"children":1108},{},[1109],{"type":181,"tag":1098,"props":1110,"children":1113},{"href":1111,"rel":1112},"https://www.zhihu.com/question/19867627",[1102],[1114],{"type":187,"value":1115},"中文的直角引号 「」、『』 源自哪里? - 知乎",{"type":181,"tag":1094,"props":1117,"children":1118},{},[1119],{"type":181,"tag":1098,"props":1120,"children":1123},{"href":1121,"rel":1122},"https://sspai.com/post/33549",[1102],[1124],{"type":187,"value":1125},"为什么你们就是不能加个空格呢？",{"type":181,"tag":1094,"props":1127,"children":1128},{},[1129],{"type":181,"tag":1098,"props":1130,"children":1133},{"href":1131,"rel":1132},"https://fonts.google.com/specimen/Noto+Serif+SC?query=Noto",[1102],[1134],{"type":187,"value":1135},"Google Fonts - Noto Serif SC",{"type":181,"tag":189,"props":1137,"children":1138},{},[1139,1141,1148],{"type":187,"value":1140},"本文首发于我的博客，",{"type":181,"tag":1098,"props":1142,"children":1145},{"href":1143,"rel":1144},"http://www.lionad.art/flows/%E5%85%B3%E4%BA%8E%E6%A0%87%E7%82%B9%E7%9A%84%E9%82%A3%E4%BA%9B%E4%BA%8B%E5%84%BF",[1102],[1146],{"type":187,"value":1147},"《关于标点的那些事儿》",{"type":187,"value":1149},"，欢迎来我的博客玩耍，里面能看源码。",{"type":181,"tag":1151,"props":1152,"children":1153}