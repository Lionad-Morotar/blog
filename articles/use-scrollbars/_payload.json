61,266,271,279,293,298,303,311,316,324,330,342,349,354,379,384,389,394,780,788,793,798,1117,1122,1285,1290,1387,1392,1410,1424,1436],{"type":179,"tag":180,"props":181,"children":183},"element","h2",{"id":182},"原生滚动条样式一言难尽",[184],{"type":185,"value":182},"text",{"type":179,"tag":187,"props":188,"children":189},"p",{},[190,192,201],{"type":185,"value":191},"公司项目需要用到多表头等复杂的表格功能，一直使用 vxe-table 并在其基础上定制开发。但相比 Element Plus 的表格，它有一个对界面来说很不友好的缺陷：",{"type":179,"tag":193,"props":194,"children":198},"a",{"href":195,"rel":196},"https://vxetable.cn/#/table/base/scrollStyle",[197],"nofollow",[199],{"type":185,"value":200},"不能自定义滚动条",{"type":185,"value":202},"。使用原生滚动条会使表格右侧多出一块空白的区域，令人难受。",{"type":179,"tag":187,"props":204,"children":205},{},[206,208,215],{"type":185,"value":207},"年前，我们要在一个新系统中画甘特图，用到了在 Github 极其流行的 ",{"type":179,"tag":193,"props":209,"children":212},{"href":210,"rel":211},"https://github.com/neuronetio/gantt-elastic",[197],[213],{"type":185,"value":214},"vue-gantt-elastic",{"type":185,"value":216},"。并不出乎意料，这玩意儿也不支持自定义滚动条。",{"type":179,"tag":187,"props":218,"children":219},{},[220],{"type":185,"value":221},"也许大家没见过 Windows 的滚动条样式是到底有多么出戏。这里截张图给大家感受一下。",{"type":179,"tag":187,"props":223,"children":224},{},[225],{"type":179,"tag":226,"props":227,"children":230},"img",{"alt":228,"src":229},"CodePen","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20230218235213.png",[],{"type":179,"tag":187,"props":232,"children":233},{},[234,236,243],{"type":185,"value":235},"CSS 滚动条相关的规范如 ",{"type":179,"tag":193,"props":237,"children":240},{"href":238,"rel":239},"https://www.w3.org/TR/2021/CR-css-scrollbars-1-20211209/",[197],[241],{"type":185,"value":242},"CSS Scrollbars Styling Module",{"type":185,"value":244}," 所规范的功能不多，甚至可以说太弱了。它只描述了一些用来简单处理滚动条样式的属性，如宽度和颜色。考虑到 PC 端用户使用鼠标，给滚动条加上动画或鼠标交互也是完全合情合理的需求，所以依赖 CSS 滚动条规范完全不够用。",{"type":179,"tag":187,"props":246,"children":247},{},[248,250],{"type":185,"value":249},"但大佬对原生滚动条样式不满意，前端怎么能说不行呢，改！",{"type":179,"tag":251,"props":252,"children":253},"del",{},[254],{"type":185,"value":255},"（不是手痒痒了）",{"type":179,"tag":180,"props":257,"children":259},{"id":258},"寻找简单的解决方案",[260],{"type":185,"value":258},{"type":179,"tag":187,"props":262,"children":263},{},[264],{"type":185,"value":265},"要把基础库依赖的 vxe-table 直接替换为 Element Plus 表格很不现实。在没做过表格调研的情况下就迁移基础组件是不可接受的，何况我们只想改个滚动条样式。",{"type":179,"tag":187,"props":267,"children":268},{},[269],{"type":185,"value":270},"这是 ElTable 的示例。看着这漂亮的滚动条当时真是心痒痒呀！",{"type":179,"tag":187,"props":272,"children":273},{},[274],{"type":179,"tag":226,"props":275,"children":278},{"alt":276,"src":277},"element-plus table","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20230218231215.png?w=60",[],{"type":179,"tag":187,"props":280,"children":281},{},[282,284,291],{"type":185,"value":283},"讲到 Element Plus，能不能用 ",{"type":179,"tag":193,"props":285,"children":288},{"href":286,"rel":287},"https://element-plus.gitee.io/zh-CN/component/scrollbar.html",[197],[289],{"type":185,"value":290},"ElScrollbar",{"type":185,"value":292}," 组件做点什么呢？",{"type":179,"tag":187,"props":294,"children":295},{},[296],{"type":185,"value":297},"答案是否定的，因为 ElScrollbar 只能处理简单的滚动系统。",{"type":179,"tag":187,"props":299,"children":300},{},[301],{"type":185,"value":302},"如图所示，假设 ElScrollbar 组件 S 本身高 400px，其直接子元素 Children 高 1000px。这个场景足够简单，所以能轻易获取 S 的滚动余量有 600px。",{"type":179,"tag":187,"props":304,"children":305},{},[306],{"type":179,"tag":226,"props":307,"children":310},{"alt":308,"src":309},"Simple Scrollbar System","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20230219003509.png?w=50",[],{"type":179,"tag":187,"props":312,"children":313},{},[314],{"type":185,"value":315},"当组件有复杂的层级嵌套时，ElScrollbar 组件就不知道你要使用哪一个元素去计算滚动余量了。如图所示，在复杂情况下，ElScrollbar 的虚拟滚动条甚至会和原生滚动条出现冲突的情况。",{"type":179,"tag":187,"props":317,"children":318},{},[319],{"type":179,"tag":226,"props":320,"children":323},{"alt":321,"src":322},"Complex Scrollbar System","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20230219004750.png?w=50",[],{"type":179,"tag":180,"props":325,"children":327},{"id":326},"use-scrollbars-的诞生",[328],{"type":185,"value":329},"Use Scrollbars 的诞生",{"type":179,"tag":187,"props":331,"children":332},{},[333,335],{"type":185,"value":334},"这段时间想了许多方法，也试了不少开源轮子，它们都不能满足我“一键替换” vxe-table 及 vue-gantt-elastic 滚动条样式的需求。所以我找时间把温习了一下浏览器滚动系统相关知识，并把需求精简后，封装出顺手的工具，",{"type":179,"tag":193,"props":336,"children":339},{"href":337,"rel":338},"https://github.com/Lionad-Morotar/use-scrollbar",[197],[340],{"type":185,"value":341},"use-scrollbars",{"type":179,"tag":187,"props":343,"children":344},{},[345],{"type":179,"tag":226,"props":346,"children":348},{"alt":173,"src":347},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/logo.png?w=50&type=win11",[],{"type":179,"tag":187,"props":350,"children":351},{},[352],{"type":185,"value":353},"use-scrollbars 有以下几个特点：",{"type":179,"tag":355,"props":356,"children":357},"ol",{},[358,364,369,374],{"type":179,"tag":359,"props":360,"children":361},"li",{},[362],{"type":185,"value":363},"它支持定制复杂组件的滚动条样式",{"type":179,"tag":359,"props":365,"children":366},{},[367],{"type":185,"value":368},"它能提供比原生滚动条更丰富的样式、动画和交互效果",{"type":179,"tag":359,"props":370,"children":371},{},[372],{"type":185,"value":373},"它使用原生滚动事件而不是 CSS Transform 等低性能滚动方案",{"type":179,"tag":359,"props":375,"children":376},{},[377],{"type":185,"value":378},"它的状态是响应式的且有完整的类型提示",{"type":179,"tag":187,"props":380,"children":381},{},[382],{"type":185,"value":383},"第一点，也就是我的需求，use-scrollbars 能修改 vxe-table 等复杂组件的滚动条，这是 ElScrollbar 等其它开源组件目前无法实现的功能。第二点和第三点意味着更低的代码复杂度。第四点是说 use-scrollbars 是用 TypeSript 实现的 Vue Hook...",{"type":179,"tag":180,"props":385,"children":387},{"id":386},"使用示例",[388],{"type":185,"value":386},{"type":179,"tag":187,"props":390,"children":391},{},[392],{"type":185,"value":393},"对于简单的滚动系统，use-scrollbars 能做到 API 足够简单。",{"type":179,"tag":395,"props":396,"children":400},"pre",{"className":397,"code":398,"language":399,"meta":173,"style":173},"language-vue shik