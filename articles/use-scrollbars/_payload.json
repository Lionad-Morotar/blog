,"toc":1445},"root",[181,189,206,220,225,234,248,259,264,269,274,282,296,301,306,314,319,327,333,345,352,357,382,387,392,397,783,791,796,801,1120,1125,1288,1293,1390,1395,1413,1427,1439],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"原生滚动条样式一言难尽",[187],{"type":188,"value":185},"text",{"type":182,"tag":190,"props":191,"children":192},"p",{},[193,195,204],{"type":188,"value":194},"公司项目需要用到多表头等复杂的表格功能，一直使用 vxe-table 并在其基础上定制开发。但相比 Element Plus 的表格，它有一个对界面来说很不友好的缺陷：",{"type":182,"tag":196,"props":197,"children":201},"a",{"href":198,"rel":199},"https://vxetable.cn/#/table/base/scrollStyle",[200],"nofollow",[202],{"type":188,"value":203},"不能自定义滚动条",{"type":188,"value":205},"。使用原生滚动条会使表格右侧多出一块空白的区域，令人难受。",{"type":182,"tag":190,"props":207,"children":208},{},[209,211,218],{"type":188,"value":210},"年前，我们要在一个新系统中画甘特图，用到了在 Github 极其流行的 ",{"type":182,"tag":196,"props":212,"children":215},{"href":213,"rel":214},"https://github.com/neuronetio/gantt-elastic",[200],[216],{"type":188,"value":217},"vue-gantt-elastic",{"type":188,"value":219},"。并不出乎意料，这玩意儿也不支持自定义滚动条。",{"type":182,"tag":190,"props":221,"children":222},{},[223],{"type":188,"value":224},"也许大家没见过 Windows 的滚动条样式是到底有多么出戏。这里截张图给大家感受一下。",{"type":182,"tag":190,"props":226,"children":227},{},[228],{"type":182,"tag":229,"props":230,"children":233},"img",{"alt":231,"src":232},"CodePen","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20230218235213.png",[],{"type":182,"tag":190,"props":235,"children":236},{},[237,239,246],{"type":188,"value":238},"CSS 滚动条相关的规范如 ",{"type":182,"tag":196,"props":240,"children":243},{"href":241,"rel":242},"https://www.w3.org/TR/2021/CR-css-scrollbars-1-20211209/",[200],[244],{"type":188,"value":245},"CSS Scrollbars Styling Module",{"type":188,"value":247}," 所规范的功能不多，甚至可以说太弱了。它只描述了一些用来简单处理滚动条样式的属性，如宽度和颜色。考虑到 PC 端用户使用鼠标，给滚动条加上动画或鼠标交互也是完全合情合理的需求，所以依赖 CSS 滚动条规范完全不够用。",{"type":182,"tag":190,"props":249,"children":250},{},[251,253],{"type":188,"value":252},"但大佬对原生滚动条样式不满意，前端怎么能说不行呢，改！",{"type":182,"tag":254,"props":255,"children":256},"del",{},[257],{"type":188,"value":258},"（不是手痒痒了）",{"type":182,"tag":183,"props":260,"children":262},{"id":261},"寻找简单的解决方案",[263],{"type":188,"value":261},{"type":182,"tag":190,"props":265,"children":266},{},[267],{"type":188,"value":268},"要把基础库依赖的 vxe-table 直接替换为 Element Plus 表格很不现实。在没做过表格调研的情况下就迁移基础组件是不可接受的，何况我们只想改个滚动条样式。",{"type":182,"tag":190,"props":270,"children":271},{},[272],{"type":188,"value":273},"这是 ElTable 的示例。看着这漂亮的滚动条当时真是心痒痒呀！",{"type":182,"tag":190,"props":275,"children":276},{},[277],{"type":182,"tag":229,"props":278,"children":281},{"alt":279,"src":280},"element-plus table","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20230218231215.png?w=60",[],{"type":182,"tag":190,"props":283,"children":284},{},[285,287,294],{"type":188,"value":286},"讲到 Element Plus，能不能用 ",{"type":182,"tag":196,"props":288,"children":291},{"href":289,"rel":290},"https://element-plus.gitee.io/zh-CN/component/scrollbar.html",[200],[292],{"type":188,"value":293},"ElScrollbar",{"type":188,"value":295}," 组件做点什么呢？",{"type":182,"tag":190,"props":297,"children":298},{},[299],{"type":188,"value":300},"答案是否定的，因为 ElScrollbar 只能处理简单的滚动系统。",{"type":182,"tag":190,"props":302,"children":303},{},[304],{"type":188,"value":305},"如图所示，假设 ElScrollbar 组件 S 本身高 400px，其直接子元素 Children 高 1000px。这个场景足够简单，所以能轻易获取 S 的滚动余量有 600px。",{"type":182,"tag":190,"props":307,"children":308},{},[309],{"type":182,"tag":229,"props":310,"children":313},{"alt":311,"src":312},"Simple Scrollbar System","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20230219003509.png?w=50",[],{"type":182,"tag":190,"props":315,"children":316},{},[317],{"type":188,"value":318},"当组件有复杂的层级嵌套时，ElScrollbar 组件就不知道你要使用哪一个元素去计算滚动余量了。如图所示，在复杂情况下，ElScrollbar 的虚拟滚动条甚至会和原生滚动条出现冲突的情况。",{"type":182,"tag":190,"props":320,"children":321},{},[322],{"type":182,"tag":229,"props":323,"children":326},{"alt":324,"src":325},"Complex Scrollbar System","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20230219004750.png?w=50",[],{"type":182,"tag":183,"props":328,"children":330},{"id":329},"use-scrollbars-的诞生",[331],{"type":188,"value":332},"Use Scrollbars 的诞生",{"type":182,"tag":190,"props":334,"children":335},{},[336,338],{"type":188,"value":337},"这段时间想了许多方法，也试了不少开源轮子，它们都不能满足我“一键替换” vxe-table 及 vue-gantt-elastic 滚动条样式的需求。所以我找时间把温习了一下浏览器滚动系统相关知识，并把需求精简后，封装出顺手的工具，",{"type":182,"tag":196,"props":339,"children":342},{"href":340,"rel":341},"https://github.com/Lionad-Morotar/use-scrollbar",[200],[343],{"type":188,"value":344},"use-scrollbars",{"type":182,"tag":190,"props":346,"children":347},{},[348],{"type":182,"tag":229,"props":349,"children":351},{"alt":176,"src":350},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/logo.png?w=50&type=win11",[],{"type":182,"tag":190,"props":353,"children":354},{},[355],{"type":188,"value":356},"use-scrollbars 有以下几个特点：",{"type":182,"tag":358,"props":359,"children":360},"ol",{},[361,367,372,377],{"type":182,"tag":362,"props":363,"children":364},"li",{},[365],{"type":188,"value":366},"它支持定制复杂组件的滚动条样式",{"type":182,"tag":362,"props":368,"children":369},{},[370],{"type":188,"value":371},"它能提供比原生滚动条更丰富的样式、动画和交互效果",{"type":182,"tag":362,"props":373,"children":374},{},[375],{"type":188,"value":376},"它使用原生滚动事件而不是 CSS Transform 等低性能滚动方案",{"type":182,"tag":362,"props":378,"children":379},{},[380],{"type":188,"value":381},"它的状态是响应式的且有完整的类型提示",{"type":182,"tag":190,"props":383,"children":384},{},[385],{"type":188,"value":386},"第一点，也就是我的需求，use-scrollbars 能修改 vxe-table 等复杂组件的滚动条，这是 ElScrollbar 等其它开源组件目前无法实现的功能。第二点和第三点意味着更低的代码复杂度。第四点是说 use-scrollbars 是用 TypeSript 实现的 Vue Hook...",{"type":182,"tag":183,"props":388,"children":390},{"id":389},"使用示例",[391],{"type":188,"value":389},{"type":182,"tag":190,"props":393,"children":394},{},[395],{"type":188,"value":396},"对于简单的滚动系统，use-scrollbars 能做到 API 足够简单。",{"type":182,"tag":398,"props":399,"children":403},"pre",{"className":400,"code":401,"la