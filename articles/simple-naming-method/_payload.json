81,189,204,209,215,228,240,254,259,273,278,317,321,326,331,352,365,371,397,409,420,425,441,462,474,632,638],{"type":182,"tag":183,"props":184,"children":185},"element","p",{},[186],{"type":187,"value":188},"text","太多项目要跑，端口号命名是个麻烦的问题。",{"type":182,"tag":190,"props":191,"children":192},"ul",{},[193,199],{"type":182,"tag":194,"props":195,"children":196},"li",{},[197],{"type":187,"value":198},"Vibe 流行的这两年，新项目眼花缭乱，太多项目要本地启动才能验证和消化，多个项目端口号容易冲突",{"type":182,"tag":194,"props":200,"children":201},{},[202],{"type":187,"value":203},"为了在浏览器保存标签页（或书签），每个项目的端口号是不能改变。",{"type":182,"tag":183,"props":205,"children":206},{},[207],{"type":187,"value":208},"比如，我电脑上光 Nuxt 应用程序就十来个，清一色的 3000 端口，肯定不行，所以创建了一套简单有效的端口命名规则，用来约定项目端口号。",{"type":182,"tag":210,"props":211,"children":213},"h2",{"id":212},"核心思路",[214],{"type":187,"value":212},{"type":182,"tag":183,"props":216,"children":217},{},[218,220,226],{"type":187,"value":219},"与其随意挑选数字，不如把 ",{"type":182,"tag":221,"props":222,"children":223},"strong",{},[224],{"type":187,"value":225},"项目名称映射到键盘上对应的数字",{"type":187,"value":227}," 来生成一个“可读、可记”的端口。只要结果落在合法的端口范围（0 ~ 65535），且不占用系统保留端口，就可以直接使用。",{"type":182,"tag":183,"props":229,"children":230},{},[231,233,238],{"type":187,"value":232},"即按照标准 QWERTY 键盘的 ",{"type":182,"tag":221,"props":234,"children":235},{},[236],{"type":187,"value":237},"行列坐标",{"type":187,"value":239}," 把每个字母映射为一个单数字，举个例子",{"type":182,"tag":183,"props":241,"children":242},{},[243,245,252],{"type":187,"value":244},"“cfetch” → ",{"type":182,"tag":246,"props":247,"children":249},"code",{"className":248},[],[250],{"type":187,"value":251},"c(3) f(4) e(3) t(5) c(3) h(6)",{"type":187,"value":253},"，取前四位即 3453 或全部五位 34353 都可以。",{"type":182,"tag":183,"props":255,"children":256},{},[257],{"type":187,"value":258},"有些项目前端、后端、数据库等等包含多个端口号，则以下两种命名方式二选一：",{"type":182,"tag":260,"props":261,"children":262},"ol",{},[263,268],{"type":182,"tag":194,"props":264,"children":265},{},[266],{"type":187,"value":267},"“cfetch”，取 3435，然后前端（fe，即 43）取 34354，后端（server）取 34352，数据库（mongo）取34357，以此类推",{"type":182,"tag":194,"props":269,"children":270},{},[271],{"type":187,"value":272},"“cfetch”，取 3435，然后 Web 取 34351，后端取 34352，数据库取34353，以此类推",{"type":182,"tag":210,"props":274,"children":276},{"id":275},"端口号的合法范围",[277],{"type":187,"value":275},{"type":182,"tag":190,"props":279,"children":280},{},[281,293,312],{"type":182,"tag":194,"props":282,"children":283},{},[284,286,291],{"type":187,"value":285},"端口号必须在 ",{"type":182,"tag":221,"props":287,"children":288},{},[289],{"type":187,"value":290},"0‑65535",{"type":187,"value":292}," 范围内。",{"type":182,"tag":194,"props":294,"children":295},{},[296,298,303,305,310],{"type":187,"value":297},"对于自定义服务，一般建议使用 ",{"type":182,"tag":221,"props":299,"children":300},{},[301],{"type":187,"value":302},"1024 ~ 49151",{"type":187,"value":304},"（非系统保留范围）或更高的 ",{"type":182,"tag":221,"props":306,"children":307},{},[308],{"type":187,"value":309},"49152 ~ 65535",{"type":187,"value":311},"（私有/动态端口）。",{"type":182,"tag":194,"props":313,"children":314},{},[315],{"type":187,"value":316},"只要映射得到的数值不超过上述上限，就算有效。",{"type":182,"tag":318,"props":319,"children":320},"hr",{},[],{"type":182,"tag":183,"props":322,"children":323},{},[324],{"type":187,"value":325},"AI Translation",{"type":182,"tag":183,"props":327,"children":328},{},[329],{"type":187,"value":330},"When you’re running a bunch of projects locally, picking port numbers becomes annoying.",{"type":182,"tag":190,"props":332,"children":333},{},[334,347],{"type":182,"tag":194,"props":335,"children":336},{},[337,339,345],{"type":187,"value":338},"Over the last couple of years, there have been ",{"type":182,"tag":340,"props":341,"children":342},"em",{},[343],{"type":187,"value":344},"so many",{"type":187,"value":346}," new projects. To really try them out, you often need to boot them locally—and then ports start colliding.",{"type":182,"tag":194,"props":348,"children":349},{},[350],{"type":187,"value":351},"If you want to keep browser tabs (or bookmarks) stable, a project’s port shouldn’t keep changing.",{"type":182,"tag":183,"props":353,"children":354},{},[355,357,363],{"type":187,"value":356},"For example, I have more than ten Nuxt apps on my machine. If they all default to ",{"type":182,"tag":246,"props":358,"children":360},{"className":359},[],[361],{"type":187,"value":362},"3000",{"type":187,"value":364},", that’s obviously not going to work. So I came up with a simple, consistent port naming rule to “assign” ports per project.",{"type":182,"tag":210,"props":366,"children":368},{"id":367},"core-idea",[369],{"type":187,"value":370},"Core idea",{"type":182,"tag":183,"props":372,"children":373},{},[374,376,381,383,388,390,395],{"type":187,"value":375},"Instead of picking random numbers, map the ",{"type":182,"tag":221,"props":377,"children":378},{},[379],{"type":187,"value":380},"project name to numbers based on the keyboard",{"type":187,"value":382},", so the port is ",{"type":182,"tag":340,"props":384,"children":385},{},[386],{"type":187,"value":387},"readable",{"type":187,"value":389}," and ",{"type":182,"tag":340,"props":391,"children":392},{},[393],{"type":187,"value":394},"memorable",{"type":187,"value":396},".",{"type":182,"tag":183,"props":398,"children":399},{},[400,402,407],{"type":187,"value":401},"As long as the result is within the valid port range (",{"type":182,"tag":221,"props":403,"children":404},{},[405],{"type":187,"value":406},"0–65535",{"type":187,"value":408},") and doesn’t hit reserved/system ports, you can just use it.",{"type":182,"tag":183,"props":410,"children":411},{},[412,414,419],{"type":187,"value":413},"More specifically: using a standard QWERTY keyboard, map each letter to a single digit based on its ",{"type":182,"tag":221,"props":415,"children":416},{},[417],{"type":187,"value":418},"row/column position",{"type":187,"value":396},{"type":182,"tag":183,"props":421,"children":422},{},[423],{"type":187,"value":424},"Example:",{"type":182,"tag":183,"props":426,"children":427},{},[428,434,436],{"type":182,"tag":246,"props":429,"children":431},{"className":430},[],[432],{"type":187,"value":433},"\"cfetch\"",{"type":187,"value":435}," → ",{"type":182,"tag":246,"props":437,"children":439},{"className":438},[],[440],{"type":187,"value":251},{"type":182,"tag":183,"props":442,"children":443},{},[444,446,452,454,460],{"type":187,"value":445},"Then you can take the first 4 digits (e.g. ",{"type":182,"tag":246,"props":447,"children":449},{"className":448},[],[450],{"type":187,"value":451},"3453",{"type":187,"value":453},"), or keep more digits (e.g. ",{"type":182,"tag":246,"props":455,"children":457},{"className":456},[],[458],{"type":187,"value":459},"34353",{"type":187,"value":461},"). Either is fine.",{"type":182,"tag":183,"props":463,"children":464},{},[465,467,472],{"type":187,"value":466},"If a project needs multiple ports (frontend, backend, database, etc.), pick ",{"type":182,"tag":221,"props":468,"children":469},{},[470],{"type":187,"value":471},"one",{"type":187,"value":473}," of these two approaches:",{"type":182,"tag":260,"props":475,"children":476},{},[477,573],{"type":182,"tag":194,"props":478,"children":479},{},[480,482],{"type":187,"value":481},"Use the project prefix, then append a “role suffix”",{"type":182,"tag":190,"props":483,"children":484},{},[485,505,532,550,568],{"type":182,"tag":194,"props":486,"children":487},{},[488,490,495,497,503],{"type":187,"value":489},"For ",{"type":182,"tag":246,"props":491,"children":493},{"className":492},[],[494],{"type":187,"value":433},{"type":187,"value":496},", take ",{"type":182,"tag":246,"props":498,"children":500},{"className":499},[],[501],{"type":187,"value":502},"3435",{"type":187,"value":504}," as the base",{"type":182,"tag":194,"props":506,"children":507},{},[508,510,516,518,524,526],{"type":187,"value":509},"Frontend (",{"type":182,"tag":246,"props":511,"children":513},{"className":512},[],[514],{"type":187,"value":515},"fe",{"type":187,"value":517},", i.e. ",{"type":182,"tag":246,"props":519,"children":521},{"className":520},[],[522],{"type":187,"value":523},"43",{"type":187,"value":525},") → ",{"type":182,"tag":246,"props":527,"children":529},{"className":528},[],[530],{"type":187,"value":531},"34354",{"type":182,"tag":194,"props":533,"children":534},{},[535,537,543,544],{"type":187,"value":536},"Backend (",{"type":182,"tag":246,"props":538,"children":540},{"className":539},[],[541],{"type":187,"value":542},"server",{"type":187,"value":525},{"type":182,"tag":246,"props":545,"children":547},{"className":546},[],[548],{"type":187,"value":549},"34352",{"type":182,"tag":194,"props":551,"children":552},{},[553,555,561,562],{"type":187,"value":554},"Database (",{"type":182,"tag":246,"props":556,"children":558},{"className":557},[],[559],{"type":187,"value":560},"mongo",{"type":187,"value":525},{"type":182,"tag":246,"props":563,"children":565},{"className":564},[],[566],{"type":187,"value":567},"34357",{"type":182,"tag":194,"props":569,"children":570},{},[571],{"type":187,"value":572},"…and so on",{"type":182,"tag":194,"props":574,"children":575},{},[576,578],{"type":187,"value":577},"Use the project prefix, then assign sequential roles",{"type":182,"tag":190,"props":579,"children":580},{},[581,597,608,618,628],{"type":182,"tag":194,"props":582,"children":583},{},[584,585,590,591,596],{"type":187,"value":489},{"type":182,"tag":246,"props":586,"children":588},{"className":587},[],[589],{"type":187,"value":433},{"type":187,"value":496},{"type":182,"tag":246,"props":592,"children":594},{"className":593},[],[595],{"type":187,"value":502},{"type":187,"value":504},{"type":182,"tag":194,"props":598,"children":599},{},[600,602],{"type":187,"value":601},"Web → ",{"type":182,"tag":246,"props":603,"children":605},{"className":604},[],[606],{"type":187,"value":607},"34351",{"type":182,"tag":194,"props":609,"children":610},{},[611,613],{"type":187,"value":612},"Backend → ",{"type":182,"tag":246,"props":614,"children":616},{"className":615},[],[617],{"type":187,"value":549},{"type":182,"tag":194,"props":619,"children":620},{},[621,623],{"type":187,"value":622},"Database → ",{"type":182,"tag":246,"props":624,"children":626},{"className":625},[],[627],{"type":187,"value":459},{"type":182,"tag":194,"props":629,"children":630},{},[631],{"type":187,"value":572},{"type":182,"tag":210,"props":633,"children":635},{"id":634},"valid-port-range",[636],{"type":187,"value":637},"Valid port range",{"type":182,"tag":190,"props":639,"children":640},{},[641,651,670],{"type":182,"tag":194,"props":642,"children":643},{},[644,646,650],{"type":187,"value":645},"Ports must be within ",{"type":182,"tag":221,"props":647,"children":648},{},[649],{"type":187,"value":406},{"type":187,"value":396},{"type":182,"tag":194,"props":652,"children":653},{},[654,656,661,663,668],{"type":187,"value":655},"For custom services, it’s usually best to use ",{"type":182,"tag":221,"props":657,"children":658},{},[659],{"type":187,"value":660},"1024–49151",{"type":187,"value":662}," (non-reserved) or ",{"type":182,"tag":221,"props":664,"children":665},{},[666],{"type":187,"value":667},"49152–65535",{"type":187,"value":669}," (private/dynamic).",{"type":182,"tag":194,"props":671,"children":672},{},[673],{"type":187,"value":674},"As long as the mapped number stays under the limit, it’s valid.",{"title":176,"searchDepth":676,"depth":676,"links":677},2,[678,679,680,681],{"id":212,"depth":676,"text":212},{"id":275,"depth":676,"text":275},{"id":367,"depth":676,"text":370},{"id":634,"depth":676,"text":637},"markdown","content:2.articles:1093.simple-naming-method.md","content","2.articles/1093.simple-naming-method.md","2.articles/1093.simple-naming-method","md",[689,691],{"_path":37,"title":40,"description":690},"笔记、博客以及碎碎念，我的思考和再创造。",{"_path":46,"title":45,"description":692},"tailwind4 不支持 sass 的解决方法",1772185439753]