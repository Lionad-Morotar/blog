,328,349,362,368,394,406,417,422,438,459,471,629,635],{"type":179,"tag":180,"props":181,"children":182},"element","p",{},[183],{"type":184,"value":185},"text","太多项目要跑，端口号命名是个麻烦的问题。",{"type":179,"tag":187,"props":188,"children":189},"ul",{},[190,196],{"type":179,"tag":191,"props":192,"children":193},"li",{},[194],{"type":184,"value":195},"Vibe 流行的这两年，新项目眼花缭乱，太多项目要本地启动才能验证和消化，多个项目端口号容易冲突",{"type":179,"tag":191,"props":197,"children":198},{},[199],{"type":184,"value":200},"为了在浏览器保存标签页（或书签），每个项目的端口号是不能改变。",{"type":179,"tag":180,"props":202,"children":203},{},[204],{"type":184,"value":205},"比如，我电脑上光 Nuxt 应用程序就十来个，清一色的 3000 端口，肯定不行，所以创建了一套简单有效的端口命名规则，用来约定项目端口号。",{"type":179,"tag":207,"props":208,"children":210},"h2",{"id":209},"核心思路",[211],{"type":184,"value":209},{"type":179,"tag":180,"props":213,"children":214},{},[215,217,223],{"type":184,"value":216},"与其随意挑选数字，不如把 ",{"type":179,"tag":218,"props":219,"children":220},"strong",{},[221],{"type":184,"value":222},"项目名称映射到键盘上对应的数字",{"type":184,"value":224}," 来生成一个“可读、可记”的端口。只要结果落在合法的端口范围（0 ~ 65535），且不占用系统保留端口，就可以直接使用。",{"type":179,"tag":180,"props":226,"children":227},{},[228,230,235],{"type":184,"value":229},"即按照标准 QWERTY 键盘的 ",{"type":179,"tag":218,"props":231,"children":232},{},[233],{"type":184,"value":234},"行列坐标",{"type":184,"value":236}," 把每个字母映射为一个单数字，举个例子",{"type":179,"tag":180,"props":238,"children":239},{},[240,242,249],{"type":184,"value":241},"“cfetch” → ",{"type":179,"tag":243,"props":244,"children":246},"code",{"className":245},[],[247],{"type":184,"value":248},"c(3) f(4) e(3) t(5) c(3) h(6)",{"type":184,"value":250},"，取前四位即 3453 或全部五位 34353 都可以。",{"type":179,"tag":180,"props":252,"children":253},{},[254],{"type":184,"value":255},"有些项目前端、后端、数据库等等包含多个端口号，则以下两种命名方式二选一：",{"type":179,"tag":257,"props":258,"children":259},"ol",{},[260,265],{"type":179,"tag":191,"props":261,"children":262},{},[263],{"type":184,"value":264},"“cfetch”，取 3435，然后前端（fe，即 43）取 34354，后端（server）取 34352，数据库（mongo）取34357，以此类推",{"type":179,"tag":191,"props":266,"children":267},{},[268],{"type":184,"value":269},"“cfetch”，取 3435，然后 Web 取 34351，后端取 34352，数据库取34353，以此类推",{"type":179,"tag":207,"props":271,"children":273},{"id":272},"端口号的合法范围",[274],{"type":184,"value":272},{"type":179,"tag":187,"props":276,"children":277},{},[278,290,309],{"type":179,"tag":191,"props":279,"children":280},{},[281,283,288],{"type":184,"value":282},"端口号必须在 ",{"type":179,"tag":218,"props":284,"children":285},{},[286],{"type":184,"value":287},"0‑65535",{"type":184,"value":289}," 范围内。",{"type":179,"tag":191,"props":291,"children":292},{},[293,295,300,302,307],{"type":184,"value":294},"对于自定义服务，一般建议使用 ",{"type":179,"tag":218,"props":296,"children":297},{},[298],{"type":184,"value":299},"1024 ~ 49151",{"type":184,"value":301},"（非系统保留范围）或更高的 ",{"type":179,"tag":218,"props":303,"children":304},{},[305],{"type":184,"value":306},"49152 ~ 65535",{"type":184,"value":308},"（私有/动态端口）。",{"type":179,"tag":191,"props":310,"children":311},{},[312],{"type":184,"value":313},"只要映射得到的数值不超过上述上限，就算有效。",{"type":179,"tag":315,"props":316,"children":317},"hr",{},[],{"type":179,"tag":180,"props":319,"children":320},{},[321],{"type":184,"value":322},"AI Translation",{"type":179,"tag":180,"props":324,"children":325},{},[326],{"type":184,"value":327},"When you’re running a bunch of projects locally, picking port numbers becomes annoying.",{"type":179,"tag":187,"props":329,"children":330},{},[331,344],{"type":179,"tag":191,"props":332,"children":333},{},[334,336,342],{"type":184,"value":335},"Over the last couple of years, there have been ",{"type":179,"tag":337,"props":338,"children":339},"em",{},[340],{"type":184,"value":341},"so many",{"type":184,"value":343}," new projects. To really try them out, you often need to boot them locally—and then ports start colliding.",{"type":179,"tag":191,"props":345,"children":346},{},[347],{"type":184,"value":348},"If you want to keep browser tabs (or bookmarks) stable, a project’s port shouldn’t keep changing.",{"type":179,"tag":180,"props":350,"children":351},{},[352,354,360],{"type":184,"value":353},"For example, I have more than ten Nuxt apps on my machine. If they all default to ",{"type":179,"tag":243,"props":355,"children":357},{"className":356},[],[358],{"type":184,"value":359},"3000",{"type":184,"value":361},", that’s obviously not going to work. So I came up with a simple, consistent port naming rule to “assign” ports per project.",{"type":179,"tag":207,"props":363,"children":365},{"id":364},"core-idea",[366],{"type":184,"value":367},"Core idea",{"type":179,"tag":180,"props":369,"children":370},{},[371,373,378,380,385,387,392],{"type":184,"value":372},"Instead of picking random numbers, map the ",{"type":179,"tag":218,"props":374,"children":375},{},[376],{"type":184,"value":377},"project name to numbers based on the keyboard",{"type":184,"value":379},", so the port is ",{"type":179,"tag":337,"props":381,"children":382},{},[383],{"type":184,"value":384},"readable",{"type":184,"value":386}," and ",{"type":179,"tag":337,"props":388,"children":389},{},[390],{"type":184,"value":391},"memorable",{"type":184,"value":393},".",{"type":179,"tag":180,"props":395,"children":396},{},[397,399,404],{"type":184,"value":398},"As long as the result is within the valid port range (",{"type":179,"tag":218,"props":400,"children":401},{},[402],{"type":184,"value":403},"0–65535",{"type":184,"value":405},") and doesn’t hit reserved/system ports, you can just use it.",{"type":179,"tag":180,"props":407,"children":408},{},[409,411,416],{"type":184,"value":410},"More specifically: using a standard QWERTY keyboard, map each letter to a single digit based on its ",{"type":179,"tag":218,"props":412,"children":413},{},[414],{"type":184,"value":415},"row/column position",{"type":184,"value":393},{"type":179,"tag":180,"props":418,"children":419},{},[420],{"type":184,"value":421},"Example:",{"type":179,"tag":180,"props":423,"children":424},{},[425,431,433],{"type":179,"tag":243,"props":426,"children":428},{"className":427},[],[429],{"type":184,"value":430},"\"cfetch\"",{"type":184,"value":432}," → ",{"type":179,"tag":243,"props":434,"children":436},{"className":435},[],[437],{"type":184,"value":248},{"type":179,"tag":180,"props":439,"children":440},{},[441,443,449,451,457],{"type":184,"value":442},"Then you can take the first 4 digits (e.g. ",{"type":179,"tag":243,"props":444,"children":446},{"className":445},[],[447],{"type":184,"value":448},"3453",{"type":184,"value":450},"), or keep more digits (e.g. ",{"type":179,"tag":243,"props":452,"children":454},{"className":453},[],[455],{"type":184,"value":456},"34353",{"type":184,"value":458},"). Either is fine.",{"type":179,"tag":180,"props":460,"children":461},{},[462,464,469],{"type":184,"value":463},"If a project needs multiple ports (frontend, backend, database, etc.), pick ",{"type":179,"tag":218,"props":465,"children":466},{},[467],{"type":184,"value":468},"one",{"type":184,"value":470}," of these two approaches:",{"type":179,"tag":257,"props":472,"children":473},{},[474,570],{"type":179,"tag":191,"props":475,"children":476},{},[477,479],{"type":184,"value":478},"Use the project prefix, then append a “role suffix”",{"type":179,"tag":187,"props":480,"children":481},{},[482,502,529,547,565],{"type":179,"tag":191,"props":483,"children":484},{},[485,487,492,494,500],{"type":184,"value":486},"For ",{"type":179,"tag":243,"props":488,"children":490},{"className":489},[],[491],{"type":184,"value":430},{"type":184,"value":493},", take ",{"type":179,"tag":243,"props":495,"children":497},{"className":496},[],[498],{"type":184,"value":499},"3435",{"type":184,"value":501}," as the base",{"type":179,"tag":191,"props":503,"children":504},{},[505,507,513,515,521,523],{"type":184,"value":506},"Frontend (",{"type":179,"tag":243,"props":508,"children":510},{"className":509},[],[511],{"type":184,"value":512},"fe",{"type":184,"value":514},", i.e. ",{"type":179,"tag":243,"props":516,"children":518},{"className":517},[],[519],{"type":184,"value":520},"43",{"type":184,"value":522},") → ",{"type":179,"tag":243,"props":524,"children":526},{"className":525},[],[527],{"type":184,"value":528},"34354",{"type":179,"tag":191,"props":530,"children":531},{},[532,534,540,541],{"type":184,"value":533},"Backend (",{"type":179,"tag":243,"props":535,"children":537},{"className":536},[],[538],{"type":184,"value":539},"server",{"type":184,"value":522},{"type":179,"tag":243,"props":542,"children":544},{"className":543},[],[545],{"type":184,"value":546},"34352",{"type":179,"tag":191,"props":548,"children":549},{},[550,552,558,559],{"type":184,"value":551},"Database (",{"type":179,"tag":243,"props":553,"children":555},{"className":554},[],[556],{"type":184,"value":557},"mongo",{"type":184,"value":522},{"type":179,"tag":243,"props":560,"children":562},{"className":561},[],[563],{"type":184,"value":564},"34357",{"type":179,"tag":191,"props":566,"children":567},{},[568],{"type":184,"value":569},"…and so on",{"type":179,"tag":191,"props":571,"children":572},{},[573,575],{"type":184,"value":574},"Use the project prefix, then assign sequential roles",{"type":179,"tag":187,"props":576,"children":577},{},[578,594,605,615,625],{"type":179,"tag":191,"props":579,"children":580},{},[581,582,587,588,593],{"type":184,"value":486},{"type":179,"tag":243,"props":583,"children":585},{"className":584},[],[586],{"type":184,"value":430},{"type":184,"value":493},{"type":179,"tag":243,"props":589,"children":591},{"className":590},[],[592],{"type":184,"value":499},{"type":184,"value":501},{"type":179,"tag":191,"props":595,"children":596},{},[597,599],{"type":184,"value":598},"Web → ",{"type":179,"tag":243,"props":600,"children":602},{"className":601},[],[603],{"type":184,"value":604},"34351",{"type":179,"tag":191,"props":606,"children":607},{},[608,610],{"type":184,"value":609},"Backend → ",{"type":179,"tag":243,"props":611,"children":613},{"className":612},[],[614],{"type":184,"value":546},{"type":179,"tag":191,"props":616,"children":617},{},[618,620],{"type":184,"value":619},"Database → ",{"type":179,"tag":243,"props":621,"children":623},{"className":622},[],[624],{"type":184,"value":456},{"type":179,"tag":191,"props":626,"children":627},{},[628],{"type":184,"value":569},{"type":179,"tag":207,"props":630,"children":632},{"id":631},"valid-port-range",[633],{"type":184,"value":634},"Valid port range",{"type":179,"tag":187,"props":636,"children":637},{},[638,648,667],{"type":179,"tag":191,"props":639,"children":640},{},[641,643,647],{"type":184,"value":642},"Ports must be within ",{"type":179,"tag":218,"props":644,"children":645},{},[646],{"type":184,"value":403},{"type":184,"value":393},{"type":179,"tag":191,"props":649,"children":650},{},[651,653,658,660,665],{"type":184,"value":652},"For custom services, it’s usually best to use ",{"type":179,"tag":218,"props":654,"children":655},{},[656],{"type":184,"value":657},"1024–49151",{"type":184,"value":659}," (non-reserved) or ",{"type":179,"tag":218,"props":661,"children":662},{},[663],{"type":184,"value":664},"49152–65535",{"type":184,"value":666}," (private/dynamic).",{"type":179,"tag":191,"props":668,"children":669},{},[670],{"type":184,"value":671},"As long as the mapped number stays under the limit, it’s valid.",{"title":173,"searchDepth":673,"depth":673,"links":674},2,[675,676,677,678],{"id":209,"depth":673,"text":209},{"id":272,"depth":673,"text":272},{"id":364,"depth":673,"text":367},{"id":631,"depth":673,"text":634},"markdown","content:2.articles:1093.simple-naming-method.md","content","2.articles/1093.simple-naming-method.md","2.articles/1093.simple-naming-method","md",[686,688],{"_path":37,"title":40,"description":687},"笔记、博客以及碎碎念，我的思考和再创造。",{"_path":46,"title":45,"description":689},"tailwind4 不支持 sass 的解决方法",1771214180162]