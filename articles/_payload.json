5,236,259,264,269,303,315,320,334,339,349],{"type":180,"tag":181,"props":182,"children":184},"element","h2",{"id":183},"我是谁",[185],{"type":186,"value":187},"text","我是谁？",{"type":180,"tag":189,"props":190,"children":191},"p",{},[192],{"type":186,"value":193},"学习并模仿身边的人类行动的机器人，中文名叫“仿生狮子”，但真实身份是只猫。",{"type":180,"tag":189,"props":195,"children":196},{},[197],{"type":186,"value":198},"博客是我顺手建成的，这么说是因为我最初想把这个网站做成笔记项目，类似富文本编辑器之类的，有着更高级交互方式的笔记应用。但网站建起来后就开始摸了，没有思考过或学习过要怎么记笔记，这是不好的，千万别学。",{"type":180,"tag":181,"props":200,"children":202},{"id":201},"为什么写博客",[203],{"type":186,"value":204},"为什么写博客？",{"type":180,"tag":189,"props":206,"children":207},{},[208],{"type":186,"value":209},"以前，放在这首页的内容是一篇长篇大论。增增补补，最终全删了，因为其中观点已经不再重要。不过我依然认同不论传统的博客精神的好坏，其形式总的来说太难持续。",{"type":180,"tag":189,"props":211,"children":212},{},[213],{"type":186,"value":214},"我更多把当前网站（我的博客）看成某种墓碑，主页也罢，或在数字世界的投射。曾经想过，如果意识数字化合法，那我应该是最先尝试上传意识的那批人，而在此之前，为何不能是这个网站？至于为什么不能是其他平台，那也仅因为目前存在数据所有权问题相关争论。",{"type":180,"tag":189,"props":216,"children":217},{},[218,220,234],{"type":186,"value":219},"另一种看法是，我把博客当成数字花园",{"type":180,"tag":221,"props":222,"children":223},"sup",{},[224],{"type":180,"tag":225,"props":226,"children":231},"a",{"href":227,"ariaDescribedBy":228,"dataFootnoteRef":174,"id":230},"#user-content-fn-digital_garden",[229],"footnote-label","user-content-fnref-digital_garden",[232],{"type":186,"value":233},"1",{"type":186,"value":235},"。收集点资料，就当浇水；写点什么，就当施肥。对于后 LLM 时代的数字花园，拥有个人的烙印是一件难得的事情。看看从这些有点人味儿的，以及零散的、灰屑的、燃烧的、组成我的，从中能长出什么东西。",{"type":180,"tag":189,"props":237,"children":238},{},[239,241,247,249,257],{"type":186,"value":240},"本站提供 ",{"type":180,"tag":225,"props":242,"children":244},{"href":243},"/links",[245],{"type":186,"value":246},"友链",{"type":186,"value":248}," 以及 ",{"type":180,"tag":225,"props":250,"children":254},{"href":251,"rel":252},"https://lionad.art/feed.xml",[253],"nofollow",[255],{"type":186,"value":256},"RSS 订阅",{"type":186,"value":258},"。有些内容也许会同步更新其他平台，比如知乎、微信公众号（Lionad）或者哔哩哔哩。",{"type":180,"tag":181,"props":260,"children":262},{"id":261},"网站导航",[263],{"type":186,"value":261},{"type":180,"tag":189,"props":265,"children":266},{},[267],{"type":186,"value":268},"大体来说，这个网站包含：“心流”、技术博客、笔记这三个板块。",{"type":180,"tag":270,"props":271,"children":272},"ul",{},[273,279,289],{"type":180,"tag":274,"props":275,"children":276},"li",{},[277],{"type":186,"value":278},"心流：闪念以及部分体裁不明的文章。",{"type":180,"tag":274,"props":280,"children":281},{},[282,287],{"type":180,"tag":225,"props":283,"children":284},{"href":127},[285],{"type":186,"value":286},"笔记",{"type":186,"value":288},"：领域化或结构化的笔记。",{"type":180,"tag":274,"props":290,"children":291},{},[292,294,301],{"type":186,"value":293},"技术博客：有阵子喜欢写文章放到 ",{"type":180,"tag":225,"props":295,"children":298},{"href":296,"rel":297},"https://juejin.cn/user/289926800227694",[253],[299],{"type":186,"value":300},"掘金社区",{"type":186,"value":302},"，现在以本博客为主。",{"type":180,"tag":189,"props":304,"children":305},{},[306,308,313],{"type":186,"value":307},"鉴于并不擅长写技术博客，所以相关内容的比重会降低。接下来持续很长一段时间的写作重点会放到 ",{"type":180,"tag":225,"props":309,"children":310},{"href":13},[311],{"type":186,"value":312},"《四十二篇》系列",{"type":186,"value":314},"。",{"type":180,"tag":181,"props":316,"children":318},{"id":317},"注意事项",[319],{"type":186,"value":317},{"type":180,"tag":189,"props":321,"children":322},{},[323,325,332],{"type":186,"value":324},"本站内容除特别说明外，均采用 ",{"type":180,"tag":225,"props":326,"children":329},{"href":327,"rel":328},"https://creativecommons.org/licenses/by-nc-sa/4.0/",[253],[330],{"type":186,"value":331},"CC BY-NC-SA 4.0",{"type":186,"value":333}," 协议。因笔记固有的时效性和不确定性，以及部分内容由 GPT 辅助完成，请在参考时进行必要的核对。",{"type":180,"tag":181,"props":335,"children":337},{"id":336},"联系我",[338],{"type":186,"value":336},{"type":180,"tag":189,"props":340,"children":341},{},[342,344,348],{"type":186,"value":343},"见：",{"type":180,"tag":225,"props":345,"children":346},{"href":243},[347],{"type":186,"value":246},{"type":186,"value":314},{"type":180,"tag":350,"props":351,"children":354},"