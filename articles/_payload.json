ren":181,"toc":393},"root",[182,191,197,202,208,213,218,239,262,267,272,306,318,323,337,342,352],{"type":183,"tag":184,"props":185,"children":187},"element","h2",{"id":186},"我是谁",[188],{"type":189,"value":190},"text","我是谁？",{"type":183,"tag":192,"props":193,"children":194},"p",{},[195],{"type":189,"value":196},"学习并模仿身边的人类行动的机器人，中文名叫“仿生狮子”，但真实身份是只猫。",{"type":183,"tag":192,"props":198,"children":199},{},[200],{"type":189,"value":201},"博客是我顺手建成的，这么说是因为我最初想把这个网站做成笔记项目，类似富文本编辑器之类的，有着更高级交互方式的笔记应用。但网站建起来后就开始摸了，没有思考过或学习过要怎么记笔记，这是不好的，千万别学。",{"type":183,"tag":184,"props":203,"children":205},{"id":204},"为什么写博客",[206],{"type":189,"value":207},"为什么写博客？",{"type":183,"tag":192,"props":209,"children":210},{},[211],{"type":189,"value":212},"以前，放在这首页的内容是一篇长篇大论。增增补补，最终全删了，因为其中观点已经不再重要。不过我依然认同不论传统的博客精神的好坏，其形式总的来说太难持续。",{"type":183,"tag":192,"props":214,"children":215},{},[216],{"type":189,"value":217},"我更多把当前网站（我的博客）看成某种墓碑，主页也罢，或在数字世界的投射。曾经想过，如果意识数字化合法，那我应该是最先尝试上传意识的那批人，而在此之前，为何不能是这个网站？至于为什么不能是其他平台，那也仅因为目前存在数据所有权问题相关争论。",{"type":183,"tag":192,"props":219,"children":220},{},[221,223,237],{"type":189,"value":222},"另一种看法是，我把博客当成数字花园",{"type":183,"tag":224,"props":225,"children":226},"sup",{},[227],{"type":183,"tag":228,"props":229,"children":234},"a",{"href":230,"ariaDescribedBy":231,"dataFootnoteRef":177,"id":233},"#user-content-fn-digital_garden",[232],"footnote-label","user-content-fnref-digital_garden",[235],{"type":189,"value":236},"1",{"type":189,"value":238},"。收集点资料，就当浇水；写点什么，就当施肥。对于后 LLM 时代的数字花园，拥有个人的烙印是一件难得的事情。看看从这些有点人味儿的，以及零散的、灰屑的、燃烧的、组成我的，从中能长出什么东西。",{"type":183,"tag":192,"props":240,"children":241},{},[242,244,250,252,260],{"type":189,"value":243},"本站提供 ",{"type":183,"tag":228,"props":245,"children":247},{"href":246},"/links",[248],{"type":189,"value":249},"友链",{"type":189,"value":251}," 以及 ",{"type":183,"tag":228,"props":253,"children":257},{"href":254,"rel":255},"https://lionad.art/feed.xml",[256],"nofollow",[258],{"type":189,"value":259},"RSS 订阅",{"type":189,"value":261},"。有些内容也许会同步更新其他平台，比如知乎、微信公众号（Lionad）或者哔哩哔哩。",{"type":183,"tag":184,"props":263,"children":265},{"id":264},"网站导航",[266],{"type":189,"value":264},{"type":183,"tag":192,"props":268,"children":269},{},[270],{"type":189,"value":271},"大体来说，这个网站包含：“心流”、技术博客、笔记这三个板块。",{"type":183,"tag":273,"props":274,"children":275},"ul",{},[276,282,292],{"type":183,"tag":277,"props":278,"children":279},"li",{},[280],{"type":189,"value":281},"心流：闪念以及部分体裁不明的文章。",{"type":183,"tag":277,"props":283,"children":284},{},[285,290],{"type":183,"tag":228,"props":286,"children":287},{"href":127},[288],{"type":189,"value":289},"笔记",{"type":189,"value":291},"：领域化或结构化的笔记。",{"type":183,"tag":277,"props":293,"children":294},{},[295,297,304],{"type":189,"value":296},"技术博客：有阵子喜欢写文章放到 ",{"type":183,"tag":228,"props":298,"children":301},{"href":299,"rel":300},"https://juejin.cn/user/289926800227694",[256],[302],{"type":189,"value":303},"掘金社区",{"type":189,"value":305},"，现在以本博客为主。",{"type":183,"tag":192,"props":307,"children":308},{},[309,311,316],{"type":189,"value":310},"鉴于并不擅长写技术博客，所以相关内容的比重会降低。接下来持续很长一段时间的写作重点会放到 ",{"type":183,"tag":228,"props":312,"children":313},{"href":13},[314],{"type":189,"value":315},"《四十二篇》系列",{"type":189,"value":317},"。",{"type":183,"tag":184,"props":319,"children":321},{"id":320},"注意事项",[322],{"type":189,"value":320},{"type":183,"tag":192,"props":324,"children":325},{},[326,328,335],{"type":189,"value":327},"本站内容除特别说明外，均采用 ",{"type":183,"tag":228,"props":329,"children":332},{"href":330,"rel":331},"https://creativecommons.org/licenses/by-nc-sa/4.0/",[256],[333],{"type":189,"value":334},"CC BY-NC-SA 4.0",{"type":189,"value":336}," 协议。因笔记固有的时效性和不确定性，以及部分内容由 GPT 辅助完成，请在参考时进行必要的核对。",{"type":183,"tag":184,"props":338,"children":340},{"id":339},"联系我",[341],{"type":189,"value":339},{"type":183,"tag":192,"props":343,"children":344},{},[345,347,351],{"type":189,"value":346},"见：",{"type":183,"tag":228,"props":348,"children":349},{"href":246},[350],{"type":189,"value":249},{"type":189,"value":31