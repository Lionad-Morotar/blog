置等实用内容。",{"type":182,"children":183,"toc":1805},"root",[184,192,209,214,221,237,243,248,253,258,263,268,284,289,295,328,333,339,344,350,413,418,447,452,458,581,587,624,630,723,729,743,1013,1018,1024,1309,1315,1320,1468,1478,1484,1493,1651,1659,1743,1751,1771,1777,1781,1794,1799],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"操作手册",[190],{"type":191,"value":188},"text",{"type":185,"tag":193,"props":194,"children":195},"ul",{},[196],{"type":185,"tag":197,"props":198,"children":199},"li",{},[200],{"type":185,"tag":201,"props":202,"children":206},"a",{"href":203,"rel":204},"https://dashdash.io/",[205],"nofollow",[207],{"type":191,"value":208},"DashDash Linux Manual",{"type":185,"tag":186,"props":210,"children":212},{"id":211},"系统原理",[213],{"type":191,"value":211},{"type":185,"tag":215,"props":216,"children":218},"h4",{"id":217},"linux-内核是如何分层的",[219],{"type":191,"value":220},"Linux 内核是如何分层的？",{"type":185,"tag":222,"props":223,"children":224},"p",{},[225,227],{"type":191,"value":226},"!(Linux Kernel)",{"type":185,"tag":228,"props":229,"children":230},"span",{},[231],{"type":185,"tag":201,"props":232,"children":235},{"href":233,"rel":234},"https://makelinux.github.io/kernel/diagram/",[205],[236],{"type":191,"value":233},{"type":185,"tag":215,"props":238,"children":240},{"id":239},"什么是零拷贝技术",[241],{"type":191,"value":242},"什么是零拷贝技术？",{"type":185,"tag":222,"props":244,"children":245},{},[246],{"type":191,"value":247},"TODO review",{"type":185,"tag":222,"props":249,"children":250},{},[251],{"type":191,"value":252},"传统的文件传输需要经历四次拷贝以及四次内核态用户态切换：磁盘数据 -> dmacopy() -> 内核缓存区 -> read() -> 用户缓存区 -> write() -> 套接字缓存区 -> dmacopy() -> 网卡。read 或 write 时，系统先从用户态切换到内核态，等内核完成任务再切换回去。由于每次切换都需要消耗 50ns~100ns 的时间，所以在并发量大的情况下，会多很多不必要的开销。",{"type":185,"tag":222,"props":254,"children":255},{},[256],{"type":191,"value":257},"使用 mmap 替代 read 可以把内核区中的文件直接映射到用户缓冲区，这可以减少一次 CPU 拷贝带来的消耗。",{"type":185,"tag":222,"props":259,"children":260},{},[261],{"type":191,"value":262},"从 Linux 2.1 可以使用 sendFile 替代 read，数据根本不经过用户态，可以在调用 write 时，直接把数据从内核缓冲区进入到 Socket 缓存区，减少了一次 CPU 拷贝和上下文切换。",{"type":185,"tag":222,"props":264,"children":265},{},[266],{"type":191,"value":267},"Linux 2.4 又进行了一些修改。在 sendFile 的基础上，如果网卡支持 SG-DMA 技术，在从用 DMA 拷贝把磁盘数据拷贝到内核缓冲区后，可以直接把内核缓存区的数据拷贝到网卡。这样一来就只有 3 次上下文切换和 2 次拷贝。为什么还有两次拷贝也能叫零拷贝呢？实际上，零拷贝应该叫零冗余拷贝，因为磁盘到内核，内核到网卡这两次拷贝并没有像 Linux 2.1 的 sendFile 一样在内核与内核之间多一次冗余拷贝（内核缓存区到 Socket 缓存区），内核只保有一份数据。",{"type":185,"tag":222,"props":269,"children":270},{},[271,273],{"type":191,"value":272},"见：",{"type":185,"tag":201,"props":274,"children":277},{"href":275,"rel":276},"https://trashcode.io/post/d/Zero-copy-mmap-and-sendfile-in-detail",[205],[278],{"type":185,"tag":279,"props":280,"children":281},"i",{},[282],{"type":191,"value":283},"Zero copy : mmap and sendfile in detail",{"type":185,"tag":186,"props":285,"children":287},{"id":286},"系统编程",[288],{"type":191,"value":286},{"type":185,"tag":215,"props":290,"children":292},{"id":291},"signalh-中常见系统信号有哪些",[293],{"type":191,"value":294},"signal.h 中常见系统信号有哪些？",{"type":185,"tag":193,"props":296,"children":297},{},[298,303,308,313,318,323],{"type":185,"tag":197,"props":299,"children":300},{},[301],{"type":191,"value":302},"SIGTERM：终止请求，发送到程序",{"type":185,"tag":197,"props":304,"children":305},{},[306],{"type":191,"value":307},"SIGSEGV：无效的内存访问（分段故障）",{"type":185,"tag":197,"props":309,"children":310},{},[311],{"type":191,"value":312},"SIGINT：外部中断，通常由用户发起",{"type":185,"tag":197,"props":314,"children":315},{},[316],{"type":191,"value":317},"SIGILL：无效的程序映像，如无效指令",{"type":185,"tag":197,"props":319,"children":320},{},[321],{"type":191,"value":322},"SIGABRT：异常终止条件，如例如由 abort() 触发",{"type":185,"tag":197,"props":324,"children":325},{},[326],{"type":191,"value":327},"SIGFPE：错误的算术运算，如除以零",{"type":185,"tag":186,"props":329,"children":331},{"id":330},"脚本",[332],{"type":191,"value":330},{"type":185,"tag":215,"props":334,"children":336},{"id":335},"文件的权限怎么设定",[337],{"type":191,"value":338},"文件的权限怎么设定？",{"type":185