,[181,189,206,211,218,234,240,245,250,255,260,265,281,286,292,325,330,336,341,347,410,415,444,449,455,578,584,621,627,720,726,740,1010,1015,1021,1306,1312,1317,1465,1475,1481,1490,1648,1656,1740,1748,1768,1774,1778,1791,1796],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"操作手册",[187],{"type":188,"value":185},"text",{"type":182,"tag":190,"props":191,"children":192},"ul",{},[193],{"type":182,"tag":194,"props":195,"children":196},"li",{},[197],{"type":182,"tag":198,"props":199,"children":203},"a",{"href":200,"rel":201},"https://dashdash.io/",[202],"nofollow",[204],{"type":188,"value":205},"DashDash Linux Manual",{"type":182,"tag":183,"props":207,"children":209},{"id":208},"系统原理",[210],{"type":188,"value":208},{"type":182,"tag":212,"props":213,"children":215},"h4",{"id":214},"linux-内核是如何分层的",[216],{"type":188,"value":217},"Linux 内核是如何分层的？",{"type":182,"tag":219,"props":220,"children":221},"p",{},[222,224],{"type":188,"value":223},"!(Linux Kernel)",{"type":182,"tag":225,"props":226,"children":227},"span",{},[228],{"type":182,"tag":198,"props":229,"children":232},{"href":230,"rel":231},"https://makelinux.github.io/kernel/diagram/",[202],[233],{"type":188,"value":230},{"type":182,"tag":212,"props":235,"children":237},{"id":236},"什么是零拷贝技术",[238],{"type":188,"value":239},"什么是零拷贝技术？",{"type":182,"tag":219,"props":241,"children":242},{},[243],{"type":188,"value":244},"TODO review",{"type":182,"tag":219,"props":246,"children":247},{},[248],{"type":188,"value":249},"传统的文件传输需要经历四次拷贝以及四次内核态用户态切换：磁盘数据 -> dmacopy() -> 内核缓存区 -> read() -> 用户缓存区 -> write() -> 套接字缓存区 -> dmacopy() -> 网卡。read 或 write 时，系统先从用户态切换到内核态，等内核完成任务再切换回去。由于每次切换都需要消耗 50ns~100ns 的时间，所以在并发量大的情况下，会多很多不必要的开销。",{"type":182,"tag":219,"props":251,"children":252},{},[253],{"type":188,"value":254},"使用 mmap 替代 read 可以把内核区中的文件直接映射到用户缓冲区，这可以减少一次 CPU 拷贝带来的消耗。",{"type":182,"tag":219,"props":256,"children":257},{},[258],{"type":188,"value":259},"从 Linux 2.1 可以使用 sendFile 替代 read，数据根本不经过用户态，可以在调用 write 时，直接把数据从内核缓冲区进入到 Socket 缓存区，减少了一次 CPU 拷贝和上下文切换。",{"type":182,"tag":219,"props":261,"children":262},{},[263],{"type":188,"value":264},"Linux 2.4 又进行了一些修改。在 sendFile 的基础上，如果网卡支持 SG-DMA 技术，在从用 DMA 拷贝把磁盘数据拷贝到内核缓冲区后，可以直接把内核缓存区的数据拷贝到网卡。这样一来就只有 3 次上下文切换和 2 次拷贝。为什么还有两次拷贝也能叫零拷贝呢？实际上，零拷贝应该叫零冗余拷贝，因为磁盘到内核，内核到网卡这两次拷贝并没有像 Linux 2.1 的 sendFile 一样在内核与内核之间多一次冗余拷贝（内核缓存区到 Socket 缓存区），内核只保有一份数据。",{"type":182,"tag":219,"props":266,"children":267},{},[268,270],{"type":188,"value":269},"见：",{"type":182,"tag":198,"props":271,"children":274},{"href":272,"rel":273},"https://trashcode.io/post/d/Zero-copy-mmap-and-sendfile-in-detail",[202],[275],{"type":182,"tag":276,"props":277,"children":278},"i",{},[279],{"type":188,"value":280},"Zero copy : mmap and sendfile in detail",{"type":182,"tag":183,"props":282,"children":284},{"id":283},"系统编程",[285],{"type":188,"value":283},{"type":182,"tag":212,"props":287,"children":289},{"id":288},"signalh-中常见系统信号有哪些",[290],{"type":188,"value":291},"signal.h 中常见系统信号有哪些？",{"type":182,"tag":190,"props":293,"children":294},{},[295,300,305,310,315,320],{"type":182,"tag":194,"props":296,"children":297},{},[298],{"type":188,"value":299},"SIGTERM：终止请求，发送到程序",{"type":182,"tag":194,"props":301,"children":302},{},[303],{"type":188,"value":304},"SIGSEGV：无效的内存访问（分段故障）",{"type":182,"tag":194,"props":306,"children":307},{},[308],{"type":188,"value":309},"SIGINT：外部中断，通常由用户发起",{"type":182,"tag":194,"props":311,"children":312},{},[313],{"type":188,"value":314},"SIGILL：无效的程序映像，如无效指令",{"type":182,"tag":194,"props":316,"children":317},{},[318],{"type":188,"value":319},"SIGABRT：异常终止条件，如例如由 abort() 触发",{"type":182,"tag":194,"props":321,"children":322},{},[323],{"type":188,"value":324},"SIGFPE：错误的算术运算，如除以零",{"type":182,"tag":183,"props":326,"children":328},{"id":327},"脚本",[329],{"type":188,"value":327},{"type":182,"tag":212,"props":331,"children":333},{"id":332},"文件的权限怎么设定",[334],{"type":188,"value":335},"文件的权限怎么设定？",{"type":182,"tag":219,"props":337,"children":338},{},[339],{"type