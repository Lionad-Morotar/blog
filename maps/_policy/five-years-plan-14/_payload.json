[{"data":1,"prerenderedAt":678},["ShallowReactive",2],{"navigation":3,"/maps/_policy/five-years-plan-14":173,"/maps/_policy/five-years-plan-14-surround":670},[4,35,92,98,125,134,158,164],{"title":5,"_path":6,"children":7},"心流思绪 / Heart Flows","/flows",[8,11,14,17,20,23,26,29,32],{"title":9,"_path":10},"📕 狮子的书单推荐","/flows/books",{"title":12,"_path":13},"🚝 四十二篇系列","/flows/forty-two",{"title":15,"_path":16},"🌃 长夜梦","/flows/long-night-dream",{"title":18,"_path":19},"🌌 万物联结与幸福感","/flows/everything",{"title":21,"_path":22},"⌛ 偷取时间","/flows/stealing-time-from-god",{"title":24,"_path":25},"🌆 表达和孤独","/flows/expression-and-loneliness",{"title":27,"_path":28},"🌧️ 我的腼腆","/flows/shy",{"title":30,"_path":31},"🥛 新工作，喝新饮料","/flows/drinking-while-thinking",{"title":33,"_path":34},"📝 心流归档","/flows/archive",{"title":36,"_path":37,"children":38},"技术博客 / Coder","/articles",[39,41,44,47,50,53,56,59,62,65,68,71,74,77,80,83,86,89],{"title":40,"_path":37},"🦁 欢迎",{"title":42,"_path":43},"📦 一个简单有效的端口命名策略：","/articles/simple-naming-method",{"title":45,"_path":46},"🌪️ Tailwind v4 如何兼容预处理器","/articles/tailwind4-with-sass",{"title":48,"_path":49},"🥞 在 tailwind 中使用现代化 CSS Layers","/articles/tailwind-sass-and-css-layer",{"title":51,"_path":52},"💻 本地部署 Qwen 翻译网页","/articles/local-translator",{"title":54,"_path":55},"🧊 模板解析器轻考古","/articles/micro-templating",{"title":57,"_path":58},"Ⓜ️ Mini CSS Parser","/articles/mini-css-parser",{"title":60,"_path":61},"🚩 向AI咨询前端问题","/articles/use-gpt-learn-complex-frontend",{"title":63,"_path":64},"⛸️ 怎样定制复杂组件的自定义滚动条？","/articles/use-scrollbars",{"title":66,"_path":67},"⚖️ 统一多组件库的层叠顺序","/articles/zindex-manager",{"title":69,"_path":70},"🕷️ 滑动验证码破解思路","/articles/crack-the-slider",{"title":72,"_path":73},"🌟 探秘 CSS 光影效果","/articles/css-light-travel",{"title":75,"_path":76},"🍲 设计模式与 JS 魔法锅","/articles/design-patterns-and-js-magic-pot",{"title":78,"_path":79},"🌐 Anysort：灵活、优雅的多属性排序","/articles/anysort-2th",{"title":81,"_path":82},"💫 CSS 幻术 | 抗锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"body":181,"_type":664,"_id":665,"_source":666,"_file":667,"_stem":668,"_extension":669},"/maps/_policy/five-years-plan-14","_policy",false,true,"","五年规划","对未来五年内的发展目标、发展方向、发展重点、发展任务等进行系统安排和部署的规划。",{"type":182,"children":183,"toc":661},"root",[184,200,206,215,224,229,237,242,247,252,257,265,270,305,313,321,326,331,384,392,400,405,413,421,429,434,442,447,455,460,474,482,487,495,503,508,516,521,529,536,544,549,557,565,573,581,589,597,605,613,621,629,637,645,653],{"type":185,"tag":186,"props":187,"children":189},"element","h4",{"id":188},"中华人民共和国国民经济和社会发展第十四个五年规划和-2035-年远景目标纲要",[190],{"type":185,"tag":191,"props":192,"children":196},"a",{"href":193,"rel":194},"https://www.gov.cn/xinwen/2021-03/13/content_5592681.htm",[195],"nofollow",[197],{"type":198,"value":199},"text","《中华人民共和国国民经济和社会发展第十四个五年规划和 2035 年远景目标纲要》",{"type":185,"tag":201,"props":202,"children":203},"p",{},[204],{"type":198,"value":205},"2021-03-13",{"type":185,"tag":201,"props":207,"children":208},{},[209],{"type":185,"tag":210,"props":211,"children":212},"strong",{},[213],{"type":198,"value":214},"第一篇　开启全面建设社会主义现代化国家新征程",{"type":185,"tag":201,"props":216,"children":217},{},[218],{"type":185,"tag":219,"props":220,"children":221},"q",{},[222],{"type":198,"value":223},"（十三五期间）经济运行总体平稳，经济结构持续优化，国内生产总值突破 100 万亿元。创新型国家建设成果丰硕，在载人航天、探月工程、深海工程、超级计算、量子信息、“复兴号”高速列车、大飞机制造等领域取得一批重大科技成果。",{"type":185,"tag":201,"props":225,"children":226},{},[227],{"type":198,"value":228},"神威·太湖之光、墨子号、复兴号高速列车、国产大型客机 C919",{"type":185,"tag":201,"props":230,"children":231},{},[232],{"type":185,"tag":219,"props":233,"children":234},{},[235],{"type":198,"value":236},"（十三五期间）国际环境日趋复杂，不稳定性不确定性明显增加，新冠肺炎疫情影响广泛深远，世界经济陷入低迷期，经济全球化遭遇逆流，全球能源供需版图深刻变革，国际经济政治格局复杂多变，世界进入动荡变革期，单边主义、保护主义、霸权主义对世界和平与发展构成威胁。",{"type":185,"tag":201,"props":238,"children":239},{},[240],{"type":198,"value":241},"疫情除了增了公共卫生治理压力、对诸如旅游、航空、餐饮、零售和制造业等行业带来经济打击之外，在一定程度上促进了全球范围内对数字经济、在线办公、远程教育、跨境电商等新模式的探索。钉钉就是那会儿出圈的。",{"type":185,"tag":201,"props":243,"children":244},{},[245],{"type":198,"value":246},"单边主义指的是国际社会中实力地位较强的某一个国家，为了落实对本国有利的外交政策而忽视多数国家的人民意愿，违反国际社会潮流，不顾他国利益，拒绝采取协商途径，凭借自己的力量我行我素的行为。",{"type":185,"tag":201,"props":248,"children":249},{},[250],{"type":198,"value":251},"保护主义即贸易保护主义（Protectionism），指在对外贸易中限制进口以保护本国（地区）商品在国内市场免受外国商品竞争，以及向本国（地区）商品提供各种优惠以增强其国际竞争力的政策。",{"type":185,"tag":201,"props":253,"children":254},{},[255],{"type":198,"value":256},"霸权主义（Hegemonism），是指一国凭借其政治、军事和经济的极大优势，在全世界或个别地区维持秩序、主导国际事务或谋求统治地位的政策的意识形态。",{"type":185,"tag":201,"props":258,"children":259},{},[260],{"type":185,"tag":219,"props":261,"children":262},{},[263],{"type":198,"value":264},"展望 2035 年，我国将基本实现社会主义现代化，基本实现国防和军队现代化。",{"type":185,"tag":201,"props":266,"children":267},{},[268],{"type":198,"value":269},"社会主义现代化是个新概念，国防和军队现代化也是个没听过的概念。",{"type":185,"tag":271,"props":272,"children":273},"ul",{},[274,280,285,290,295,300],{"type":185,"tag":275,"props":276,"children":277},"li",{},[278],{"type":198,"value":279},"装备现代化：引入先进的军事技术，研发高精尖武器和装备。例如，高超音速武器、无人机技术、人工智能和网络战等领域。",{"type":185,"tag":275,"props":281,"children":282},{},[283],{"type":198,"value":284},"战略和战术的升级：根据现代战争的特点，如信息化、智能化和联合作战，优化军事战略和作战模式，使国防力量更加高效和精准。",{"type":185,"tag":275,"props":286,"children":287},{},[288],{"type":198,"value":289},"军队结构调整：现代化军队需要高效组织，例如推动从传统兵种向信息化、联合化方向的转型，提升全域作战能力。",{"type":185,"tag":275,"props":291,"children":292},{},[293],{"type":198,"value":294},"国防科技创新：通过国防科研与创新驱动，加速军事科技领域的突破，使国防技术始终具有国际竞争力。",{"type":185,"tag":275,"props":296,"children":297},{},[298],{"type":198,"value":299},"体制和管理现代化：完善军事体制，优化军队管理机制，加强国防资源分配的科学性和均衡性。",{"type":185,"tag":275,"props":301,"children":302},{},[303],{"type":198,"value":304},"后勤与保障能力提升：包括后勤物资、能源供应、医疗服务保障等现代化管理，使军队在复杂环境下具备持续作战的能力。",{"type":185,"tag":201,"props":306,"children":307},{},[308],{"type":185,"tag":219,"props":309,"children":310},{},[311],{"type":198,"value":312},"“十四五”时期经济社会发展主要指标",{"type":185,"tag":201,"props":314,"children":315},{},[316],{"type":185,"tag":317,"props":318,"children":320},"img",{"alt":312,"src":319},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202503110615037.png",[],{"type":185,"tag":201,"props":322,"children":323},{},[324],{"type":198,"value":325},"约束性指标大多在“绿色生态”和“安全保障”类别。创新驱动主要关注：全社会研发经费、万人专利数、数字经济核心产业 GDP 比重。",{"type":185,"tag":201,"props":327,"children":328},{},[329],{"type":198,"value":330},"数字经济核心产业包括哪些呢？",{"type":185,"tag":271,"props":332,"children":333},{},[334,339,344,349,354,359,364,369,374,379],{"type":185,"tag":275,"props":335,"children":336},{},[337],{"type":198,"value":338},"电子信息制造业：计算机、通信设备、半导体芯片、传感器等核心硬件设备的生产，是数字经济发展的基础设施。",{"type":185,"tag":275,"props":340,"children":341},{},[342],{"type":198,"value":343},"软件和信息技术服务业：软件开发、操作系统、数据库管理系统、云计算服务、大数据解决方案等构成了支撑数字经济运行的技术基础。",{"type":185,"tag":275,"props":345,"children":346},{},[347],{"type":198,"value":348},"通信和网络产业：5G、光纤宽带、物联网、卫星通信等技术与网络架构，它们对数字经济的互联互通至关重要。",{"type":185,"tag":275,"props":350,"children":351},{},[352],{"type":198,"value":353},"互联网产业：电子商务、搜索引擎、社交媒体、流媒体服务、网络广告等依托互联网的平台经济形式。",{"type":185,"tag":275,"props":355,"children":356},{},[357],{"type":198,"value":358},"云计算和大数据产业：大数据存储和分析，云计算技术与服务，是实现数字化管理、预测和商业价值挖掘的核心。",{"type":185,"tag":275,"props":360,"children":361},{},[362],{"type":198,"value":363},"人工智能（AI）产业：AI 算法开发、计算机视觉、自然语言处理、深度学习等技术领域，用于智能化工业、服务业、和商业决策。",{"type":185,"tag":275,"props":365,"children":366},{},[367],{"type":198,"value":368},"区块链产业：提供分布式账本技术，应用于金融科技（如虚拟货币）、供应链管理、电子政务等领域。",{"type":185,"tag":275,"props":370,"children":371},{},[372],{"type":198,"value":373},"数字内容产业：游戏、虚拟现实（VR）、增强现实（AR）、在线教育、数字媒体、音视频内容创作与传播等新兴内容形式。",{"type":185,"tag":275,"props":375,"children":376},{},[377],{"type":198,"value":378},"信息安全产业：网络安全、数据加密、防火墙等。",{"type":185,"tag":275,"props":380,"children":381},{},[382],{"type":198,"value":383},"智能制造和工业互联网：将数字技术与传统制造业深度融合，实现工业设备智能化、生产流程数字化。",{"type":185,"tag":201,"props":385,"children":386},{},[387],{"type":185,"tag":210,"props":388,"children":389},{},[390],{"type":198,"value":391},"第二篇　坚持创新驱动发展 全面塑造发展新优势",{"type":185,"tag":201,"props":393,"children":394},{},[395],{"type":185,"tag":219,"props":396,"children":397},{},[398],{"type":198,"value":399},"强化国家战略科技力量",{"type":185,"tag":201,"props":401,"children":402},{},[403],{"type":198,"value":404},"整合优化科技资源配置，也就搞好国家实验室、创新基地、资源共享、研究型大学等概念，至于战略目标，见下图：",{"type":185,"tag":201,"props":406,"children":407},{},[408],{"type":185,"tag":317,"props":409,"children":412},{"alt":410,"src":411},"科技前沿领域","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202503110632135.png",[],{"type":185,"tag":201,"props":414,"children":415},{},[416],{"type":185,"tag":210,"props":417,"children":418},{},[419],{"type":198,"value":420},"第三篇　加快发展现代产业体系 巩固壮大实体经济根基",{"type":185,"tag":201,"props":422,"children":423},{},[424],{"type":185,"tag":219,"props":425,"children":426},{},[427],{"type":198,"value":428},"加强产业基础能力建设，实施产业基础再造工程",{"type":185,"tag":201,"props":430,"children":431},{},[432],{"type":198,"value":433},"除了补齐工艺技术短板，在软件方面也看到了：推动首版次软件示范应用，建设生产应用示范平台和标准计量、认证认可、检验检测、试验验证等产业技术基础公共服务平台，完善技术、工艺等工业基础数据库。",{"type":185,"tag":201,"props":435,"children":436},{},[437],{"type":185,"tag":219,"props":438,"children":439},{},[440],{"type":198,"value":441},"实施制造业降本减负行动",{"type":185,"tag":201,"props":443,"children":444},{},[445],{"type":198,"value":446},"包括支持建设中小企业信息、技术、进出口和数字化转型综合性服务平台。北斗包含在内，也难怪进来的新手机顶配版本都是带卫星通讯的。数字化不属于制造业的“核心竞争力”，而是和网络一样属于基础设施。",{"type":185,"tag":201,"props":448,"children":449},{},[450],{"type":185,"tag":219,"props":451,"children":452},{},[453],{"type":198,"value":454},"建设高速泛在、天地一体、集成互联、安全高效的信息基础设施，增强数据感知、传输、存储和运算能力；加快构建全国一体化大数据中心体系；加快交通、能源、市政等传统基础设施数字化改造；发挥市场主导作用，打通多元化投资渠道，构建新型基础设施标准体系。",{"type":185,"tag":201,"props":456,"children":457},{},[458],{"type":198,"value":459},"除了数据和计算，电力、交通、水利也算基础设施，而且这几项天然适合放到一起讨论。",{"type":185,"tag":201,"props":461,"children":462},{},[463,465,472],{"type":198,"value":464},"国家信息中心还在 2024 年设立了大数据发展部，",{"type":185,"tag":191,"props":466,"children":469},{"href":467,"rel":468},"http://www.sic.gov.cn/sic/78/97/0705/20240705102749893150783_pc.html",[195],[470],{"type":198,"value":471},"他们的职责",{"type":198,"value":473}," 是面向发改委等上级开展大数据、大算力、大模型前沿研究与应用。",{"type":185,"tag":201,"props":475,"children":476},{},[477],{"type":185,"tag":210,"props":478,"children":479},{},[480],{"type":198,"value":481},"第四篇　形成强大国内市场 构建新发展格局",{"type":185,"tag":201,"props":483,"children":484},{},[485],{"type":198,"value":486},"内需体系主要由国内消费需求和投资需求构成，国内大循环需要建立在坚实的内需体系之上，只有当国内居民收入不断提高、消费能力持续扩大、投资领域有广阔空间时，大循环才有足够活力。",{"type":185,"tag":201,"props":488,"children":489},{},[490],{"type":185,"tag":210,"props":491,"children":492},{},[493],{"type":198,"value":494},"第五篇　加快数字化发展 建设数字中国",{"type":185,"tag":201,"props":496,"children":497},{},[498],{"type":185,"tag":219,"props":499,"children":500},{},[501],{"type":198,"value":502},"加强关键数字技术创新应用，加快布局量子计算、量子通信、神经芯片、DNA 存储等前沿技术，加强信息科学与生命科学、材料等基础学科的交叉创新，支持数字技术开源社区等创新联合体发展，完善开源知识产权和法律体系，鼓励企业开放软件源代码、硬件设计和应用服务。",{"type":185,"tag":201,"props":504,"children":505},{},[506],{"type":198,"value":507},"看到了不少新东西，DNA 存储、交叉创新、开放源码等等。",{"type":185,"tag":201,"props":509,"children":510},{},[511],{"type":185,"tag":219,"props":512,"children":513},{},[514],{"type":198,"value":515},"鼓励企业开放搜索、电商、社交等数据，发展第三方大数据服务产业。",{"type":185,"tag":201,"props":517,"children":518},{},[519],{"type":198,"value":520},"就差点名张小龙和马云了。",{"type":185,"tag":201,"props":522,"children":523},{},[524],{"type":185,"tag":219,"props":525,"children":526},{},[527],{"type":198,"value":528},"数字经济重点产业",{"type":185,"tag":201,"props":530,"children":531},{},[532],{"type":185,"tag":317,"props":533,"children":535},{"alt":528,"src":534},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202503110714738.png",[],{"type":185,"tag":201,"props":537,"children":538},{},[539],{"type":185,"tag":219,"props":540,"children":541},{},[542],{"type":198,"value":543},"适应数字技术全面融入社会交往和日常生活新趋势，促进公共服务和社会运行方式创新，构筑全民畅享的数字生活。",{"type":185,"tag":201,"props":545,"children":546},{},[547],{"type":198,"value":548},"数字化社会主要涉及智慧公共服务、智慧城市、数字乡村等概念。之前在视频里见过深圳的公园里有扫码就能计数的跑步机（？）应该属于这一类智慧公共服务。",{"type":185,"tag":201,"props":550,"children":551},{},[552],{"type":185,"tag":210,"props":553,"children":554},{},[555],{"type":198,"value":556},"第六篇　全面深化改革 构建高水平社会主义市场经济体制",{"type":185,"tag":201,"props":558,"children":559},{},[560],{"type":185,"tag":210,"props":561,"children":562},{},[563],{"type":198,"value":564},"第七篇　坚持农业农村优先发展 全面推进乡村振兴",{"type":185,"tag":201,"props":566,"children":567},{},[568],{"type":185,"tag":210,"props":569,"children":570},{},[571],{"type":198,"value":572},"第八篇　完善新型城镇化战略 提升城镇化发展质量",{"type":185,"tag":201,"props":574,"children":575},{},[576],{"type":185,"tag":210,"props":577,"children":578},{},[579],{"type":198,"value":580},"第九篇　优化区域经济布局 促进区域协调发展",{"type":185,"tag":201,"props":582,"children":583},{},[584],{"type":185,"tag":210,"props":585,"children":586},{},[587],{"type":198,"value":588},"第十篇　发展社会主义先进文化 提升国家文化软实力",{"type":185,"tag":201,"props":590,"children":591},{},[592],{"type":185,"tag":210,"props":593,"children":594},{},[595],{"type":198,"value":596},"第十一篇　推动绿色发展 促进人与自然和谐共生",{"type":185,"tag":201,"props":598,"children":599},{},[600],{"type":185,"tag":210,"props":601,"children":602},{},[603],{"type":198,"value":604},"第十二篇　实行高水平对外开放 开拓合作共赢新局面",{"type":185,"tag":201,"props":606,"children":607},{},[608],{"type":185,"tag":210,"props":609,"children":610},{},[611],{"type":198,"value":612},"第十三篇　提升国民素质 促进人的全面发展",{"type":185,"tag":201,"props":614,"children":615},{},[616],{"type":185,"tag":210,"props":617,"children":618},{},[619],{"type":198,"value":620},"第十四篇　增进民生福祉 提升共建共治共享水平",{"type":185,"tag":201,"props":622,"children":623},{},[624],{"type":185,"tag":210,"props":625,"children":626},{},[627],{"type":198,"value":628},"第十五篇　统筹发展和安全 建设更高水平的平安中国",{"type":185,"tag":201,"props":630,"children":631},{},[632],{"type":185,"tag":210,"props":633,"children":634},{},[635],{"type":198,"value":636},"第十六篇　加快国防和军队现代化 实现富国和强军相统一",{"type":185,"tag":201,"props":638,"children":639},{},[640],{"type":185,"tag":210,"props":641,"children":642},{},[643],{"type":198,"value":644},"第十七篇　加强社会主义民主法治建设 健全党和国家监督制度",{"type":185,"tag":201,"props":646,"children":647},{},[648],{"type":185,"tag":210,"props":649,"children":650},{},[651],{"type":198,"value":652},"第十八篇　坚持“一国两制” 推进祖国统一",{"type":185,"tag":201,"props":654,"children":655},{},[656],{"type":185,"tag":210,"props":657,"children":658},{},[659],{"type":198,"value":660},"第十九篇　加强规划实施保障",{"title":178,"searchDepth":662,"depth":662,"links":663},2,[],"markdown","content:6.maps:_policy:five-years-plan-14.md","content","6.maps/_policy/five-years-plan-14.md","6.maps/_policy/five-years-plan-14","md",[671,675],{"_path":672,"title":673,"description":674},"/maps/_php/php","PHP","PHP 是一种广泛使用的开源服务器端脚本语言，特别适用于Web开发并可以嵌入HTML中。",{"_path":676,"title":677,"description":178},"/maps/_policy/policy","政策",1771693719291]