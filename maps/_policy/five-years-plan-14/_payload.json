[{"data":1,"prerenderedAt":675},["ShallowReactive",2],{"navigation":3,"/maps/_policy/five-years-plan-14":170,"/maps/_policy/five-years-plan-14-surround":667},[4,35,92,98,125,131,155,161],{"title":5,"_path":6,"children":7},"心流思绪 / Heart Flows","/flows",[8,11,14,17,20,23,26,29,32],{"title":9,"_path":10},"📕 狮子的书单推荐","/flows/books",{"title":12,"_path":13},"🚝 四十二篇系列","/flows/forty-two",{"title":15,"_path":16},"🌃 长夜梦","/flows/long-night-dream",{"title":18,"_path":19},"🌌 万物联结与幸福感","/flows/everything",{"title":21,"_path":22},"⌛ 偷取时间","/flows/stealing-time-from-god",{"title":24,"_path":25},"🌆 表达和孤独","/flows/expression-and-loneliness",{"title":27,"_path":28},"🌧️ 我的腼腆","/flows/shy",{"title":30,"_path":31},"🥛 新工作，喝新饮料","/flows/drinking-while-thinking",{"title":33,"_path":34},"📝 心流归档","/flows/archive",{"title":36,"_path":37,"children":38},"技术博客 / Coder","/articles",[39,41,44,47,50,53,56,59,62,65,68,71,74,77,80,83,86,89],{"title":40,"_path":37},"🦁 欢迎",{"title":42,"_path":43},"📦 一个简单有效的端口命名策略：","/articles/simple-naming-method",{"title":45,"_path":46},"🌪️ Tailwind v4 如何兼容预处理器","/articles/tailwind4-with-sass",{"title":48,"_path":49},"🥞 在 tailwind 中使用现代化 CSS Layers","/articles/tailwind-sass-and-css-layer",{"title":51,"_path":52},"💻 本地部署 Qwen 翻译网页","/articles/local-translator",{"title":54,"_path":55},"🧊 模板解析器轻考古","/articles/micro-templating",{"title":57,"_path":58},"Ⓜ️ Mini CSS Parser","/articles/mini-css-parser",{"title":60,"_path":61},"🚩 向AI咨询前端问题","/articles/use-gpt-learn-complex-frontend",{"title":63,"_path":64},"⛸️ 怎样定制复杂组件的自定义滚动条？","/articles/use-scrollbars",{"title":66,"_path":67},"⚖️ 统一多组件库的层叠顺序","/articles/zindex-manager",{"title":69,"_path":70},"🕷️ 滑动验证码破解思路","/articles/crack-the-slider",{"title":72,"_path":73},"🌟 探秘 CSS 光影效果","/articles/css-light-travel",{"title":75,"_path":76},"🍲 设计模式与 JS 魔法锅","/articles/design-patterns-and-js-magic-pot",{"title":78,"_path":79},"🌐 Anysort：灵活、优雅的多属性排序","/articles/anysort-2th",{"title":81,"_path":82},"💫 CSS 幻术 | 抗锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133,"children":134},"造物 / Make","/tools",[135,137,140,143,146,149,152],{"title":136,"_path":133},"🧰 工具收集",{"title":138,"_path":139},"📕 博客","/tools/blog",{"title":141,"_path":142},"🥥 Coconut","/tools/coconut",{"title":144,"_path":145},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":147,"_path":148},"🌐 AnySort","/tools/anysort",{"title":150,"_path":151},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":153,"_path":154},"👓 Crapto","/tools/crypto-inline",{"title":156,"_path":157,"children":158},"我 / About","/hire",[159],{"title":160,"_path":157},"📬 技术简历",{"title":162,"_path":163,"children":164},"En","/en",[165],{"title":166,"_path":167,"children":168},"🦁 Welcome","/en/articles",[169],{"title":166,"_path":167},{"_path":171,"_dir":172,"_draft":173,"_partial":174,"_locale":175,"title":176,"description":177,"body":178,"_type":661,"_id":662,"_source":663,"_file":664,"_stem":665,"_extension":666},"/maps/_policy/five-years-plan-14","_policy",false,true,"","五年规划","对未来五年内的发展目标、发展方向、发展重点、发展任务等进行系统安排和部署的规划。",{"type":179,"children":180,"toc":658},"root",[181,197,203,212,221,226,234,239,244,249,254,262,267,302,310,318,323,328,381,389,397,402,410,418,426,431,439,444,452,457,471,479,484,492,500,505,513,518,526,533,541,546,554,562,570,578,586,594,602,610,618,626,634,642,650],{"type":182,"tag":183,"props":184,"children":186},"element","h4",{"id":185},"中华人民共和国国民经济和社会发展第十四个五年规划和-2035-年远景目标纲要",[187],{"type":182,"tag":188,"props":189,"children":193},"a",{"href":190,"rel":191},"https://www.gov.cn/xinwen/2021-03/13/content_5592681.htm",[192],"nofollow",[194],{"type":195,"value":196},"text","《中华人民共和国国民经济和社会发展第十四个五年规划和 2035 年远景目标纲要》",{"type":182,"tag":198,"props":199,"children":200},"p",{},[201],{"type":195,"value":202},"2021-03-13",{"type":182,"tag":198,"props":204,"children":205},{},[206],{"type":182,"tag":207,"props":208,"children":209},"strong",{},[210],{"type":195,"value":211},"第一篇　开启全面建设社会主义现代化国家新征程",{"type":182,"tag":198,"props":213,"children":214},{},[215],{"type":182,"tag":216,"props":217,"children":218},"q",{},[219],{"type":195,"value":220},"（十三五期间）经济运行总体平稳，经济结构持续优化，国内生产总值突破 100 万亿元。创新型国家建设成果丰硕，在载人航天、探月工程、深海工程、超级计算、量子信息、“复兴号”高速列车、大飞机制造等领域取得一批重大科技成果。",{"type":182,"tag":198,"props":222,"children":223},{},[224],{"type":195,"value":225},"神威·太湖之光、墨子号、复兴号高速列车、国产大型客机 C919",{"type":182,"tag":198,"props":227,"children":228},{},[229],{"type":182,"tag":216,"props":230,"children":231},{},[232],{"type":195,"value":233},"（十三五期间）国际环境日趋复杂，不稳定性不确定性明显增加，新冠肺炎疫情影响广泛深远，世界经济陷入低迷期，经济全球化遭遇逆流，全球能源供需版图深刻变革，国际经济政治格局复杂多变，世界进入动荡变革期，单边主义、保护主义、霸权主义对世界和平与发展构成威胁。",{"type":182,"tag":198,"props":235,"children":236},{},[237],{"type":195,"value":238},"疫情除了增了公共卫生治理压力、对诸如旅游、航空、餐饮、零售和制造业等行业带来经济打击之外，在一定程度上促进了全球范围内对数字经济、在线办公、远程教育、跨境电商等新模式的探索。钉钉就是那会儿出圈的。",{"type":182,"tag":198,"props":240,"children":241},{},[242],{"type":195,"value":243},"单边主义指的是国际社会中实力地位较强的某一个国家，为了落实对本国有利的外交政策而忽视多数国家的人民意愿，违反国际社会潮流，不顾他国利益，拒绝采取协商途径，凭借自己的力量我行我素的行为。",{"type":182,"tag":198,"props":245,"children":246},{},[247],{"type":195,"value":248},"保护主义即贸易保护主义（Protectionism），指在对外贸易中限制进口以保护本国（地区）商品在国内市场免受外国商品竞争，以及向本国（地区）商品提供各种优惠以增强其国际竞争力的政策。",{"type":182,"tag":198,"props":250,"children":251},{},[252],{"type":195,"value":253},"霸权主义（Hegemonism），是指一国凭借其政治、军事和经济的极大优势，在全世界或个别地区维持秩序、主导国际事务或谋求统治地位的政策的意识形态。",{"type":182,"tag":198,"props":255,"children":256},{},[257],{"type":182,"tag":216,"props":258,"children":259},{},[260],{"type":195,"value":261},"展望 2035 年，我国将基本实现社会主义现代化，基本实现国防和军队现代化。",{"type":182,"tag":198,"props":263,"children":264},{},[265],{"type":195,"value":266},"社会主义现代化是个新概念，国防和军队现代化也是个没听过的概念。",{"type":182,"tag":268,"props":269,"children":270},"ul",{},[271,277,282,287,292,297],{"type":182,"tag":272,"props":273,"children":274},"li",{},[275],{"type":195,"value":276},"装备现代化：引入先进的军事技术，研发高精尖武器和装备。例如，高超音速武器、无人机技术、人工智能和网络战等领域。",{"type":182,"tag":272,"props":278,"children":279},{},[280],{"type":195,"value":281},"战略和战术的升级：根据现代战争的特点，如信息化、智能化和联合作战，优化军事战略和作战模式，使国防力量更加高效和精准。",{"type":182,"tag":272,"props":283,"children":284},{},[285],{"type":195,"value":286},"军队结构调整：现代化军队需要高效组织，例如推动从传统兵种向信息化、联合化方向的转型，提升全域作战能力。",{"type":182,"tag":272,"props":288,"children":289},{},[290],{"type":195,"value":291},"国防科技创新：通过国防科研与创新驱动，加速军事科技领域的突破，使国防技术始终具有国际竞争力。",{"type":182,"tag":272,"props":293,"children":294},{},[295],{"type":195,"value":296},"体制和管理现代化：完善军事体制，优化军队管理机制，加强国防资源分配的科学性和均衡性。",{"type":182,"tag":272,"props":298,"children":299},{},[300],{"type":195,"value":301},"后勤与保障能力提升：包括后勤物资、能源供应、医疗服务保障等现代化管理，使军队在复杂环境下具备持续作战的能力。",{"type":182,"tag":198,"props":303,"children":304},{},[305],{"type":182,"tag":216,"props":306,"children":307},{},[308],{"type":195,"value":309},"“十四五”时期经济社会发展主要指标",{"type":182,"tag":198,"props":311,"children":312},{},[313],{"type":182,"tag":314,"props":315,"children":317},"img",{"alt":309,"src":316},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202503110615037.png",[],{"type":182,"tag":198,"props":319,"children":320},{},[321],{"type":195,"value":322},"约束性指标大多在“绿色生态”和“安全保障”类别。创新驱动主要关注：全社会研发经费、万人专利数、数字经济核心产业 GDP 比重。",{"type":182,"tag":198,"props":324,"children":325},{},[326],{"type":195,"value":327},"数字经济核心产业包括哪些呢？",{"type":182,"tag":268,"props":329,"children":330},{},[331,336,341,346,351,356,361,366,371,376],{"type":182,"tag":272,"props":332,"children":333},{},[334],{"type":195,"value":335},"电子信息制造业：计算机、通信设备、半导体芯片、传感器等核心硬件设备的生产，是数字经济发展的基础设施。",{"type":182,"tag":272,"props":337,"children":338},{},[339],{"type":195,"value":340},"软件和信息技术服务业：软件开发、操作系统、数据库管理系统、云计算服务、大数据解决方案等构成了支撑数字经济运行的技术基础。",{"type":182,"tag":272,"props":342,"children":343},{},[344],{"type":195,"value":345},"通信和网络产业：5G、光纤宽带、物联网、卫星通信等技术与网络架构，它们对数字经济的互联互通至关重要。",{"type":182,"tag":272,"props":347,"children":348},{},[349],{"type":195,"value":350},"互联网产业：电子商务、搜索引擎、社交媒体、流媒体服务、网络广告等依托互联网的平台经济形式。",{"type":182,"tag":272,"props":352,"children":353},{},[354],{"type":195,"value":355},"云计算和大数据产业：大数据存储和分析，云计算技术与服务，是实现数字化管理、预测和商业价值挖掘的核心。",{"type":182,"tag":272,"props":357,"children":358},{},[359],{"type":195,"value":360},"人工智能（AI）产业：AI 算法开发、计算机视觉、自然语言处理、深度学习等技术领域，用于智能化工业、服务业、和商业决策。",{"type":182,"tag":272,"props":362,"children":363},{},[364],{"type":195,"value":365},"区块链产业：提供分布式账本技术，应用于金融科技（如虚拟货币）、供应链管理、电子政务等领域。",{"type":182,"tag":272,"props":367,"children":368},{},[369],{"type":195,"value":370},"数字内容产业：游戏、虚拟现实（VR）、增强现实（AR）、在线教育、数字媒体、音视频内容创作与传播等新兴内容形式。",{"type":182,"tag":272,"props":372,"children":373},{},[374],{"type":195,"value":375},"信息安全产业：网络安全、数据加密、防火墙等。",{"type":182,"tag":272,"props":377,"children":378},{},[379],{"type":195,"value":380},"智能制造和工业互联网：将数字技术与传统制造业深度融合，实现工业设备智能化、生产流程数字化。",{"type":182,"tag":198,"props":382,"children":383},{},[384],{"type":182,"tag":207,"props":385,"children":386},{},[387],{"type":195,"value":388},"第二篇　坚持创新驱动发展 全面塑造发展新优势",{"type":182,"tag":198,"props":390,"children":391},{},[392],{"type":182,"tag":216,"props":393,"children":394},{},[395],{"type":195,"value":396},"强化国家战略科技力量",{"type":182,"tag":198,"props":398,"children":399},{},[400],{"type":195,"value":401},"整合优化科技资源配置，也就搞好国家实验室、创新基地、资源共享、研究型大学等概念，至于战略目标，见下图：",{"type":182,"tag":198,"props":403,"children":404},{},[405],{"type":182,"tag":314,"props":406,"children":409},{"alt":407,"src":408},"科技前沿领域","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202503110632135.png",[],{"type":182,"tag":198,"props":411,"children":412},{},[413],{"type":182,"tag":207,"props":414,"children":415},{},[416],{"type":195,"value":417},"第三篇　加快发展现代产业体系 巩固壮大实体经济根基",{"type":182,"tag":198,"props":419,"children":420},{},[421],{"type":182,"tag":216,"props":422,"children":423},{},[424],{"type":195,"value":425},"加强产业基础能力建设，实施产业基础再造工程",{"type":182,"tag":198,"props":427,"children":428},{},[429],{"type":195,"value":430},"除了补齐工艺技术短板，在软件方面也看到了：推动首版次软件示范应用，建设生产应用示范平台和标准计量、认证认可、检验检测、试验验证等产业技术基础公共服务平台，完善技术、工艺等工业基础数据库。",{"type":182,"tag":198,"props":432,"children":433},{},[434],{"type":182,"tag":216,"props":435,"children":436},{},[437],{"type":195,"value":438},"实施制造业降本减负行动",{"type":182,"tag":198,"props":440,"children":441},{},[442],{"type":195,"value":443},"包括支持建设中小企业信息、技术、进出口和数字化转型综合性服务平台。北斗包含在内，也难怪进来的新手机顶配版本都是带卫星通讯的。数字化不属于制造业的“核心竞争力”，而是和网络一样属于基础设施。",{"type":182,"tag":198,"props":445,"children":446},{},[447],{"type":182,"tag":216,"props":448,"children":449},{},[450],{"type":195,"value":451},"建设高速泛在、天地一体、集成互联、安全高效的信息基础设施，增强数据感知、传输、存储和运算能力；加快构建全国一体化大数据中心体系；加快交通、能源、市政等传统基础设施数字化改造；发挥市场主导作用，打通多元化投资渠道，构建新型基础设施标准体系。",{"type":182,"tag":198,"props":453,"children":454},{},[455],{"type":195,"value":456},"除了数据和计算，电力、交通、水利也算基础设施，而且这几项天然适合放到一起讨论。",{"type":182,"tag":198,"props":458,"children":459},{},[460,462,469],{"type":195,"value":461},"国家信息中心还在 2024 年设立了大数据发展部，",{"type":182,"tag":188,"props":463,"children":466},{"href":464,"rel":465},"http://www.sic.gov.cn/sic/78/97/0705/20240705102749893150783_pc.html",[192],[467],{"type":195,"value":468},"他们的职责",{"type":195,"value":470}," 是面向发改委等上级开展大数据、大算力、大模型前沿研究与应用。",{"type":182,"tag":198,"props":472,"children":473},{},[474],{"type":182,"tag":207,"props":475,"children":476},{},[477],{"type":195,"value":478},"第四篇　形成强大国内市场 构建新发展格局",{"type":182,"tag":198,"props":480,"children":481},{},[482],{"type":195,"value":483},"内需体系主要由国内消费需求和投资需求构成，国内大循环需要建立在坚实的内需体系之上，只有当国内居民收入不断提高、消费能力持续扩大、投资领域有广阔空间时，大循环才有足够活力。",{"type":182,"tag":198,"props":485,"children":486},{},[487],{"type":182,"tag":207,"props":488,"children":489},{},[490],{"type":195,"value":491},"第五篇　加快数字化发展 建设数字中国",{"type":182,"tag":198,"props":493,"children":494},{},[495],{"type":182,"tag":216,"props":496,"children":497},{},[498],{"type":195,"value":499},"加强关键数字技术创新应用，加快布局量子计算、量子通信、神经芯片、DNA 存储等前沿技术，加强信息科学与生命科学、材料等基础学科的交叉创新，支持数字技术开源社区等创新联合体发展，完善开源知识产权和法律体系，鼓励企业开放软件源代码、硬件设计和应用服务。",{"type":182,"tag":198,"props":501,"children":502},{},[503],{"type":195,"value":504},"看到了不少新东西，DNA 存储、交叉创新、开放源码等等。",{"type":182,"tag":198,"props":506,"children":507},{},[508],{"type":182,"tag":216,"props":509,"children":510},{},[511],{"type":195,"value":512},"鼓励企业开放搜索、电商、社交等数据，发展第三方大数据服务产业。",{"type":182,"tag":198,"props":514,"children":515},{},[516],{"type":195,"value":517},"就差点名张小龙和马云了。",{"type":182,"tag":198,"props":519,"children":520},{},[521],{"type":182,"tag":216,"props":522,"children":523},{},[524],{"type":195,"value":525},"数字经济重点产业",{"type":182,"tag":198,"props":527,"children":528},{},[529],{"type":182,"tag":314,"props":530,"children":532},{"alt":525,"src":531},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202503110714738.png",[],{"type":182,"tag":198,"props":534,"children":535},{},[536],{"type":182,"tag":216,"props":537,"children":538},{},[539],{"type":195,"value":540},"适应数字技术全面融入社会交往和日常生活新趋势，促进公共服务和社会运行方式创新，构筑全民畅享的数字生活。",{"type":182,"tag":198,"props":542,"children":543},{},[544],{"type":195,"value":545},"数字化社会主要涉及智慧公共服务、智慧城市、数字乡村等概念。之前在视频里见过深圳的公园里有扫码就能计数的跑步机（？）应该属于这一类智慧公共服务。",{"type":182,"tag":198,"props":547,"children":548},{},[549],{"type":182,"tag":207,"props":550,"children":551},{},[552],{"type":195,"value":553},"第六篇　全面深化改革 构建高水平社会主义市场经济体制",{"type":182,"tag":198,"props":555,"children":556},{},[557],{"type":182,"tag":207,"props":558,"children":559},{},[560],{"type":195,"value":561},"第七篇　坚持农业农村优先发展 全面推进乡村振兴",{"type":182,"tag":198,"props":563,"children":564},{},[565],{"type":182,"tag":207,"props":566,"children":567},{},[568],{"type":195,"value":569},"第八篇　完善新型城镇化战略 提升城镇化发展质量",{"type":182,"tag":198,"props":571,"children":572},{},[573],{"type":182,"tag":207,"props":574,"children":575},{},[576],{"type":195,"value":577},"第九篇　优化区域经济布局 促进区域协调发展",{"type":182,"tag":198,"props":579,"children":580},{},[581],{"type":182,"tag":207,"props":582,"children":583},{},[584],{"type":195,"value":585},"第十篇　发展社会主义先进文化 提升国家文化软实力",{"type":182,"tag":198,"props":587,"children":588},{},[589],{"type":182,"tag":207,"props":590,"children":591},{},[592],{"type":195,"value":593},"第十一篇　推动绿色发展 促进人与自然和谐共生",{"type":182,"tag":198,"props":595,"children":596},{},[597],{"type":182,"tag":207,"props":598,"children":599},{},[600],{"type":195,"value":601},"第十二篇　实行高水平对外开放 开拓合作共赢新局面",{"type":182,"tag":198,"props":603,"children":604},{},[605],{"type":182,"tag":207,"props":606,"children":607},{},[608],{"type":195,"value":609},"第十三篇　提升国民素质 促进人的全面发展",{"type":182,"tag":198,"props":611,"children":612},{},[613],{"type":182,"tag":207,"props":614,"children":615},{},[616],{"type":195,"value":617},"第十四篇　增进民生福祉 提升共建共治共享水平",{"type":182,"tag":198,"props":619,"children":620},{},[621],{"type":182,"tag":207,"props":622,"children":623},{},[624],{"type":195,"value":625},"第十五篇　统筹发展和安全 建设更高水平的平安中国",{"type":182,"tag":198,"props":627,"children":628},{},[629],{"type":182,"tag":207,"props":630,"children":631},{},[632],{"type":195,"value":633},"第十六篇　加快国防和军队现代化 实现富国和强军相统一",{"type":182,"tag":198,"props":635,"children":636},{},[637],{"type":182,"tag":207,"props":638,"children":639},{},[640],{"type":195,"value":641},"第十七篇　加强社会主义民主法治建设 健全党和国家监督制度",{"type":182,"tag":198,"props":643,"children":644},{},[645],{"type":182,"tag":207,"props":646,"children":647},{},[648],{"type":195,"value":649},"第十八篇　坚持“一国两制” 推进祖国统一",{"type":182,"tag":198,"props":651,"children":652},{},[653],{"type":182,"tag":207,"props":654,"children":655},{},[656],{"type":195,"value":657},"第十九篇　加强规划实施保障",{"title":175,"searchDepth":659,"depth":659,"links":660},2,[],"markdown","content:6.maps:_policy:five-years-plan-14.md","content","6.maps/_policy/five-years-plan-14.md","6.maps/_policy/five-years-plan-14","md",[668,672],{"_path":669,"title":670,"description":671},"/maps/_php/php","PHP","PHP 是一种广泛使用的开源服务器端脚本语言，特别适用于Web开发并可以嵌入HTML中。",{"_path":673,"title":674,"description":175},"/maps/_policy/policy","政策",1771071680125]