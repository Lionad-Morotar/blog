[{"data":1,"prerenderedAt":680},["ShallowReactive",2],{"navigation":3,"/maps/_policy/five-years-plan-14":173,"/maps/_policy/five-years-plan-14-surround":671},[4,35,92,98,125,134,158,164],{"title":5,"_path":6,"children":7},"心流思绪 / Heart Flows","/flows",[8,11,14,17,20,23,26,29,32],{"title":9,"_path":10},"📕 狮子的书单推荐","/flows/books",{"title":12,"_path":13},"🚝 四十二篇系列","/flows/forty-two",{"title":15,"_path":16},"🌃 长夜梦","/flows/long-night-dream",{"title":18,"_path":19},"🌌 万物联结与幸福感","/flows/everything",{"title":21,"_path":22},"⌛ 偷取时间","/flows/stealing-time-from-god",{"title":24,"_path":25},"🌆 表达和孤独","/flows/expression-and-loneliness",{"title":27,"_path":28},"🌧️ 我的腼腆","/flows/shy",{"title":30,"_path":31},"🥛 新工作，喝新饮料","/flows/drinking-while-thinking",{"title":33,"_path":34},"📝 心流归档","/flows/archive",{"title":36,"_path":37,"children":38},"技术博客 / Coder","/articles",[39,41,44,47,50,53,56,59,62,65,68,71,74,77,80,83,86,89],{"title":40,"_path":37},"🦁 欢迎",{"title":42,"_path":43},"📦 一个简单有效的端口命名策略：","/articles/simple-naming-method",{"title":45,"_path":46},"🌪️ Tailwind v4 如何兼容预处理器","/articles/tailwind4-with-sass",{"title":48,"_path":49},"🥞 在 tailwind 中使用现代化 CSS Layers","/articles/tailwind-sass-and-css-layer",{"title":51,"_path":52},"💻 本地部署 Qwen 翻译网页","/articles/local-translator",{"title":54,"_path":55},"🧊 模板解析器轻考古","/articles/micro-templating",{"title":57,"_path":58},"Ⓜ️ Mini CSS Parser","/articles/mini-css-parser",{"title":60,"_path":61},"🚩 向AI咨询前端问题","/articles/use-gpt-learn-complex-frontend",{"title":63,"_path":64},"⛸️ 怎样定制复杂组件的自定义滚动条？","/articles/use-scrollbars",{"title":66,"_path":67},"⚖️ 统一多组件库的层叠顺序","/articles/zindex-manager",{"title":69,"_path":70},"🕷️ 滑动验证码破解思路","/articles/crack-the-slider",{"title":72,"_path":73},"🌟 探秘 CSS 光影效果","/articles/css-light-travel",{"title":75,"_path":76},"🍲 设计模式与 JS 魔法锅","/articles/design-patterns-and-js-magic-pot",{"title":78,"_path":79},"🌐 Anysort：灵活、优雅的多属性排序","/articles/anysort-2th",{"title":81,"_path":82},"💫 CSS 幻术 | 抗锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"original_path":181,"body":182,"_type":665,"_id":666,"_source":667,"_file":668,"_stem":669,"_extension":670},"/maps/_policy/five-years-plan-14","_policy",false,true,"","五年规划","对未来五年内的发展目标、发展方向、发展重点、发展任务等进行系统安排和部署的规划。","content/6.maps/_policy/five-years-plan-14.md",{"type":183,"children":184,"toc":662},"root",[185,201,207,216,225,230,238,243,248,253,258,266,271,306,314,322,327,332,385,393,401,406,414,422,430,435,443,448,456,461,475,483,488,496,504,509,517,522,530,537,545,550,558,566,574,582,590,598,606,614,622,630,638,646,654],{"type":186,"tag":187,"props":188,"children":190},"element","h4",{"id":189},"中华人民共和国国民经济和社会发展第十四个五年规划和-2035-年远景目标纲要",[191],{"type":186,"tag":192,"props":193,"children":197},"a",{"href":194,"rel":195},"https://www.gov.cn/xinwen/2021-03/13/content_5592681.htm",[196],"nofollow",[198],{"type":199,"value":200},"text","《中华人民共和国国民经济和社会发展第十四个五年规划和 2035 年远景目标纲要》",{"type":186,"tag":202,"props":203,"children":204},"p",{},[205],{"type":199,"value":206},"2021-03-13",{"type":186,"tag":202,"props":208,"children":209},{},[210],{"type":186,"tag":211,"props":212,"children":213},"strong",{},[214],{"type":199,"value":215},"第一篇　开启全面建设社会主义现代化国家新征程",{"type":186,"tag":202,"props":217,"children":218},{},[219],{"type":186,"tag":220,"props":221,"children":222},"q",{},[223],{"type":199,"value":224},"（十三五期间）经济运行总体平稳，经济结构持续优化，国内生产总值突破 100 万亿元。创新型国家建设成果丰硕，在载人航天、探月工程、深海工程、超级计算、量子信息、“复兴号”高速列车、大飞机制造等领域取得一批重大科技成果。",{"type":186,"tag":202,"props":226,"children":227},{},[228],{"type":199,"value":229},"神威·太湖之光、墨子号、复兴号高速列车、国产大型客机 C919",{"type":186,"tag":202,"props":231,"children":232},{},[233],{"type":186,"tag":220,"props":234,"children":235},{},[236],{"type":199,"value":237},"（十三五期间）国际环境日趋复杂，不稳定性不确定性明显增加，新冠肺炎疫情影响广泛深远，世界经济陷入低迷期，经济全球化遭遇逆流，全球能源供需版图深刻变革，国际经济政治格局复杂多变，世界进入动荡变革期，单边主义、保护主义、霸权主义对世界和平与发展构成威胁。",{"type":186,"tag":202,"props":239,"children":240},{},[241],{"type":199,"value":242},"疫情除了增了公共卫生治理压力、对诸如旅游、航空、餐饮、零售和制造业等行业带来经济打击之外，在一定程度上促进了全球范围内对数字经济、在线办公、远程教育、跨境电商等新模式的探索。钉钉就是那会儿出圈的。",{"type":186,"tag":202,"props":244,"children":245},{},[246],{"type":199,"value":247},"单边主义指的是国际社会中实力地位较强的某一个国家，为了落实对本国有利的外交政策而忽视多数国家的人民意愿，违反国际社会潮流，不顾他国利益，拒绝采取协商途径，凭借自己的力量我行我素的行为。",{"type":186,"tag":202,"props":249,"children":250},{},[251],{"type":199,"value":252},"保护主义即贸易保护主义（Protectionism），指在对外贸易中限制进口以保护本国（地区）商品在国内市场免受外国商品竞争，以及向本国（地区）商品提供各种优惠以增强其国际竞争力的政策。",{"type":186,"tag":202,"props":254,"children":255},{},[256],{"type":199,"value":257},"霸权主义（Hegemonism），是指一国凭借其政治、军事和经济的极大优势，在全世界或个别地区维持秩序、主导国际事务或谋求统治地位的政策的意识形态。",{"type":186,"tag":202,"props":259,"children":260},{},[261],{"type":186,"tag":220,"props":262,"children":263},{},[264],{"type":199,"value":265},"展望 2035 年，我国将基本实现社会主义现代化，基本实现国防和军队现代化。",{"type":186,"tag":202,"props":267,"children":268},{},[269],{"type":199,"value":270},"社会主义现代化是个新概念，国防和军队现代化也是个没听过的概念。",{"type":186,"tag":272,"props":273,"children":274},"ul",{},[275,281,286,291,296,301],{"type":186,"tag":276,"props":277,"children":278},"li",{},[279],{"type":199,"value":280},"装备现代化：引入先进的军事技术，研发高精尖武器和装备。例如，高超音速武器、无人机技术、人工智能和网络战等领域。",{"type":186,"tag":276,"props":282,"children":283},{},[284],{"type":199,"value":285},"战略和战术的升级：根据现代战争的特点，如信息化、智能化和联合作战，优化军事战略和作战模式，使国防力量更加高效和精准。",{"type":186,"tag":276,"props":287,"children":288},{},[289],{"type":199,"value":290},"军队结构调整：现代化军队需要高效组织，例如推动从传统兵种向信息化、联合化方向的转型，提升全域作战能力。",{"type":186,"tag":276,"props":292,"children":293},{},[294],{"type":199,"value":295},"国防科技创新：通过国防科研与创新驱动，加速军事科技领域的突破，使国防技术始终具有国际竞争力。",{"type":186,"tag":276,"props":297,"children":298},{},[299],{"type":199,"value":300},"体制和管理现代化：完善军事体制，优化军队管理机制，加强国防资源分配的科学性和均衡性。",{"type":186,"tag":276,"props":302,"children":303},{},[304],{"type":199,"value":305},"后勤与保障能力提升：包括后勤物资、能源供应、医疗服务保障等现代化管理，使军队在复杂环境下具备持续作战的能力。",{"type":186,"tag":202,"props":307,"children":308},{},[309],{"type":186,"tag":220,"props":310,"children":311},{},[312],{"type":199,"value":313},"“十四五”时期经济社会发展主要指标",{"type":186,"tag":202,"props":315,"children":316},{},[317],{"type":186,"tag":318,"props":319,"children":321},"img",{"alt":313,"src":320},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202503110615037.png",[],{"type":186,"tag":202,"props":323,"children":324},{},[325],{"type":199,"value":326},"约束性指标大多在“绿色生态”和“安全保障”类别。创新驱动主要关注：全社会研发经费、万人专利数、数字经济核心产业 GDP 比重。",{"type":186,"tag":202,"props":328,"children":329},{},[330],{"type":199,"value":331},"数字经济核心产业包括哪些呢？",{"type":186,"tag":272,"props":333,"children":334},{},[335,340,345,350,355,360,365,370,375,380],{"type":186,"tag":276,"props":336,"children":337},{},[338],{"type":199,"value":339},"电子信息制造业：计算机、通信设备、半导体芯片、传感器等核心硬件设备的生产，是数字经济发展的基础设施。",{"type":186,"tag":276,"props":341,"children":342},{},[343],{"type":199,"value":344},"软件和信息技术服务业：软件开发、操作系统、数据库管理系统、云计算服务、大数据解决方案等构成了支撑数字经济运行的技术基础。",{"type":186,"tag":276,"props":346,"children":347},{},[348],{"type":199,"value":349},"通信和网络产业：5G、光纤宽带、物联网、卫星通信等技术与网络架构，它们对数字经济的互联互通至关重要。",{"type":186,"tag":276,"props":351,"children":352},{},[353],{"type":199,"value":354},"互联网产业：电子商务、搜索引擎、社交媒体、流媒体服务、网络广告等依托互联网的平台经济形式。",{"type":186,"tag":276,"props":356,"children":357},{},[358],{"type":199,"value":359},"云计算和大数据产业：大数据存储和分析，云计算技术与服务，是实现数字化管理、预测和商业价值挖掘的核心。",{"type":186,"tag":276,"props":361,"children":362},{},[363],{"type":199,"value":364},"人工智能（AI）产业：AI 算法开发、计算机视觉、自然语言处理、深度学习等技术领域，用于智能化工业、服务业、和商业决策。",{"type":186,"tag":276,"props":366,"children":367},{},[368],{"type":199,"value":369},"区块链产业：提供分布式账本技术，应用于金融科技（如虚拟货币）、供应链管理、电子政务等领域。",{"type":186,"tag":276,"props":371,"children":372},{},[373],{"type":199,"value":374},"数字内容产业：游戏、虚拟现实（VR）、增强现实（AR）、在线教育、数字媒体、音视频内容创作与传播等新兴内容形式。",{"type":186,"tag":276,"props":376,"children":377},{},[378],{"type":199,"value":379},"信息安全产业：网络安全、数据加密、防火墙等。",{"type":186,"tag":276,"props":381,"children":382},{},[383],{"type":199,"value":384},"智能制造和工业互联网：将数字技术与传统制造业深度融合，实现工业设备智能化、生产流程数字化。",{"type":186,"tag":202,"props":386,"children":387},{},[388],{"type":186,"tag":211,"props":389,"children":390},{},[391],{"type":199,"value":392},"第二篇　坚持创新驱动发展 全面塑造发展新优势",{"type":186,"tag":202,"props":394,"children":395},{},[396],{"type":186,"tag":220,"props":397,"children":398},{},[399],{"type":199,"value":400},"强化国家战略科技力量",{"type":186,"tag":202,"props":402,"children":403},{},[404],{"type":199,"value":405},"整合优化科技资源配置，也就搞好国家实验室、创新基地、资源共享、研究型大学等概念，至于战略目标，见下图：",{"type":186,"tag":202,"props":407,"children":408},{},[409],{"type":186,"tag":318,"props":410,"children":413},{"alt":411,"src":412},"科技前沿领域","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202503110632135.png",[],{"type":186,"tag":202,"props":415,"children":416},{},[417],{"type":186,"tag":211,"props":418,"children":419},{},[420],{"type":199,"value":421},"第三篇　加快发展现代产业体系 巩固壮大实体经济根基",{"type":186,"tag":202,"props":423,"children":424},{},[425],{"type":186,"tag":220,"props":426,"children":427},{},[428],{"type":199,"value":429},"加强产业基础能力建设，实施产业基础再造工程",{"type":186,"tag":202,"props":431,"children":432},{},[433],{"type":199,"value":434},"除了补齐工艺技术短板，在软件方面也看到了：推动首版次软件示范应用，建设生产应用示范平台和标准计量、认证认可、检验检测、试验验证等产业技术基础公共服务平台，完善技术、工艺等工业基础数据库。",{"type":186,"tag":202,"props":436,"children":437},{},[438],{"type":186,"tag":220,"props":439,"children":440},{},[441],{"type":199,"value":442},"实施制造业降本减负行动",{"type":186,"tag":202,"props":444,"children":445},{},[446],{"type":199,"value":447},"包括支持建设中小企业信息、技术、进出口和数字化转型综合性服务平台。北斗包含在内，也难怪进来的新手机顶配版本都是带卫星通讯的。数字化不属于制造业的“核心竞争力”，而是和网络一样属于基础设施。",{"type":186,"tag":202,"props":449,"children":450},{},[451],{"type":186,"tag":220,"props":452,"children":453},{},[454],{"type":199,"value":455},"建设高速泛在、天地一体、集成互联、安全高效的信息基础设施，增强数据感知、传输、存储和运算能力；加快构建全国一体化大数据中心体系；加快交通、能源、市政等传统基础设施数字化改造；发挥市场主导作用，打通多元化投资渠道，构建新型基础设施标准体系。",{"type":186,"tag":202,"props":457,"children":458},{},[459],{"type":199,"value":460},"除了数据和计算，电力、交通、水利也算基础设施，而且这几项天然适合放到一起讨论。",{"type":186,"tag":202,"props":462,"children":463},{},[464,466,473],{"type":199,"value":465},"国家信息中心还在 2024 年设立了大数据发展部，",{"type":186,"tag":192,"props":467,"children":470},{"href":468,"rel":469},"http://www.sic.gov.cn/sic/78/97/0705/20240705102749893150783_pc.html",[196],[471],{"type":199,"value":472},"他们的职责",{"type":199,"value":474}," 是面向发改委等上级开展大数据、大算力、大模型前沿研究与应用。",{"type":186,"tag":202,"props":476,"children":477},{},[478],{"type":186,"tag":211,"props":479,"children":480},{},[481],{"type":199,"value":482},"第四篇　形成强大国内市场 构建新发展格局",{"type":186,"tag":202,"props":484,"children":485},{},[486],{"type":199,"value":487},"内需体系主要由国内消费需求和投资需求构成，国内大循环需要建立在坚实的内需体系之上，只有当国内居民收入不断提高、消费能力持续扩大、投资领域有广阔空间时，大循环才有足够活力。",{"type":186,"tag":202,"props":489,"children":490},{},[491],{"type":186,"tag":211,"props":492,"children":493},{},[494],{"type":199,"value":495},"第五篇　加快数字化发展 建设数字中国",{"type":186,"tag":202,"props":497,"children":498},{},[499],{"type":186,"tag":220,"props":500,"children":501},{},[502],{"type":199,"value":503},"加强关键数字技术创新应用，加快布局量子计算、量子通信、神经芯片、DNA 存储等前沿技术，加强信息科学与生命科学、材料等基础学科的交叉创新，支持数字技术开源社区等创新联合体发展，完善开源知识产权和法律体系，鼓励企业开放软件源代码、硬件设计和应用服务。",{"type":186,"tag":202,"props":505,"children":506},{},[507],{"type":199,"value":508},"看到了不少新东西，DNA 存储、交叉创新、开放源码等等。",{"type":186,"tag":202,"props":510,"children":511},{},[512],{"type":186,"tag":220,"props":513,"children":514},{},[515],{"type":199,"value":516},"鼓励企业开放搜索、电商、社交等数据，发展第三方大数据服务产业。",{"type":186,"tag":202,"props":518,"children":519},{},[520],{"type":199,"value":521},"就差点名张小龙和马云了。",{"type":186,"tag":202,"props":523,"children":524},{},[525],{"type":186,"tag":220,"props":526,"children":527},{},[528],{"type":199,"value":529},"数字经济重点产业",{"type":186,"tag":202,"props":531,"children":532},{},[533],{"type":186,"tag":318,"props":534,"children":536},{"alt":529,"src":535},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202503110714738.png",[],{"type":186,"tag":202,"props":538,"children":539},{},[540],{"type":186,"tag":220,"props":541,"children":542},{},[543],{"type":199,"value":544},"适应数字技术全面融入社会交往和日常生活新趋势，促进公共服务和社会运行方式创新，构筑全民畅享的数字生活。",{"type":186,"tag":202,"props":546,"children":547},{},[548],{"type":199,"value":549},"数字化社会主要涉及智慧公共服务、智慧城市、数字乡村等概念。之前在视频里见过深圳的公园里有扫码就能计数的跑步机（？）应该属于这一类智慧公共服务。",{"type":186,"tag":202,"props":551,"children":552},{},[553],{"type":186,"tag":211,"props":554,"children":555},{},[556],{"type":199,"value":557},"第六篇　全面深化改革 构建高水平社会主义市场经济体制",{"type":186,"tag":202,"props":559,"children":560},{},[561],{"type":186,"tag":211,"props":562,"children":563},{},[564],{"type":199,"value":565},"第七篇　坚持农业农村优先发展 全面推进乡村振兴",{"type":186,"tag":202,"props":567,"children":568},{},[569],{"type":186,"tag":211,"props":570,"children":571},{},[572],{"type":199,"value":573},"第八篇　完善新型城镇化战略 提升城镇化发展质量",{"type":186,"tag":202,"props":575,"children":576},{},[577],{"type":186,"tag":211,"props":578,"children":579},{},[580],{"type":199,"value":581},"第九篇　优化区域经济布局 促进区域协调发展",{"type":186,"tag":202,"props":583,"children":584},{},[585],{"type":186,"tag":211,"props":586,"children":587},{},[588],{"type":199,"value":589},"第十篇　发展社会主义先进文化 提升国家文化软实力",{"type":186,"tag":202,"props":591,"children":592},{},[593],{"type":186,"tag":211,"props":594,"children":595},{},[596],{"type":199,"value":597},"第十一篇　推动绿色发展 促进人与自然和谐共生",{"type":186,"tag":202,"props":599,"children":600},{},[601],{"type":186,"tag":211,"props":602,"children":603},{},[604],{"type":199,"value":605},"第十二篇　实行高水平对外开放 开拓合作共赢新局面",{"type":186,"tag":202,"props":607,"children":608},{},[609],{"type":186,"tag":211,"props":610,"children":611},{},[612],{"type":199,"value":613},"第十三篇　提升国民素质 促进人的全面发展",{"type":186,"tag":202,"props":615,"children":616},{},[617],{"type":186,"tag":211,"props":618,"children":619},{},[620],{"type":199,"value":621},"第十四篇　增进民生福祉 提升共建共治共享水平",{"type":186,"tag":202,"props":623,"children":624},{},[625],{"type":186,"tag":211,"props":626,"children":627},{},[628],{"type":199,"value":629},"第十五篇　统筹发展和安全 建设更高水平的平安中国",{"type":186,"tag":202,"props":631,"children":632},{},[633],{"type":186,"tag":211,"props":634,"children":635},{},[636],{"type":199,"value":637},"第十六篇　加快国防和军队现代化 实现富国和强军相统一",{"type":186,"tag":202,"props":639,"children":640},{},[641],{"type":186,"tag":211,"props":642,"children":643},{},[644],{"type":199,"value":645},"第十七篇　加强社会主义民主法治建设 健全党和国家监督制度",{"type":186,"tag":202,"props":647,"children":648},{},[649],{"type":186,"tag":211,"props":650,"children":651},{},[652],{"type":199,"value":653},"第十八篇　坚持“一国两制” 推进祖国统一",{"type":186,"tag":202,"props":655,"children":656},{},[657],{"type":186,"tag":211,"props":658,"children":659},{},[660],{"type":199,"value":661},"第十九篇　加强规划实施保障",{"title":178,"searchDepth":663,"depth":663,"links":664},2,[],"markdown","content:6.maps:_policy:five-years-plan-14.md","content","6.maps/_policy/five-years-plan-14.md","6.maps/_policy/five-years-plan-14","md",[672,676],{"_path":673,"title":674,"description":675},"/maps/_php/php/php","PHP","PHP 是一种广泛使用的开源服务器端脚本语言，特别适用于Web开发并可以嵌入HTML中。",{"_path":677,"title":678,"description":679},"/maps/_policy/industrial-parks-guide","工业园区高质量发展指引","工信部、国家发改委联合印发的工业园区发展政策，明确\"特色化、集约化、数智化、绿色化、规范化\"五化发展方向",1772504934065]