ganization","organization",false,true,"","组织","团队组织架构、管理方法、沟通方式等。","content/6.maps/_management/organization.md",{"type":183,"children":184,"toc":342},"root",[185,193,208,213,221,226,238,243,250,264,281,287,293,298,303,315,321],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"组织方法",[191],{"type":192,"value":189},"text",{"type":186,"tag":194,"props":195,"children":196},"ul",{},[197],{"type":186,"tag":198,"props":199,"children":200},"li",{},[201],{"type":186,"tag":202,"props":203,"children":205},"a",{"href":204},"/maps/_management/shape-up/shape-up",[206],{"type":192,"value":207},"Shape Up",{"type":186,"tag":187,"props":209,"children":211},{"id":210},"目标管理",[212],{"type":192,"value":210},{"type":186,"tag":194,"props":214,"children":215},{},[216],{"type":186,"tag":198,"props":217,"children":218},{},[219],{"type":192,"value":220},"OKR",{"type":186,"tag":187,"props":222,"children":224},{"id":223},"组织切面",[225],{"type":192,"value":223},{"type":186,"tag":194,"props":227,"children":228},{},[229],{"type":186,"tag":198,"props":230,"children":231},{},[232],{"type":186,"tag":202,"props":233,"children":235},{"href":234},"/maps/_management/slice/standalone-data-engineering-team",[236],{"type":192,"value":237},"独立数据工程团队",{"type":186,"tag":187,"props":239,"children":241},{"id":240},"团队规模",[242],{"type":192,"value":240},{"type":186,"tag":244,"props":245,"children":247},"h4",{"id":246},"什么是两个披萨团队原则",[248],{"type":192,"value":249},"什么是\"两个披萨\"团队原则？",{"type":186,"tag":251,"props":252,"children":253},"p",{},[254,256,262],{"type":192,"value":255},"亚马逊创始人贝佐斯提出的管理原则：团队规模应控制在",{"type":186,"tag":257,"props":258,"children":259},"strong",{},[260],{"type":192,"value":261},"两个披萨能喂饱的人数",{"type":192,"value":263},"范围内，即约 5-8 人。AI 出现以后，这一原则可能演变为\"单披萨团队\"——只需 2-3 人（含产品经理和设计师）即可完成过去需要更大团队的工作。这反映了 AI 对组织形态的深刻影响：小团队的生产力正在被重新定义。",{"type":186,"tag":265,"props":266,"children":267},"blockquote",{},[268],{"type":186,"tag":251,"props":269,"children":270},{},[271,273],{"type":192,"value":272},"#周刊摘录 见：",{"type":186,"tag":202,"props":274,"children":278},{"href":275,"rel":276},"https://www.ruanyifeng.com/blog/2026/02/weekly-issue-385.html",[277],"nofollow",[279],{"type":192,"value":280},"科技周刊第385期",{"type":186,"tag":187,"props":282,"children":284},{"id":283},"agent-teams-与组织架构",[285],{"type":192,"value":286},"Agent Teams 与组织架构",{"type":186,"tag":244,"props":288,"children":290},{"id":289},"agentic-swarm-的组织架构陷阱",[291],{"type":192,"value":292},"Agentic Swarm 的组织架构陷阱",{"type":186,"tag":251,"props":294,"children":295},{},[296],{"type":192,"value":297},"企业将 AI Agent 简单替换组织底层的\"机器人版组织架构图\"模式存在根本性缺陷。这种做法本质上是将现有企业层级中的底层替换为一群 AI Agent,保留人类作为监督者——这看似熟悉且令人安心,但恰恰是最大的危险信号。真正的问题在于:当 Agent 能够自主协调和执行时,中层管理的\"信息路由\"价值被抽空,组织需要从根本上重新思考结构,而非简单替换。",{"type":186,"tag":251,"props":299,"children":300},{},[301],{"type":192,"value":302},"我的看法是,Agent Teams 本身就不是为了构建人类组织的数字化复刻,那是对生产技术理解不够深刻的人的自嗨,实际上 Agent Teams 主要是解决工程问题,和上下文管理相关。",{"type":186,"tag":251,"props":304,"children":305},{},[306,308],{"type":192,"value":307},"见：",{"type":186,"tag":202,"props":309,"children":312},{"href":310,"rel":311},"https://www.joanwestenberg.com/agentic-swarms-are-an-org-chart-delusion/",[277],[313],{"type":192,"value":314},"Agentic Swarms Are an Org-Chart Delusion - Joan Westenberg",{"type":186,"tag":187,"props":316,"children":318},{"id":317},"domain",[319],{"type":192,"value":320},"Domain",{"type":186,"tag":194,"props":322,"children":323},{},[324,333],{"type":186,"tag":198,"props":325,"children":326},{},[327],{"type":186,"tag":202,"props":328,"children":330},{"href":329},"/maps/_management/shadow-it/ai-accelerated-shadow-it",[331],{"type":192,"value":332},"AI-accelerated Shadow IT",{"type":186,"tag":198,"props":334,"children":335},{},[336],{"type":186,"tag":202,"props":337,"children":339},{"href":338},"/maps/_management/capacity-driven-development/capacity-driven-development",[340],{"type":192,"value":341},"产能驱动开发",{"title":178,"searchDepth":343,"depth":343,"links":344},2,[345,346,347,348,349,