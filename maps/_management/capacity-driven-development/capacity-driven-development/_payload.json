[{"data":1,"prerenderedAt":1149},["ShallowReactive",2],{"navigation":3,"/maps/_management/capacity-driven-development/capacity-driven-development":173,"/maps/_management/capacity-driven-development/capacity-driven-development-surround":1140},[4,35,92,98,125,134,158,164],{"title":5,"_path":6,"children":7},"心流思绪 / Heart Flows","/flows",[8,11,14,17,20,23,26,29,32],{"title":9,"_path":10},"📕 狮子的书单推荐","/flows/books",{"title":12,"_path":13},"🚝 四十二篇系列","/flows/forty-two",{"title":15,"_path":16},"🌃 长夜梦","/flows/long-night-dream",{"title":18,"_path":19},"🌌 万物联结与幸福感","/flows/everything",{"title":21,"_path":22},"⌛ 偷取时间","/flows/stealing-time-from-god",{"title":24,"_path":25},"🌆 表达和孤独","/flows/expression-and-loneliness",{"title":27,"_path":28},"🌧️ 我的腼腆","/flows/shy",{"title":30,"_path":31},"🥛 新工作，喝新饮料","/flows/drinking-while-thinking",{"title":33,"_path":34},"📝 心流归档","/flows/archive",{"title":36,"_path":37,"children":38},"技术博客 / Coder","/articles",[39,41,44,47,50,53,56,59,62,65,68,71,74,77,80,83,86,89],{"title":40,"_path":37},"🦁 欢迎",{"title":42,"_path":43},"📦 一个简单有效的端口命名策略：","/articles/simple-naming-method",{"title":45,"_path":46},"🌪️ Tailwind v4 如何兼容预处理器","/articles/tailwind4-with-sass",{"title":48,"_path":49},"🥞 在 tailwind 中使用现代化 CSS Layers","/articles/tailwind-sass-and-css-layer",{"title":51,"_path":52},"💻 本地部署 Qwen 翻译网页","/articles/local-translator",{"title":54,"_path":55},"🧊 模板解析器轻考古","/articles/micro-templating",{"title":57,"_path":58},"Ⓜ️ Mini CSS Parser","/articles/mini-css-parser",{"title":60,"_path":61},"🚩 向AI咨询前端问题","/articles/use-gpt-learn-complex-frontend",{"title":63,"_path":64},"⛸️ 怎样定制复杂组件的自定义滚动条？","/articles/use-scrollbars",{"title":66,"_path":67},"⚖️ 统一多组件库的层叠顺序","/articles/zindex-manager",{"title":69,"_path":70},"🕷️ 滑动验证码破解思路","/articles/crack-the-slider",{"title":72,"_path":73},"🌟 探秘 CSS 光影效果","/articles/css-light-travel",{"title":75,"_path":76},"🍲 设计模式与 JS 魔法锅","/articles/design-patterns-and-js-magic-pot",{"title":78,"_path":79},"🌐 Anysort：灵活、优雅的多属性排序","/articles/anysort-2th",{"title":81,"_path":82},"💫 CSS 幻术 | 抗锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"original_path":181,"body":182,"_type":1134,"_id":1135,"_source":1136,"_file":1137,"_stem":1138,"_extension":1139},"/maps/_management/capacity-driven-development/capacity-driven-development","capacity-driven-development",false,true,"","Capacity-driven development（产能驱动开发）","警惕用「填满人」替代「保障价值流」的局部最优，建议用系统健康与组织调度来管理空闲产能。","content/6.maps/_management/capacity-driven-development.md",{"type":183,"children":184,"toc":1121},"root",[185,194,200,205,210,230,236,243,250,255,268,273,286,291,297,303,308,321,326,339,344,349,388,393,406,412,417,456,461,474,480,486,491,535,548,554,559,590,595,613,619,624,629,647,652,657,662,719,725,730,735,774,779,792,797,802,841,846,859,865,871,876,929,934,940,945,984,989,995,1000,1046,1051,1057,1062,1111,1116],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"brief",[191],{"type":192,"value":193},"text","Brief",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198],{"type":192,"value":199},"在现代软件开发实践中，成功的关键是聚焦工作流本身，而不是单纯追求资源利用率最大化。Stream-aligned 团队本应围绕单一且有价值的流（例如一条用户旅程或一个产品）工作，从而高效地交付端到端价值。",{"type":186,"tag":195,"props":201,"children":202},{},[203],{"type":192,"value":204},"目前出现了一个令人担忧的趋势：所谓\"产能驱动开发\"。当这些团队出现空闲产能时，会去承接来自其他产品或其他价值流的功能。这在短期内似乎提高了效率，但本质上只是适合应对突发需求高峰的局部优化。一旦被常态化，会显著增加团队认知负荷和技术债；在最坏情况下，由于跨产品频繁上下文切换的成本不断叠加，可能导致类似\"拥塞崩溃\"的现象，整体交付能力反而下降。",{"type":186,"tag":195,"props":206,"children":207},{},[208],{"type":192,"value":209},"当团队出现富余产能时，更好的选择是优先投入到系统健康的改进上。为了更有效地管理产能，可以：",{"type":186,"tag":211,"props":212,"children":213},"ul",{},[214,220,225],{"type":186,"tag":215,"props":216,"children":217},"li",{},[218],{"type":192,"value":219},"使用 WIP 限制（Work-in-Progress limits）来控制相邻价值流上的并行工作；",{"type":186,"tag":215,"props":221,"children":222},{},[223],{"type":192,"value":224},"通过跨技能训练（cross-training）来平衡不同时间段的需求高峰；",{"type":186,"tag":215,"props":226,"children":227},{},[228],{"type":192,"value":229},"在需要时采用动态重组团队（dynamic reteaming），而不是简单通过\"多接单\"填满人力。",{"type":186,"tag":187,"props":231,"children":233},{"id":232},"details",[234],{"type":192,"value":235},"Details",{"type":186,"tag":237,"props":238,"children":240},"h3",{"id":239},"背景与现状从人不能闲着到流不能乱",[241],{"type":192,"value":242},"背景与现状：从「人不能闲着」到「流不能乱」",{"type":186,"tag":244,"props":245,"children":247},"h4",{"id":246},"为什么现在要讨论-capacity-driven-development",[248],{"type":192,"value":249},"为什么现在要讨论 Capacity-driven development",{"type":186,"tag":195,"props":251,"children":252},{},[253],{"type":192,"value":254},"在很多正在向现代工程体系演进的组织里，大家已经接受：",{"type":186,"tag":211,"props":256,"children":257},{},[258,263],{"type":186,"tag":215,"props":259,"children":260},{},[261],{"type":192,"value":262},"用 stream-aligned 团队围绕某条价值流或产品组织；",{"type":186,"tag":215,"props":264,"children":265},{},[266],{"type":192,"value":267},"通过端到端 ownership 保证交付速度和反馈闭环。",{"type":186,"tag":195,"props":269,"children":270},{},[271],{"type":192,"value":272},"但是在落地过程中，传统的「人力利用率」心智往往没有一起升级：",{"type":186,"tag":211,"props":274,"children":275},{},[276,281],{"type":186,"tag":215,"props":277,"children":278},{},[279],{"type":192,"value":280},"当发现某个团队近期需求较少，就自然地把其他产品/流的 backlog 塞过去；",{"type":186,"tag":215,"props":282,"children":283},{},[284],{"type":192,"value":285},"产能调度的基本目标仍然是\"不要有闲人\"，而不是\"保障关键流的稳态和系统健康\"。",{"type":186,"tag":195,"props":287,"children":288},{},[289],{"type":192,"value":290},"在这种语境下，\"产能驱动开发\"很容易变成一种不被察觉、但对系统长期健康影响巨大的反模式。",{"type":186,"tag":237,"props":292,"children":294},{"id":293},"问题与风险局部最优带来的系统性退化",[295],{"type":192,"value":296},"问题与风险：局部最优带来的系统性退化",{"type":186,"tag":244,"props":298,"children":300},{"id":299},"核心矛盾填满人-vs-保持单一价值流专注",[301],{"type":192,"value":302},"核心矛盾：填满人 vs 保持单一价值流专注",{"type":186,"tag":195,"props":304,"children":305},{},[306],{"type":192,"value":307},"原文指出的本质冲突是：",{"type":186,"tag":211,"props":309,"children":310},{},[311,316],{"type":186,"tag":215,"props":312,"children":313},{},[314],{"type":192,"value":315},"设计初衷：stream-aligned 团队只专注于一个单一、清晰的价值流；",{"type":186,"tag":215,"props":317,"children":318},{},[319],{"type":192,"value":320},"实际操作：当有空档，就去做其他产品或 value stream 的功能。",{"type":186,"tag":195,"props":322,"children":323},{},[324],{"type":192,"value":325},"这种偏差带来的典型风险包括：",{"type":186,"tag":211,"props":327,"children":328},{},[329,334],{"type":186,"tag":215,"props":330,"children":331},{},[332],{"type":192,"value":333},"价值流聚焦被打散，团队从\"深耕一个流\"变成\"多线拉扯\"；",{"type":186,"tag":215,"props":335,"children":336},{},[337],{"type":192,"value":338},"注意力被短期需求填满，长期的系统性改进持续被挤出优先级。",{"type":186,"tag":244,"props":340,"children":342},{"id":341},"认知负荷与上下文切换成本",[343],{"type":192,"value":341},{"type":186,"tag":195,"props":345,"children":346},{},[347],{"type":192,"value":348},"当团队开始常态化接多个流的工作时：",{"type":186,"tag":211,"props":350,"children":351},{},[352,370],{"type":186,"tag":215,"props":353,"children":354},{},[355,357],{"type":192,"value":356},"业务维度：\n",{"type":186,"tag":211,"props":358,"children":359},{},[360,365],{"type":186,"tag":215,"props":361,"children":362},{},[363],{"type":192,"value":364},"团队被迫理解多个产品/旅程的规则和边界；",{"type":186,"tag":215,"props":366,"children":367},{},[368],{"type":192,"value":369},"心智模型从\"一条清晰主线\"变成若干不完整的碎片。",{"type":186,"tag":215,"props":371,"children":372},{},[373,375],{"type":192,"value":374},"技术维度：\n",{"type":186,"tag":211,"props":376,"children":377},{},[378,383],{"type":186,"tag":215,"props":379,"children":380},{},[381],{"type":192,"value":382},"可能涉及不同代码库、部署 pipeline、监控体系、合规约束；",{"type":186,"tag":215,"props":384,"children":385},{},[386],{"type":192,"value":387},"每一次任务切换，都是一次完整的上下文加载与卸载。",{"type":186,"tag":195,"props":389,"children":390},{},[391],{"type":192,"value":392},"这些成本短期内很隐性，但累积效果往往是：",{"type":186,"tag":211,"props":394,"children":395},{},[396,401],{"type":186,"tag":215,"props":397,"children":398},{},[399],{"type":192,"value":400},"Throughput 下降：表面上故事点完成不少，实际交付节奏变慢；",{"type":186,"tag":215,"props":402,"children":403},{},[404],{"type":192,"value":405},"质量波动：在不熟悉的上下文里更容易引入缺陷，也更难做好非功能性要求。",{"type":186,"tag":244,"props":407,"children":409},{"id":408},"技术债与拥塞崩溃",[410],{"type":192,"value":411},"技术债与\"拥塞崩溃\"",{"type":186,"tag":195,"props":413,"children":414},{},[415],{"type":192,"value":416},"原文特别强调的\"congestion collapse\"值得重视：",{"type":186,"tag":211,"props":418,"children":419},{},[420,438],{"type":186,"tag":215,"props":421,"children":422},{},[423,425],{"type":192,"value":424},"当多个产品/流都把团队视作\"可借用的通用产能池\"时：\n",{"type":186,"tag":211,"props":426,"children":427},{},[428,433],{"type":186,"tag":215,"props":429,"children":430},{},[431],{"type":192,"value":432},"任何流的需求高峰都会叠加到这个团队上；",{"type":186,"tag":215,"props":434,"children":435},{},[436],{"type":192,"value":437},"优先级频繁重排，上下文不断来回切换。",{"type":186,"tag":215,"props":439,"children":440},{},[441,443],{"type":192,"value":442},"结果是：\n",{"type":186,"tag":211,"props":444,"children":445},{},[446,451],{"type":186,"tag":215,"props":447,"children":448},{},[449],{"type":192,"value":450},"看起来事情全都在推进，实际上没有一个流推进得好；",{"type":186,"tag":215,"props":452,"children":453},{},[454],{"type":192,"value":455},"新需求和缺陷互相挤压，技术债只增不减。",{"type":186,"tag":195,"props":457,"children":458},{},[459],{"type":192,"value":460},"同时，当团队只作为\"支援劳动力\"参与其他流时：",{"type":186,"tag":211,"props":462,"children":463},{},[464,469],{"type":186,"tag":215,"props":465,"children":466},{},[467],{"type":192,"value":468},"对于那些流的技术决策和演进路径缺乏长期 ownership；",{"type":186,"tag":215,"props":470,"children":471},{},[472],{"type":192,"value":473},"为赶进度容易落入局部 hack，长远看拖累系统整体演进。",{"type":186,"tag":237,"props":475,"children":477},{"id":476},"模式与原理从产能导向回到价值流导向",[478],{"type":192,"value":479},"模式与原理：从「产能导向」回到「价值流导向」",{"type":186,"tag":244,"props":481,"children":483},{"id":482},"capacity-driven-development-的模式特征",[484],{"type":192,"value":485},"Capacity-driven development 的模式特征",{"type":186,"tag":195,"props":487,"children":488},{},[489],{"type":192,"value":490},"从模式角度看，capacity-driven development 具有几个典型特征：",{"type":186,"tag":211,"props":492,"children":493},{},[494,517],{"type":186,"tag":215,"props":495,"children":496},{},[497,499],{"type":192,"value":498},"优化目标被设在\"让每个团队都满负荷工作\"，而不是：\n",{"type":186,"tag":211,"props":500,"children":501},{},[502,507,512],{"type":186,"tag":215,"props":503,"children":504},{},[505],{"type":192,"value":506},"缩短端到端 lead time；",{"type":186,"tag":215,"props":508,"children":509},{},[510],{"type":192,"value":511},"提升关键流的可靠性和可预期性；",{"type":186,"tag":215,"props":513,"children":514},{},[515],{"type":192,"value":516},"改善架构和工程基础设施。",{"type":186,"tag":215,"props":518,"children":519},{},[520,522],{"type":192,"value":521},"组织层面缺乏系统性调度手段，于是：\n",{"type":186,"tag":211,"props":523,"children":524},{},[525,530],{"type":186,"tag":215,"props":526,"children":527},{},[528],{"type":192,"value":529},"用\"多接项目/多接 feature\"来填平不均匀负载；",{"type":186,"tag":215,"props":531,"children":532},{},[533],{"type":192,"value":534},"把结构性问题（流划分、组织边界、平台能力不足）压在一线团队的 task 分配上。",{"type":186,"tag":195,"props":536,"children":537},{},[538,540,546],{"type":192,"value":539},"原文的态度非常明确：这种做法仅在",{"type":186,"tag":541,"props":542,"children":543},"strong",{},[544],{"type":192,"value":545},"应对突发需求高峰",{"type":192,"value":547},"时是合理的局部优化，一旦常态化，就是系统性的反模式。",{"type":186,"tag":244,"props":549,"children":551},{"id":550},"推荐的原则空闲产能优先投向系统健康",[552],{"type":192,"value":553},"推荐的原则：空闲产能优先投向系统健康",{"type":186,"tag":195,"props":555,"children":556},{},[557],{"type":192,"value":558},"原文给出的对策是把\"多余产能\"视为改善系统健康的机会，而不是自由市场里的\"可出售工时\"：",{"type":186,"tag":211,"props":560,"children":561},{},[562],{"type":186,"tag":215,"props":563,"children":564},{},[565,567],{"type":192,"value":566},"当一个 stream-aligned 团队出现富余产能时，更优先的方向包括：\n",{"type":186,"tag":211,"props":568,"children":569},{},[570,575,580,585],{"type":186,"tag":215,"props":571,"children":572},{},[573],{"type":192,"value":574},"偿还技术债；",{"type":186,"tag":215,"props":576,"children":577},{},[578],{"type":192,"value":579},"提升平台与工程效率；",{"type":186,"tag":215,"props":581,"children":582},{},[583],{"type":192,"value":584},"强化可观测性与稳定性；",{"type":186,"tag":215,"props":586,"children":587},{},[588],{"type":192,"value":589},"改善开发者体验（DevEx）等。",{"type":186,"tag":195,"props":591,"children":592},{},[593],{"type":192,"value":594},"这背后的逻辑是：",{"type":186,"tag":211,"props":596,"children":597},{},[598,603,608],{"type":186,"tag":215,"props":599,"children":600},{},[601],{"type":192,"value":602},"系统健康的改进往往难以在高需求期挤进 backlog；",{"type":186,"tag":215,"props":604,"children":605},{},[606],{"type":192,"value":607},"利用低需求期系统性加强\"基础设施\"，能提升未来处理高负载的能力；",{"type":186,"tag":215,"props":609,"children":610},{},[611],{"type":192,"value":612},"与\"多接其他流需求\"相比，这种投资对长期吞吐量和质量更有保障。",{"type":186,"tag":237,"props":614,"children":616},{"id":615},"对比与演进旧的多项目团队思路-vs-新的-stream-aligned-实践",[617],{"type":192,"value":618},"对比与演进：旧的「多项目团队」思路 vs 新的 Stream-aligned 实践",{"type":186,"tag":244,"props":620,"children":622},{"id":621},"传统多项目模式的惯性",[623],{"type":192,"value":621},{"type":186,"tag":195,"props":625,"children":626},{},[627],{"type":192,"value":628},"很多团队的历史状态是\"多项目执行单元\"：",{"type":186,"tag":211,"props":630,"children":631},{},[632,637,642],{"type":186,"tag":215,"props":633,"children":634},{},[635],{"type":192,"value":636},"同一团队同时为多个产品、多个项目服务；",{"type":186,"tag":215,"props":638,"children":639},{},[640],{"type":192,"value":641},"通过工时分配和项目数量来衡量价值；",{"type":186,"tag":215,"props":643,"children":644},{},[645],{"type":192,"value":646},"\"谁有空就去哪儿支援\"是默认调度策略。",{"type":186,"tag":195,"props":648,"children":649},{},[650],{"type":192,"value":651},"在这种文化下，当组织开始谈 stream-aligned 时，容易出现\"名义上围绕流组织，实际上仍然是通用产能池\"的过渡态，也就是本文批评的产能驱动模式。",{"type":186,"tag":244,"props":653,"children":655},{"id":654},"向流导向模式的演进重点",[656],{"type":192,"value":654},{"type":186,"tag":195,"props":658,"children":659},{},[660],{"type":192,"value":661},"要真正从\"多项目团队\"演进为\"stream-aligned 团队\"，需要在实践上做到：",{"type":186,"tag":211,"props":663,"children":664},{},[665,683,701],{"type":186,"tag":215,"props":666,"children":667},{},[668,670],{"type":192,"value":669},"唯一主责流：\n",{"type":186,"tag":211,"props":671,"children":672},{},[673,678],{"type":186,"tag":215,"props":674,"children":675},{},[676],{"type":192,"value":677},"每个团队只拥有一个一等公民级别的价值流；",{"type":186,"tag":215,"props":679,"children":680},{},[681],{"type":192,"value":682},"其他工作的参与被定义为\"例外支援\"，而不是默认期望。",{"type":186,"tag":215,"props":684,"children":685},{},[686,688],{"type":192,"value":687},"上下文数量有上限：\n",{"type":186,"tag":211,"props":689,"children":690},{},[691,696],{"type":186,"tag":215,"props":692,"children":693},{},[694],{"type":192,"value":695},"有意识地限制团队同时参与的产品/流数量；",{"type":186,"tag":215,"props":697,"children":698},{},[699],{"type":192,"value":700},"对跨域工作尽量通过接口协作、平台能力、组织重构来吸收，而不是压到现有团队上。",{"type":186,"tag":215,"props":702,"children":703},{},[704,706],{"type":192,"value":705},"明确\"系统健康工作\"的合法性：\n",{"type":186,"tag":211,"props":707,"children":708},{},[709,714],{"type":186,"tag":215,"props":710,"children":711},{},[712],{"type":192,"value":713},"在组织层面默认：在主责流相对平稳时，把空档用来改善系统，而不是自动帮其他流清 backlog；",{"type":186,"tag":215,"props":715,"children":716},{},[717],{"type":192,"value":718},"让架构演进、技术债治理、DevEx 优化成为 backlog 的一等公民。",{"type":186,"tag":237,"props":720,"children":722},{"id":721},"系统影响对架构工程效率与组织协作的牵引",[723],{"type":192,"value":724},"系统影响：对架构、工程效率与组织协作的牵引",{"type":186,"tag":244,"props":726,"children":728},{"id":727},"对架构与技术栈治理的一致性影响",[729],{"type":192,"value":727},{"type":186,"tag":195,"props":731,"children":732},{},[733],{"type":192,"value":734},"当团队经常在多个价值流之间来回：",{"type":186,"tag":211,"props":736,"children":737},{},[738,756],{"type":186,"tag":215,"props":739,"children":740},{},[741,743],{"type":192,"value":742},"容易在不同业务中种下风格各异的实现方式：\n",{"type":186,"tag":211,"props":744,"children":745},{},[746,751],{"type":186,"tag":215,"props":747,"children":748},{},[749],{"type":192,"value":750},"技术选型和编码风格漂移，难以形成清晰的架构\"主干\"；",{"type":186,"tag":215,"props":752,"children":753},{},[754],{"type":192,"value":755},"局部为了短期交付做出的折衷，很难在后续获得时间系统清理。",{"type":186,"tag":215,"props":757,"children":758},{},[759,761],{"type":192,"value":760},"领域边界容易变模糊：\n",{"type":186,"tag":211,"props":762,"children":763},{},[764,769],{"type":186,"tag":215,"props":765,"children":766},{},[767],{"type":192,"value":768},"谁对哪个域的长期演进负责不清晰；",{"type":186,"tag":215,"props":770,"children":771},{},[772],{"type":192,"value":773},"通用能力和业务特定实现混杂在一起。",{"type":186,"tag":195,"props":775,"children":776},{},[777],{"type":192,"value":778},"反之，如果坚持流导向原则、避免常态化跨流开发：",{"type":186,"tag":211,"props":780,"children":781},{},[782,787],{"type":186,"tag":215,"props":783,"children":784},{},[785],{"type":192,"value":786},"领域边界和所有权更清晰，有利于中长期的架构演进；",{"type":186,"tag":215,"props":788,"children":789},{},[790],{"type":192,"value":791},"可以更从容地在每条流内打磨稳定的技术栈与平台能力。",{"type":186,"tag":244,"props":793,"children":795},{"id":794},"对工程效率与质量文化的影响",[796],{"type":192,"value":794},{"type":186,"tag":195,"props":798,"children":799},{},[800],{"type":192,"value":801},"在产能驱动模式下：",{"type":186,"tag":211,"props":803,"children":804},{},[805,823],{"type":186,"tag":215,"props":806,"children":807},{},[808,810],{"type":192,"value":809},"指标和文化可能偏向：\n",{"type":186,"tag":211,"props":811,"children":812},{},[813,818],{"type":186,"tag":215,"props":814,"children":815},{},[816],{"type":192,"value":817},"以任务数量、支援次数、工时填满度作为成功衡量；",{"type":186,"tag":215,"props":819,"children":820},{},[821],{"type":192,"value":822},"没有显性空间讨论系统健康、架构演进、工程基础设施。",{"type":186,"tag":215,"props":824,"children":825},{},[826,828],{"type":192,"value":827},"对质量与可维护性的长期关注被弱化：\n",{"type":186,"tag":211,"props":829,"children":830},{},[831,836],{"type":186,"tag":215,"props":832,"children":833},{},[834],{"type":192,"value":835},"团队处在持续多线程状态，很难在某个流/系统上形成深度掌控；",{"type":186,"tag":215,"props":837,"children":838},{},[839],{"type":192,"value":840},"缺陷与技术债在多个产品间分散，使得治理难度和成本都上升。",{"type":186,"tag":195,"props":842,"children":843},{},[844],{"type":192,"value":845},"而按照原文建议将空闲产能投入系统健康：",{"type":186,"tag":211,"props":847,"children":848},{},[849,854],{"type":186,"tag":215,"props":850,"children":851},{},[852],{"type":192,"value":853},"有助于形成\"质量、可靠性、工程基础设施是团队职责一部分\"的共识；",{"type":186,"tag":215,"props":855,"children":856},{},[857],{"type":192,"value":858},"从长期来看，提高处理高峰期的抗压能力，降低事故率。",{"type":186,"tag":237,"props":860,"children":862},{"id":861},"落地建议如何在实际团队中避免产能驱动陷阱",[863],{"type":192,"value":864},"落地建议：如何在实际团队中避免「产能驱动陷阱」",{"type":186,"tag":244,"props":866,"children":868},{"id":867},"_1-明确跨流支援是短期应急而非常态机制",[869],{"type":192,"value":870},"1. 明确：跨流支援是短期应急，而非常态机制",{"type":186,"tag":195,"props":872,"children":873},{},[874],{"type":192,"value":875},"可以在团队与管理层达成几个基础原则：",{"type":186,"tag":211,"props":877,"children":878},{},[879,904],{"type":186,"tag":215,"props":880,"children":881},{},[882,884,889,891],{"type":192,"value":883},"Stream-aligned 团队的",{"type":186,"tag":541,"props":885,"children":886},{},[887],{"type":192,"value":888},"默认状态",{"type":192,"value":890},"：\n",{"type":186,"tag":211,"props":892,"children":893},{},[894,899],{"type":186,"tag":215,"props":895,"children":896},{},[897],{"type":192,"value":898},"专注于单一主责价值流；",{"type":186,"tag":215,"props":900,"children":901},{},[902],{"type":192,"value":903},"富余产能用于该流相关的系统健康与工程提升。",{"type":186,"tag":215,"props":905,"children":906},{},[907,909,914,916],{"type":192,"value":908},"跨流支援的",{"type":186,"tag":541,"props":910,"children":911},{},[912],{"type":192,"value":913},"触发条件",{"type":192,"value":915},"应当明确且有限：\n",{"type":186,"tag":211,"props":917,"children":918},{},[919,924],{"type":186,"tag":215,"props":920,"children":921},{},[922],{"type":192,"value":923},"例如：重大业务活动、突发流量高峰、严重生产事故等；",{"type":186,"tag":215,"props":925,"children":926},{},[927],{"type":192,"value":928},"支援时间范围和职责范围事先约定清楚，不演化为长期分身。",{"type":186,"tag":195,"props":930,"children":931},{},[932],{"type":192,"value":933},"这有助于把\"不断接其他流需求\"的惯性约束在例外范围之内。",{"type":186,"tag":244,"props":935,"children":937},{"id":936},"_2-使用-wip-limits-控制跨流在制品",[938],{"type":192,"value":939},"2. 使用 WIP limits 控制跨流在制品",{"type":186,"tag":195,"props":941,"children":942},{},[943],{"type":192,"value":944},"针对\"多流并行导致拥塞\"的核心问题，可以：",{"type":186,"tag":211,"props":946,"children":947},{},[948,966],{"type":186,"tag":215,"props":949,"children":950},{},[951,953],{"type":192,"value":952},"在团队内部：\n",{"type":186,"tag":211,"props":954,"children":955},{},[956,961],{"type":186,"tag":215,"props":957,"children":958},{},[959],{"type":192,"value":960},"定义团队整体的在制品上限；",{"type":186,"tag":215,"props":962,"children":963},{},[964],{"type":192,"value":965},"为跨产品/跨流的工作单独设置更严格的 WIP 配额（比如最多 1 个）。",{"type":186,"tag":215,"props":967,"children":968},{},[969,971],{"type":192,"value":970},"在相邻流层面：\n",{"type":186,"tag":211,"props":972,"children":973},{},[974,979],{"type":186,"tag":215,"props":975,"children":976},{},[977],{"type":192,"value":978},"对同一组团队能够同时承载的邻接流工作量设置总 WIP；",{"type":186,"tag":215,"props":980,"children":981},{},[982],{"type":192,"value":983},"严格采用\"拉动式\"机制：团队依据 WIP 余量拉取，而不是由上游不断推任务。",{"type":186,"tag":195,"props":985,"children":986},{},[987],{"type":192,"value":988},"这样可以把\"多塞需求\"的冲动转化为对现有工作流动性的显性权衡。",{"type":186,"tag":244,"props":990,"children":992},{"id":991},"_3-通过-cross-training-与-dynamic-reteaming-做结构性平衡",[993],{"type":192,"value":994},"3. 通过 Cross-training 与 Dynamic reteaming 做结构性平衡",{"type":186,"tag":195,"props":996,"children":997},{},[998],{"type":192,"value":999},"原文建议的 cross-training 和 dynamic reteaming，可以理解为：",{"type":186,"tag":211,"props":1001,"children":1002},{},[1003,1028],{"type":186,"tag":215,"props":1004,"children":1005},{},[1006,1008],{"type":192,"value":1007},"Cross-training：\n",{"type":186,"tag":211,"props":1009,"children":1010},{},[1011,1016],{"type":186,"tag":215,"props":1012,"children":1013},{},[1014],{"type":192,"value":1015},"在同一条流或强相关流内部，提升团队成员的技能冗余；",{"type":186,"tag":215,"props":1017,"children":1018},{},[1019,1021,1026],{"type":192,"value":1020},"使团队在需求侧波动时可以在",{"type":186,"tag":541,"props":1022,"children":1023},{},[1024],{"type":192,"value":1025},"同一上下文内",{"type":192,"value":1027},"灵活调度人，而非强迫个人去适配完全不同的产品/技术栈。",{"type":186,"tag":215,"props":1029,"children":1030},{},[1031,1033],{"type":192,"value":1032},"Dynamic reteaming：\n",{"type":186,"tag":211,"props":1034,"children":1035},{},[1036,1041],{"type":186,"tag":215,"props":1037,"children":1038},{},[1039],{"type":192,"value":1040},"当某些流长期高压而另一些长期低压时，考虑调整团队边界；",{"type":186,"tag":215,"props":1042,"children":1043},{},[1044],{"type":192,"value":1045},"通过拆分、合并或重划 stream 来对齐长期负载，而不是用临时借人解决结构性矛盾。",{"type":186,"tag":195,"props":1047,"children":1048},{},[1049],{"type":192,"value":1050},"这两种手段的共同点是：用组织结构和技能结构调整匹配长期 demand pattern，而不是简单做短期工时调度。",{"type":186,"tag":244,"props":1052,"children":1054},{"id":1053},"_4-让系统健康成为-backlog-中的显式选项",[1055],{"type":192,"value":1056},"4. 让\"系统健康\"成为 backlog 中的显式选项",{"type":186,"tag":195,"props":1058,"children":1059},{},[1060],{"type":192,"value":1061},"要避免\"有空就去帮其他流做 feature\"的惯性，需要在实践层面：",{"type":186,"tag":211,"props":1063,"children":1064},{},[1065,1093],{"type":186,"tag":215,"props":1066,"children":1067},{},[1068,1070],{"type":192,"value":1069},"把系统健康相关事项加入 backlog，并定期 review：\n",{"type":186,"tag":211,"props":1071,"children":1072},{},[1073,1078,1083,1088],{"type":186,"tag":215,"props":1074,"children":1075},{},[1076],{"type":192,"value":1077},"技术债偿还项；",{"type":186,"tag":215,"props":1079,"children":1080},{},[1081],{"type":192,"value":1082},"架构演进与平台能力增强；",{"type":186,"tag":215,"props":1084,"children":1085},{},[1086],{"type":192,"value":1087},"可观测性、SLO 实现与运维自动化改进；",{"type":186,"tag":215,"props":1089,"children":1090},{},[1091],{"type":192,"value":1092},"开发效率工具和实践优化。",{"type":186,"tag":215,"props":1094,"children":1095},{},[1096,1098],{"type":192,"value":1097},"对这类工作给出明确的业务/工程价值叙事：\n",{"type":186,"tag":211,"props":1099,"children":1100},{},[1101,1106],{"type":186,"tag":215,"props":1102,"children":1103},{},[1104],{"type":192,"value":1105},"例如减少事故恢复时间、缩短 lead time、降低新功能引入边际成本等；",{"type":186,"tag":215,"props":1107,"children":1108},{},[1109],{"type":192,"value":1110},"让管理层看到\"空档做系统健康\"并不是\"没有产出\"。",{"type":186,"tag":195,"props":1112,"children":1113},{},[1114],{"type":192,"value":1115},"这样，当团队出现富余产能时，有一个\"默认优先队列\"，而不是只能通过接额外需求来证明存在价值。",{"type":186,"tag":195,"props":1117,"children":1118},{},[1119],{"type":192,"value":1120},"整体来看，这条雷达的核心提醒是：**不要用看似合理的\"产能利用率最大化\"破坏流导向团队的设计初衷。**在 stream-aligned 的世界里，真正值得优化的是价值流的稳定性与系统健康，而不是把每一点空闲时间都填满跨流需求。用 WIP 限制、跨技能训练与动态重组这类系统性手段管理波动，才更符合长期的架构与工程效率目标。",{"title":178,"searchDepth":1122,"depth":1122,"links":1123},2,[1124,1125],{"id":189,"depth":1122,"text":193},{"id":232,"depth":1122,"text":235,"children":1126},[1127,1129,1130,1131,1132,1133],{"id":239,"depth":1128,"text":242},3,{"id":293,"depth":1128,"text":296},{"id":476,"depth":1128,"text":479},{"id":615,"depth":1128,"text":618},{"id":721,"depth":1128,"text":724},{"id":861,"depth":1128,"text":864},"markdown","content:6.maps:_management:capacity-driven-development:capacity-driven-development.md","content","6.maps/_management/capacity-driven-development/capacity-driven-development.md","6.maps/_management/capacity-driven-development/capacity-driven-development","md",[1141,1145],{"_path":1142,"title":1143,"description":1144},"/maps/_manage/manage/project-management","项目管理","项目管理实践指南，涵盖项目类型、目标设定、里程碑规划、风险管理等核心环节的系统性介绍。",{"_path":1146,"title":1147,"description":1148},"/maps/_management/leadership","领导力","领导力原则与团队管理智慧",1772504938952]