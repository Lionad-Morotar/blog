[{"data":1,"prerenderedAt":1145},["ShallowReactive",2],{"navigation":3,"/maps/_management/capacity-driven-development":170,"/maps/_management/capacity-driven-development-surround":1136},[4,35,92,98,125,131,155,161],{"title":5,"_path":6,"children":7},"心流思绪 / Heart Flows","/flows",[8,11,14,17,20,23,26,29,32],{"title":9,"_path":10},"📕 狮子的书单推荐","/flows/books",{"title":12,"_path":13},"🚝 四十二篇系列","/flows/forty-two",{"title":15,"_path":16},"🌃 长夜梦","/flows/long-night-dream",{"title":18,"_path":19},"🌌 万物联结与幸福感","/flows/everything",{"title":21,"_path":22},"⌛ 偷取时间","/flows/stealing-time-from-god",{"title":24,"_path":25},"🌆 表达和孤独","/flows/expression-and-loneliness",{"title":27,"_path":28},"🌧️ 我的腼腆","/flows/shy",{"title":30,"_path":31},"🥛 新工作，喝新饮料","/flows/drinking-while-thinking",{"title":33,"_path":34},"📝 心流归档","/flows/archive",{"title":36,"_path":37,"children":38},"技术博客 / Coder","/articles",[39,41,44,47,50,53,56,59,62,65,68,71,74,77,80,83,86,89],{"title":40,"_path":37},"🦁 欢迎",{"title":42,"_path":43},"📦 一个简单有效的端口命名策略：","/articles/simple-naming-method",{"title":45,"_path":46},"🌪️ Tailwind v4 如何兼容预处理器","/articles/tailwind4-with-sass",{"title":48,"_path":49},"🥞 在 tailwind 中使用现代化 CSS Layers","/articles/tailwind-sass-and-css-layer",{"title":51,"_path":52},"💻 本地部署 Qwen 翻译网页","/articles/local-translator",{"title":54,"_path":55},"🧊 模板解析器轻考古","/articles/micro-templating",{"title":57,"_path":58},"Ⓜ️ Mini CSS Parser","/articles/mini-css-parser",{"title":60,"_path":61},"🚩 向AI咨询前端问题","/articles/use-gpt-learn-complex-frontend",{"title":63,"_path":64},"⛸️ 怎样定制复杂组件的自定义滚动条？","/articles/use-scrollbars",{"title":66,"_path":67},"⚖️ 统一多组件库的层叠顺序","/articles/zindex-manager",{"title":69,"_path":70},"🕷️ 滑动验证码破解思路","/articles/crack-the-slider",{"title":72,"_path":73},"🌟 探秘 CSS 光影效果","/articles/css-light-travel",{"title":75,"_path":76},"🍲 设计模式与 JS 魔法锅","/articles/design-patterns-and-js-magic-pot",{"title":78,"_path":79},"🌐 Anysort：灵活、优雅的多属性排序","/articles/anysort-2th",{"title":81,"_path":82},"💫 CSS 幻术 | 抗锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133,"children":134},"造物 / Make","/tools",[135,137,140,143,146,149,152],{"title":136,"_path":133},"🧰 工具收集",{"title":138,"_path":139},"📕 博客","/tools/blog",{"title":141,"_path":142},"🥥 Coconut","/tools/coconut",{"title":144,"_path":145},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":147,"_path":148},"🌐 AnySort","/tools/anysort",{"title":150,"_path":151},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":153,"_path":154},"👓 Crapto","/tools/crypto-inline",{"title":156,"_path":157,"children":158},"我 / About","/hire",[159],{"title":160,"_path":157},"📬 技术简历",{"title":162,"_path":163,"children":164},"En","/en",[165],{"title":166,"_path":167,"children":168},"🦁 Welcome","/en/articles",[169],{"title":166,"_path":167},{"_path":171,"_dir":172,"_draft":173,"_partial":174,"_locale":175,"title":176,"description":177,"body":178,"_type":1130,"_id":1131,"_source":1132,"_file":1133,"_stem":1134,"_extension":1135},"/maps/_management/capacity-driven-development","_management",false,true,"","Capacity-driven development（产能驱动开发）","警惕用「填满人」替代「保障价值流」的局部最优，建议用系统健康与组织调度来管理空闲产能。",{"type":179,"children":180,"toc":1117},"root",[181,190,196,201,206,226,232,239,246,251,264,269,282,287,293,299,304,317,322,335,340,345,384,389,402,408,413,452,457,470,476,482,487,531,544,550,555,586,591,609,615,620,625,643,648,653,658,715,721,726,731,770,775,788,793,798,837,842,855,861,867,872,925,930,936,941,980,985,991,996,1042,1047,1053,1058,1107,1112],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"brief",[187],{"type":188,"value":189},"text","Brief",{"type":182,"tag":191,"props":192,"children":193},"p",{},[194],{"type":188,"value":195},"在现代软件开发实践中，成功的关键是聚焦工作流本身，而不是单纯追求资源利用率最大化。Stream-aligned 团队本应围绕单一且有价值的流（例如一条用户旅程或一个产品）工作，从而高效地交付端到端价值。",{"type":182,"tag":191,"props":197,"children":198},{},[199],{"type":188,"value":200},"目前出现了一个令人担忧的趋势：所谓“产能驱动开发”。当这些团队出现空闲产能时，会去承接来自其他产品或其他价值流的功能。这在短期内似乎提高了效率，但本质上只是适合应对突发需求高峰的局部优化。一旦被常态化，会显著增加团队认知负荷和技术债；在最坏情况下，由于跨产品频繁上下文切换的成本不断叠加，可能导致类似“拥塞崩溃”的现象，整体交付能力反而下降。",{"type":182,"tag":191,"props":202,"children":203},{},[204],{"type":188,"value":205},"当团队出现富余产能时，更好的选择是优先投入到系统健康的改进上。为了更有效地管理产能，可以：",{"type":182,"tag":207,"props":208,"children":209},"ul",{},[210,216,221],{"type":182,"tag":211,"props":212,"children":213},"li",{},[214],{"type":188,"value":215},"使用 WIP 限制（Work-in-Progress limits）来控制相邻价值流上的并行工作；",{"type":182,"tag":211,"props":217,"children":218},{},[219],{"type":188,"value":220},"通过跨技能训练（cross-training）来平衡不同时间段的需求高峰；",{"type":182,"tag":211,"props":222,"children":223},{},[224],{"type":188,"value":225},"在需要时采用动态重组团队（dynamic reteaming），而不是简单通过“多接单”填满人力。",{"type":182,"tag":183,"props":227,"children":229},{"id":228},"details",[230],{"type":188,"value":231},"Details",{"type":182,"tag":233,"props":234,"children":236},"h3",{"id":235},"背景与现状从人不能闲着到流不能乱",[237],{"type":188,"value":238},"背景与现状：从「人不能闲着」到「流不能乱」",{"type":182,"tag":240,"props":241,"children":243},"h4",{"id":242},"为什么现在要讨论-capacity-driven-development",[244],{"type":188,"value":245},"为什么现在要讨论 Capacity-driven development",{"type":182,"tag":191,"props":247,"children":248},{},[249],{"type":188,"value":250},"在很多正在向现代工程体系演进的组织里，大家已经接受：",{"type":182,"tag":207,"props":252,"children":253},{},[254,259],{"type":182,"tag":211,"props":255,"children":256},{},[257],{"type":188,"value":258},"用 stream-aligned 团队围绕某条价值流或产品组织；",{"type":182,"tag":211,"props":260,"children":261},{},[262],{"type":188,"value":263},"通过端到端 ownership 保证交付速度和反馈闭环。",{"type":182,"tag":191,"props":265,"children":266},{},[267],{"type":188,"value":268},"但是在落地过程中，传统的「人力利用率」心智往往没有一起升级：",{"type":182,"tag":207,"props":270,"children":271},{},[272,277],{"type":182,"tag":211,"props":273,"children":274},{},[275],{"type":188,"value":276},"当发现某个团队近期需求较少，就自然地把其他产品/流的 backlog 塞过去；",{"type":182,"tag":211,"props":278,"children":279},{},[280],{"type":188,"value":281},"产能调度的基本目标仍然是“不要有闲人”，而不是“保障关键流的稳态和系统健康”。",{"type":182,"tag":191,"props":283,"children":284},{},[285],{"type":188,"value":286},"在这种语境下，“产能驱动开发”很容易变成一种不被察觉、但对系统长期健康影响巨大的反模式。",{"type":182,"tag":233,"props":288,"children":290},{"id":289},"问题与风险局部最优带来的系统性退化",[291],{"type":188,"value":292},"问题与风险：局部最优带来的系统性退化",{"type":182,"tag":240,"props":294,"children":296},{"id":295},"核心矛盾填满人-vs-保持单一价值流专注",[297],{"type":188,"value":298},"核心矛盾：填满人 vs 保持单一价值流专注",{"type":182,"tag":191,"props":300,"children":301},{},[302],{"type":188,"value":303},"原文指出的本质冲突是：",{"type":182,"tag":207,"props":305,"children":306},{},[307,312],{"type":182,"tag":211,"props":308,"children":309},{},[310],{"type":188,"value":311},"设计初衷：stream-aligned 团队只专注于一个单一、清晰的价值流；",{"type":182,"tag":211,"props":313,"children":314},{},[315],{"type":188,"value":316},"实际操作：当有空档，就去做其他产品或 value stream 的功能。",{"type":182,"tag":191,"props":318,"children":319},{},[320],{"type":188,"value":321},"这种偏差带来的典型风险包括：",{"type":182,"tag":207,"props":323,"children":324},{},[325,330],{"type":182,"tag":211,"props":326,"children":327},{},[328],{"type":188,"value":329},"价值流聚焦被打散，团队从“深耕一个流”变成“多线拉扯”；",{"type":182,"tag":211,"props":331,"children":332},{},[333],{"type":188,"value":334},"注意力被短期需求填满，长期的系统性改进持续被挤出优先级。",{"type":182,"tag":240,"props":336,"children":338},{"id":337},"认知负荷与上下文切换成本",[339],{"type":188,"value":337},{"type":182,"tag":191,"props":341,"children":342},{},[343],{"type":188,"value":344},"当团队开始常态化接多个流的工作时：",{"type":182,"tag":207,"props":346,"children":347},{},[348,366],{"type":182,"tag":211,"props":349,"children":350},{},[351,353],{"type":188,"value":352},"业务维度：\n",{"type":182,"tag":207,"props":354,"children":355},{},[356,361],{"type":182,"tag":211,"props":357,"children":358},{},[359],{"type":188,"value":360},"团队被迫理解多个产品/旅程的规则和边界；",{"type":182,"tag":211,"props":362,"children":363},{},[364],{"type":188,"value":365},"心智模型从“一条清晰主线”变成若干不完整的碎片。",{"type":182,"tag":211,"props":367,"children":368},{},[369,371],{"type":188,"value":370},"技术维度：\n",{"type":182,"tag":207,"props":372,"children":373},{},[374,379],{"type":182,"tag":211,"props":375,"children":376},{},[377],{"type":188,"value":378},"可能涉及不同代码库、部署 pipeline、监控体系、合规约束；",{"type":182,"tag":211,"props":380,"children":381},{},[382],{"type":188,"value":383},"每一次任务切换，都是一次完整的上下文加载与卸载。",{"type":182,"tag":191,"props":385,"children":386},{},[387],{"type":188,"value":388},"这些成本短期内很隐性，但累积效果往往是：",{"type":182,"tag":207,"props":390,"children":391},{},[392,397],{"type":182,"tag":211,"props":393,"children":394},{},[395],{"type":188,"value":396},"Throughput 下降：表面上故事点完成不少，实际交付节奏变慢；",{"type":182,"tag":211,"props":398,"children":399},{},[400],{"type":188,"value":401},"质量波动：在不熟悉的上下文里更容易引入缺陷，也更难做好非功能性要求。",{"type":182,"tag":240,"props":403,"children":405},{"id":404},"技术债与拥塞崩溃",[406],{"type":188,"value":407},"技术债与“拥塞崩溃”",{"type":182,"tag":191,"props":409,"children":410},{},[411],{"type":188,"value":412},"原文特别强调的“congestion collapse”值得重视：",{"type":182,"tag":207,"props":414,"children":415},{},[416,434],{"type":182,"tag":211,"props":417,"children":418},{},[419,421],{"type":188,"value":420},"当多个产品/流都把团队视作“可借用的通用产能池”时：\n",{"type":182,"tag":207,"props":422,"children":423},{},[424,429],{"type":182,"tag":211,"props":425,"children":426},{},[427],{"type":188,"value":428},"任何流的需求高峰都会叠加到这个团队上；",{"type":182,"tag":211,"props":430,"children":431},{},[432],{"type":188,"value":433},"优先级频繁重排，上下文不断来回切换。",{"type":182,"tag":211,"props":435,"children":436},{},[437,439],{"type":188,"value":438},"结果是：\n",{"type":182,"tag":207,"props":440,"children":441},{},[442,447],{"type":182,"tag":211,"props":443,"children":444},{},[445],{"type":188,"value":446},"看起来事情全都在推进，实际上没有一个流推进得好；",{"type":182,"tag":211,"props":448,"children":449},{},[450],{"type":188,"value":451},"新需求和缺陷互相挤压，技术债只增不减。",{"type":182,"tag":191,"props":453,"children":454},{},[455],{"type":188,"value":456},"同时，当团队只作为“支援劳动力”参与其他流时：",{"type":182,"tag":207,"props":458,"children":459},{},[460,465],{"type":182,"tag":211,"props":461,"children":462},{},[463],{"type":188,"value":464},"对于那些流的技术决策和演进路径缺乏长期 ownership；",{"type":182,"tag":211,"props":466,"children":467},{},[468],{"type":188,"value":469},"为赶进度容易落入局部 hack，长远看拖累系统整体演进。",{"type":182,"tag":233,"props":471,"children":473},{"id":472},"模式与原理从产能导向回到价值流导向",[474],{"type":188,"value":475},"模式与原理：从「产能导向」回到「价值流导向」",{"type":182,"tag":240,"props":477,"children":479},{"id":478},"capacity-driven-development-的模式特征",[480],{"type":188,"value":481},"Capacity-driven development 的模式特征",{"type":182,"tag":191,"props":483,"children":484},{},[485],{"type":188,"value":486},"从模式角度看，capacity-driven development 具有几个典型特征：",{"type":182,"tag":207,"props":488,"children":489},{},[490,513],{"type":182,"tag":211,"props":491,"children":492},{},[493,495],{"type":188,"value":494},"优化目标被设在“让每个团队都满负荷工作”，而不是：\n",{"type":182,"tag":207,"props":496,"children":497},{},[498,503,508],{"type":182,"tag":211,"props":499,"children":500},{},[501],{"type":188,"value":502},"缩短端到端 lead time；",{"type":182,"tag":211,"props":504,"children":505},{},[506],{"type":188,"value":507},"提升关键流的可靠性和可预期性；",{"type":182,"tag":211,"props":509,"children":510},{},[511],{"type":188,"value":512},"改善架构和工程基础设施。",{"type":182,"tag":211,"props":514,"children":515},{},[516,518],{"type":188,"value":517},"组织层面缺乏系统性调度手段，于是：\n",{"type":182,"tag":207,"props":519,"children":520},{},[521,526],{"type":182,"tag":211,"props":522,"children":523},{},[524],{"type":188,"value":525},"用“多接项目/多接 feature”来填平不均匀负载；",{"type":182,"tag":211,"props":527,"children":528},{},[529],{"type":188,"value":530},"把结构性问题（流划分、组织边界、平台能力不足）压在一线团队的 task 分配上。",{"type":182,"tag":191,"props":532,"children":533},{},[534,536,542],{"type":188,"value":535},"原文的态度非常明确：这种做法仅在",{"type":182,"tag":537,"props":538,"children":539},"strong",{},[540],{"type":188,"value":541},"应对突发需求高峰",{"type":188,"value":543},"时是合理的局部优化，一旦常态化，就是系统性的反模式。",{"type":182,"tag":240,"props":545,"children":547},{"id":546},"推荐的原则空闲产能优先投向系统健康",[548],{"type":188,"value":549},"推荐的原则：空闲产能优先投向系统健康",{"type":182,"tag":191,"props":551,"children":552},{},[553],{"type":188,"value":554},"原文给出的对策是把“多余产能”视为改善系统健康的机会，而不是自由市场里的“可出售工时”：",{"type":182,"tag":207,"props":556,"children":557},{},[558],{"type":182,"tag":211,"props":559,"children":560},{},[561,563],{"type":188,"value":562},"当一个 stream-aligned 团队出现富余产能时，更优先的方向包括：\n",{"type":182,"tag":207,"props":564,"children":565},{},[566,571,576,581],{"type":182,"tag":211,"props":567,"children":568},{},[569],{"type":188,"value":570},"偿还技术债；",{"type":182,"tag":211,"props":572,"children":573},{},[574],{"type":188,"value":575},"提升平台与工程效率；",{"type":182,"tag":211,"props":577,"children":578},{},[579],{"type":188,"value":580},"强化可观测性与稳定性；",{"type":182,"tag":211,"props":582,"children":583},{},[584],{"type":188,"value":585},"改善开发者体验（DevEx）等。",{"type":182,"tag":191,"props":587,"children":588},{},[589],{"type":188,"value":590},"这背后的逻辑是：",{"type":182,"tag":207,"props":592,"children":593},{},[594,599,604],{"type":182,"tag":211,"props":595,"children":596},{},[597],{"type":188,"value":598},"系统健康的改进往往难以在高需求期挤进 backlog；",{"type":182,"tag":211,"props":600,"children":601},{},[602],{"type":188,"value":603},"利用低需求期系统性加强“基础设施”，能提升未来处理高负载的能力；",{"type":182,"tag":211,"props":605,"children":606},{},[607],{"type":188,"value":608},"与“多接其他流需求”相比，这种投资对长期吞吐量和质量更有保障。",{"type":182,"tag":233,"props":610,"children":612},{"id":611},"对比与演进旧的多项目团队思路-vs-新的-stream-aligned-实践",[613],{"type":188,"value":614},"对比与演进：旧的「多项目团队」思路 vs 新的 Stream-aligned 实践",{"type":182,"tag":240,"props":616,"children":618},{"id":617},"传统多项目模式的惯性",[619],{"type":188,"value":617},{"type":182,"tag":191,"props":621,"children":622},{},[623],{"type":188,"value":624},"很多团队的历史状态是“多项目执行单元”：",{"type":182,"tag":207,"props":626,"children":627},{},[628,633,638],{"type":182,"tag":211,"props":629,"children":630},{},[631],{"type":188,"value":632},"同一团队同时为多个产品、多个项目服务；",{"type":182,"tag":211,"props":634,"children":635},{},[636],{"type":188,"value":637},"通过工时分配和项目数量来衡量价值；",{"type":182,"tag":211,"props":639,"children":640},{},[641],{"type":188,"value":642},"“谁有空就去哪儿支援”是默认调度策略。",{"type":182,"tag":191,"props":644,"children":645},{},[646],{"type":188,"value":647},"在这种文化下，当组织开始谈 stream-aligned 时，容易出现“名义上围绕流组织，实际上仍然是通用产能池”的过渡态，也就是本文批评的产能驱动模式。",{"type":182,"tag":240,"props":649,"children":651},{"id":650},"向流导向模式的演进重点",[652],{"type":188,"value":650},{"type":182,"tag":191,"props":654,"children":655},{},[656],{"type":188,"value":657},"要真正从“多项目团队”演进为“stream-aligned 团队”，需要在实践上做到：",{"type":182,"tag":207,"props":659,"children":660},{},[661,679,697],{"type":182,"tag":211,"props":662,"children":663},{},[664,666],{"type":188,"value":665},"唯一主责流：\n",{"type":182,"tag":207,"props":667,"children":668},{},[669,674],{"type":182,"tag":211,"props":670,"children":671},{},[672],{"type":188,"value":673},"每个团队只拥有一个一等公民级别的价值流；",{"type":182,"tag":211,"props":675,"children":676},{},[677],{"type":188,"value":678},"其他工作的参与被定义为“例外支援”，而不是默认期望。",{"type":182,"tag":211,"props":680,"children":681},{},[682,684],{"type":188,"value":683},"上下文数量有上限：\n",{"type":182,"tag":207,"props":685,"children":686},{},[687,692],{"type":182,"tag":211,"props":688,"children":689},{},[690],{"type":188,"value":691},"有意识地限制团队同时参与的产品/流数量；",{"type":182,"tag":211,"props":693,"children":694},{},[695],{"type":188,"value":696},"对跨域工作尽量通过接口协作、平台能力、组织重构来吸收，而不是压到现有团队上。",{"type":182,"tag":211,"props":698,"children":699},{},[700,702],{"type":188,"value":701},"明确“系统健康工作”的合法性：\n",{"type":182,"tag":207,"props":703,"children":704},{},[705,710],{"type":182,"tag":211,"props":706,"children":707},{},[708],{"type":188,"value":709},"在组织层面默认：在主责流相对平稳时，把空档用来改善系统，而不是自动帮其他流清 backlog；",{"type":182,"tag":211,"props":711,"children":712},{},[713],{"type":188,"value":714},"让架构演进、技术债治理、DevEx 优化成为 backlog 的一等公民。",{"type":182,"tag":233,"props":716,"children":718},{"id":717},"系统影响对架构工程效率与组织协作的牵引",[719],{"type":188,"value":720},"系统影响：对架构、工程效率与组织协作的牵引",{"type":182,"tag":240,"props":722,"children":724},{"id":723},"对架构与技术栈治理的一致性影响",[725],{"type":188,"value":723},{"type":182,"tag":191,"props":727,"children":728},{},[729],{"type":188,"value":730},"当团队经常在多个价值流之间来回：",{"type":182,"tag":207,"props":732,"children":733},{},[734,752],{"type":182,"tag":211,"props":735,"children":736},{},[737,739],{"type":188,"value":738},"容易在不同业务中种下风格各异的实现方式：\n",{"type":182,"tag":207,"props":740,"children":741},{},[742,747],{"type":182,"tag":211,"props":743,"children":744},{},[745],{"type":188,"value":746},"技术选型和编码风格漂移，难以形成清晰的架构“主干”；",{"type":182,"tag":211,"props":748,"children":749},{},[750],{"type":188,"value":751},"局部为了短期交付做出的折衷，很难在后续获得时间系统清理。",{"type":182,"tag":211,"props":753,"children":754},{},[755,757],{"type":188,"value":756},"领域边界容易变模糊：\n",{"type":182,"tag":207,"props":758,"children":759},{},[760,765],{"type":182,"tag":211,"props":761,"children":762},{},[763],{"type":188,"value":764},"谁对哪个域的长期演进负责不清晰；",{"type":182,"tag":211,"props":766,"children":767},{},[768],{"type":188,"value":769},"通用能力和业务特定实现混杂在一起。",{"type":182,"tag":191,"props":771,"children":772},{},[773],{"type":188,"value":774},"反之，如果坚持流导向原则、避免常态化跨流开发：",{"type":182,"tag":207,"props":776,"children":777},{},[778,783],{"type":182,"tag":211,"props":779,"children":780},{},[781],{"type":188,"value":782},"领域边界和所有权更清晰，有利于中长期的架构演进；",{"type":182,"tag":211,"props":784,"children":785},{},[786],{"type":188,"value":787},"可以更从容地在每条流内打磨稳定的技术栈与平台能力。",{"type":182,"tag":240,"props":789,"children":791},{"id":790},"对工程效率与质量文化的影响",[792],{"type":188,"value":790},{"type":182,"tag":191,"props":794,"children":795},{},[796],{"type":188,"value":797},"在产能驱动模式下：",{"type":182,"tag":207,"props":799,"children":800},{},[801,819],{"type":182,"tag":211,"props":802,"children":803},{},[804,806],{"type":188,"value":805},"指标和文化可能偏向：\n",{"type":182,"tag":207,"props":807,"children":808},{},[809,814],{"type":182,"tag":211,"props":810,"children":811},{},[812],{"type":188,"value":813},"以任务数量、支援次数、工时填满度作为成功衡量；",{"type":182,"tag":211,"props":815,"children":816},{},[817],{"type":188,"value":818},"没有显性空间讨论系统健康、架构演进、工程基础设施。",{"type":182,"tag":211,"props":820,"children":821},{},[822,824],{"type":188,"value":823},"对质量与可维护性的长期关注被弱化：\n",{"type":182,"tag":207,"props":825,"children":826},{},[827,832],{"type":182,"tag":211,"props":828,"children":829},{},[830],{"type":188,"value":831},"团队处在持续多线程状态，很难在某个流/系统上形成深度掌控；",{"type":182,"tag":211,"props":833,"children":834},{},[835],{"type":188,"value":836},"缺陷与技术债在多个产品间分散，使得治理难度和成本都上升。",{"type":182,"tag":191,"props":838,"children":839},{},[840],{"type":188,"value":841},"而按照原文建议将空闲产能投入系统健康：",{"type":182,"tag":207,"props":843,"children":844},{},[845,850],{"type":182,"tag":211,"props":846,"children":847},{},[848],{"type":188,"value":849},"有助于形成“质量、可靠性、工程基础设施是团队职责一部分”的共识；",{"type":182,"tag":211,"props":851,"children":852},{},[853],{"type":188,"value":854},"从长期来看，提高处理高峰期的抗压能力，降低事故率。",{"type":182,"tag":233,"props":856,"children":858},{"id":857},"落地建议如何在实际团队中避免产能驱动陷阱",[859],{"type":188,"value":860},"落地建议：如何在实际团队中避免「产能驱动陷阱」",{"type":182,"tag":240,"props":862,"children":864},{"id":863},"_1-明确跨流支援是短期应急而非常态机制",[865],{"type":188,"value":866},"1. 明确：跨流支援是短期应急，而非常态机制",{"type":182,"tag":191,"props":868,"children":869},{},[870],{"type":188,"value":871},"可以在团队与管理层达成几个基础原则：",{"type":182,"tag":207,"props":873,"children":874},{},[875,900],{"type":182,"tag":211,"props":876,"children":877},{},[878,880,885,887],{"type":188,"value":879},"Stream-aligned 团队的",{"type":182,"tag":537,"props":881,"children":882},{},[883],{"type":188,"value":884},"默认状态",{"type":188,"value":886},"：\n",{"type":182,"tag":207,"props":888,"children":889},{},[890,895],{"type":182,"tag":211,"props":891,"children":892},{},[893],{"type":188,"value":894},"专注于单一主责价值流；",{"type":182,"tag":211,"props":896,"children":897},{},[898],{"type":188,"value":899},"富余产能用于该流相关的系统健康与工程提升。",{"type":182,"tag":211,"props":901,"children":902},{},[903,905,910,912],{"type":188,"value":904},"跨流支援的",{"type":182,"tag":537,"props":906,"children":907},{},[908],{"type":188,"value":909},"触发条件",{"type":188,"value":911},"应当明确且有限：\n",{"type":182,"tag":207,"props":913,"children":914},{},[915,920],{"type":182,"tag":211,"props":916,"children":917},{},[918],{"type":188,"value":919},"例如：重大业务活动、突发流量高峰、严重生产事故等；",{"type":182,"tag":211,"props":921,"children":922},{},[923],{"type":188,"value":924},"支援时间范围和职责范围事先约定清楚，不演化为长期分身。",{"type":182,"tag":191,"props":926,"children":927},{},[928],{"type":188,"value":929},"这有助于把“不断接其他流需求”的惯性约束在例外范围之内。",{"type":182,"tag":240,"props":931,"children":933},{"id":932},"_2-使用-wip-limits-控制跨流在制品",[934],{"type":188,"value":935},"2. 使用 WIP limits 控制跨流在制品",{"type":182,"tag":191,"props":937,"children":938},{},[939],{"type":188,"value":940},"针对“多流并行导致拥塞”的核心问题，可以：",{"type":182,"tag":207,"props":942,"children":943},{},[944,962],{"type":182,"tag":211,"props":945,"children":946},{},[947,949],{"type":188,"value":948},"在团队内部：\n",{"type":182,"tag":207,"props":950,"children":951},{},[952,957],{"type":182,"tag":211,"props":953,"children":954},{},[955],{"type":188,"value":956},"定义团队整体的在制品上限；",{"type":182,"tag":211,"props":958,"children":959},{},[960],{"type":188,"value":961},"为跨产品/跨流的工作单独设置更严格的 WIP 配额（比如最多 1 个）。",{"type":182,"tag":211,"props":963,"children":964},{},[965,967],{"type":188,"value":966},"在相邻流层面：\n",{"type":182,"tag":207,"props":968,"children":969},{},[970,975],{"type":182,"tag":211,"props":971,"children":972},{},[973],{"type":188,"value":974},"对同一组团队能够同时承载的邻接流工作量设置总 WIP；",{"type":182,"tag":211,"props":976,"children":977},{},[978],{"type":188,"value":979},"严格采用“拉动式”机制：团队依据 WIP 余量拉取，而不是由上游不断推任务。",{"type":182,"tag":191,"props":981,"children":982},{},[983],{"type":188,"value":984},"这样可以把“多塞需求”的冲动转化为对现有工作流动性的显性权衡。",{"type":182,"tag":240,"props":986,"children":988},{"id":987},"_3-通过-cross-training-与-dynamic-reteaming-做结构性平衡",[989],{"type":188,"value":990},"3. 通过 Cross-training 与 Dynamic reteaming 做结构性平衡",{"type":182,"tag":191,"props":992,"children":993},{},[994],{"type":188,"value":995},"原文建议的 cross-training 和 dynamic reteaming，可以理解为：",{"type":182,"tag":207,"props":997,"children":998},{},[999,1024],{"type":182,"tag":211,"props":1000,"children":1001},{},[1002,1004],{"type":188,"value":1003},"Cross-training：\n",{"type":182,"tag":207,"props":1005,"children":1006},{},[1007,1012],{"type":182,"tag":211,"props":1008,"children":1009},{},[1010],{"type":188,"value":1011},"在同一条流或强相关流内部，提升团队成员的技能冗余；",{"type":182,"tag":211,"props":1013,"children":1014},{},[1015,1017,1022],{"type":188,"value":1016},"使团队在需求侧波动时可以在",{"type":182,"tag":537,"props":1018,"children":1019},{},[1020],{"type":188,"value":1021},"同一上下文内",{"type":188,"value":1023},"灵活调度人，而非强迫个人去适配完全不同的产品/技术栈。",{"type":182,"tag":211,"props":1025,"children":1026},{},[1027,1029],{"type":188,"value":1028},"Dynamic reteaming：\n",{"type":182,"tag":207,"props":1030,"children":1031},{},[1032,1037],{"type":182,"tag":211,"props":1033,"children":1034},{},[1035],{"type":188,"value":1036},"当某些流长期高压而另一些长期低压时，考虑调整团队边界；",{"type":182,"tag":211,"props":1038,"children":1039},{},[1040],{"type":188,"value":1041},"通过拆分、合并或重划 stream 来对齐长期负载，而不是用临时借人解决结构性矛盾。",{"type":182,"tag":191,"props":1043,"children":1044},{},[1045],{"type":188,"value":1046},"这两种手段的共同点是：用组织结构和技能结构调整匹配长期 demand pattern，而不是简单做短期工时调度。",{"type":182,"tag":240,"props":1048,"children":1050},{"id":1049},"_4-让系统健康成为-backlog-中的显式选项",[1051],{"type":188,"value":1052},"4. 让“系统健康”成为 backlog 中的显式选项",{"type":182,"tag":191,"props":1054,"children":1055},{},[1056],{"type":188,"value":1057},"要避免“有空就去帮其他流做 feature”的惯性，需要在实践层面：",{"type":182,"tag":207,"props":1059,"children":1060},{},[1061,1089],{"type":182,"tag":211,"props":1062,"children":1063},{},[1064,1066],{"type":188,"value":1065},"把系统健康相关事项加入 backlog，并定期 review：\n",{"type":182,"tag":207,"props":1067,"children":1068},{},[1069,1074,1079,1084],{"type":182,"tag":211,"props":1070,"children":1071},{},[1072],{"type":188,"value":1073},"技术债偿还项；",{"type":182,"tag":211,"props":1075,"children":1076},{},[1077],{"type":188,"value":1078},"架构演进与平台能力增强；",{"type":182,"tag":211,"props":1080,"children":1081},{},[1082],{"type":188,"value":1083},"可观测性、SLO 实现与运维自动化改进；",{"type":182,"tag":211,"props":1085,"children":1086},{},[1087],{"type":188,"value":1088},"开发效率工具和实践优化。",{"type":182,"tag":211,"props":1090,"children":1091},{},[1092,1094],{"type":188,"value":1093},"对这类工作给出明确的业务/工程价值叙事：\n",{"type":182,"tag":207,"props":1095,"children":1096},{},[1097,1102],{"type":182,"tag":211,"props":1098,"children":1099},{},[1100],{"type":188,"value":1101},"例如减少事故恢复时间、缩短 lead time、降低新功能引入边际成本等；",{"type":182,"tag":211,"props":1103,"children":1104},{},[1105],{"type":188,"value":1106},"让管理层看到“空档做系统健康”并不是“没有产出”。",{"type":182,"tag":191,"props":1108,"children":1109},{},[1110],{"type":188,"value":1111},"这样，当团队出现富余产能时，有一个“默认优先队列”，而不是只能通过接额外需求来证明存在价值。",{"type":182,"tag":191,"props":1113,"children":1114},{},[1115],{"type":188,"value":1116},"整体来看，这条雷达的核心提醒是：**不要用看似合理的“产能利用率最大化”破坏流导向团队的设计初衷。**在 stream-aligned 的世界里，真正值得优化的是价值流的稳定性与系统健康，而不是把每一点空闲时间都填满跨流需求。用 WIP 限制、跨技能训练与动态重组这类系统性手段管理波动，才更符合长期的架构与工程效率目标。",{"title":175,"searchDepth":1118,"depth":1118,"links":1119},2,[1120,1121],{"id":185,"depth":1118,"text":189},{"id":228,"depth":1118,"text":231,"children":1122},[1123,1125,1126,1127,1128,1129],{"id":235,"depth":1124,"text":238},3,{"id":289,"depth":1124,"text":292},{"id":472,"depth":1124,"text":475},{"id":611,"depth":1124,"text":614},{"id":717,"depth":1124,"text":720},{"id":857,"depth":1124,"text":860},"markdown","content:6.maps:_management:capacity-driven-development.md","content","6.maps/_management/capacity-driven-development.md","6.maps/_management/capacity-driven-development","md",[1137,1141],{"_path":1138,"title":1139,"description":1140},"/maps/_manage/project-management","项目管理","项目管理实践指南，涵盖项目类型、目标设定、里程碑规划、风险管理等核心环节的系统性介绍。",{"_path":1142,"title":1143,"description":1144},"/maps/_management/organization","组织","团队组织架构、管理方法、沟通方式等。",1771214954383]