[{"data":1,"prerenderedAt":1148},["ShallowReactive",2],{"navigation":3,"/maps/_management/capacity-driven-development":173,"/maps/_management/capacity-driven-development-surround":1139},[4,35,92,98,125,134,158,164],{"title":5,"_path":6,"children":7},"心流思绪 / Heart Flows","/flows",[8,11,14,17,20,23,26,29,32],{"title":9,"_path":10},"📕 狮子的书单推荐","/flows/books",{"title":12,"_path":13},"🚝 四十二篇系列","/flows/forty-two",{"title":15,"_path":16},"🌃 长夜梦","/flows/long-night-dream",{"title":18,"_path":19},"🌌 万物联结与幸福感","/flows/everything",{"title":21,"_path":22},"⌛ 偷取时间","/flows/stealing-time-from-god",{"title":24,"_path":25},"🌆 表达和孤独","/flows/expression-and-loneliness",{"title":27,"_path":28},"🌧️ 我的腼腆","/flows/shy",{"title":30,"_path":31},"🥛 新工作，喝新饮料","/flows/drinking-while-thinking",{"title":33,"_path":34},"📝 心流归档","/flows/archive",{"title":36,"_path":37,"children":38},"技术博客 / Coder","/articles",[39,41,44,47,50,53,56,59,62,65,68,71,74,77,80,83,86,89],{"title":40,"_path":37},"🦁 欢迎",{"title":42,"_path":43},"📦 一个简单有效的端口命名策略：","/articles/simple-naming-method",{"title":45,"_path":46},"🌪️ Tailwind v4 如何兼容预处理器","/articles/tailwind4-with-sass",{"title":48,"_path":49},"🥞 在 tailwind 中使用现代化 CSS Layers","/articles/tailwind-sass-and-css-layer",{"title":51,"_path":52},"💻 本地部署 Qwen 翻译网页","/articles/local-translator",{"title":54,"_path":55},"🧊 模板解析器轻考古","/articles/micro-templating",{"title":57,"_path":58},"Ⓜ️ Mini CSS Parser","/articles/mini-css-parser",{"title":60,"_path":61},"🚩 向AI咨询前端问题","/articles/use-gpt-learn-complex-frontend",{"title":63,"_path":64},"⛸️ 怎样定制复杂组件的自定义滚动条？","/articles/use-scrollbars",{"title":66,"_path":67},"⚖️ 统一多组件库的层叠顺序","/articles/zindex-manager",{"title":69,"_path":70},"🕷️ 滑动验证码破解思路","/articles/crack-the-slider",{"title":72,"_path":73},"🌟 探秘 CSS 光影效果","/articles/css-light-travel",{"title":75,"_path":76},"🍲 设计模式与 JS 魔法锅","/articles/design-patterns-and-js-magic-pot",{"title":78,"_path":79},"🌐 Anysort：灵活、优雅的多属性排序","/articles/anysort-2th",{"title":81,"_path":82},"💫 CSS 幻术 | 抗锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"body":181,"_type":1133,"_id":1134,"_source":1135,"_file":1136,"_stem":1137,"_extension":1138},"/maps/_management/capacity-driven-development","_management",false,true,"","Capacity-driven development（产能驱动开发）","警惕用「填满人」替代「保障价值流」的局部最优，建议用系统健康与组织调度来管理空闲产能。",{"type":182,"children":183,"toc":1120},"root",[184,193,199,204,209,229,235,242,249,254,267,272,285,290,296,302,307,320,325,338,343,348,387,392,405,411,416,455,460,473,479,485,490,534,547,553,558,589,594,612,618,623,628,646,651,656,661,718,724,729,734,773,778,791,796,801,840,845,858,864,870,875,928,933,939,944,983,988,994,999,1045,1050,1056,1061,1110,1115],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"brief",[190],{"type":191,"value":192},"text","Brief",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"在现代软件开发实践中，成功的关键是聚焦工作流本身，而不是单纯追求资源利用率最大化。Stream-aligned 团队本应围绕单一且有价值的流（例如一条用户旅程或一个产品）工作，从而高效地交付端到端价值。",{"type":185,"tag":194,"props":200,"children":201},{},[202],{"type":191,"value":203},"目前出现了一个令人担忧的趋势：所谓“产能驱动开发”。当这些团队出现空闲产能时，会去承接来自其他产品或其他价值流的功能。这在短期内似乎提高了效率，但本质上只是适合应对突发需求高峰的局部优化。一旦被常态化，会显著增加团队认知负荷和技术债；在最坏情况下，由于跨产品频繁上下文切换的成本不断叠加，可能导致类似“拥塞崩溃”的现象，整体交付能力反而下降。",{"type":185,"tag":194,"props":205,"children":206},{},[207],{"type":191,"value":208},"当团队出现富余产能时，更好的选择是优先投入到系统健康的改进上。为了更有效地管理产能，可以：",{"type":185,"tag":210,"props":211,"children":212},"ul",{},[213,219,224],{"type":185,"tag":214,"props":215,"children":216},"li",{},[217],{"type":191,"value":218},"使用 WIP 限制（Work-in-Progress limits）来控制相邻价值流上的并行工作；",{"type":185,"tag":214,"props":220,"children":221},{},[222],{"type":191,"value":223},"通过跨技能训练（cross-training）来平衡不同时间段的需求高峰；",{"type":185,"tag":214,"props":225,"children":226},{},[227],{"type":191,"value":228},"在需要时采用动态重组团队（dynamic reteaming），而不是简单通过“多接单”填满人力。",{"type":185,"tag":186,"props":230,"children":232},{"id":231},"details",[233],{"type":191,"value":234},"Details",{"type":185,"tag":236,"props":237,"children":239},"h3",{"id":238},"背景与现状从人不能闲着到流不能乱",[240],{"type":191,"value":241},"背景与现状：从「人不能闲着」到「流不能乱」",{"type":185,"tag":243,"props":244,"children":246},"h4",{"id":245},"为什么现在要讨论-capacity-driven-development",[247],{"type":191,"value":248},"为什么现在要讨论 Capacity-driven development",{"type":185,"tag":194,"props":250,"children":251},{},[252],{"type":191,"value":253},"在很多正在向现代工程体系演进的组织里，大家已经接受：",{"type":185,"tag":210,"props":255,"children":256},{},[257,262],{"type":185,"tag":214,"props":258,"children":259},{},[260],{"type":191,"value":261},"用 stream-aligned 团队围绕某条价值流或产品组织；",{"type":185,"tag":214,"props":263,"children":264},{},[265],{"type":191,"value":266},"通过端到端 ownership 保证交付速度和反馈闭环。",{"type":185,"tag":194,"props":268,"children":269},{},[270],{"type":191,"value":271},"但是在落地过程中，传统的「人力利用率」心智往往没有一起升级：",{"type":185,"tag":210,"props":273,"children":274},{},[275,280],{"type":185,"tag":214,"props":276,"children":277},{},[278],{"type":191,"value":279},"当发现某个团队近期需求较少，就自然地把其他产品/流的 backlog 塞过去；",{"type":185,"tag":214,"props":281,"children":282},{},[283],{"type":191,"value":284},"产能调度的基本目标仍然是“不要有闲人”，而不是“保障关键流的稳态和系统健康”。",{"type":185,"tag":194,"props":286,"children":287},{},[288],{"type":191,"value":289},"在这种语境下，“产能驱动开发”很容易变成一种不被察觉、但对系统长期健康影响巨大的反模式。",{"type":185,"tag":236,"props":291,"children":293},{"id":292},"问题与风险局部最优带来的系统性退化",[294],{"type":191,"value":295},"问题与风险：局部最优带来的系统性退化",{"type":185,"tag":243,"props":297,"children":299},{"id":298},"核心矛盾填满人-vs-保持单一价值流专注",[300],{"type":191,"value":301},"核心矛盾：填满人 vs 保持单一价值流专注",{"type":185,"tag":194,"props":303,"children":304},{},[305],{"type":191,"value":306},"原文指出的本质冲突是：",{"type":185,"tag":210,"props":308,"children":309},{},[310,315],{"type":185,"tag":214,"props":311,"children":312},{},[313],{"type":191,"value":314},"设计初衷：stream-aligned 团队只专注于一个单一、清晰的价值流；",{"type":185,"tag":214,"props":316,"children":317},{},[318],{"type":191,"value":319},"实际操作：当有空档，就去做其他产品或 value stream 的功能。",{"type":185,"tag":194,"props":321,"children":322},{},[323],{"type":191,"value":324},"这种偏差带来的典型风险包括：",{"type":185,"tag":210,"props":326,"children":327},{},[328,333],{"type":185,"tag":214,"props":329,"children":330},{},[331],{"type":191,"value":332},"价值流聚焦被打散，团队从“深耕一个流”变成“多线拉扯”；",{"type":185,"tag":214,"props":334,"children":335},{},[336],{"type":191,"value":337},"注意力被短期需求填满，长期的系统性改进持续被挤出优先级。",{"type":185,"tag":243,"props":339,"children":341},{"id":340},"认知负荷与上下文切换成本",[342],{"type":191,"value":340},{"type":185,"tag":194,"props":344,"children":345},{},[346],{"type":191,"value":347},"当团队开始常态化接多个流的工作时：",{"type":185,"tag":210,"props":349,"children":350},{},[351,369],{"type":185,"tag":214,"props":352,"children":353},{},[354,356],{"type":191,"value":355},"业务维度：\n",{"type":185,"tag":210,"props":357,"children":358},{},[359,364],{"type":185,"tag":214,"props":360,"children":361},{},[362],{"type":191,"value":363},"团队被迫理解多个产品/旅程的规则和边界；",{"type":185,"tag":214,"props":365,"children":366},{},[367],{"type":191,"value":368},"心智模型从“一条清晰主线”变成若干不完整的碎片。",{"type":185,"tag":214,"props":370,"children":371},{},[372,374],{"type":191,"value":373},"技术维度：\n",{"type":185,"tag":210,"props":375,"children":376},{},[377,382],{"type":185,"tag":214,"props":378,"children":379},{},[380],{"type":191,"value":381},"可能涉及不同代码库、部署 pipeline、监控体系、合规约束；",{"type":185,"tag":214,"props":383,"children":384},{},[385],{"type":191,"value":386},"每一次任务切换，都是一次完整的上下文加载与卸载。",{"type":185,"tag":194,"props":388,"children":389},{},[390],{"type":191,"value":391},"这些成本短期内很隐性，但累积效果往往是：",{"type":185,"tag":210,"props":393,"children":394},{},[395,400],{"type":185,"tag":214,"props":396,"children":397},{},[398],{"type":191,"value":399},"Throughput 下降：表面上故事点完成不少，实际交付节奏变慢；",{"type":185,"tag":214,"props":401,"children":402},{},[403],{"type":191,"value":404},"质量波动：在不熟悉的上下文里更容易引入缺陷，也更难做好非功能性要求。",{"type":185,"tag":243,"props":406,"children":408},{"id":407},"技术债与拥塞崩溃",[409],{"type":191,"value":410},"技术债与“拥塞崩溃”",{"type":185,"tag":194,"props":412,"children":413},{},[414],{"type":191,"value":415},"原文特别强调的“congestion collapse”值得重视：",{"type":185,"tag":210,"props":417,"children":418},{},[419,437],{"type":185,"tag":214,"props":420,"children":421},{},[422,424],{"type":191,"value":423},"当多个产品/流都把团队视作“可借用的通用产能池”时：\n",{"type":185,"tag":210,"props":425,"children":426},{},[427,432],{"type":185,"tag":214,"props":428,"children":429},{},[430],{"type":191,"value":431},"任何流的需求高峰都会叠加到这个团队上；",{"type":185,"tag":214,"props":433,"children":434},{},[435],{"type":191,"value":436},"优先级频繁重排，上下文不断来回切换。",{"type":185,"tag":214,"props":438,"children":439},{},[440,442],{"type":191,"value":441},"结果是：\n",{"type":185,"tag":210,"props":443,"children":444},{},[445,450],{"type":185,"tag":214,"props":446,"children":447},{},[448],{"type":191,"value":449},"看起来事情全都在推进，实际上没有一个流推进得好；",{"type":185,"tag":214,"props":451,"children":452},{},[453],{"type":191,"value":454},"新需求和缺陷互相挤压，技术债只增不减。",{"type":185,"tag":194,"props":456,"children":457},{},[458],{"type":191,"value":459},"同时，当团队只作为“支援劳动力”参与其他流时：",{"type":185,"tag":210,"props":461,"children":462},{},[463,468],{"type":185,"tag":214,"props":464,"children":465},{},[466],{"type":191,"value":467},"对于那些流的技术决策和演进路径缺乏长期 ownership；",{"type":185,"tag":214,"props":469,"children":470},{},[471],{"type":191,"value":472},"为赶进度容易落入局部 hack，长远看拖累系统整体演进。",{"type":185,"tag":236,"props":474,"children":476},{"id":475},"模式与原理从产能导向回到价值流导向",[477],{"type":191,"value":478},"模式与原理：从「产能导向」回到「价值流导向」",{"type":185,"tag":243,"props":480,"children":482},{"id":481},"capacity-driven-development-的模式特征",[483],{"type":191,"value":484},"Capacity-driven development 的模式特征",{"type":185,"tag":194,"props":486,"children":487},{},[488],{"type":191,"value":489},"从模式角度看，capacity-driven development 具有几个典型特征：",{"type":185,"tag":210,"props":491,"children":492},{},[493,516],{"type":185,"tag":214,"props":494,"children":495},{},[496,498],{"type":191,"value":497},"优化目标被设在“让每个团队都满负荷工作”，而不是：\n",{"type":185,"tag":210,"props":499,"children":500},{},[501,506,511],{"type":185,"tag":214,"props":502,"children":503},{},[504],{"type":191,"value":505},"缩短端到端 lead time；",{"type":185,"tag":214,"props":507,"children":508},{},[509],{"type":191,"value":510},"提升关键流的可靠性和可预期性；",{"type":185,"tag":214,"props":512,"children":513},{},[514],{"type":191,"value":515},"改善架构和工程基础设施。",{"type":185,"tag":214,"props":517,"children":518},{},[519,521],{"type":191,"value":520},"组织层面缺乏系统性调度手段，于是：\n",{"type":185,"tag":210,"props":522,"children":523},{},[524,529],{"type":185,"tag":214,"props":525,"children":526},{},[527],{"type":191,"value":528},"用“多接项目/多接 feature”来填平不均匀负载；",{"type":185,"tag":214,"props":530,"children":531},{},[532],{"type":191,"value":533},"把结构性问题（流划分、组织边界、平台能力不足）压在一线团队的 task 分配上。",{"type":185,"tag":194,"props":535,"children":536},{},[537,539,545],{"type":191,"value":538},"原文的态度非常明确：这种做法仅在",{"type":185,"tag":540,"props":541,"children":542},"strong",{},[543],{"type":191,"value":544},"应对突发需求高峰",{"type":191,"value":546},"时是合理的局部优化，一旦常态化，就是系统性的反模式。",{"type":185,"tag":243,"props":548,"children":550},{"id":549},"推荐的原则空闲产能优先投向系统健康",[551],{"type":191,"value":552},"推荐的原则：空闲产能优先投向系统健康",{"type":185,"tag":194,"props":554,"children":555},{},[556],{"type":191,"value":557},"原文给出的对策是把“多余产能”视为改善系统健康的机会，而不是自由市场里的“可出售工时”：",{"type":185,"tag":210,"props":559,"children":560},{},[561],{"type":185,"tag":214,"props":562,"children":563},{},[564,566],{"type":191,"value":565},"当一个 stream-aligned 团队出现富余产能时，更优先的方向包括：\n",{"type":185,"tag":210,"props":567,"children":568},{},[569,574,579,584],{"type":185,"tag":214,"props":570,"children":571},{},[572],{"type":191,"value":573},"偿还技术债；",{"type":185,"tag":214,"props":575,"children":576},{},[577],{"type":191,"value":578},"提升平台与工程效率；",{"type":185,"tag":214,"props":580,"children":581},{},[582],{"type":191,"value":583},"强化可观测性与稳定性；",{"type":185,"tag":214,"props":585,"children":586},{},[587],{"type":191,"value":588},"改善开发者体验（DevEx）等。",{"type":185,"tag":194,"props":590,"children":591},{},[592],{"type":191,"value":593},"这背后的逻辑是：",{"type":185,"tag":210,"props":595,"children":596},{},[597,602,607],{"type":185,"tag":214,"props":598,"children":599},{},[600],{"type":191,"value":601},"系统健康的改进往往难以在高需求期挤进 backlog；",{"type":185,"tag":214,"props":603,"children":604},{},[605],{"type":191,"value":606},"利用低需求期系统性加强“基础设施”，能提升未来处理高负载的能力；",{"type":185,"tag":214,"props":608,"children":609},{},[610],{"type":191,"value":611},"与“多接其他流需求”相比，这种投资对长期吞吐量和质量更有保障。",{"type":185,"tag":236,"props":613,"children":615},{"id":614},"对比与演进旧的多项目团队思路-vs-新的-stream-aligned-实践",[616],{"type":191,"value":617},"对比与演进：旧的「多项目团队」思路 vs 新的 Stream-aligned 实践",{"type":185,"tag":243,"props":619,"children":621},{"id":620},"传统多项目模式的惯性",[622],{"type":191,"value":620},{"type":185,"tag":194,"props":624,"children":625},{},[626],{"type":191,"value":627},"很多团队的历史状态是“多项目执行单元”：",{"type":185,"tag":210,"props":629,"children":630},{},[631,636,641],{"type":185,"tag":214,"props":632,"children":633},{},[634],{"type":191,"value":635},"同一团队同时为多个产品、多个项目服务；",{"type":185,"tag":214,"props":637,"children":638},{},[639],{"type":191,"value":640},"通过工时分配和项目数量来衡量价值；",{"type":185,"tag":214,"props":642,"children":643},{},[644],{"type":191,"value":645},"“谁有空就去哪儿支援”是默认调度策略。",{"type":185,"tag":194,"props":647,"children":648},{},[649],{"type":191,"value":650},"在这种文化下，当组织开始谈 stream-aligned 时，容易出现“名义上围绕流组织，实际上仍然是通用产能池”的过渡态，也就是本文批评的产能驱动模式。",{"type":185,"tag":243,"props":652,"children":654},{"id":653},"向流导向模式的演进重点",[655],{"type":191,"value":653},{"type":185,"tag":194,"props":657,"children":658},{},[659],{"type":191,"value":660},"要真正从“多项目团队”演进为“stream-aligned 团队”，需要在实践上做到：",{"type":185,"tag":210,"props":662,"children":663},{},[664,682,700],{"type":185,"tag":214,"props":665,"children":666},{},[667,669],{"type":191,"value":668},"唯一主责流：\n",{"type":185,"tag":210,"props":670,"children":671},{},[672,677],{"type":185,"tag":214,"props":673,"children":674},{},[675],{"type":191,"value":676},"每个团队只拥有一个一等公民级别的价值流；",{"type":185,"tag":214,"props":678,"children":679},{},[680],{"type":191,"value":681},"其他工作的参与被定义为“例外支援”，而不是默认期望。",{"type":185,"tag":214,"props":683,"children":684},{},[685,687],{"type":191,"value":686},"上下文数量有上限：\n",{"type":185,"tag":210,"props":688,"children":689},{},[690,695],{"type":185,"tag":214,"props":691,"children":692},{},[693],{"type":191,"value":694},"有意识地限制团队同时参与的产品/流数量；",{"type":185,"tag":214,"props":696,"children":697},{},[698],{"type":191,"value":699},"对跨域工作尽量通过接口协作、平台能力、组织重构来吸收，而不是压到现有团队上。",{"type":185,"tag":214,"props":701,"children":702},{},[703,705],{"type":191,"value":704},"明确“系统健康工作”的合法性：\n",{"type":185,"tag":210,"props":706,"children":707},{},[708,713],{"type":185,"tag":214,"props":709,"children":710},{},[711],{"type":191,"value":712},"在组织层面默认：在主责流相对平稳时，把空档用来改善系统，而不是自动帮其他流清 backlog；",{"type":185,"tag":214,"props":714,"children":715},{},[716],{"type":191,"value":717},"让架构演进、技术债治理、DevEx 优化成为 backlog 的一等公民。",{"type":185,"tag":236,"props":719,"children":721},{"id":720},"系统影响对架构工程效率与组织协作的牵引",[722],{"type":191,"value":723},"系统影响：对架构、工程效率与组织协作的牵引",{"type":185,"tag":243,"props":725,"children":727},{"id":726},"对架构与技术栈治理的一致性影响",[728],{"type":191,"value":726},{"type":185,"tag":194,"props":730,"children":731},{},[732],{"type":191,"value":733},"当团队经常在多个价值流之间来回：",{"type":185,"tag":210,"props":735,"children":736},{},[737,755],{"type":185,"tag":214,"props":738,"children":739},{},[740,742],{"type":191,"value":741},"容易在不同业务中种下风格各异的实现方式：\n",{"type":185,"tag":210,"props":743,"children":744},{},[745,750],{"type":185,"tag":214,"props":746,"children":747},{},[748],{"type":191,"value":749},"技术选型和编码风格漂移，难以形成清晰的架构“主干”；",{"type":185,"tag":214,"props":751,"children":752},{},[753],{"type":191,"value":754},"局部为了短期交付做出的折衷，很难在后续获得时间系统清理。",{"type":185,"tag":214,"props":756,"children":757},{},[758,760],{"type":191,"value":759},"领域边界容易变模糊：\n",{"type":185,"tag":210,"props":761,"children":762},{},[763,768],{"type":185,"tag":214,"props":764,"children":765},{},[766],{"type":191,"value":767},"谁对哪个域的长期演进负责不清晰；",{"type":185,"tag":214,"props":769,"children":770},{},[771],{"type":191,"value":772},"通用能力和业务特定实现混杂在一起。",{"type":185,"tag":194,"props":774,"children":775},{},[776],{"type":191,"value":777},"反之，如果坚持流导向原则、避免常态化跨流开发：",{"type":185,"tag":210,"props":779,"children":780},{},[781,786],{"type":185,"tag":214,"props":782,"children":783},{},[784],{"type":191,"value":785},"领域边界和所有权更清晰，有利于中长期的架构演进；",{"type":185,"tag":214,"props":787,"children":788},{},[789],{"type":191,"value":790},"可以更从容地在每条流内打磨稳定的技术栈与平台能力。",{"type":185,"tag":243,"props":792,"children":794},{"id":793},"对工程效率与质量文化的影响",[795],{"type":191,"value":793},{"type":185,"tag":194,"props":797,"children":798},{},[799],{"type":191,"value":800},"在产能驱动模式下：",{"type":185,"tag":210,"props":802,"children":803},{},[804,822],{"type":185,"tag":214,"props":805,"children":806},{},[807,809],{"type":191,"value":808},"指标和文化可能偏向：\n",{"type":185,"tag":210,"props":810,"children":811},{},[812,817],{"type":185,"tag":214,"props":813,"children":814},{},[815],{"type":191,"value":816},"以任务数量、支援次数、工时填满度作为成功衡量；",{"type":185,"tag":214,"props":818,"children":819},{},[820],{"type":191,"value":821},"没有显性空间讨论系统健康、架构演进、工程基础设施。",{"type":185,"tag":214,"props":823,"children":824},{},[825,827],{"type":191,"value":826},"对质量与可维护性的长期关注被弱化：\n",{"type":185,"tag":210,"props":828,"children":829},{},[830,835],{"type":185,"tag":214,"props":831,"children":832},{},[833],{"type":191,"value":834},"团队处在持续多线程状态，很难在某个流/系统上形成深度掌控；",{"type":185,"tag":214,"props":836,"children":837},{},[838],{"type":191,"value":839},"缺陷与技术债在多个产品间分散，使得治理难度和成本都上升。",{"type":185,"tag":194,"props":841,"children":842},{},[843],{"type":191,"value":844},"而按照原文建议将空闲产能投入系统健康：",{"type":185,"tag":210,"props":846,"children":847},{},[848,853],{"type":185,"tag":214,"props":849,"children":850},{},[851],{"type":191,"value":852},"有助于形成“质量、可靠性、工程基础设施是团队职责一部分”的共识；",{"type":185,"tag":214,"props":854,"children":855},{},[856],{"type":191,"value":857},"从长期来看，提高处理高峰期的抗压能力，降低事故率。",{"type":185,"tag":236,"props":859,"children":861},{"id":860},"落地建议如何在实际团队中避免产能驱动陷阱",[862],{"type":191,"value":863},"落地建议：如何在实际团队中避免「产能驱动陷阱」",{"type":185,"tag":243,"props":865,"children":867},{"id":866},"_1-明确跨流支援是短期应急而非常态机制",[868],{"type":191,"value":869},"1. 明确：跨流支援是短期应急，而非常态机制",{"type":185,"tag":194,"props":871,"children":872},{},[873],{"type":191,"value":874},"可以在团队与管理层达成几个基础原则：",{"type":185,"tag":210,"props":876,"children":877},{},[878,903],{"type":185,"tag":214,"props":879,"children":880},{},[881,883,888,890],{"type":191,"value":882},"Stream-aligned 团队的",{"type":185,"tag":540,"props":884,"children":885},{},[886],{"type":191,"value":887},"默认状态",{"type":191,"value":889},"：\n",{"type":185,"tag":210,"props":891,"children":892},{},[893,898],{"type":185,"tag":214,"props":894,"children":895},{},[896],{"type":191,"value":897},"专注于单一主责价值流；",{"type":185,"tag":214,"props":899,"children":900},{},[901],{"type":191,"value":902},"富余产能用于该流相关的系统健康与工程提升。",{"type":185,"tag":214,"props":904,"children":905},{},[906,908,913,915],{"type":191,"value":907},"跨流支援的",{"type":185,"tag":540,"props":909,"children":910},{},[911],{"type":191,"value":912},"触发条件",{"type":191,"value":914},"应当明确且有限：\n",{"type":185,"tag":210,"props":916,"children":917},{},[918,923],{"type":185,"tag":214,"props":919,"children":920},{},[921],{"type":191,"value":922},"例如：重大业务活动、突发流量高峰、严重生产事故等；",{"type":185,"tag":214,"props":924,"children":925},{},[926],{"type":191,"value":927},"支援时间范围和职责范围事先约定清楚，不演化为长期分身。",{"type":185,"tag":194,"props":929,"children":930},{},[931],{"type":191,"value":932},"这有助于把“不断接其他流需求”的惯性约束在例外范围之内。",{"type":185,"tag":243,"props":934,"children":936},{"id":935},"_2-使用-wip-limits-控制跨流在制品",[937],{"type":191,"value":938},"2. 使用 WIP limits 控制跨流在制品",{"type":185,"tag":194,"props":940,"children":941},{},[942],{"type":191,"value":943},"针对“多流并行导致拥塞”的核心问题，可以：",{"type":185,"tag":210,"props":945,"children":946},{},[947,965],{"type":185,"tag":214,"props":948,"children":949},{},[950,952],{"type":191,"value":951},"在团队内部：\n",{"type":185,"tag":210,"props":953,"children":954},{},[955,960],{"type":185,"tag":214,"props":956,"children":957},{},[958],{"type":191,"value":959},"定义团队整体的在制品上限；",{"type":185,"tag":214,"props":961,"children":962},{},[963],{"type":191,"value":964},"为跨产品/跨流的工作单独设置更严格的 WIP 配额（比如最多 1 个）。",{"type":185,"tag":214,"props":966,"children":967},{},[968,970],{"type":191,"value":969},"在相邻流层面：\n",{"type":185,"tag":210,"props":971,"children":972},{},[973,978],{"type":185,"tag":214,"props":974,"children":975},{},[976],{"type":191,"value":977},"对同一组团队能够同时承载的邻接流工作量设置总 WIP；",{"type":185,"tag":214,"props":979,"children":980},{},[981],{"type":191,"value":982},"严格采用“拉动式”机制：团队依据 WIP 余量拉取，而不是由上游不断推任务。",{"type":185,"tag":194,"props":984,"children":985},{},[986],{"type":191,"value":987},"这样可以把“多塞需求”的冲动转化为对现有工作流动性的显性权衡。",{"type":185,"tag":243,"props":989,"children":991},{"id":990},"_3-通过-cross-training-与-dynamic-reteaming-做结构性平衡",[992],{"type":191,"value":993},"3. 通过 Cross-training 与 Dynamic reteaming 做结构性平衡",{"type":185,"tag":194,"props":995,"children":996},{},[997],{"type":191,"value":998},"原文建议的 cross-training 和 dynamic reteaming，可以理解为：",{"type":185,"tag":210,"props":1000,"children":1001},{},[1002,1027],{"type":185,"tag":214,"props":1003,"children":1004},{},[1005,1007],{"type":191,"value":1006},"Cross-training：\n",{"type":185,"tag":210,"props":1008,"children":1009},{},[1010,1015],{"type":185,"tag":214,"props":1011,"children":1012},{},[1013],{"type":191,"value":1014},"在同一条流或强相关流内部，提升团队成员的技能冗余；",{"type":185,"tag":214,"props":1016,"children":1017},{},[1018,1020,1025],{"type":191,"value":1019},"使团队在需求侧波动时可以在",{"type":185,"tag":540,"props":1021,"children":1022},{},[1023],{"type":191,"value":1024},"同一上下文内",{"type":191,"value":1026},"灵活调度人，而非强迫个人去适配完全不同的产品/技术栈。",{"type":185,"tag":214,"props":1028,"children":1029},{},[1030,1032],{"type":191,"value":1031},"Dynamic reteaming：\n",{"type":185,"tag":210,"props":1033,"children":1034},{},[1035,1040],{"type":185,"tag":214,"props":1036,"children":1037},{},[1038],{"type":191,"value":1039},"当某些流长期高压而另一些长期低压时，考虑调整团队边界；",{"type":185,"tag":214,"props":1041,"children":1042},{},[1043],{"type":191,"value":1044},"通过拆分、合并或重划 stream 来对齐长期负载，而不是用临时借人解决结构性矛盾。",{"type":185,"tag":194,"props":1046,"children":1047},{},[1048],{"type":191,"value":1049},"这两种手段的共同点是：用组织结构和技能结构调整匹配长期 demand pattern，而不是简单做短期工时调度。",{"type":185,"tag":243,"props":1051,"children":1053},{"id":1052},"_4-让系统健康成为-backlog-中的显式选项",[1054],{"type":191,"value":1055},"4. 让“系统健康”成为 backlog 中的显式选项",{"type":185,"tag":194,"props":1057,"children":1058},{},[1059],{"type":191,"value":1060},"要避免“有空就去帮其他流做 feature”的惯性，需要在实践层面：",{"type":185,"tag":210,"props":1062,"children":1063},{},[1064,1092],{"type":185,"tag":214,"props":1065,"children":1066},{},[1067,1069],{"type":191,"value":1068},"把系统健康相关事项加入 backlog，并定期 review：\n",{"type":185,"tag":210,"props":1070,"children":1071},{},[1072,1077,1082,1087],{"type":185,"tag":214,"props":1073,"children":1074},{},[1075],{"type":191,"value":1076},"技术债偿还项；",{"type":185,"tag":214,"props":1078,"children":1079},{},[1080],{"type":191,"value":1081},"架构演进与平台能力增强；",{"type":185,"tag":214,"props":1083,"children":1084},{},[1085],{"type":191,"value":1086},"可观测性、SLO 实现与运维自动化改进；",{"type":185,"tag":214,"props":1088,"children":1089},{},[1090],{"type":191,"value":1091},"开发效率工具和实践优化。",{"type":185,"tag":214,"props":1093,"children":1094},{},[1095,1097],{"type":191,"value":1096},"对这类工作给出明确的业务/工程价值叙事：\n",{"type":185,"tag":210,"props":1098,"children":1099},{},[1100,1105],{"type":185,"tag":214,"props":1101,"children":1102},{},[1103],{"type":191,"value":1104},"例如减少事故恢复时间、缩短 lead time、降低新功能引入边际成本等；",{"type":185,"tag":214,"props":1106,"children":1107},{},[1108],{"type":191,"value":1109},"让管理层看到“空档做系统健康”并不是“没有产出”。",{"type":185,"tag":194,"props":1111,"children":1112},{},[1113],{"type":191,"value":1114},"这样，当团队出现富余产能时，有一个“默认优先队列”，而不是只能通过接额外需求来证明存在价值。",{"type":185,"tag":194,"props":1116,"children":1117},{},[1118],{"type":191,"value":1119},"整体来看，这条雷达的核心提醒是：**不要用看似合理的“产能利用率最大化”破坏流导向团队的设计初衷。**在 stream-aligned 的世界里，真正值得优化的是价值流的稳定性与系统健康，而不是把每一点空闲时间都填满跨流需求。用 WIP 限制、跨技能训练与动态重组这类系统性手段管理波动，才更符合长期的架构与工程效率目标。",{"title":178,"searchDepth":1121,"depth":1121,"links":1122},2,[1123,1124],{"id":188,"depth":1121,"text":192},{"id":231,"depth":1121,"text":234,"children":1125},[1126,1128,1129,1130,1131,1132],{"id":238,"depth":1127,"text":241},3,{"id":292,"depth":1127,"text":295},{"id":475,"depth":1127,"text":478},{"id":614,"depth":1127,"text":617},{"id":720,"depth":1127,"text":723},{"id":860,"depth":1127,"text":863},"markdown","content:6.maps:_management:capacity-driven-development.md","content","6.maps/_management/capacity-driven-development.md","6.maps/_management/capacity-driven-development","md",[1140,1144],{"_path":1141,"title":1142,"description":1143},"/maps/_manage/project-management","项目管理","项目管理实践指南，涵盖项目类型、目标设定、里程碑规划、风险管理等核心环节的系统性介绍。",{"_path":1145,"title":1146,"description":1147},"/maps/_management/organization","组织","团队组织架构、管理方法、沟通方式等。",1771693420701]