pe":182,"children":183,"toc":238},"root",[184,193,199,204,209,214,219,224],{"type":185,"tag":186,"props":187,"children":189},"element","h4",{"id":188},"领导力的手艺智慧从控制到对齐的范式转变",[190],{"type":191,"value":192},"text","领导力的手艺智慧：从控制到对齐的范式转变",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"领导力是一门手艺，其本质不在于个人英雄主义的控制，而在于设计一个能自我对齐、持续进化的系统。\n这7条mantras共同指向一个核心认知转变：",{"type":185,"tag":194,"props":200,"children":201},{},[202],{"type":191,"value":203},"领导者的角色不是 wield power，而是 distribute power——通过设定方向、赋能他人、确保决策发生在拥有正确技能和语境的层级，领导者将自身影响力规模化。",{"type":185,"tag":194,"props":205,"children":206},{},[207],{"type":191,"value":208},"组织应被视为系统而非零件的加总。孤立优化个体（无论是明星员工还是单个部门）往往损害整体；\n真正的改进来自于调整各部分之间的互动关系——明确目标、对齐激励、关注接口与交接。",{"type":185,"tag":194,"props":210,"children":211},{},[212],{"type":191,"value":213},"进步的路径是\"走向绿色\"而非追求完美。复杂问题不需要宏大的解决方案，而需要识别渐进的改进路径，通过务实的近程行动积累动能。",{"type":185,"tag":194,"props":215,"children":216},{},[217],{"type":191,"value":218},"预算是用数字表达的策略，数据是业务的真相来源。理解资源流向，才能理解业务的本质和未来走向。",{"type":185,"tag":194,"props":220,"children":221},{},[222],{"type":191,"value":223},"这些mantras不是教条，而是反思的路标。它们源于医学领域的\"craft wisdom\"传统——那些无法从教科书中获得、只能通过实践吸收的智慧。",{"type":185,"tag":194,"props":225,"children":226},{},[227,229],{"type":191,"value":228},"见：",{"type":185,"tag":230,"props":231,"children":235},"a",{"href":232,"rel":233},"https://hackernoon.com/optimize-for-alignment-not-control-great-leaders-serve-and-more-startup-mantras",[234],"nofollow",[236],{"type":191,"value":237},"Optimize for Alignment, Not Control",{"title":178,"searchDepth":239,"depth":239,"links":240},2,[],"markdown","content:6.maps:_management:leadership.md","content","6.maps/_management/leadership.md","6.maps/_management/leadership","md",[248,252],{"_path":249,"title":250,"description":251},"/maps/_management/capacity-driven-development/capacity-driven-development","Capacity-driven development（产能驱动开发）","警惕用「填满人」替代「保障价值流」的局部最优，建议用系统健康与组织调度来管理空闲产能。",{"_path":253,"title":254,"description":255},"/maps/_management/management","管理","团队管理、组织架构、开发方法和工程文化",1772185503927]