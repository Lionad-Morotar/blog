192,"value":1066},"落地建议：如何减少“独立数据工程团队”的反模式风险",{"type":186,"tag":224,"props":1068,"children":1070},{"id":1069},"_1-明确hold的含义与边界",[1071],{"type":192,"value":1072},"1. 明确“Hold”的含义与边界",{"type":186,"tag":195,"props":1074,"children":1075},{},[1076,1078,1083],{"type":192,"value":1077},"作者将该实践标记为 ",{"type":186,"tag":284,"props":1079,"children":1080},{},[1081],{"type":192,"value":1082},"Hold",{"type":192,"value":1084},"，意图是“强烈不鼓励”：",{"type":186,"tag":236,"props":1086,"children":1087},{},[1088,1093],{"type":186,"tag":240,"props":1089,"children":1090},{},[1091],{"type":192,"value":1092},"并非说“任何形式的集中数据工程能力都不允许存在”",{"type":186,"tag":240,"props":1094,"children":1095},{},[1096,1098],{"type":192,"value":1097},"而是反对这种组织结构：\n",{"type":186,"tag":236,"props":1099,"children":1100},{},[1101,1106],{"type":186,"tag":240,"props":1102,"children":1103},{},[1104],{"type":192,"value":1105},"数据工程团队与业务领域割裂",{"type":186,"tag":240,"props":1107,"children":1108},{},[1109],{"type":192,"value":1110},"由该团队“代为拥有”各领域的数据产品",{"type":186,"tag":195,"props":1112,"children":1113},{},[1114,1116],{"type":192,"value":1115},"也就是说，",{"type":186,"tag":284,"props":1117,"children":1118},{},[1119],{"type":192,"value":1120},"集中式的平台能力可以存在，但不应承担“代替领域拥有数据产品”的职责。",{"type":186,"tag":224,"props":1122,"children":1124},{"id":1123},"_2-重构职责边界从做事转向赋能",[1125],{"type":192,"value":1126},"2. 重构职责边界：从“做事”转向“赋能”",{"type":186,"tag":195,"props":1128,"children":1129},{},[1130],{"type":192,"value":1131},"如果当前组织已经有独立的数据工程团队，可以考虑以下路径：",{"type":186,"tag":236,"props":1133,"children":1134},{},[1135,1153,1171],{"type":186,"tag":240,"props":1136,"children":1137},{},[1138,1140],{"type":192,"value":1139},"对现有工作进行职责梳理：",{"type":186,"tag":236,"props":1141,"children":1142},{},[1143,1148],{"type":186,"tag":240,"props":1144,"children":1145},{},[1146],{"type":192,"value":1147},"哪些是“平台能力”的建设（统一调度、存储、质量、监控）",{"type":186,"tag":240,"props":1149,"children":1150},{},[1151],{"type":192,"value":1152},"哪些是“领域特定数据产品”的建设",{"type":186,"tag":240,"props":1154,"children":1155},{},[1156,1158],{"type":192,"value":1157},"将平台相关部分：",{"type":186,"tag":236,"props":1159,"children":1160},{},[1161,1166],{"type":186,"tag":240,"props":1162,"children":1163},{},[1164],{"type":192,"value":1165},"明确为“平台团队”的 backlog 与目标",{"type":186,"tag":240,"props":1167,"children":1168},{},[1169],{"type":192,"value":1170},"用产品化思维提升复用与自助程度",{"type":186,"tag":240,"props":1172,"children":1173},{},[1174,1176],{"type":192,"value":1175},"将领域特定部分：",{"type":186,"tag":236,"props":1177,"children":1178},{},[1179,1184],{"type":186,"tag":240,"props":1180,"children":1181},{},[1182],{"type":192,"value":1183},"逐步迁移到各个流向对齐（stream-aligned）的业务团队",{"type":186,"tag":240,"props":1185,"children":1186},{},[1187],{"type":192,"value":1188},"或通过“嵌入式数据工程师”的方式下沉到领域团队",{"type":186,"tag":224,"props":1190,"children":1192},{"id":1191},"_3-建立跨职能的领域团队形态",[1193],{"type":192,"value":1194},"3. 建立跨职能的领域团队形态",{"type":186,"tag":195,"props":1196,"children":1197},{},[1198],{"type":192,"value":1199},"为了支撑领域团队真正拥有数据产品，需要：",{"type":186,"tag":236,"props":1201,"children":1202},{},[1203,1226],{"type":186,"tag":240,"props":1204,"children":1205},{},[1206,1208],{"type":192,"value":1207},"在每个核心业务域中，构建包含：",{"type":186,"tag":236,"props":1209,"children":1210},{},[1211,1216,1221],{"type":186,"tag":240,"props":1212,"children":1213},{},[1214],{"type":192,"value":1215},"产品/业务负责人",{"type":186,"tag":240,"props":1217,"children":1218},{},[1219],{"type":192,"value":1220},"应用工程师",{"type":186,"tag":240,"props":1222,"children":1223},{},[1224],{"type":192,"value":1225},"数据工程角色（专职或兼职）\n的跨职能团队形态。",{"type":186,"tag":240,"props":1227,"children":1228},{},[1229,1231],{"type":192,"value":1230},"平台团队则负责：",{"type":186,"tag":236,"props":1232,"children":1233},{},[1234,1239,1244],{"type":186,"tag":240,"props":1235,"children":1236},{},[1237],{"type":192,"value":1238},"培训这些团队正确使用平台",{"type":186,"tag":240,"props":1240,"children":1241},{},[1242],{"type":192,"value":1243},"为常见模式提供最佳实践（模板管道、可复用组件）",{"type":186,"tag":240,"props":1245,"children":124