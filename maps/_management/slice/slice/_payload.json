":182,"children":183,"toc":249},"root",[184,192,207,212,218,229,239],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"子主题",[190],{"type":191,"value":188},"text",{"type":185,"tag":193,"props":194,"children":195},"ul",{},[196],{"type":185,"tag":197,"props":198,"children":199},"li",{},[200],{"type":185,"tag":201,"props":202,"children":204},"a",{"href":203},"/maps/_management/slice/standalone-data-engineering-team",[205],{"type":191,"value":206},"独立数据工程团队",{"type":185,"tag":186,"props":208,"children":210},{"id":209},"概述",[211],{"type":191,"value":209},{"type":185,"tag":213,"props":214,"children":215},"p",{},[216],{"type":191,"value":217},"团队切片（Team Slicing）探讨如何合理切分团队边界和组织结构，以及常见的组织反模式。",{"type":185,"tag":213,"props":219,"children":220},{},[221,227],{"type":185,"tag":222,"props":223,"children":224},"strong",{},[225],{"type":191,"value":226},"组织模式与反模式",{"type":191,"value":228},"：分析不同团队组织方式的利弊，识别可能导致效率下降、知识孤岛和流程瓶颈的组织结构问题。",{"type":185,"tag":213,"props":230,"children":231},{},[232,237],{"type":185,"tag":222,"props":233,"children":234},{},[235],{"type":191,"value":236},"独立数据工程团队作为一种反模式",{"type":191,"value":238},"：将数据工程从业务领域团队中剥离出来是一种组织反模式，会导致知识孤岛、流程瓶颈和大量浪费。更合理的模式是数据平台团队专注于建设和维护共享基础设施，而跨职能的业务领域团队在其上构建并拥有自己的数据产品。",{"type":185,"tag":213,"props":240,"children":241},{},[242,247],{"type":185,"tag":222,"props":243,"children":244},{},[245],{"type":191,"value":246},"Data Mesh 原则",{"type":191,"value":248},"：数据应以业务领域作为第一抽象单元，领域团队对其域内数据的质量、可用性、可理解性负责，而不是由独立的集中式团队代为拥有所有数据产品。",{"title":178,"searchDepth":250,"depth":250,"links":251},2,[252,253],{"id":188,"depth":250,"text":188},{"id":209,"depth":250,"text":209},"markdown","content:6.maps:_management:slice:slice.md","content","6.maps/_management/slice/slice.md","6.maps/_management/slice/slice","md",[261,265],{"_path":262,"title":263,"description":264},"/maps/_management/shape-up/shape-up","Shape Up","适合中小团队的一种工作方式。",{"_path":203,"title":266,"description":267},"Standalone Data Engineering Teams（独立数据工程团队）","为什么将数据工程从业务领域团队中剥离出来是一种组织反模式，以及应该如何用平台 + 领域团队协作来取代它。",1772185503936]