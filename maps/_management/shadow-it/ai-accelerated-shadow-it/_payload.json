,"💫 CSS 幻术 | 抗锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133,"children":134},"造物 / Make","/tools",[135,137,140,143,146,149,152],{"title":136,"_path":133},"🧰 工具收集",{"title":138,"_path":139},"📕 博客","/tools/blog",{"title":141,"_path":142},"🥥 Coconut","/tools/coconut",{"title":144,"_path":145},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":147,"_path":148},"🌐 AnySort","/tools/anysort",{"title":150,"_path":151},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":153,"_path":154},"👓 Crapto","/tools/crypto-inline",{"title":156,"_path":157,"children":158},"我 / About","/hire",[159],{"title":160,"_path":157},"📬 技术简历",{"title":162,"_path":163,"children":164},"En","/en",[165],{"title":166,"_path":167,"children":168},"🦁 Welcome","/en/articles",[169],{"title":166,"_path":167},{"_path":171,"_dir":172,"_draft":173,"_partial":174,"_locale":175,"title":176,"description":177,"body":178,"_type":1253,"_id":1254,"_source":1255,"_file":1256,"_stem":1257,"_extension":1258},"/maps/_management/shadow-it/ai-accelerated-shadow-it","shadow-it",false,true,"","AI 加速的影子 IT","讨论生成式 AI 和无代码平台如何催生新一轮影子 IT 现象，其风险与治理建议。",{"type":179,"children":180,"toc":1242},"root",[181,190,204,209,257,263,270,277,308,314,358,362,368,374,379,397,402,425,431,436,493,499,504,561,564,570,576,581,590,603,612,625,634,647,653,658,707,712,720,723,729,735,740,784,790,795,826,829,835,841,846,885,891,896,909,914,953,959,964,995,998,1004,1010,1015,1067,1073,1078,1122,1127,1140,1146,1151,1208,1214,1219],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"brief",[187],{"type":188,"value":189},"text","Brief",{"type":182,"tag":191,"props":192,"children":193},"p",{},[194,196,202],{"type":188,"value":195},"这段文本讨论的是「AI 加速的影子 IT」，目前在技术雷达中的状态是 ",{"type":182,"tag":197,"props":198,"children":199},"em",{},[200],{"type":188,"value":201},"Hold",{"type":188,"value":203},"（保持警惕/慎用）。",{"type":182,"tag":191,"props":205,"children":206},{},[207],{"type":188,"value":208},"核心观点：",{"type":182,"tag":210,"props":211,"children":212},"ul",{},[213,219,224,229,234,252],{"type":182,"tag":214,"props":215,"children":216},"li",{},[217],{"type":188,"value":218},"生成式 AI + 无代码平台正在大幅降低「非工程师自己搭东西」的门槛。",{"type":182,"tag":214,"props":220,"children":221},{},[222],{"type":188,"value":223},"无代码工作流平台已经支持直接集成 OpenAI、Anthropic 等 AI API；AI coding assistant 也越来越“像代理”，让只受过基础培训的非开发人员可以拼出内部工具和集成。",{"type":182,"tag":214,"props":225,"children":226},{},[227],{"type":188,"value":228},"这些组合，很容易被当成「AI 胶水」：通过 LLM 把本来难以打通的系统粘在一起，比如把某个聊天系统里的消息转成 ERP 的 API 调用。",{"type":182,"tag":214,"props":230,"children":231},{},[232],{"type":188,"value":233},"这轮趋势和当年「用 Excel/表格驱动关键业务流程」非常像，但潜在影响面更大。",{"type":182,"tag":214,"props":235,"children":236},{},[237,239],{"type":188,"value":238},"如果缺乏治理，新一轮影子 IT 会导致：\n",{"type":182,"tag":210,"props":240,"children":241},{},[242,247],{"type":182,"tag":214,"props":243,"children":244},{},[245],{"type":188,"value":246},"大量未受管控、可能不安全的小应用和自动化；",{"type":182,"tag":214,"props":248,"children":249},{},[250],{"type":188,"value":251},"数据在更多系统之间被复制和散落，进一步加剧数据治理难度。",{"type":182,"tag":214,"props":253,"children":254},{},[255],{"type":188,"value":256},"建议组织对这种趋势保持警惕：在「快速解决问题」与「长期稳定和可治理性」之间做清醒的权衡，而不是一味追求短期提效。",{"type":182,"tag":183,"props":258,"children":260},{"id":259},"details",[261],{"type":188,"value":262},"Details",{"type":182,"tag":264,"props":265,"children":267},"h3",{"id":266},"一背景与现状从表格驱动业务到ai-胶水应用",[268],{"type":188,"value":269},"一、背景与现状：从「表格驱动业务」到「AI 胶水应用」",{"type":182,"tag":271,"props":272,"children":274},"h4",{"id":273},"_11-业务压力it-供给长期不足影子-it-有天然土壤",[275],{"type":188,"value":276},"1.1 业务压力：IT 供给长期不足，影子 IT 有天然土壤",{"type":182,"tag":210,"props":278,"children":279},{},[280,285,303],{"type":182,"tag":214,"props":281,"children":282},{},[283],{"type":188,"value":284},"在大多数中大型组织里，业务团队对数字化的需求远超 IT 部门的交付能力：小需求排不上优先级、大需求项目周期长。",{"type":182,"tag":214,"props":286,"children":287},{},[288,290],{"type":188,"value":289},"历史上的典型应对方式就是「自己搞」：\n",{"type":182,"tag":210,"props":291,"children":292},{},[293,298],{"type":182,"tag":214,"props":294,"children":295},{},[296],{"type":188,"value":297},"用 Excel/Sheets + VBA/脚本支撑关键流程；",{"type":182,"tag":214,"props":299,"children":300},{},[301],{"type":188,"value":302},"用低代码、RPA、iPaaS 拼出业务自动化。",{"type":182,"tag":214,"props":304,"children":305},{},[306],{"type":188,"value":307},"现在，生成式 AI 和无代码平台进一步降低了门槛，非技术人员可以用自然语言驱动自动化和集成，影子 IT 的形态因此发生质变。",{"type":182,"tag":271,"props":309,"children":311},{"id":310},"_12-工具有了ai-增压集成更简单能力边界被推高",[312],{"type":188,"value":313},"1.2 工具有了「AI 增压」：集成更简单，能力边界被推高",{"type":182,"tag":210,"props":315,"children":316},{},[317,335,353],{"type":182,"tag":214,"props":318,"children":319},{},[320,322],{"type":188,"value":321},"无代码工作流平台开始原生支持 AI API（OpenAI、Anthropic 等），让业务用户可以：\n",{"type":182,"tag":210,"props":323,"children":324},{},[325,330],{"type":182,"tag":214,"props":326,"children":327},{},[328],{"type":188,"value":329},"在拖拽式流程里插入 LLM 步骤，实现解析、决策、路由；",{"type":182,"tag":214,"props":331,"children":332},{},[333],{"type":188,"value":334},"用自然语言生成数据转换、规则和小片段逻辑。",{"type":182,"tag":214,"props":336,"children":337},{},[338,340],{"type":188,"value":339},"同时，更「agent-like」的 AI coding assistant 让具备基本技术素养的非工程师也可以：\n",{"type":182,"tag":210,"props":341,"children":342},{},[343,348],{"type":182,"tag":214,"props":344,"children":345},{},[346],{"type":188,"value":347},"生成简单的 Web 工具、后台小页面；",{"type":182,"tag":214,"props":349,"children":350},{},[351],{"type":188,"value":352},"操作数据库和内部 API，做数据拉通和页面拼装。",{"type":182,"tag":214,"props":354,"children":355},{},[356],{"type":188,"value":357},"结果是：大量「原本不可能、或者成本太高的集成」突然变得可行，而且不需要走正式 IT 流程。",{"type":182,"tag":359,"props":360,"children":361},"hr",{},[],{"type":182,"tag":264,"props":363,"children":365},{"id":364},"二问题与风险新一轮影子-it-的结构性矛盾",[366],{"type":188,"value":367},"二、问题与风险：新一轮影子 IT 的结构性矛盾",{"type":182,"tag":271,"props":369,"children":371},{"id":370},"_21-ai-胶水的诱惑只看见快不看见结构成本",[372],{"type":188,"value":373},"2.1 「AI 胶水」的诱惑：只看见快，不看见结构成本",{"type":182,"tag":191,"props":375,"children":376},{},[377],{"type":188,"value":378},"常见模式是：",{"type":182,"tag":210,"props":380,"children":381},{},[382,387,392],{"type":182,"tag":214,"props":383,"children":384},{},[385],{"type":188,"value":386},"在某个聊天系统里监听消息；",{"type":182,"tag":214,"props":388,"children":389},{},[390],{"type":188,"value":391},"用 LLM 解析语义、提取字段、做判断；",{"type":182,"tag":214,"props":393,"children":394},{},[395],{"type":188,"value":396},"然后在另一个系统（如 ERP）发起 API 调用。",{"type":182,"tag":191,"props":398,"children":399},{},[400],{"type":188,"value":401},"对于业务：",{"type":182,"tag":210,"props":403,"children":404},{},[405,410,415,420],{"type":182,"tag":214,"props":406,"children":407},{},[408],{"type":188,"value":409},"这是极具吸引力的「局部最优解」：不用排 IT 需求、上线快、显性成本低。\n但在架构层面，往往引入这些长期矛盾：",{"type":182,"tag":214,"props":411,"children":412},{},[413],{"type":188,"value":414},"业务规则散落在多个 LLM prompt、工作流节点和临时脚本中，缺乏统一抽象；",{"type":182,"tag":214,"props":416,"children":417},{},[418],{"type":188,"value":419},"集成路径绕开既有集成层/服务层，形成「旁路」，后续难以观测和治理；",{"type":182,"tag":214,"props":421,"children":422},{},[423],{"type":188,"value":424},"安全模型和访问控制往往只是平台默认值，很难符合企业级要求。",{"type":182,"tag":271,"props":426,"children":428},{"id":427},"_22-比表格更危险的地方规模化和不可见性",[429],{"type":188,"value":430},"2.2 「比表格更危险」的地方：规模化和不可见性",{"type":182,"tag":191,"props":432,"children":433},{},[434],{"type":188,"value":435},"与传统「Excel 影子系统」相比，AI 加速的影子 IT 有几类放大因素：",{"type":182,"tag":210,"props":437,"children":438},{},[439,457,475],{"type":182,"tag":214,"props":440,"children":441},{},[442,444],{"type":188,"value":443},"覆盖范围更广：\n",{"type":182,"tag":210,"props":445,"children":446},{},[447,452],{"type":182,"tag":214,"props":448,"children":449},{},[450],{"type":188,"value":451},"不仅限于单人/小组操作，还可以通过机器人账号、Webhooks 等触达更多系统；",{"type":182,"tag":214,"props":453,"children":454},{},[455],{"type":188,"value":456},"许多自动化可以 7×24 运行，对生产系统产生持续影响。",{"type":182,"tag":214,"props":458,"children":459},{},[460,462],{"type":188,"value":461},"逻辑更难审计：\n",{"type":182,"tag":210,"props":463,"children":464},{},[465,470],{"type":182,"tag":214,"props":466,"children":467},{},[468],{"type":188,"value":469},"LLM 的行为受 prompt、模型版本、上下文等多因素影响；",{"type":182,"tag":214,"props":471,"children":472},{},[473],{"type":188,"value":474},"很多业务决策隐含在自然语言提示和微妙的示例里，传统 code review 不再适用。",{"type":182,"tag":214,"props":476,"children":477},{},[478,480],{"type":188,"value":479},"复用性和扩散更快：\n",{"type":182,"tag":210,"props":481,"children":482},{},[483,488],{"type":182,"tag":214,"props":484,"children":485},{},[486],{"type":188,"value":487},"复制一个工作流模板、fork 一个 AI agent，成本极低；",{"type":182,"tag":214,"props":489,"children":490},{},[491],{"type":188,"value":492},"组织内部会很快出现多个类似却略有差异的流程版本，难以追踪。",{"type":182,"tag":271,"props":494,"children":496},{"id":495},"_23-数据安全与合规多系统复制与权限外溢",[497],{"type":188,"value":498},"2.3 数据安全与合规：多系统复制与权限外溢",{"type":182,"tag":191,"props":500,"children":501},{},[502],{"type":188,"value":503},"影子 IT 模式下，常见风险包括：",{"type":182,"tag":210,"props":505,"children":506},{},[507,525,543],{"type":182,"tag":214,"props":508,"children":509},{},[510,512],{"type":188,"value":511},"数据多点复制：\n",{"type":182,"tag":210,"props":513,"children":514},{},[515,520],{"type":182,"tag":214,"props":516,"children":517},{},[518],{"type":188,"value":519},"原本集中在核心系统里的数据被同步到各种「临时自动化」「小工具」中；",{"type":182,"tag":214,"props":521,"children":522},{},[523],{"type":188,"value":524},"缺乏统一的生命周期管理，删除/脱敏无法覆盖所有副本。",{"type":182,"tag":214,"props":526,"children":527},{},[528,530],{"type":188,"value":529},"权限与审计断层：\n",{"type":182,"tag":210,"props":531,"children":532},{},[533,538],{"type":182,"tag":214,"props":534,"children":535},{},[536],{"type":188,"value":537},"使用个人/共享账号调用关键系统 API；",{"type":182,"tag":214,"props":539,"children":540},{},[541],{"type":188,"value":542},"审计日志停留在无代码平台，而不是企业 SIEM/审计系统。",{"type":182,"tag":214,"props":544,"children":545},{},[546,548],{"type":188,"value":547},"模型调用合规性：\n",{"type":182,"tag":210,"props":549,"children":550},{},[551,556],{"type":182,"tag":214,"props":552,"children":553},{},[554],{"type":188,"value":555},"不同场景下，是否允许将数据发往外部模型服务、采用什么脱敏策略，往往没有统一约束；",{"type":182,"tag":214,"props":557,"children":558},{},[559],{"type":188,"value":560},"业务自发集成 AI API 容易绕过这些统一规范。",{"type":182,"tag":359,"props":562,"children":563},{},[],{"type":182,"tag":264,"props":565,"children":567},{"id":566},"三模式与原理ai-accelerated-shadow-it-的典型形态",[568],{"type":188,"value":569},"三、模式与原理：AI-accelerated Shadow IT 的典型形态",{"type":182,"tag":271,"props":571,"children":573},{"id":572},"_31-三类高频形态自动化集成中台替身",[574],{"type":188,"value":575},"3.1 三类高频形态：自动化、集成、中台替身",{"type":182,"tag":191,"props":577,"children":578},{},[579],{"type":188,"value":580},"在实践中，AI 加速影子 IT 多表现为三大类：",{"type":182,"tag":582,"props":583,"children":584},"ol",{},[585],{"type":182,"tag":214,"props":586,"children":587},{},[588],{"type":188,"value":589},"自动化机器人",{"type":182,"tag":210,"props":591,"children":592},{},[593,598],{"type":182,"tag":214,"props":594,"children":595},{},[596],{"type":188,"value":597},"以「if X then Y」为骨架，插入 LLM 作为解析/判断模块。",{"type":182,"tag":214,"props":599,"children":600},{},[601],{"type":188,"value":602},"例如：解析邮件、工单、聊天内容，自动创建任务、工单或业务对象。",{"type":182,"tag":582,"props":604,"children":606},{"start":605},2,[607],{"type":182,"tag":214,"props":608,"children":609},{},[610],{"type":188,"value":611},"集成胶水",{"type":182,"tag":210,"props":613,"children":614},{},[615,620],{"type":182,"tag":214,"props":616,"children":617},{},[618],{"type":188,"value":619},"连接两个原本无直接集成的系统，用 LLM 做协议转换和字段映射。",{"type":182,"tag":214,"props":621,"children":622},{},[623],{"type":188,"value":624},"例如：把自然语言描述转为 ERP/CRM 的结构化 API 请求。",{"type":182,"tag":582,"props":626,"children":628},{"start":627},3,[629],{"type":182,"tag":214,"props":630,"children":631},{},[632],{"type":188,"value":633},"轻量 pseudo-中台",{"type":182,"tag":210,"props":635,"children":636},{},[637,642],{"type":182,"tag":214,"props":638,"children":639},{},[640],{"type":188,"value":641},"基于无代码/低代码 + LLM，快速搭一个「内部工具」集中处理某类业务。",{"type":182,"tag":214,"props":643,"children":644},{},[645],{"type":188,"value":646},"实际上承担了一部分中台职能，却没有纳入中台的标准、治理和演进路线。",{"type":182,"tag":271,"props":648,"children":650},{"id":649},"_32-关键技术构件平台llm连接器",[651],{"type":188,"value":652},"3.2 关键技术构件：平台、LLM、连接器",{"type":182,"tag":191,"props":654,"children":655},{},[656],{"type":188,"value":657},"在技术视角下，这类影子 IT 大致由三层构成：",{"type":182,"tag":210,"props":659,"children":660},{},[661,666,689],{"type":182,"tag":214,"props":662,"children":663},{},[664],{"type":188,"value":665},"编排层：无代码/低代码工作流平台、RPA 平台、轻量集成平台；",{"type":182,"tag":214,"props":667,"children":668},{},[669,671],{"type":188,"value":670},"智能层：一个或多个 LLM/agent，用于：\n",{"type":182,"tag":210,"props":672,"children":673},{},[674,679,684],{"type":182,"tag":214,"props":675,"children":676},{},[677],{"type":188,"value":678},"解析自然语言输入；",{"type":182,"tag":214,"props":680,"children":681},{},[682],{"type":188,"value":683},"做简单决策、路由和字段映射；",{"type":182,"tag":214,"props":685,"children":686},{},[687],{"type":188,"value":688},"根据模板生成 API 调用参数或系统指令。",{"type":182,"tag":214,"props":690,"children":691},{},[692,694],{"type":188,"value":693},"连接层：\n",{"type":182,"tag":210,"props":695,"children":696},{},[697,702],{"type":182,"tag":214,"props":698,"children":699},{},[700],{"type":188,"value":701},"预置或自定义连接器（Webhook、REST、DB 连接等）；",{"type":182,"tag":214,"props":703,"children":704},{},[705],{"type":188,"value":706},"各种凭证和密钥配置。",{"type":182,"tag":191,"props":708,"children":709},{},[710],{"type":188,"value":711},"治理难点在于：",{"type":182,"tag":210,"props":713,"children":714},{},[715],{"type":182,"tag":214,"props":716,"children":717},{},[718],{"type":188,"value":719},"这三层通常由业务人员在「自己的空间」拼装起来，IT 部门只看到结果（有请求打到系统），看不到中间逻辑。",{"type":182,"tag":359,"props":721,"children":722},{},[],{"type":182,"tag":264,"props":724,"children":726},{"id":725},"四对比与演进从禁止到引导的策略选择",[727],{"type":188,"value":728},"四、对比与演进：从「禁止」到「引导」的策略选择",{"type":182,"tag":271,"props":730,"children":732},{"id":731},"_41-传统影子-it-的教训一刀切禁用常常失败",[733],{"type":188,"value":734},"4.1 传统影子 IT 的教训：一刀切禁用常常失败",{"type":182,"tag":191,"props":736,"children":737},{},[738],{"type":188,"value":739},"历史经验表明：",{"type":182,"tag":210,"props":741,"children":742},{},[743,761],{"type":182,"tag":214,"props":744,"children":745},{},[746,748],{"type":188,"value":747},"简单粗暴地「禁止使用」往往只会把问题推入地下渠道：\n",{"type":182,"tag":210,"props":749,"children":750},{},[751,756],{"type":182,"tag":214,"props":752,"children":753},{},[754],{"type":188,"value":755},"业务依然会在个人账号、个人云盘、第三方 SaaS 上构建自己的系统；",{"type":182,"tag":214,"props":757,"children":758},{},[759],{"type":188,"value":760},"IT 部门失去可见性，风险反而变大。",{"type":182,"tag":214,"props":762,"children":763},{},[764,766],{"type":188,"value":765},"比较可持续的做法往往是：\n",{"type":182,"tag":210,"props":767,"children":768},{},[769,774,779],{"type":182,"tag":214,"props":770,"children":771},{},[772],{"type":188,"value":773},"明确红线（哪些业务数据/场景严禁影子实现）；",{"type":182,"tag":214,"props":775,"children":776},{},[777],{"type":188,"value":778},"提供「安全可用的正规替代选项」（标准平台、组件、工作流模板）；",{"type":182,"tag":214,"props":780,"children":781},{},[782],{"type":188,"value":783},"通过平台化和规范化来「收编」影子创新。",{"type":182,"tag":271,"props":785,"children":787},{"id":786},"_42-ai-时代的演进从ai-胶水走向受控的智能编排",[788],{"type":188,"value":789},"4.2 AI 时代的演进：从「AI 胶水」走向「受控的智能编排」",{"type":182,"tag":191,"props":791,"children":792},{},[793],{"type":188,"value":794},"一个更现实的演进路径通常包括：",{"type":182,"tag":210,"props":796,"children":797},{},[798,803,821],{"type":182,"tag":214,"props":799,"children":800},{},[801],{"type":188,"value":802},"先承认：AI+无代码在边缘流程、小团队创新上的价值；",{"type":182,"tag":214,"props":804,"children":805},{},[806,808],{"type":188,"value":807},"再设计：\n",{"type":182,"tag":210,"props":809,"children":810},{},[811,816],{"type":182,"tag":214,"props":812,"children":813},{},[814],{"type":188,"value":815},"在统一平台内提供「受控能力」——标准连接器、预设 Prompt 模板、数据访问边界；",{"type":182,"tag":214,"props":817,"children":818},{},[819],{"type":188,"value":820},"把业务自建的自动化纳入统一目录和度量体系。",{"type":182,"tag":214,"props":822,"children":823},{},[824],{"type":188,"value":825},"最终目标是：使「AI 胶水」升级为「受控的智能编排能力」，而不是四处分散的脚本和工作流。",{"type":182,"tag":359,"props":827,"children":828},{},[],{"type":182,"tag":264,"props":830,"children":832},{"id":831},"五系统性影响架构工程效率与技术栈治理",[833],{"type":188,"value":834},"五、系统性影响：架构、工程效率与技术栈治理",{"type":182,"tag":271,"props":836,"children":838},{"id":837},"_51-架构视角集成层被旁路领域边界被稀释",[839],{"type":188,"value":840},"5.1 架构视角：集成层被旁路、领域边界被稀释",{"type":182,"tag":191,"props":842,"children":843},{},[844],{"type":188,"value":845},"放任 AI-accelerated Shadow IT 发展，可能带来的架构层影响包括：",{"type":182,"tag":210,"props":847,"children":848},{},[849,867],{"type":182,"tag":214,"props":850,"children":851},{},[852,854],{"type":188,"value":853},"集成层被旁路：\n",{"type":182,"tag":210,"props":855,"children":856},{},[857,862],{"type":182,"tag":214,"props":858,"children":859},{},[860],{"type":188,"value":861},"原本通过 ESB/API Gateway/中台服务完成的集成，被各种直接 API 调用取代；",{"type":182,"tag":214,"props":863,"children":864},{},[865],{"type":188,"value":866},"横切能力（限流、熔断、审计、监控）难以统一施加。",{"type":182,"tag":214,"props":868,"children":869},{},[870,872],{"type":188,"value":871},"领域边界模糊：\n",{"type":182,"tag":210,"props":873,"children":874},{},[875,880],{"type":182,"tag":214,"props":876,"children":877},{},[878],{"type":188,"value":879},"业务规则在 LLM prompt 和工作流里散落一地；",{"type":182,"tag":214,"props":881,"children":882},{},[883],{"type":188,"value":884},"领域模型无法沉淀到共享代码和服务中，领域知识变成「prompt 资产」。",{"type":182,"tag":271,"props":886,"children":888},{"id":887},"_52-工程效率与质量文化短期提效-vs-长期债务",[889],{"type":188,"value":890},"5.2 工程效率与质量文化：短期提效 vs 长期债务",{"type":182,"tag":191,"props":892,"children":893},{},[894],{"type":188,"value":895},"短期看：",{"type":182,"tag":210,"props":897,"children":898},{},[899,904],{"type":182,"tag":214,"props":900,"children":901},{},[902],{"type":188,"value":903},"业务痛点能快速得到缓解，减少对开发团队的小需求骚扰；",{"type":182,"tag":214,"props":905,"children":906},{},[907],{"type":188,"value":908},"一线同事对「技术可达成之事」的感知被放大，促进创新尝试。",{"type":182,"tag":191,"props":910,"children":911},{},[912],{"type":188,"value":913},"长期看：",{"type":182,"tag":210,"props":915,"children":916},{},[917,935],{"type":182,"tag":214,"props":918,"children":919},{},[920,922],{"type":188,"value":921},"维护责任模糊：\n",{"type":182,"tag":210,"props":923,"children":924},{},[925,930],{"type":182,"tag":214,"props":926,"children":927},{},[928],{"type":188,"value":929},"这些自动化出了问题，通常没有明确的 owner 或 SLO/SLA；",{"type":182,"tag":214,"props":931,"children":932},{},[933],{"type":188,"value":934},"影响生产后，IT 团队需要兜底，却未参与设计。",{"type":182,"tag":214,"props":936,"children":937},{},[938,940],{"type":188,"value":939},"质量与测试文化被边缘化：\n",{"type":182,"tag":210,"props":941,"children":942},{},[943,948],{"type":182,"tag":214,"props":944,"children":945},{},[946],{"type":188,"value":947},"很多影子流程没有系统化测试，只依赖「试了几次能跑」；",{"type":182,"tag":214,"props":949,"children":950},{},[951],{"type":188,"value":952},"一旦业务复杂度上升，缺乏回归测试框架，问题成指数级积累。",{"type":182,"tag":271,"props":954,"children":956},{"id":955},"_53-安全与合规从技术问题变成治理议题",[957],{"type":188,"value":958},"5.3 安全与合规：从「技术问题」变成「治理议题」",{"type":182,"tag":191,"props":960,"children":961},{},[962],{"type":188,"value":963},"在安全与合规层面，这更像是一个组织治理问题：",{"type":182,"tag":210,"props":965,"children":966},{},[967,972],{"type":182,"tag":214,"props":968,"children":969},{},[970],{"type":188,"value":971},"如果没有统一的政策和技术护栏，安全团队会始终处于被动排雷状态；",{"type":182,"tag":214,"props":973,"children":974},{},[975,977],{"type":188,"value":976},"相反，如果能在平台和规范层做前置设计：\n",{"type":182,"tag":210,"props":978,"children":979},{},[980,985,990],{"type":182,"tag":214,"props":981,"children":982},{},[983],{"type":188,"value":984},"对哪些数据可以流入外部模型、以什么方式流入给出清晰规则；",{"type":182,"tag":214,"props":986,"children":987},{},[988],{"type":188,"value":989},"对谁可以创建/发布工作流、怎样审批和审计设置统一机制；",{"type":182,"tag":214,"props":991,"children":992},{},[993],{"type":188,"value":994},"对平台本身进行集中加固和监控，就可以把风险集中管理。",{"type":182,"tag":359,"props":996,"children":997},{},[],{"type":182,"tag":264,"props":999,"children":1001},{"id":1000},"六落地建议在快与稳之间找到平衡",[1002],{"type":188,"value":1003},"六、落地建议：在「快」与「稳」之间找到平衡",{"type":182,"tag":271,"props":1005,"children":1007},{"id":1006},"_61-识别与分层先搞清楚哪些属于不可接受的影子-it",[1008],{"type":188,"value":1009},"6.1 识别与分层：先搞清楚哪些属于「不可接受的影子 IT」",{"type":182,"tag":191,"props":1011,"children":1012},{},[1013],{"type":188,"value":1014},"建议组织先做一轮分类与盘点：",{"type":182,"tag":210,"props":1016,"children":1017},{},[1018,1041,1054],{"type":182,"tag":214,"props":1019,"children":1020},{},[1021,1023],{"type":188,"value":1022},"明确「禁区」：\n",{"type":182,"tag":210,"props":1024,"children":1025},{},[1026,1031,1036],{"type":182,"tag":214,"props":1027,"children":1028},{},[1029],{"type":188,"value":1030},"涉及核心财务、监管强约束数据的流程和系统；",{"type":182,"tag":214,"props":1032,"children":1033},{},[1034],{"type":188,"value":1035},"涉及高敏感个人数据、商业机密的数据流动；",{"type":182,"tag":214,"props":1037,"children":1038},{},[1039],{"type":188,"value":1040},"这些场景禁止自发构建 AI+无代码集成，只能走正式技术路径。",{"type":182,"tag":214,"props":1042,"children":1043},{},[1044,1046],{"type":188,"value":1045},"区分「灰度区」：\n",{"type":182,"tag":210,"props":1047,"children":1048},{},[1049],{"type":182,"tag":214,"props":1050,"children":1051},{},[1052],{"type":188,"value":1053},"如内部协作流程优化、低风险报表生成等，可以在受控平台内试点；",{"type":182,"tag":214,"props":1055,"children":1056},{},[1057,1059],{"type":188,"value":1058},"对「安全区」：\n",{"type":182,"tag":210,"props":1060,"children":1061},{},[1062],{"type":182,"tag":214,"props":1063,"children":1064},{},[1065],{"type":188,"value":1066},"如纯信息聚合、低风险查询类工具，可以给予相对宽松的试验空间。",{"type":182,"tag":271,"props":1068,"children":1070},{"id":1069},"_62-提供正规渠道建设企业级的-ai-编排能力",[1071],{"type":188,"value":1072},"6.2 提供「正规渠道」：建设企业级的 AI 编排能力",{"type":182,"tag":191,"props":1074,"children":1075},{},[1076],{"type":188,"value":1077},"如果只压制不供给，影子 IT 很难真正减少。更可行的做法是：",{"type":182,"tag":210,"props":1079,"children":1080},{},[1081,1104],{"type":182,"tag":214,"props":1082,"children":1083},{},[1084,1086],{"type":188,"value":1085},"搭建统一的自动化/集成平台，内置：\n",{"type":182,"tag":210,"props":1087,"children":1088},{},[1089,1094,1099],{"type":182,"tag":214,"props":1090,"children":1091},{},[1092],{"type":188,"value":1093},"统一身份和权限管理；",{"type":182,"tag":214,"props":1095,"children":1096},{},[1097],{"type":188,"value":1098},"标准化的系统连接器和数据访问策略；",{"type":182,"tag":214,"props":1100,"children":1101},{},[1102],{"type":188,"value":1103},"可被审计的审批流和发布流程。",{"type":182,"tag":214,"props":1105,"children":1106},{},[1107,1109],{"type":188,"value":1108},"在该平台上以「产品化方式」提供 AI 能力：\n",{"type":182,"tag":210,"props":1110,"children":1111},{},[1112,1117],{"type":182,"tag":214,"props":1113,"children":1114},{},[1115],{"type":188,"value":1116},"预设若干「安全的 Prompt/Agent 模板」；",{"type":182,"tag":214,"props":1118,"children":1119},{},[1120],{"type":188,"value":1121},"为业务提供经评审的工作流模板库，支持复制和轻量定制。",{"type":182,"tag":191,"props":1123,"children":1124},{},[1125],{"type":188,"value":1126},"这样可以兼顾：",{"type":182,"tag":210,"props":1128,"children":1129},{},[1130,1135],{"type":182,"tag":214,"props":1131,"children":1132},{},[1133],{"type":188,"value":1134},"业务的敏捷和自助构建能力；",{"type":182,"tag":214,"props":1136,"children":1137},{},[1138],{"type":188,"value":1139},"IT 的可见性、安全与治理诉求。",{"type":182,"tag":271,"props":1141,"children":1143},{"id":1142},"_63-治理与运营把影子创新纳入可观测的实验",[1144],{"type":188,"value":1145},"6.3 治理与运营：把影子创新纳入「可观测的实验」",{"type":182,"tag":191,"props":1147,"children":1148},{},[1149],{"type":188,"value":1150},"为了在不扼杀创新的前提下降低风险，可以考虑：",{"type":182,"tag":210,"props":1152,"children":1153},{},[1154,1172,1190],{"type":182,"tag":214,"props":1155,"children":1156},{},[1157,1159],{"type":188,"value":1158},"建立「实验登记」机制：\n",{"type":182,"tag":210,"props":1160,"children":1161},{},[1162,1167],{"type":182,"tag":214,"props":1163,"children":1164},{},[1165],{"type":188,"value":1166},"所有新建的 AI 自动化、agent、工作流都需要登记基本元数据（owner、数据范围、涉及系统、预期影响）；",{"type":182,"tag":214,"props":1168,"children":1169},{},[1170],{"type":188,"value":1171},"重要流程需要简化版的风险评审。",{"type":182,"tag":214,"props":1173,"children":1174},{},[1175,1177],{"type":188,"value":1176},"强制基本观测能力：\n",{"type":182,"tag":210,"props":1178,"children":1179},{},[1180,1185],{"type":182,"tag":214,"props":1181,"children":1182},{},[1183],{"type":188,"value":1184},"统一采集运行日志、错误率、调用量等；",{"type":182,"tag":214,"props":1186,"children":1187},{},[1188],{"type":188,"value":1189},"在异常频发或影响面的流程上设置阈值和告警。",{"type":182,"tag":214,"props":1191,"children":1192},{},[1193,1195],{"type":188,"value":1194},"定期「体检和收敛」：\n",{"type":182,"tag":210,"props":1196,"children":1197},{},[1198,1203],{"type":182,"tag":214,"props":1199,"children":1200},{},[1201],{"type":188,"value":1202},"定期审查自动化目录，识别冗余、风险高、价值低的流程并退役；",{"type":182,"tag":214,"props":1204,"children":1205},{},[1206],{"type":188,"value":1207},"把运行稳定、影响大的影子流程纳入正式产品/平台演进路线。",{"type":182,"tag":271,"props":1209,"children":1211},{"id":1210},"_64-小结对于技术负责人可以考虑的几条实操路线",[1212],{"type":188,"value":1213},"6.4 小结：对于技术负责人可以考虑的几条实操路线",{"type":182,"tag":191,"props":1215,"children":1216},{},[1217],{"type":188,"value":1218},"结合上述分析，对架构师和技术负责人，可以概括为几条可执行方向：",{"type":182,"tag":210,"props":1220,"children":1221},{},[1222,1227,1232,1237],{"type":182,"tag":214,"props":1223,"children":1224},{},[1225],{"type":188,"value":1226},"不否认 AI-accelerated Shadow IT 的存在和价值，而是主动识别和分层管理；",{"type":182,"tag":214,"props":1228,"children":1229},{},[1230],{"type":188,"value":1231},"投资一个企业级、可观测的 AI 编排/自动化平台，作为业务自助构建的「唯一正门」；",{"type":182,"tag":214,"props":1233,"children":1234},{},[1235],{"type":188,"value":1236},"在平台层提供安全边界、连接器、Prompt/Agent 模板，而不是把这些责任下放给业务团队；",{"type":182,"tag":214,"props":1238,"children":1239},{},[1240],{"type":188,"value":1241},"通过治理机制（登记、审批、监控、定期体检）把「影子创新」转变为「可控实验」，在快速试错和长期稳定之间找到合理平衡。",{"title":175,"searchDepth":605,"depth":605,"links":1243},[1244,1245],{"id":185,"depth":605,"text":189},{"id":259,"depth":605,"text":262,"children":1246},[1247,1248,1249,1250,1251,1252],{"id":266,"depth":627,"text":269},{"id":364,"depth":627,"text":367},{"id":566,"depth":627,"text":569},{"id":725,"depth":627,"text":728},{"id":831,"depth":627,"text":834},{"id":1000,"depth":627,"text":1003},"markdown","content:6.maps:_management:shadow-it:ai-accelerated-shadow-it.md","content","6.maps/_management/shadow-it/ai-accelerated-shadow-it.md","6.maps/_management/shadow-it/ai-accelerated-shadow-it","md",[1260,1264],{"_path":1261,"title":1262,"description":1263},"/maps/_management/organization","组织","团队组织架构、管理方法、沟通方式等。",{"_path":1265,"title":1266,"description":1267},"/maps/_management/shape-up","Shape Up","适合中小团队的一种工作方式。",1771264656520]