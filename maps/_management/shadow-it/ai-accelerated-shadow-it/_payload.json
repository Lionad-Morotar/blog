,"💫 CSS 幻术 | 抗锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"body":181,"_type":1256,"_id":1257,"_source":1258,"_file":1259,"_stem":1260,"_extension":1261},"/maps/_management/shadow-it/ai-accelerated-shadow-it","shadow-it",false,true,"","AI 加速的影子 IT","讨论生成式 AI 和无代码平台如何催生新一轮影子 IT 现象，其风险与治理建议。",{"type":182,"children":183,"toc":1245},"root",[184,193,207,212,260,266,273,280,311,317,361,365,371,377,382,400,405,428,434,439,496,502,507,564,567,573,579,584,593,606,615,628,637,650,656,661,710,715,723,726,732,738,743,787,793,798,829,832,838,844,849,888,894,899,912,917,956,962,967,998,1001,1007,1013,1018,1070,1076,1081,1125,1130,1143,1149,1154,1211,1217,1222],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"brief",[190],{"type":191,"value":192},"text","Brief",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197,199,205],{"type":191,"value":198},"这段文本讨论的是「AI 加速的影子 IT」，目前在技术雷达中的状态是 ",{"type":185,"tag":200,"props":201,"children":202},"em",{},[203],{"type":191,"value":204},"Hold",{"type":191,"value":206},"（保持警惕/慎用）。",{"type":185,"tag":194,"props":208,"children":209},{},[210],{"type":191,"value":211},"核心观点：",{"type":185,"tag":213,"props":214,"children":215},"ul",{},[216,222,227,232,237,255],{"type":185,"tag":217,"props":218,"children":219},"li",{},[220],{"type":191,"value":221},"生成式 AI + 无代码平台正在大幅降低「非工程师自己搭东西」的门槛。",{"type":185,"tag":217,"props":223,"children":224},{},[225],{"type":191,"value":226},"无代码工作流平台已经支持直接集成 OpenAI、Anthropic 等 AI API；AI coding assistant 也越来越“像代理”，让只受过基础培训的非开发人员可以拼出内部工具和集成。",{"type":185,"tag":217,"props":228,"children":229},{},[230],{"type":191,"value":231},"这些组合，很容易被当成「AI 胶水」：通过 LLM 把本来难以打通的系统粘在一起，比如把某个聊天系统里的消息转成 ERP 的 API 调用。",{"type":185,"tag":217,"props":233,"children":234},{},[235],{"type":191,"value":236},"这轮趋势和当年「用 Excel/表格驱动关键业务流程」非常像，但潜在影响面更大。",{"type":185,"tag":217,"props":238,"children":239},{},[240,242],{"type":191,"value":241},"如果缺乏治理，新一轮影子 IT 会导致：\n",{"type":185,"tag":213,"props":243,"children":244},{},[245,250],{"type":185,"tag":217,"props":246,"children":247},{},[248],{"type":191,"value":249},"大量未受管控、可能不安全的小应用和自动化；",{"type":185,"tag":217,"props":251,"children":252},{},[253],{"type":191,"value":254},"数据在更多系统之间被复制和散落，进一步加剧数据治理难度。",{"type":185,"tag":217,"props":256,"children":257},{},[258],{"type":191,"value":259},"建议组织对这种趋势保持警惕：在「快速解决问题」与「长期稳定和可治理性」之间做清醒的权衡，而不是一味追求短期提效。",{"type":185,"tag":186,"props":261,"children":263},{"id":262},"details",[264],{"type":191,"value":265},"Details",{"type":185,"tag":267,"props":268,"children":270},"h3",{"id":269},"一背景与现状从表格驱动业务到ai-胶水应用",[271],{"type":191,"value":272},"一、背景与现状：从「表格驱动业务」到「AI 胶水应用」",{"type":185,"tag":274,"props":275,"children":277},"h4",{"id":276},"_11-业务压力it-供给长期不足影子-it-有天然土壤",[278],{"type":191,"value":279},"1.1 业务压力：IT 供给长期不足，影子 IT 有天然土壤",{"type":185,"tag":213,"props":281,"children":282},{},[283,288,306],{"type":185,"tag":217,"props":284,"children":285},{},[286],{"type":191,"value":287},"在大多数中大型组织里，业务团队对数字化的需求远超 IT 部门的交付能力：小需求排不上优先级、大需求项目周期长。",{"type":185,"tag":217,"props":289,"children":290},{},[291,293],{"type":191,"value":292},"历史上的典型应对方式就是「自己搞」：\n",{"type":185,"tag":213,"props":294,"children":295},{},[296,301],{"type":185,"tag":217,"props":297,"children":298},{},[299],{"type":191,"value":300},"用 Excel/Sheets + VBA/脚本支撑关键流程；",{"type":185,"tag":217,"props":302,"children":303},{},[304],{"type":191,"value":305},"用低代码、RPA、iPaaS 拼出业务自动化。",{"type":185,"tag":217,"props":307,"children":308},{},[309],{"type":191,"value":310},"现在，生成式 AI 和无代码平台进一步降低了门槛，非技术人员可以用自然语言驱动自动化和集成，影子 IT 的形态因此发生质变。",{"type":185,"tag":274,"props":312,"children":314},{"id":313},"_12-工具有了ai-增压集成更简单能力边界被推高",[315],{"type":191,"value":316},"1.2 工具有了「AI 增压」：集成更简单，能力边界被推高",{"type":185,"tag":213,"props":318,"children":319},{},[320,338,356],{"type":185,"tag":217,"props":321,"children":322},{},[323,325],{"type":191,"value":324},"无代码工作流平台开始原生支持 AI API（OpenAI、Anthropic 等），让业务用户可以：\n",{"type":185,"tag":213,"props":326,"children":327},{},[328,333],{"type":185,"tag":217,"props":329,"children":330},{},[331],{"type":191,"value":332},"在拖拽式流程里插入 LLM 步骤，实现解析、决策、路由；",{"type":185,"tag":217,"props":334,"children":335},{},[336],{"type":191,"value":337},"用自然语言生成数据转换、规则和小片段逻辑。",{"type":185,"tag":217,"props":339,"children":340},{},[341,343],{"type":191,"value":342},"同时，更「agent-like」的 AI coding assistant 让具备基本技术素养的非工程师也可以：\n",{"type":185,"tag":213,"props":344,"children":345},{},[346,351],{"type":185,"tag":217,"props":347,"children":348},{},[349],{"type":191,"value":350},"生成简单的 Web 工具、后台小页面；",{"type":185,"tag":217,"props":352,"children":353},{},[354],{"type":191,"value":355},"操作数据库和内部 API，做数据拉通和页面拼装。",{"type":185,"tag":217,"props":357,"children":358},{},[359],{"type":191,"value":360},"结果是：大量「原本不可能、或者成本太高的集成」突然变得可行，而且不需要走正式 IT 流程。",{"type":185,"tag":362,"props":363,"children":364},"hr",{},[],{"type":185,"tag":267,"props":366,"children":368},{"id":367},"二问题与风险新一轮影子-it-的结构性矛盾",[369],{"type":191,"value":370},"二、问题与风险：新一轮影子 IT 的结构性矛盾",{"type":185,"tag":274,"props":372,"children":374},{"id":373},"_21-ai-胶水的诱惑只看见快不看见结构成本",[375],{"type":191,"value":376},"2.1 「AI 胶水」的诱惑：只看见快，不看见结构成本",{"type":185,"tag":194,"props":378,"children":379},{},[380],{"type":191,"value":381},"常见模式是：",{"type":185,"tag":213,"props":383,"children":384},{},[385,390,395],{"type":185,"tag":217,"props":386,"children":387},{},[388],{"type":191,"value":389},"在某个聊天系统里监听消息；",{"type":185,"tag":217,"props":391,"children":392},{},[393],{"type":191,"value":394},"用 LLM 解析语义、提取字段、做判断；",{"type":185,"tag":217,"props":396,"children":397},{},[398],{"type":191,"value":399},"然后在另一个系统（如 ERP）发起 API 调用。",{"type":185,"tag":194,"props":401,"children":402},{},[403],{"type":191,"value":404},"对于业务：",{"type":185,"tag":213,"props":406,"children":407},{},[408,413,418,423],{"type":185,"tag":217,"props":409,"children":410},{},[411],{"type":191,"value":412},"这是极具吸引力的「局部最优解」：不用排 IT 需求、上线快、显性成本低。\n但在架构层面，往往引入这些长期矛盾：",{"type":185,"tag":217,"props":414,"children":415},{},[416],{"type":191,"value":417},"业务规则散落在多个 LLM prompt、工作流节点和临时脚本中，缺乏统一抽象；",{"type":185,"tag":217,"props":419,"children":420},{},[421],{"type":191,"value":422},"集成路径绕开既有集成层/服务层，形成「旁路」，后续难以观测和治理；",{"type":185,"tag":217,"props":424,"children":425},{},[426],{"type":191,"value":427},"安全模型和访问控制往往只是平台默认值，很难符合企业级要求。",{"type":185,"tag":274,"props":429,"children":431},{"id":430},"_22-比表格更危险的地方规模化和不可见性",[432],{"type":191,"value":433},"2.2 「比表格更危险」的地方：规模化和不可见性",{"type":185,"tag":194,"props":435,"children":436},{},[437],{"type":191,"value":438},"与传统「Excel 影子系统」相比，AI 加速的影子 IT 有几类放大因素：",{"type":185,"tag":213,"props":440,"children":441},{},[442,460,478],{"type":185,"tag":217,"props":443,"children":444},{},[445,447],{"type":191,"value":446},"覆盖范围更广：\n",{"type":185,"tag":213,"props":448,"children":449},{},[450,455],{"type":185,"tag":217,"props":451,"children":452},{},[453],{"type":191,"value":454},"不仅限于单人/小组操作，还可以通过机器人账号、Webhooks 等触达更多系统；",{"type":185,"tag":217,"props":456,"children":457},{},[458],{"type":191,"value":459},"许多自动化可以 7×24 运行，对生产系统产生持续影响。",{"type":185,"tag":217,"props":461,"children":462},{},[463,465],{"type":191,"value":464},"逻辑更难审计：\n",{"type":185,"tag":213,"props":466,"children":467},{},[468,473],{"type":185,"tag":217,"props":469,"children":470},{},[471],{"type":191,"value":472},"LLM 的行为受 prompt、模型版本、上下文等多因素影响；",{"type":185,"tag":217,"props":474,"children":475},{},[476],{"type":191,"value":477},"很多业务决策隐含在自然语言提示和微妙的示例里，传统 code review 不再适用。",{"type":185,"tag":217,"props":479,"children":480},{},[481,483],{"type":191,"value":482},"复用性和扩散更快：\n",{"type":185,"tag":213,"props":484,"children":485},{},[486,491],{"type":185,"tag":217,"props":487,"children":488},{},[489],{"type":191,"value":490},"复制一个工作流模板、fork 一个 AI agent，成本极低；",{"type":185,"tag":217,"props":492,"children":493},{},[494],{"type":191,"value":495},"组织内部会很快出现多个类似却略有差异的流程版本，难以追踪。",{"type":185,"tag":274,"props":497,"children":499},{"id":498},"_23-数据安全与合规多系统复制与权限外溢",[500],{"type":191,"value":501},"2.3 数据安全与合规：多系统复制与权限外溢",{"type":185,"tag":194,"props":503,"children":504},{},[505],{"type":191,"value":506},"影子 IT 模式下，常见风险包括：",{"type":185,"tag":213,"props":508,"children":509},{},[510,528,546],{"type":185,"tag":217,"props":511,"children":512},{},[513,515],{"type":191,"value":514},"数据多点复制：\n",{"type":185,"tag":213,"props":516,"children":517},{},[518,523],{"type":185,"tag":217,"props":519,"children":520},{},[521],{"type":191,"value":522},"原本集中在核心系统里的数据被同步到各种「临时自动化」「小工具」中；",{"type":185,"tag":217,"props":524,"children":525},{},[526],{"type":191,"value":527},"缺乏统一的生命周期管理，删除/脱敏无法覆盖所有副本。",{"type":185,"tag":217,"props":529,"children":530},{},[531,533],{"type":191,"value":532},"权限与审计断层：\n",{"type":185,"tag":213,"props":534,"children":535},{},[536,541],{"type":185,"tag":217,"props":537,"children":538},{},[539],{"type":191,"value":540},"使用个人/共享账号调用关键系统 API；",{"type":185,"tag":217,"props":542,"children":543},{},[544],{"type":191,"value":545},"审计日志停留在无代码平台，而不是企业 SIEM/审计系统。",{"type":185,"tag":217,"props":547,"children":548},{},[549,551],{"type":191,"value":550},"模型调用合规性：\n",{"type":185,"tag":213,"props":552,"children":553},{},[554,559],{"type":185,"tag":217,"props":555,"children":556},{},[557],{"type":191,"value":558},"不同场景下，是否允许将数据发往外部模型服务、采用什么脱敏策略，往往没有统一约束；",{"type":185,"tag":217,"props":560,"children":561},{},[562],{"type":191,"value":563},"业务自发集成 AI API 容易绕过这些统一规范。",{"type":185,"tag":362,"props":565,"children":566},{},[],{"type":185,"tag":267,"props":568,"children":570},{"id":569},"三模式与原理ai-accelerated-shadow-it-的典型形态",[571],{"type":191,"value":572},"三、模式与原理：AI-accelerated Shadow IT 的典型形态",{"type":185,"tag":274,"props":574,"children":576},{"id":575},"_31-三类高频形态自动化集成中台替身",[577],{"type":191,"value":578},"3.1 三类高频形态：自动化、集成、中台替身",{"type":185,"tag":194,"props":580,"children":581},{},[582],{"type":191,"value":583},"在实践中，AI 加速影子 IT 多表现为三大类：",{"type":185,"tag":585,"props":586,"children":587},"ol",{},[588],{"type":185,"tag":217,"props":589,"children":590},{},[591],{"type":191,"value":592},"自动化机器人",{"type":185,"tag":213,"props":594,"children":595},{},[596,601],{"type":185,"tag":217,"props":597,"children":598},{},[599],{"type":191,"value":600},"以「if X then Y」为骨架，插入 LLM 作为解析/判断模块。",{"type":185,"tag":217,"props":602,"children":603},{},[604],{"type":191,"value":605},"例如：解析邮件、工单、聊天内容，自动创建任务、工单或业务对象。",{"type":185,"tag":585,"props":607,"children":609},{"start":608},2,[610],{"type":185,"tag":217,"props":611,"children":612},{},[613],{"type":191,"value":614},"集成胶水",{"type":185,"tag":213,"props":616,"children":617},{},[618,623],{"type":185,"tag":217,"props":619,"children":620},{},[621],{"type":191,"value":622},"连接两个原本无直接集成的系统，用 LLM 做协议转换和字段映射。",{"type":185,"tag":217,"props":624,"children":625},{},[626],{"type":191,"value":627},"例如：把自然语言描述转为 ERP/CRM 的结构化 API 请求。",{"type":185,"tag":585,"props":629,"children":631},{"start":630},3,[632],{"type":185,"tag":217,"props":633,"children":634},{},[635],{"type":191,"value":636},"轻量 pseudo-中台",{"type":185,"tag":213,"props":638,"children":639},{},[640,645],{"type":185,"tag":217,"props":641,"children":642},{},[643],{"type":191,"value":644},"基于无代码/低代码 + LLM，快速搭一个「内部工具」集中处理某类业务。",{"type":185,"tag":217,"props":646,"children":647},{},[648],{"type":191,"value":649},"实际上承担了一部分中台职能，却没有纳入中台的标准、治理和演进路线。",{"type":185,"tag":274,"props":651,"children":653},{"id":652},"_32-关键技术构件平台llm连接器",[654],{"type":191,"value":655},"3.2 关键技术构件：平台、LLM、连接器",{"type":185,"tag":194,"props":657,"children":658},{},[659],{"type":191,"value":660},"在技术视角下，这类影子 IT 大致由三层构成：",{"type":185,"tag":213,"props":662,"children":663},{},[664,669,692],{"type":185,"tag":217,"props":665,"children":666},{},[667],{"type":191,"value":668},"编排层：无代码/低代码工作流平台、RPA 平台、轻量集成平台；",{"type":185,"tag":217,"props":670,"children":671},{},[672,674],{"type":191,"value":673},"智能层：一个或多个 LLM/agent，用于：\n",{"type":185,"tag":213,"props":675,"children":676},{},[677,682,687],{"type":185,"tag":217,"props":678,"children":679},{},[680],{"type":191,"value":681},"解析自然语言输入；",{"type":185,"tag":217,"props":683,"children":684},{},[685],{"type":191,"value":686},"做简单决策、路由和字段映射；",{"type":185,"tag":217,"props":688,"children":689},{},[690],{"type":191,"value":691},"根据模板生成 API 调用参数或系统指令。",{"type":185,"tag":217,"props":693,"children":694},{},[695,697],{"type":191,"value":696},"连接层：\n",{"type":185,"tag":213,"props":698,"children":699},{},[700,705],{"type":185,"tag":217,"props":701,"children":702},{},[703],{"type":191,"value":704},"预置或自定义连接器（Webhook、REST、DB 连接等）；",{"type":185,"tag":217,"props":706,"children":707},{},[708],{"type":191,"value":709},"各种凭证和密钥配置。",{"type":185,"tag":194,"props":711,"children":712},{},[713],{"type":191,"value":714},"治理难点在于：",{"type":185,"tag":213,"props":716,"children":717},{},[718],{"type":185,"tag":217,"props":719,"children":720},{},[721],{"type":191,"value":722},"这三层通常由业务人员在「自己的空间」拼装起来，IT 部门只看到结果（有请求打到系统），看不到中间逻辑。",{"type":185,"tag":362,"props":724,"children":725},{},[],{"type":185,"tag":267,"props":727,"children":729},{"id":728},"四对比与演进从禁止到引导的策略选择",[730],{"type":191,"value":731},"四、对比与演进：从「禁止」到「引导」的策略选择",{"type":185,"tag":274,"props":733,"children":735},{"id":734},"_41-传统影子-it-的教训一刀切禁用常常失败",[736],{"type":191,"value":737},"4.1 传统影子 IT 的教训：一刀切禁用常常失败",{"type":185,"tag":194,"props":739,"children":740},{},[741],{"type":191,"value":742},"历史经验表明：",{"type":185,"tag":213,"props":744,"children":745},{},[746,764],{"type":185,"tag":217,"props":747,"children":748},{},[749,751],{"type":191,"value":750},"简单粗暴地「禁止使用」往往只会把问题推入地下渠道：\n",{"type":185,"tag":213,"props":752,"children":753},{},[754,759],{"type":185,"tag":217,"props":755,"children":756},{},[757],{"type":191,"value":758},"业务依然会在个人账号、个人云盘、第三方 SaaS 上构建自己的系统；",{"type":185,"tag":217,"props":760,"children":761},{},[762],{"type":191,"value":763},"IT 部门失去可见性，风险反而变大。",{"type":185,"tag":217,"props":765,"children":766},{},[767,769],{"type":191,"value":768},"比较可持续的做法往往是：\n",{"type":185,"tag":213,"props":770,"children":771},{},[772,777,782],{"type":185,"tag":217,"props":773,"children":774},{},[775],{"type":191,"value":776},"明确红线（哪些业务数据/场景严禁影子实现）；",{"type":185,"tag":217,"props":778,"children":779},{},[780],{"type":191,"value":781},"提供「安全可用的正规替代选项」（标准平台、组件、工作流模板）；",{"type":185,"tag":217,"props":783,"children":784},{},[785],{"type":191,"value":786},"通过平台化和规范化来「收编」影子创新。",{"type":185,"tag":274,"props":788,"children":790},{"id":789},"_42-ai-时代的演进从ai-胶水走向受控的智能编排",[791],{"type":191,"value":792},"4.2 AI 时代的演进：从「AI 胶水」走向「受控的智能编排」",{"type":185,"tag":194,"props":794,"children":795},{},[796],{"type":191,"value":797},"一个更现实的演进路径通常包括：",{"type":185,"tag":213,"props":799,"children":800},{},[801,806,824],{"type":185,"tag":217,"props":802,"children":803},{},[804],{"type":191,"value":805},"先承认：AI+无代码在边缘流程、小团队创新上的价值；",{"type":185,"tag":217,"props":807,"children":808},{},[809,811],{"type":191,"value":810},"再设计：\n",{"type":185,"tag":213,"props":812,"children":813},{},[814,819],{"type":185,"tag":217,"props":815,"children":816},{},[817],{"type":191,"value":818},"在统一平台内提供「受控能力」——标准连接器、预设 Prompt 模板、数据访问边界；",{"type":185,"tag":217,"props":820,"children":821},{},[822],{"type":191,"value":823},"把业务自建的自动化纳入统一目录和度量体系。",{"type":185,"tag":217,"props":825,"children":826},{},[827],{"type":191,"value":828},"最终目标是：使「AI 胶水」升级为「受控的智能编排能力」，而不是四处分散的脚本和工作流。",{"type":185,"tag":362,"props":830,"children":831},{},[],{"type":185,"tag":267,"props":833,"children":835},{"id":834},"五系统性影响架构工程效率与技术栈治理",[836],{"type":191,"value":837},"五、系统性影响：架构、工程效率与技术栈治理",{"type":185,"tag":274,"props":839,"children":841},{"id":840},"_51-架构视角集成层被旁路领域边界被稀释",[842],{"type":191,"value":843},"5.1 架构视角：集成层被旁路、领域边界被稀释",{"type":185,"tag":194,"props":845,"children":846},{},[847],{"type":191,"value":848},"放任 AI-accelerated Shadow IT 发展，可能带来的架构层影响包括：",{"type":185,"tag":213,"props":850,"children":851},{},[852,870],{"type":185,"tag":217,"props":853,"children":854},{},[855,857],{"type":191,"value":856},"集成层被旁路：\n",{"type":185,"tag":213,"props":858,"children":859},{},[860,865],{"type":185,"tag":217,"props":861,"children":862},{},[863],{"type":191,"value":864},"原本通过 ESB/API Gateway/中台服务完成的集成，被各种直接 API 调用取代；",{"type":185,"tag":217,"props":866,"children":867},{},[868],{"type":191,"value":869},"横切能力（限流、熔断、审计、监控）难以统一施加。",{"type":185,"tag":217,"props":871,"children":872},{},[873,875],{"type":191,"value":874},"领域边界模糊：\n",{"type":185,"tag":213,"props":876,"children":877},{},[878,883],{"type":185,"tag":217,"props":879,"children":880},{},[881],{"type":191,"value":882},"业务规则在 LLM prompt 和工作流里散落一地；",{"type":185,"tag":217,"props":884,"children":885},{},[886],{"type":191,"value":887},"领域模型无法沉淀到共享代码和服务中，领域知识变成「prompt 资产」。",{"type":185,"tag":274,"props":889,"children":891},{"id":890},"_52-工程效率与质量文化短期提效-vs-长期债务",[892],{"type":191,"value":893},"5.2 工程效率与质量文化：短期提效 vs 长期债务",{"type":185,"tag":194,"props":895,"children":896},{},[897],{"type":191,"value":898},"短期看：",{"type":185,"tag":213,"props":900,"children":901},{},[902,907],{"type":185,"tag":217,"props":903,"children":904},{},[905],{"type":191,"value":906},"业务痛点能快速得到缓解，减少对开发团队的小需求骚扰；",{"type":185,"tag":217,"props":908,"children":909},{},[910],{"type":191,"value":911},"一线同事对「技术可达成之事」的感知被放大，促进创新尝试。",{"type":185,"tag":194,"props":913,"children":914},{},[915],{"type":191,"value":916},"长期看：",{"type":185,"tag":213,"props":918,"children":919},{},[920,938],{"type":185,"tag":217,"props":921,"children":922},{},[923,925],{"type":191,"value":924},"维护责任模糊：\n",{"type":185,"tag":213,"props":926,"children":927},{},[928,933],{"type":185,"tag":217,"props":929,"children":930},{},[931],{"type":191,"value":932},"这些自动化出了问题，通常没有明确的 owner 或 SLO/SLA；",{"type":185,"tag":217,"props":934,"children":935},{},[936],{"type":191,"value":937},"影响生产后，IT 团队需要兜底，却未参与设计。",{"type":185,"tag":217,"props":939,"children":940},{},[941,943],{"type":191,"value":942},"质量与测试文化被边缘化：\n",{"type":185,"tag":213,"props":944,"children":945},{},[946,951],{"type":185,"tag":217,"props":947,"children":948},{},[949],{"type":191,"value":950},"很多影子流程没有系统化测试，只依赖「试了几次能跑」；",{"type":185,"tag":217,"props":952,"children":953},{},[954],{"type":191,"value":955},"一旦业务复杂度上升，缺乏回归测试框架，问题成指数级积累。",{"type":185,"tag":274,"props":957,"children":959},{"id":958},"_53-安全与合规从技术问题变成治理议题",[960],{"type":191,"value":961},"5.3 安全与合规：从「技术问题」变成「治理议题」",{"type":185,"tag":194,"props":963,"children":964},{},[965],{"type":191,"value":966},"在安全与合规层面，这更像是一个组织治理问题：",{"type":185,"tag":213,"props":968,"children":969},{},[970,975],{"type":185,"tag":217,"props":971,"children":972},{},[973],{"type":191,"value":974},"如果没有统一的政策和技术护栏，安全团队会始终处于被动排雷状态；",{"type":185,"tag":217,"props":976,"children":977},{},[978,980],{"type":191,"value":979},"相反，如果能在平台和规范层做前置设计：\n",{"type":185,"tag":213,"props":981,"children":982},{},[983,988,993],{"type":185,"tag":217,"props":984,"children":985},{},[986],{"type":191,"value":987},"对哪些数据可以流入外部模型、以什么方式流入给出清晰规则；",{"type":185,"tag":217,"props":989,"children":990},{},[991],{"type":191,"value":992},"对谁可以创建/发布工作流、怎样审批和审计设置统一机制；",{"type":185,"tag":217,"props":994,"children":995},{},[996],{"type":191,"value":997},"对平台本身进行集中加固和监控，就可以把风险集中管理。",{"type":185,"tag":362,"props":999,"children":1000},{},[],{"type":185,"tag":267,"props":1002,"children":1004},{"id":1003},"六落地建议在快与稳之间找到平衡",[1005],{"type":191,"value":1006},"六、落地建议：在「快」与「稳」之间找到平衡",{"type":185,"tag":274,"props":1008,"children":1010},{"id":1009},"_61-识别与分层先搞清楚哪些属于不可接受的影子-it",[1011],{"type":191,"value":1012},"6.1 识别与分层：先搞清楚哪些属于「不可接受的影子 IT」",{"type":185,"tag":194,"props":1014,"children":1015},{},[1016],{"type":191,"value":1017},"建议组织先做一轮分类与盘点：",{"type":185,"tag":213,"props":1019,"children":1020},{},[1021,1044,1057],{"type":185,"tag":217,"props":1022,"children":1023},{},[1024,1026],{"type":191,"value":1025},"明确「禁区」：\n",{"type":185,"tag":213,"props":1027,"children":1028},{},[1029,1034,1039],{"type":185,"tag":217,"props":1030,"children":1031},{},[1032],{"type":191,"value":1033},"涉及核心财务、监管强约束数据的流程和系统；",{"type":185,"tag":217,"props":1035,"children":1036},{},[1037],{"type":191,"value":1038},"涉及高敏感个人数据、商业机密的数据流动；",{"type":185,"tag":217,"props":1040,"children":1041},{},[1042],{"type":191,"value":1043},"这些场景禁止自发构建 AI+无代码集成，只能走正式技术路径。",{"type":185,"tag":217,"props":1045,"children":1046},{},[1047,1049],{"type":191,"value":1048},"区分「灰度区」：\n",{"type":185,"tag":213,"props":1050,"children":1051},{},[1052],{"type":185,"tag":217,"props":1053,"children":1054},{},[1055],{"type":191,"value":1056},"如内部协作流程优化、低风险报表生成等，可以在受控平台内试点；",{"type":185,"tag":217,"props":1058,"children":1059},{},[1060,1062],{"type":191,"value":1061},"对「安全区」：\n",{"type":185,"tag":213,"props":1063,"children":1064},{},[1065],{"type":185,"tag":217,"props":1066,"children":1067},{},[1068],{"type":191,"value":1069},"如纯信息聚合、低风险查询类工具，可以给予相对宽松的试验空间。",{"type":185,"tag":274,"props":1071,"children":1073},{"id":1072},"_62-提供正规渠道建设企业级的-ai-编排能力",[1074],{"type":191,"value":1075},"6.2 提供「正规渠道」：建设企业级的 AI 编排能力",{"type":185,"tag":194,"props":1077,"children":1078},{},[1079],{"type":191,"value":1080},"如果只压制不供给，影子 IT 很难真正减少。更可行的做法是：",{"type":185,"tag":213,"props":1082,"children":1083},{},[1084,1107],{"type":185,"tag":217,"props":1085,"children":1086},{},[1087,1089],{"type":191,"value":1088},"搭建统一的自动化/集成平台，内置：\n",{"type":185,"tag":213,"props":1090,"children":1091},{},[1092,1097,1102],{"type":185,"tag":217,"props":1093,"children":1094},{},[1095],{"type":191,"value":1096},"统一身份和权限管理；",{"type":185,"tag":217,"props":1098,"children":1099},{},[1100],{"type":191,"value":1101},"标准化的系统连接器和数据访问策略；",{"type":185,"tag":217,"props":1103,"children":1104},{},[1105],{"type":191,"value":1106},"可被审计的审批流和发布流程。",{"type":185,"tag":217,"props":1108,"children":1109},{},[1110,1112],{"type":191,"value":1111},"在该平台上以「产品化方式」提供 AI 能力：\n",{"type":185,"tag":213,"props":1113,"children":1114},{},[1115,1120],{"type":185,"tag":217,"props":1116,"children":1117},{},[1118],{"type":191,"value":1119},"预设若干「安全的 Prompt/Agent 模板」；",{"type":185,"tag":217,"props":1121,"children":1122},{},[1123],{"type":191,"value":1124},"为业务提供经评审的工作流模板库，支持复制和轻量定制。",{"type":185,"tag":194,"props":1126,"children":1127},{},[1128],{"type":191,"value":1129},"这样可以兼顾：",{"type":185,"tag":213,"props":1131,"children":1132},{},[1133,1138],{"type":185,"tag":217,"props":1134,"children":1135},{},[1136],{"type":191,"value":1137},"业务的敏捷和自助构建能力；",{"type":185,"tag":217,"props":1139,"children":1140},{},[1141],{"type":191,"value":1142},"IT 的可见性、安全与治理诉求。",{"type":185,"tag":274,"props":1144,"children":1146},{"id":1145},"_63-治理与运营把影子创新纳入可观测的实验",[1147],{"type":191,"value":1148},"6.3 治理与运营：把影子创新纳入「可观测的实验」",{"type":185,"tag":194,"props":1150,"children":1151},{},[1152],{"type":191,"value":1153},"为了在不扼杀创新的前提下降低风险，可以考虑：",{"type":185,"tag":213,"props":1155,"children":1156},{},[1157,1175,1193],{"type":185,"tag":217,"props":1158,"children":1159},{},[1160,1162],{"type":191,"value":1161},"建立「实验登记」机制：\n",{"type":185,"tag":213,"props":1163,"children":1164},{},[1165,1170],{"type":185,"tag":217,"props":1166,"children":1167},{},[1168],{"type":191,"value":1169},"所有新建的 AI 自动化、agent、工作流都需要登记基本元数据（owner、数据范围、涉及系统、预期影响）；",{"type":185,"tag":217,"props":1171,"children":1172},{},[1173],{"type":191,"value":1174},"重要流程需要简化版的风险评审。",{"type":185,"tag":217,"props":1176,"children":1177},{},[1178,1180],{"type":191,"value":1179},"强制基本观测能力：\n",{"type":185,"tag":213,"props":1181,"children":1182},{},[1183,1188],{"type":185,"tag":217,"props":1184,"children":1185},{},[1186],{"type":191,"value":1187},"统一采集运行日志、错误率、调用量等；",{"type":185,"tag":217,"props":1189,"children":1190},{},[1191],{"type":191,"value":1192},"在异常频发或影响面的流程上设置阈值和告警。",{"type":185,"tag":217,"props":1194,"children":1195},{},[1196,1198],{"type":191,"value":1197},"定期「体检和收敛」：\n",{"type":185,"tag":213,"props":1199,"children":1200},{},[1201,1206],{"type":185,"tag":217,"props":1202,"children":1203},{},[1204],{"type":191,"value":1205},"定期审查自动化目录，识别冗余、风险高、价值低的流程并退役；",{"type":185,"tag":217,"props":1207,"children":1208},{},[1209],{"type":191,"value":1210},"把运行稳定、影响大的影子流程纳入正式产品/平台演进路线。",{"type":185,"tag":274,"props":1212,"children":1214},{"id":1213},"_64-小结对于技术负责人可以考虑的几条实操路线",[1215],{"type":191,"value":1216},"6.4 小结：对于技术负责人可以考虑的几条实操路线",{"type":185,"tag":194,"props":1218,"children":1219},{},[1220],{"type":191,"value":1221},"结合上述分析，对架构师和技术负责人，可以概括为几条可执行方向：",{"type":185,"tag":213,"props":1223,"children":1224},{},[1225,1230,1235,1240],{"type":185,"tag":217,"props":1226,"children":1227},{},[1228],{"type":191,"value":1229},"不否认 AI-accelerated Shadow IT 的存在和价值，而是主动识别和分层管理；",{"type":185,"tag":217,"props":1231,"children":1232},{},[1233],{"type":191,"value":1234},"投资一个企业级、可观测的 AI 编排/自动化平台，作为业务自助构建的「唯一正门」；",{"type":185,"tag":217,"props":1236,"children":1237},{},[1238],{"type":191,"value":1239},"在平台层提供安全边界、连接器、Prompt/Agent 模板，而不是把这些责任下放给业务团队；",{"type":185,"tag":217,"props":1241,"children":1242},{},[1243],{"type":191,"value":1244},"通过治理机制（登记、审批、监控、定期体检）把「影子创新」转变为「可控实验」，在快速试错和长期稳定之间找到合理平衡。",{"title":178,"searchDepth":608,"depth":608,"links":1246},[1247,1248],{"id":188,"depth":608,"text":192},{"id":262,"depth":608,"text":265,"children":1249},[1250,1251,1252,1253,1254,1255],{"id":269,"depth":630,"text":272},{"id":367,"depth":630,"text":370},{"id":569,"depth":630,"text":572},{"id":728,"depth":630,"text":731},{"id":834,"depth":630,"text":837},{"id":1003,"depth":630,"text":1006},"markdown","content:6.maps:_management:shadow-it:ai-accelerated-shadow-it.md","content","6.maps/_management/shadow-it/ai-accelerated-shadow-it.md","6.maps/_management/shadow-it/ai-accelerated-shadow-it","md",[1263,1267],{"_path":1264,"title":1265,"description":1266},"/maps/_management/organization","组织","团队组织架构、管理方法、沟通方式等。",{"_path":1268,"title":1269,"description":1270},"/maps/_management/shape-up","Shape Up","适合中小团队的一种工作方式。",1771695807228]