,"💫 CSS 幻术 | 抗锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"original_path":181,"body":182,"_type":1257,"_id":1258,"_source":1259,"_file":1260,"_stem":1261,"_extension":1262},"/maps/_management/shadow-it/ai-accelerated-shadow-it","shadow-it",false,true,"","AI 加速的影子 IT","讨论生成式 AI 和无代码平台如何催生新一轮影子 IT 现象，其风险与治理建议。","content/6.maps/_management/shadow-it/ai-accelerated-shadow-it.md",{"type":183,"children":184,"toc":1246},"root",[185,194,208,213,261,267,274,281,312,318,362,366,372,378,383,401,406,429,435,440,497,503,508,565,568,574,580,585,594,607,616,629,638,651,657,662,711,716,724,727,733,739,744,788,794,799,830,833,839,845,850,889,895,900,913,918,957,963,968,999,1002,1008,1014,1019,1071,1077,1082,1126,1131,1144,1150,1155,1212,1218,1223],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"brief",[191],{"type":192,"value":193},"text","Brief",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198,200,206],{"type":192,"value":199},"这段文本讨论的是「AI 加速的影子 IT」，目前在技术雷达中的状态是 ",{"type":186,"tag":201,"props":202,"children":203},"em",{},[204],{"type":192,"value":205},"Hold",{"type":192,"value":207},"（保持警惕/慎用）。",{"type":186,"tag":195,"props":209,"children":210},{},[211],{"type":192,"value":212},"核心观点：",{"type":186,"tag":214,"props":215,"children":216},"ul",{},[217,223,228,233,238,256],{"type":186,"tag":218,"props":219,"children":220},"li",{},[221],{"type":192,"value":222},"生成式 AI + 无代码平台正在大幅降低「非工程师自己搭东西」的门槛。",{"type":186,"tag":218,"props":224,"children":225},{},[226],{"type":192,"value":227},"无代码工作流平台已经支持直接集成 OpenAI、Anthropic 等 AI API；AI coding assistant 也越来越“像代理”，让只受过基础培训的非开发人员可以拼出内部工具和集成。",{"type":186,"tag":218,"props":229,"children":230},{},[231],{"type":192,"value":232},"这些组合，很容易被当成「AI 胶水」：通过 LLM 把本来难以打通的系统粘在一起，比如把某个聊天系统里的消息转成 ERP 的 API 调用。",{"type":186,"tag":218,"props":234,"children":235},{},[236],{"type":192,"value":237},"这轮趋势和当年「用 Excel/表格驱动关键业务流程」非常像，但潜在影响面更大。",{"type":186,"tag":218,"props":239,"children":240},{},[241,243],{"type":192,"value":242},"如果缺乏治理，新一轮影子 IT 会导致：\n",{"type":186,"tag":214,"props":244,"children":245},{},[246,251],{"type":186,"tag":218,"props":247,"children":248},{},[249],{"type":192,"value":250},"大量未受管控、可能不安全的小应用和自动化；",{"type":186,"tag":218,"props":252,"children":253},{},[254],{"type":192,"value":255},"数据在更多系统之间被复制和散落，进一步加剧数据治理难度。",{"type":186,"tag":218,"props":257,"children":258},{},[259],{"type":192,"value":260},"建议组织对这种趋势保持警惕：在「快速解决问题」与「长期稳定和可治理性」之间做清醒的权衡，而不是一味追求短期提效。",{"type":186,"tag":187,"props":262,"children":264},{"id":263},"details",[265],{"type":192,"value":266},"Details",{"type":186,"tag":268,"props":269,"children":271},"h3",{"id":270},"一背景与现状从表格驱动业务到ai-胶水应用",[272],{"type":192,"value":273},"一、背景与现状：从「表格驱动业务」到「AI 胶水应用」",{"type":186,"tag":275,"props":276,"children":278},"h4",{"id":277},"_11-业务压力it-供给长期不足影子-it-有天然土壤",[279],{"type":192,"value":280},"1.1 业务压力：IT 供给长期不足，影子 IT 有天然土壤",{"type":186,"tag":214,"props":282,"children":283},{},[284,289,307],{"type":186,"tag":218,"props":285,"children":286},{},[287],{"type":192,"value":288},"在大多数中大型组织里，业务团队对数字化的需求远超 IT 部门的交付能力：小需求排不上优先级、大需求项目周期长。",{"type":186,"tag":218,"props":290,"children":291},{},[292,294],{"type":192,"value":293},"历史上的典型应对方式就是「自己搞」：\n",{"type":186,"tag":214,"props":295,"children":296},{},[297,302],{"type":186,"tag":218,"props":298,"children":299},{},[300],{"type":192,"value":301},"用 Excel/Sheets + VBA/脚本支撑关键流程；",{"type":186,"tag":218,"props":303,"children":304},{},[305],{"type":192,"value":306},"用低代码、RPA、iPaaS 拼出业务自动化。",{"type":186,"tag":218,"props":308,"children":309},{},[310],{"type":192,"value":311},"现在，生成式 AI 和无代码平台进一步降低了门槛，非技术人员可以用自然语言驱动自动化和集成，影子 IT 的形态因此发生质变。",{"type":186,"tag":275,"props":313,"children":315},{"id":314},"_12-工具有了ai-增压集成更简单能力边界被推高",[316],{"type":192,"value":317},"1.2 工具有了「AI 增压」：集成更简单，能力边界被推高",{"type":186,"tag":214,"props":319,"children":320},{},[321,339,357],{"type":186,"tag":218,"props":322,"children":323},{},[324,326],{"type":192,"value":325},"无代码工作流平台开始原生支持 AI API（OpenAI、Anthropic 等），让业务用户可以：\n",{"type":186,"tag":214,"props":327,"children":328},{},[329,334],{"type":186,"tag":218,"props":330,"children":331},{},[332],{"type":192,"value":333},"在拖拽式流程里插入 LLM 步骤，实现解析、决策、路由；",{"type":186,"tag":218,"props":335,"children":336},{},[337],{"type":192,"value":338},"用自然语言生成数据转换、规则和小片段逻辑。",{"type":186,"tag":218,"props":340,"children":341},{},[342,344],{"type":192,"value":343},"同时，更「agent-like」的 AI coding assistant 让具备基本技术素养的非工程师也可以：\n",{"type":186,"tag":214,"props":345,"children":346},{},[347,352],{"type":186,"tag":218,"props":348,"children":349},{},[350],{"type":192,"value":351},"生成简单的 Web 工具、后台小页面；",{"type":186,"tag":218,"props":353,"children":354},{},[355],{"type":192,"value":356},"操作数据库和内部 API，做数据拉通和页面拼装。",{"type":186,"tag":218,"props":358,"children":359},{},[360],{"type":192,"value":361},"结果是：大量「原本不可能、或者成本太高的集成」突然变得可行，而且不需要走正式 IT 流程。",{"type":186,"tag":363,"props":364,"children":365},"hr",{},[],{"type":186,"tag":268,"props":367,"children":369},{"id":368},"二问题与风险新一轮影子-it-的结构性矛盾",[370],{"type":192,"value":371},"二、问题与风险：新一轮影子 IT 的结构性矛盾",{"type":186,"tag":275,"props":373,"children":375},{"id":374},"_21-ai-胶水的诱惑只看见快不看见结构成本",[376],{"type":192,"value":377},"2.1 「AI 胶水」的诱惑：只看见快，不看见结构成本",{"type":186,"tag":195,"props":379,"children":380},{},[381],{"type":192,"value":382},"常见模式是：",{"type":186,"tag":214,"props":384,"children":385},{},[386,391,396],{"type":186,"tag":218,"props":387,"children":388},{},[389],{"type":192,"value":390},"在某个聊天系统里监听消息；",{"type":186,"tag":218,"props":392,"children":393},{},[394],{"type":192,"value":395},"用 LLM 解析语义、提取字段、做判断；",{"type":186,"tag":218,"props":397,"children":398},{},[399],{"type":192,"value":400},"然后在另一个系统（如 ERP）发起 API 调用。",{"type":186,"tag":195,"props":402,"children":403},{},[404],{"type":192,"value":405},"对于业务：",{"type":186,"tag":214,"props":407,"children":408},{},[409,414,419,424],{"type":186,"tag":218,"props":410,"children":411},{},[412],{"type":192,"value":413},"这是极具吸引力的「局部最优解」：不用排 IT 需求、上线快、显性成本低。\n但在架构层面，往往引入这些长期矛盾：",{"type":186,"tag":218,"props":415,"children":416},{},[417],{"type":192,"value":418},"业务规则散落在多个 LLM prompt、工作流节点和临时脚本中，缺乏统一抽象；",{"type":186,"tag":218,"props":420,"children":421},{},[422],{"type":192,"value":423},"集成路径绕开既有集成层/服务层，形成「旁路」，后续难以观测和治理；",{"type":186,"tag":218,"props":425,"children":426},{},[427],{"type":192,"value":428},"安全模型和访问控制往往只是平台默认值，很难符合企业级要求。",{"type":186,"tag":275,"props":430,"children":432},{"id":431},"_22-比表格更危险的地方规模化和不可见性",[433],{"type":192,"value":434},"2.2 「比表格更危险」的地方：规模化和不可见性",{"type":186,"tag":195,"props":436,"children":437},{},[438],{"type":192,"value":439},"与传统「Excel 影子系统」相比，AI 加速的影子 IT 有几类放大因素：",{"type":186,"tag":214,"props":441,"children":442},{},[443,461,479],{"type":186,"tag":218,"props":444,"children":445},{},[446,448],{"type":192,"value":447},"覆盖范围更广：\n",{"type":186,"tag":214,"props":449,"children":450},{},[451,456],{"type":186,"tag":218,"props":452,"children":453},{},[454],{"type":192,"value":455},"不仅限于单人/小组操作，还可以通过机器人账号、Webhooks 等触达更多系统；",{"type":186,"tag":218,"props":457,"children":458},{},[459],{"type":192,"value":460},"许多自动化可以 7×24 运行，对生产系统产生持续影响。",{"type":186,"tag":218,"props":462,"children":463},{},[464,466],{"type":192,"value":465},"逻辑更难审计：\n",{"type":186,"tag":214,"props":467,"children":468},{},[469,474],{"type":186,"tag":218,"props":470,"children":471},{},[472],{"type":192,"value":473},"LLM 的行为受 prompt、模型版本、上下文等多因素影响；",{"type":186,"tag":218,"props":475,"children":476},{},[477],{"type":192,"value":478},"很多业务决策隐含在自然语言提示和微妙的示例里，传统 code review 不再适用。",{"type":186,"tag":218,"props":480,"children":481},{},[482,484],{"type":192,"value":483},"复用性和扩散更快：\n",{"type":186,"tag":214,"props":485,"children":486},{},[487,492],{"type":186,"tag":218,"props":488,"children":489},{},[490],{"type":192,"value":491},"复制一个工作流模板、fork 一个 AI agent，成本极低；",{"type":186,"tag":218,"props":493,"children":494},{},[495],{"type":192,"value":496},"组织内部会很快出现多个类似却略有差异的流程版本，难以追踪。",{"type":186,"tag":275,"props":498,"children":500},{"id":499},"_23-数据安全与合规多系统复制与权限外溢",[501],{"type":192,"value":502},"2.3 数据安全与合规：多系统复制与权限外溢",{"type":186,"tag":195,"props":504,"children":505},{},[506],{"type":192,"value":507},"影子 IT 模式下，常见风险包括：",{"type":186,"tag":214,"props":509,"children":510},{},[511,529,547],{"type":186,"tag":218,"props":512,"children":513},{},[514,516],{"type":192,"value":515},"数据多点复制：\n",{"type":186,"tag":214,"props":517,"children":518},{},[519,524],{"type":186,"tag":218,"props":520,"children":521},{},[522],{"type":192,"value":523},"原本集中在核心系统里的数据被同步到各种「临时自动化」「小工具」中；",{"type":186,"tag":218,"props":525,"children":526},{},[527],{"type":192,"value":528},"缺乏统一的生命周期管理，删除/脱敏无法覆盖所有副本。",{"type":186,"tag":218,"props":530,"children":531},{},[532,534],{"type":192,"value":533},"权限与审计断层：\n",{"type":186,"tag":214,"props":535,"children":536},{},[537,542],{"type":186,"tag":218,"props":538,"children":539},{},[540],{"type":192,"value":541},"使用个人/共享账号调用关键系统 API；",{"type":186,"tag":218,"props":543,"children":544},{},[545],{"type":192,"value":546},"审计日志停留在无代码平台，而不是企业 SIEM/审计系统。",{"type":186,"tag":218,"props":548,"children":549},{},[550,552],{"type":192,"value":551},"模型调用合规性：\n",{"type":186,"tag":214,"props":553,"children":554},{},[555,560],{"type":186,"tag":218,"props":556,"children":557},{},[558],{"type":192,"value":559},"不同场景下，是否允许将数据发往外部模型服务、采用什么脱敏策略，往往没有统一约束；",{"type":186,"tag":218,"props":561,"children":562},{},[563],{"type":192,"value":564},"业务自发集成 AI API 容易绕过这些统一规范。",{"type":186,"tag":363,"props":566,"children":567},{},[],{"type":186,"tag":268,"props":569,"children":571},{"id":570},"三模式与原理ai-accelerated-shadow-it-的典型形态",[572],{"type":192,"value":573},"三、模式与原理：AI-accelerated Shadow IT 的典型形态",{"type":186,"tag":275,"props":575,"children":577},{"id":576},"_31-三类高频形态自动化集成中台替身",[578],{"type":192,"value":579},"3.1 三类高频形态：自动化、集成、中台替身",{"type":186,"tag":195,"props":581,"children":582},{},[583],{"type":192,"value":584},"在实践中，AI 加速影子 IT 多表现为三大类：",{"type":186,"tag":586,"props":587,"children":588},"ol",{},[589],{"type":186,"tag":218,"props":590,"children":591},{},[592],{"type":192,"value":593},"自动化机器人",{"type":186,"tag":214,"props":595,"children":596},{},[597,602],{"type":186,"tag":218,"props":598,"children":599},{},[600],{"type":192,"value":601},"以「if X then Y」为骨架，插入 LLM 作为解析/判断模块。",{"type":186,"tag":218,"props":603,"children":604},{},[605],{"type":192,"value":606},"例如：解析邮件、工单、聊天内容，自动创建任务、工单或业务对象。",{"type":186,"tag":586,"props":608,"children":610},{"start":609},2,[611],{"type":186,"tag":218,"props":612,"children":613},{},[614],{"type":192,"value":615},"集成胶水",{"type":186,"tag":214,"props":617,"children":618},{},[619,624],{"type":186,"tag":218,"props":620,"children":621},{},[622],{"type":192,"value":623},"连接两个原本无直接集成的系统，用 LLM 做协议转换和字段映射。",{"type":186,"tag":218,"props":625,"children":626},{},[627],{"type":192,"value":628},"例如：把自然语言描述转为 ERP/CRM 的结构化 API 请求。",{"type":186,"tag":586,"props":630,"children":632},{"start":631},3,[633],{"type":186,"tag":218,"props":634,"children":635},{},[636],{"type":192,"value":637},"轻量 pseudo-中台",{"type":186,"tag":214,"props":639,"children":640},{},[641,646],{"type":186,"tag":218,"props":642,"children":643},{},[644],{"type":192,"value":645},"基于无代码/低代码 + LLM，快速搭一个「内部工具」集中处理某类业务。",{"type":186,"tag":218,"props":647,"children":648},{},[649],{"type":192,"value":650},"实际上承担了一部分中台职能，却没有纳入中台的标准、治理和演进路线。",{"type":186,"tag":275,"props":652,"children":654},{"id":653},"_32-关键技术构件平台llm连接器",[655],{"type":192,"value":656},"3.2 关键技术构件：平台、LLM、连接器",{"type":186,"tag":195,"props":658,"children":659},{},[660],{"type":192,"value":661},"在技术视角下，这类影子 IT 大致由三层构成：",{"type":186,"tag":214,"props":663,"children":664},{},[665,670,693],{"type":186,"tag":218,"props":666,"children":667},{},[668],{"type":192,"value":669},"编排层：无代码/低代码工作流平台、RPA 平台、轻量集成平台；",{"type":186,"tag":218,"props":671,"children":672},{},[673,675],{"type":192,"value":674},"智能层：一个或多个 LLM/agent，用于：\n",{"type":186,"tag":214,"props":676,"children":677},{},[678,683,688],{"type":186,"tag":218,"props":679,"children":680},{},[681],{"type":192,"value":682},"解析自然语言输入；",{"type":186,"tag":218,"props":684,"children":685},{},[686],{"type":192,"value":687},"做简单决策、路由和字段映射；",{"type":186,"tag":218,"props":689,"children":690},{},[691],{"type":192,"value":692},"根据模板生成 API 调用参数或系统指令。",{"type":186,"tag":218,"props":694,"children":695},{},[696,698],{"type":192,"value":697},"连接层：\n",{"type":186,"tag":214,"props":699,"children":700},{},[701,706],{"type":186,"tag":218,"props":702,"children":703},{},[704],{"type":192,"value":705},"预置或自定义连接器（Webhook、REST、DB 连接等）；",{"type":186,"tag":218,"props":707,"children":708},{},[709],{"type":192,"value":710},"各种凭证和密钥配置。",{"type":186,"tag":195,"props":712,"children":713},{},[714],{"type":192,"value":715},"治理难点在于：",{"type":186,"tag":214,"props":717,"children":718},{},[719],{"type":186,"tag":218,"props":720,"children":721},{},[722],{"type":192,"value":723},"这三层通常由业务人员在「自己的空间」拼装起来，IT 部门只看到结果（有请求打到系统），看不到中间逻辑。",{"type":186,"tag":363,"props":725,"children":726},{},[],{"type":186,"tag":268,"props":728,"children":730},{"id":729},"四对比与演进从禁止到引导的策略选择",[731],{"type":192,"value":732},"四、对比与演进：从「禁止」到「引导」的策略选择",{"type":186,"tag":275,"props":734,"children":736},{"id":735},"_41-传统影子-it-的教训一刀切禁用常常失败",[737],{"type":192,"value":738},"4.1 传统影子 IT 的教训：一刀切禁用常常失败",{"type":186,"tag":195,"props":740,"children":741},{},[742],{"type":192,"value":743},"历史经验表明：",{"type":186,"tag":214,"props":745,"children":746},{},[747,765],{"type":186,"tag":218,"props":748,"children":749},{},[750,752],{"type":192,"value":751},"简单粗暴地「禁止使用」往往只会把问题推入地下渠道：\n",{"type":186,"tag":214,"props":753,"children":754},{},[755,760],{"type":186,"tag":218,"props":756,"children":757},{},[758],{"type":192,"value":759},"业务依然会在个人账号、个人云盘、第三方 SaaS 上构建自己的系统；",{"type":186,"tag":218,"props":761,"children":762},{},[763],{"type":192,"value":764},"IT 部门失去可见性，风险反而变大。",{"type":186,"tag":218,"props":766,"children":767},{},[768,770],{"type":192,"value":769},"比较可持续的做法往往是：\n",{"type":186,"tag":214,"props":771,"children":772},{},[773,778,783],{"type":186,"tag":218,"props":774,"children":775},{},[776],{"type":192,"value":777},"明确红线（哪些业务数据/场景严禁影子实现）；",{"type":186,"tag":218,"props":779,"children":780},{},[781],{"type":192,"value":782},"提供「安全可用的正规替代选项」（标准平台、组件、工作流模板）；",{"type":186,"tag":218,"props":784,"children":785},{},[786],{"type":192,"value":787},"通过平台化和规范化来「收编」影子创新。",{"type":186,"tag":275,"props":789,"children":791},{"id":790},"_42-ai-时代的演进从ai-胶水走向受控的智能编排",[792],{"type":192,"value":793},"4.2 AI 时代的演进：从「AI 胶水」走向「受控的智能编排」",{"type":186,"tag":195,"props":795,"children":796},{},[797],{"type":192,"value":798},"一个更现实的演进路径通常包括：",{"type":186,"tag":214,"props":800,"children":801},{},[802,807,825],{"type":186,"tag":218,"props":803,"children":804},{},[805],{"type":192,"value":806},"先承认：AI+无代码在边缘流程、小团队创新上的价值；",{"type":186,"tag":218,"props":808,"children":809},{},[810,812],{"type":192,"value":811},"再设计：\n",{"type":186,"tag":214,"props":813,"children":814},{},[815,820],{"type":186,"tag":218,"props":816,"children":817},{},[818],{"type":192,"value":819},"在统一平台内提供「受控能力」——标准连接器、预设 Prompt 模板、数据访问边界；",{"type":186,"tag":218,"props":821,"children":822},{},[823],{"type":192,"value":824},"把业务自建的自动化纳入统一目录和度量体系。",{"type":186,"tag":218,"props":826,"children":827},{},[828],{"type":192,"value":829},"最终目标是：使「AI 胶水」升级为「受控的智能编排能力」，而不是四处分散的脚本和工作流。",{"type":186,"tag":363,"props":831,"children":832},{},[],{"type":186,"tag":268,"props":834,"children":836},{"id":835},"五系统性影响架构工程效率与技术栈治理",[837],{"type":192,"value":838},"五、系统性影响：架构、工程效率与技术栈治理",{"type":186,"tag":275,"props":840,"children":842},{"id":841},"_51-架构视角集成层被旁路领域边界被稀释",[843],{"type":192,"value":844},"5.1 架构视角：集成层被旁路、领域边界被稀释",{"type":186,"tag":195,"props":846,"children":847},{},[848],{"type":192,"value":849},"放任 AI-accelerated Shadow IT 发展，可能带来的架构层影响包括：",{"type":186,"tag":214,"props":851,"children":852},{},[853,871],{"type":186,"tag":218,"props":854,"children":855},{},[856,858],{"type":192,"value":857},"集成层被旁路：\n",{"type":186,"tag":214,"props":859,"children":860},{},[861,866],{"type":186,"tag":218,"props":862,"children":863},{},[864],{"type":192,"value":865},"原本通过 ESB/API Gateway/中台服务完成的集成，被各种直接 API 调用取代；",{"type":186,"tag":218,"props":867,"children":868},{},[869],{"type":192,"value":870},"横切能力（限流、熔断、审计、监控）难以统一施加。",{"type":186,"tag":218,"props":872,"children":873},{},[874,876],{"type":192,"value":875},"领域边界模糊：\n",{"type":186,"tag":214,"props":877,"children":878},{},[879,884],{"type":186,"tag":218,"props":880,"children":881},{},[882],{"type":192,"value":883},"业务规则在 LLM prompt 和工作流里散落一地；",{"type":186,"tag":218,"props":885,"children":886},{},[887],{"type":192,"value":888},"领域模型无法沉淀到共享代码和服务中，领域知识变成「prompt 资产」。",{"type":186,"tag":275,"props":890,"children":892},{"id":891},"_52-工程效率与质量文化短期提效-vs-长期债务",[893],{"type":192,"value":894},"5.2 工程效率与质量文化：短期提效 vs 长期债务",{"type":186,"tag":195,"props":896,"children":897},{},[898],{"type":192,"value":899},"短期看：",{"type":186,"tag":214,"props":901,"children":902},{},[903,908],{"type":186,"tag":218,"props":904,"children":905},{},[906],{"type":192,"value":907},"业务痛点能快速得到缓解，减少对开发团队的小需求骚扰；",{"type":186,"tag":218,"props":909,"children":910},{},[911],{"type":192,"value":912},"一线同事对「技术可达成之事」的感知被放大，促进创新尝试。",{"type":186,"tag":195,"props":914,"children":915},{},[916],{"type":192,"value":917},"长期看：",{"type":186,"tag":214,"props":919,"children":920},{},[921,939],{"type":186,"tag":218,"props":922,"children":923},{},[924,926],{"type":192,"value":925},"维护责任模糊：\n",{"type":186,"tag":214,"props":927,"children":928},{},[929,934],{"type":186,"tag":218,"props":930,"children":931},{},[932],{"type":192,"value":933},"这些自动化出了问题，通常没有明确的 owner 或 SLO/SLA；",{"type":186,"tag":218,"props":935,"children":936},{},[937],{"type":192,"value":938},"影响生产后，IT 团队需要兜底，却未参与设计。",{"type":186,"tag":218,"props":940,"children":941},{},[942,944],{"type":192,"value":943},"质量与测试文化被边缘化：\n",{"type":186,"tag":214,"props":945,"children":946},{},[947,952],{"type":186,"tag":218,"props":948,"children":949},{},[950],{"type":192,"value":951},"很多影子流程没有系统化测试，只依赖「试了几次能跑」；",{"type":186,"tag":218,"props":953,"children":954},{},[955],{"type":192,"value":956},"一旦业务复杂度上升，缺乏回归测试框架，问题成指数级积累。",{"type":186,"tag":275,"props":958,"children":960},{"id":959},"_53-安全与合规从技术问题变成治理议题",[961],{"type":192,"value":962},"5.3 安全与合规：从「技术问题」变成「治理议题」",{"type":186,"tag":195,"props":964,"children":965},{},[966],{"type":192,"value":967},"在安全与合规层面，这更像是一个组织治理问题：",{"type":186,"tag":214,"props":969,"children":970},{},[971,976],{"type":186,"tag":218,"props":972,"children":973},{},[974],{"type":192,"value":975},"如果没有统一的政策和技术护栏，安全团队会始终处于被动排雷状态；",{"type":186,"tag":218,"props":977,"children":978},{},[979,981],{"type":192,"value":980},"相反，如果能在平台和规范层做前置设计：\n",{"type":186,"tag":214,"props":982,"children":983},{},[984,989,994],{"type":186,"tag":218,"props":985,"children":986},{},[987],{"type":192,"value":988},"对哪些数据可以流入外部模型、以什么方式流入给出清晰规则；",{"type":186,"tag":218,"props":990,"children":991},{},[992],{"type":192,"value":993},"对谁可以创建/发布工作流、怎样审批和审计设置统一机制；",{"type":186,"tag":218,"props":995,"children":996},{},[997],{"type":192,"value":998},"对平台本身进行集中加固和监控，就可以把风险集中管理。",{"type":186,"tag":363,"props":1000,"children":1001},{},[],{"type":186,"tag":268,"props":1003,"children":1005},{"id":1004},"六落地建议在快与稳之间找到平衡",[1006],{"type":192,"value":1007},"六、落地建议：在「快」与「稳」之间找到平衡",{"type":186,"tag":275,"props":1009,"children":1011},{"id":1010},"_61-识别与分层先搞清楚哪些属于不可接受的影子-it",[1012],{"type":192,"value":1013},"6.1 识别与分层：先搞清楚哪些属于「不可接受的影子 IT」",{"type":186,"tag":195,"props":1015,"children":1016},{},[1017],{"type":192,"value":1018},"建议组织先做一轮分类与盘点：",{"type":186,"tag":214,"props":1020,"children":1021},{},[1022,1045,1058],{"type":186,"tag":218,"props":1023,"children":1024},{},[1025,1027],{"type":192,"value":1026},"明确「禁区」：\n",{"type":186,"tag":214,"props":1028,"children":1029},{},[1030,1035,1040],{"type":186,"tag":218,"props":1031,"children":1032},{},[1033],{"type":192,"value":1034},"涉及核心财务、监管强约束数据的流程和系统；",{"type":186,"tag":218,"props":1036,"children":1037},{},[1038],{"type":192,"value":1039},"涉及高敏感个人数据、商业机密的数据流动；",{"type":186,"tag":218,"props":1041,"children":1042},{},[1043],{"type":192,"value":1044},"这些场景禁止自发构建 AI+无代码集成，只能走正式技术路径。",{"type":186,"tag":218,"props":1046,"children":1047},{},[1048,1050],{"type":192,"value":1049},"区分「灰度区」：\n",{"type":186,"tag":214,"props":1051,"children":1052},{},[1053],{"type":186,"tag":218,"props":1054,"children":1055},{},[1056],{"type":192,"value":1057},"如内部协作流程优化、低风险报表生成等，可以在受控平台内试点；",{"type":186,"tag":218,"props":1059,"children":1060},{},[1061,1063],{"type":192,"value":1062},"对「安全区」：\n",{"type":186,"tag":214,"props":1064,"children":1065},{},[1066],{"type":186,"tag":218,"props":1067,"children":1068},{},[1069],{"type":192,"value":1070},"如纯信息聚合、低风险查询类工具，可以给予相对宽松的试验空间。",{"type":186,"tag":275,"props":1072,"children":1074},{"id":1073},"_62-提供正规渠道建设企业级的-ai-编排能力",[1075],{"type":192,"value":1076},"6.2 提供「正规渠道」：建设企业级的 AI 编排能力",{"type":186,"tag":195,"props":1078,"children":1079},{},[1080],{"type":192,"value":1081},"如果只压制不供给，影子 IT 很难真正减少。更可行的做法是：",{"type":186,"tag":214,"props":1083,"children":1084},{},[1085,1108],{"type":186,"tag":218,"props":1086,"children":1087},{},[1088,1090],{"type":192,"value":1089},"搭建统一的自动化/集成平台，内置：\n",{"type":186,"tag":214,"props":1091,"children":1092},{},[1093,1098,1103],{"type":186,"tag":218,"props":1094,"children":1095},{},[1096],{"type":192,"value":1097},"统一身份和权限管理；",{"type":186,"tag":218,"props":1099,"children":1100},{},[1101],{"type":192,"value":1102},"标准化的系统连接器和数据访问策略；",{"type":186,"tag":218,"props":1104,"children":1105},{},[1106],{"type":192,"value":1107},"可被审计的审批流和发布流程。",{"type":186,"tag":218,"props":1109,"children":1110},{},[1111,1113],{"type":192,"value":1112},"在该平台上以「产品化方式」提供 AI 能力：\n",{"type":186,"tag":214,"props":1114,"children":1115},{},[1116,1121],{"type":186,"tag":218,"props":1117,"children":1118},{},[1119],{"type":192,"value":1120},"预设若干「安全的 Prompt/Agent 模板」；",{"type":186,"tag":218,"props":1122,"children":1123},{},[1124],{"type":192,"value":1125},"为业务提供经评审的工作流模板库，支持复制和轻量定制。",{"type":186,"tag":195,"props":1127,"children":1128},{},[1129],{"type":192,"value":1130},"这样可以兼顾：",{"type":186,"tag":214,"props":1132,"children":1133},{},[1134,1139],{"type":186,"tag":218,"props":1135,"children":1136},{},[1137],{"type":192,"value":1138},"业务的敏捷和自助构建能力；",{"type":186,"tag":218,"props":1140,"children":1141},{},[1142],{"type":192,"value":1143},"IT 的可见性、安全与治理诉求。",{"type":186,"tag":275,"props":1145,"children":1147},{"id":1146},"_63-治理与运营把影子创新纳入可观测的实验",[1148],{"type":192,"value":1149},"6.3 治理与运营：把影子创新纳入「可观测的实验」",{"type":186,"tag":195,"props":1151,"children":1152},{},[1153],{"type":192,"value":1154},"为了在不扼杀创新的前提下降低风险，可以考虑：",{"type":186,"tag":214,"props":1156,"children":1157},{},[1158,1176,1194],{"type":186,"tag":218,"props":1159,"children":1160},{},[1161,1163],{"type":192,"value":1162},"建立「实验登记」机制：\n",{"type":186,"tag":214,"props":1164,"children":1165},{},[1166,1171],{"type":186,"tag":218,"props":1167,"children":1168},{},[1169],{"type":192,"value":1170},"所有新建的 AI 自动化、agent、工作流都需要登记基本元数据（owner、数据范围、涉及系统、预期影响）；",{"type":186,"tag":218,"props":1172,"children":1173},{},[1174],{"type":192,"value":1175},"重要流程需要简化版的风险评审。",{"type":186,"tag":218,"props":1177,"children":1178},{},[1179,1181],{"type":192,"value":1180},"强制基本观测能力：\n",{"type":186,"tag":214,"props":1182,"children":1183},{},[1184,1189],{"type":186,"tag":218,"props":1185,"children":1186},{},[1187],{"type":192,"value":1188},"统一采集运行日志、错误率、调用量等；",{"type":186,"tag":218,"props":1190,"children":1191},{},[1192],{"type":192,"value":1193},"在异常频发或影响面的流程上设置阈值和告警。",{"type":186,"tag":218,"props":1195,"children":1196},{},[1197,1199],{"type":192,"value":1198},"定期「体检和收敛」：\n",{"type":186,"tag":214,"props":1200,"children":1201},{},[1202,1207],{"type":186,"tag":218,"props":1203,"children":1204},{},[1205],{"type":192,"value":1206},"定期审查自动化目录，识别冗余、风险高、价值低的流程并退役；",{"type":186,"tag":218,"props":1208,"children":1209},{},[1210],{"type":192,"value":1211},"把运行稳定、影响大的影子流程纳入正式产品/平台演进路线。",{"type":186,"tag":275,"props":1213,"children":1215},{"id":1214},"_64-小结对于技术负责人可以考虑的几条实操路线",[1216],{"type":192,"value":1217},"6.4 小结：对于技术负责人可以考虑的几条实操路线",{"type":186,"tag":195,"props":1219,"children":1220},{},[1221],{"type":192,"value":1222},"结合上述分析，对架构师和技术负责人，可以概括为几条可执行方向：",{"type":186,"tag":214,"props":1224,"children":1225},{},[1226,1231,1236,1241],{"type":186,"tag":218,"props":1227,"children":1228},{},[1229],{"type":192,"value":1230},"不否认 AI-accelerated Shadow IT 的存在和价值，而是主动识别和分层管理；",{"type":186,"tag":218,"props":1232,"children":1233},{},[1234],{"type":192,"value":1235},"投资一个企业级、可观测的 AI 编排/自动化平台，作为业务自助构建的「唯一正门」；",{"type":186,"tag":218,"props":1237,"children":1238},{},[1239],{"type":192,"value":1240},"在平台层提供安全边界、连接器、Prompt/Agent 模板，而不是把这些责任下放给业务团队；",{"type":186,"tag":218,"props":1242,"children":1243},{},[1244],{"type":192,"value":1245},"通过治理机制（登记、审批、监控、定期体检）把「影子创新」转变为「可控实验」，在快速试错和长期稳定之间找到合理平衡。",{"title":178,"searchDepth":609,"depth":609,"links":1247},[1248,1249],{"id":189,"depth":609,"text":193},{"id":263,"depth":609,"text":266,"children":1250},[1251,1252,1253,1254,1255,1256],{"id":270,"depth":631,"text":273},{"id":368,"depth":631,"text":371},{"id":570,"depth":631,"text":573},{"id":729,"depth":631,"text":732},{"id":835,"depth":631,"text":838},{"id":1004,"depth":631,"text":1007},"markdown","content:6.maps:_management:shadow-it:ai-accelerated-shadow-it.md","content","6.maps/_management/shadow-it/ai-accelerated-shadow-it.md","6.maps/_management/shadow-it/ai-accelerated-shadow-it","md",[1264,1268],{"_path":1265,"title":1266,"description":1267},"/maps/_management/organization/organization","组织","团队组织架构、管理方法、沟通方式等。",{"_path":1269,"title":1270,"description":1271},"/maps/_management/shadow-it/shadow-it","影子 IT","影子 IT 现象、风险与治理策略",1772185485579]