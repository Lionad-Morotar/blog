ath":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"body":181,"_type":218,"_id":219,"_source":220,"_file":221,"_stem":222,"_extension":223},"/maps/_docs/doc-manage/sdd","doc-manage",false,true,"","规格驱动开发（SDD）","规格驱动开发是一种新兴的 AI 辅助编码工作流方法",{"type":182,"children":183,"toc":214},"root",[184,193,199,204,209],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"brief",[190],{"type":191,"value":192},"text","Brief",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"规格驱动开发（Spec-driven development）是一种新兴的 AI 辅助编码工作流方法。尽管这一术语的定义仍在演化之中，但通常是指：以结构化的功能规格说明为起点的工作流，然后通过多步过程将其分解为更小的模块、解决方案和具体任务。规格本身可以有多种形态：一份单一文档、一组文档，或是一系列结构化工件，用于表达不同的功能侧面。",{"type":185,"tag":194,"props":200,"children":201},{},[202],{"type":191,"value":203},"我们已经看到许多开发者采用了这种风格（我们在 Thoughtworks 内部也有自研版本并在内部分享）。尤其有三款工具，最近对规格驱动开发给出了各自不同的诠释。亚马逊的 Kiro 会引导用户经历三个工作流阶段——需求、设计以及任务创建。GitHub 的 spec-kit 也遵循类似的三步流程，但增加了更丰富的编排能力、可配置提示，以及一套“宪法”，用于定义必须始终遵守的不可变原则。Tessl Framework（截至 2025 年 9 月仍处于私测阶段）则采取了更为激进的做法：在其中，规格本身而非代码成为主要的维护工件。",{"type":185,"tag":194,"props":205,"children":206},{},[207],{"type":191,"value":208},"我们认为这个领域非常有意思，不过目前的工作流依然相当繁琐且带有很强的主观设计倾向。这些工具在不同任务规模和类型下的表现差异很大：有些会生成冗长的规格文件，难以审阅；而在生成 PRD 或用户故事时，有时又不清楚其目标读者究竟是谁。我们或许正在重温一个苦涩的教训——为 AI 逐条手工制定详细规则，从根本上说是难以扩展的。",{"type":185,"tag":194,"props":210,"children":211},{},[212],{"type":191,"value":213},"来源：技术雷达",{"title":178,"searchDepth":215,"depth":215,"links":216},2,[217],{"id":188,"depth":215,"text":192},"markdown","content:6.maps:_docs:doc-manage:sdd.md","content","6.maps/_docs/doc-manage/sdd.md","6.maps/_docs/doc-manage/sdd","md",[225,229],{"_path":226,"title":227,"description":228},"/maps/_docs/doc-manage/doc-manage","文档管理","文档管理相关",{"_path":230,"title":231,"description":232},"/maps/_docs/tech-docs/knowledge-flow","知识流优于知识库存","Knowledge flow is better than knowledge stocks",1771690617468]