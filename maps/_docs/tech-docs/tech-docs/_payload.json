","技术文档","技术文档与知识管理","content/6.maps/_docs/tech-docs/tech-docs.md",{"type":183,"children":184,"toc":317},"root",[185,194,209,214,221,227,233,246,252,257,263,275,281,286,292,304],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"domain",[191],{"type":192,"value":193},"text","Domain",{"type":186,"tag":195,"props":196,"children":197},"ul",{},[198],{"type":186,"tag":199,"props":200,"children":201},"li",{},[202],{"type":186,"tag":203,"props":204,"children":206},"a",{"href":205},"/maps/_docs/tech-docs/knowledge-flow",[207],{"type":192,"value":208},"Knowledge flow",{"type":186,"tag":187,"props":210,"children":212},{"id":211},"教学设计的认知科学原理",[213],{"type":192,"value":211},{"type":186,"tag":215,"props":216,"children":218},"h4",{"id":217},"叙事传输narrative-transportation",[219],{"type":192,"value":220},"叙事传输（Narrative Transportation）",{"type":186,"tag":222,"props":223,"children":224},"p",{},[225],{"type":192,"value":226},"用具体场景（如 YNAB 连接 Chase Bank）贯穿技术概念，而非抽象定义。\n人类大脑对故事的记忆强度是抽象信息的 6-7 倍（双编码理论）。\n情境模型让学习者在脑中\"预演\"使用过程，降低认知负荷。",{"type":186,"tag":215,"props":228,"children":230},{"id":229},"渐进式术语引入progressive-jargon-disclosure",[231],{"type":192,"value":232},"渐进式术语引入（Progressive Jargon Disclosure）",{"type":186,"tag":222,"props":234,"children":235},{},[236,238,244],{"type":192,"value":237},"先让用户熟悉流程（\"你登录、选择账户、点击同意\"），再引入术语（\"这叫 resource owner\"）。\n",{"type":186,"tag":239,"props":240,"children":241},"strong",{},[242],{"type":192,"value":243},"先体验后命名",{"type":192,"value":245},"符合概念形成的心理机制——人类需要先建立直觉，再给直觉贴标签。",{"type":186,"tag":215,"props":247,"children":249},{"id":248},"认知缺口制造information-gap-theory",[250],{"type":192,"value":251},"认知缺口制造（Information Gap Theory）",{"type":186,"tag":222,"props":253,"children":254},{},[255],{"type":192,"value":256},"\"魔法发生了...我会剧透\"——故意制造信息缺口，触发好奇心。\n当大脑感知到\"已知\"与\"欲知\"的差距时，会产生认知性好奇，驱动注意力集中。",{"type":186,"tag":215,"props":258,"children":260},{"id":259},"情感标记emotional-tagging",[261],{"type":192,"value":262},"情感标记（Emotional Tagging）",{"type":186,"tag":222,"props":264,"children":265},{},[266,268,273],{"type":192,"value":267},"\"",{"type":186,"tag":239,"props":269,"children":270},{},[271],{"type":192,"value":272},"BAD IDEA!!",{"type":192,"value":274},"\"——全大写加双感叹号，视觉和情绪的冲击激活杏仁核，给记忆打上情感标签。\n神经科学研究表明，带情感色彩的记忆更容易从长时记忆中提取。",{"type":186,"tag":215,"props":276,"children":278},{"id":277},"双重编码dual-coding",[279],{"type":192,"value":280},"双重编码（Dual Coding）",{"type":186,"tag":222,"props":282,"children":283},{},[284],{"type":192,"value":285},"让用户\"先看用户视角，再看开发者视角\"——\n同一信息通过两种不同的心理表征进行编码，显著增强理解和记忆。",{"type":186,"tag":215,"props":287,"children":289},{"id":288},"自我解释self-explanation",[290],{"type":192,"value":291},"自我解释（Self-Explanation）",{"type":186,"tag":222,"props":293,"children":294},{},[295,297,302],{"type":192,"value":296},"不断解释\"为什么要这样做\"（\"为什么不用 URL 传 token\"）。\n这种因果解释触发",{"type":186,"tag":239,"props":298,"children":299},{},[300],{"type":192,"value":301},"自我生成效应",{"type":192,"value":303},"——人对自己\"想明白\"的内容记忆更深刻。",{"type":186,"tag":222,"props":305,"children":306},{},[307,309],{"type":192,"value":308},"见：",{"type":186,"tag":203,"props":310,"children":314},{"href":311,"rel":312},"https://www.ducktyped.org/p/an-illustrated-guide-to-oauth",[313],"nofollow",[315],{"type":192,"value":316},"An Illustrated Guide to OAuth",{"title":178,"searchDepth":318,"depth":318,"links":319},2,[320,321],{"id":189,"depth":318,"text":193},{"id":211,"depth":318,"text":211},"markdown","content:6.maps:_docs:tech-docs:tech-docs.md","content","6.maps/_docs/tech-docs/tech-docs.md","6.maps/_docs/tech-docs/tech-docs","md",[329,332],{"_path":205,"title":330,"description":331},"知识流优于知识库存","Knowledge flow is better than knowledge stocks",{"_path":333,"title":334,"description":335},"/maps/_fe-framework/assets/iconify","Iconify","Iconify 是一个图标库，提供了多种图标集合的访问和使用方式。",1772185455655]