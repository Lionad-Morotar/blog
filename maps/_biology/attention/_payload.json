51},"root",[183,192,199,205,211,223,266,272,284,294,304,322],{"type":184,"tag":185,"props":186,"children":188},"element","h2",{"id":187},"daily-bugs",[189],{"type":190,"value":191},"text","Daily Bugs",{"type":184,"tag":193,"props":194,"children":196},"h4",{"id":195},"_2026-01-10",[197],{"type":190,"value":198},"2026-01-10",{"type":184,"tag":200,"props":201,"children":202},"p",{},[203],{"type":190,"value":204},"上周还是什么时候，我快速浏览了某篇文档，里面有A，但是我脑海里想的是B，就以为文档记录的是B。我特喵特意过了两遍文档，信誓旦旦和别人说B，结果是错的，后来才发现。这特喵是哪门子注意力啊！",{"type":184,"tag":185,"props":206,"children":208},{"id":207},"reports",[209],{"type":190,"value":210},"Reports",{"type":184,"tag":193,"props":212,"children":214},{"id":213},"注意力使用不完全报告",[215],{"type":184,"tag":216,"props":217,"children":221},"a",{"href":218,"rel":219},"https://sspai.com/post/70482",[220],"nofollow",[222],{"type":190,"value":213},{"type":184,"tag":224,"props":225,"children":226},"ul",{},[227,233,238,243,248,261],{"type":184,"tag":228,"props":229,"children":230},"li",{},[231],{"type":190,"value":232},"在精神最佳、状态最好的时候完成最重要的任务。",{"type":184,"tag":228,"props":234,"children":235},{},[236],{"type":190,"value":237},"任务目标越清楚，大脑越容易进入专注状态。",{"type":184,"tag":228,"props":239,"children":240},{},[241],{"type":190,"value":242},"使用注意力会消耗体能，吃饱饭、睡好觉、多锻炼，都可以有效提升注意力的上限。",{"type":184,"tag":228,"props":244,"children":245},{},[246],{"type":190,"value":247},"注意力不是恒定不变，而是在时刻波动的。短暂的跑神可以让大脑得到休息，要主动提醒自己回到焦点，保持专注。",{"type":184,"tag":228,"props":249,"children":250},{},[251,253,259],{"type":190,"value":252},"注意力就像摄影，找到目标之后要通过",{"type":184,"tag":254,"props":255,"children":256},"strong",{},[257],{"type":190,"value":258},"建立心理路径",{"type":190,"value":260},"将焦点锁定，避免大脑受到其它元素干扰而脱离主线。",{"type":184,"tag":228,"props":262,"children":263},{},[264],{"type":190,"value":265},"注意力和身体素质一样，越锻炼越强壮，越使用越熟练。",{"type":184,"tag":193,"props":267,"children":269},{"id":268},"横幅盲视如何削弱警示信息的有效性",[270],{"type":190,"value":271},"横幅盲视如何削弱警示信息的有效性？",{"type":184,"tag":200,"props":273,"children":274},{},[275,277,282],{"type":190,"value":276},"屏幕角落常驻显示的警示标语（如赌博成瘾预防信息）实际视线占有率极低。\n这种现象被称为",{"type":184,"tag":254,"props":278,"children":279},{},[280],{"type":190,"value":281},"横幅盲视（Banner Blindness）",{"type":190,"value":283},"——用户因长期暴露在固定位置而自动忽略这些元素。\n该概念最早由 Benway 于 1998 年提出，后经 Nielsen 用眼动追踪实验确认：\n用户几乎从不查看任何看起来像广告的内容，无论其是否为真正的广告。",{"type":184,"tag":200,"props":285,"children":286},{},[287,292],{"type":184,"tag":254,"props":288,"children":289},{},[290],{"type":190,"value":291},"非注意盲视加剧忽视",{"type":190,"value":293},"：当用户高度专注于主任务时，\n大脑因**高知觉负载（Perceptual Load）**而缩小注意范围，\n导致周边视野信息处理能力显著下降（Lavie, 2005）。\n这与隧道视野（Tunnel Vision）效应类似——注意力集中于中心任务时，\n周边信息被主动过滤。",{"type":184,"tag":200,"props":295,"children":296},{},[297,302],{"type":184,"tag":254,"props":298,"children":299},{},[300],{"type":190,"value":301},"改进方向",{"type":190,"value":303},"：从\"单向告知\"转向\"对话型警告\"",{"type":184,"tag":224,"props":305,"children":306},{},[307,312,317],{"type":184,"tag":228,"props":308,"children":309},{},[310],{"type":190,"value":311},"引入交互元素（如强制确认弹窗而非静态文字）",{"type":184,"tag":228,"props":313,"children":314},{},[315],{"type":190,"value":316},"基于情境的动态曝光（如游戏时长触发）",{"type":184,"tag":228,"props":318,"children":319},{},[320],{"type":190,"value":321},"与全面预防体系联动（如结合账户限额、强制冷却期）",{"type":184,"tag":200,"props":323,"children":324},{},[325,327,334,336,343,344],{"type":190,"value":326},"见：",{"type":184,"tag":216,"props":328,"children":331},{"href":329,"rel":330},"https://piracysim.com/%ed%99%94%eb%a9%b4-%ea%b5%ac%ec%84%9d-%ec%83%81%ec%8b%9c-%eb%85%b8%ec%b6%9c-%eb%8f%84%eb%b0%95-%ec%a4%91%eb%8f%85-%ec%98%88%eb%b0%a9-%eb%ac%b8%ea%b5%ac-%ec%8b%a4%ec%a7%88%ec%a0%81-%ec%8b%9c%ec%84%a0/",[220],[332],{"type":190,"value":333},"화면 구석 상시 노출되는 도박 중독 예방 문구의 실질적 시선 점유율",{"type":190,"value":335},"、\n",{"type":184,"tag":216,"props":337,"children":340},{"href":338,"rel":339},"https://baike.baidu.com/item/banner%2520blindness/10544170",[220],[341],{"type":190,"value":342},"Banner Blindness - Benway (1998)",{"type":190,"value":335},{"type":184,"tag":216,"props":345,"children":348},{"href":346,"rel":347},"https://link.springer.com/article/10.3758/s13423-015-0982-5",[220],[349],{"type":190,"value":350},"知觉负载理论 - Lavie (2005)",{"title":178,"searchDepth":352,"depth":352,"links":353},2,[354,355],{"id":187,"depth":352,"text":191},{"id":207,"depth":352,"text":210},"markdown","content:6.maps:_biology:attention.md","content","6.maps/_biology/attention.md","6.maps/_biology/attention","md",[363,366],{"_path":364,"title":365,"description":178},"/maps/_biology/aging","衰老",{"_path":367,"title":368,"description":369},"/maps/_biology/sleep","睡觉","这里记录了一些关于睡眠的知识。",1772185516470]