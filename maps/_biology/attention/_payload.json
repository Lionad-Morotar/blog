66},"root",[183,192,199,205,211,223],{"type":184,"tag":185,"props":186,"children":188},"element","h2",{"id":187},"daily-bugs",[189],{"type":190,"value":191},"text","Daily Bugs",{"type":184,"tag":193,"props":194,"children":196},"h4",{"id":195},"_2026-01-10",[197],{"type":190,"value":198},"2026-01-10",{"type":184,"tag":200,"props":201,"children":202},"p",{},[203],{"type":190,"value":204},"上周还是什么时候，我快速浏览了某篇文档，里面有A，但是我脑海里想的是B，就以为文档记录的是B。我特喵特意过了两遍文档，信誓旦旦和别人说B，结果是错的，后来才发现。这特喵是哪门子注意力啊！",{"type":184,"tag":185,"props":206,"children":208},{"id":207},"reports",[209],{"type":190,"value":210},"Reports",{"type":184,"tag":193,"props":212,"children":214},{"id":213},"注意力使用不完全报告",[215],{"type":184,"tag":216,"props":217,"children":221},"a",{"href":218,"rel":219},"https://sspai.com/post/70482",[220],"nofollow",[222],{"type":190,"value":213},{"type":184,"tag":224,"props":225,"children":226},"ul",{},[227,233,238,243,248,261],{"type":184,"tag":228,"props":229,"children":230},"li",{},[231],{"type":190,"value":232},"在精神最佳、状态最好的时候完成最重要的任务。",{"type":184,"tag":228,"props":234,"children":235},{},[236],{"type":190,"value":237},"任务目标越清楚，大脑越容易进入专注状态。",{"type":184,"tag":228,"props":239,"children":240},{},[241],{"type":190,"value":242},"使用注意力会消耗体能，吃饱饭、睡好觉、多锻炼，都可以有效提升注意力的上限。",{"type":184,"tag":228,"props":244,"children":245},{},[246],{"type":190,"value":247},"注意力不是恒定不变，而是在时刻波动的。短暂的跑神可以让大脑得到休息，要主动提醒自己回到焦点，保持专注。",{"type":184,"tag":228,"props":249,"children":250},{},[251,253,259],{"type":190,"value":252},"注意力就像摄影，找到目标之后要通过",{"type":184,"tag":254,"props":255,"children":256},"strong",{},[257],{"type":190,"value":258},"建立心理路径",{"type":190,"value":260},"将焦点锁定，避免大脑受到其它元素干扰而脱离主线。",{"type":184,"tag":228,"props":262,"children":263},{},[264],{"type":190,"value":265},"注意力和身体素质一样，越锻炼越强壮，越使用越熟练。",{"title":178,"searchDepth":267,"depth":267,"links":268},2,[269,270],{"id":187,"depth":267,"text":191},{"id":207,"depth":267,"text":210},"markdown","content:6.maps:_biology:attention.md","content","6.maps/_biology/attention