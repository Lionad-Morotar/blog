:182,"props":183,"children":185},"element","h2",{"id":184},"daily-bugs",[186],{"type":187,"value":188},"text","Daily Bugs",{"type":181,"tag":190,"props":191,"children":193},"h4",{"id":192},"_2026-01-10",[194],{"type":187,"value":195},"2026-01-10",{"type":181,"tag":197,"props":198,"children":199},"p",{},[200],{"type":187,"value":201},"上周还是什么时候，我快速浏览了某篇文档，里面有A，但是我脑海里想的是B，就以为文档记录的是B。我特喵特意过了两遍文档，信誓旦旦和别人说B，结果是错的，后来才发现。这特喵是哪门子注意力啊！",{"type":181,"tag":182,"props":203,"children":205},{"id":204},"reports",[206],{"type":187,"value":207},"Reports",{"type":181,"tag":190,"props":209,"children":211},{"id":210},"注意力使用不完全报告",[212],{"type":181,"tag":213,"props":214,"children":218},"a",{"href":215,"rel":216},"https://sspai.com/post/70482",[217],"nofollow",[219],{"type":187,"value":210},{"type":181,"tag":221,"props":222,"children":223},"ul",{},[224,230,235,240,245,258],{"type":181,"tag":225,"props":226,"children":227},"li",{},[228],{"type":187,"value":229},"在精神最佳、状态最好的时候完成最重要的任务。",{"type":181,"tag":225,"props":231,"children":232},{},[233],{"type":187,"value":234},"任务目标越清楚，大脑越容易进入专注状态。",{"type":181,"tag":225,"props":236,"children":237},{},[238],{"type":187,"value":239},"使用注意力会消耗体能，吃饱饭、睡好觉、多锻炼，都可以有效提升注意力的上限。",{"type":181,"tag":225,"props":241,"children":242},{},[243],{"type":187,"value":244},"注意力不是恒定不变，而是在时刻波动的。短暂的跑神可以让大脑得到休息，要主动提醒自己回到焦点，保持专注。",{"type":181,"tag":225,"props":246,"children":247},{},[248,250,256],{"type":187,"value":249},"注意力就像摄影，找到目标之后要通过",{"type":181,"tag":251,"props":252,"children":253},"strong",{},[254],{"type":187,"value":255},"建立心理路径",{"type":187,"value":257},"将焦点锁定，避免大脑受到其它元素干扰而脱离主线。",{"type":181,"tag":225,"props":259,"children":260},{},[261],{"type":187,"value":262},"注意力和身体素质一样，越锻炼越强壮，越使用越熟练。",{"title":175,"searchDepth":264,"depth":264,"links":265},2,[266,267],{"id":184,"depth":264,"text":188},{"id":204,"depth":264,"text":207},"markdown","content:6.maps:_biology:attention.md","content","6.maps/_biology/attention.md","6.maps/_biology/attention","md",[275,278],{"_pat