用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":178,"body":180,"_type":250,"_id":251,"_source":252,"_file":253,"_stem":254,"_extension":255},"/maps/_biology/aging","_biology",false,true,"","衰老",{"type":181,"children":182,"toc":247},"root",[183,192,198,203,208,228,233],{"type":184,"tag":185,"props":186,"children":188},"element","h4",{"id":187},"如何定义衰老",[189],{"type":190,"value":191},"text","如何定义衰老？",{"type":184,"tag":193,"props":194,"children":195},"p",{},[196],{"type":190,"value":197},"主观上，衰老是随时间推移的功能丧失，或损伤及其他有害变化的积累。尽管客观上可以通过分子特征和生物标志物来衡量，但在细胞层面衰老与整体生物体衰老的问题上，仍然缺乏如何定义衰老的共识：如何确认结构损伤、功能丧失、死亡率增加的因果关系。",{"type":184,"tag":193,"props":199,"children":200},{},[201],{"type":190,"value":202},"衰老的实体是整个生物体，而非该生物体各个衰老成分的总和，也即，在发育初期开始，单个细胞的损伤程度和衰老生物标志物预测年龄均在增加，但这些特征不属于衰老。有趣的地方在于，关于“戒烟后生物年龄下降算不算返老还童”的问题，科学家的分歧很大，关键在返老还童是仅限于让现有器官或组织变年轻，还是只要最终功能恢复就算？",{"type":184,"tag":193,"props":204,"children":205},{},[206],{"type":190,"value":207},"同时，导致衰老的根本原因同样不明确，但回避定义衰老，而是尝试描述衰老的特征，可能更有助于理解衰老的本质：",{"type":184,"tag":209,"props":210,"children":211},"ul",{},[212,218,223],{"type":184,"tag":213,"props":214,"children":215},"li",{},[216],{"type":190,"value":217},"细胞层面：端粒缩短、DNA 损伤累积、蛋白质稳态失衡、线粒体功能下降、干细胞耗竭。",{"type":184,"tag":213,"props":219,"children":220},{},[221],{"type":190,"value":222},"器官层面：组织再生能力减弱（如皮肤弹性下降、骨密度降低）、免疫功能下降（免疫衰老）、代谢效率降低。",{"type":184,"tag":213,"props":224,"children":225},{},[226],{"type":190,"value":227},"个体层面：心血管、神经、内分泌等系统协调性降低，对应激（如感染、创伤）的恢复能力下降。",{"type":184,"tag":193,"props":229,"children":230},{},[231],{"type":190,"value":232},"分层次描述衰老的特征会碰到一个问题：“衰老是系统的“涌现特性”（emergent property），还是仅仅是各部分衰老的简单叠加？”；此外，研究方向的不同也会导致研究分歧：机制模型（分子层面）试图确认生物体如何衰老，而进化模型（种群层面）则尝试解释生物体为何衰老。",{"type":184,"tag":193,"props":234,"children":235},{},[236,238],{"type":190,"value":237},"见：",{"type":184,"tag":239,"props":240,"children":244},"a",{"href":241,"rel":242},"https://mp.weixin.qq.com/s/lOOfScYwGnMLCMIKxjMl6A",[243],"nofollow",[245],{"type":190,"value":246},"何为衰老？@追问",{"title":178,"searchDepth":248,"depth":248,"links":249},2,[],"markdown","content:6.maps:_biology:aging.md","content","6.maps/_biology/aging.md","6.maps/_biology/aging","md",[257,261],{"_path":258,"title":259,"description":260},"/maps/_architecture/tech-architecture","技术架构","技术架构是指软件系统的整体结构，包括软件组件、子系统、模块之间的关系，以及软件系统的外部特性和行为。技术架构设计是软件开发的重要环节，它决定了软件系统的质量、性能、可维护性和可扩展性。",{"_path":262,"title":263,"description":178},"/maps/_biology/attention","注意力",1771695784400]