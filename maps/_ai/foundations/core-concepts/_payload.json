Core Concepts","20个AI核心概念一句话速查",{"type":182,"children":183,"toc":460},"root",[184,192,198,212,218,225,230,236,241,247,252,258,263,269,274,280,286,291,297,302,308,313,319,324,330,335,340,346,351,357,362,368,373,379,384,389,395,400,406,411,417,422,428,433,438,444,449,455],{"type":185,"tag":186,"props":187,"children":189},"element","h1",{"id":188},"ai-core-concepts",[190],{"type":191,"value":179},"text",{"type":185,"tag":193,"props":194,"children":195},"p",{},[196],{"type":191,"value":197},"20个AI核心概念的一句话总结，涵盖神经网络基础、LLM机制、推理技巧和应用模式。",{"type":185,"tag":193,"props":199,"children":200},{},[201,203],{"type":191,"value":202},"见：",{"type":185,"tag":204,"props":205,"children":209},"a",{"href":206,"rel":207},"https://blog.algomaster.io/p/20-ai-concepts-explained-simply",[208],"nofollow",[210],{"type":191,"value":211},"20 AI Concepts Explained Simply",{"type":185,"tag":213,"props":214,"children":216},"h2",{"id":215},"神经网络基础",[217],{"type":191,"value":215},{"type":185,"tag":219,"props":220,"children":222},"h4",{"id":221},"neural-network神经网络",[223],{"type":191,"value":224},"Neural Network（神经网络）？",{"type":185,"tag":193,"props":226,"children":227},{},[228],{"type":191,"value":229},"由神经元组成的层级结构，通过逐层转换输入来生成预测。",{"type":185,"tag":219,"props":231,"children":233},{"id":232},"transfer-learning迁移学习",[234],{"type":191,"value":235},"Transfer Learning（迁移学习）？",{"type":185,"tag":193,"props":237,"children":238},{},[239],{"type":191,"value":240},"复用预训练模型进行新任务，而非从头训练，从而获得强劲的先发优势。",{"type":185,"tag":219,"props":242,"children":244},{"id":243},"embeddings嵌入向量",[245],{"type":191,"value":246},"Embeddings（嵌入向量）？",{"type":185,"tag":193,"props":248,"children":249},{},[250],{"type":191,"value":251},"捕获语义的向量表示，使语义相似的词在高维向量空间中距离相近。",{"type":185,"tag":219,"props":253,"children":255},{"id":254},"attention注意力机制",[256],{"type":191,"value":257},"Attention（注意力机制）？",{"type":185,"tag":193,"props":259,"children":260},{},[261],{"type":191,"value":262},"让每个token能够查看输入中的其他所有token，并决定哪些对理解上下文更重要。",{"type":185,"tag":219,"props":264,"children":266},{"id":265},"transformer",[267],{"type":191,"value":268},"Transformer？",{"type":185,"tag":193,"props":270,"children":271},{},[272],{"type":191,"value":273},"出自论文\"Attention Is All You Need\"的架构，使用堆叠的注意力层并行处理token。",{"type":185,"tag":213,"props":275,"children":277},{"id":276},"llm核心机制",[278],{"type":191,"value":279},"LLM核心机制",{"type":185,"tag":219,"props":281,"children":283},{"id":282},"llm大语言模型",[284],{"type":191,"value":285},"LLM（大语言模型）？",{"type":185,"tag":193,"props":287,"children":288},{},[289],{"type":191,"value":290},"在数千亿到数万亿token上训练的Transformer，核心能力是预测下一个token。",{"type":185,"tag":219,"props":292,"children":294},{"id":293},"tokenization分词",[295],{"type":191,"value":296},"Tokenization（分词）？",{"type":185,"tag":193,"props":298,"children":299},{},[300],{"type":191,"value":301},"将文本转换为token（词、子词或字符）的过程，基于固定的词汇表进行映射。",{"type":185,"tag":219,"props":303,"children":305},{"id":304},"context-window上下文窗口",[306],{"type":191,"value":307},"Context Window（上下文窗口）？",{"type":185,"tag":193,"props":309,"children":310},{},[311],{"type":191,"value":312},"模型一次能处理的最大token数量，相当于LLM的工作记忆容量。",{"type":185,"tag":219,"props":314,"children":316},{"id":315},"temperature温度参数",[317],{"type":191,"value":318},"Temperature（温度参数）？",{"type":185,"tag":193,"props":320,"children":321},{},[322],{"type":191,"value":323},"控制token选择随机性的参数，0表示确定性输出，1+表示 increasingly random。",{"type":185,"tag":219,"props":325,"children":327},{"id":326},"hallucination幻觉",[328],{"type":191,"value":329},"Hallucination（幻觉）？",{"type":185,"tag":193,"props":331,"children":332},{},[333],{"type":191,"value":334},"LLM生成听起来自信可信但实际上不正确或虚构的内容。",{"type":185,"tag":213,"props":336,"children":338},{"id":337},"训练与优化",[339],{"type":191,"value":337},{"type":185,"tag":219,"props":341,"children":343},{"id":342},"fine-tuning微调",[344],{"type":191,"value":345},"Fine-tuning（微调）？",{"type":185,"tag":193,"props":347,"children":348},{},[349],{"type":191,"value":350},"在特定任务的小数据集上继续训练预训练模型，使其向特定行为方向调整。",{"type":185,"tag":219,"props":352,"children":354},{"id":353},"rlhf基于人类反馈的强化学习",[355],{"type":191,"value":356},"RLHF（基于人类反馈的强化学习）？",{"type":185,"tag":193,"props":358,"children":359},{},[360],{"type":191,"value":361},"利用人类对模型回答的排序来训练奖励模型，使LLM输出更有帮助、礼貌且安全。",{"type":185,"tag":219,"props":363,"children":365},{"id":364},"lora低秩适配",[366],{"type":191,"value":367},"LoRA（低秩适配）？",{"type":185,"tag":193,"props":369,"children":370},{},[371],{"type":191,"value":372},"冻结原始权重，仅添加少量可训练的适配器矩阵，用0.1%到1%的参数实现高效微调。",{"type":185,"tag":219,"props":374,"children":376},{"id":375},"quantization量化",[377],{"type":191,"value":378},"Quantization（量化）？",{"type":185,"tag":193,"props":380,"children":381},{},[382],{"type":191,"value":383},"将权重精度从32位降至16/8/4位，大幅缩减模型体积并降低内存使用。",{"type":185,"tag":213,"props":385,"children":387},{"id":386},"推理技巧",[388],{"type":191,"value":386},{"type":185,"tag":219,"props":390,"children":392},{"id":391},"prompt-engineering提示工程",[393],{"type":191,"value":394},"Prompt Engineering（提示工程）？",{"type":185,"tag":193,"props":396,"children":397},{},[398],{"type":191,"value":399},"通过角色设定、 few-shot 示例等技巧精心构造输入，以获得更好的模型输出。",{"type":185,"tag":219,"props":401,"children":403},{"id":402},"chain-of-thought思维链",[404],{"type":191,"value":405},"Chain of Thought（思维链）？",{"type":185,"tag":193,"props":407,"children":408},{},[409],{"type":191,"value":410},"让模型在给出最终答案前逐步展示推理过程，提高复杂任务的准确性。",{"type":185,"tag":219,"props":412,"children":414},{"id":413},"rag检索增强生成",[415],{"type":191,"value":416},"RAG（检索增强生成）？",{"type":185,"tag":193,"props":418,"children":419},{},[420],{"type":191,"value":421},"在生成回答前先检索相关文档，使模型输出基于真实、最新的信息。",{"type":185,"tag":219,"props":423,"children":425},{"id":424},"vector-database向量数据库",[426],{"type":191,"value":427},"Vector Database（向量数据库）？",{"type":185,"tag":193,"props":429,"children":430},{},[431],{"type":191,"value":432},"存储嵌入向量并通过相似度搜索实现\"按语义而非关键词\"检索的数据库。",{"type":185,"tag":213,"props":434,"children":436},{"id":435},"应用与生成",[437],{"type":191,"value":435},{"type":185,"tag":219,"props":439,"children":441},{"id":440},"ai-agentsai智能体",[442],{"type":191,"value":443},"AI Agents（AI智能体）？",{"type":185,"tag":193,"props":445,"children":446},{},[447],{"type":191,"value":448},"能够执行操作、做出决策并与外部工具交互的LLM，通过观察-思考-行动循环完成任务。",{"type":185,"tag":219,"props":450,"children":452},{"id":451},"diffusion-models扩散模型",[453],{"type":191,"value":454},"Diffusion Models（扩散模型）？",{"type":185,"tag":193,"props":456,"children":457},{},[458],{"type":191,"value":459},"通过学习逆转噪声腐蚀过程来生成数据，从随机噪声逐步恢复出结构化信号。",{"title":178,"searchDepth":461,"depth":461,"links":462},2,[463,464,465,466,467],{"id":215,"depth":461,"text":215},{"id":276,"depth":461,"text":279},{"id":337,"depth":461,"text":337},{"id":386,"depth":461,"text":386},{"id":435,"depth":461,"text":435},"markdown","content:6.maps:_ai:foundations:core-concepts.md","content","6.maps/_ai/foundations/core-concepts.md","6.maps/_ai/foundations/core-concepts","md",[475,479],{"_path":476,"title":477,"description":478},"/maps/_ai/foundations/architectures","AI Architectures","System architectures and design patterns for AI systems",{"_path":480,"title":481,"description":482},"/maps/_ai/foundations/emerging","Emerging AI Technologies","Emerging technologies and research directions in AI",1772504959138]