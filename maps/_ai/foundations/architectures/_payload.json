[{"data":1,"prerenderedAt":833},["ShallowReactive",2],{"navigation":3,"/maps/_ai/foundations/architectures":173,"/maps/_ai/foundations/architectures-surround":824},[4,35,92,98,125,134,158,164],{"title":5,"_path":6,"children":7},"心流思绪 / Heart Flows","/flows",[8,11,14,17,20,23,26,29,32],{"title":9,"_path":10},"📕 狮子的书单推荐","/flows/books",{"title":12,"_path":13},"🚝 四十二篇系列","/flows/forty-two",{"title":15,"_path":16},"🌃 长夜梦","/flows/long-night-dream",{"title":18,"_path":19},"🌌 万物联结与幸福感","/flows/everything",{"title":21,"_path":22},"⌛ 偷取时间","/flows/stealing-time-from-god",{"title":24,"_path":25},"🌆 表达和孤独","/flows/expression-and-loneliness",{"title":27,"_path":28},"🌧️ 我的腼腆","/flows/shy",{"title":30,"_path":31},"🥛 新工作，喝新饮料","/flows/drinking-while-thinking",{"title":33,"_path":34},"📝 心流归档","/flows/archive",{"title":36,"_path":37,"children":38},"技术博客 / Coder","/articles",[39,41,44,47,50,53,56,59,62,65,68,71,74,77,80,83,86,89],{"title":40,"_path":37},"🦁 欢迎",{"title":42,"_path":43},"📦 一个简单有效的端口命名策略：","/articles/simple-naming-method",{"title":45,"_path":46},"🌪️ Tailwind v4 如何兼容预处理器","/articles/tailwind4-with-sass",{"title":48,"_path":49},"🥞 在 tailwind 中使用现代化 CSS Layers","/articles/tailwind-sass-and-css-layer",{"title":51,"_path":52},"💻 本地部署 Qwen 翻译网页","/articles/local-translator",{"title":54,"_path":55},"🧊 模板解析器轻考古","/articles/micro-templating",{"title":57,"_path":58},"Ⓜ️ Mini CSS Parser","/articles/mini-css-parser",{"title":60,"_path":61},"🚩 向AI咨询前端问题","/articles/use-gpt-learn-complex-frontend",{"title":63,"_path":64},"⛸️ 怎样定制复杂组件的自定义滚动条？","/articles/use-scrollbars",{"title":66,"_path":67},"⚖️ 统一多组件库的层叠顺序","/articles/zindex-manager",{"title":69,"_path":70},"🕷️ 滑动验证码破解思路","/articles/crack-the-slider",{"title":72,"_path":73},"🌟 探秘 CSS 光影效果","/articles/css-light-travel",{"title":75,"_path":76},"🍲 设计模式与 JS 魔法锅","/articles/design-patterns-and-js-magic-pot",{"title":78,"_path":79},"🌐 Anysort：灵活、优雅的多属性排序","/articles/anysort-2th",{"title":81,"_path":82},"💫 CSS 幻术 | 抗锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"original_path":181,"body":182,"_type":818,"_id":819,"_source":820,"_file":821,"_stem":822,"_extension":823},"/maps/_ai/foundations/architectures","foundations",false,true,"","AI Architectures","System architectures and design patterns for AI systems","_ai/architectures.md",{"type":183,"children":184,"toc":807},"root",[185,194,201,207,230,236,241,260,266,271,290,296,301,320,326,331,350,356,361,380,386,391,410,414,420,427,440,451,457,462,521,527,532,575,581,586,647,653,658,681,687,692,768,774],{"type":186,"tag":187,"props":188,"children":190},"element","h1",{"id":189},"模型架构-model-architectures",[191],{"type":192,"value":193},"text","模型架构 (Model Architectures)",{"type":186,"tag":195,"props":196,"children":198},"h2",{"id":197},"litgptpytorch-lightning-原生的-llm-工具包",[199],{"type":192,"value":200},"LitGPT：PyTorch Lightning 原生的 LLM 工具包",{"type":186,"tag":202,"props":203,"children":204},"p",{},[205],{"type":192,"value":206},"LitGPT 让在个人数据上训练、微调和部署大模型变得简单高效。它内置 20+ 主流开源架构（Llama、Mistral、Qwen 等），并预配置 Flash Attention、FSDP 分布式训练、4-bit/8-bit 量化等生产级优化，开箱即用。核心代码采用\"单文件模型\"设计，没有过度抽象，适合快速原型验证和学习 LLM 工程实践。",{"type":186,"tag":202,"props":208,"children":209},{},[210,212,221,223],{"type":192,"value":211},"见：",{"type":186,"tag":213,"props":214,"children":218},"a",{"href":215,"rel":216},"https://github.com/Lightning-AI/litgpt",[217],"nofollow",[219],{"type":192,"value":220},"LitGPT GitHub",{"type":192,"value":222}," | ",{"type":186,"tag":213,"props":224,"children":227},{"href":225,"rel":226},"https://lightning.ai/litgpt",[217],[228],{"type":192,"value":229},"LitGPT 文档",{"type":186,"tag":195,"props":231,"children":233},{"id":232},"mamba线性复杂度的状态空间模型",[234],{"type":192,"value":235},"Mamba：线性复杂度的状态空间模型",{"type":186,"tag":202,"props":237,"children":238},{},[239],{"type":192,"value":240},"Mamba 代表了后 Transformer 时代的重要探索。传统 Transformer 的自注意力机制是二次复杂度 O(n²)，长序列时计算和内存开销爆炸。Mamba 通过选择性状态空间（Selective State Space）将复杂度降至线性 O(n)，同时保留了长程依赖建模能力。2024 年起，Mamba 与 Transformer 的混合架构成为主流——用 Mamba 处理长程上下文，用注意力机制处理局部精细交互。",{"type":186,"tag":202,"props":242,"children":243},{},[244,245,252,253],{"type":192,"value":211},{"type":186,"tag":213,"props":246,"children":249},{"href":247,"rel":248},"https://arxiv.org/abs/2312.00752",[217],[250],{"type":192,"value":251},"Mamba: Linear-Time Sequence Modeling",{"type":192,"value":222},{"type":186,"tag":213,"props":254,"children":257},{"href":255,"rel":256},"https://newsletter.maartengrootendorst.com/p/a-visual-guide-to-mamba-and-state",[217],[258],{"type":192,"value":259},"A Visual Guide to Mamba",{"type":186,"tag":195,"props":261,"children":263},{"id":262},"nanogpt极简-gpt-教学实现",[264],{"type":192,"value":265},"NanoGPT：极简 GPT 教学实现",{"type":186,"tag":202,"props":267,"children":268},{},[269],{"type":192,"value":270},"Andrej Karpathy 开发的 NanoGPT 用最简洁的代码实现了完整的 GPT 训练流程，核心代码仅约 300 行。这种\"minimal but complete\"的设计理念，让研究者能聚焦核心机制而非工程细节。配合《Let's build GPT: from scratch》视频系列，是理解 GPT 原理的最佳入门资料。",{"type":186,"tag":202,"props":272,"children":273},{},[274,275,282,283],{"type":192,"value":211},{"type":186,"tag":213,"props":276,"children":279},{"href":277,"rel":278},"https://github.com/karpathy/nanoGPT",[217],[280],{"type":192,"value":281},"nanoGPT GitHub",{"type":192,"value":222},{"type":186,"tag":213,"props":284,"children":287},{"href":285,"rel":286},"https://github.com/karpathy/build-nanogpt",[217],[288],{"type":192,"value":289},"build-nanogpt 教学仓库",{"type":186,"tag":195,"props":291,"children":293},{"id":292},"rwkvrnn-与-transformer-的混合架构",[294],{"type":192,"value":295},"RWKV：RNN 与 Transformer 的混合架构",{"type":186,"tag":202,"props":297,"children":298},{},[299],{"type":192,"value":300},"RWKV（Receptance Weighted Key Value）结合了 RNN 的 O(1) 推理内存和 Transformer 的并行训练能力。训练时像 Transformer 一样并行，推理时像 RNN 一样常数内存——这个特性让它在端侧部署和长文本生成场景有独特优势，支持 10 万+ tokens 的长文本续写。",{"type":186,"tag":202,"props":302,"children":303},{},[304,305,312,313],{"type":192,"value":211},{"type":186,"tag":213,"props":306,"children":309},{"href":307,"rel":308},"https://arxiv.org/abs/2305.13048",[217],[310],{"type":192,"value":311},"RWKV 论文",{"type":192,"value":222},{"type":186,"tag":213,"props":314,"children":317},{"href":315,"rel":316},"https://huggingface.co/blog/rwkv",[217],[318],{"type":192,"value":319},"Hugging Face RWKV 介绍",{"type":186,"tag":195,"props":321,"children":323},{"id":322},"torchtitanpytorch-原生大规模训练框架",[324],{"type":192,"value":325},"TorchTitan：PyTorch 原生大规模训练框架",{"type":186,"tag":202,"props":327,"children":328},{},[329],{"type":192,"value":330},"TorchTitan 是 PyTorch 官方出品的大规模模型训练框架，目标是成为\"PyTorch 原生的 Megatron/DeepSpeed 替代\"。它提供 4D 并行（数据并行、张量并行、流水线并行、序列并行）的统一实现，支持弹性扩缩容。各并行策略可独立开关、自由组合，无需修改模型代码即可无缝应用到大规模训练。",{"type":186,"tag":202,"props":332,"children":333},{},[334,335,342,343],{"type":192,"value":211},{"type":186,"tag":213,"props":336,"children":339},{"href":337,"rel":338},"https://github.com/pytorch/torchtitan",[217],[340],{"type":192,"value":341},"TorchTitan GitHub",{"type":192,"value":222},{"type":186,"tag":213,"props":344,"children":347},{"href":345,"rel":346},"https://arxiv.org/abs/2410.06511",[217],[348],{"type":192,"value":349},"TorchTitan 论文",{"type":186,"tag":195,"props":351,"children":353},{"id":352},"jepa非生成式自监督学习架构",[354],{"type":192,"value":355},"JEPA：非生成式自监督学习架构",{"type":186,"tag":202,"props":357,"children":358},{},[359],{"type":192,"value":360},"JEPA（Joint Embedding Predictive Architecture）是杨立昆提出的非生成式学习架构，核心创新是在抽象表示空间而非像素/token 空间进行预测。与传统生成模型重建输入不同，JEPA 学习语义表示，一次性预测而无需顺序解码。LeCun 认为这是通向 AGI 的必经之路——真正的智能需要世界模型，而非仅仅自回归生成。",{"type":186,"tag":202,"props":362,"children":363},{},[364,365,372,373],{"type":192,"value":211},{"type":186,"tag":213,"props":366,"children":369},{"href":367,"rel":368},"https://rohitbandaru.github.io/blog/JEPA-Deep-Dive/",[217],[370],{"type":192,"value":371},"JEPA 深度解析",{"type":192,"value":222},{"type":186,"tag":213,"props":374,"children":377},{"href":375,"rel":376},"https://ai.meta.com/blog/v-jepa-yann-lecun-ai-model-video-joint-embedding-predictive-architecture/",[217],[378],{"type":192,"value":379},"V-JEPA 官方发布",{"type":186,"tag":195,"props":381,"children":383},{"id":382},"空间智能理解三维世界的新一代-ai",[384],{"type":192,"value":385},"空间智能：理解三维世界的新一代 AI",{"type":186,"tag":202,"props":387,"children":388},{},[389],{"type":192,"value":390},"李飞飞创立的 World Labs 专注于\"空间智能\"——让 AI 理解三维世界的几何、物理和语义。真正的空间智能世界模型需要三种能力：生成性（创造遵守物理定律的世界）、多模态（融合视觉、语言、空间信息）、交互性（支持探索和导航的 3D 环境）。她预言未来五年，Transformer 可能被淘汰。",{"type":186,"tag":202,"props":392,"children":393},{},[394,395,402,403],{"type":192,"value":211},{"type":186,"tag":213,"props":396,"children":399},{"href":397,"rel":398},"https://www.mittrchina.com/news/detail/15468",[217],[400],{"type":192,"value":401},"李飞飞空间智能长文",{"type":192,"value":222},{"type":186,"tag":213,"props":404,"children":407},{"href":405,"rel":406},"https://zhuanlan.zhihu.com/p/1976808836682765387",[217],[408],{"type":192,"value":409},"李飞飞万字访谈",{"type":186,"tag":411,"props":412,"children":413},"hr",{},[],{"type":186,"tag":195,"props":415,"children":417},{"id":416},"transformer-基础架构",[418],{"type":192,"value":419},"Transformer 基础架构",{"type":186,"tag":421,"props":422,"children":424},"h4",{"id":423},"transformer-是什么",[425],{"type":192,"value":426},"Transformer 是什么？",{"type":186,"tag":202,"props":428,"children":429},{},[430,432,438],{"type":192,"value":431},"Transformer 是一种神经网络架构，2017 年在论文 \"Attention is All You Need\" 中首次提出。它已成为深度学习模型的主流架构，驱动着 GPT、Llama、Gemini 等文本生成模型，同时也应用于音频生成、图像识别、蛋白质结构预测等领域。文本生成类 Transformer 的核心原理是",{"type":186,"tag":433,"props":434,"children":435},"strong",{},[436],{"type":192,"value":437},"下一个 token 预测",{"type":192,"value":439},"——根据用户输入的文本提示，预测最可能的下一个词（或词片段）。其核心创新在于自注意力机制（self-attention），使模型能够处理整个序列并更有效地捕捉长距离依赖关系。",{"type":186,"tag":202,"props":441,"children":442},{},[443,444],{"type":192,"value":211},{"type":186,"tag":213,"props":445,"children":448},{"href":446,"rel":447},"https://poloclub.github.io/transformer-explainer/",[217],[449],{"type":192,"value":450},"Transformer Explainer",{"type":186,"tag":421,"props":452,"children":454},{"id":453},"transformer-架构三大组件是什么",[455],{"type":192,"value":456},"Transformer 架构三大组件是什么？",{"type":186,"tag":202,"props":458,"children":459},{},[460],{"type":192,"value":461},"每个文本生成 Transformer 包含三个关键组件：",{"type":186,"tag":463,"props":464,"children":465},"ol",{},[466,477,511],{"type":186,"tag":467,"props":468,"children":469},"li",{},[470,475],{"type":186,"tag":433,"props":471,"children":472},{},[473],{"type":192,"value":474},"Embedding（嵌入层）",{"type":192,"value":476},"：将文本输入切分为 token（词或子词），转换为捕获语义含义的数值向量",{"type":186,"tag":467,"props":478,"children":479},{},[480,485,487],{"type":186,"tag":433,"props":481,"children":482},{},[483],{"type":192,"value":484},"Transformer Block（变换器块）",{"type":192,"value":486},"：模型的核心构建模块，包含：\n",{"type":186,"tag":488,"props":489,"children":490},"ul",{},[491,501],{"type":186,"tag":467,"props":492,"children":493},{},[494,499],{"type":186,"tag":433,"props":495,"children":496},{},[497],{"type":192,"value":498},"Attention Mechanism（注意力机制）",{"type":192,"value":500},"：允许 token 之间通信，捕获上下文信息和词间关系",{"type":186,"tag":467,"props":502,"children":503},{},[504,509],{"type":186,"tag":433,"props":505,"children":506},{},[507],{"type":192,"value":508},"MLP（多层感知机）",{"type":192,"value":510},"：对每个 token 独立操作，精化每个 token 的表示",{"type":186,"tag":467,"props":512,"children":513},{},[514,519],{"type":186,"tag":433,"props":515,"children":516},{},[517],{"type":192,"value":518},"Output Probabilities（输出概率）",{"type":192,"value":520},"：最终的线性层和 softmax 层将处理后的嵌入转换为概率，预测序列中的下一个 token",{"type":186,"tag":421,"props":522,"children":524},{"id":523},"embedding-层如何将文本转换为向量表示",[525],{"type":192,"value":526},"Embedding 层如何将文本转换为向量表示？",{"type":186,"tag":202,"props":528,"children":529},{},[530],{"type":192,"value":531},"Embedding 层将输入提示转换为模型可理解的数值表示，包含四个步骤：",{"type":186,"tag":463,"props":533,"children":534},{},[535,545,555,565],{"type":186,"tag":467,"props":536,"children":537},{},[538,543],{"type":186,"tag":433,"props":539,"children":540},{},[541],{"type":192,"value":542},"Tokenization（分词）",{"type":192,"value":544},"：将输入文本切分为 token（词或子词）。GPT-2 的词表有 50,257 个唯一 token",{"type":186,"tag":467,"props":546,"children":547},{},[548,553],{"type":186,"tag":433,"props":549,"children":550},{},[551],{"type":192,"value":552},"Token Embedding（词嵌入）",{"type":192,"value":554},"：每个 token 被表示为 768 维向量（维度因模型而异）。相似含义的 token 在高维空间中距离更近",{"type":186,"tag":467,"props":556,"children":557},{},[558,563],{"type":186,"tag":433,"props":559,"children":560},{},[561],{"type":192,"value":562},"Positional Encoding（位置编码）",{"type":192,"value":564},"：编码每个 token 在输入序列中的位置信息。GPT-2 从零开始训练自己的位置编码矩阵",{"type":186,"tag":467,"props":566,"children":567},{},[568,573],{"type":186,"tag":433,"props":569,"children":570},{},[571],{"type":192,"value":572},"Final Embedding（最终嵌入）",{"type":192,"value":574},"：将 token 编码和位置编码相加，得到最终的嵌入表示",{"type":186,"tag":421,"props":576,"children":578},{"id":577},"多头自注意力机制如何工作",[579],{"type":192,"value":580},"多头自注意力机制如何工作？",{"type":186,"tag":202,"props":582,"children":583},{},[584],{"type":192,"value":585},"自注意力机制使模型能够捕获序列中 token 之间的关系：",{"type":186,"tag":463,"props":587,"children":588},{},[589,599,609,637],{"type":186,"tag":467,"props":590,"children":591},{},[592,597],{"type":186,"tag":433,"props":593,"children":594},{},[595],{"type":192,"value":596},"Q/K/V 矩阵计算",{"type":192,"value":598},"：每个 token 的嵌入向量被转换为三个向量——Query（查询）、Key（键）、Value（值）。可用搜索类比理解：Q 是搜索框输入，K 是网页标题，V 是网页内容",{"type":186,"tag":467,"props":600,"children":601},{},[602,607],{"type":186,"tag":433,"props":603,"children":604},{},[605],{"type":192,"value":606},"多头分割",{"type":192,"value":608},"：Q/K/V 向量被分割成多个头（GPT-2 small 有 12 个头），每个头独立处理嵌入的不同段，捕获不同的句法和语义关系",{"type":186,"tag":467,"props":610,"children":611},{},[612,617,619],{"type":186,"tag":433,"props":613,"children":614},{},[615],{"type":192,"value":616},"Masked Self-Attention（掩码自注意力）",{"type":192,"value":618},"：\n",{"type":186,"tag":488,"props":620,"children":621},{},[622,627,632],{"type":186,"tag":467,"props":623,"children":624},{},[625],{"type":192,"value":626},"计算 Q 和 K 的点积得到注意力分数",{"type":186,"tag":467,"props":628,"children":629},{},[630],{"type":192,"value":631},"对注意力矩阵的上三角应用 mask，防止模型访问未来 token（不能\"偷看\"未来）",{"type":186,"tag":467,"props":633,"children":634},{},[635],{"type":192,"value":636},"经过 softmax 转换为概率，每行总和为 1",{"type":186,"tag":467,"props":638,"children":639},{},[640,645],{"type":186,"tag":433,"props":641,"children":642},{},[643],{"type":192,"value":644},"输出和拼接",{"type":192,"value":646},"：将注意力分数与 V 矩阵相乘，12 个头的输出拼接后通过线性投影",{"type":186,"tag":421,"props":648,"children":650},{"id":649},"mlp-层的作用是什么",[651],{"type":192,"value":652},"MLP 层的作用是什么？",{"type":186,"tag":202,"props":654,"children":655},{},[656],{"type":192,"value":657},"MLP（多层感知机）在自注意力之后增强模型的表示能力：",{"type":186,"tag":488,"props":659,"children":660},{},[661,666,671,676],{"type":186,"tag":467,"props":662,"children":663},{},[664],{"type":192,"value":665},"包含两个线性变换，中间使用 GELU 激活函数",{"type":186,"tag":467,"props":667,"children":668},{},[669],{"type":192,"value":670},"第一次线性变换将维度从 768 扩展到 3072（4 倍），允许模型在高维空间捕获更复杂的模式",{"type":186,"tag":467,"props":672,"children":673},{},[674],{"type":192,"value":675},"第二次线性变换将维度压缩回 768，保留有用的非线性变换",{"type":186,"tag":467,"props":677,"children":678},{},[679],{"type":192,"value":680},"与自注意力不同，MLP 独立处理每个 token，仅将每个 token 的表示从一个空间映射到另一个空间",{"type":186,"tag":421,"props":682,"children":684},{"id":683},"输出概率如何生成下一个-token",[685],{"type":192,"value":686},"输出概率如何生成下一个 token？",{"type":186,"tag":202,"props":688,"children":689},{},[690],{"type":192,"value":691},"经过所有 Transformer Block 处理后：",{"type":186,"tag":463,"props":693,"children":694},{},[695,700,705],{"type":186,"tag":467,"props":696,"children":697},{},[698],{"type":192,"value":699},"最终线性层将表示投影到 50,257 维空间（词表大小），每个 token 对应一个 logit 值",{"type":186,"tag":467,"props":701,"children":702},{},[703],{"type":192,"value":704},"Softmax 将 logits 转换为概率分布（总和为 1）",{"type":186,"tag":467,"props":706,"children":707},{},[708,710],{"type":192,"value":709},"通过采样生成下一个 token，关键超参数：\n",{"type":186,"tag":488,"props":711,"children":712},{},[713,748,758],{"type":186,"tag":467,"props":714,"children":715},{},[716,721,723],{"type":186,"tag":433,"props":717,"children":718},{},[719],{"type":192,"value":720},"Temperature",{"type":192,"value":722},"：控制随机性\n",{"type":186,"tag":488,"props":724,"children":725},{},[726,731,736],{"type":186,"tag":467,"props":727,"children":728},{},[729],{"type":192,"value":730},"=1：无影响",{"type":186,"tag":467,"props":732,"children":733},{},[734],{"type":192,"value":735},"\u003C1：更确定、更尖锐的分布",{"type":186,"tag":467,"props":737,"children":738},{},[739],{"type":186,"tag":740,"props":741,"children":742},"blockquote",{},[743],{"type":186,"tag":202,"props":744,"children":745},{},[746],{"type":192,"value":747},"1：更柔和、更\"有创意\"的分布",{"type":186,"tag":467,"props":749,"children":750},{},[751,756],{"type":186,"tag":433,"props":752,"children":753},{},[754],{"type":192,"value":755},"Top-k 采样",{"type":192,"value":757},"：仅考虑概率最高的 k 个 token",{"type":186,"tag":467,"props":759,"children":760},{},[761,766],{"type":186,"tag":433,"props":762,"children":763},{},[764],{"type":192,"value":765},"Top-p 采样",{"type":192,"value":767},"：考虑累积概率超过阈值 p 的最小 token 集合",{"type":186,"tag":421,"props":769,"children":771},{"id":770},"辅助架构特性有哪些",[772],{"type":192,"value":773},"辅助架构特性有哪些？",{"type":186,"tag":488,"props":775,"children":776},{},[777,787,797],{"type":186,"tag":467,"props":778,"children":779},{},[780,785],{"type":186,"tag":433,"props":781,"children":782},{},[783],{"type":192,"value":784},"Layer Normalization（层归一化）",{"type":192,"value":786},"：稳定训练、加速收敛，在每个 Transformer Block 中应用两次（注意力前和 MLP 前）",{"type":186,"tag":467,"props":788,"children":789},{},[790,795],{"type":186,"tag":433,"props":791,"children":792},{},[793],{"type":192,"value":794},"Dropout（随机失活）",{"type":192,"value":796},"：训练时随机将部分权重设为零，防止过拟合；推理时关闭",{"type":186,"tag":467,"props":798,"children":799},{},[800,805],{"type":186,"tag":433,"props":801,"children":802},{},[803],{"type":192,"value":804},"Residual Connections（残差连接）",{"type":192,"value":806},"：绕过一层或多层的快捷连接，缓解梯度消失问题，使深层网络训练成为可能。GPT-2 在每个 Transformer Block 中使用两次",{"title":178,"searchDepth":808,"depth":808,"links":809},2,[810,811,812,813,814,815,816,817],{"id":197,"depth":808,"text":200},{"id":232,"depth":808,"text":235},{"id":262,"depth":808,"text":265},{"id":292,"depth":808,"text":295},{"id":322,"depth":808,"text":325},{"id":352,"depth":808,"text":355},{"id":382,"depth":808,"text":385},{"id":416,"depth":808,"text":419},"markdown","content:6.maps:_ai:foundations:architectures.md","content","6.maps/_ai/foundations/architectures.md","6.maps/_ai/foundations/architectures","md",[825,829],{"_path":826,"title":827,"description":828},"/maps/_ai/evaluation/reproducibility","Reproducibility","机器学习可重复性（Reproducibility）的核心价值与实践方法，包括随机种子固定、数据版本控制等关键实践。",{"_path":830,"title":831,"description":832},"/maps/_ai/foundations/emerging","Emerging AI Technologies","Emerging technologies and research directions in AI",1772185504515]