a",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"original_path":181,"body":182,"_type":858,"_id":859,"_source":860,"_file":861,"_stem":862,"_extension":863},"/maps/_ai/foundations/architectures","foundations",false,true,"","AI Architectures","System architectures and design patterns for AI systems","_ai/architectures.md",{"type":183,"children":184,"toc":846},"root",[185,194,201,207,230,236,241,260,266,271,290,296,301,320,326,331,350,356,361,380,386,391,410,416,423,436,447,453,458,517,523,528,571,577,582,643,649,654,677,683,688,764,770,803,809,815,820,825,830,835],{"type":186,"tag":187,"props":188,"children":190},"element","h1",{"id":189},"模型架构-model-architectures",[191],{"type":192,"value":193},"text","模型架构 (Model Architectures)",{"type":186,"tag":195,"props":196,"children":198},"h2",{"id":197},"litgptpytorch-lightning-原生的-llm-工具包",[199],{"type":192,"value":200},"LitGPT：PyTorch Lightning 原生的 LLM 工具包",{"type":186,"tag":202,"props":203,"children":204},"p",{},[205],{"type":192,"value":206},"LitGPT 让在个人数据上训练、微调和部署大模型变得简单高效。它内置 20+ 主流开源架构（Llama、Mistral、Qwen 等），并预配置 Flash Attention、FSDP 分布式训练、4-bit/8-bit 量化等生产级优化，开箱即用。核心代码采用\"单文件模型\"设计，没有过度抽象，适合快速原型验证和学习 LLM 工程实践。",{"type":186,"tag":202,"props":208,"children":209},{},[210,212,221,223],{"type":192,"value":211},"见：",{"type":186,"tag":213,"props":214,"children":218},"a",{"href":215,"rel":216},"https://github.com/Lightning-AI/litgpt",[217],"nofollow",[219],{"type":192,"value":220},"LitGPT GitHub",{"type":192,"value":222}," | ",{"type":186,"tag":213,"props":224,"children":227},{"href":225,"rel":226},"https://lightning.ai/litgpt",[217],[228],{"type":192,"value":229},"LitGPT 文档",{"type":186,"tag":195,"props":231,"children":233},{"id":232},"mamba线性复杂度的状态空间模型",[234],{"type":192,"value":235},"Mamba：线性复杂度的状态空间模型",{"type":186,"tag":202,"props":237,"children":238},{},[239],{"type":192,"value":240},"Mamba 代表了后 Transformer 时代的重要探索。传统 Transformer 的自注意力机制是二次复杂度 O(n²)，长序列时计算和内存开销爆炸。Mamba 通过选择性状态空间（Selective State Space）将复杂度降至线性 O(n)，同时保留了长程依赖建模能力。2024 年起，Mamba 与 Transformer 的混合架构成为主流——用 Mamba 处理长程上下文，用注意力机制处理局部精细交互。",{"type":186,"tag":202,"props":242,"children":243},{},[244,245,252,253],{"type":192,"value":211},{"type":186,"tag":213,"props":246,"children":249},{"href":247,"rel":248},"https://arxiv.org/abs/2312.00752",[217],[250],{"type":192,"value":251},"Mamba: Linear-Time Sequence Modeling",{"type":192,"value":222},{"type":186,"tag":213,"props":254,"children":257},{"href":255,"rel":256},"https://newsletter.maartengrootendorst.com/p/a-visual-guide-to-mamba-and-state",[217],[258],{"type":192,"value":259},"A Visual Guide to Mamba",{"type":186,"tag":195,"props":261,"children":263},{"id":262},"nanogpt极简-gpt-教学实现",[264],{"type":192,"value":265},"NanoGPT：极简 GPT 教学实现",{"type":186,"tag":202,"props":267,"children":268},{},[269],{"type":192,"value":270},"Andrej Karpathy 开发的 NanoGPT 用最简洁的代码实现了完整的 GPT 训练流程，核心代码仅约 300 行。这种\"minimal but complete\"的设计理念，让研究者能聚焦核心机制而非工程细节。配合《Let's build GPT: from scratch》视频系列，是理解 GPT 原理的最佳入门资料。",{"type":186,"tag":202,"props":272,"children":273},{},[274,275,282,283],{"type":192,"value":211},{"type":186,"tag":213,"props":276,"children":279},{"href":277,"rel":278},"https://github.com/karpathy/nanoGPT",[217],[280],{"type":192,"value":281},"nanoGPT GitHub",{"type":192,"value":222},{"type":186,"tag":213,"props":284,"children":287},{"href":285,"rel":286},"https://github.com/karpathy/build-nanogpt",[217],[288],{"type":192,"value":289},"build-nanogpt 教学仓库",{"type":186,"tag":195,"props":291,"children":293},{"id":292},"rwkvrnn-与-transformer-的混合架构",[294],{"type":192,"value":295},"RWKV：RNN 与 Transformer 的混合架构",{"type":186,"tag":202,"props":297,"children":298},{},[299],{"type":192,"value":300},"RWKV（Receptance Weighted Key Value）结合了 RNN 的 O(1) 推理内存和 Transformer 的并行训练能力。训练时像 Transformer 一样并行，推理时像 RNN 一样常数内存——这个特性让它在端侧部署和长文本生成场景有独特优势，支持 10 万+ tokens 的长文本续写。",{"type":186,"tag":202,"props":302,"children":303},{},[304,305,312,313],{"type":192,"value":211},{"type":186,"tag":213,"props":306,"children":309},{"href":307,"rel":308},"https://arxiv.org/abs/2305.13048",[217],[310],{"type":192,"value":311},"RWKV 论文",{"type":192,"value":222},{"type":186,"tag":213,"props":314,"children":317},{"href":315,"rel":316},"https://huggingface.co/blog/rwkv",[217],[318],{"type":192,"value":319},"Hugging Face RWKV 介绍",{"type":186,"tag":195,"props":321,"children":323},{"id":322},"torchtitanpytorch-原生大规模训练框架",[324],{"type":192,"value":325},"TorchTitan：PyTorch 原生大规模训练框架",{"type":186,"tag":202,"props":327,"children":328},{},[329],{"type":192,"value":330},"TorchTitan 是 PyTorch 官方出品的大规模模型训练框架，目标是成为\"PyTorch 原生的 Megatron/DeepSpeed 替代\"。它提供 4D 并行（数据并行、张量并行、流水线并行、序列并行）的统一实现，支持弹性扩缩容。各并行策略可独立开关、自由组合，无需修改模型代码即可无缝应用到大规模训练。",{"type":186,"tag":202,"props":332,"children":333},{},[334,335,342,343],{"type":192,"value":211},{"type":186,"tag":213,"props":336,"children":339},{"href":337,"rel":338},"https://github.com/pytorch/torchtitan",[217],[340],{"type":192,"value":341},"TorchTitan GitHub",{"type":192,"value":222},{"type":186,"tag":213,"props":344,"children":347},{"href":345,"rel":346},"https://arxiv.org/abs/2410.06511",[217],[348],{"type":192,"value":349},"TorchTitan 论文",{"type":186,"tag":195,"props":351,"children":353},{"id":352},"jepa非生成式自监督学习架构",[354],{"type":192,"value":355},"JEPA：非生成式自监督学习架构",{"type":186,"tag":202,"props":357,"children":358},{},[359],{"type":192,"value":360},"JEPA（Joint Embedding Predictive Architecture）是杨立昆提出的非生成式学习架构，核心创新是在抽象表示空间而非像素/token 空间进行预测。与传统生成模型重建输入不同，JEPA 学习语义表示，一次性预测而无需顺序解码。LeCun 认为这是通向 AGI 的必经之路——真正的智能需要世界模型，而非仅仅自回归生成。",{"type":186,"tag":202,"props":362,"children":363},{},[364,365,372,373],{"type":192,"value":211},{"type":186,"tag":213,"props":366,"children":369},{"href":367,"rel":368},"https://rohitbandaru.github.io/blog/JEPA-Deep-Dive/",[217],[370],{"type":192,"value":371},"JEPA 深度解析",{"type":192,"value":222},{"type":186,"tag":213,"props":374,"children":377},{"href":375,"rel":376},"https://ai.meta.com/blog/v-jepa-yann-lecun-ai-model-video-joint-embedding-predictive-architecture/",[217],[378],{"type":192,"value":379},"V-JEPA 官方发布",{"type":186,"tag":195,"props":381,"children":383},{"id":382},"空间智能理解三维世界的新一代-ai",[384],{"type":192,"value":385},"空间智能：理解三维世界的新一代 AI",{"type":186,"tag":202,"props":387,"children":388},{},[389],{"type":192,"value":390},"李飞飞创立的 World Labs 专注于\"空间智能\"——让 AI 理解三维世界的几何、物理和语义。真正的空间智能世界模型需要三种能力：生成性（创造遵守物理定律的世界）、多模态（融合视觉、语言、空间信息）、交互性（支持探索和导航的 3D 环境）。她预言未来五年，Transformer 可能被淘汰。",{"type":186,"tag":202,"props":392,"children":393},{},[394,395,402,403],{"type":192,"value":211},{"type":186,"tag":213,"props":396,"children":399},{"href":397,"rel":398},"https://www.mittrchina.com/news/detail/15468",[217],[400],{"type":192,"value":401},"李飞飞空间智能长文",{"type":192,"value":222},{"type":186,"tag":213,"props":404,"children":407},{"href":405,"rel":406},"https://zhuanlan.zhihu.com/p/1976808836682765387",[217],[408],{"type":192,"value":409},"李飞飞万字访谈",{"type":186,"tag":195,"props":411,"children":413},{"id":412},"transformer-基础架构",[414],{"type":192,"value":415},"Transformer 基础架构",{"type":186,"tag":417,"props":418,"children":420},"h4",{"id":419},"transformer-是什么",[421],{"type":192,"value":422},"Transformer 是什么？",{"type":186,"tag":202,"props":424,"children":425},{},[426,428,434],{"type":192,"value":427},"Transformer 是一种神经网络架构，2017 年在论文 \"Attention is All You Need\" 中首次提出。它已成为深度学习模型的主流架构，驱动着 GPT、Llama、Gemini 等文本生成模型，同时也应用于音频生成、图像识别、蛋白质结构预测等领域。文本生成类 Transformer 的核心原理是",{"type":186,"tag":429,"props":430,"children":431},"strong",{},[432],{"type":192,"value":433},"下一个 token 预测",{"type":192,"value":435},"——根据用户输入的文本提示，预测最可能的下一个词（或词片段）。其核心创新在于自注意力机制（self-attention），使模型能够处理整个序列并更有效地捕捉长距离依赖关系。",{"type":186,"tag":202,"props":437,"children":438},{},[439,440],{"type":192,"value":211},{"type":186,"tag":213,"props":441,"children":444},{"href":442,"rel":443},"https://poloclub.github.io/transformer-explainer/",[217],[445],{"type":192,"value":446},"Transformer Explainer",{"type":186,"tag":417,"props":448,"children":450},{"id":449},"transformer-架构三大组件是什么",[451],{"type":192,"value":452},"Transformer 架构三大组件是什么？",{"type":186,"tag":202,"props":454,"children":455},{},[456],{"type":192,"value":457},"每个文本生成 Transformer 包含三个关键组件：",{"type":186,"tag":459,"props":460,"children":461},"ol",{},[462,473,507],{"type":186,"tag":463,"props":464,"children":465},"li",{},[466,471],{"type":186,"tag":429,"props":467,"children":468},{},[469],{"type":192,"value":470},"Embedding（嵌入层）",{"type":192,"value":472},"：将文本输入切分为 token（词或子词），转换为捕获语义含义的数值向量",{"type":186,"tag":463,"props":474,"children":475},{},[476,481,483],{"type":186,"tag":429,"props":477,"children":478},{},[479],{"type":192,"value":480},"Transformer Block（变换器块）",{"type":192,"value":482},"：模型的核心构建模块，包含：\n",{"type":186,"tag":484,"props":485,"children":486},"ul",{},[487,497],{"type":186,"tag":463,"props":488,"children":489},{},[490,495],{"type":186,"tag":429,"props":491,"children":492},{},[493],{"type":192,"value":494},"Attention Mechanism（注意力机制）",{"type":192,"value":496},"：允许 token 之间通信，捕获上下文信息和词间关系",{"type":186,"tag":463,"props":498,"children":499},{},[500,505],{"type":186,"tag":429,"props":501,"children":502},{},[503],{"type":192,"value":504},"MLP（多层感知机）",{"type":192,"value":506},"：对每个 token 独立操作，精化每个 token 的表示",{"type":186,"tag":463,"props":508,"children":509},{},[510,515],{"type":186,"tag":429,"props":511,"children":512},{},[513],{"type":192,"value":514},"Output Probabilities（输出概率）",{"type":192,"value":516},"：最终的线性层和 softmax 层将处理后的嵌入转换为概率，预测序列中的下一个 token",{"type":186,"tag":417,"props":518,"children":520},{"id":519},"embedding-层如何将文本转换为向量表示",[521],{"type":192,"value":522},"Embedding 层如何将文本转换为向量表示？",{"type":186,"tag":202,"props":524,"children":525},{},[526],{"type":192,"value":527},"Embedding 层将输入提示转换为模型可理解的数值表示，包含四个步骤：",{"type":186,"tag":459,"props":529,"children":530},{},[531,541,551,561],{"type":186,"tag":463,"props":532,"children":533},{},[534,539],{"type":186,"tag":429,"props":535,"children":536},{},[537],{"type":192,"value":538},"Tokenization（分词）",{"type":192,"value":540},"：将输入文本切分为 token（词或子词）。GPT-2 的词表有 50,257 个唯一 token",{"type":186,"tag":463,"props":542,"children":543},{},[544,549],{"type":186,"tag":429,"props":545,"children":546},{},[547],{"type":192,"value":548},"Token Embedding（词嵌入）",{"type":192,"value":550},"：每个 token 被表示为 768 维向量（维度因模型而异）。相似含义的 token 在高维空间中距离更近",{"type":186,"tag":463,"props":552,"children":553},{},[554,559],{"type":186,"tag":429,"props":555,"children":556},{},[557],{"type":192,"value":558},"Positional Encoding（位置编码）",{"type":192,"value":560},"：编码每个 token 在输入序列中的位置信息。GPT-2 从零开始训练自己的位置编码矩阵",{"type":186,"tag":463,"props":562,"children":563},{},[564,569],{"type":186,"tag":429,"props":565,"children":566},{},[567],{"type":192,"value":568},"Final Embedding（最终嵌入）",{"type":192,"value":570},"：将 token 编码和位置编码相加，得到最终的嵌入表示",{"type":186,"tag":417,"props":572,"children":574},{"id":573},"多头自注意力机制如何工作",[575],{"type":192,"value":576},"多头自注意力机制如何工作？",{"type":186,"tag":202,"props":578,"children":579},{},[580],{"type":192,"value":581},"自注意力机制使模型能够捕获序列中 token 之间的关系：",{"type":186,"tag":459,"props":583,"children":584},{},[585,595,605,633],{"type":186,"tag":463,"props":586,"children":587},{},[588,593],{"type":186,"tag":429,"props":589,"children":590},{},[591],{"type":192,"value":592},"Q/K/V 矩阵计算",{"type":192,"value":594},"：每个 token 的嵌入向量被转换为三个向量——Query（查询）、Key（键）、Value（值）。可用搜索类比理解：Q 是搜索框输入，K 是网页标题，V 是网页内容",{"type":186,"tag":463,"props":596,"children":597},{},[598,603],{"type":186,"tag":429,"props":599,"children":600},{},[601],{"type":192,"value":602},"多头分割",{"type":192,"value":604},"：Q/K/V 向量被分割成多个头（GPT-2 small 有 12 个头），每个头独立处理嵌入的不同段，捕获不同的句法和语义关系",{"type":186,"tag":463,"props":606,"children":607},{},[608,613,615],{"type":186,"tag":429,"props":609,"children":610},{},[611],{"type":192,"value":612},"Masked Self-Attention（掩码自注意力）",{"type":192,"value":614},"：\n",{"type":186,"tag":484,"props":616,"children":617},{},[618,623,628],{"type":186,"tag":463,"props":619,"children":620},{},[621],{"type":192,"value":622},"计算 Q 和 K 的点积得到注意力分数",{"type":186,"tag":463,"props":624,"children":625},{},[626],{"type":192,"value":627},"对注意力矩阵的上三角应用 mask，防止模型访问未来 token（不能\"偷看\"未来）",{"type":186,"tag":463,"props":629,"children":630},{},[631],{"type":192,"value":632},"经过 softmax 转换为概率，每行总和为 1",{"type":186,"tag":463,"props":634,"children":635},{},[636,641],{"type":186,"tag":429,"props":637,"children":638},{},[639],{"type":192,"value":640},"输出和拼接",{"type":192,"value":642},"：将注意力分数与 V 矩阵相乘，12 个头的输出拼接后通过线性投影",{"type":186,"tag":417,"props":644,"children":646},{"id":645},"mlp-层的作用是什么",[647],{"type":192,"value":648},"MLP 层的作用是什么？",{"type":186,"tag":202,"props":650,"children":651},{},[652],{"type":192,"value":653},"MLP（多层感知机）在自注意力之后增强模型的表示能力：",{"type":186,"tag":484,"props":655,"children":656},{},[657,662,667,672],{"type":186,"tag":463,"props":658,"children":659},{},[660],{"type":192,"value":661},"包含两个线性变换，中间使用 GELU 激活函数",{"type":186,"tag":463,"props":663,"children":664},{},[665],{"type":192,"value":666},"第一次线性变换将维度从 768 扩展到 3072（4 倍），允许模型在高维空间捕获更复杂的模式",{"type":186,"tag":463,"props":668,"children":669},{},[670],{"type":192,"value":671},"第二次线性变换将维度压缩回 768，保留有用的非线性变换",{"type":186,"tag":463,"props":673,"children":674},{},[675],{"type":192,"value":676},"与自注意力不同，MLP 独立处理每个 token，仅将每个 token 的表示从一个空间映射到另一个空间",{"type":186,"tag":417,"props":678,"children":680},{"id":679},"输出概率如何生成下一个-token",[681],{"type":192,"value":682},"输出概率如何生成下一个 token？",{"type":186,"tag":202,"props":684,"children":685},{},[686],{"type":192,"value":687},"经过所有 Transformer Block 处理后：",{"type":186,"tag":459,"props":689,"children":690},{},[691,696,701],{"type":186,"tag":463,"props":692,"children":693},{},[694],{"type":192,"value":695},"最终线性层将表示投影到 50,257 维空间（词表大小），每个 token 对应一个 logit 值",{"type":186,"tag":463,"props":697,"children":698},{},[699],{"type":192,"value":700},"Softmax 将 logits 转换为概率分布（总和为 1）",{"type":186,"tag":463,"props":702,"children":703},{},[704,706],{"type":192,"value":705},"通过采样生成下一个 token，关键超参数：\n",{"type":186,"tag":484,"props":707,"children":708},{},[709,744,754],{"type":186,"tag":463,"props":710,"children":711},{},[712,717,719],{"type":186,"tag":429,"props":713,"children":714},{},[715],{"type":192,"value":716},"Temperature",{"type":192,"value":718},"：控制随机性\n",{"type":186,"tag":484,"props":720,"children":721},{},[722,727,732],{"type":186,"tag":463,"props":723,"children":724},{},[725],{"type":192,"value":726},"=1：无影响",{"type":186,"tag":463,"props":728,"children":729},{},[730],{"type":192,"value":731},"\u003C1：更确定、更尖锐的分布",{"type":186,"tag":463,"props":733,"children":734},{},[735],{"type":186,"tag":736,"props":737,"children":738},"blockquote",{},[739],{"type":186,"tag":202,"props":740,"children":741},{},[742],{"type":192,"value":743},"1：更柔和、更\"有创意\"的分布",{"type":186,"tag":463,"props":745,"children":746},{},[747,752],{"type":186,"tag":429,"props":748,"children":749},{},[750],{"type":192,"value":751},"Top-k 采样",{"type":192,"value":753},"：仅考虑概率最高的 k 个 token",{"type":186,"tag":463,"props":755,"children":756},{},[757,762],{"type":186,"tag":429,"props":758,"children":759},{},[760],{"type":192,"value":761},"Top-p 采样",{"type":192,"value":763},"：考虑累积概率超过阈值 p 的最小 token 集合",{"type":186,"tag":417,"props":765,"children":767},{"id":766},"辅助架构特性有哪些",[768],{"type":192,"value":769},"辅助架构特性有哪些？",{"type":186,"tag":484,"props":771,"children":772},{},[773,783,793],{"type":186,"tag":463,"props":774,"children":775},{},[776,781],{"type":186,"tag":429,"props":777,"children":778},{},[779],{"type":192,"value":780},"Layer Normalization（层归一化）",{"type":192,"value":782},"：稳定训练、加速收敛，在每个 Transformer Block 中应用两次（注意力前和 MLP 前）",{"type":186,"tag":463,"props":784,"children":785},{},[786,791],{"type":186,"tag":429,"props":787,"children":788},{},[789],{"type":192,"value":790},"Dropout（随机失活）",{"type":192,"value":792},"：训练时随机将部分权重设为零，防止过拟合；推理时关闭",{"type":186,"tag":463,"props":794,"children":795},{},[796,801],{"type":186,"tag":429,"props":797,"children":798},{},[799],{"type":192,"value":800},"Residual Connections（残差连接）",{"type":192,"value":802},"：绕过一层或多层的快捷连接，缓解梯度消失问题，使深层网络训练成为可能。GPT-2 在每个 Transformer Block 中使用两次",{"type":186,"tag":195,"props":804,"children":806},{"id":805},"端侧-ai-限制",[807],{"type":192,"value":808},"端侧 AI 限制",{"type":186,"tag":417,"props":810,"children":812},{"id":811},"端侧-agent-的物理瓶颈",[813],{"type":192,"value":814},"端侧 Agent 的物理瓶颈",{"type":186,"tag":202,"props":816,"children":817},{},[818],{"type":192,"value":819},"端侧 AI 面临严峻的物理限制：新设备通常仅 8-16GB RAM，扣除系统占用后仅剩 4-8GB 给 AI。\n7B 参数模型需 5GB+，而 Agent 任务需要 32K+ 上下文，KV Cache 可能使 AI 部分占用超过 16GB RAM。",{"type":186,"tag":202,"props":821,"children":822},{},[823],{"type":192,"value":824},"更棘手的是速度问题：端侧 token 生成随上下文增长急剧下降，16K 上下文时从 100 tok/s 跌至 \u003C10 tok/s。\n长时间运行还导致过热降频。",{"type":186,"tag":417,"props":826,"children":828},{"id":827},"供应链与规模困境",[829],{"type":192,"value":827},{"type":186,"tag":202,"props":831,"children":832},{},[833],{"type":192,"value":834},"HBM（数据中心）与 DDR5（消费端）竞争产能，RAM 价格上涨 300%。\n即使云端卸载，数十亿设备的计算需求也是巨大挑战——仅 5% 的 iOS 用户（约 1 亿）使用轻量级 Agent，\n就可能消耗相当于 Anthropic 全部的计算资源。",{"type":186,"tag":202,"props":836,"children":837},{},[838,839],{"type":192,"value":211},{"type":186,"tag":213,"props":840,"children":843},{"href":841,"rel":842},"https://martinalderson.com/posts/why-on-device-agentic-ai-cant-keep-up/",[217],[844],{"type":192,"value":845},"Why On-Device Agentic AI Can't Keep Up",{"title":178,"searchDepth":847,"depth":847,"links":848},2,[849,850,851,852,853,854,855,856,857],{"id":197,"depth":847,"text":200},{"id":232,"depth":847,"text":235},{"id":262,"depth":847,"text":265},{"id":292,"depth":847,"text":295},{"id":322,"depth":847,"text":325},{"id":352,"depth":847,"text":355},{"id":382,"depth":847,"text":385},{"id":412,"depth":847,"text":415},{"id":805,"depth":847,"text":808},"markdown","content:6.maps:_ai:foundations:architectures.md","content","6.maps/_ai/foundations/architectures.md","6.maps/_ai/foundations/architectures","md",[865,869],{"_path":866,"title":867,"description":868},"/maps/_ai/evaluation/reproducibility","Reproducibility","机器学习可重复性（Reproducibility）的核心价值与实践方法，包括随机种子固定、数据版本控制等关键实践。",{"_path":870,"title":871,"description":872},"/maps/_ai/foundations/core-concepts","AI Core Concepts","20个AI核心概念一句话速查",1772504959161]