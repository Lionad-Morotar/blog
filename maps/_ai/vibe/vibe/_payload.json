，旨在通过自然语言提示帮助开发者快速生成代码片段、自动化任务和提升编程效率。","_ai/vibe.md",{"type":183,"children":184,"toc":425},"root",[185,194,200,215,230,278,292,297,309,314,335,340,354,359,365,370,375,380,391,397,402],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"domain",[191],{"type":192,"value":193},"text","Domain",{"type":186,"tag":195,"props":196,"children":198},"h3",{"id":197},"基础配置",[199],{"type":192,"value":197},{"type":186,"tag":201,"props":202,"children":203},"ul",{},[204],{"type":186,"tag":205,"props":206,"children":207},"li",{},[208],{"type":186,"tag":209,"props":210,"children":212},"a",{"href":211},"/maps/_ai/vibe/agents-md",[213],{"type":192,"value":214},"agents.md",{"type":186,"tag":216,"props":217,"children":219},"h4",{"id":218},"编写-agentsmd-的关键要点",[220,222,228],{"type":192,"value":221},"编写 ",{"type":186,"tag":223,"props":224,"children":226},"code",{"className":225},[],[227],{"type":192,"value":214},{"type":192,"value":229}," 的关键要点？",{"type":186,"tag":201,"props":231,"children":232},{},[233,238,243,248,253,258,263,268,273],{"type":186,"tag":205,"props":234,"children":235},{},[236],{"type":192,"value":237},"CLAUDE.md 是每次会话默认载入的文件，用来在编码代理启动时把代码库信息传给 Claude。",{"type":186,"tag":205,"props":239,"children":240},{},[241],{"type":192,"value":242},"LLM 本质上无状态，代理一开始对代码库一无所知。",{"type":186,"tag":205,"props":244,"children":245},{},[246],{"type":192,"value":247},"CLAUDE.md 应只包含“WHAT/WHY/HOW”：技术栈、项目结构、目的以及如何运行测试等。",{"type":186,"tag":205,"props":249,"children":250},{},[251],{"type":192,"value":252},"避免把所有命令和风格规范塞进去，LLM 能跟随的指令数有限（≈150‑200）。",{"type":186,"tag":205,"props":254,"children":255},{},[256],{"type":192,"value":257},"保持文件短小，最好 \u003C300 行；更短越好。",{"type":186,"tag":205,"props":259,"children":260},{},[261],{"type":192,"value":262},"使用渐进式披露：把任务专属说明拆成单独 Markdown，CLAUDE.md 只列出指向并让 Claude 决定是否读取。",{"type":186,"tag":205,"props":264,"children":265},{},[266],{"type":192,"value":267},"别把代码风格规则放进 CLAUDE.md；让 linters/formatters 处理，LLM 用来写代码即可。",{"type":186,"tag":205,"props":269,"children":270},{},[271],{"type":192,"value":272},"Claude 会在系统提醒中自动忽略不相关内容，越通用的指令越有可能被采纳。",{"type":186,"tag":205,"props":274,"children":275},{},[276],{"type":192,"value":277},"切勿自动生成 CLAUDE.md；每一行都要经过精心策划，以免产生错误的实现。",{"type":186,"tag":279,"props":280,"children":281},"p",{},[282,284],{"type":192,"value":283},"见：",{"type":186,"tag":209,"props":285,"children":289},{"href":286,"rel":287},"https://www.humanlayer.dev/blog/writing-a-good-claude-md",[288],"nofollow",[290],{"type":192,"value":291},"Writing a good CLAUDE.md",{"type":186,"tag":195,"props":293,"children":295},{"id":294},"规模化",[296],{"type":192,"value":294},{"type":186,"tag":201,"props":298,"children":299},{},[300],{"type":186,"tag":205,"props":301,"children":302},{},[303],{"type":186,"tag":209,"props":304,"children":306},{"href":305},"/maps/_ai/vibe/team-of-agents",[307],{"type":192,"value":308},"Team of Agents",{"type":186,"tag":195,"props":310,"children":312},{"id":311},"持续集成",[313],{"type":192,"value":311},{"type":186,"tag":201,"props":315,"children":316},{},[317,326],{"type":186,"tag":205,"props":318,"children":319},{},[320],{"type":186,"tag":209,"props":321,"children":323},{"href":322},"/maps/_ai/vibe/anchoring",[324],{"type":192,"value":325},"Anchoring coding agents to a ref application",{"type":186,"tag":205,"props":327,"children":328},{},[329],{"type":186,"tag":209,"props":330,"children":332},{"href":331},"/maps/_ai/vibe/complacency",[333],{"type":192,"value":334},"Complacency in AI-assisted coding",{"type":186,"tag":195,"props":336,"children":338},{"id":337},"设计思维",[339],{"type":192,"value":337},{"type":186,"tag":201,"props":341,"children":342},{},[343],{"type":186,"tag":205,"props":344,"children":345},{},[346,352],{"type":186,"tag":209,"props":347,"children":349},{"href":348},"/maps/_ai/vibe/playful-ai",[350],{"type":192,"value":351},"玩具化设计思维",{"type":192,"value":353}," - 将复杂 AI 能力转化为情感化、游戏化体验",{"type":186,"tag":195,"props":355,"children":357},{"id":356},"暗面与风险",[358],{"type":192,"value":356},{"type":186,"tag":216,"props":360,"children":362},{"id":361},"vibescammingai-降低了诈骗的技术门槛",[363],{"type":192,"value":364},"VibeScamming：AI 降低了诈骗的技术门槛",{"type":186,"tag":279,"props":366,"children":367},{},[368],{"type":192,"value":369},"Vibe coding 不仅被用于正当开发，也正被滥用为\"VibeScamming\"——\n利用 AI 工具几乎零技术门槛地创建专业级垃圾邮件和诈骗方案。",{"type":186,"tag":279,"props":371,"children":372},{},[373],{"type":192,"value":374},"诈骗者只需几个提示词，就能生成窃取信用卡信息、钓鱼 Office365 凭证等的完整方案。\nAnthropic 的报告指出，即使是\"无代码\"的勒索软件，现在也能由完全不会编程的人通过 LLM 构建，并以高达 1200 美元的价格出售。",{"type":186,"tag":279,"props":376,"children":377},{},[378],{"type":192,"value":379},"这种趋势带来了双重问题：垃圾邮件的视觉质量提升使传统识别方法失效；\n而 vibe-coded 应用的特定视觉风格（过多的 chrome、颜色和表情符号）\n反而可能让正当的 AI 辅助开发作品看起来不可信。",{"type":186,"tag":279,"props":381,"children":382},{},[383,384],{"type":192,"value":283},{"type":186,"tag":209,"props":385,"children":388},{"href":386,"rel":387},"https://tedium.co/2026/02/25/vibe-coded-email-spam/",[288],[389],{"type":192,"value":390},"Why Email Spam Looks Better Than Usual These Days",{"type":186,"tag":187,"props":392,"children":394},{"id":393},"links",[395],{"type":192,"value":396},"Links",{"type":186,"tag":216,"props":398,"children":400},{"id":399},"余额查询",[401],{"type":192,"value":399},{"type":186,"tag":201,"props":403,"children":404},{},[405,415],{"type":186,"tag":205,"props":406,"children":407},{},[408],{"type":186,"tag":209,"props":409,"children":412},{"href":410,"rel":411},"https://github.com/settings/billing/budgets",[288],[413],{"type":192,"value":414},"Copilot",{"type":186,"tag":205,"props":416,"children":417},{},[418],{"type":186,"tag":209,"props":419,"children":422},{"href":420,"rel":421},"https://www.trae.ai/account-setting?user_id=7473336841417851912&username=Lionad-Morotar#usage",[288],[423],{"type":192,"value":424},"Trae",{"title":178,"searchDepth":426,"depth":426,"links":427},2,[428,436],{"id":189,"depth":426,"text":193,"children":429},[430,432,433,434,435],{"id":197,"depth":431,"text":197},3,{"id":294,"depth":431,"text":294},{"id":311,"