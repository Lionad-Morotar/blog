格式",{"type":182,"children":183,"toc":759},"root",[184,193,205,210,230,235,240,246,253,316,322,472,478,550,556,623,629,699,705],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"brief",[190],{"type":191,"value":192},"text","Brief",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197,199,203],{"type":191,"value":198},"AGENTS.md 是一种常用格式，用来向参与项目的 AI 编码代理提供说明。",{"type":185,"tag":200,"props":201,"children":202},"br",{},[],{"type":191,"value":204},"\n它本质上相当于面向代理的 README 文件，没有任何必填字段或强制格式要求，只需要使用 Markdown 即可，依赖的是基于大语言模型的编码代理去理解由人类撰写、供人阅读的指引内容。",{"type":185,"tag":194,"props":206,"children":207},{},[208],{"type":191,"value":209},"典型用途包括：",{"type":185,"tag":211,"props":212,"children":213},"ul",{},[214,220,225],{"type":185,"tag":215,"props":216,"children":217},"li",{},[218],{"type":191,"value":219},"如何在当前编码环境中使用各种工具的提示；",{"type":185,"tag":215,"props":221,"children":222},{},[223],{"type":191,"value":224},"测试相关的操作说明；",{"type":185,"tag":215,"props":226,"children":227},{},[228],{"type":191,"value":229},"管理提交（commits）时的推荐实践等。",{"type":185,"tag":194,"props":231,"children":232},{},[233],{"type":191,"value":234},"虽然各种 AI 工具有很多不同的上下文工程（context engineering）方法，但 AGENTS.md 的价值在于：它为这样一个文件建立了一个简单的约定，使其可以作为整个过程的起点。",{"type":185,"tag":194,"props":236,"children":237},{},[238],{"type":191,"value":239},"来源：技术雷达",{"type":185,"tag":186,"props":241,"children":243},{"id":242},"details",[244],{"type":191,"value":245},"Details",{"type":185,"tag":247,"props":248,"children":250},"h3",{"id":249},"_21-agentsmd-的定位与作用",[251],{"type":191,"value":252},"2.1 AGENTS.md 的定位与作用",{"type":185,"tag":254,"props":255,"children":256},"ol",{},[257,275,298],{"type":185,"tag":215,"props":258,"children":259},{},[260,262],{"type":191,"value":261},"文件本质",{"type":185,"tag":211,"props":263,"children":264},{},[265,270],{"type":185,"tag":215,"props":266,"children":267},{},[268],{"type":191,"value":269},"AGENTS.md 是面向「AI 编码代理」的项目说明文件。",{"type":185,"tag":215,"props":271,"children":272},{},[273],{"type":191,"value":274},"类似人类开发者使用的 README，但目标读者是 LLM 驱动的编码代理（或协同开发的 AI 工具）。",{"type":185,"tag":215,"props":276,"children":277},{},[278,280],{"type":191,"value":279},"设计目标",{"type":185,"tag":211,"props":281,"children":282},{},[283,288,293],{"type":185,"tag":215,"props":284,"children":285},{},[286],{"type":191,"value":287},"提供统一、可约定的入口文件，让 AI 工具在接入项目时，有一个清晰的起点。",{"type":185,"tag":215,"props":289,"children":290},{},[291],{"type":191,"value":292},"通过自然语言 + Markdown 的方式，减少对特定 schema、配置格式的依赖。",{"type":185,"tag":215,"props":294,"children":295},{},[296],{"type":191,"value":297},"把「人类对项目工作方式的经验和偏好」显式固化下来，让多代理、多工具共享。",{"type":185,"tag":215,"props":299,"children":300},{},[301,303],{"type":191,"value":302},"与其他文档的关系（类比）",{"type":185,"tag":211,"props":304,"children":305},{},[306,311],{"type":185,"tag":215,"props":307,"children":308},{},[309],{"type":191,"value":310},"与 README：README 面向人类开发者，AGENTS.md 面向 AI 代理；二者可以内容互补。",{"type":185,"tag":215,"props":312,"children":313},{},[314],{"type":191,"value":315},"与配置/提示工程文件：AGENTS.md 不替代复杂的 prompt/config，而是提供一个「通俗、统一的门牌号」。",{"type":185,"tag":247,"props":317,"children":319},{"id":318},"_22-使用场景与典型内容",[320],{"type":191,"value":321},"2.2 使用场景与典型内容",{"type":185,"tag":254,"props":323,"children":324},{},[325,361,410],{"type":185,"tag":215,"props":326,"children":327},{},[328,330],{"type":191,"value":329},"工具使用指引",{"type":185,"tag":211,"props":331,"children":332},{},[333,356],{"type":185,"tag":215,"props":334,"children":335},{},[336,338],{"type":191,"value":337},"说明项目中可用的工具链与调用方式，例如：\n",{"type":185,"tag":211,"props":339,"children":340},{},[341,346,351],{"type":185,"tag":215,"props":342,"children":343},{},[344],{"type":191,"value":345},"构建工具（如 Make、npm scripts、Gradle 等）；",{"type":185,"tag":215,"props":347,"children":348},{},[349],{"type":191,"value":350},"代码生成/分析工具；",{"type":185,"tag":215,"props":352,"children":353},{},[354],{"type":191,"value":355},"内部脚本或 CLI 工具的入口和使用方式。",{"type":185,"tag":215,"props":357,"children":358},{},[359],{"type":191,"value":360},"明确哪些操作应由 AI 自动执行，哪些需要人类开发者介入或审批。",{"type":185,"tag":215,"props":362,"children":363},{},[364,366],{"type":191,"value":365},"测试与质量控制说明",{"type":185,"tag":211,"props":367,"children":368},{},[369,374,392],{"type":185,"tag":215,"props":370,"children":371},{},[372],{"type":191,"value":373},"测试命令：如何运行单元测试、集成测试、端到端测试等。",{"type":185,"tag":215,"props":375,"children":376},{},[377,379],{"type":191,"value":378},"测试策略：\n",{"type":185,"tag":211,"props":380,"children":381},{},[382,387],{"type":185,"tag":215,"props":383,"children":384},{},[385],{"type":191,"value":386},"代码变更前后需要哪些级别的测试；",{"type":185,"tag":215,"props":388,"children":389},{},[390],{"type":191,"value":391},"什么情况下需要跑全量测试或关键路径测试。",{"type":185,"tag":215,"props":393,"children":394},{},[395,397],{"type":191,"value":396},"质量门槛约定：\n",{"type":185,"tag":211,"props":398,"children":399},{},[400,405],{"type":185,"tag":215,"props":401,"children":402},{},[403],{"type":191,"value":404},"测试失败时的处理准则；",{"type":185,"tag":215,"props":406,"children":407},{},[408],{"type":191,"value":409},"覆盖率或静态检查（lint、type check）的要求。",{"type":185,"tag":215,"props":411,"children":412},{},[413,415],{"type":191,"value":414},"提交与变更管理实践",{"type":185,"tag":211,"props":416,"children":417},{},[418,436,454],{"type":185,"tag":215,"props":419,"children":420},{},[421,423],{"type":191,"value":422},"Commit 规范：\n",{"type":185,"tag":211,"props":424,"children":425},{},[426,431],{"type":185,"tag":215,"props":427,"children":428},{},[429],{"type":191,"value":430},"Commit message 风格（如 Conventional Commits）；",{"type":185,"tag":215,"props":432,"children":433},{},[434],{"type":191,"value":435},"单次提交的粒度控制（避免过大/过小）。",{"type":185,"tag":215,"props":437,"children":438},{},[439,441],{"type":191,"value":440},"分支策略：\n",{"type":185,"tag":211,"props":442,"children":443},{},[444,449],{"type":185,"tag":215,"props":445,"children":446},{},[447],{"type":191,"value":448},"是否采用 GitFlow、Trunk-based 等；",{"type":185,"tag":215,"props":450,"children":451},{},[452],{"type":191,"value":453},"哪些分支允许自动提交，哪些只能由人类合并。",{"type":185,"tag":215,"props":455,"children":456},{},[457,459],{"type":191,"value":458},"Code review 约定：\n",{"type":185,"tag":211,"props":460,"children":461},{},[462,467],{"type":185,"tag":215,"props":463,"children":464},{},[465],{"type":191,"value":466},"AI 改动需要怎样的人类审核流程；",{"type":185,"tag":215,"props":468,"children":469},{},[470],{"type":191,"value":471},"哪些目录或模块必须有人类最终确认。",{"type":185,"tag":247,"props":473,"children":475},{"id":474},"_23-格式与灵活性",[476],{"type":191,"value":477},"2.3 格式与灵活性",{"type":185,"tag":254,"props":479,"children":480},{},[481,504],{"type":185,"tag":215,"props":482,"children":483},{},[484,486],{"type":191,"value":485},"格式要求",{"type":185,"tag":211,"props":487,"children":488},{},[489,494,499],{"type":185,"tag":215,"props":490,"children":491},{},[492],{"type":191,"value":493},"唯一硬性要求：使用 Markdown。",{"type":185,"tag":215,"props":495,"children":496},{},[497],{"type":191,"value":498},"不规定任何必填字段、章节结构或元数据格式。",{"type":185,"tag":215,"props":500,"children":501},{},[502],{"type":191,"value":503},"依赖 AI 代理对自然语言文本的理解能力，而非结构化 schema。",{"type":185,"tag":215,"props":505,"children":506},{},[507,509],{"type":191,"value":508},"内容组织建议",{"type":185,"tag":211,"props":510,"children":511},{},[512,545],{"type":185,"tag":215,"props":513,"children":514},{},[515,517],{"type":191,"value":516},"即使没有强制结构，也建议采用清晰的层次：\n",{"type":185,"tag":211,"props":518,"children":519},{},[520,525,530,535,540],{"type":185,"tag":215,"props":521,"children":522},{},[523],{"type":191,"value":524},"项目简介与目标；",{"type":185,"tag":215,"props":526,"children":527},{},[528],{"type":191,"value":529},"环境与工具；",{"type":185,"tag":215,"props":531,"children":532},{},[533],{"type":191,"value":534},"开发/生成代码约定；",{"type":185,"tag":215,"props":536,"children":537},{},[538],{"type":191,"value":539},"测试与交付流程；",{"type":185,"tag":215,"props":541,"children":542},{},[543],{"type":191,"value":544},"风险与禁止事项（例如不得触碰的目录、不能自动修改的配置）。",{"type":185,"tag":215,"props":546,"children":547},{},[548],{"type":191,"value":549},"保持简洁、可维护，避免演变为过度复杂的「文档系统」。",{"type":185,"tag":247,"props":551,"children":553},{"id":552},"_24-在上下文工程中的位置",[554],{"type":191,"value":555},"2.4 在上下文工程中的位置",{"type":185,"tag":254,"props":557,"children":558},{},[559,600],{"type":185,"tag":215,"props":560,"children":561},{},[562,564],{"type":191,"value":563},"多种上下文工程手段并存",{"type":185,"tag":211,"props":565,"children":566},{},[567,595],{"type":185,"tag":215,"props":568,"children":569},{},[570,572],{"type":191,"value":571},"现代 AI 工具通常支持：\n",{"type":185,"tag":211,"props":573,"children":574},{},[575,580,585,590],{"type":185,"tag":215,"props":576,"children":577},{},[578],{"type":191,"value":579},"系统提示（System Prompt）；",{"type":185,"tag":215,"props":581,"children":582},{},[583],{"type":191,"value":584},"工具/函数调用定义；",{"type":185,"tag":215,"props":586,"children":587},{},[588],{"type":191,"value":589},"模型配置文件；",{"type":185,"tag":215,"props":591,"children":592},{},[593],{"type":191,"value":594},"外部知识库（向量库、搜索索引）等。",{"type":185,"tag":215,"props":596,"children":597},{},[598],{"type":191,"value":599},"AGENTS.md 并不与这些方法竞争，而是提供一个通用、易识别的入口。",{"type":185,"tag":215,"props":601,"children":602},{},[603,605],{"type":191,"value":604},"AGENTS.md 的独特价值",{"type":185,"tag":211,"props":606,"children":607},{},[608,613,618],{"type":185,"tag":215,"props":609,"children":610},{},[611],{"type":191,"value":612},"轻量约定：任何项目中只要放置一个 AGENTS.md，就为 AI 工具提供了「默认入口」。",{"type":185,"tag":215,"props":614,"children":615},{},[616],{"type":191,"value":617},"人类友好：内容是「给人写的」，也完全可以被人类开发者阅读与维护。",{"type":185,"tag":215,"props":619,"children":620},{},[621],{"type":191,"value":622},"跨工具兼容：不同 LLM、不同代理框架都能识别并利用同一份文档。",{"type":185,"tag":247,"props":624,"children":626},{"id":625},"_25-对架构与团队协作的影响",[627],{"type":191,"value":628},"2.5 对架构与团队协作的影响",{"type":185,"tag":254,"props":630,"children":631},{},[632,650,681],{"type":185,"tag":215,"props":633,"children":634},{},[635,637],{"type":191,"value":636},"面向 AI 协作者的「工程规范」载体",{"type":185,"tag":211,"props":638,"children":639},{},[640,645],{"type":185,"tag":215,"props":641,"children":642},{},[643],{"type":191,"value":644},"把「团队如何与 AI 合作写代码」这一套规范沉淀在代码库中，而不是散落在口头或文档外。",{"type":185,"tag":215,"props":646,"children":647},{},[648],{"type":191,"value":649},"让 AI 在参与项目时遵循既定工程实践，降低「风格不一致」和「破坏流程」的风险。",{"type":185,"tag":215,"props":651,"children":652},{},[653,655],{"type":191,"value":654},"可演进的协同接口",{"type":185,"tag":211,"props":656,"children":657},{},[658,676],{"type":185,"tag":215,"props":659,"children":660},{},[661,663],{"type":191,"value":662},"随项目演化调整：\n",{"type":185,"tag":211,"props":664,"children":665},{},[666,671],{"type":185,"tag":215,"props":667,"children":668},{},[669],{"type":191,"value":670},"新增工具/脚本时更新 AGENTS.md；",{"type":185,"tag":215,"props":672,"children":673},{},[674],{"type":191,"value":675},"测试策略或分支策略变更时同步在此处说明。",{"type":185,"tag":215,"props":677,"children":678},{},[679],{"type":191,"value":680},"让 AGENTS.md 成为「AI 接入协议」的一部分，便于新工具、新代理直接接入。",{"type":185,"tag":215,"props":682,"children":683},{},[684,686],{"type":191,"value":685},"治理与审计",{"type":185,"tag":211,"props":687,"children":688},{},[689,694],{"type":185,"tag":215,"props":690,"children":691},{},[692],{"type":191,"value":693},"团队可以审视 AGENTS.md 中对 AI 行为的约束和授权范围，确保符合法规、合规和安全要求。",{"type":185,"tag":215,"props":695,"children":696},{},[697],{"type":191,"value":698},"为后续引入更复杂的自动化与自治代理打基础：先通过简单约定规范行为，再逐步自动化。",{"type":185,"tag":247,"props":700,"children":702},{"id":701},"_26-建议的落地实践",[703],{"type":191,"value":704},"2.6 建议的落地实践",{"type":185,"tag":254,"props":706,"children":707},{},[708,713,736,754],{"type":185,"tag":215,"props":709,"children":710},{},[711],{"type":191,"value":712},"在每个需要 AI 参与的代码仓库根目录创建 AGENTS.md。",{"type":185,"tag":215,"props":714,"children":715},{},[716,718],{"type":191,"value":717},"保持内容短小可读（首版控制在 1–2 页），强调：\n",{"type":185,"tag":211,"props":719,"children":720},{},[721,726,731],{"type":185,"tag":215,"props":722,"children":723},{},[724],{"type":191,"value":725},"项目背景与边界；",{"type":185,"tag":215,"props":727,"children":728},{},[729],{"type":191,"value":730},"最关键的工具使用方式；",{"type":185,"tag":215,"props":732,"children":733},{},[734],{"type":191,"value":735},"最不可违反的流程和限制。",{"type":185,"tag":215,"props":737,"children":738},{},[739,741],{"type":191,"value":740},"随迭代进行版本化管理：\n",{"type":185,"tag":211,"props":742,"children":743},{},[744,749],{"type":185,"tag":215,"props":745,"children":746},{},[747],{"type":191,"value":748},"每次明显变更 AI 使用方式时更新 AGENTS.md；",{"type":185,"tag":215,"props":750,"children":751},{},[752],{"type":191,"value":753},"在变更记录中注明对 AI 行为约束的变化。",{"type":185,"tag":215,"props":755,"children":756},{},[757],{"type":191,"value":758},"将 AGENTS.md 纳入代码评审范围，确保人类与 AI 对协作规则有一致理解。",{"title":178,"searchDepth":760,"depth":760,"links":761},2,[762,763],{"id":188,"depth":760,"text":192},{"id":242,"depth":760,"text":245,"children":764},[765,767,768,769,770,771],{"id":249,"depth":766,"text":252},3,{"id":318,"depth":766,"text":321},{"id":474,"depth":766,"text":477},{"id":552,"depth":766,"text":555},{"id":625,"depth":766,"text":628},{"id":701,"depth":766,"text":704},"markdown","content:6.maps:_ai:vibe:agents-md.md","content","6.maps/_ai/vibe/agents-md.md","6.maps/_ai/vibe/agents-md","md",[779,783],{"_path":780,"title":781,"description":782},"/maps/_ai/training/training","AI Training","AI 训练是指通过提供大量数据和调整模型参数，使人工智能系统能够学习和改进其性能的过程。",{"_path":784,"title":785,"description":786},"/maps/_ai/vibe/anchoring","Anchoring coding agents to a ref application","在编码代理时代，通过将其锚定至实时可编译的参考应用，有效应对代码漂移问题",1771695798526]