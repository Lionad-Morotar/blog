190,202,207,227,232,237,243,250,313,319,469,475,547,553,620,626,696,702],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"brief",[187],{"type":188,"value":189},"text","Brief",{"type":182,"tag":191,"props":192,"children":193},"p",{},[194,196,200],{"type":188,"value":195},"AGENTS.md 是一种常用格式，用来向参与项目的 AI 编码代理提供说明。",{"type":182,"tag":197,"props":198,"children":199},"br",{},[],{"type":188,"value":201},"\n它本质上相当于面向代理的 README 文件，没有任何必填字段或强制格式要求，只需要使用 Markdown 即可，依赖的是基于大语言模型的编码代理去理解由人类撰写、供人阅读的指引内容。",{"type":182,"tag":191,"props":203,"children":204},{},[205],{"type":188,"value":206},"典型用途包括：",{"type":182,"tag":208,"props":209,"children":210},"ul",{},[211,217,222],{"type":182,"tag":212,"props":213,"children":214},"li",{},[215],{"type":188,"value":216},"如何在当前编码环境中使用各种工具的提示；",{"type":182,"tag":212,"props":218,"children":219},{},[220],{"type":188,"value":221},"测试相关的操作说明；",{"type":182,"tag":212,"props":223,"children":224},{},[225],{"type":188,"value":226},"管理提交（commits）时的推荐实践等。",{"type":182,"tag":191,"props":228,"children":229},{},[230],{"type":188,"value":231},"虽然各种 AI 工具有很多不同的上下文工程（context engineering）方法，但 AGENTS.md 的价值在于：它为这样一个文件建立了一个简单的约定，使其可以作为整个过程的起点。",{"type":182,"tag":191,"props":233,"children":234},{},[235],{"type":188,"value":236},"来源：技术雷达",{"type":182,"tag":183,"props":238,"children":240},{"id":239},"details",[241],{"type":188,"value":242},"Details",{"type":182,"tag":244,"props":245,"children":247},"h3",{"id":246},"_21-agentsmd-的定位与作用",[248],{"type":188,"value":249},"2.1 AGENTS.md 的定位与作用",{"type":182,"tag":251,"props":252,"children":253},"ol",{},[254,272,295],{"type":182,"tag":212,"props":255,"children":256},{},[257,259],{"type":188,"value":258},"文件本质",{"type":182,"tag":208,"props":260,"children":261},{},[262,267],{"type":182,"tag":212,"props":263,"children":264},{},[265],{"type":188,"value":266},"AGENTS.md 是面向「AI 编码代理」的项目说明文件。",{"type":182,"tag":212,"props":268,"children":269},{},[270],{"type":188,"value":271},"类似人类开发者使用的 README，但目标读者是 LLM 驱动的编码代理（或协同开发的 AI 工具）。",{"type":182,"tag":212,"props":273,"children":274},{},[275,277],{"type":188,"value":276},"设计目标",{"type":182,"tag":208,"props":278,"children":279},{},[280,285,290],{"type":182,"tag":212,"props":281,"children":282},{},[283],{"type":188,"value":284},"提供统一、可约定的入口文件，让 AI 工具在接入项目时，有一个清晰的起点。",{"type":182,"tag":212,"props":286,"children":287},{},[288],{"type":188,"value":289},"通过自然语言 + Markdown 的方式，减少对特定 schema、配置格式的依赖。",{"type":182,"tag":212,"props":291,"children":292},{},[293],{"type":188,"value":294},"把「人类对项目工作方式的经验和偏好」显式固化下来，让多代理、多工具共享。",{"type":182,"tag":212,"props":296,"children":297},{},[298,300],{"type":188,"value":299},"与其他文档的关系（类比）",{"type":182,"tag":208,"props":301,"children":302},{},[303,308],{"type":182,"tag":212,"props":304,"children":305},{},[306],{"type":188,"value":307},"与 README：README 面向人类开发者，AGENTS.md 面向 AI 代理；二者可以内容互补。",{"type":182,"tag":212,"props":309,"children":310},{},[311],{"type":188,"value":312},"与配置/提示工程文件：AGENTS.md 不替代复杂的 prompt/config，而是提供一个「通俗、统一的门牌号」。",{"type":182,"tag":244,"props":314,"children":316},{"id":315},"_22-使用场景与典型内容",[317],{"type":188,"value":318},"2.2 使用场景与典型内容",{"type":182,"tag":251,"props":320,"children":321},{},[322,358,407],{"type":182,"tag":212,"props":323,"children":324},{},[325,327],{"type":188,"value":326},"工具使用指引",{"type":182,"tag":208,"props":328,"children":329},{},[330,353],{"type":182,"tag":212,"props":331,"children":332},{},[333,335],{"type":188,"value":334},"说明项目中可用的工具链与调用方式，例如：\n",{"type":182,"tag":208,"props":336,"children":337},{},[338,343,348],{"type":182,"tag":212,"props":339,"children":340},{},[341],{"type":188,"value":342},"构建工具（如 Make、npm scripts、Gradle 等）；",{"type":182,"tag":212,"props":344,"children":345},{},[346],{"type":188,"value":347},"代码生成/分析工具；",{"type":182,"tag":212,"props":349,"children":350},{},[351],{"type":188,"value":352},"内部脚本或 CLI 工具的入口和使用方式。",{"type":182,"tag":212,"props":354,"children":355},{},[356],{"type":188,"value":357},"明确哪些操作应由 AI 自动执行，哪些需要人类开发者介入或审批。",{"type":182,"tag":212,"props":359,"children":360},{},[361,363],{"type":188,"value":362},"测试与质量控制说明",{"type":182,"tag":208,"props":364,"children":365},{},[366,371,389],{"type":182,"tag":212,"props":367,"children":368},{},[369],{"type":188,"value":370},"测试命令：如何运行单元测试、集成测试、端到端测试等。",{"type":182,"tag":212,"props":372,"children":373},{},[374,376],{"type":188,"value":375},"测试策略：\n",{"type":182,"tag":208,"props":377,"children":378},{},[379,384],{"type":182,"tag":212,"props":380,"children":381},{},[382],{"type":188,"value":383},"代码变更前后需要哪些级别的测试；",{"type":182,"tag":212,"props":385,"children":386},{},[387],{"type":188,"value":388},"什么情况下需要跑全量测试或关键路径测试。",{"type":182,"tag":212,"props":390,"children":391},{},[392,394],{"type":188,"value":393},"质量门槛约定：\n",{"type":182,"tag":208,"props":395,"children":396},{},[397,402],{"type":182,"tag":212,"props":398,"children":399},{},[400],{"type":188,"value":401},"测试失败时的处理准则；",{"type":182,"tag":212,"props":403,"children":404},{},[405],{"type":188,"value":406},"覆盖率或静态检查（lint、type check）的要求。",{"type":182,"tag":212,"props":408,"children":409},{},[410,412],{"type":188,"value":411},"提交与变更管理实践",{"type":182,"tag":208,"props":413,"children":414},{},[415,433,451],{"type":182,"tag":212,"props":416,"children":417},{},[418,420],{"type":188,"value":419},"Commit 规范：\n",{"type":182,"tag":208,"props":421,"children":422},{},[423,428],{"type":182,"tag":212,"props":424,"children":425},{},[426],{"type":188,"value":427},"Commit message 风格（如 Conventional Commits）；",{"type":182,"tag":212,"props":429,"children":430},{},[431],{"type":188,"value":432},"单次提交的粒度控制（避免过大/过小）。",{"type":182,"tag":212,"props":434,"children":435},{},[436,438],{"type":188,"value":437},"分支策略：\n",{"type":182,"tag":208,"props":439,"children":440},{},[441,446],{"type":182,"tag":212,"props":442,"children":443},{},[444],{"type":188,"value":445},"是否采用 GitFlow、Trunk-based 等；",{"type":182,"tag":212,"props":447,"children":448},{},[449],{"type":188,"value":450},"哪些分支允许自动提交，哪些只能由人类合并。",{"type":182,"tag":212,"props":452,"children":453},{},[454,456],{"type":188,"value":455},"Code review 约定：\n",{"type":182,"tag":208,"props":457,"children":458},{},[459,464],{"type":182,"tag":212,"props":460,"children":461},{},[462],{"type":188,"value":463},"AI 改动需要怎样的人类审核流程；",{"type":182,"tag":212,"props":465,"children":466},{},[467],{"type":188,"value":468},"哪些目录或模块必须有人类最终确认。",{"type":182,"tag":244,"props":470,"children":472},{"id":471},"_23-格式与灵活性",[473],{"type":188,"value":474},"2.3 格式与灵活性",{"type":182,"tag":251,"props":476,"children":477},{},[478,501],{"type":182,"tag":212,"props":479,"children":480},{},[481,483],{"type":188,"value":482},"格式要求",{"type":182,"tag":208,"props":484,"children":485},{},[486,491,496],{"type":182,"tag":212,"props":487,"children":488},{},[489],{"type":188,"value":490},"唯一硬性要求：使用 Markdown。",{"type":182,"tag":212,"props":492,"children":493},{},[494],{"type":188,"value":495},"不规定任何必填字段、章节结构或元数据格式。",{"type":182,"tag":212,"props":497,"children":498},{},[499],{"type":188,"value":500},"依赖 AI 代理对自然语言文本的理解能力，而非结构化 schema。",{"type":182,"tag":212,"props":502,"children":503},{},[504,506],{"type":188,"value":505},"内容组织建议",{"type":182,"tag":208,"props":507,"children":508},{},[509,542],{"type":182,"tag":212,"props":510,"children":511},{},[512,514],{"type":188,"value":513},"即使没有强制结构，也建议采用清晰的层次：\n",{"type":182,"tag":208,"props":515,"children":516},{},[517,522,527,532,537],{"type":182,"tag":212,"props":518,"children":519},{},[520],{"type":188,"value":521},"项目简介与目标；",{"type":182,"tag":212,"props":523,"children":524},{},[525],{"type":188,"value":526},"环境与工具；",{"type":182,"tag":212,"props":528,"children":529},{},[530],{"type":188,"value":531},"开发/生成代码约定；",{"type":182,"tag":212,"props":533,"children":534},{},[535],{"type":188,"value":536},"测试与交付流程；",{"type":182,"tag":212,"props":538,"children":539},{},[540],{"type":188,"value":541},"风险与禁止事项（例如不得触碰的目录、不能自动修改的配置）。",{"type":182,"tag":212,"props":543,"children":544},{},[545],{"type":188,"value":546},"保持简洁、可维护，避免演变为过度复杂的「文档系统」。",{"type":182,"tag":244,"props":548,"children":550},{"id":549},"_24-在上下文工程中的位置",[551],{"type":188,"value":552},"2.4 在上下文工程中的位置",{"type":182,"tag":251,"props":554,"children":555},{},[556,597],{"type":182,"tag":212,"props":557,"children":558},{},[559,561],{"type":188,"value":560},"多种上下文工程手段并存",{"type":182,"tag":208,"props":562,"children":563},{},[564,592],{"type":182,"tag":212,"props":565,"children":566},{},[567,569],{"type":188,"value":568},"现代 AI 工具通常支持：\n",{"type":182,"tag":208,"props":570,"children":571},{},[572,577,582,587],{"type":182,"tag":212,"props":573,"children":574},{},[575],{"type":188,"value":576},"系统提示（System Prompt）；",{"type":182,"tag":212,"props":578,"children":579},{},[580],{"type":188,"value":581},"工具/函数调用定义；",{"type":182,"tag":212,"props":583,"children":584},{},[585],{"type":188,"value":586},"模型配置文件；",{"type":182,"tag":212,"props":588,"children":589},{},[590],{"type":188,"value":591},"外部知识库（向量库、搜索索引）等。",{"type":182,"tag":212,"props":593,"children":594},{},[595],{"type":188,"value":596},"AGENTS.md 并不与这些方法竞争，而是提供一个通用、易识别的入口。",{"type":182,"tag":212,"props":598,"children":599},{},[600,602],{"type":188,"value":601},"AGENTS.md 的独特价值",{"type":182,"tag":208,"props":603,"children":604},{},[605,610,615],{"type":182,"tag":212,"props":606,"children":607},{},[608],{"type":188,"value":609},"轻量约定：任何项目中只要放置一个 AGENTS.md，就为 AI 工具提供了「默认入口」。",{"type":182,"tag":212,"props":611,"children":612},{},[613],{"type":188,"value":614},"人类友好：内容是「给人写的」，也完全可以被人类开发者阅读与维护。",{"type":182,"tag":212,"props":616,"children":617},{},[618],{"type":188,"value":619},"跨工具兼容：不同 LLM、不同代理框架都能识别并利用同一份文档。",{"type":182,"tag":244,"props":621,"children":623},{"id":622},"_25-对架构与团队协作的影响",[624],{"type":188,"value":625},"2.5 对架构与团队协作的影响",{"type":182,"tag":251,"props":627,"children":628},{},[629,647,678],{"type":182,"tag":212,"props":630,"children":631},{},[632,634],{"type":188,"value":633},"面向 AI 协作者的「工程规范」载体",{"type":182,"tag":208,"props":635,"children":636},{},[637,642],{"type":182,"tag":212,"props":638,"children":639},{},[640],{"type":188,"value":641},"把「团队如何与 AI 合作写代码」这一套规范沉淀在代码库中，而不是散落在口头或文档外。",{"type":182,"tag":212,"props":643,"children":644},{},[645],{"type":188,"value":646},"让 AI 在参与项目时遵循既定工程实践，降低「风格不一致」和「破坏流程」的风险。",{"type":182,"tag":212,"props":648,"children":649},{},[650,652],{"type":188,"value":651},"可演进的协同接口",{"type":182,"tag":208,"props":653,"children":654},{},[655,673],{"type":182,"tag":212,"props":656,"children":657},{},[658,660],{"type":188,"value":659},"随项目演化调整：\n",{"type":182,"tag":208,"props":661,"children":662},{},[663,668],{"type":182,"tag":212,"props":664,"children":665},{},[666],{"type":188,"value":667},"新增工具/脚本时更新 AGENTS.md；",{"type":182,"tag":212,"props":669,"children":670},{},[671],{"type":188,"value":672},"测试策略或分支策略变更时同步在此处说明。",{"type":182,"tag":212,"props":674,"children":675},{},[676],{"type":188,"value":677},"让 AGENTS.md 成为「AI 接入协议」的一部分，便于新工具、新代理直接接入。",{"type":182,"tag":212,"props":679,"children":680},{},[681,683],{"type":188,"value":682},"治理与审计",{"type":182,"tag":208,"props":684,"children":685},{},[686,691],{"type":182,"tag":212,"props":687,"children":688},{},[689],{"type":188,"value":690},"团队可以审视 AGENTS.md 中对 AI 行为的约束和授权范围，确保符合法规、合规和安全要求。",{"type":182,"tag":212,"props":692,"children":693},{},[694],{"type":188,"value":695},"为后续引入更复杂的自动化与自治代理打基础：先通过简单约定规范行为，再逐步自动化。",{"type":182,"tag":244,"props":697,"children":699},{"id":698},"_26-建议的落地实践",[700],{"type":188,"value":701},"2.6 建议的落地实践",{"type":182,"tag":251,"props":703,"children":704},{},[705,710,733,751],{"type":182,"tag":212,"props":706,"children":707},{},[708],{"type":188,"value":709},"在每个需要 AI 参与的代码仓库根目录创建 AGENTS.md。",{"type":182,"tag":212,"props":711,"children":712},{},[713,715],{"type":188,"value":714},"保持内容短小可读（首版控制在 1–2 页），强调：\n",{"type":182,"tag":208,"props":716,"children":717},{},[718,723,728],{"type":182,"tag":212,"props":719,"children":720},{},[721],{"type":188,"value":722},"项目背景与边界；",{"type":182,"tag":212,"props":724,"children":725},{},[726],{"type":188,"value":727},"最关键的工具使用方式；",{"type":182,"tag":212,"props":729,"children":730},{},[731],{"type":188,"value":732},"最不可违反的流程和限制。",{"type":182,"tag":212,"props":734,"children":735},{},[736,738],{"type":188,"value":737},"随迭代进行版本化管理：\n",{"type":182,"tag":208,"props":739,"children":740},{},[741,746],{"type":182,"tag":212,"props":742,"children":743},{},[744],{"type":188,"value":745},"每次明显变更 AI 使用方式时更新 AGENTS.md；",{"type":182,"tag":212,"props":747,"children":748},{},[749],{"type":188,"value":750},"在变更记录中注明对 AI 行为约束的变化。",{"type":182,"tag":212,"props":752,"children":753},{},[754],{"type":188,"value":755},"将 AGENTS.md 纳入代码评审范围，确保人类与 AI 对协作规则有一致理解。",{"title":175,"searchDepth":757,"depth":757,"links":758},2,[759,760],{"id":185,"depth":757,"text":189},{"id":239,"depth":757,"text":242,"children":761},[762,764,765,766,767,768],{"id":246,"depth":763,"text":249},3,{"id":315,"depth":763,"text":318},{"id":471,"depth":763,"text":474},{"id":549,"depth":763,"text":552},{"id":622,"depth":763,"text":625},{"id":698,"depth":763,"text":701},"markdown","content:6.maps:_ai:vibe:agents-md.md","content","6.maps/_ai/vibe/agents-md.md","6.maps/_ai/vibe/agents-md","md",[776,780],{"_path":777,"title":778,"description":779},"/maps/_ai/training/training","AI Training","AI 训练是指通过提供大量数据和调整模型参数，使人工智能系统能够学习和改进其性能的过程。",{"_path":781,"title":782,"description":783},"/maps/_ai/vibe/anchoring","Anchoring coding agents to a ref application","在编码代理时代，通过将其锚定至实时可编译的参考应用，有效应对代码漂移问题",1771214948738]