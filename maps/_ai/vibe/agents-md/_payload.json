一种用于向 AI 编码代理提供说明的常用格式","_ai/vibe/agents-md.md",{"type":183,"children":184,"toc":760},"root",[185,194,206,211,231,236,241,247,254,317,323,473,479,551,557,624,630,700,706],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"brief",[191],{"type":192,"value":193},"text","Brief",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198,200,204],{"type":192,"value":199},"AGENTS.md 是一种常用格式，用来向参与项目的 AI 编码代理提供说明。",{"type":186,"tag":201,"props":202,"children":203},"br",{},[],{"type":192,"value":205},"\n它本质上相当于面向代理的 README 文件，没有任何必填字段或强制格式要求，只需要使用 Markdown 即可，依赖的是基于大语言模型的编码代理去理解由人类撰写、供人阅读的指引内容。",{"type":186,"tag":195,"props":207,"children":208},{},[209],{"type":192,"value":210},"典型用途包括：",{"type":186,"tag":212,"props":213,"children":214},"ul",{},[215,221,226],{"type":186,"tag":216,"props":217,"children":218},"li",{},[219],{"type":192,"value":220},"如何在当前编码环境中使用各种工具的提示；",{"type":186,"tag":216,"props":222,"children":223},{},[224],{"type":192,"value":225},"测试相关的操作说明；",{"type":186,"tag":216,"props":227,"children":228},{},[229],{"type":192,"value":230},"管理提交（commits）时的推荐实践等。",{"type":186,"tag":195,"props":232,"children":233},{},[234],{"type":192,"value":235},"虽然各种 AI 工具有很多不同的上下文工程（context engineering）方法，但 AGENTS.md 的价值在于：它为这样一个文件建立了一个简单的约定，使其可以作为整个过程的起点。",{"type":186,"tag":195,"props":237,"children":238},{},[239],{"type":192,"value":240},"来源：技术雷达",{"type":186,"tag":187,"props":242,"children":244},{"id":243},"details",[245],{"type":192,"value":246},"Details",{"type":186,"tag":248,"props":249,"children":251},"h3",{"id":250},"_21-agentsmd-的定位与作用",[252],{"type":192,"value":253},"2.1 AGENTS.md 的定位与作用",{"type":186,"tag":255,"props":256,"children":257},"ol",{},[258,276,299],{"type":186,"tag":216,"props":259,"children":260},{},[261,263],{"type":192,"value":262},"文件本质",{"type":186,"tag":212,"props":264,"children":265},{},[266,271],{"type":186,"tag":216,"props":267,"children":268},{},[269],{"type":192,"value":270},"AGENTS.md 是面向「AI 编码代理」的项目说明文件。",{"type":186,"tag":216,"props":272,"children":273},{},[274],{"type":192,"value":275},"类似人类开发者使用的 README，但目标读者是 LLM 驱动的编码代理（或协同开发的 AI 工具）。",{"type":186,"tag":216,"props":277,"children":278},{},[279,281],{"type":192,"value":280},"设计目标",{"type":186,"tag":212,"props":282,"children":283},{},[284,289,294],{"type":186,"tag":216,"props":285,"children":286},{},[287],{"type":192,"value":288},"提供统一、可约定的入口文件，让 AI 工具在接入项目时，有一个清晰的起点。",{"type":186,"tag":216,"props":290,"children":291},{},[292],{"type":192,"value":293},"通过自然语言 + Markdown 的方式，减少对特定 schema、配置格式的依赖。",{"type":186,"tag":216,"props":295,"children":296},{},[297],{"type":192,"value":298},"把「人类对项目工作方式的经验和偏好」显式固化下来，让多代理、多工具共享。",{"type":186,"tag":216,"props":300,"children":301},{},[302,304],{"type":192,"value":303},"与其他文档的关系（类比）",{"type":186,"tag":212,"props":305,"children":306},{},[307,312],{"type":186,"tag":216,"props":308,"children":309},{},[310],{"type":192,"value":311},"与 README：README 面向人类开发者，AGENTS.md 面向 AI 代理；二者可以内容互补。",{"type":186,"tag":216,"props":313,"children":314},{},[315],{"type":192,"value":316},"与配置/提示工程文件：AGENTS.md 不替代复杂的 prompt/config，而是提供一个「通俗、统一的门牌号」。",{"type":186,"tag":248,"props":318,"children":320},{"id":319},"_22-使用场景与典型内容",[321],{"type":192,"value":322},"2.2 使用场景与典型内容",{"type":186,"tag":255,"props":324,"children":325},{},[326,362,411],{"type":186,"tag":216,"props":327,"children":328},{},[329,331],{"type":192,"value":330},"工具使用指引",{"type":186,"tag":212,"props":332,"children":333},{},[334,357],{"type":186,"tag":216,"props":335,"children":336},{},[337,339],{"type":192,"value":338},"说明项目中可用的工具链与调用方式，例如：\n",{"type":186,"tag":212,"props":340,"children":341},{},[342,347,352],{"type":186,"tag":216,"props":343,"children":344},{},[345],{"type":192,"value":346},"构建工具（如 Make、npm scripts、Gradle 等）；",{"type":186,"tag":216,"props":348,"children":349},{},[350],{"type":192,"value":351},"代码生成/分析工具；",{"type":186,"tag":216,"props":353,"children":354},{},[355],{"type":192,"value":356},"内部脚本或 CLI 工具的入口和使用方式。",{"type":186,"tag":216,"props":358,"children":359},{},[360],{"type":192,"value":361},"明确哪些操作应由 AI 自动执行，哪些需要人类开发者介入或审批。",{"type":186,"tag":216,"props":363,"children":364},{},[365,367],{"type":192,"value":366},"测试与质量控制说明",{"type":186,"tag":212,"props":368,"children":369},{},[370,375,393],{"type":186,"tag":216,"props":371,"children":372},{},[373],{"type":192,"value":374},"测试命令：如何运行单元测试、集成测试、端到端测试等。",{"type":186,"tag":216,"props":376,"children":377},{},[378,380],{"type":192,"value":379},"测试策略：\n",{"type":186,"tag":212,"props":381,"children":382},{},[383,388],{"type":186,"tag":216,"props":384,"children":385},{},[386],{"type":192,"value":387},"代码变更前后需要哪些级别的测试；",{"type":186,"tag":216,"props":389,"children":390},{},[391],{"type":192,"value":392},"什么情况下需要跑全量测试或关键路径测试。",{"type":186,"tag":216,"props":394,"children":395},{},[396,398],{"type":192,"value":397},"质量门槛约定：\n",{"type":186,"tag":212,"props":399,"children":400},{},[401,406],{"type":186,"tag":216,"props":402,"children":403},{},[404],{"type":192,"value":405},"测试失败时的处理准则；",{"type":186,"tag":216,"props":407,"children":408},{},[409],{"type":192,"value":410},"覆盖率或静态检查（lint、type check）的要求。",{"type":186,"tag":216,"props":412,"children":413},{},[414,416],{"type":192,"value":415},"提交与变更管理实践",{"type":186,"tag":212,"props":417,"children":418},{},[419,437,455],{"type":186,"tag":216,"props":420,"children":421},{},[422,424],{"type":192,"value":423},"Commit 规范：\n",{"type":186,"tag":212,"props":425,"children":426},{},[427,432],{"type":186,"tag":216,"props":428,"children":429},{},[430],{"type":192,"value":431},"Commit message 风格（如 Conventional Commits）；",{"type":186,"tag":216,"props":433,"children":434},{},[435],{"type":192,"value":436},"单次提交的粒度控制（避免过大/过小）。",{"type":186,"tag":216,"props":438,"children":439},{},[440,442],{"type":192,"value":441},"分支策略：\n",{"type":186,"tag":212,"props":443,"children":444},{},[445,450],{"type":186,"tag":216,"props":446,"children":447},{},[448],{"type":192,"value":449},"是否采用 GitFlow、Trunk-based 等；",{"type":186,"tag":216,"props":451,"children":452},{},[453],{"type":192,"value":454},"哪些分支允许自动提交，哪些只能由人类合并。",{"type":186,"tag":216,"props":456,"children":457},{},[458,460],{"type":192,"value":459},"Code review 约定：\n",{"type":186,"tag":212,"props":461,"children":462},{},[463,468],{"type":186,"tag":216,"props":464,"children":465},{},[466],{"type":192,"value":467},"AI 改动需要怎样的人类审核流程；",{"type":186,"tag":216,"props":469,"children":470},{},[471],{"type":192,"value":472},"哪些目录或模块必须有人类最终确认。",{"type":186,"tag":248,"props":474,"children":476},{"id":475},"_23-格式与灵活性",[477],{"type":192,"value":478},"2.3 格式与灵活性",{"type":186,"tag":255,"props":480,"children":481},{},[482,505],{"type":186,"tag":216,"props":483,"children":484},{},[485,487],{"type":192,"value":486},"格式要求",{"type":186,"tag":212,"props":488,"children":489},{},[490,495,500],{"type":186,"tag":216,"props":491,"children":492},{},[493],{"type":192,"value":494},"唯一硬性要求：使用 Markdown。",{"type":186,"tag":216,"props":496,"children":497},{},[498],{"type":192,"value":499},"不规定任何必填字段、章节结构或元数据格式。",{"type":186,"tag":216,"props":501,"children":502},{},[503],{"type":192,"value":504},"依赖 AI 代理对自然语言文本的理解能力，而非结构化 schema。",{"type":186,"tag":216,"props":506,"children":507},{},[508,510],{"type":192,"value":509},"内容组织建议",{"type":186,"tag":212,"props":511,"children":512},{},[513,546],{"type":186,"tag":216,"props":514,"children":515},{},[516,518],{"type":192,"value":517},"即使没有强制结构，也建议采用清晰的层次：\n",{"type":186,"tag":212,"props":519,"children":520},{},[521,526,531,536,541],{"type":186,"tag":216,"props":522,"children":523},{},[524],{"type":192,"value":525},"项目简介与目标；",{"type":186,"tag":216,"props":527,"children":528},{},[529],{"type":192,"value":530},"环境与工具；",{"type":186,"tag":216,"props":532,"children":533},{},[534],{"type":192,"value":535},"开发/生成代码约定；",{"type":186,"tag":216,"props":537,"children":538},{},[539],{"type":192,"value":540},"测试与交付流程；",{"type":186,"tag":216,"props":542,"children":543},{},[544],{"type":192,"value":545},"风险与禁止事项（例如不得触碰的目录、不能自动修改的配置）。",{"type":186,"tag":216,"props":547,"children":548},{},[549],{"type":192,"value":550},"保持简洁、可维护，避免演变为过度复杂的「文档系统」。",{"type":186,"tag":248,"props":552,"children":554},{"id":553},"_24-在上下文工程中的位置",[555],{"type":192,"value":556},"2.4 在上下文工程中的位置",{"type":186,"tag":255,"props":558,"children":559},{},[560,601],{"type":186,"tag":216,"props":561,"children":562},{},[563,565],{"type":192,"value":564},"多种上下文工程手段并存",{"type":186,"tag":212,"props":566,"children":567},{},[568,596],{"type":186,"tag":216,"props":569,"children":570},{},[571,573],{"type":192,"value":572},"现代 AI 工具通常支持：\n",{"type":186,"tag":212,"props":574,"children":575},{},[576,581,586,591],{"type":186,"tag":216,"props":577,"children":578},{},[579],{"type":192,"value":580},"系统提示（System Prompt）；",{"type":186,"tag":216,"props":582,"children":583},{},[584],{"type":192,"value":585},"工具/函数调用定义；",{"type":186,"tag":216,"props":587,"children":588},{},[589],{"type":192,"value":590},"模型配置文件；",{"type":186,"tag":216,"props":592,"children":593},{},[594],{"type":192,"value":595},"外部知识库（向量库、搜索索引）等。",{"type":186,"tag":216,"props":597,"children":598},{},[599],{"type":192,"value":600},"AGENTS.md 并不与这些方法竞争，而是提供一个通用、易识别的入口。",{"type":186,"tag":216,"props":602,"children":603},{},[604,606],{"type":192,"value":605},"AGENTS.md 的独特价值",{"type":186,"tag":212,"props":607,"children":608},{},[609,614,619],{"type":186,"tag":216,"props":610,"children":611},{},[612],{"type":192,"value":613},"轻量约定：任何项目中只要放置一个 AGENTS.md，就为 AI 工具提供了「默认入口」。",{"type":186,"tag":216,"props":615,"children":616},{},[617],{"type":192,"value":618},"人类友好：内容是「给人写的」，也完全可以被人类开发者阅读与维护。",{"type":186,"tag":216,"props":620,"children":621},{},[622],{"type":192,"value":623},"跨工具兼容：不同 LLM、不同代理框架都能识别并利用同一份文档。",{"type":186,"tag":248,"props":625,"children":627},{"id":626},"_25-对架构与团队协作的影响",[628],{"type":192,"value":629},"2.5 对架构与团队协作的影响",{"type":186,"tag":255,"props":631,"children":632},{},[633,651,682],{"type":186,"tag":216,"props":634,"children":635},{},[636,638],{"type":192,"value":637},"面向 AI 协作者的「工程规范」载体",{"type":186,"tag":212,"props":639,"children":640},{},[641,646],{"type":186,"tag":216,"props":642,"children":643},{},[644],{"type":192,"value":645},"把「团队如何与 AI 合作写代码」这一套规范沉淀在代码库中，而不是散落在口头或文档外。",{"type":186,"tag":216,"props":647,"children":648},{},[649],{"type":192,"value":650},"让 AI 在参与项目时遵循既定工程实践，降低「风格不一致」和「破坏流程」的风险。",{"type":186,"tag":216,"props":652,"children":653},{},[654,656],{"type":192,"value":655},"可演进的协同接口",{"type":186,"tag":212,"props":657,"children":658},{},[659,677],{"type":186,"tag":216,"props":660,"children":661},{},[662,664],{"type":192,"value":663},"随项目演化调整：\n",{"type":186,"tag":212,"props":665,"children":666},{},[667,672],{"type":186,"tag":216,"props":668,"children":669},{},[670],{"type":192,"value":671},"新增工具/脚本时更新 AGENTS.md；",{"type":186,"tag":216,"props":673,"children":674},{},[675],{"type":192,"value":676},"测试策略或分支策略变更时同步在此处说明。",{"type":186,"tag":216,"props":678,"children":679},{},[680],{"type":192,"value":681},"让 AGENTS.md 成为「AI 接入协议」的一部分，便于新工具、新代理直接接入。",{"type":186,"tag":216,"props":683,"children":684},{},[685,687],{"type":192,"value":686},"治理与审计",{"type":186,"tag":212,"props":688,"children":689},{},[690,695],{"type":186,"tag":216,"props":691,"children":692},{},[693],{"type":192,"value":694},"团队可以审视 AGENTS.md 中对 AI 行为的约束和授权范围，确保符合法规、合规和安全要求。",{"type":186,"tag":216,"props":696,"children":697},{},[698],{"type":192,"value":699},"为后续引入更复杂的自动化与自治代理打基础：先通过简单约定规范行为，再逐步自动化。",{"type":186,"tag":248,"props":701,"children":703},{"id":702},"_26-建议的落地实践",[704],{"type":192,"value":705},"2.6 建议的落地实践",{"type":186,"tag":255,"props":707,"children":708},{},[709,714,737,755],{"type":186,"tag":216,"props":710,"children":711},{},[712],{"type":192,"value":713},"在每个需要 AI 参与的代码仓库根目录创建 AGENTS.md。",{"type":186,"tag":216,"props":715,"children":716},{},[717,719],{"type":192,"value":718},"保持内容短小可读（首版控制在 1–2 页），强调：\n",{"type":186,"tag":212,"props":720,"children":721},{},[722,727,732],{"type":186,"tag":216,"props":723,"children":724},{},[725],{"type":192,"value":726},"项目背景与边界；",{"type":186,"tag":216,"props":728,"children":729},{},[730],{"type":192,"value":731},"最关键的工具使用方式；",{"type":186,"tag":216,"props":733,"children":734},{},[735],{"type":192,"value":736},"最不可违反的流程和限制。",{"type":186,"tag":216,"props":738,"children":739},{},[740,742],{"type":192,"value":741},"随迭代进行版本化管理：\n",{"type":186,"tag":212,"props":743,"children":744},{},[745,750],{"type":186,"tag":216,"props":746,"children":747},{},[748],{"type":192,"value":749},"每次明显变更 AI 使用方式时更新 AGENTS.md；",{"type":186,"tag":216,"props":751,"children":752},{},[753],{"type":192,"value":754},"在变更记录中注明对 AI 行为约束的变化。",{"type":186,"tag":216,"props":756,"children":757},{},[758],{"type":192,"value":759},"将 AGENTS.md 纳入代码评审范围，确保人类与 AI 对协作规则有一致理解。",{"title":178,"searchDepth":761,"depth":761,"links":762},2,[763,764],{"id":189,"depth":761,"text":193},{"id":243,"depth":761,"text":246,"children":765},[766,768,769,770,771,772],{"id":250,"depth":767,"text":253},3,{"id":319,"depth":767,"text":322},{"id":475,"depth":767,"text":478},{"id":553,"depth":767,"text":556},{"id":626,"depth":767,"text":629},{"id":702,"depth":767,"text":705},"markdown","content:6.maps:_ai:vibe:agents-md.md","content","6.maps/_ai/vibe/agents-md.md","6.maps/_ai/vibe/agents-md","md",[780,784],{"_path":781,"title":782,"description":783},"/maps/_ai/training/training","AI Training","Model training, fine-tuning, and post-training techniques",{"_path":785,"title":786,"description":787},"/maps/_ai/vibe/anchoring","Anchoring coding agents to a ref application","在编码代理时代，通过将其锚定至实时可编译的参考应用，有效应对代码漂移问题",1772185473676]