_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133,"children":134},"造物 / Make","/tools",[135,137,140,143,146,149,152],{"title":136,"_path":133},"🧰 工具收集",{"title":138,"_path":139},"📕 博客","/tools/blog",{"title":141,"_path":142},"🥥 Coconut","/tools/coconut",{"title":144,"_path":145},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":147,"_path":148},"🌐 AnySort","/tools/anysort",{"title":150,"_path":151},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":153,"_path":154},"👓 Crapto","/tools/crypto-inline",{"title":156,"_path":157,"children":158},"我 / About","/hire",[159],{"title":160,"_path":157},"📬 技术简历",{"title":162,"_path":163,"children":164},"En","/en",[165],{"title":166,"_path":167,"children":168},"🦁 Welcome","/en/articles",[169],{"title":166,"_path":167},{"_path":171,"_dir":172,"_draft":173,"_partial":174,"_locale":175,"title":176,"description":177,"body":178,"_type":1263,"_id":1264,"_source":1265,"_file":1266,"_stem":1267,"_extension":1268},"/maps/_ai/vibe/complacency","vibe",false,true,"","对 AI 生成代码“惰性依赖”的警惕与治理","AI 编程助手提高效率的同时，会放大重复代码、代码 churn 和审查难度，需要用工程实践和流程设计来对冲“惰性依赖”风险。",{"type":179,"children":180,"toc":1250},"root",[181,190,204,269,274,280,287,294,345,350,356,420,430,434,440,446,451,515,526,532,603,606,612,618,623,652,657,689,699,705,710,735,740,758,761,767,773,778,801,806,829,835,840,889,892,898,904,909,940,946,993,996,1002,1008,1018,1023,1062,1068,1080,1127,1138,1144,1149,1191,1197,1202,1220,1225,1238],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"brief",[187],{"type":188,"value":189},"text","Brief",{"type":182,"tag":191,"props":192,"children":193},"p",{},[194,196,202],{"type":188,"value":195},"对 AI 编程助手和代理（agents）的研究和实践逐渐暴露出一个结构性问题：",{"type":182,"tag":197,"props":198,"children":199},"strong",{},[200],{"type":188,"value":201},"随着使用时间增加，代码质量容易因为“惰性依赖”（complacency）而下滑",{"type":188,"value":203},"。",{"type":182,"tag":205,"props":206,"children":207},"ul",{},[208,227,245],{"type":182,"tag":209,"props":210,"children":211},"li",{},[212,214],{"type":188,"value":213},"实证信号：\n",{"type":182,"tag":205,"props":215,"children":216},{},[217,222],{"type":182,"tag":209,"props":218,"children":219},{},[220],{"type":188,"value":221},"GitClear 2024 研究发现，重复代码和代码 churn 的增长超出预期，而提交历史中的重构活动在减少。",{"type":182,"tag":209,"props":223,"children":224},{},[225],{"type":188,"value":226},"微软针对知识工作者的研究表明：AI 帮助带来的“信心提升”，往往以“批判性思考能力下降”为代价；在长期使用编程助手后，这种惰性思考会明显加剧。",{"type":182,"tag":209,"props":228,"children":229},{},[230,232],{"type":188,"value":231},"机制上：\n",{"type":182,"tag":205,"props":233,"children":234},{},[235,240],{"type":182,"tag":209,"props":236,"children":237},{},[238],{"type":188,"value":239},"AI 代理可以一次性生成更大规模的改动集（large change sets），人工 review 成本和难度上升，问题更难被及时发现。",{"type":182,"tag":209,"props":241,"children":242},{},[243],{"type":188,"value":244},"加速了“写代码”这一步，就隐性地对“审查、测试、重构”等后续环节施加压力，如果不做制度化补偿，整体质量会被侵蚀。",{"type":182,"tag":209,"props":246,"children":247},{},[248,250],{"type":188,"value":249},"应对建议（来自原文）：\n",{"type":182,"tag":205,"props":251,"children":252},{},[253,264],{"type":182,"tag":209,"props":254,"children":255},{},[256,258,263],{"type":188,"value":257},"在生产环境中有效使用 AI，需要",{"type":182,"tag":197,"props":259,"children":260},{},[261],{"type":188,"value":262},"重新强化代码质量意识和实践",{"type":188,"value":203},{"type":182,"tag":209,"props":265,"children":266},{},[267],{"type":188,"value":268},"尤其是将 TDD、静态分析等既有工程实践重新嵌入到编码工作流中，例如通过针对软件团队的“共享指令集”（curated shared instructions）来固化这些约束与规范。",{"type":182,"tag":191,"props":270,"children":271},{},[272],{"type":188,"value":273},"来源：技术雷达",{"type":182,"tag":183,"props":275,"children":277},{"id":276},"details",[278],{"type":188,"value":279},"Details",{"type":182,"tag":281,"props":282,"children":284},"h3",{"id":283},"一背景与现状从提效工具到系统性质量压力",[285],{"type":188,"value":286},"一、背景与现状：从“提效工具”到“系统性质量压力”",{"type":182,"tag":288,"props":289,"children":291},"h4",{"id":290},"_11-技术与业务场景ai-编程从辅助走向代理",[292],{"type":188,"value":293},"1.1 技术与业务场景：AI 编程从辅助走向代理",{"type":182,"tag":205,"props":295,"children":296},{},[297,320],{"type":182,"tag":209,"props":298,"children":299},{},[300,302],{"type":188,"value":301},"典型使用场景：\n",{"type":182,"tag":205,"props":303,"children":304},{},[305,310,315],{"type":182,"tag":209,"props":306,"children":307},{},[308],{"type":188,"value":309},"日常编码中使用 Copilot 类助手补全和生成函数、测试。",{"type":182,"tag":209,"props":311,"children":312},{},[313],{"type":188,"value":314},"通过自然语言需求驱动 agent 生成多个文件、跨模块改动。",{"type":182,"tag":209,"props":316,"children":317},{},[318],{"type":188,"value":319},"在原型开发、绿地项目中，用 AI 快速跑通端到端 demo。",{"type":182,"tag":209,"props":321,"children":322},{},[323,325],{"type":188,"value":324},"背景趋势：\n",{"type":182,"tag":205,"props":326,"children":327},{},[328,333],{"type":182,"tag":209,"props":329,"children":330},{},[331],{"type":188,"value":332},"早期共识是“AI 编码主要是提效工具”，风险更多被视为局部的、可控的。",{"type":182,"tag":209,"props":334,"children":335},{},[336,338,343],{"type":188,"value":337},"随着 AI 的覆盖范围从“补全几行代码”扩展到“生成大规模改动集”，其对",{"type":182,"tag":197,"props":339,"children":340},{},[341],{"type":188,"value":342},"整体工程系统",{"type":188,"value":344},"的影响被显著放大。",{"type":182,"tag":191,"props":346,"children":347},{},[348],{"type":188,"value":349},"这也意味着：对 AI 的评估不能只看“开发速度”，需要把“演进后的代码库形态”和“团队认知习惯的改变”也纳入考量。",{"type":182,"tag":288,"props":351,"children":353},{"id":352},"_12-研究发现效率收益与质量退化并存",[354],{"type":188,"value":355},"1.2 研究发现：效率收益与质量退化并存",{"type":182,"tag":205,"props":357,"children":358},{},[359,391],{"type":182,"tag":209,"props":360,"children":361},{},[362,364],{"type":188,"value":363},"GitClear 2024：\n",{"type":182,"tag":205,"props":365,"children":366},{},[367,379],{"type":182,"tag":209,"props":368,"children":369},{},[370,372,377],{"type":188,"value":371},"观察到**重复代码（duplication）",{"type":182,"tag":197,"props":373,"children":374},{},[375],{"type":188,"value":376},"和",{"type":188,"value":378},"代码 churn（短期内频繁增删改的代码）**显著上升。",{"type":182,"tag":209,"props":380,"children":381},{},[382,384,389],{"type":188,"value":383},"与此对照，",{"type":182,"tag":197,"props":385,"children":386},{},[387],{"type":188,"value":388},"重构类提交占比下降",{"type":188,"value":390},"，说明许多“第一次写得差不多就算了”的代码，没有被系统性打磨。",{"type":182,"tag":209,"props":392,"children":393},{},[394,396],{"type":188,"value":395},"微软对知识工作者的研究：\n",{"type":182,"tag":205,"props":397,"children":398},{},[399,404,415],{"type":182,"tag":209,"props":400,"children":401},{},[402],{"type":188,"value":403},"AI 使得个体在完成任务时**“自我感知的信心”上升**。",{"type":182,"tag":209,"props":405,"children":406},{},[407,409,414],{"type":188,"value":408},"但在可测量的指标上，",{"type":182,"tag":197,"props":410,"children":411},{},[412],{"type":188,"value":413},"批判性审查和深度思考的投入反而减少",{"type":188,"value":203},{"type":182,"tag":209,"props":416,"children":417},{},[418],{"type":188,"value":419},"长期使用编程助手后，团队中这种“有答案就不再往下问”的惰性模式会更明显。",{"type":182,"tag":191,"props":421,"children":422},{},[423,425],{"type":188,"value":424},"对技术负责人来说，这些信号指向的是：",{"type":182,"tag":197,"props":426,"children":427},{},[428],{"type":188,"value":429},"AI 的“提效收益”会与“认知松懈”叠加，最终体现在存量代码质量的慢性恶化上。",{"type":182,"tag":431,"props":432,"children":433},"hr",{},[],{"type":182,"tag":281,"props":435,"children":437},{"id":436},"二问题与风险惰性依赖的技术与组织后果",[438],{"type":188,"value":439},"二、问题与风险：惰性依赖的技术与组织后果",{"type":182,"tag":288,"props":441,"children":443},{"id":442},"_21-代码层面的结构性退化",[444],{"type":188,"value":445},"2.1 代码层面的结构性退化",{"type":182,"tag":191,"props":447,"children":448},{},[449],{"type":188,"value":450},"在广泛使用 AI 编码助手/代理的团队中，常见的风险模式包括：",{"type":182,"tag":205,"props":452,"children":453},{},[454,479,497],{"type":182,"tag":209,"props":455,"children":456},{},[457,459],{"type":188,"value":458},"重复与散乱：\n",{"type":182,"tag":205,"props":460,"children":461},{},[462,467],{"type":182,"tag":209,"props":463,"children":464},{},[465],{"type":188,"value":466},"AI 为了“就近满足上下文需求”，倾向于复制相似逻辑，而不是抽象复用。",{"type":182,"tag":209,"props":468,"children":469},{},[470,472,477],{"type":188,"value":471},"结果是：",{"type":182,"tag":197,"props":473,"children":474},{},[475],{"type":188,"value":476},"功能上线更快",{"type":188,"value":478},"，但后续修 bug / 改需求时维护成本急剧上升。",{"type":182,"tag":209,"props":480,"children":481},{},[482,484],{"type":188,"value":483},"短期 churn 增加：\n",{"type":182,"tag":205,"props":485,"children":486},{},[487,492],{"type":182,"tag":209,"props":488,"children":489},{},[490],{"type":188,"value":491},"开发者更容易“先让它写一版再说”，产生大量低质量试验性代码。",{"type":182,"tag":209,"props":493,"children":494},{},[495],{"type":188,"value":496},"如果缺乏严格的 review / 清理机制，这些“实验产物”往往残留在主干代码库。",{"type":182,"tag":209,"props":498,"children":499},{},[500,502],{"type":188,"value":501},"重构意愿降低：\n",{"type":182,"tag":205,"props":503,"children":504},{},[505,510],{"type":182,"tag":209,"props":506,"children":507},{},[508],{"type":188,"value":509},"由于“复制修一份就能过需求”，团队对“抽象、整合、简化”的内在动力被稀释。",{"type":182,"tag":209,"props":511,"children":512},{},[513],{"type":188,"value":514},"体现在数据上，就是重构型提交在整个提交历史中的占比下降。",{"type":182,"tag":191,"props":516,"children":517},{},[518,520,525],{"type":188,"value":519},"这些现象并不是 AI 独有，而是",{"type":182,"tag":197,"props":521,"children":522},{},[523],{"type":188,"value":524},"人类长期就存在的问题被放大加速",{"type":188,"value":203},{"type":182,"tag":288,"props":527,"children":529},{"id":528},"_22-认知与流程层面的惰性",[530],{"type":188,"value":531},"2.2 认知与流程层面的惰性",{"type":182,"tag":205,"props":533,"children":534},{},[535,553,571],{"type":182,"tag":209,"props":536,"children":537},{},[538,540],{"type":188,"value":539},"过度信任模型输出：\n",{"type":182,"tag":205,"props":541,"children":542},{},[543,548],{"type":182,"tag":209,"props":544,"children":545},{},[546],{"type":188,"value":547},"“AI 写的看起来没问题”常常替代了“我真的理解了代码意图和边界”。",{"type":182,"tag":209,"props":549,"children":550},{},[551],{"type":188,"value":552},"评审被动化：review 流于查风格、改命名，而不是深度审查领域逻辑。",{"type":182,"tag":209,"props":554,"children":555},{},[556,558],{"type":188,"value":557},"拆解问题的能力退化：\n",{"type":182,"tag":205,"props":559,"children":560},{},[561,566],{"type":182,"tag":209,"props":562,"children":563},{},[564],{"type":188,"value":565},"在“提示-生成-接受”的循环中，工程师容易跳过需求澄清、边界定义、建模等关键思考步骤。",{"type":182,"tag":209,"props":567,"children":568},{},[569],{"type":188,"value":570},"长期来看，团队的“架构思维密度”和“问题分解能力”都会受损。",{"type":182,"tag":209,"props":572,"children":573},{},[574,576],{"type":188,"value":575},"流程瓶颈挤压：\n",{"type":182,"tag":205,"props":577,"children":578},{},[579,591],{"type":182,"tag":209,"props":580,"children":581},{},[582,584,589],{"type":188,"value":583},"写代码明显加速后，",{"type":182,"tag":197,"props":585,"children":586},{},[587],{"type":188,"value":588},"测试、review、上线评估",{"type":188,"value":590},"成为新的瓶颈。",{"type":182,"tag":209,"props":592,"children":593},{},[594,596,601],{"type":188,"value":595},"如果组织不主动“抬升”这些环节的工程能力，",{"type":182,"tag":197,"props":597,"children":598},{},[599],{"type":188,"value":600},"就会自发削弱它们的标准",{"type":188,"value":602},"，以适配更快的提交节奏。",{"type":182,"tag":431,"props":604,"children":605},{},[],{"type":182,"tag":281,"props":607,"children":609},{"id":608},"三模式与原理从快写到系统配平",[610],{"type":188,"value":611},"三、模式与原理：从“快写”到“系统配平”",{"type":182,"tag":288,"props":613,"children":615},{"id":614},"_31-速度质量认知负载的再平衡",[616],{"type":188,"value":617},"3.1 速度—质量—认知负载的再平衡",{"type":182,"tag":191,"props":619,"children":620},{},[621],{"type":188,"value":622},"可以把 AI 编码工具视为在“实现代码”环节上强行压缩了周期：",{"type":182,"tag":205,"props":624,"children":625},{},[626,639],{"type":182,"tag":209,"props":627,"children":628},{},[629,631],{"type":188,"value":630},"过去：\n",{"type":182,"tag":205,"props":632,"children":633},{},[634],{"type":182,"tag":209,"props":635,"children":636},{},[637],{"type":188,"value":638},"需求澄清 → 设计 → 手写代码 → 手写测试 → review & 重构",{"type":182,"tag":209,"props":640,"children":641},{},[642,644],{"type":188,"value":643},"现在（AI 辅助）：\n",{"type":182,"tag":205,"props":645,"children":646},{},[647],{"type":182,"tag":209,"props":648,"children":649},{},[650],{"type":188,"value":651},"需求描述 → prompt → 一次生成大量代码 + 测试样例 → 轻量 review → merge",{"type":182,"tag":191,"props":653,"children":654},{},[655],{"type":188,"value":656},"如果其他环节不做调整，典型后果包括：",{"type":182,"tag":205,"props":658,"children":659},{},[660,672,684],{"type":182,"tag":209,"props":661,"children":662},{},[663,665,670],{"type":188,"value":664},"代码审查阶段：",{"type":182,"tag":197,"props":666,"children":667},{},[668],{"type":188,"value":669},"diff 过大",{"type":188,"value":671},"，reviewer 很难逐行理解和验证。",{"type":182,"tag":209,"props":673,"children":674},{},[675,677,682],{"type":188,"value":676},"测试阶段：",{"type":182,"tag":197,"props":678,"children":679},{},[680],{"type":188,"value":681},"测试覆盖和质量“被动接受”模型输出",{"type":188,"value":683},"，而非由工程师主动设计。",{"type":182,"tag":209,"props":685,"children":686},{},[687],{"type":188,"value":688},"演进阶段：缺少重构和演化设计，代码库像“地层沉积”一样堆积。",{"type":182,"tag":191,"props":690,"children":691},{},[692,694],{"type":188,"value":693},"因此，",{"type":182,"tag":197,"props":695,"children":696},{},[697],{"type":188,"value":698},"引入 AI 的前提不是“让工程实践变轻”，而是“重新设计如何让实践在新的速度条件下依然有效”。",{"type":182,"tag":288,"props":700,"children":702},{"id":701},"_32-coding-agents-带来的巨大变更集问题",[703],{"type":188,"value":704},"3.2 Coding agents 带来的“巨大变更集”问题",{"type":182,"tag":191,"props":706,"children":707},{},[708],{"type":188,"value":709},"相对普通助手，coding agent 的突出特点是：",{"type":182,"tag":205,"props":711,"children":712},{},[713,725,730],{"type":182,"tag":209,"props":714,"children":715},{},[716,718,723],{"type":188,"value":717},"生成",{"type":182,"tag":197,"props":719,"children":720},{},[721],{"type":188,"value":722},"多文件、多模块",{"type":188,"value":724},"的改动；",{"type":182,"tag":209,"props":726,"children":727},{},[728],{"type":188,"value":729},"改动之间经常存在跨边界依赖；",{"type":182,"tag":209,"props":731,"children":732},{},[733],{"type":188,"value":734},"本质上更接近“自动化执行一个小型重构或特性开发”。",{"type":182,"tag":191,"props":736,"children":737},{},[738],{"type":188,"value":739},"这直接导致：",{"type":182,"tag":205,"props":741,"children":742},{},[743,748,753],{"type":182,"tag":209,"props":744,"children":745},{},[746],{"type":188,"value":747},"Review 复杂度从“函数级”上升到“模块/系统级”；",{"type":182,"tag":209,"props":749,"children":750},{},[751],{"type":188,"value":752},"线上回滚与故障定位难度增加——一次错误可能影响更多路径；",{"type":182,"tag":209,"props":754,"children":755},{},[756],{"type":188,"value":757},"对 CI/CD 与回归测试体系提出更高要求，否则就只能靠“运气上线”。",{"type":182,"tag":431,"props":759,"children":760},{},[],{"type":182,"tag":281,"props":762,"children":764},{"id":763},"四对比与演进ai-工具前后的工程形态",[765],{"type":188,"value":766},"四、对比与演进：AI 工具前后的工程形态",{"type":182,"tag":288,"props":768,"children":770},{"id":769},"_41-传统高质量工程实践-vs-ai-加持下的新挑战",[771],{"type":188,"value":772},"4.1 传统高质量工程实践 vs AI 加持下的新挑战",{"type":182,"tag":191,"props":774,"children":775},{},[776],{"type":188,"value":777},"传统上，维持代码库长寿的关键手段包括：",{"type":182,"tag":205,"props":779,"children":780},{},[781,786,791,796],{"type":182,"tag":209,"props":782,"children":783},{},[784],{"type":188,"value":785},"TDD / 测试先行：先定行为边界，再写实现；",{"type":182,"tag":209,"props":787,"children":788},{},[789],{"type":188,"value":790},"持续重构：在功能迭代中不断整理抽象边界；",{"type":182,"tag":209,"props":792,"children":793},{},[794],{"type":188,"value":795},"静态分析与规范：对常见错误和风格问题做自动化约束；",{"type":182,"tag":209,"props":797,"children":798},{},[799],{"type":188,"value":800},"小步提交与可审查变更集。",{"type":182,"tag":191,"props":802,"children":803},{},[804],{"type":188,"value":805},"引入 AI 后，如果不做任何治理，常出现如下反差：",{"type":182,"tag":205,"props":807,"children":808},{},[809,814,819,824],{"type":182,"tag":209,"props":810,"children":811},{},[812],{"type":188,"value":813},"TDD 弱化： “AI 代码已可运行”被当作“行为已可靠”的替代。",{"type":182,"tag":209,"props":815,"children":816},{},[817],{"type":188,"value":818},"重构滞后：工程师更习惯“再复制一段新代码满足当前需求”。",{"type":182,"tag":209,"props":820,"children":821},{},[822],{"type":188,"value":823},"静态分析形同虚设：规则不更新、不针对 AI 生成模式做加强（例如检测重复逻辑、copy-paste 风险）。",{"type":182,"tag":209,"props":825,"children":826},{},[827],{"type":188,"value":828},"提交粒度变大：agent 一次性生成大变更集，破坏“小步可回滚”原则。",{"type":182,"tag":288,"props":830,"children":832},{"id":831},"_42-可能的演进方向",[833],{"type":188,"value":834},"4.2 可能的演进方向",{"type":182,"tag":191,"props":836,"children":837},{},[838],{"type":188,"value":839},"为了让 AI 真正服务于长期可维护性，可以考虑这样的演进路径：",{"type":182,"tag":205,"props":841,"children":842},{},[843,863,876],{"type":182,"tag":209,"props":844,"children":845},{},[846,848],{"type":188,"value":847},"将 AI 纳入“质量工具链”：\n",{"type":182,"tag":205,"props":849,"children":850},{},[851],{"type":182,"tag":209,"props":852,"children":853},{},[854,856,861],{"type":188,"value":855},"不是“人在上、AI 在下”，而是把 AI 作为",{"type":182,"tag":197,"props":857,"children":858},{},[859],{"type":188,"value":860},"执行规范与检查的自动化手段",{"type":188,"value":862},"之一。",{"type":182,"tag":209,"props":864,"children":865},{},[866,868],{"type":188,"value":867},"让 AI 也参与重构和测试改进：\n",{"type":182,"tag":205,"props":869,"children":870},{},[871],{"type":182,"tag":209,"props":872,"children":873},{},[874],{"type":188,"value":875},"引导 AI 生成 refactoring plan、测试增强方案，而非只用来“生成新功能代码”。",{"type":182,"tag":209,"props":877,"children":878},{},[879,881],{"type":188,"value":880},"从“代码级助手”升级为“工程级守门人”：\n",{"type":182,"tag":205,"props":882,"children":883},{},[884],{"type":182,"tag":209,"props":885,"children":886},{},[887],{"type":188,"value":888},"用共享指令固定质量红线（见下文），让 AI 在生成时自带审查意识。",{"type":182,"tag":431,"props":890,"children":891},{},[],{"type":182,"tag":281,"props":893,"children":895},{"id":894},"五系统影响对架构工程效率与协作的牵引",[896],{"type":188,"value":897},"五、系统影响：对架构、工程效率与协作的牵引",{"type":182,"tag":288,"props":899,"children":901},{"id":900},"_51-对架构与代码库形态的影响",[902],{"type":188,"value":903},"5.1 对架构与代码库形态的影响",{"type":182,"tag":191,"props":905,"children":906},{},[907],{"type":188,"value":908},"如果不加约束，AI 辅助编码往往会导致：",{"type":182,"tag":205,"props":910,"children":911},{},[912,917,922],{"type":182,"tag":209,"props":913,"children":914},{},[915],{"type":188,"value":916},"领域边界模糊：AI 只关心“把当前需求拼起来能跑”，不关心是否破坏既有领域划分。",{"type":182,"tag":209,"props":918,"children":919},{},[920],{"type":188,"value":921},"接口与模型扩张：为了兼容临时诉求不断往对象、DTO、API 里加字段，缺少“收敛与精简”。",{"type":182,"tag":209,"props":923,"children":924},{},[925,927],{"type":188,"value":926},"技术债表面隐蔽：\n",{"type":182,"tag":205,"props":928,"children":929},{},[930,935],{"type":182,"tag":209,"props":931,"children":932},{},[933],{"type":188,"value":934},"从静态看，代码能编译、能跑测试；",{"type":182,"tag":209,"props":936,"children":937},{},[938],{"type":188,"value":939},"从动态看，复杂度和耦合在缓慢积累，几年后演进阻力巨大。",{"type":182,"tag":288,"props":941,"children":943},{"id":942},"_52-对工程效率与质量文化的拉扯",[944],{"type":188,"value":945},"5.2 对工程效率与质量文化的拉扯",{"type":182,"tag":205,"props":947,"children":948},{},[949,962,975],{"type":182,"tag":209,"props":950,"children":951},{},[952,954],{"type":188,"value":953},"短期效率观：\n",{"type":182,"tag":205,"props":955,"children":956},{},[957],{"type":182,"tag":209,"props":958,"children":959},{},[960],{"type":188,"value":961},"团队容易只看“功能交付速度”，忽略“未来一年维护投入”。",{"type":182,"tag":209,"props":963,"children":964},{},[965,967],{"type":188,"value":966},"质量文化淡化：\n",{"type":182,"tag":205,"props":968,"children":969},{},[970],{"type":182,"tag":209,"props":971,"children":972},{},[973],{"type":188,"value":974},"如果管理层只追求“AI 提效指标”，工程师自然会在质量标准上“向下对齐”。",{"type":182,"tag":209,"props":976,"children":977},{},[978,980],{"type":188,"value":979},"知识沉淀路径变化：\n",{"type":182,"tag":205,"props":981,"children":982},{},[983,988],{"type":182,"tag":209,"props":984,"children":985},{},[986],{"type":188,"value":987},"原本通过手写和重构沉淀的“隐性知识”，被部分转移到“提示语”和“过往生成代码”中。",{"type":182,"tag":209,"props":989,"children":990},{},[991],{"type":188,"value":992},"如果缺乏规范的共享指令与知识库建设，这些知识很难被团队系统地复用。",{"type":182,"tag":431,"props":994,"children":995},{},[],{"type":182,"tag":281,"props":997,"children":999},{"id":998},"六落地建议在生产中负责任地用-ai",[1000],{"type":188,"value":1001},"六、落地建议：在生产中“负责任地用 AI”",{"type":182,"tag":288,"props":1003,"children":1005},{"id":1004},"_61-强化并嵌入既有实践tdd-与静态分析",[1006],{"type":188,"value":1007},"6.1 强化并嵌入既有实践：TDD 与静态分析",{"type":182,"tag":191,"props":1009,"children":1010},{},[1011,1013],{"type":188,"value":1012},"原文明确提出：",{"type":182,"tag":197,"props":1014,"children":1015},{},[1016],{"type":188,"value":1017},"在生产环境中有效使用 AI，需要重新强化代码质量实践，尤其是 TDD 和静态分析，并把它们嵌入到开发流中。",{"type":182,"tag":191,"props":1019,"children":1020},{},[1021],{"type":188,"value":1022},"一个可操作的落地思路是：",{"type":182,"tag":205,"props":1024,"children":1025},{},[1026,1044],{"type":182,"tag":209,"props":1027,"children":1028},{},[1029,1031],{"type":188,"value":1030},"对 TDD 的强化：\n",{"type":182,"tag":205,"props":1032,"children":1033},{},[1034,1039],{"type":182,"tag":209,"props":1035,"children":1036},{},[1037],{"type":188,"value":1038},"明确要求“AI 生成代码前先定义测试”，或者让 AI 先生成测试 skeleton，再填实现。",{"type":182,"tag":209,"props":1040,"children":1041},{},[1042],{"type":188,"value":1043},"在 review checklist 中加入“测试先行/测试充分性”项，而不仅是“代码可读性”。",{"type":182,"tag":209,"props":1045,"children":1046},{},[1047,1049],{"type":188,"value":1048},"对静态分析的升级：\n",{"type":182,"tag":205,"props":1050,"children":1051},{},[1052,1057],{"type":182,"tag":209,"props":1053,"children":1054},{},[1055],{"type":188,"value":1056},"针对 AI 生成特点增加规则，例如：\n- 重复逻辑检测；\n- 可疑大函数/大类的警报；\n- magic number / 无注释复杂逻辑的提示。",{"type":182,"tag":209,"props":1058,"children":1059},{},[1060],{"type":188,"value":1061},"将静态分析结果纳入 CI 阶段的“硬门槛”，而不是可选提示。",{"type":182,"tag":288,"props":1063,"children":1065},{"id":1064},"_62-利用共享指令把规范写进工作流",[1066],{"type":188,"value":1067},"6.2 利用“共享指令”把规范写进工作流",{"type":182,"tag":191,"props":1069,"children":1070},{},[1071,1073,1078],{"type":188,"value":1072},"原文提到的一个关键建议是：",{"type":182,"tag":197,"props":1074,"children":1075},{},[1076],{"type":188,"value":1077},"通过精心策划的“共享指令集”（curated shared instructions）直接嵌入团队的编码工作流",{"type":188,"value":1079},"。这在实践中可以演化为：",{"type":182,"tag":205,"props":1081,"children":1082},{},[1083,1101,1114],{"type":182,"tag":209,"props":1084,"children":1085},{},[1086,1088],{"type":188,"value":1087},"团队级系统提示（system / team prompt）：\n",{"type":182,"tag":205,"props":1089,"children":1090},{},[1091,1096],{"type":182,"tag":209,"props":1092,"children":1093},{},[1094],{"type":188,"value":1095},"固定质量原则：如“禁止复制粘贴大段代码”、“需要解释复杂逻辑意图”等。",{"type":182,"tag":209,"props":1097,"children":1098},{},[1099],{"type":188,"value":1100},"约束生成范围：例如“严禁改动超出当前模块边界的代码”。",{"type":182,"tag":209,"props":1102,"children":1103},{},[1104,1106],{"type":188,"value":1105},"场景化模板：\n",{"type":182,"tag":205,"props":1107,"children":1108},{},[1109],{"type":182,"tag":209,"props":1110,"children":1111},{},[1112],{"type":188,"value":1113},"不同任务类型（bug 修复 / 新功能 / 重构 / 跨模块变更）对应不同的提示模板和 review checklist。",{"type":182,"tag":209,"props":1115,"children":1116},{},[1117,1119],{"type":188,"value":1118},"持续演化机制：\n",{"type":182,"tag":205,"props":1120,"children":1121},{},[1122],{"type":182,"tag":209,"props":1123,"children":1124},{},[1125],{"type":188,"value":1126},"将线上事故、review 发现的问题沉淀为新指令，不断迭代团队共享 prompt。",{"type":182,"tag":191,"props":1128,"children":1129},{},[1130,1132,1137],{"type":188,"value":1131},"这样做的目标是：",{"type":182,"tag":197,"props":1133,"children":1134},{},[1135],{"type":188,"value":1136},"把“经验性规范”变成“系统性约束”，并让 AI 自身也遵守这些约束",{"type":188,"value":203},{"type":182,"tag":288,"props":1139,"children":1141},{"id":1140},"_63-控制变更粒度与审查策略",[1142],{"type":188,"value":1143},"6.3 控制变更粒度与审查策略",{"type":182,"tag":191,"props":1145,"children":1146},{},[1147],{"type":188,"value":1148},"对于 coding agents 特别需要注意：",{"type":182,"tag":205,"props":1150,"children":1151},{},[1152,1165,1178],{"type":182,"tag":209,"props":1153,"children":1154},{},[1155,1157],{"type":188,"value":1156},"限制单次变更范围：\n",{"type":182,"tag":205,"props":1158,"children":1159},{},[1160],{"type":182,"tag":209,"props":1161,"children":1162},{},[1163],{"type":188,"value":1164},"在提示中明确“一个任务只改一个有界上下文/子系统”，减少超大 diff。",{"type":182,"tag":209,"props":1166,"children":1167},{},[1168,1170],{"type":188,"value":1169},"强化自动化保护网：\n",{"type":182,"tag":205,"props":1171,"children":1172},{},[1173],{"type":182,"tag":209,"props":1174,"children":1175},{},[1176],{"type":188,"value":1177},"为 agent 生成的改动配置更严格的测试门槛和预发布验证流程。",{"type":182,"tag":209,"props":1179,"children":1180},{},[1181,1183],{"type":188,"value":1182},"采用分阶段 rollout：\n",{"type":182,"tag":205,"props":1184,"children":1185},{},[1186],{"type":182,"tag":209,"props":1187,"children":1188},{},[1189],{"type":188,"value":1190},"对高风险变更采用灰度发布、分流验证，并要求 agent 输出“变更点清单”和“潜在影响区域”。",{"type":182,"tag":288,"props":1192,"children":1194},{"id":1193},"_64-识别不适用场景与风险边界",[1195],{"type":188,"value":1196},"6.4 识别不适用场景与风险边界",{"type":182,"tag":191,"props":1198,"children":1199},{},[1200],{"type":188,"value":1201},"在以下场景中，应更加谨慎使用 AI 直接生成或大规模修改代码：",{"type":182,"tag":205,"props":1203,"children":1204},{},[1205,1210,1215],{"type":182,"tag":209,"props":1206,"children":1207},{},[1208],{"type":188,"value":1209},"高安全/高合规要求系统（金融、隐私敏感业务等）；",{"type":182,"tag":209,"props":1211,"children":1212},{},[1213],{"type":188,"value":1214},"对领域建模要求极高、规则复杂且多变的核心域；",{"type":182,"tag":209,"props":1216,"children":1217},{},[1218],{"type":188,"value":1219},"现有代码库已高度耦合，缺乏测试与观测基础，无法有效回归与监控。",{"type":182,"tag":191,"props":1221,"children":1222},{},[1223],{"type":188,"value":1224},"对于这些场景，更合理的策略通常是：",{"type":182,"tag":205,"props":1226,"children":1227},{},[1228,1233],{"type":182,"tag":209,"props":1229,"children":1230},{},[1231],{"type":188,"value":1232},"优先用 AI 做辅助分析、重构建议、测试生成，而非直接放权给 agent 做大规模改动；",{"type":182,"tag":209,"props":1234,"children":1235},{},[1236],{"type":188,"value":1237},"先补齐测试和监控能力，再逐步扩大 AI 参与范围。",{"type":182,"tag":191,"props":1239,"children":1240},{},[1241,1243,1248],{"type":188,"value":1242},"综合来看，原文的核心立场并不是“反对 AI 编程”，而是明确提醒：",{"type":182,"tag":197,"props":1244,"children":1245},{},[1246],{"type":188,"value":1247},"AI 提速的是“编码”这一局部环节，但代价是在系统层面增加了质量管理的复杂度和认知风险",{"type":188,"value":1249},"。要在生产中有效使用这类工具，技术负责人需要把 TDD、静态分析、review 规范等实践重新“嵌入工作流”，并通过共享指令和流程设计，把团队的质量文化编码进 AI 使用方式，而不是寄希望于“更聪明的模型自动抵消这些风险”。",{"title":175,"searchDepth":1251,"depth":1251,"links":1252},2,[1253,1254],{"id":185,"depth":1251,"text":189},{"id":276,"depth":1251,"text":279,"children":1255},[1256,1258,1259,1260,1261,1262],{"id":283,"depth":1257,"text":286},3,{"id":436,"depth":1257,"text":439},{"id":608,"depth":1257,"text":611},{"id":763,"depth":1257,"text":766},{"id":894,"depth":1257,"text":897},{"id":998,"depth":1257,"text":1001},"markdown","content:6.maps:_ai:vibe:complacency.md","content","6.maps/_ai/vibe/complacency.md","6.maps/_ai/vibe/complacency","md",[1270,1274],{"_path":1271,"title":1272,"description":1273},"/maps/_ai/vibe/anchoring","Anchoring coding agents to a ref application","在编码代理时代，通过将其锚定至实时可编译的参考应用，有效应对代码漂移问题",{"_path":1275,"title":1276,"description":1277},"/maps/_ai/vibe/team-of-agents","编码智能体团队","通过协作的多个 AI 编码智能体来完成开发任务",1771264667058]