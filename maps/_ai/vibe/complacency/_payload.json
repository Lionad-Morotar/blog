_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"body":181,"_type":1266,"_id":1267,"_source":1268,"_file":1269,"_stem":1270,"_extension":1271},"/maps/_ai/vibe/complacency","vibe",false,true,"","对 AI 生成代码“惰性依赖”的警惕与治理","AI 编程助手提高效率的同时，会放大重复代码、代码 churn 和审查难度，需要用工程实践和流程设计来对冲“惰性依赖”风险。",{"type":182,"children":183,"toc":1253},"root",[184,193,207,272,277,283,290,297,348,353,359,423,433,437,443,449,454,518,529,535,606,609,615,621,626,655,660,692,702,708,713,738,743,761,764,770,776,781,804,809,832,838,843,892,895,901,907,912,943,949,996,999,1005,1011,1021,1026,1065,1071,1083,1130,1141,1147,1152,1194,1200,1205,1223,1228,1241],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"brief",[190],{"type":191,"value":192},"text","Brief",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197,199,205],{"type":191,"value":198},"对 AI 编程助手和代理（agents）的研究和实践逐渐暴露出一个结构性问题：",{"type":185,"tag":200,"props":201,"children":202},"strong",{},[203],{"type":191,"value":204},"随着使用时间增加，代码质量容易因为“惰性依赖”（complacency）而下滑",{"type":191,"value":206},"。",{"type":185,"tag":208,"props":209,"children":210},"ul",{},[211,230,248],{"type":185,"tag":212,"props":213,"children":214},"li",{},[215,217],{"type":191,"value":216},"实证信号：\n",{"type":185,"tag":208,"props":218,"children":219},{},[220,225],{"type":185,"tag":212,"props":221,"children":222},{},[223],{"type":191,"value":224},"GitClear 2024 研究发现，重复代码和代码 churn 的增长超出预期，而提交历史中的重构活动在减少。",{"type":185,"tag":212,"props":226,"children":227},{},[228],{"type":191,"value":229},"微软针对知识工作者的研究表明：AI 帮助带来的“信心提升”，往往以“批判性思考能力下降”为代价；在长期使用编程助手后，这种惰性思考会明显加剧。",{"type":185,"tag":212,"props":231,"children":232},{},[233,235],{"type":191,"value":234},"机制上：\n",{"type":185,"tag":208,"props":236,"children":237},{},[238,243],{"type":185,"tag":212,"props":239,"children":240},{},[241],{"type":191,"value":242},"AI 代理可以一次性生成更大规模的改动集（large change sets），人工 review 成本和难度上升，问题更难被及时发现。",{"type":185,"tag":212,"props":244,"children":245},{},[246],{"type":191,"value":247},"加速了“写代码”这一步，就隐性地对“审查、测试、重构”等后续环节施加压力，如果不做制度化补偿，整体质量会被侵蚀。",{"type":185,"tag":212,"props":249,"children":250},{},[251,253],{"type":191,"value":252},"应对建议（来自原文）：\n",{"type":185,"tag":208,"props":254,"children":255},{},[256,267],{"type":185,"tag":212,"props":257,"children":258},{},[259,261,266],{"type":191,"value":260},"在生产环境中有效使用 AI，需要",{"type":185,"tag":200,"props":262,"children":263},{},[264],{"type":191,"value":265},"重新强化代码质量意识和实践",{"type":191,"value":206},{"type":185,"tag":212,"props":268,"children":269},{},[270],{"type":191,"value":271},"尤其是将 TDD、静态分析等既有工程实践重新嵌入到编码工作流中，例如通过针对软件团队的“共享指令集”（curated shared instructions）来固化这些约束与规范。",{"type":185,"tag":194,"props":273,"children":274},{},[275],{"type":191,"value":276},"来源：技术雷达",{"type":185,"tag":186,"props":278,"children":280},{"id":279},"details",[281],{"type":191,"value":282},"Details",{"type":185,"tag":284,"props":285,"children":287},"h3",{"id":286},"一背景与现状从提效工具到系统性质量压力",[288],{"type":191,"value":289},"一、背景与现状：从“提效工具”到“系统性质量压力”",{"type":185,"tag":291,"props":292,"children":294},"h4",{"id":293},"_11-技术与业务场景ai-编程从辅助走向代理",[295],{"type":191,"value":296},"1.1 技术与业务场景：AI 编程从辅助走向代理",{"type":185,"tag":208,"props":298,"children":299},{},[300,323],{"type":185,"tag":212,"props":301,"children":302},{},[303,305],{"type":191,"value":304},"典型使用场景：\n",{"type":185,"tag":208,"props":306,"children":307},{},[308,313,318],{"type":185,"tag":212,"props":309,"children":310},{},[311],{"type":191,"value":312},"日常编码中使用 Copilot 类助手补全和生成函数、测试。",{"type":185,"tag":212,"props":314,"children":315},{},[316],{"type":191,"value":317},"通过自然语言需求驱动 agent 生成多个文件、跨模块改动。",{"type":185,"tag":212,"props":319,"children":320},{},[321],{"type":191,"value":322},"在原型开发、绿地项目中，用 AI 快速跑通端到端 demo。",{"type":185,"tag":212,"props":324,"children":325},{},[326,328],{"type":191,"value":327},"背景趋势：\n",{"type":185,"tag":208,"props":329,"children":330},{},[331,336],{"type":185,"tag":212,"props":332,"children":333},{},[334],{"type":191,"value":335},"早期共识是“AI 编码主要是提效工具”，风险更多被视为局部的、可控的。",{"type":185,"tag":212,"props":337,"children":338},{},[339,341,346],{"type":191,"value":340},"随着 AI 的覆盖范围从“补全几行代码”扩展到“生成大规模改动集”，其对",{"type":185,"tag":200,"props":342,"children":343},{},[344],{"type":191,"value":345},"整体工程系统",{"type":191,"value":347},"的影响被显著放大。",{"type":185,"tag":194,"props":349,"children":350},{},[351],{"type":191,"value":352},"这也意味着：对 AI 的评估不能只看“开发速度”，需要把“演进后的代码库形态”和“团队认知习惯的改变”也纳入考量。",{"type":185,"tag":291,"props":354,"children":356},{"id":355},"_12-研究发现效率收益与质量退化并存",[357],{"type":191,"value":358},"1.2 研究发现：效率收益与质量退化并存",{"type":185,"tag":208,"props":360,"children":361},{},[362,394],{"type":185,"tag":212,"props":363,"children":364},{},[365,367],{"type":191,"value":366},"GitClear 2024：\n",{"type":185,"tag":208,"props":368,"children":369},{},[370,382],{"type":185,"tag":212,"props":371,"children":372},{},[373,375,380],{"type":191,"value":374},"观察到**重复代码（duplication）",{"type":185,"tag":200,"props":376,"children":377},{},[378],{"type":191,"value":379},"和",{"type":191,"value":381},"代码 churn（短期内频繁增删改的代码）**显著上升。",{"type":185,"tag":212,"props":383,"children":384},{},[385,387,392],{"type":191,"value":386},"与此对照，",{"type":185,"tag":200,"props":388,"children":389},{},[390],{"type":191,"value":391},"重构类提交占比下降",{"type":191,"value":393},"，说明许多“第一次写得差不多就算了”的代码，没有被系统性打磨。",{"type":185,"tag":212,"props":395,"children":396},{},[397,399],{"type":191,"value":398},"微软对知识工作者的研究：\n",{"type":185,"tag":208,"props":400,"children":401},{},[402,407,418],{"type":185,"tag":212,"props":403,"children":404},{},[405],{"type":191,"value":406},"AI 使得个体在完成任务时**“自我感知的信心”上升**。",{"type":185,"tag":212,"props":408,"children":409},{},[410,412,417],{"type":191,"value":411},"但在可测量的指标上，",{"type":185,"tag":200,"props":413,"children":414},{},[415],{"type":191,"value":416},"批判性审查和深度思考的投入反而减少",{"type":191,"value":206},{"type":185,"tag":212,"props":419,"children":420},{},[421],{"type":191,"value":422},"长期使用编程助手后，团队中这种“有答案就不再往下问”的惰性模式会更明显。",{"type":185,"tag":194,"props":424,"children":425},{},[426,428],{"type":191,"value":427},"对技术负责人来说，这些信号指向的是：",{"type":185,"tag":200,"props":429,"children":430},{},[431],{"type":191,"value":432},"AI 的“提效收益”会与“认知松懈”叠加，最终体现在存量代码质量的慢性恶化上。",{"type":185,"tag":434,"props":435,"children":436},"hr",{},[],{"type":185,"tag":284,"props":438,"children":440},{"id":439},"二问题与风险惰性依赖的技术与组织后果",[441],{"type":191,"value":442},"二、问题与风险：惰性依赖的技术与组织后果",{"type":185,"tag":291,"props":444,"children":446},{"id":445},"_21-代码层面的结构性退化",[447],{"type":191,"value":448},"2.1 代码层面的结构性退化",{"type":185,"tag":194,"props":450,"children":451},{},[452],{"type":191,"value":453},"在广泛使用 AI 编码助手/代理的团队中，常见的风险模式包括：",{"type":185,"tag":208,"props":455,"children":456},{},[457,482,500],{"type":185,"tag":212,"props":458,"children":459},{},[460,462],{"type":191,"value":461},"重复与散乱：\n",{"type":185,"tag":208,"props":463,"children":464},{},[465,470],{"type":185,"tag":212,"props":466,"children":467},{},[468],{"type":191,"value":469},"AI 为了“就近满足上下文需求”，倾向于复制相似逻辑，而不是抽象复用。",{"type":185,"tag":212,"props":471,"children":472},{},[473,475,480],{"type":191,"value":474},"结果是：",{"type":185,"tag":200,"props":476,"children":477},{},[478],{"type":191,"value":479},"功能上线更快",{"type":191,"value":481},"，但后续修 bug / 改需求时维护成本急剧上升。",{"type":185,"tag":212,"props":483,"children":484},{},[485,487],{"type":191,"value":486},"短期 churn 增加：\n",{"type":185,"tag":208,"props":488,"children":489},{},[490,495],{"type":185,"tag":212,"props":491,"children":492},{},[493],{"type":191,"value":494},"开发者更容易“先让它写一版再说”，产生大量低质量试验性代码。",{"type":185,"tag":212,"props":496,"children":497},{},[498],{"type":191,"value":499},"如果缺乏严格的 review / 清理机制，这些“实验产物”往往残留在主干代码库。",{"type":185,"tag":212,"props":501,"children":502},{},[503,505],{"type":191,"value":504},"重构意愿降低：\n",{"type":185,"tag":208,"props":506,"children":507},{},[508,513],{"type":185,"tag":212,"props":509,"children":510},{},[511],{"type":191,"value":512},"由于“复制修一份就能过需求”，团队对“抽象、整合、简化”的内在动力被稀释。",{"type":185,"tag":212,"props":514,"children":515},{},[516],{"type":191,"value":517},"体现在数据上，就是重构型提交在整个提交历史中的占比下降。",{"type":185,"tag":194,"props":519,"children":520},{},[521,523,528],{"type":191,"value":522},"这些现象并不是 AI 独有，而是",{"type":185,"tag":200,"props":524,"children":525},{},[526],{"type":191,"value":527},"人类长期就存在的问题被放大加速",{"type":191,"value":206},{"type":185,"tag":291,"props":530,"children":532},{"id":531},"_22-认知与流程层面的惰性",[533],{"type":191,"value":534},"2.2 认知与流程层面的惰性",{"type":185,"tag":208,"props":536,"children":537},{},[538,556,574],{"type":185,"tag":212,"props":539,"children":540},{},[541,543],{"type":191,"value":542},"过度信任模型输出：\n",{"type":185,"tag":208,"props":544,"children":545},{},[546,551],{"type":185,"tag":212,"props":547,"children":548},{},[549],{"type":191,"value":550},"“AI 写的看起来没问题”常常替代了“我真的理解了代码意图和边界”。",{"type":185,"tag":212,"props":552,"children":553},{},[554],{"type":191,"value":555},"评审被动化：review 流于查风格、改命名，而不是深度审查领域逻辑。",{"type":185,"tag":212,"props":557,"children":558},{},[559,561],{"type":191,"value":560},"拆解问题的能力退化：\n",{"type":185,"tag":208,"props":562,"children":563},{},[564,569],{"type":185,"tag":212,"props":565,"children":566},{},[567],{"type":191,"value":568},"在“提示-生成-接受”的循环中，工程师容易跳过需求澄清、边界定义、建模等关键思考步骤。",{"type":185,"tag":212,"props":570,"children":571},{},[572],{"type":191,"value":573},"长期来看，团队的“架构思维密度”和“问题分解能力”都会受损。",{"type":185,"tag":212,"props":575,"children":576},{},[577,579],{"type":191,"value":578},"流程瓶颈挤压：\n",{"type":185,"tag":208,"props":580,"children":581},{},[582,594],{"type":185,"tag":212,"props":583,"children":584},{},[585,587,592],{"type":191,"value":586},"写代码明显加速后，",{"type":185,"tag":200,"props":588,"children":589},{},[590],{"type":191,"value":591},"测试、review、上线评估",{"type":191,"value":593},"成为新的瓶颈。",{"type":185,"tag":212,"props":595,"children":596},{},[597,599,604],{"type":191,"value":598},"如果组织不主动“抬升”这些环节的工程能力，",{"type":185,"tag":200,"props":600,"children":601},{},[602],{"type":191,"value":603},"就会自发削弱它们的标准",{"type":191,"value":605},"，以适配更快的提交节奏。",{"type":185,"tag":434,"props":607,"children":608},{},[],{"type":185,"tag":284,"props":610,"children":612},{"id":611},"三模式与原理从快写到系统配平",[613],{"type":191,"value":614},"三、模式与原理：从“快写”到“系统配平”",{"type":185,"tag":291,"props":616,"children":618},{"id":617},"_31-速度质量认知负载的再平衡",[619],{"type":191,"value":620},"3.1 速度—质量—认知负载的再平衡",{"type":185,"tag":194,"props":622,"children":623},{},[624],{"type":191,"value":625},"可以把 AI 编码工具视为在“实现代码”环节上强行压缩了周期：",{"type":185,"tag":208,"props":627,"children":628},{},[629,642],{"type":185,"tag":212,"props":630,"children":631},{},[632,634],{"type":191,"value":633},"过去：\n",{"type":185,"tag":208,"props":635,"children":636},{},[637],{"type":185,"tag":212,"props":638,"children":639},{},[640],{"type":191,"value":641},"需求澄清 → 设计 → 手写代码 → 手写测试 → review & 重构",{"type":185,"tag":212,"props":643,"children":644},{},[645,647],{"type":191,"value":646},"现在（AI 辅助）：\n",{"type":185,"tag":208,"props":648,"children":649},{},[650],{"type":185,"tag":212,"props":651,"children":652},{},[653],{"type":191,"value":654},"需求描述 → prompt → 一次生成大量代码 + 测试样例 → 轻量 review → merge",{"type":185,"tag":194,"props":656,"children":657},{},[658],{"type":191,"value":659},"如果其他环节不做调整，典型后果包括：",{"type":185,"tag":208,"props":661,"children":662},{},[663,675,687],{"type":185,"tag":212,"props":664,"children":665},{},[666,668,673],{"type":191,"value":667},"代码审查阶段：",{"type":185,"tag":200,"props":669,"children":670},{},[671],{"type":191,"value":672},"diff 过大",{"type":191,"value":674},"，reviewer 很难逐行理解和验证。",{"type":185,"tag":212,"props":676,"children":677},{},[678,680,685],{"type":191,"value":679},"测试阶段：",{"type":185,"tag":200,"props":681,"children":682},{},[683],{"type":191,"value":684},"测试覆盖和质量“被动接受”模型输出",{"type":191,"value":686},"，而非由工程师主动设计。",{"type":185,"tag":212,"props":688,"children":689},{},[690],{"type":191,"value":691},"演进阶段：缺少重构和演化设计，代码库像“地层沉积”一样堆积。",{"type":185,"tag":194,"props":693,"children":694},{},[695,697],{"type":191,"value":696},"因此，",{"type":185,"tag":200,"props":698,"children":699},{},[700],{"type":191,"value":701},"引入 AI 的前提不是“让工程实践变轻”，而是“重新设计如何让实践在新的速度条件下依然有效”。",{"type":185,"tag":291,"props":703,"children":705},{"id":704},"_32-coding-agents-带来的巨大变更集问题",[706],{"type":191,"value":707},"3.2 Coding agents 带来的“巨大变更集”问题",{"type":185,"tag":194,"props":709,"children":710},{},[711],{"type":191,"value":712},"相对普通助手，coding agent 的突出特点是：",{"type":185,"tag":208,"props":714,"children":715},{},[716,728,733],{"type":185,"tag":212,"props":717,"children":718},{},[719,721,726],{"type":191,"value":720},"生成",{"type":185,"tag":200,"props":722,"children":723},{},[724],{"type":191,"value":725},"多文件、多模块",{"type":191,"value":727},"的改动；",{"type":185,"tag":212,"props":729,"children":730},{},[731],{"type":191,"value":732},"改动之间经常存在跨边界依赖；",{"type":185,"tag":212,"props":734,"children":735},{},[736],{"type":191,"value":737},"本质上更接近“自动化执行一个小型重构或特性开发”。",{"type":185,"tag":194,"props":739,"children":740},{},[741],{"type":191,"value":742},"这直接导致：",{"type":185,"tag":208,"props":744,"children":745},{},[746,751,756],{"type":185,"tag":212,"props":747,"children":748},{},[749],{"type":191,"value":750},"Review 复杂度从“函数级”上升到“模块/系统级”；",{"type":185,"tag":212,"props":752,"children":753},{},[754],{"type":191,"value":755},"线上回滚与故障定位难度增加——一次错误可能影响更多路径；",{"type":185,"tag":212,"props":757,"children":758},{},[759],{"type":191,"value":760},"对 CI/CD 与回归测试体系提出更高要求，否则就只能靠“运气上线”。",{"type":185,"tag":434,"props":762,"children":763},{},[],{"type":185,"tag":284,"props":765,"children":767},{"id":766},"四对比与演进ai-工具前后的工程形态",[768],{"type":191,"value":769},"四、对比与演进：AI 工具前后的工程形态",{"type":185,"tag":291,"props":771,"children":773},{"id":772},"_41-传统高质量工程实践-vs-ai-加持下的新挑战",[774],{"type":191,"value":775},"4.1 传统高质量工程实践 vs AI 加持下的新挑战",{"type":185,"tag":194,"props":777,"children":778},{},[779],{"type":191,"value":780},"传统上，维持代码库长寿的关键手段包括：",{"type":185,"tag":208,"props":782,"children":783},{},[784,789,794,799],{"type":185,"tag":212,"props":785,"children":786},{},[787],{"type":191,"value":788},"TDD / 测试先行：先定行为边界，再写实现；",{"type":185,"tag":212,"props":790,"children":791},{},[792],{"type":191,"value":793},"持续重构：在功能迭代中不断整理抽象边界；",{"type":185,"tag":212,"props":795,"children":796},{},[797],{"type":191,"value":798},"静态分析与规范：对常见错误和风格问题做自动化约束；",{"type":185,"tag":212,"props":800,"children":801},{},[802],{"type":191,"value":803},"小步提交与可审查变更集。",{"type":185,"tag":194,"props":805,"children":806},{},[807],{"type":191,"value":808},"引入 AI 后，如果不做任何治理，常出现如下反差：",{"type":185,"tag":208,"props":810,"children":811},{},[812,817,822,827],{"type":185,"tag":212,"props":813,"children":814},{},[815],{"type":191,"value":816},"TDD 弱化： “AI 代码已可运行”被当作“行为已可靠”的替代。",{"type":185,"tag":212,"props":818,"children":819},{},[820],{"type":191,"value":821},"重构滞后：工程师更习惯“再复制一段新代码满足当前需求”。",{"type":185,"tag":212,"props":823,"children":824},{},[825],{"type":191,"value":826},"静态分析形同虚设：规则不更新、不针对 AI 生成模式做加强（例如检测重复逻辑、copy-paste 风险）。",{"type":185,"tag":212,"props":828,"children":829},{},[830],{"type":191,"value":831},"提交粒度变大：agent 一次性生成大变更集，破坏“小步可回滚”原则。",{"type":185,"tag":291,"props":833,"children":835},{"id":834},"_42-可能的演进方向",[836],{"type":191,"value":837},"4.2 可能的演进方向",{"type":185,"tag":194,"props":839,"children":840},{},[841],{"type":191,"value":842},"为了让 AI 真正服务于长期可维护性，可以考虑这样的演进路径：",{"type":185,"tag":208,"props":844,"children":845},{},[846,866,879],{"type":185,"tag":212,"props":847,"children":848},{},[849,851],{"type":191,"value":850},"将 AI 纳入“质量工具链”：\n",{"type":185,"tag":208,"props":852,"children":853},{},[854],{"type":185,"tag":212,"props":855,"children":856},{},[857,859,864],{"type":191,"value":858},"不是“人在上、AI 在下”，而是把 AI 作为",{"type":185,"tag":200,"props":860,"children":861},{},[862],{"type":191,"value":863},"执行规范与检查的自动化手段",{"type":191,"value":865},"之一。",{"type":185,"tag":212,"props":867,"children":868},{},[869,871],{"type":191,"value":870},"让 AI 也参与重构和测试改进：\n",{"type":185,"tag":208,"props":872,"children":873},{},[874],{"type":185,"tag":212,"props":875,"children":876},{},[877],{"type":191,"value":878},"引导 AI 生成 refactoring plan、测试增强方案，而非只用来“生成新功能代码”。",{"type":185,"tag":212,"props":880,"children":881},{},[882,884],{"type":191,"value":883},"从“代码级助手”升级为“工程级守门人”：\n",{"type":185,"tag":208,"props":885,"children":886},{},[887],{"type":185,"tag":212,"props":888,"children":889},{},[890],{"type":191,"value":891},"用共享指令固定质量红线（见下文），让 AI 在生成时自带审查意识。",{"type":185,"tag":434,"props":893,"children":894},{},[],{"type":185,"tag":284,"props":896,"children":898},{"id":897},"五系统影响对架构工程效率与协作的牵引",[899],{"type":191,"value":900},"五、系统影响：对架构、工程效率与协作的牵引",{"type":185,"tag":291,"props":902,"children":904},{"id":903},"_51-对架构与代码库形态的影响",[905],{"type":191,"value":906},"5.1 对架构与代码库形态的影响",{"type":185,"tag":194,"props":908,"children":909},{},[910],{"type":191,"value":911},"如果不加约束，AI 辅助编码往往会导致：",{"type":185,"tag":208,"props":913,"children":914},{},[915,920,925],{"type":185,"tag":212,"props":916,"children":917},{},[918],{"type":191,"value":919},"领域边界模糊：AI 只关心“把当前需求拼起来能跑”，不关心是否破坏既有领域划分。",{"type":185,"tag":212,"props":921,"children":922},{},[923],{"type":191,"value":924},"接口与模型扩张：为了兼容临时诉求不断往对象、DTO、API 里加字段，缺少“收敛与精简”。",{"type":185,"tag":212,"props":926,"children":927},{},[928,930],{"type":191,"value":929},"技术债表面隐蔽：\n",{"type":185,"tag":208,"props":931,"children":932},{},[933,938],{"type":185,"tag":212,"props":934,"children":935},{},[936],{"type":191,"value":937},"从静态看，代码能编译、能跑测试；",{"type":185,"tag":212,"props":939,"children":940},{},[941],{"type":191,"value":942},"从动态看，复杂度和耦合在缓慢积累，几年后演进阻力巨大。",{"type":185,"tag":291,"props":944,"children":946},{"id":945},"_52-对工程效率与质量文化的拉扯",[947],{"type":191,"value":948},"5.2 对工程效率与质量文化的拉扯",{"type":185,"tag":208,"props":950,"children":951},{},[952,965,978],{"type":185,"tag":212,"props":953,"children":954},{},[955,957],{"type":191,"value":956},"短期效率观：\n",{"type":185,"tag":208,"props":958,"children":959},{},[960],{"type":185,"tag":212,"props":961,"children":962},{},[963],{"type":191,"value":964},"团队容易只看“功能交付速度”，忽略“未来一年维护投入”。",{"type":185,"tag":212,"props":966,"children":967},{},[968,970],{"type":191,"value":969},"质量文化淡化：\n",{"type":185,"tag":208,"props":971,"children":972},{},[973],{"type":185,"tag":212,"props":974,"children":975},{},[976],{"type":191,"value":977},"如果管理层只追求“AI 提效指标”，工程师自然会在质量标准上“向下对齐”。",{"type":185,"tag":212,"props":979,"children":980},{},[981,983],{"type":191,"value":982},"知识沉淀路径变化：\n",{"type":185,"tag":208,"props":984,"children":985},{},[986,991],{"type":185,"tag":212,"props":987,"children":988},{},[989],{"type":191,"value":990},"原本通过手写和重构沉淀的“隐性知识”，被部分转移到“提示语”和“过往生成代码”中。",{"type":185,"tag":212,"props":992,"children":993},{},[994],{"type":191,"value":995},"如果缺乏规范的共享指令与知识库建设，这些知识很难被团队系统地复用。",{"type":185,"tag":434,"props":997,"children":998},{},[],{"type":185,"tag":284,"props":1000,"children":1002},{"id":1001},"六落地建议在生产中负责任地用-ai",[1003],{"type":191,"value":1004},"六、落地建议：在生产中“负责任地用 AI”",{"type":185,"tag":291,"props":1006,"children":1008},{"id":1007},"_61-强化并嵌入既有实践tdd-与静态分析",[1009],{"type":191,"value":1010},"6.1 强化并嵌入既有实践：TDD 与静态分析",{"type":185,"tag":194,"props":1012,"children":1013},{},[1014,1016],{"type":191,"value":1015},"原文明确提出：",{"type":185,"tag":200,"props":1017,"children":1018},{},[1019],{"type":191,"value":1020},"在生产环境中有效使用 AI，需要重新强化代码质量实践，尤其是 TDD 和静态分析，并把它们嵌入到开发流中。",{"type":185,"tag":194,"props":1022,"children":1023},{},[1024],{"type":191,"value":1025},"一个可操作的落地思路是：",{"type":185,"tag":208,"props":1027,"children":1028},{},[1029,1047],{"type":185,"tag":212,"props":1030,"children":1031},{},[1032,1034],{"type":191,"value":1033},"对 TDD 的强化：\n",{"type":185,"tag":208,"props":1035,"children":1036},{},[1037,1042],{"type":185,"tag":212,"props":1038,"children":1039},{},[1040],{"type":191,"value":1041},"明确要求“AI 生成代码前先定义测试”，或者让 AI 先生成测试 skeleton，再填实现。",{"type":185,"tag":212,"props":1043,"children":1044},{},[1045],{"type":191,"value":1046},"在 review checklist 中加入“测试先行/测试充分性”项，而不仅是“代码可读性”。",{"type":185,"tag":212,"props":1048,"children":1049},{},[1050,1052],{"type":191,"value":1051},"对静态分析的升级：\n",{"type":185,"tag":208,"props":1053,"children":1054},{},[1055,1060],{"type":185,"tag":212,"props":1056,"children":1057},{},[1058],{"type":191,"value":1059},"针对 AI 生成特点增加规则，例如：\n- 重复逻辑检测；\n- 可疑大函数/大类的警报；\n- magic number / 无注释复杂逻辑的提示。",{"type":185,"tag":212,"props":1061,"children":1062},{},[1063],{"type":191,"value":1064},"将静态分析结果纳入 CI 阶段的“硬门槛”，而不是可选提示。",{"type":185,"tag":291,"props":1066,"children":1068},{"id":1067},"_62-利用共享指令把规范写进工作流",[1069],{"type":191,"value":1070},"6.2 利用“共享指令”把规范写进工作流",{"type":185,"tag":194,"props":1072,"children":1073},{},[1074,1076,1081],{"type":191,"value":1075},"原文提到的一个关键建议是：",{"type":185,"tag":200,"props":1077,"children":1078},{},[1079],{"type":191,"value":1080},"通过精心策划的“共享指令集”（curated shared instructions）直接嵌入团队的编码工作流",{"type":191,"value":1082},"。这在实践中可以演化为：",{"type":185,"tag":208,"props":1084,"children":1085},{},[1086,1104,1117],{"type":185,"tag":212,"props":1087,"children":1088},{},[1089,1091],{"type":191,"value":1090},"团队级系统提示（system / team prompt）：\n",{"type":185,"tag":208,"props":1092,"children":1093},{},[1094,1099],{"type":185,"tag":212,"props":1095,"children":1096},{},[1097],{"type":191,"value":1098},"固定质量原则：如“禁止复制粘贴大段代码”、“需要解释复杂逻辑意图”等。",{"type":185,"tag":212,"props":1100,"children":1101},{},[1102],{"type":191,"value":1103},"约束生成范围：例如“严禁改动超出当前模块边界的代码”。",{"type":185,"tag":212,"props":1105,"children":1106},{},[1107,1109],{"type":191,"value":1108},"场景化模板：\n",{"type":185,"tag":208,"props":1110,"children":1111},{},[1112],{"type":185,"tag":212,"props":1113,"children":1114},{},[1115],{"type":191,"value":1116},"不同任务类型（bug 修复 / 新功能 / 重构 / 跨模块变更）对应不同的提示模板和 review checklist。",{"type":185,"tag":212,"props":1118,"children":1119},{},[1120,1122],{"type":191,"value":1121},"持续演化机制：\n",{"type":185,"tag":208,"props":1123,"children":1124},{},[1125],{"type":185,"tag":212,"props":1126,"children":1127},{},[1128],{"type":191,"value":1129},"将线上事故、review 发现的问题沉淀为新指令，不断迭代团队共享 prompt。",{"type":185,"tag":194,"props":1131,"children":1132},{},[1133,1135,1140],{"type":191,"value":1134},"这样做的目标是：",{"type":185,"tag":200,"props":1136,"children":1137},{},[1138],{"type":191,"value":1139},"把“经验性规范”变成“系统性约束”，并让 AI 自身也遵守这些约束",{"type":191,"value":206},{"type":185,"tag":291,"props":1142,"children":1144},{"id":1143},"_63-控制变更粒度与审查策略",[1145],{"type":191,"value":1146},"6.3 控制变更粒度与审查策略",{"type":185,"tag":194,"props":1148,"children":1149},{},[1150],{"type":191,"value":1151},"对于 coding agents 特别需要注意：",{"type":185,"tag":208,"props":1153,"children":1154},{},[1155,1168,1181],{"type":185,"tag":212,"props":1156,"children":1157},{},[1158,1160],{"type":191,"value":1159},"限制单次变更范围：\n",{"type":185,"tag":208,"props":1161,"children":1162},{},[1163],{"type":185,"tag":212,"props":1164,"children":1165},{},[1166],{"type":191,"value":1167},"在提示中明确“一个任务只改一个有界上下文/子系统”，减少超大 diff。",{"type":185,"tag":212,"props":1169,"children":1170},{},[1171,1173],{"type":191,"value":1172},"强化自动化保护网：\n",{"type":185,"tag":208,"props":1174,"children":1175},{},[1176],{"type":185,"tag":212,"props":1177,"children":1178},{},[1179],{"type":191,"value":1180},"为 agent 生成的改动配置更严格的测试门槛和预发布验证流程。",{"type":185,"tag":212,"props":1182,"children":1183},{},[1184,1186],{"type":191,"value":1185},"采用分阶段 rollout：\n",{"type":185,"tag":208,"props":1187,"children":1188},{},[1189],{"type":185,"tag":212,"props":1190,"children":1191},{},[1192],{"type":191,"value":1193},"对高风险变更采用灰度发布、分流验证，并要求 agent 输出“变更点清单”和“潜在影响区域”。",{"type":185,"tag":291,"props":1195,"children":1197},{"id":1196},"_64-识别不适用场景与风险边界",[1198],{"type":191,"value":1199},"6.4 识别不适用场景与风险边界",{"type":185,"tag":194,"props":1201,"children":1202},{},[1203],{"type":191,"value":1204},"在以下场景中，应更加谨慎使用 AI 直接生成或大规模修改代码：",{"type":185,"tag":208,"props":1206,"children":1207},{},[1208,1213,1218],{"type":185,"tag":212,"props":1209,"children":1210},{},[1211],{"type":191,"value":1212},"高安全/高合规要求系统（金融、隐私敏感业务等）；",{"type":185,"tag":212,"props":1214,"children":1215},{},[1216],{"type":191,"value":1217},"对领域建模要求极高、规则复杂且多变的核心域；",{"type":185,"tag":212,"props":1219,"children":1220},{},[1221],{"type":191,"value":1222},"现有代码库已高度耦合，缺乏测试与观测基础，无法有效回归与监控。",{"type":185,"tag":194,"props":1224,"children":1225},{},[1226],{"type":191,"value":1227},"对于这些场景，更合理的策略通常是：",{"type":185,"tag":208,"props":1229,"children":1230},{},[1231,1236],{"type":185,"tag":212,"props":1232,"children":1233},{},[1234],{"type":191,"value":1235},"优先用 AI 做辅助分析、重构建议、测试生成，而非直接放权给 agent 做大规模改动；",{"type":185,"tag":212,"props":1237,"children":1238},{},[1239],{"type":191,"value":1240},"先补齐测试和监控能力，再逐步扩大 AI 参与范围。",{"type":185,"tag":194,"props":1242,"children":1243},{},[1244,1246,1251],{"type":191,"value":1245},"综合来看，原文的核心立场并不是“反对 AI 编程”，而是明确提醒：",{"type":185,"tag":200,"props":1247,"children":1248},{},[1249],{"type":191,"value":1250},"AI 提速的是“编码”这一局部环节，但代价是在系统层面增加了质量管理的复杂度和认知风险",{"type":191,"value":1252},"。要在生产中有效使用这类工具，技术负责人需要把 TDD、静态分析、review 规范等实践重新“嵌入工作流”，并通过共享指令和流程设计，把团队的质量文化编码进 AI 使用方式，而不是寄希望于“更聪明的模型自动抵消这些风险”。",{"title":178,"searchDepth":1254,"depth":1254,"links":1255},2,[1256,1257],{"id":188,"depth":1254,"text":192},{"id":279,"depth":1254,"text":282,"children":1258},[1259,1261,1262,1263,1264,1265],{"id":286,"depth":1260,"text":289},3,{"id":439,"depth":1260,"text":442},{"id":611,"depth":1260,"text":614},{"id":766,"depth":1260,"text":769},{"id":897,"depth":1260,"text":900},{"id":1001,"depth":1260,"text":1004},"markdown","content:6.maps:_ai:vibe:complacency.md","content","6.maps/_ai/vibe/complacency.md","6.maps/_ai/vibe/complacency","md",[1273,1277],{"_path":1274,"title":1275,"description":1276},"/maps/_ai/vibe/anchoring","Anchoring coding agents to a ref application","在编码代理时代，通过将其锚定至实时可编译的参考应用，有效应对代码漂移问题",{"_path":1278,"title":1279,"description":1280},"/maps/_ai/vibe/team-of-agents","编码智能体团队","通过协作的多个 AI 编码智能体来完成开发任务",1771693438213]