”惰性依赖”的警惕与治理","AI 编程助手提高效率的同时，会放大重复代码、代码 churn 和审查难度，需要用工程实践和流程设计来对冲”惰性依赖”风险","_ai/vibe/complacency.md",{"type":183,"children":184,"toc":1254},"root",[185,194,208,273,278,284,291,298,349,354,360,424,434,438,444,450,455,519,530,536,607,610,616,622,627,656,661,693,703,709,714,739,744,762,765,771,777,782,805,810,833,839,844,893,896,902,908,913,944,950,997,1000,1006,1012,1022,1027,1066,1072,1084,1131,1142,1148,1153,1195,1201,1206,1224,1229,1242],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"brief",[191],{"type":192,"value":193},"text","Brief",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198,200,206],{"type":192,"value":199},"对 AI 编程助手和代理（agents）的研究和实践逐渐暴露出一个结构性问题：",{"type":186,"tag":201,"props":202,"children":203},"strong",{},[204],{"type":192,"value":205},"随着使用时间增加，代码质量容易因为“惰性依赖”（complacency）而下滑",{"type":192,"value":207},"。",{"type":186,"tag":209,"props":210,"children":211},"ul",{},[212,231,249],{"type":186,"tag":213,"props":214,"children":215},"li",{},[216,218],{"type":192,"value":217},"实证信号：\n",{"type":186,"tag":209,"props":219,"children":220},{},[221,226],{"type":186,"tag":213,"props":222,"children":223},{},[224],{"type":192,"value":225},"GitClear 2024 研究发现，重复代码和代码 churn 的增长超出预期，而提交历史中的重构活动在减少。",{"type":186,"tag":213,"props":227,"children":228},{},[229],{"type":192,"value":230},"微软针对知识工作者的研究表明：AI 帮助带来的“信心提升”，往往以“批判性思考能力下降”为代价；在长期使用编程助手后，这种惰性思考会明显加剧。",{"type":186,"tag":213,"props":232,"children":233},{},[234,236],{"type":192,"value":235},"机制上：\n",{"type":186,"tag":209,"props":237,"children":238},{},[239,244],{"type":186,"tag":213,"props":240,"children":241},{},[242],{"type":192,"value":243},"AI 代理可以一次性生成更大规模的改动集（large change sets），人工 review 成本和难度上升，问题更难被及时发现。",{"type":186,"tag":213,"props":245,"children":246},{},[247],{"type":192,"value":248},"加速了“写代码”这一步，就隐性地对“审查、测试、重构”等后续环节施加压力，如果不做制度化补偿，整体质量会被侵蚀。",{"type":186,"tag":213,"props":250,"children":251},{},[252,254],{"type":192,"value":253},"应对建议（来自原文）：\n",{"type":186,"tag":209,"props":255,"children":256},{},[257,268],{"type":186,"tag":213,"props":258,"children":259},{},[260,262,267],{"type":192,"value":261},"在生产环境中有效使用 AI，需要",{"type":186,"tag":201,"props":263,"children":264},{},[265],{"type":192,"value":266},"重新强化代码质量意识和实践",{"type":192,"value":207},{"type":186,"tag":213,"props":269,"children":270},{},[271],{"type":192,"value":272},"尤其是将 TDD、静态分析等既有工程实践重新嵌入到编码工作流中，例如通过针对软件团队的“共享指令集”（curated shared instructions）来固化这些约束与规范。",{"type":186,"tag":195,"props":274,"children":275},{},[276],{"type":192,"value":277},"来源：技术雷达",{"type":186,"tag":187,"props":279,"children":281},{"id":280},"details",[282],{"type":192,"value":283},"Details",{"type":186,"tag":285,"props":286,"children":288},"h3",{"id":287},"一背景与现状从提效工具到系统性质量压力",[289],{"type":192,"value":290},"一、背景与现状：从“提效工具”到“系统性质量压力”",{"type":186,"tag":292,"props":293,"children":295},"h4",{"id":294},"_11-技术与业务场景ai-编程从辅助走向代理",[296],{"type":192,"value":297},"1.1 技术与业务场景：AI 编程从辅助走向代理",{"type":186,"tag":209,"props":299,"children":300},{},[301,324],{"type":186,"tag":213,"props":302,"children":303},{},[304,306],{"type":192,"value":305},"典型使用场景：\n",{"type":186,"tag":209,"props":307,"children":308},{},[309,314,319],{"type":186,"tag":213,"props":310,"children":311},{},[312],{"type":192,"value":313},"日常编码中使用 Copilot 类助手补全和生成函数、测试。",{"type":186,"tag":213,"props":315,"children":316},{},[317],{"type":192,"value":318},"通过自然语言需求驱动 agent 生成多个文件、跨模块改动。",{"type":186,"tag":213,"props":320,"children":321},{},[322],{"type":192,"value":323},"在原型开发、绿地项目中，用 AI 快速跑通端到端 demo。",{"type":186,"tag":213,"props":325,"children":326},{},[327,329],{"type":192,"value":328},"背景趋势：\n",{"type":186,"tag":209,"props":330,"children":331},{},[332,337],{"type":186,"tag":213,"props":333,"children":334},{},[335],{"type":192,"value":336},"早期共识是“AI 编码主要是提效工具”，风险更多被视为局部的、可控的。",{"type":186,"tag":213,"props":338,"children":339},{},[340,342,347],{"type":192,"value":341},"随着 AI 的覆盖范围从“补全几行代码”扩展到“生成大规模改动集”，其对",{"type":186,"tag":201,"props":343,"children":344},{},[345],{"type":192,"value":346},"整体工程系统",{"type":192,"value":348},"的影响被显著放大。",{"type":186,"tag":195,"props":350,"children":351},{},[352],{"type":192,"value":353},"这也意味着：对 AI 的评估不能只看“开发速度”，需要把“演进后的代码库形态”和“团队认知习惯的改变”也纳入考量。",{"type":186,"tag":292,"props":355,"children":357},{"id":356},"_12-研究发现效率收益与质量退化并存",[358],{"type":192,"value":359},"1.2 研究发现：效率收益与质量退化并存",{"type":186,"tag":209,"props":361,"children":362},{},[363,395],{"type":186,"tag":213,"props":364,"children":365},{},[366,368],{"type":192,"value":367},"GitClear 2024：\n",{"type":186,"tag":209,"props":369,"children":370},{},[371,383],{"type":186,"tag":213,"props":372,"children":373},{},[374,376,381],{"type":192,"value":375},"观察到**重复代码（duplication）",{"type":186,"tag":201,"props":377,"children":378},{},[379],{"type":192,"value":380},"和",{"type":192,"value":382},"代码 churn（短期内频繁增删改的代码）**显著上升。",{"type":186,"tag":213,"props":384,"children":385},{},[386,388,393],{"type":192,"value":387},"与此对照，",{"type":186,"tag":201,"props":389,"children":390},{},[391],{"type":192,"value":392},"重构类提交占比下降",{"type":192,"value":394},"，说明许多“第一次写得差不多就算了”的代码，没有被系统性打磨。",{"type":186,"tag":213,"props":396,"children":397},{},[398,400],{"type":192,"value":399},"微软对知识工作者的研究：\n",{"type":186,"tag":209,"props":401,"children":402},{},[403,408,419],{"type":186,"tag":213,"props":404,"children":405},{},[406],{"type":192,"value":407},"AI 使得个体在完成任务时**“自我感知的信心”上升**。",{"type":186,"tag":213,"props":409,"children":410},{},[411,413,418],{"type":192,"value":412},"但在可测量的指标上，",{"type":186,"tag":201,"props":414,"children":415},{},[416],{"type":192,"value":417},"批判性审查和深度思考的投入反而减少",{"type":192,"value":207},{"type":186,"tag":213,"props":420,"children":421},{},[422],{"type":192,"value":423},"长期使用编程助手后，团队中这种“有答案就不再往下问”的惰性模式会更明显。",{"type":186,"tag":195,"props":425,"children":426},{},[427,429],{"type":192,"value":428},"对技术负责人来说，这些信号指向的是：",{"type":186,"tag":201,"props":430,"children":431},{},[432],{"type":192,"value":433},"AI 的“提效收益”会与“认知松懈”叠加，最终体现在存量代码质量的慢性恶化上。",{"type":186,"tag":435,"props":436,"children":437},"hr",{},[],{"type":186,"tag":285,"props":439,"children":441},{"id":440},"二问题与风险惰性依赖的技术与组织后果",[442],{"type":192,"value":443},"二、问题与风险：惰性依赖的技术与组织后果",{"type":186,"tag":292,"props":445,"children":447},{"id":446},"_21-代码层面的结构性退化",[448],{"type":192,"value":449},"2.1 代码层面的结构性退化",{"type":186,"tag":195,"props":451,"children":452},{},[453],{"type":192,"value":454},"在广泛使用 AI 编码助手/代理的团队中，常见的风险模式包括：",{"type":186,"tag":209,"props":456,"children":457},{},[458,483,501],{"type":186,"tag":213,"props":459,"children":460},{},[461,463],{"type":192,"value":462},"重复与散乱：\n",{"type":186,"tag":209,"props":464,"children":465},{},[466,471],{"type":186,"tag":213,"props":467,"children":468},{},[469],{"type":192,"value":470},"AI 为了“就近满足上下文需求”，倾向于复制相似逻辑，而不是抽象复用。",{"type":186,"tag":213,"props":472,"children":473},{},[474,476,481],{"type":192,"value":475},"结果是：",{"type":186,"tag":201,"props":477,"children":478},{},[479],{"type":192,"value":480},"功能上线更快",{"type":192,"value":482},"，但后续修 bug / 改需求时维护成本急剧上升。",{"type":186,"tag":213,"props":484,"children":485},{},[486,488],{"type":192,"value":487},"短期 churn 增加：\n",{"type":186,"tag":209,"props":489,"children":490},{},[491,496],{"type":186,"tag":213,"props":492,"children":493},{},[494],{"type":192,"value":495},"开发者更容易“先让它写一版再说”，产生大量低质量试验性代码。",{"type":186,"tag":213,"props":497,"children":498},{},[499],{"type":192,"value":500},"如果缺乏严格的 review / 清理机制，这些“实验产物”往往残留在主干代码库。",{"type":186,"tag":213,"props":502,"children":503},{},[504,506],{"type":192,"value":505},"重构意愿降低：\n",{"type":186,"tag":209,"props":507,"children":508},{},[509,514],{"type":186,"tag":213,"props":510,"children":511},{},[512],{"type":192,"value":513},"由于“复制修一份就能过需求”，团队对“抽象、整合、简化”的内在动力被稀释。",{"type":186,"tag":213,"props":515,"children":516},{},[517],{"type":192,"value":518},"体现在数据上，就是重构型提交在整个提交历史中的占比下降。",{"type":186,"tag":195,"props":520,"children":521},{},[522,524,529],{"type":192,"value":523},"这些现象并不是 AI 独有，而是",{"type":186,"tag":201,"props":525,"children":526},{},[527],{"type":192,"value":528},"人类长期就存在的问题被放大加速",{"type":192,"value":207},{"type":186,"tag":292,"props":531,"children":533},{"id":532},"_22-认知与流程层面的惰性",[534],{"type":192,"value":535},"2.2 认知与流程层面的惰性",{"type":186,"tag":209,"props":537,"children":538},{},[539,557,575],{"type":186,"tag":213,"props":540,"children":541},{},[542,544],{"type":192,"value":543},"过度信任模型输出：\n",{"type":186,"tag":209,"props":545,"children":546},{},[547,552],{"type":186,"tag":213,"props":548,"children":549},{},[550],{"type":192,"value":551},"“AI 写的看起来没问题”常常替代了“我真的理解了代码意图和边界”。",{"type":186,"tag":213,"props":553,"children":554},{},[555],{"type":192,"value":556},"评审被动化：review 流于查风格、改命名，而不是深度审查领域逻辑。",{"type":186,"tag":213,"props":558,"children":559},{},[560,562],{"type":192,"value":561},"拆解问题的能力退化：\n",{"type":186,"tag":209,"props":563,"children":564},{},[565,570],{"type":186,"tag":213,"props":566,"children":567},{},[568],{"type":192,"value":569},"在“提示-生成-接受”的循环中，工程师容易跳过需求澄清、边界定义、建模等关键思考步骤。",{"type":186,"tag":213,"props":571,"children":572},{},[573],{"type":192,"value":574},"长期来看，团队的“架构思维密度”和“问题分解能力”都会受损。",{"type":186,"tag":213,"props":576,"children":577},{},[578,580],{"type":192,"value":579},"流程瓶颈挤压：\n",{"type":186,"tag":209,"props":581,"children":582},{},[583,595],{"type":186,"tag":213,"props":584,"children":585},{},[586,588,593],{"type":192,"value":587},"写代码明显加速后，",{"type":186,"tag":201,"props":589,"children":590},{},[591],{"type":192,"value":592},"测试、review、上线评估",{"type":192,"value":594},"成为新的瓶颈。",{"type":186,"tag":213,"props":596,"children":597},{},[598,600,605],{"type":192,"value":599},"如果组织不主动“抬升”这些环节的工程能力，",{"type":186,"tag":201,"props":601,"children":602},{},[603],{"type":192,"value":604},"就会自发削弱它们的标准",{"type":192,"value":606},"，以适配更快的提交节奏。",{"type":186,"tag":435,"props":608,"children":609},{},[],{"type":186,"tag":285,"props":611,"children":613},{"id":612},"三模式与原理从快写到系统配平",[614],{"type":192,"value":615},"三、模式与原理：从“快写”到“系统配平”",{"type":186,"tag":292,"props":617,"children":619},{"id":618},"_31-速度质量认知负载的再平衡",[620],{"type":192,"value":621},"3.1 速度—质量—认知负载的再平衡",{"type":186,"tag":195,"props":623,"children":624},{},[625],{"type":192,"value":626},"可以把 AI 编码工具视为在“实现代码”环节上强行压缩了周期：",{"type":186,"tag":209,"props":628,"children":629},{},[630,643],{"type":186,"tag":213,"props":631,"children":632},{},[633,635],{"type":192,"value":634},"过去：\n",{"type":186,"tag":209,"props":636,"children":637},{},[638],{"type":186,"tag":213,"props":639,"children":640},{},[641],{"type":192,"value":642},"需求澄清 → 设计 → 手写代码 → 手写测试 → review & 重构",{"type":186,"tag":213,"props":644,"children":645},{},[646,648],{"type":192,"value":647},"现在（AI 辅助）：\n",{"type":186,"tag":209,"props":649,"children":650},{},[651],{"type":186,"tag":213,"props":652,"children":653},{},[654],{"type":192,"value":655},"需求描述 → prompt → 一次生成大量代码 + 测试样例 → 轻量 review → merge",{"type":186,"tag":195,"props":657,"children":658},{},[659],{"type":192,"value":660},"如果其他环节不做调整，典型后果包括：",{"type":186,"tag":209,"props":662,"children":663},{},[664,676,688],{"type":186,"tag":213,"props":665,"children":666},{},[667,669,674],{"type":192,"value":668},"代码审查阶段：",{"type":186,"tag":201,"props":670,"children":671},{},[672],{"type":192,"value":673},"diff 过大",{"type":192,"value":675},"，reviewer 很难逐行理解和验证。",{"type":186,"tag":213,"props":677,"children":678},{},[679,681,686],{"type":192,"value":680},"测试阶段：",{"type":186,"tag":201,"props":682,"children":683},{},[684],{"type":192,"value":685},"测试覆盖和质量“被动接受”模型输出",{"type":192,"value":687},"，而非由工程师主动设计。",{"type":186,"tag":213,"props":689,"children":690},{},[691],{"type":192,"value":692},"演进阶段：缺少重构和演化设计，代码库像“地层沉积”一样堆积。",{"type":186,"tag":195,"props":694,"children":695},{},[696,698],{"type":192,"value":697},"因此，",{"type":186,"tag":201,"props":699,"children":700},{},[701],{"type":192,"value":702},"引入 AI 的前提不是“让工程实践变轻”，而是“重新设计如何让实践在新的速度条件下依然有效”。",{"type":186,"tag":292,"props":704,"children":706},{"id":705},"_32-coding-agents-带来的巨大变更集问题",[707],{"type":192,"value":708},"3.2 Coding agents 带来的“巨大变更集”问题",{"type":186,"tag":195,"props":710,"children":711},{},[712],{"type":192,"value":713},"相对普通助手，coding agent 的突出特点是：",{"type":186,"tag":209,"props":715,"children":716},{},[717,729,734],{"type":186,"tag":213,"props":718,"children":719},{},[720,722,727],{"type":192,"value":721},"生成",{"type":186,"tag":201,"props":723,"children":724},{},[725],{"type":192,"value":726},"多文件、多模块",{"type":192,"value":728},"的改动；",{"type":186,"tag":213,"props":730,"children":731},{},[732],{"type":192,"value":733},"改动之间经常存在跨边界依赖；",{"type":186,"tag":213,"props":735,"children":736},{},[737],{"type":192,"value":738},"本质上更接近“自动化执行一个小型重构或特性开发”。",{"type":186,"tag":195,"props":740,"children":741},{},[742],{"type":192,"value":743},"这直接导致：",{"type":186,"tag":209,"props":745,"children":746},{},[747,752,757],{"type":186,"tag":213,"props":748,"children":749},{},[750],{"type":192,"value":751},"Review 复杂度从“函数级”上升到“模块/系统级”；",{"type":186,"tag":213,"props":753,"children":754},{},[755],{"type":192,"value":756},"线上回滚与故障定位难度增加——一次错误可能影响更多路径；",{"type":186,"tag":213,"props":758,"children":759},{},[760],{"type":192,"value":761},"对 CI/CD 与回归测试体系提出更高要求，否则就只能靠“运气上线”。",{"type":186,"tag":435,"props":763,"children":764},{},[],{"type":186,"tag":285,"props":766,"children":768},{"id":767},"四对比与演进ai-工具前后的工程形态",[769],{"type":192,"value":770},"四、对比与演进：AI 工具前后的工程形态",{"type":186,"tag":292,"props":772,"children":774},{"id":773},"_41-传统高质量工程实践-vs-ai-加持下的新挑战",[775],{"type":192,"value":776},"4.1 传统高质量工程实践 vs AI 加持下的新挑战",{"type":186,"tag":195,"props":778,"children":779},{},[780],{"type":192,"value":781},"传统上，维持代码库长寿的关键手段包括：",{"type":186,"tag":209,"props":783,"children":784},{},[785,790,795,800],{"type":186,"tag":213,"props":786,"children":787},{},[788],{"type":192,"value":789},"TDD / 测试先行：先定行为边界，再写实现；",{"type":186,"tag":213,"props":791,"children":792},{},[793],{"type":192,"value":794},"持续重构：在功能迭代中不断整理抽象边界；",{"type":186,"tag":213,"props":796,"children":797},{},[798],{"type":192,"value":799},"静态分析与规范：对常见错误和风格问题做自动化约束；",{"type":186,"tag":213,"props":801,"children":802},{},[803],{"type":192,"value":804},"小步提交与可审查变更集。",{"type":186,"tag":195,"props":806,"children":807},{},[808],{"type":192,"value":809},"引入 AI 后，如果不做任何治理，常出现如下反差：",{"type":186,"tag":209,"props":811,"children":812},{},[813,818,823,828],{"type":186,"tag":213,"props":814,"children":815},{},[816],{"type":192,"value":817},"TDD 弱化： “AI 代码已可运行”被当作“行为已可靠”的替代。",{"type":186,"tag":213,"props":819,"children":820},{},[821],{"type":192,"value":822},"重构滞后：工程师更习惯“再复制一段新代码满足当前需求”。",{"type":186,"tag":213,"props":824,"children":825},{},[826],{"type":192,"value":827},"静态分析形同虚设：规则不更新、不针对 AI 生成模式做加强（例如检测重复逻辑、copy-paste 风险）。",{"type":186,"tag":213,"props":829,"children":830},{},[831],{"type":192,"value":832},"提交粒度变大：agent 一次性生成大变更集，破坏“小步可回滚”原则。",{"type":186,"tag":292,"props":834,"children":836},{"id":835},"_42-可能的演进方向",[837],{"type":192,"value":838},"4.2 可能的演进方向",{"type":186,"tag":195,"props":840,"children":841},{},[842],{"type":192,"value":843},"为了让 AI 真正服务于长期可维护性，可以考虑这样的演进路径：",{"type":186,"tag":209,"props":845,"children":846},{},[847,867,880],{"type":186,"tag":213,"props":848,"children":849},{},[850,852],{"type":192,"value":851},"将 AI 纳入“质量工具链”：\n",{"type":186,"tag":209,"props":853,"children":854},{},[855],{"type":186,"tag":213,"props":856,"children":857},{},[858,860,865],{"type":192,"value":859},"不是“人在上、AI 在下”，而是把 AI 作为",{"type":186,"tag":201,"props":861,"children":862},{},[863],{"type":192,"value":864},"执行规范与检查的自动化手段",{"type":192,"value":866},"之一。",{"type":186,"tag":213,"props":868,"children":869},{},[870,872],{"type":192,"value":871},"让 AI 也参与重构和测试改进：\n",{"type":186,"tag":209,"props":873,"children":874},{},[875],{"type":186,"tag":213,"props":876,"children":877},{},[878],{"type":192,"value":879},"引导 AI 生成 refactoring plan、测试增强方案，而非只用来“生成新功能代码”。",{"type":186,"tag":213,"props":881,"children":882},{},[883,885],{"type":192,"value":884},"从“代码级助手”升级为“工程级守门人”：\n",{"type":186,"tag":209,"props":886,"children":887},{},[888],{"type":186,"tag":213,"props":889,"children":890},{},[891],{"type":192,"value":892},"用共享指令固定质量红线（见下文），让 AI 在生成时自带审查意识。",{"type":186,"tag":435,"props":894,"children":895},{},[],{"type":186,"tag":285,"props":897,"children":899},{"id":898},"五系统影响对架构工程效率与协作的牵引",[900],{"type":192,"value":901},"五、系统影响：对架构、工程效率与协作的牵引",{"type":186,"tag":292,"props":903,"children":905},{"id":904},"_51-对架构与代码库形态的影响",[906],{"type":192,"value":907},"5.1 对架构与代码库形态的影响",{"type":186,"tag":195,"props":909,"children":910},{},[911],{"type":192,"value":912},"如果不加约束，AI 辅助编码往往会导致：",{"type":186,"tag":209,"props":914,"children":915},{},[916,921,926],{"type":186,"tag":213,"props":917,"children":918},{},[919],{"type":192,"value":920},"领域边界模糊：AI 只关心“把当前需求拼起来能跑”，不关心是否破坏既有领域划分。",{"type":186,"tag":213,"props":922,"children":923},{},[924],{"type":192,"value":925},"接口与模型扩张：为了兼容临时诉求不断往对象、DTO、API 里加字段，缺少“收敛与精简”。",{"type":186,"tag":213,"props":927,"children":928},{},[929,931],{"type":192,"value":930},"技术债表面隐蔽：\n",{"type":186,"tag":209,"props":932,"children":933},{},[934,939],{"type":186,"tag":213,"props":935,"children":936},{},[937],{"type":192,"value":938},"从静态看，代码能编译、能跑测试；",{"type":186,"tag":213,"props":940,"children":941},{},[942],{"type":192,"value":943},"从动态看，复杂度和耦合在缓慢积累，几年后演进阻力巨大。",{"type":186,"tag":292,"props":945,"children":947},{"id":946},"_52-对工程效率与质量文化的拉扯",[948],{"type":192,"value":949},"5.2 对工程效率与质量文化的拉扯",{"type":186,"tag":209,"props":951,"children":952},{},[953,966,979],{"type":186,"tag":213,"props":954,"children":955},{},[956,958],{"type":192,"value":957},"短期效率观：\n",{"type":186,"tag":209,"props":959,"children":960},{},[961],{"type":186,"tag":213,"props":962,"children":963},{},[964],{"type":192,"value":965},"团队容易只看“功能交付速度”，忽略“未来一年维护投入”。",{"type":186,"tag":213,"props":967,"children":968},{},[969,971],{"type":192,"value":970},"质量文化淡化：\n",{"type":186,"tag":209,"props":972,"children":973},{},[974],{"type":186,"tag":213,"props":975,"children":976},{},[977],{"type":192,"value":978},"如果管理层只追求“AI 提效指标”，工程师自然会在质量标准上“向下对齐”。",{"type":186,"tag":213,"props":980,"children":981},{},[982,984],{"type":192,"value":983},"知识沉淀路径变化：\n",{"type":186,"tag":209,"props":985,"children":986},{},[987,992],{"type":186,"tag":213,"props":988,"children":989},{},[990],{"type":192,"value":991},"原本通过手写和重构沉淀的“隐性知识”，被部分转移到“提示语”和“过往生成代码”中。",{"type":186,"tag":213,"props":993,"children":994},{},[995],{"type":192,"value":996},"如果缺乏规范的共享指令与知识库建设，这些知识很难被团队系统地复用。",{"type":186,"tag":435,"props":998,"children":999},{},[],{"type":186,"tag":285,"props":1001,"children":1003},{"id":1002},"六落地建议在生产中负责任地用-ai",[1004],{"type":192,"value":1005},"六、落地建议：在生产中“负责任地用 AI”",{"type":186,"tag":292,"props":1007,"children":1009},{"id":1008},"_61-强化并嵌入既有实践tdd-与静态分析",[1010],{"type":192,"value":1011},"6.1 强化并嵌入既有实践：TDD 与静态分析",{"type":186,"tag":195,"props":1013,"children":1014},{},[1015,1017],{"type":192,"value":1016},"原文明确提出：",{"type":186,"tag":201,"props":1018,"children":1019},{},[1020],{"type":192,"value":1021},"在生产环境中有效使用 AI，需要重新强化代码质量实践，尤其是 TDD 和静态分析，并把它们嵌入到开发流中。",{"type":186,"tag":195,"props":1023,"children":1024},{},[1025],{"type":192,"value":1026},"一个可操作的落地思路是：",{"type":186,"tag":209,"props":1028,"children":1029},{},[1030,1048],{"type":186,"tag":213,"props":1031,"children":1032},{},[1033,1035],{"type":192,"value":1034},"对 TDD 的强化：\n",{"type":186,"tag":209,"props":1036,"children":1037},{},[1038,1043],{"type":186,"tag":213,"props":1039,"children":1040},{},[1041],{"type":192,"value":1042},"明确要求“AI 生成代码前先定义测试”，或者让 AI 先生成测试 skeleton，再填实现。",{"type":186,"tag":213,"props":1044,"children":1045},{},[1046],{"type":192,"value":1047},"在 review checklist 中加入“测试先行/测试充分性”项，而不仅是“代码可读性”。",{"type":186,"tag":213,"props":1049,"children":1050},{},[1051,1053],{"type":192,"value":1052},"对静态分析的升级：\n",{"type":186,"tag":209,"props":1054,"children":1055},{},[1056,1061],{"type":186,"tag":213,"props":1057,"children":1058},{},[1059],{"type":192,"value":1060},"针对 AI 生成特点增加规则，例如：\n- 重复逻辑检测；\n- 可疑大函数/大类的警报；\n- magic number / 无注释复杂逻辑的提示。",{"type":186,"tag":213,"props":1062,"children":1063},{},[1064],{"type":192,"value":1065},"将静态分析结果纳入 CI 阶段的“硬门槛”，而不是可选提示。",{"type":186,"tag":292,"props":1067,"children":1069},{"id":1068},"_62-利用共享指令把规范写进工作流",[1070],{"type":192,"value":1071},"6.2 利用“共享指令”把规范写进工作流",{"type":186,"tag":195,"props":1073,"children":1074},{},[1075,1077,1082],{"type":192,"value":1076},"原文提到的一个关键建议是：",{"type":186,"tag":201,"props":1078,"children":1079},{},[1080],{"type":192,"value":1081},"通过精心策划的“共享指令集”（curated shared instructions）直接嵌入团队的编码工作流",{"type":192,"value":1083},"。这在实践中可以演化为：",{"type":186,"tag":209,"props":1085,"children":1086},{},[1087,1105,1118],{"type":186,"tag":213,"props":1088,"children":1089},{},[1090,1092],{"type":192,"value":1091},"团队级系统提示（system / team prompt）：\n",{"type":186,"tag":209,"props":1093,"children":1094},{},[1095,1100],{"type":186,"tag":213,"props":1096,"children":1097},{},[1098],{"type":192,"value":1099},"固定质量原则：如“禁止复制粘贴大段代码”、“需要解释复杂逻辑意图”等。",{"type":186,"tag":213,"props":1101,"children":1102},{},[1103],{"type":192,"value":1104},"约束生成范围：例如“严禁改动超出当前模块边界的代码”。",{"type":186,"tag":213,"props":1106,"children":1107},{},[1108,1110],{"type":192,"value":1109},"场景化模板：\n",{"type":186,"tag":209,"props":1111,"children":1112},{},[1113],{"type":186,"tag":213,"props":1114,"children":1115},{},[1116],{"type":192,"value":1117},"不同任务类型（bug 修复 / 新功能 / 重构 / 跨模块变更）对应不同的提示模板和 review checklist。",{"type":186,"tag":213,"props":1119,"children":1120},{},[1121,1123],{"type":192,"value":1122},"持续演化机制：\n",{"type":186,"tag":209,"props":1124,"children":1125},{},[1126],{"type":186,"tag":213,"props":1127,"children":1128},{},[1129],{"type":192,"value":1130},"将线上事故、review 发现的问题沉淀为新指令，不断迭代团队共享 prompt。",{"type":186,"tag":195,"props":1132,"children":1133},{},[1134,1136,1141],{"type":192,"value":1135},"这样做的目标是：",{"type":186,"tag":201,"props":1137,"children":1138},{},[1139],{"type":192,"value":1140},"把“经验性规范”变成“系统性约束”，并让 AI 自身也遵守这些约束",{"type":192,"value":207},{"type":186,"tag":292,"props":1143,"children":1145},{"id":1144},"_63-控制变更粒度与审查策略",[1146],{"type":192,"value":1147},"6.3 控制变更粒度与审查策略",{"type":186,"tag":195,"props":1149,"children":1150},{},[1151],{"type":192,"value":1152},"对于 coding agents 特别需要注意：",{"type":186,"tag":209,"props":1154,"children":1155},{},[1156,1169,1182],{"type":186,"tag":213,"props":1157,"children":1158},{},[1159,1161],{"type":192,"value":1160},"限制单次变更范围：\n",{"type":186,"tag":209,"props":1162,"children":1163},{},[1164],{"type":186,"tag":213,"props":1165,"children":1166},{},[1167],{"type":192,"value":1168},"在提示中明确“一个任务只改一个有界上下文/子系统”，减少超大 diff。",{"type":186,"tag":213,"props":1170,"children":1171},{},[1172,1174],{"type":192,"value":1173},"强化自动化保护网：\n",{"type":186,"tag":209,"props":1175,"children":1176},{},[1177],{"type":186,"tag":213,"props":1178,"children":1179},{},[1180],{"type":192,"value":1181},"为 agent 生成的改动配置更严格的测试门槛和预发布验证流程。",{"type":186,"tag":213,"props":1183,"children":1184},{},[1185,1187],{"type":192,"value":1186},"采用分阶段 rollout：\n",{"type":186,"tag":209,"props":1188,"children":1189},{},[1190],{"type":186,"tag":213,"props":1191,"children":1192},{},[1193],{"type":192,"value":1194},"对高风险变更采用灰度发布、分流验证，并要求 agent 输出“变更点清单”和“潜在影响区域”。",{"type":186,"tag":292,"props":1196,"children":1198},{"id":1197},"_64-识别不适用场景与风险边界",[1199],{"type":192,"value":1200},"6.4 识别不适用场景与风险边界",{"type":186,"tag":195,"props":1202,"children":1203},{},[1204],{"type":192,"value":1205},"在以下场景中，应更加谨慎使用 AI 直接生成或大规模修改代码：",{"type":186,"tag":209,"props":1207,"children":1208},{},[1209,1214,1219],{"type":186,"tag":213,"props":1210,"children":1211},{},[1212],{"type":192,"value":1213},"高安全/高合规要求系统（金融、隐私敏感业务等）；",{"type":186,"tag":213,"props":1215,"children":1216},{},[1217],{"type":192,"value":1218},"对领域建模要求极高、规则复杂且多变的核心域；",{"type":186,"tag":213,"props":1220,"children":1221},{},[1222],{"type":192,"value":1223},"现有代码库已高度耦合，缺乏测试与观测基础，无法有效回归与监控。",{"type":186,"tag":195,"props":1225,"children":1226},{},[1227],{"type":192,"value":1228},"对于这些场景，更合理的策略通常是：",{"type":186,"tag":209,"props":1230,"children":1231},{},[1232,1237],{"type":186,"tag":213,"props":1233,"children":1234},{},[1235],{"type":192,"value":1236},"优先用 AI 做辅助分析、重构建议、测试生成，而非直接放权给 agent 做大规模改动；",{"type":186,"tag":213,"props":1238,"children":1239},{},[1240],{"type":192,"value":1241},"先补齐测试和监控能力，再逐步扩大 AI 参与范围。",{"type":186,"tag":195,"props":1243,"children":1244},{},[1245,1247,1252],{"type":192,"value":1246},"综合来看，原文的核心立场并不是“反对 AI 编程”，而是明确提醒：",{"type":186,"tag":201,"props":1248,"children":1249},{},[1250],{"type":192,"value":1251},"AI 提速的是“编码”这一局部环节，但代价是在系统层面增加了质量管理的复杂度和认知风险",{"type":192,"value":1253},"。要在生产中有效使用这类工具，技术负责人需要把 TDD、静态分析、review 规范等实践重新“嵌入工作流”，并通过共享指令和流程设计，把团队的质量文化编码进 AI 使用方式，而不是寄希望于“更聪明的模型自动抵消这些风险”。",{"title":178,"searchDepth":1255,"depth":1255,"links":1256},2,[1257,1258],{"id":189,"depth":1255,"text":193},{"id":280,"depth":1255,"text":283,"children":1259},[1260,1262,1263,1264,1265,1266],{"id":287,"depth":1261,"text":290},3,{"id":440,"depth":1261,"text":443},{"id":612,"depth":1261,"text":615},{"id":767,"depth":1261,"text":770},{"id":898,"depth":1261,"text":901},{"id":1002,"depth":1261,"text":1005},"markdown","content:6.maps:_ai:vibe:complacency.md","content","6.maps/_ai/vibe/complacency.md","6.maps/_ai/vibe/complacency","md",[1274,1278],{"_path":1275,"title":1276,"description":1277},"/maps/_ai/vibe/anchoring","Anchoring coding agents to a ref application","在编码代理时代，通过将其锚定至实时可编译的参考应用，有效应对代码漂移问题",{"_path":1279,"title":1280,"description":1281},"/maps/_ai/vibe/playful-ai","玩具化设计思维","将复杂 AI 能力转化为情感化、游戏化体验的包装策略",1772504967547]