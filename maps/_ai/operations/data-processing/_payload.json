ns",false,true,"","Data Processing","AI 数据处理技术与最佳实践，包括 NeMo Curator、Ray Data、MinHash + LSH 等工具和方法。","_ai/data-processing.md",{"type":183,"children":184,"toc":358},"root",[185,194,201,207,238,244,249,268,274,279,298,304,309,328,334,339],{"type":186,"tag":187,"props":188,"children":190},"element","h1",{"id":189},"数据处理-data-processing",[191],{"type":192,"value":193},"text","数据处理 (Data Processing)",{"type":186,"tag":195,"props":196,"children":198},"h2",{"id":197},"nemo-curatorgpu-加速的企业级数据整理",[199],{"type":192,"value":200},"NeMo Curator：GPU 加速的企业级数据整理",{"type":186,"tag":202,"props":203,"children":204},"p",{},[205],{"type":192,"value":206},"NeMo Curator 是 NVIDIA 推出的企业级数据整理工具包，专为大规模生成式 AI 训练设计。它利用 RAPIDS 库（cuDF、cuML、cuGraph）实现 GPU 加速，配合 Ray 支持多节点分布式扩展。在 DGX 系统上可在数小时内处理 TB 级语料，比传统 CPU 方案快 10-100 倍。支持文档提取、文本清洗、精确/模糊去重、质量评分和 PII 检测等模块化管道。",{"type":186,"tag":202,"props":208,"children":209},{},[210,212,221,223,230,231],{"type":192,"value":211},"见：",{"type":186,"tag":213,"props":214,"children":218},"a",{"href":215,"rel":216},"https://github.com/NVIDIA-NeMo/Curator",[217],"nofollow",[219],{"type":192,"value":220},"NeMo Curator GitHub",{"type":192,"value":222}," | ",{"type":186,"tag":213,"props":224,"children":227},{"href":225,"rel":226},"https://docs.nvidia.com/nemo/curator/",[217],[228],{"type":192,"value":229},"NVIDIA 官方文档",{"type":192,"value":222},{"type":186,"tag":213,"props":232,"children":235},{"href":233,"rel":234},"https://developer.nvidia.cn/blog/streamlining-data-processing-for-domain-adaptive-pretraining-with-nvidia-nemo-curator/",[217],[236],{"type":192,"value":237},"ChipNeMo 案例",{"type":186,"tag":195,"props":239,"children":241},{"id":240},"ray-data分布式数据加载与预处理",[242],{"type":192,"value":243},"Ray Data：分布式数据加载与预处理",{"type":186,"tag":202,"props":245,"children":246},{},[247],{"type":192,"value":248},"Ray Data 是 Ray 生态系统中的数据层，提供可扩展的数据加载、转换和传输能力。它与 PyTorch、TensorFlow、HuggingFace 无缝集成，支持从单机扩展到千节点集群。关键特性包括流式处理（无需全部载入内存）、自动分片（与分布式训练对齐）、以及 CPU 预处理 + GPU 训练的流水线并行。",{"type":186,"tag":202,"props":250,"children":251},{},[252,253,260,261],{"type":192,"value":211},{"type":186,"tag":213,"props":254,"children":257},{"href":255,"rel":256},"https://docs.ray.io/en/latest/data/data.html",[217],[258],{"type":192,"value":259},"Ray Data 文档",{"type":192,"value":222},{"type":186,"tag":213,"props":262,"children":265},{"href":263,"rel":264},"https://www.anyscale.com/blog/fast-flexible-scalable-data-loading-for-ml-training-with-ray-data",[217],[266],{"type":192,"value":267},"Ray Data 博客",{"type":186,"tag":195,"props":269,"children":271},{"id":270},"minhash-lsh大规模近似去重",[272],{"type":192,"value":273},"MinHash + LSH：大规模近似去重",{"type":186,"tag":202,"props":275,"children":276},{},[277],{"type":192,"value":278},"MinHash 结合局部敏感哈希（LSH）是大规模数据集去重的标准算法。通过计算文档的签名并比较相似度，可以高效识别重复或高度相似的文档。研究表明这是 LLM 预训练数据去重的最合适算法，Data-Juicer 的实现在 8 节点 1280 CPU 核心上可在 3 小时内完成 TB 级数据集去重。",{"type":186,"tag":202,"props":280,"children":281},{},[282,283,290,291],{"type":192,"value":211},{"type":186,"tag":213,"props":284,"children":287},{"href":285,"rel":286},"https://dl.acm.org/doi/10.1007/978-3-031-82481-4_27",[217],[288],{"type":192,"value":289},"MinHash LSH 去重研究",{"type":192,"value":222},{"type":186,"tag":213,"props":292,"children":295},{"href":293,"rel":294},"https://zilliz.com/blog/data-deduplication-at-trillion-scale-solve-the-biggest-bottleneck-of-llm-training",[217],[296],{"type":192,"value":297},"Zilliz 万亿级去重",{"type":186,"tag":195,"props":299,"children":301},{"id":300},"数据质量分层tier-1-3-体系",[302],{"type":192,"value":303},"数据质量分层：Tier 1-3 体系",{"type":186,"tag":202,"props":305,"children":306},{},[307],{"type":192,"value":308},"高质量数据应分为多个层级训练：Tier 1 是人工精选（Wikipedia、书籍、学术论文），Tier 2 是自动过滤后的 Web 数据（Common Crawl 子集），Tier 3 是代码、对话等专项数据。训练时按不同比例混合各层级数据，可显著提升模型泛化能力并减少数据污染。",{"type":186,"tag":202,"props":310,"children":311},{},[312,313,320,321],{"type":192,"value":211},{"type":186,"tag":213,"props":314,"children":317},{"href":315,"rel":316},"https://arxiv.org/abs/2107.06499",[217],[318],{"type":192,"value":319},"Deduplicating Training Data 论文",{"type":192,"value":222},{"type":186,"tag":213,"props":322,"children":325},{"href":323,"rel":324},"https://arxiv.org/abs/2101.00027",[217],[326],{"type":192,"value":327},"The Pile 数据集论文",{"type":186,"tag":195,"props":329,"children":331},{"id":330},"数据混合策略决定模型能力的关键",[332],{"type":192,"value":333},"数据混合策略：决定模型能力的关键",{"type":186,"tag":202,"props":335,"children":336},{},[337],{"type":192,"value":338},"不同来源数据的比例对模型能力有显著影响：代码数据比例提升会增强推理能力，对话数据比例提升会增强指令遵循能力，Web 数据比例提升会扩展知识广度但引入噪声。精心设计的数据混合策略是训练高性能模型的核心 secret sauce。",{"type":186,"tag":202,"props":340,"children":341},{},[342,343,350,351],{"type":192,"value":211},{"type":186,"tag":213,"props":344,"children":347},{"href":345,"rel":346},"https://huggingface.co/spaces/HuggingFaceFW/blogpost-fineweb-v1",[217],[348],{"type":192,"value":349},"FineWeb 技术报告",{"type":192,"value":222},{"type":186,"tag":213,"props":352,"children":355},{"href":353,"rel":354},"https://datacomp.ai/",[217],[356],{"type":192,"value":357},"DataComp 基准",{"title":178,"searchDepth":359,"depth":359,"links":360},2,[361,362,363,364,365],{"id":197,"depth":359,"text":200},{"id":240,"depth":359,"text":243},{"id":270,"depth":359,"text":273},{"id":300,"depth":359,"text":303},{"id":330,"depth":359,"text":333},"markdown","content:6.maps:_ai:operations:data-processing.md","content","6.maps/_ai/operations/data-processing.md","6.maps/_ai/operations/data-processing","md",[373,377],{"_path":374,"title":375,"description":376},"/maps/_ai/models/tokenization","Tokenization","Text tokenization and encoding",{"_path":378,"title":379,"description":380},"/maps/_ai/operations/distributed","Distributed Training","分布式训练技术与框架，包括 DeepSpeed、FSDP、Megatron-Core 等大规模模型训练方案。",1772185506267]