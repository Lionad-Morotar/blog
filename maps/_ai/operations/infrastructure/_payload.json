,false,true,"","Infrastructure","AI 基础设施与云平台，包括 Modal、Lambda Labs、SkyPilot 等 Serverless GPU 和多云编排方案。","_ai/infrastructure.md",{"type":183,"children":184,"toc":343},"root",[185,194,201,207,238,244,249,276,282,287,314,319,324],{"type":186,"tag":187,"props":188,"children":190},"element","h1",{"id":189},"基础设施-infrastructure",[191],{"type":192,"value":193},"text","基础设施 (Infrastructure)",{"type":186,"tag":195,"props":196,"children":198},"h2",{"id":197},"modalpython-原生的-serverless-gpu-平台",[199],{"type":192,"value":200},"Modal：Python 原生的 Serverless GPU 平台",{"type":186,"tag":202,"props":203,"children":204},"p",{},[205],{"type":192,"value":206},"Modal 是面向 AI/ML 工程师的 Serverless 计算平台，核心卖点是\"Python-native\"——用纯 Python 代码定义计算任务，自动处理容器化、调度、扩缩容。支持从 0 到数百 GPU 的秒级扩容，按秒计费，用后即焚。内置高性能分布式文件系统，大模型权重秒级加载。适合快速原型验证和推理服务部署。",{"type":186,"tag":202,"props":208,"children":209},{},[210,212,221,223,230,231],{"type":192,"value":211},"见：",{"type":186,"tag":213,"props":214,"children":218},"a",{"href":215,"rel":216},"https://modal.com/",[217],"nofollow",[219],{"type":192,"value":220},"Modal 官网",{"type":192,"value":222}," | ",{"type":186,"tag":213,"props":224,"children":227},{"href":225,"rel":226},"https://modal.com/docs",[217],[228],{"type":192,"value":229},"Modal 文档",{"type":192,"value":222},{"type":186,"tag":213,"props":232,"children":235},{"href":233,"rel":234},"https://modal.com/blog/serverless-gpu-article",[217],[236],{"type":192,"value":237},"Serverless GPU 对比",{"type":186,"tag":195,"props":239,"children":241},{"id":240},"lambda-labs高性价比-ai-云服务商",[242],{"type":192,"value":243},"Lambda Labs：高性价比 AI 云服务商",{"type":186,"tag":202,"props":245,"children":246},{},[247],{"type":192,"value":248},"Lambda Labs 是专注 AI 工作负载的云服务商，以高性价比 GPU 实例著称。相比 AWS/GCP，Lambda 的 GPU 价格通常低 50%+，且提供即时可用的实例（无需排队）。支持 NVIDIA B200、H100、A100、GH200 等最新 GPU，提供按小时计费的 GPU 实例和长期租用的私有集群，是训练任务的性价比之选。",{"type":186,"tag":202,"props":250,"children":251},{},[252,253,260,261,268,269],{"type":192,"value":211},{"type":186,"tag":213,"props":254,"children":257},{"href":255,"rel":256},"https://lambda.ai/",[217],[258],{"type":192,"value":259},"Lambda Labs 官网",{"type":192,"value":222},{"type":186,"tag":213,"props":262,"children":265},{"href":263,"rel":264},"https://lambda.ai/pricing",[217],[266],{"type":192,"value":267},"Lambda 定价",{"type":192,"value":222},{"type":186,"tag":213,"props":270,"children":273},{"href":271,"rel":272},"https://lambda.ai/blog/deepchat-3-step-training-at-scale-nvidia-h100-sxm5-vs-a100-sxm4",[217],[274],{"type":192,"value":275},"H100 vs A100 对比",{"type":186,"tag":195,"props":277,"children":279},{"id":278},"skypilot多云-ai-编排框架",[280],{"type":192,"value":281},"SkyPilot：多云 AI 编排框架",{"type":186,"tag":202,"props":283,"children":284},{},[285],{"type":192,"value":286},"SkyPilot 是伯克利大学 Sky Computing Lab 开源的多云编排工具，目标是\"Run AI on Any Infrastructure\"。它抽象了不同云厂商的差异，支持 AWS、GCP、Azure、Lambda、Kubernetes、Slurm 等多种基础设施，自动选择最便宜的可用区域和实例类型，实例被抢占时自动迁移，让用户专注算法而非基础设施。",{"type":186,"tag":202,"props":288,"children":289},{},[290,291,298,299,306,307],{"type":192,"value":211},{"type":186,"tag":213,"props":292,"children":295},{"href":293,"rel":294},"https://skypilot.co/",[217],[296],{"type":192,"value":297},"SkyPilot 官网",{"type":192,"value":222},{"type":186,"tag":213,"props":300,"children":303},{"href":301,"rel":302},"https://docs.skypilot.co/",[217],[304],{"type":192,"value":305},"SkyPilot 文档",{"type":192,"value":222},{"type":186,"tag":213,"props":308,"children":311},{"href":309,"rel":310},"https://www.usenix.org/system/files/nsdi23-yang-zongheng.pdf",[217],[312],{"type":192,"value":313},"SkyPilot 论文",{"type":186,"tag":195,"props":315,"children":317},{"id":316},"基础设施选型指南",[318],{"type":192,"value":316},{"type":186,"tag":202,"props":320,"children":321},{},[322],{"type":192,"value":323},"快速原型和推理服务推荐 Modal，开发效率最高；长期训练任务推荐 Lambda Labs，性价比最优；多云和混合云场景推荐 SkyPilot，避免厂商锁定；企业级需求选择 AWS/GCP/Azure，生态最完善。实际选择应权衡开发效率、成本、可迁移性和合规要求。",{"type":186,"tag":202,"props":325,"children":326},{},[327,328,335,336],{"type":192,"value":211},{"type":186,"tag":213,"props":329,"children":332},{"href":330,"rel":331},"https://fullstackdeeplearning.com/cloud-gpus/",[217],[333],{"type":192,"value":334},"Cloud GPUs 完整对比",{"type":192,"value":222},{"type":186,"tag":213,"props":337,"children":340},{"href":338,"rel":339},"https://www.linkedin.com/pulse/skypilotvllmaws-vs-modal-which-platform-should-power-ai-ramkumar-zqghe",[217],[341],{"type":192,"value":342},"SkyPilot vs Modal 对比",{"title":178,"searchDepth":344,"depth":344,"links":345},2,[346,347,348,349],{"id":197,"depth":344,"text":200},{"id":240,"depth":344,"text":243},{"id":278,"depth":344,"text":281},{"id":316,"depth":344,"text":316},"markdown","content:6.maps:_ai:operations:infrastructure.md","content","6.maps/_ai/operations/infrastructure.md","6.maps/_ai/operations/infrastructure","md",[357,361],{"_path":358,"title":359,"description":360},"/maps/_ai/operations/distributed","Distributed Training","分布式训练技术与框架，包括 DeepSpeed、FSDP、Megatron-Core 等大规模模型训练方案。",{"_path":362,"title":363,"description":364},"/maps/_ai/operations/mlops","MLOps","机器学习运维平台与工具，包括 Weights & Biases、MLflow、TensorBoard 等实验跟踪和模型管理方案。",1772504961230]