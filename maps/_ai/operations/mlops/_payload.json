习运维平台与工具，包括 Weights & Biases、MLflow、TensorBoard 等实验跟踪和模型管理方案。","_ai/mlops.md",{"type":183,"children":184,"toc":345},"root",[185,193,200,206,237,243,248,275,281,286,297,303,308,327,332],{"type":186,"tag":187,"props":188,"children":190},"element","h1",{"id":189},"mlops",[191],{"type":192,"value":179},"text",{"type":186,"tag":194,"props":195,"children":197},"h2",{"id":196},"weights-biases商业-mlops-平台事实标准",[198],{"type":192,"value":199},"Weights & Biases：商业 MLOps 平台事实标准",{"type":186,"tag":201,"props":202,"children":203},"p",{},[204],{"type":192,"value":205},"W&B 是商业 MLOps 平台的事实标准，提供实验跟踪、超参搜索、模型管理、协作报告等一站式能力。核心功能包括自动记录超参/指标/输出、Artifact 版本追踪、Sweeps 分布式超参搜索、交互式实验报告。是 LLM 微调实验跟踪的首选工具。",{"type":186,"tag":201,"props":207,"children":208},{},[209,211,220,222,229,230],{"type":192,"value":210},"见：",{"type":186,"tag":212,"props":213,"children":217},"a",{"href":214,"rel":215},"https://wandb.ai/",[216],"nofollow",[218],{"type":192,"value":219},"W&B 官网",{"type":192,"value":221}," | ",{"type":186,"tag":212,"props":223,"children":226},{"href":224,"rel":225},"https://wandb.ai/site/solutions/llm-fine-tuning/",[216],[227],{"type":192,"value":228},"W&B LLM 专项功能",{"type":192,"value":221},{"type":186,"tag":212,"props":231,"children":234},{"href":232,"rel":233},"https://wandb.ai/site/experiment-tracking/",[216],[235],{"type":192,"value":236},"W&B 实验跟踪",{"type":186,"tag":194,"props":238,"children":240},{"id":239},"mlflow开源-ml-生命周期管理",[241],{"type":192,"value":242},"MLflow：开源 ML 生命周期管理",{"type":186,"tag":201,"props":244,"children":245},{},[246],{"type":192,"value":247},"MLflow 是 Databricks 开源的 MLOps 平台，模块化设计可独立使用各组件：Tracking（实验记录）、Projects（可复现工作流打包）、Models（模型格式标准化）、Registry（模型版本管理）。完全开源、自建托管，适合需要数据主权和成本控制的企业。",{"type":186,"tag":201,"props":249,"children":250},{},[251,252,259,260,267,268],{"type":192,"value":210},{"type":186,"tag":212,"props":253,"children":256},{"href":254,"rel":255},"https://mlflow.org/",[216],[257],{"type":192,"value":258},"MLflow 官网",{"type":192,"value":221},{"type":186,"tag":212,"props":261,"children":264},{"href":262,"rel":263},"https://mlflow.org/docs/latest/ml/model-registry/",[216],[265],{"type":192,"value":266},"MLflow Model Registry",{"type":192,"value":221},{"type":186,"tag":212,"props":269,"children":272},{"href":270,"rel":271},"https://github.com/mlflow/mlflow",[216],[273],{"type":192,"value":274},"MLflow GitHub",{"type":186,"tag":194,"props":276,"children":278},{"id":277},"tensorboard基础可视化工具",[279],{"type":192,"value":280},"TensorBoard：基础可视化工具",{"type":186,"tag":201,"props":282,"children":283},{},[284],{"type":192,"value":285},"TensorBoard 是 TensorFlow 配套的可视化工具，也支持 PyTorch（通过 torch.utils.tensorboard）。适合小规模实验快速可视化、训练曲线和学习率监控、嵌入向量降维可视化。轻量易用，是调试训练过程的常用工具。",{"type":186,"tag":201,"props":287,"children":288},{},[289,290],{"type":192,"value":210},{"type":186,"tag":212,"props":291,"children":294},{"href":292,"rel":293},"https://www.tensorflow.org/tensorboard",[216],[295],{"type":192,"value":296},"TensorBoard 文档",{"type":186,"tag":194,"props":298,"children":300},{"id":299},"llm-专项-mlops-挑战",[301],{"type":192,"value":302},"LLM 专项 MLOps 挑战",{"type":186,"tag":201,"props":304,"children":305},{},[306],{"type":192,"value":307},"LLM 带来独特挑战：模型文件巨大（7B 模型 14GB，版本管理困难）、训练周期长（需要断点续训和容错）、评估复杂（多维度基准测试）、对齐流程多阶段（SFT → DPO → RLHF）。解决方案包括模型注册表（MLflow Model Registry、W&B Artifacts）、分布式跟踪（Ray Train + W&B 集成）、评估集成（lm-eval-harness 结果自动记录）、Prompt 版本管理（W&B Prompts）。",{"type":186,"tag":201,"props":309,"children":310},{},[311,312,319,320],{"type":192,"value":210},{"type":186,"tag":212,"props":313,"children":316},{"href":314,"rel":315},"https://github.com/tensorchord/Awesome-LLMOps",[216],[317],{"type":192,"value":318},"LLMOps 工具集",{"type":192,"value":221},{"type":186,"tag":212,"props":321,"children":324},{"href":322,"rel":323},"https://www.datacamp.com/blog/top-mlops-tools",[216],[325],{"type":192,"value":326},"2025 MLOps 工具榜单",{"type":186,"tag":194,"props":328,"children":330},{"id":329},"可重复性与实验管理",[331],{"type":192,"value":329},{"type":186,"tag":201,"props":333,"children":334},{},[335,337,343],{"type":192,"value":336},"可重复性是 ML 系统的核心支柱，涉及随机种子固定、数据版本控制、环境容器化等关键实践。详见 ",{"type":186,"tag":212,"props":338,"children":340},{"href":339},"./reproducibility",[341],{"type":192,"value":342},"ML 可重复性",{"type":192,"value":344},"。",{"title":178,"searchDepth":346,"depth":346,"links":347},2,[348,349,350,351,352],{"id":196,"depth":346,"text":199},{"id":239,"depth":346,"text":242},{"id":277,"depth":346,"text":280},{"id":299,"depth":346,"text":302},{"id":329,"depth":346,"text":329},"markdown","content:6.maps:_ai:operations:mlops.md","content","6.maps/_ai/operations/mlops.md","6.maps/_ai/operations/mlops","md",[360,364],{"_path":361,"title":362,"description":363},"/maps/_ai/operations/infrastructure","Infrastructure","AI 基础设施与云平台，包括 Modal、Lambda Labs、SkyPilot 等 Serverless GPU 和多云编排方案。",{"_path":365,"title":366,"description":367},"/maps/_ai/operations/operations","Operations","AI 系统运维与工程实践，涵盖数据处理、分布式训练、基础设施和 MLOps 等关键领域。",1772185505607]