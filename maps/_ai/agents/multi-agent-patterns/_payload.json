185,"tag":203,"props":864,"children":865},{},[866,870],{"type":185,"tag":207,"props":867,"children":868},{},[869],{"type":191,"value":466},{"type":191,"value":871},"：直接共享，智能体可直接将上下文发给另一智能体",{"type":185,"tag":203,"props":873,"children":874},{},[875,879],{"type":185,"tag":207,"props":876,"children":877},{},[878],{"type":191,"value":358},{"type":191,"value":880},"：完全隔离，高层目标与底层任务细节分开",{"type":185,"tag":203,"props":882,"children":883},{},[884,888],{"type":185,"tag":207,"props":885,"children":886},{},[887],{"type":191,"value":351},{"type":191,"value":889},"：链式传递，上一步输出直接变成下一步输入（接力赛模式）",{"type":185,"tag":203,"props":891,"children":892},{},[893,897],{"type":185,"tag":207,"props":894,"children":895},{},[896],{"type":191,"value":687},{"type":191,"value":898},"：角色文件定义上下文，Evaluators 提取关键信息",{"type":185,"tag":203,"props":900,"children":901},{},[902,906],{"type":185,"tag":207,"props":903,"children":904},{},[905],{"type":191,"value":713},{"type":191,"value":907},"：客户端 Sessions 管理，无内置持久化",{"type":185,"tag":203,"props":909,"children":910},{},[911,915],{"type":185,"tag":207,"props":912,"children":913},{},[914],{"type":191,"value":739},{"type":191,"value":916},"：MsgHub 灵活路由，支持记忆管理",{"type":185,"tag":203,"props":918,"children":919},{},[920,924],{"type":185,"tag":207,"props":921,"children":922},{},[923],{"type":191,"value":765},{"type":191,"value":925},"：状态管理器持久化，支持检查点恢复",{"type":185,"tag":186,"props":927,"children":929},{"id":928},"生产环境最佳实践",[930],{"type":191,"value":928},{"type":185,"tag":560,"props":932,"children":934},{"id":933},"状态持久化与错误恢复",[935],{"type":191,"value":933},{"type":185,"tag":280,"props":937,"children":938},{},[939],{"type":191,"value":940},"智能体可能运行很长时间，需要 durable execution 和从错误点恢复的能力，而非从头重启。",{"type":185,"tag":560,"props":942,"children":944},{"id":943},"调试与可观测性",[945],{"type":191,"value":943},{"type":185,"tag":280,"props":947,"children":948},{},[949],{"type":191,"value":950},"智能体决策是动态的、非确定性的，需要完整的生产追踪（Tracing）来诊断失败原因。",{"type":185,"tag":560,"props":952,"children":954},