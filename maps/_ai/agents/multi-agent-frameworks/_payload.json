graph",[364],[1196],{"type":191,"value":1197},"LangGraph - GitHub",{"type":185,"tag":194,"props":1199,"children":1201},{"id":1200},"低级别智能体编排框架",[1202],{"type":191,"value":1200},{"type":185,"tag":200,"props":1204,"children":1205},{},[1206],{"type":191,"value":1207},"LangGraph 是 LangChain 团队开发的低级别编排框架，用于构建、管理和部署长期运行、有状态的智能体（Agents）。它以图（Graph）的形式组织 Agent 工作流，支持循环、条件分支和持久化状态管理。被 Klarna、Replit、Elastic 等公司采用。",{"type":185,"tag":194,"props":1209,"children":1211},{"id":1210},"核心优势",[1212],{"type":191,"value":1210},{"type":185,"tag":211,"props":1214,"children":1215},{},[1216,1226,1236,1246,1256],{"type":185,"tag":215,"props":1217,"children":1218},{},[1219,1224],{"type":185,"tag":219,"props":1220,"children":1221},{},[1222],{"type":191,"value":1223},"持久化执行（Durable Execution）",{"type":191,"value":1225},"：Agent 能在故障后自动恢复，从断点继续执行",{"type":185,"tag":215,"props":1227,"children":1228},{},[1229,1234],{"type":185,"tag":219,"props":1230,"children":1231},{},[1232],{"type":191,"value":1233},"人机协作（Human-in-the-loop）",{"type":191,"value":1235},"：可在执行过程中随时检查和修改 Agent 状态",{"type":185,"tag":215,"props":1237,"children":1238},{},[1239,1244],{"type":185,"tag":219,"props":1240,"children":1241},{},[1242],{"type":191,"value":1243},"全面记忆（Comprehensive Memory）",{"type":191,"value":1245},"：支持短期工作记忆和长期跨会话持久化记忆",{"type":185,"tag":215,"props":1247,"children":1248},{},[1249,1254],{"type":185,"tag":219,"props":1250,"children":1251},{},[1252],{"type":191,"value":1253},"调试与可观测性",{"type":191,"value":1255},"：通过 LangSmith 可视化执行路径、状态转换和运行时指标",{"type":185,"tag":215,"props":1257,"children":1258},{},[1259,1264],{"type":185,"tag":219,"props":1260,"children":1261},{},[1262],{"type":191,"value":1263},"生产级部署",{"type":191,"value":1265},"：支持长周期、有状态工作流的规模化部署",{"type":185,"tag":194,"props":1267,"children":1269},{"id":1268},"与-langchain-生态系统的关系",[1270],{"type":191,"value":1271},"与 LangChain 生态系统的关系",{"type":185,"tag":211,"props":1273,"children":1274},{},[1275,1285,1295],{"type":185,"tag":215,"props":1276,"children":1277},{}