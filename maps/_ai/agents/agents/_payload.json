ose",[259],{"type":191,"value":260},"Goose",{"type":185,"tag":194,"props":262,"children":263},{},[264],{"type":185,"tag":198,"props":265,"children":266},{},[267],{"type":185,"tag":202,"props":268,"children":270},{"href":269},"/maps/_ai/agents/goose/prompts",[271],{"type":191,"value":272},"Goose Prompts",{"type":185,"tag":186,"props":274,"children":276},{"id":275},"多智能体框架",[277],{"type":191,"value":275},{"type":185,"tag":194,"props":279,"children":280},{},[281,292,301,310,319],{"type":185,"tag":198,"props":282,"children":283},{},[284,290],{"type":185,"tag":202,"props":285,"children":287},{"href":286},"/maps/_ai/agents/agent-ecosystem",[288],{"type":191,"value":289},"Agent 生态系统全景",{"type":191,"value":291},"：框架、平台、协议和基础设施全面调研",{"type":185,"tag":198,"props":293,"children":294},{},[295],{"type":185,"tag":202,"props":296,"children":298},{"href":297},"/maps/_ai/agents/agentscope",[299],{"type":191,"value":300},"AgentScope - 阿里开源多智能体框架",{"type":185,"tag":198,"props":302,"children":303},{},[304],{"type":185,"tag":202,"props":305,"children":307},{"href":306},"/maps/_ai/agents/multi-agent-frameworks",[308],{"type":191,"value":309},"框架对比：AutoGen、DeepAgents、CrewAI、ElizaOS、OpenAI Swarm、AgentScope、LangGraph",{"type":185,"tag":198,"props":311,"children":312},{},[313],{"type":185,"tag":202,"props":314,"children":316},{"href":315},"/maps/_ai/agents/multi-agent-architecture",[317],{"type":191,"value":318},"架构决策与工程实践",{"type":185,"tag":198,"props":320,"children":321},{},[322],{"type":185,"tag":202,"props":323,"children":325},{"href":324},"/maps/_ai/agents/multi-agent-patterns",[326],{"type":191,"value":327},"构建模式与实践指南",{"type":185,"tag":186,"props":329,"children":331},{"id":330},"agent-sdk",[332],{"type":191,"value":333},"Agent SDK",{"type":185,"tag":194,"props":335,"children":336},{},[337,346],{"type":185,"tag":198,"props":338,"children":339},{},[340],{"type":185,"tag":202,"props":341,"children":343},{"href":342},"/maps/_ai/agents/claude-agent-sdk-releases",[344],{"type":191,"value":345},"Claude Agent SDK (TypeScript) 发布记录",{"type":185,"tag":198,"props":347,"children":348},{},[349],{"type":185,"tag":202,"props":350,"children":352},{"href":351},"/maps/_ai/agents/openai-agents-js-releases",[353],{"type":191,"value":354},"OpenAI Agents SDK (JavaScript) 发布记录",{"type":185,"tag":186,"props":356,"children":358},{"id":357},"agent-架构第一性原理",[359],{"type":191,"value":360},"Agent 架构第一性原理",{"type":185,"tag":362,"props":363,"children":365},"h4",{"id":364},"工作流与智能体的核心区别",[366],{"type":191,"value":367},"工作流与智能体的核心区别？",{"type":185,"tag":369,"props":370,"children":371},"p",{},[372],{"type":191,"value":373},"决策权归属是区分二者的关键。",{"type":185,"tag":369,"props":375,"children":376},{},[377,383],{"type":185,"tag":378,"props":379,"children":380},"strong",{},[381],{"type":191,"value":382},"工作流（Workflow）",{"type":191,"value":384}," 像流水线或菜谱，任务流程固定且预先设计好。LLM 被代码调用完成特定子任务（如总结文本、提取信息），决策权在代码而非模型。",{"type":185,"tag":369,"props":386,"children":387},{},[388,393],{"type":185,"tag":378,"props":389,"children":390},{},[391],{"type":191,"value":392},"智能体（Agent）",{"type":191,"value":394}," 像侦探，你给它总目标，但没有固定剧本。它会根据情况动态决定下一步该做什么、使用哪个工具、任务是否完成，决策权在 LLM 而非代码。",{"type":185,"tag":362,"props":396,"children":398},{"id":397},"技术选型金字塔",[399],{"type":191,"value":400},"技术选型金字塔？",{"type":185,"tag":369,"props":402,"children":403},{},[404],{"type":191,"value":405},"Anthropic 建议始终从最简单方案开始，只有当简单方案无法满足需求时才增加复杂性。",{"type":185,"tag":407,"props":408,"children":409},"table",{},[410,434],{"type":185,"tag":411,"props":412,"children":413},"thead",{},[414],{"type":185,"tag":415,"props":416,"children":417},"tr",{},[418,424,429],{"type":185,"tag":419,"props":420,"children":421},"th",{},[422],{"type":191,"value":423},"层级",{"type":185,"tag":419,"props":425,"children":426},{},[427],{"type":191,"value":428},"方案",{"type":185,"tag":419,"props":430,"children":431},{},[432],{"type":191,"value":433},"适用场景",{"type":185,"tag":435,"props":436,"children":437},"tbody",{},[438,457,475],{"type":185,"tag":415,"props":439,"children":440},{},[441,447,452],{"type":185,"tag":442,"props":443,"children":444},"td",{},[445],{"type":191,"value":446},"底层（基础）",{"type":185,"tag":442,"props":448,"children":449},{},[450],{"type":191,"value":451},"优化单一 LLM 调用",{"type":185,"tag":442,"props":453,"children":454},{},[455],{"type":191,"value":456},"简单任务，追求效率。通过 RAG、Few-shot 示例解决大部分问题",{"type":185,"tag":415,"props":458,"children":459},{},[460,465,470],{"type":185,"tag":442,"props":461,"children":462},{},[463],{"type":191,"value":464},"中层（中级）",{"type":185,"tag":442,"props":466,"children":467},{},[468],{"type":191,"value":469},"工作流",{"type":185,"tag":442,"props":471,"children":472},{},[473],{"type":191,"value":474},"流程固定、明确、可预测，对质量有高标准",{"type":185,"tag":415,"props":476,"children":477},{},[478,483,488],{"type":185,"tag":442,"props":479,"children":480},{},[481],{"type":191,"value":482},"顶层（高级）",{"type":185,"tag":442,"props":484,"children":485},{},[486],{"type":191,"value":487},"智能体",{"type":185,"tag":442,"props":489,"children":490},{},[491],{"type":191,"value":492},"开放式任务，无法预测步骤，需要模型大规模自主决策",{"type":185,"tag":369,"props":494,"children":495},{},[496,501],{"type":185,"tag":378,"props":497,"children":498},{},[499],{"type":191,"value":500},"示例",{"type":191,"value":502},"：翻译 / 本地化任务",{"type":185,"tag":194,"props":504,"children":505},{},[506,511,516],{"type":185,"tag":198,"props":507,"children":508},{},[509],{"type":191,"value":510},"读一封外文邮件/工单，快速了解大意即可 → 单一 LLM 调用",{"type":185,"tag":198,"props":512,"children":513},{},[514],{"type":191,"value":515},"需要稳定产出与可追溯质量（术语一致、格式固定、必须复核），如用户手册/合规文档翻译 → 工作流（翻译 → 术语校验 → 审校/回译）",{"type":185,"tag":198,"props":517,"children":518},{},[519],{"type":191,"value":520},"目标是”把内容做成一条可发布的多语言产线”，涉及选题、改写、本地化用词、生成标题与摘要、更新站点/提交 PR 等多步决策与多工具协作 → 智能体",{"type":185,"tag":369,"props":522,"children":523},{},[524,526,533],{"type":191,"value":525},"见：",{"type":185,"tag":202,"props":527,"children":530},{"href":528,"rel":529},"https://www.anthropic.com/engineering/building-effective-agents",[224],[531],{"type":191,"value":532},"Building Effective Agents",{"type":191,"value":534},"（Anthropic 官方指南）",{"type":185,"tag":362,"props":536,"children":538},{"id":537},"五种工作流模式",[539],{"type":191,"value":540},"五种工作流模式？",{"type":185,"tag":369,"props":542,"children":543},{},[544],{"type":191,"value":545},"Anthropic 从生产实践中总结出五种可组合的工作流模式，按复杂度递增：",{"type":185,"tag":369,"props":547,"children":548},{},[549,554],{"type":185,"tag":378,"props":550,"children":551},{},[552],{"type":191,"value":553},"Prompt Chaining（提示链）",{"type":191,"value":555},"\n任务分解为顺序步骤，每步 LLM 处理上一步输出。可添加程序检查（gate）确保过程正确。",{"type":185,"tag":194,"props":557,"children":558},{},[559,564],{"type":185,"tag":198,"props":560,"children":561},{},[562],{"type":191,"value":563},"适用：可清晰分解为固定子任务，用延迟换准确性",{"type":185,"tag":198,"props":565,"children":566},{},[567],{"type":191,"value":568},"示例：生成营销文案 → 翻译成其他语言；写大纲 → 检查 → 写文档",{"type":185,"tag":369,"props":570,"children":571},{},[572,577],{"type":185,"tag":378,"props":573,"children":574},{},[575],{"type":191,"value":576},"Routing（路由）",{"type":191,"value":578},"\n输入分类后路由到专门下游任务，分离关注点，构建更专业的提示。",{"type":185,"tag":194,"props":580,"children":581},{},[582,587],{"type":185,"tag":198,"props":583,"children":584},{},[585],{"type":191,"value":586},"适用：复杂任务有明确类别，分类可由 LLM 或传统模型处理",{"type":185,"tag":198,"props":588,"children":589},{},[590],{"type":191,"value":591},"示例：客服查询按类型（一般问题/退款/技术支持）路由到不同流程",{"type":185,"tag":369,"props":593,"children":594},{},[595],{"type":185,"tag":378,"props":596,"children":597},{},[598],{"type":191,"value":599},"Parallelization（并行化）",{"type":185,"tag":194,"props":601,"children":602},{},[603,613,623,628],{"type":185,"tag":198,"props":604,"children":605},{},[606,611],{"type":185,"tag":378,"props":607,"children":608},{},[609],{"type":191,"value":610},"Sectioning（分段）",{"type":191,"value":612},"：任务拆分为独立子任务并行处理",{"type":185,"tag":198,"props":614,"children":615},{},[616,621],{"type":185,"tag":378,"props":617,"children":618},{},[619],{"type":191,"value":620},"Voting（投票）",{"type":191,"value":622},"：同一任务多次运行，聚合多样输出",{"type":185,"tag":198,"props":624,"children":625},{},[626],{"type":191,"value":627},"适用：可并行提速，或需多视角/多次尝试提高置信度",{"type":185,"tag":198,"props":629,"children":630},{},[631],{"type":191,"value":632},"示例：代码漏洞审查（多提示并行审查）、内容安全评估",{"type":185,"tag":369,"props":634,"children":635},{},[636,641],{"type":185,"tag":378,"props":637,"children":638},{},[639],{"type":191,"value":640},"Orchestrator-workers（编排器-工作者）",{"type":191,"value":642},"\n中心 LLM 动态分解任务，委派给工作 LLM，再综合结果。与并行的关键区别：子任务不是预定义的，而是由编排器根据输入动态决定。",{"type":185,"tag":194,"props":644,"children":645},{},[646,651],{"type":185,"tag":198,"props":647,"children":648},{},[649],{"type":191,"value":650},"适用：复杂任务无法预测子任务（如编码需修改的文件数量和性质取决于任务）",{"type":185,"tag":198,"props":652,"children":653},{},[654],{"type":191,"value":655},"示例：多文件复杂代码修改、多源信息搜集分析",{"type":185,"tag":369,"props":657,"children":658},{},[659,664],{"type":185,"tag":378,"props":660,"children":661},{},[662],{"type":191,"value":663},"Evaluator-optimizer（评估-优化）",{"type":191,"value":665},"\n一个 LLM 生成响应，另一个提供评估反馈，循环迭代。",{"type":185,"tag":194,"props":667,"children":668},{},[669,674],{"type":185,"tag":198,"props":670,"children":671},{},[672],{"type":191,"value":673},"适用：你能清楚定义“好/坏”的标准，而且多改几轮确实会变更好。通常有两个信号：人工点评能明显改善结果；模型也能按同一套标准给出可用的点评",{"type":185,"tag":198,"props":675,"children":676},{},[677],{"type":191,"value":678},"示例：文学翻译（捕捉细微差别）、复杂搜索任务（多轮搜索分析）",{"type":185,"tag":362,"props":680,"children":682},{"id":681},"agent-设计三原则",[683],{"type":191,"value":684},"Agent 设计三原则？",{"type":185,"tag":686,"props":687,"children":688},"ol",{},[689,699,709],{"type":185,"tag":198,"props":690,"children":691},{},[692,697],{"type":185,"tag":378,"props":693,"children":694},{},[695],{"type":191,"value":696},"简洁性",{"type":191,"value":698}," —— 保持设计简单",{"type":185,"tag":198,"props":700,"children":701},{},[702,707],{"type":185,"tag":378,"props":703,"children":704},{},[705],{"type":191,"value":706},"透明性",{"type":191,"value":708}," —— 显式展示规划步骤",{"type":185,"tag":198,"props":710,"children":711},{},[712,717],{"type":185,"tag":378,"props":713,"children":714},{},[715],{"type":191,"value":716},"ACI（Agent-Computer Interface）",{"type":191,"value":718}," —— 精心设计的工具文档和测试",{"type":185,"tag":362,"props":720,"children":722},{"id":721},"工具设计的最佳实践",[723],{"type":191,"value":724},"工具设计的最佳实践？",{"type":185,"tag":369,"props":726,"children":727},{},[728],{"type":191,"value":729},"设计工具时，投入与 HCI（人机界面）相当的努力到 ACI（Agent-Computer Interface）：",{"type":185,"tag":369,"props":731,"children":732},{},[733],{"type":185,"tag":378,"props":734,"children":735},{},[736],{"type":191,"value":737},"格式选择原则",{"type":185,"tag":194,"props":739,"children":740},{},[741,746,751],{"type":185,"tag":198,"props":742,"children":743},{},[744],{"type":191,"value":745},"给模型足够 token 在”陷入困境”前思考",{"type":185,"tag":198,"props":747,"children":748},{},[749],{"type":191,"value":750},"格式贴近模型在互联网上自然见过的形式",{"type":185,"tag":198,"props":752,"children":753},{},[754],{"type":191,"value":755},"避免格式开销（如 diff 需计算行数、JSON 需转义引号）",{"type":185,"tag":369,"props":757,"children":758},{},[759],{"type":185,"tag":378,"props":760,"children":761},{},[762],{"type":191,"value":763},"设计检查清单",{"type":185,"tag":194,"props":765,"children":766},{},[767,772,777,782],{"type":185,"tag":198,"props":768,"children":769},{},[770],{"type":191,"value":771},"站在模型角度：工具描述和参数是否一目了然？好的工具定义包含示例用法、边界情况、输入格式要求",{"type":185,"tag":198,"props":773,"children":774},{},[775],{"type":191,"value":776},"优化参数命名和描述：像为团队初级开发者写优秀 docstring",{"type":185,"tag":198,"props":778,"children":779},{},[780],{"type":191,"value":781},"测试迭代：在 workbench 中运行大量示例输入，观察模型错误并迭代",{"type":185,"tag":198,"props":783,"children":784},{},[785],{"type":191,"value":786},"Poka-yoke（防错）：调整参数使错误更难发生",{"type":185,"tag":369,"props":788,"children":789},{},[790],{"type":185,"tag":378,"props":791,"children":792},{},[793],{"type":191,"value":794},"Anthropic 实战经验",{"type":185,"tag":369,"props":796,"children":797},{},[798],{"type":191,"value":799},"在构建 SWE-bench Agent 时，优化工具的时间超过优化提示。例如：发现模型在使用相对路径的工具上出错（Agent 已移出根目录后），改为要求绝对路径后，模型 flawlessly 使用该方法。",{"type":185,"tag":362,"props":801,"children":803},{"id":802},"长时运行-agent-的-harness-设计",[804],{"type":191,"value":805},"长时运行 Agent 的 Harness 设计？",{"type":185,"tag":369,"props":807,"children":808},{},[809,811,816,818,823],{"type":191,"value":810},"当 Agent 需要跨多个上下文窗口工作（数小时甚至数天）时，核心挑战是",{"type":185,"tag":378,"props":812,"children":813},{},[814],{"type":191,"value":815},"每个新会话都从零开始",{"type":191,"value":817},"，对之前工作一无所知。Anthropic 采用 ",{"type":185,"tag":378,"props":819,"children":820},{},[821],{"type":191,"value":822},"Initializer Agent + Coding Agent",{"type":191,"value":824}," 的双代理架构解决此问题。",{"type":185,"tag":369,"props":826,"children":827},{},[828],{"type":185,"tag":378,"props":829,"children":830},{},[831],{"type":191,"value":832},"Initializer Agent（初始化代理）",{"type":185,"tag":369,"props":834,"children":835},{},[836],{"type":191,"value":837},"首次会话运行，负责搭建基础环境：",{"type":185,"tag":194,"props":839,"children":840},{},[841,859,870,881],{"type":185,"tag":198,"props":842,"children":843},{},[844,851,853],{"type":185,"tag":845,"props":846,"children":848},"code",{"className":847},[],[849],{"type":191,"value":850},"feature_list.json",{"type":191,"value":852},"：详细功能清单（如 claude.ai 克隆项目超过 200 个功能），全部初始标记为 ",{"type":185,"tag":845,"props":854,"children":856},{"className":855},[],[857],{"type":191,"value":858},"failing",{"type":185,"tag":198,"props":860,"children":861},{},[862,868],{"type":185,"tag":845,"props":863,"children":865},{"className":864},[],[866],{"type":191,"value":867},"claude-progress.txt",{"type":191,"value":869},"：进度日志，记录每个会话完成的工作",{"type":185,"tag":198,"props":871,"children":872},{},[873,879],{"type":185,"tag":845,"props":874,"children":876},{"className":875},[],[877],{"type":191,"value":878},"init.sh",{"type":191,"value":880},"：启动脚本，一键运行开发服务器",{"type":185,"tag":198,"props":882,"children":883},{},[884],{"type":191,"value":885},"初始 git commit，建立版本基线",{"type":185,"tag":369,"props":887,"children":888},{},[889],{"type":185,"tag":378,"props":890,"children":891},{},[892],{"type":191,"value":893},"Coding Agent（编码代理）",{"type":185,"tag":369,"props":895,"children":896},{},[897],{"type":191,"value":898},"后续所有会话运行，遵循增量开发原则：",{"type":185,"tag":194,"props":900,"children":901},{},[902,914,926],{"type":185,"tag":198,"props":903,"children":904},{},[905,907,912],{"type":191,"value":906},"会话开始时：读取进度文件和 git log → 运行 ",{"type":185,"tag":845,"props":908,"children":910},{"className":909},[],[911],{"type":191,"value":878},{"type":191,"value":913}," 启动服务 → 端到端测试验证基础功能",{"type":185,"tag":198,"props":915,"children":916},{},[917,919,924],{"type":191,"value":918},"每次只处理",{"type":185,"tag":378,"props":920,"children":921},{},[922],{"type":191,"value":923},"一个功能",{"type":191,"value":925},"，避免\"一次性做完\"的冲动",{"type":185,"tag":198,"props":927,"children":928},{},[929],{"type":191,"value":930},"会话结束时：提交 git commit（描述性消息）→ 更新进度文件 → 保持环境在\"可合并状态\"",{"type":185,"tag":369,"props":932,"children":933},{},[934],{"type":185,"tag":378,"props":935,"children":936},{},[937],{"type":191,"value":938},"功能清单的设计要点",{"type":185,"tag":369,"props":940,"children":941},{},[942,944,950,952,958,959,965,966,972,974,979],{"type":191,"value":943},"使用 JSON 而非 Markdown，因为模型更不容易误改 JSON 结构。每个功能包含 ",{"type":185,"tag":845,"props":945,"children":947},{"className":946},[],[948],{"type":191,"value":949},"category",{"type":191,"value":951},"、",{"type":185,"tag":845,"props":953,"children":955},{"className":954},[],[956],{"type":191,"value":957},"description",{"type":191,"value":951},{"type":185,"tag":845,"props":960,"children":962},{"className":961},[],[963],{"type":191,"value":964},"steps",{"type":191,"value":951},{"type":185,"tag":845,"props":967,"children":969},{"className":968},[],[970],{"type":191,"value":971},"passes",{"type":191,"value":973}," 字段。Coding Agent 只能修改 ",{"type":185,"tag":845,"props":975,"children":977},{"className":976},[],[978],{"type":191,"value":971},{"type":191,"value":980}," 字段，强烈措辞约束：\"删除或编辑测试是不可接受的，这会导致功能缺失或 bug\"。",{"type":185,"tag":369,"props":982,"children":983},{},[984],{"type":185,"tag":378,"props":985,"children":986},{},[987],{"type":191,"value":988},"端到端测试的必要性",{"type":185,"tag":369,"props":990,"children":991},{},[992],{"type":191,"value":993},"Agent 容易\"未经充分测试就标记功能完成\"。显式提示使用浏览器自动化工具（如 Puppeteer MCP），像人类用户一样测试。这能发现仅从代码看不出的 bug，但注意 Claude 无法看到浏览器原生 alert 弹窗。",{"type":185,"tag":407,"props":995,"children":996},{},[997,1018],{"type":185,"tag":411,"props":998,"children":999},{},[1000],{"type":185,"tag":415,"props":1001,"children":1002},{},[1003,1008,1013],{"type":185,"tag":419,"props":1004,"children":1005},{},[1006],{"type":191,"value":1007},"常见失败模式",{"type":185,"tag":419,"props":1009,"children":1010},{},[1011],{"type":191,"value":1012},"Initializer 解决方案",{"type":185,"tag":419,"props":1014,"children":1015},{},[1016],{"type":191,"value":1017},"Coding Agent 解决方案",{"type":185,"tag":435,"props":1019,"children":1020},{},[1021,1039,1057,1075],{"type":185,"tag":415,"props":1022,"children":1023},{},[1024,1029,1034],{"type":185,"tag":442,"props":1025,"children":1026},{},[1027],{"type":191,"value":1028},"过早宣布整个项目完成",{"type":185,"tag":442,"props":1030,"children":1031},{},[1032],{"type":191,"value":1033},"设置详细功能清单",{"type":185,"tag":442,"props":1035,"children":1036},{},[1037],{"type":191,"value":1038},"每次只选一个功能开发",{"type":185,"tag":415,"props":1040,"children":1041},{},[1042,1047,1052],{"type":185,"tag":442,"props":1043,"children":1044},{},[1045],{"type":191,"value":1046},"留下 bug 或未记录的进度",{"type":185,"tag":442,"props":1048,"children":1049},{},[1050],{"type":191,"value":1051},"初始化 git 和进度文件",{"type":185,"tag":442,"props":1053,"children":1054},{},[1055],{"type":191,"value":1056},"开始读进度/git log，结束写 commit",{"type":185,"tag":415,"props":1058,"children":1059},{},[1060,1065,1070],{"type":185,"tag":442,"props":1061,"children":1062},{},[1063],{"type":191,"value":1064},"过早标记功能完成",{"type":185,"tag":442,"props":1066,"children":1067},{},[1068],{"type":191,"value":1069},"设置功能清单文件",{"type":185,"tag":442,"props":1071,"children":1072},{},[1073],{"type":191,"value":1074},"自验证所有功能，仔细测试后才标记 passing",{"type":185,"tag":415,"props":1076,"children":1077},{},[1078,1083,1095],{"type":185,"tag":442,"props":1079,"children":1080},{},[1081],{"type":191,"value":1082},"花时间摸索如何运行应用",{"type":185,"tag":442,"props":1084,"children":1085},{},[1086,1088,1093],{"type":191,"value":1087},"编写 ",{"type":185,"tag":845,"props":1089,"children":1091},{"className":1090},[],[1092],{"type":191,"value":878},{"type":191,"value":1094}," 脚本",{"type":185,"tag":442,"props":1096,"children":1097},{},[1098,1100],{"type":191,"value":1099},"会话开始就读 ",{"type":185,"tag":845,"props":1101,"children":1103},{"className":1102},[],[1104],{"type":191,"value":878},{"type":185,"tag":369,"props":1106,"children":1107},{},[1108,1109,1116],{"type":191,"value":525},{"type":185,"tag":202,"props":1110,"children":1113},{"href":1111,"rel":1112},"https://www.anthropic.com/engineering/effective-harnesses-for-long-running-agents",[224],[1114],{"type":191,"value":1115},"Effective harnesses for long-running agents",{"type":191,"value":1117},"（Anthropic Engineering）",{"type":185,"tag":362,"props":1119,"children":1121},{"id":1120},"claude-agent-sdk-的核心设计原则",[1122],{"type":191,"value":1123},"Claude Agent SDK 的核心设计原则？",{"type":185,"tag":369,"props":1125,"children":1126},{},[1127,1129,1134],{"type":191,"value":1128},"Claude Agent SDK（原 Claude Code SDK）的设计哲学是",{"type":185,"tag":378,"props":1130,"children":1131},{},[1132],{"type":191,"value":1133},"给 Claude 一台计算机",{"type":191,"value":1135},"——让它能够使用程序员日常使用的工具（终端、文件系统、代码执行），从而像人类一样工作。",{"type":185,"tag":369,"props":1137,"children":1138},{},[1139,1141,1146],{"type":191,"value":1140},"这不仅让 Claude 擅长编码，还能处理各种非编码任务：读取 CSV、搜索网页、构建可视化、解释指标等。核心反馈循环是：",{"type":185,"tag":378,"props":1142,"children":1143},{},[1144],{"type":191,"value":1145},"收集上下文 → 采取行动 → 验证工作 → 重复",{"type":191,"value":1147},"。",{"type":185,"tag":1149,"props":1150,"children":1151},"blockquote",{},[1152],{"type":185,"tag":369,"props":1153,"children":1154},{},[1155],{"type":191,"value":1156},"Over the past several months, Claude Code has become far more than a coding tool. At Anthropic, we've been using it for deep research, video creation, and note-taking, among countless other non-coding applications. In fact, it has begun to power almost all of our major agent loops.\n—— Anthropic",{"type":185,"tag":362,"props":1158,"children":1160},{"id":1159},"agent-如何有效收集上下文",[1161],{"type":191,"value":1162},"Agent 如何有效收集上下文？",{"type":185,"tag":369,"props":1164,"children":1165},{},[1166,1171,1173,1179,1180,1186],{"type":185,"tag":378,"props":1167,"children":1168},{},[1169],{"type":191,"value":1170},"Agentic Search（代理式搜索）",{"type":191,"value":1172},"\n文件系统代表\"可能被拉入上下文\"的信息。Agent 使用 ",{"type":185,"tag":845,"props":1174,"children":1176},{"className":1175},[],[1177],{"type":191,"value":1178},"grep",{"type":191,"value":951},{"type":185,"tag":845,"props":1181,"children":1183},{"className":1182},[],[1184],{"type":191,"value":1185},"tail",{"type":191,"value":1187}," 等 bash 脚本自主决定如何加载大文件（如日志）。文件夹结构本身成为一种上下文工程。",{"type":185,"tag":369,"props":1189,"children":1190},{},[1191,1196],{"type":185,"tag":378,"props":1192,"children":1193},{},[1194],{"type":191,"value":1195},"Semantic Search（语义搜索）",{"type":191,"value":1197},"\n通常比代理式搜索更快，但准确性较低、维护更困难、透明度更低。建议先使用代理式搜索，仅在需要更快结果或更多变体时添加语义搜索。",{"type":185,"tag":369,"props":1199,"children":1200},{},[1201,1206],{"type":185,"tag":378,"props":1202,"children":1203},{},[1204],{"type":191,"value":1205},"Subagents（子代理）",{"type":191,"value":1207},"\nSDK 默认支持子代理，有两个主要用途：",{"type":185,"tag":194,"props":1209,"children":1210},{},[1211,1221],{"type":185,"tag":198,"props":1212,"children":1213},{},[1214,1219],{"type":185,"tag":378,"props":1215,"children":1216},{},[1217],{"type":191,"value":1218},"并行化",{"type":191,"value":1220},"：同时启动多个子代理处理不同任务",{"type":185,"tag":198,"props":1222,"children":1223},{},[1224,1229],{"type":185,"tag":378,"props":1225,"children":1226},{},[1227],{"type":191,"value":1228},"上下文管理",{"type":191,"value":1230},"：子代理使用独立的上下文窗口，只返回相关信息给编排器",{"type":185,"tag":369,"props":1232,"children":1233},{},[1234,1239,1241,1247],{"type":185,"tag":378,"props":1235,"children":1236},{},[1237],{"type":191,"value":1238},"Compaction（上下文压缩）",{"type":191,"value":1240},"\n当 Agent 长时间运行时，自动总结之前的消息以避免上下文耗尽。这是 Claude Code ",{"type":185,"tag":845,"props":1242,"children":1244},{"className":1243},[],[1245],{"type":191,"value":1246},"/compact",{"type":191,"value":1248}," 命令的底层能力。",{"type":185,"tag":362,"props":1250,"children":1252},{"id":1251},"agent-采取行动的关键方式",[1253],{"type":191,"value":1254},"Agent 采取行动的关键方式？",{"type":185,"tag":369,"props":1256,"children":1257},{},[1258,1263],{"type":185,"tag":378,"props":1259,"children":1260},{},[1261],{"type":191,"value":1262},"Tools（工具）",{"type":191,"value":1264},"\n工具是 Agent 执行的主要构建块，在 Claude 的上下文窗口中非常突出。设计工具时要考虑上下文效率，将最频繁的操作定义为工具。",{"type":185,"tag":369,"props":1266,"children":1267},{},[1268,1273],{"type":185,"tag":378,"props":1269,"children":1270},{},[1271],{"type":191,"value":1272},"Bash & Scripts",{"type":191,"value":1274},"\nBash 作为通用工具，让 Agent 能够灵活地使用计算机完成各种任务。例如：下载 PDF、转换为文本、搜索内容。",{"type":185,"tag":369,"props":1276,"children":1277},{},[1278,1283],{"type":185,"tag":378,"props":1279,"children":1280},{},[1281],{"type":191,"value":1282},"Code Generation（代码生成）",{"type":191,"value":1284},"\n代码精确、可组合、无限复用，是 Agent 执行复杂操作的理想输出。Claude.AI 的文件创建功能完全依赖代码生成——用 Python 脚本创建 Excel、PPT、Word 文档。",{"type":185,"tag":369,"props":1286,"children":1287},{},[1288,1293],{"type":185,"tag":378,"props":1289,"children":1290},{},[1291],{"type":191,"value":1292},"MCPs（Model Context Protocol）",{"type":191,"value":1294},"\n提供与外部服务的标准化集成，自动处理认证和 API 调用。可快速连接 Slack、GitHub、Google Drive、Asana 等，无需编写自定义集成代码。",{"type":185,"tag":362,"props":1296,"children":1298},{"id":1297},"agent-如何验证工作质量",[1299],{"type":191,"value":1300},"Agent 如何验证工作质量？",{"type":185,"tag":369,"props":1302,"children":1303},{},[1304,1309],{"type":185,"tag":378,"props":1305,"children":1306},{},[1307],{"type":191,"value":1308},"Defining Rules（定义规则）",{"type":191,"value":1310},"\n最佳反馈形式是提供清晰的输出规则，然后解释哪些规则失败及原因。代码 linting 是优秀的规则反馈——生成 TypeScript 比纯 JavaScript 更好，因为提供了额外的反馈层。",{"type":185,"tag":369,"props":1312,"children":1313},{},[1314,1319],{"type":185,"tag":378,"props":1315,"children":1316},{},[1317],{"type":191,"value":1318},"Visual Feedback（视觉反馈）",{"type":191,"value":1320},"\n对于 UI 生成或测试等视觉任务，截图或渲染可以提供有价值的验证。检查布局、样式、内容层次、响应式表现等。使用 Playwright MCP 可以自动化此反馈循环。",{"type":185,"tag":369,"props":1322,"children":1323},{},[1324,1329],{"type":185,"tag":378,"props":1325,"children":1326},{},[1327],{"type":191,"value":1328},"LLM as a Judge",{"type":191,"value":1330},"\n让另一个语言模型基于模糊规则评判输出。这不是非常稳健的方法，且有较高的延迟代价，但在追求性能提升的应用中可能有帮助。",{"type":185,"tag":362,"props":1332,"children":1334},{"id":1333},"测试和改进-agent-的关键问题",[1335],{"type":191,"value":1336},"测试和改进 Agent 的关键问题？",{"type":185,"tag":194,"props":1338,"children":1339},{},[1340,1345,1350,1355],{"type":185,"tag":198,"props":1341,"children":1342},{},[1343],{"type":191,"value":1344},"如果 Agent 误解任务，是否缺少关键信息？能否调整搜索 API 结构？",{"type":185,"tag":198,"props":1346,"children":1347},{},[1348],{"type":191,"value":1349},"如果 Agent 反复失败，能否在工具调用中添加正式规则来识别和修复？",{"type":185,"tag":198,"props":1351,"children":1352},{},[1353],{"type":191,"value":1354},"如果 Agent 无法修复错误，能否提供更有用或更有创意的工具？",{"type":185,"tag":198,"props":1356,"children":1357},{},[1358],{"type":191,"value":1359},"如果性能随功能增加而变化，能否基于客户使用构建代表性的测试集进行程序化评估？",{"type":185,"tag":369,"props":1361,"children":1362},{},[1363,1364,1371],{"type":191,"value":525},{"type":185,"tag":202,"props":1365,"children":1368},{"href":1366,"rel":1367},"https://claude.com/blog/building-agents-with-the-claude-agent-sdk",[224],[1369],{"type":191,"value":1370},"Building agents with the Claude Agent SDK",{"type":191,"value":1372},"（Claude 官方博客）",{"type":185,"tag":186,"props":1374,"children":1376},{"id":1375},"参考",[1377],{"type":191,"value":1375},{"type":185,"tag":194,"props":1379,"children":1380},{},[1381,1390],{"type":185,"tag":198,"props":1382,"children":1383},{},[1384],{"type":185,"tag":202,"props":1385,"children":1387},{"href":528,"rel":1386},[224],[1388],{"type":191,"value":1389},"Building effective agents @Anthropic",{"type":185,"tag":198,"props":1391,"children":1392},{},[1393],{"type":185,"tag":202,"props":1394,"children":1397},{"href":1395,"rel":1396},"https://www.anthropic.com/engineering/multi-agent-research-system",[224],[1398],{"type":191,"value":1399},"How we built our multi-agent research system",{"title":178,"searchDepth":1401,"depth":1401,"links":1402},2,[1403,1404,1405,1406,1407,1408,1409,1410],{"id":188,"depth":1401,"text":192},{"id":210,"depth":1401,"text":213},{"id":230,"depth":1401,"text":233},{"id":257,"depth":1401,"text":260},{"id":275,"depth":1401,"text":275},{"id":330,"depth":1401,"text":333},{"id":357,"depth":1401,"text":360},{"id":1375,"depth":1401,"text":1375},"markdown","content:6.maps:_ai:agents:agents.md","content","6.maps/_ai/agents/agents.md","6.maps/_ai/agents/agents","md",[1418,1420],{"_path":286,"title":289,"description":1419},"AI Agent 框架、平台、协议和基础设施的全面调研",{"_path":297,"title":1421,"description":1422},"AgentScope","阿里巴巴开源的生产级多智能体框架，支持 ReAct Agent、强化学习训练、实时语音交互和 MCP/A2A 协议",1772185486051]