5,"children":276},{},[277,282],{"type":186,"tag":240,"props":278,"children":279},{},[280],{"type":192,"value":281},"跨平台",{"type":192,"value":283},"：同一套 JSON 可在 Web、移动端、桌面端渲染",{"type":186,"tag":187,"props":285,"children":287},{"id":286},"与相关协议的关系",[288],{"type":192,"value":289},"与相关协议的关系？",{"type":186,"tag":232,"props":291,"children":292},{},[293,303,313],{"type":186,"tag":236,"props":294,"children":295},{},[296,301],{"type":186,"tag":240,"props":297,"children":298},{},[299],{"type":192,"value":300},"A2A",{"type":192,"value":302},"：Agent 间通信协议（Agent to Agent），A2UI 可通过 A2A 通道传输",{"type":186,"tag":236,"props":304,"children":305},{},[306,311],{"type":186,"tag":240,"props":307,"children":308},{},[309],{"type":192,"value":310},"MCP",{"type":192,"value":312},"：连接 Agent 与外部工具/数据",{"type":186,"tag":236,"props":314,"children":315},{},[316,321],{"type":186,"tag":240,"props":317,"children":318},{},[319],{"type":192,"value":320},"AG-UI",{"type":192,"value":322},"：另一个 Agent UI 协议，与 A2UI 竞争",{"type":186,"tag":195,"props":324,"children":325},{},[326,327,334,335],{"type":192,"value":204},{"type":186,"tag":206,"props":328,"children":331},{"href":329,"rel":330},"https://dev.to/czmilo/a2a-vs-mcp-vs-ag-ui-1a03",[210],[332],{"type":192,"value":333},"A2A vs MCP vs AG-UI",{"type":192,"value":255},{"type":186,"tag":206,"props":336,"children":339},{"href":337,"rel":338},"https://developers.googleblog.com/introducing-a2ui-an-open-project-for-agent-driven-interfaces/",[210],[340],{"type":192,"value":341},"Introducing A2UI",{"type":186,"tag":187,"props":343,"children":345},{"id":344},"设计原则",[346],{"type":192,"value":347},"设计原则？",{"type":186,"tag":349,"props":350,"children":351},"ol",{},[352,362,372],{"type":186,"tag":236,"props":353,"children":354},{},[355,360],{"type":186,"tag":240,"props":356,"children":357},{},[358],{"type":192,"value":359},"LLM 友好",{"type":192,"value":361},"：扁平组件列表，带 ID 引用，便于流式生成和纠错",{"type":186,"tag":236,"props":363,"children":364},{},[365,370],{"type":186,"tag":240,"props