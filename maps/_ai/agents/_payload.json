,340],{"type":181,"tag":182,"props":183,"children":185},"element","h1",{"id":184},"智能体-ai-agents",[186],{"type":187,"value":176},"text",{"type":181,"tag":189,"props":190,"children":192},"h2",{"id":191},"langchain构建-llm-应用的编排框架",[193],{"type":187,"value":194},"LangChain：构建 LLM 应用的编排框架",{"type":181,"tag":196,"props":197,"children":198},"p",{},[199],{"type":187,"value":200},"LangChain 提供构建 LLM 应用的标准组件：Chains（将多个 LLM 调用串联成工作流）、Agents（动态决策调用哪些工具）、Memory（对话历史管理）、Callbacks（日志、监控集成）。支持 ReAct（推理+行动交替）、Plan-and-Execute（先制定计划再执行）、Structured Chat（结构化输出解析）等 Agent 类型。是构建复杂 LLM 应用的首选框架。",{"type":181,"tag":196,"props":202,"children":203},{},[204,206,215,217,224,225],{"type":187,"value":205},"见：",{"type":181,"tag":207,"props":208,"children":212},"a",{"href":209,"rel":210},"https://langchain.com/",[211],"nofollow",[213],{"type":187,"value":214},"LangChain 官网",{"type":187,"value":216}," | ",{"type":181,"tag":207,"props":218,"children":221},{"href":219,"rel":220},"https://blog.langchain.com/react-agent-benchmarking/",[211],[222],{"type":187,"value":223},"ReAct Agent 基准测试",{"type":187,"value":216},{"type":181,"tag":207,"props":226,"children":229},{"href":227,"rel":228},"https://www.youtube.com/watch?v=Gi7nqB37WEY",[211],[230],{"type":187,"value":231},"LangChain Agents 教程",{"type":181,"tag":189,"props":233,"children":235},{"id":234},"llamaindex数据增强的-agent-开发框架",[236],{"type":187,"value":237},"LlamaIndex：数据增强的 Agent 开发框架",{"type":181,"tag":196,"props":239,"children":240},{},[241],{"type":187,"value":242},"LlamaIndex 专注于\"数据增强的 Agent\"——连接 LLM 与私有数据。提供 100+ Data Connectors（PDF、SQL、API 等数据源）、多种 Index Types（向量索引、树索引、图索引）、Query Engines（RAG、多文档问答）。Workflow 机制允许定义复杂的 Agent 协作流程，结合工具调用与检索能力，是 RAG 和知识库应用的首选。",{"type":181,"tag":196,"props":244,"children":245},{},[246,247,254,255,262,263],{"type":187,"value":205},{"type":181,"tag":207,"props":248,"children":251},{"href":249,"rel":250},"https://www.llamaindex.ai/",[211],[252],{"type":187,"value":253},"LlamaIndex 官网",{"type":187,"value":216},{"type":181,"tag":207,"props":256,"children":259},{"href":257,"rel":258},"https://developers.llamaindex.ai/python/framework/understanding/rag/",[211],[260],{"type":187,"value":261},"LlamaIndex RAG 指南",{"type":187,"value":216},{"type":181,"tag":207,"props":264,"children":267},{"href":265,"rel":266},"https://www.llamaindex.ai/blog/automate-workflows-with-document-agents-a-complete-tutorial-to-building-context-aware-AI",[211],[268],{"type":187,"value":269},"Document Agents 工作流",{"type":181,"tag":189,"props":271,"children":273},{"id":272},"crewai多-agent-协作框架",[274],{"type":187,"value":275},"CrewAI：多 Agent 协作框架",{"type":181,"tag":196,"props":277,"children":278},{},[279],{"type":187,"value":280},"CrewAI 将 Agent 定义为具有角色、目标和工具的\"数字员工\"，通过定义任务依赖实现协作。支持 Role-Playing Agents（专业化角色设定）、Autonomous Collaboration（自主协作）、Task Delegation（任务委托）。适合研究报告生成、代码审查流水线、客户服务自动化等需要多角色协作的场景。",{"type":181,"tag":196,"props":282,"children":283},{},[284,285,292,293,300,301],{"type":187,"value":205},{"type":181,"tag":207,"props":286,"children":289},{"href":287,"rel":288},"https://www.crewai.com/",[211],[290],{"type":187,"value":291},"CrewAI 官网",{"type":187,"value":216},{"type":181,"tag":207,"props":294,"children":297},{"href":295,"rel":296},"https://docs.crewai.com/en/introduction",[211],[298],{"type":187,"value":299},"CrewAI 文档",{"type":187,"value":216},{"type":181,"tag":207,"props":302,"children":305},{"href":303,"rel":304},"https://www.digitalocean.com/community/tutorials/crewai-crash-course-role-based-agent-orchestration",[211],[306],{"type":187,"value":307},"CrewAI 实战指南",{"type":181,"tag":189,"props":309,"children":311},{"id":310},"autogpt自主-agent-先驱",[312],{"type":187,"value":313},"AutoGPT：自主 Agent 先驱",{"type":181,"tag":196,"props":315,"children":316},{},[317],{"type":187,"value":318},"AutoGPT 是首个引发广泛关注的自主 Agent 项目，展示了 LLM 独立完成任务的可能性：目标分解将大目标拆分为可执行步骤、自主循环（观察-思考-行动-记忆）、工具使用（文件操作、网络搜索、代码执行）。但也面临循环陷阱、成本失控、可靠性等现实挑战，更多用于探索性任务。",{"type":181,"tag":196,"props":320,"children":321},{},[322,323],{"type":187,"value":205},{"type":181,"tag":207,"props":324,"children":327},{"href":325,"rel":326},"https://github.com/Significant-Gravitas/AutoGPT",[211],[328],{"type":187,"value":329},"AutoGPT GitHub",{"type":181,"tag":189,"props":331,"children":333},{"id":332},"框架选择指南",[334],{"type":187,"value":332},{"type":181,"tag":196,"props":336,"children":337},{},[338],{"type":187,"value":339},"LangChain 适合复杂 LLM 应用，学习曲线中等；LlamaIndex 适合 RAG 和知识库，学习曲线平缓；CrewAI 适合多角色协作场景，学习曲线平缓；AutoGPT 适合探索性任务，学习曲线陡峭。实际项目中常组合使用，如 LlamaIndex 负责数据检索，LangChain 负责工具编排，CrewAI 负责多 Agent 协作。",{"type":181,"tag":196,"props":341,"children":342},{},[343,344,351,352],{"type":187,"value":205},{"type":181,"tag":207,"props":345,"children":348},{"href":346,"rel":347},"https://damodev.csdn.net/69671cabea53844658f6afed.html",[211],[349],{"type":187,"value":350},"2025 主流 AI Agent 框架调研",{"type":187,"value":216},{"type":181,"tag":207,"props":353,"children":356},{"href":354,"rel":355},"https://draftnrun.com/en/blog/250915-ai-agent-frameworks-comparison/",[211],[357],{"type":187,"value":358},"LangChain vs LlamaIndex vs CrewAI 对比",{"title":175,"searchDepth":360,"depth":360,"links":361},2,[362,363,364,365,366],{"id":191,"depth":360,"text":194},{"id":234,"depth":360,"text":237},{"id":272,"depth":360,"text":275},{"id":310,"depth":360,"text":313},{"id":332,"depth":360,"text":332},"markdown","content:6.maps:_ai:agents.md","content","6.maps/_ai/agents.md","6.maps/_ai/agents","md",[374,376],{"_path":124,"title":123,"description":375},"一千个人有一千种无题",{"_path":377,"title":378,"description":379},"/maps/_ai/agents/agents","Agents","AI 代理（Agents）是能够自主执行任务并与环境交互的智能实体，通常基于大语言模型（LLM）构建。",1771264638069]