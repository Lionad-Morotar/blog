91,198,204,235,241,246,273,279,284,311,317,322,333,339,346,351,357,362,367,372,383,388,393,412,418,424,429,438,473,481,514,522,536,542,629],{"type":184,"tag":185,"props":186,"children":188},"element","h1",{"id":187},"智能体-ai-agents",[189],{"type":190,"value":179},"text",{"type":184,"tag":192,"props":193,"children":195},"h2",{"id":194},"langchain构建-llm-应用的编排框架",[196],{"type":190,"value":197},"LangChain：构建 LLM 应用的编排框架",{"type":184,"tag":199,"props":200,"children":201},"p",{},[202],{"type":190,"value":203},"LangChain 提供构建 LLM 应用的标准组件：Chains（将多个 LLM 调用串联成工作流）、Agents（动态决策调用哪些工具）、Memory（对话历史管理）、Callbacks（日志、监控集成）。支持 ReAct（推理+行动交替）、Plan-and-Execute（先制定计划再执行）、Structured Chat（结构化输出解析）等 Agent 类型。是构建复杂 LLM 应用的首选框架。",{"type":184,"tag":199,"props":205,"children":206},{},[207,209,218,220,227,228],{"type":190,"value":208},"见：",{"type":184,"tag":210,"props":211,"children":215},"a",{"href":212,"rel":213},"https://langchain.com/",[214],"nofollow",[216],{"type":190,"value":217},"LangChain 官网",{"type":190,"value":219}," | ",{"type":184,"tag":210,"props":221,"children":224},{"href":222,"rel":223},"https://blog.langchain.com/react-agent-benchmarking/",[214],[225],{"type":190,"value":226},"ReAct Agent 基准测试",{"type":190,"value":219},{"type":184,"tag":210,"props":229,"children":232},{"href":230,"rel":231},"https://www.youtube.com/watch?v=Gi7nqB37WEY",[214],[233],{"type":190,"value":234},"LangChain Agents 教程",{"type":184,"tag":192,"props":236,"children":238},{"id":237},"llamaindex数据增强的-agent-开发框架",[239],{"type":190,"value":240},"LlamaIndex：数据增强的 Agent 开发框架",{"type":184,"tag":199,"props":242,"children":243},{},[244],{"type":190,"value":245},"LlamaIndex 专注于\"数据增强的 Agent\"——连接 LLM 与私有数据。提供 100+ Data Connectors（PDF、SQL、API 等数据源）、多种 Index Types（向量索引、树索引、图索引）、Query Engines（RAG、多文档问答）。Workflow 机制允许定义复杂的 Agent 协作流程，结合工具调用与检索能力，是 RAG 和知识库应用的首选。",{"type":184,"tag":199,"props":247,"children":248},{},[249,250,257,258,265,266],{"type":190,"value":208},{"type":184,"tag":210,"props":251,"children":254},{"href":252,"rel":253},"https://www.llamaindex.ai/",[214],[255],{"type":190,"value":256},"LlamaIndex 官网",{"type":190,"value":219},{"type":184,"tag":210,"props":259,"children":262},{"href":260,"rel":261},"https://developers.llamaindex.ai/python/framework/understanding/rag/",[214],[263],{"type":190,"value":264},"LlamaIndex RAG 指南",{"type":190,"value":219},{"type":184,"tag":210,"props":267,"children":270},{"href":268,"rel":269},"https://www.llamaindex.ai/blog/automate-workflows-with-document-agents-a-complete-tutorial-to-building-context-aware-AI",[214],[271],{"type":190,"value":272},"Document Agents 工作流",{"type":184,"tag":192,"props":274,"children":276},{"id":275},"crewai多-agent-协作框架",[277],{"type":190,"value":278},"CrewAI：多 Agent 协作框架",{"type":184,"tag":199,"props":280,"children":281},{},[282],{"type":190,"value":283},"CrewAI 将 Agent 定义为具有角色、目标和工具的\"数字员工\"，通过定义任务依赖实现协作。支持 Role-Playing Agents（专业化角色设定）、Autonomous Collaboration（自主协作）、Task Delegation（任务委托）。适合研究报告生成、代码审查流水线、客户服务自动化等需要多角色协作的场景。",{"type":184,"tag":199,"props":285,"children":286},{},[287,288,295,296,303,304],{"type":190,"value":208},{"type":184,"tag":210,"props":289,"children":292},{"href":290,"rel":291},"https://www.crewai.com/",[214],[293],{"type":190,"value":294},"CrewAI 官网",{"type":190,"value":219},{"type":184,"tag":210,"props":297,"children":300},{"href":298,"rel":299},"https://docs.crewai.com/en/introduction",[214],[301],{"type":190,"value":302},"CrewAI 文档",{"type":190,"value":219},{"type":184,"tag":210,"props":305,"children":308},{"href":306,"rel":307},"https://www.digitalocean.com/community/tutorials/crewai-crash-course-role-based-agent-orchestration",[214],[309],{"type":190,"value":310},"CrewAI 实战指南",{"type":184,"tag":192,"props":312,"children":314},{"id":313},"autogpt自主-agent-先驱",[315],{"type":190,"value":316},"AutoGPT：自主 Agent 先驱",{"type":184,"tag":199,"props":318,"children":319},{},[320],{"type":190,"value":321},"AutoGPT 是首个引发广泛关注的自主 Agent 项目，展示了 LLM 独立完成任务的可能性：目标分解将大目标拆分为可执行步骤、自主循环（观察-思考-行动-记忆）、工具使用（文件操作、网络搜索、代码执行）。但也面临循环陷阱、成本失控、可靠性等现实挑战，更多用于探索性任务。",{"type":184,"tag":199,"props":323,"children":324},{},[325,326],{"type":190,"value":208},{"type":184,"tag":210,"props":327,"children":330},{"href":328,"rel":329},"https://github.com/Significant-Gravitas/AutoGPT",[214],[331],{"type":190,"value":332},"AutoGPT GitHub",{"type":184,"tag":192,"props":334,"children":336},{"id":335},"agent-的记忆问题",[337],{"type":190,"value":338},"Agent 的记忆问题",{"type":184,"tag":340,"props":341,"children":343},"h4",{"id":342},"ai-记忆层次的缺陷",[344],{"type":190,"value":345},"AI 记忆层次的缺陷",{"type":184,"tag":199,"props":347,"children":348},{},[349],{"type":190,"value":350},"人类记忆层次包括感觉记忆、短期记忆和长期记忆，可随时将短期记忆巩固为长期记忆。但 AI 系统仅有两种记忆：上下文作为短期记忆（任务结束即清除）、模型权重作为长期记忆（需昂贵训练才能更新）。这种缺失限制了 Agent 的持续学习和个性化能力。",{"type":184,"tag":340,"props":352,"children":354},{"id":353},"为什么记忆对-agent-至关重要",[355],{"type":190,"value":356},"为什么记忆对 Agent 至关重要",{"type":184,"tag":199,"props":358,"children":359},{},[360],{"type":190,"value":361},"想象一下：如果软件工程师每天醒来后对公司代码库一无所知，又要重新开始入职培训；如果每次与朋友聊天都忘记之前的对话内容。这正是当前 AI Agent 的处境——缺乏将短期经验转化为长期记忆的灵活机制。ChatGPT 的\"记忆功能\"尝试通过提取用户偏好摘要来解决这一问题，但仍显初级。",{"type":184,"tag":340,"props":363,"children":365},{"id":364},"持续学习评估的缺失",[366],{"type":190,"value":364},{"type":184,"tag":199,"props":368,"children":369},{},[370],{"type":190,"value":371},"学术界面临的核心挑战不是缺少方法，而是缺少合适的评估基准。当研究者尝试让 Agent 从过往任务中学习时，审稿人往往质疑\"这对其他方法不公平\"。这种评估困境阻碍了持续学习 Agent 的发展。真正的突破需要重新设计评估设定，从评估\"现有能力\"转向评估\"学习能力\"。",{"type":184,"tag":199,"props":373,"children":374},{},[375,376],{"type":190,"value":208},{"type":184,"tag":210,"props":377,"children":380},{"href":378,"rel":379},"https://ysymyth.github.io/The-Second-Half/",[214],[381],{"type":190,"value":382},"The Second Half - 长期记忆",{"type":184,"tag":192,"props":384,"children":386},{"id":385},"框架选择指南",[387],{"type":190,"value":385},{"type":184,"tag":199,"props":389,"children":390},{},[391],{"type":190,"value":392},"LangChain 适合复杂 LLM 应用，学习曲线中等；LlamaIndex 适合 RAG 和知识库，学习曲线平缓；CrewAI 适合多角色协作场景，学习曲线平缓；AutoGPT 适合探索性任务，学习曲线陡峭。实际项目中常组合使用，如 LlamaIndex 负责数据检索，LangChain 负责工具编排，CrewAI 负责多 Agent 协作。",{"type":184,"tag":199,"props":394,"children":395},{},[396,397,404,405],{"type":190,"value":208},{"type":184,"tag":210,"props":398,"children":401},{"href":399,"rel":400},"https://damodev.csdn.net/69671cabea53844658f6afed.html",[214],[402],{"type":190,"value":403},"2025 主流 AI Agent 框架调研",{"type":190,"value":219},{"type":184,"tag":210,"props":406,"children":409},{"href":407,"rel":408},"https://draftnrun.com/en/blog/250915-ai-agent-frameworks-comparison/",[214],[410],{"type":190,"value":411},"LangChain vs LlamaIndex vs CrewAI 对比",{"type":184,"tag":192,"props":413,"children":415},{"id":414},"多-agent-架构模式",[416],{"type":190,"value":417},"多 Agent 架构模式",{"type":184,"tag":340,"props":419,"children":421},{"id":420},"通用智能体-业务领域-agent",[422],{"type":190,"value":423},"通用智能体 + 业务领域 Agent",{"type":184,"tag":199,"props":425,"children":426},{},[427],{"type":190,"value":428},"一种适用于企业级多业务系统的分层架构模式：",{"type":184,"tag":199,"props":430,"children":431},{},[432],{"type":184,"tag":433,"props":434,"children":435},"strong",{},[436],{"type":190,"value":437},"角色划分：",{"type":184,"tag":439,"props":440,"children":441},"ul",{},[442,453,463],{"type":184,"tag":443,"props":444,"children":445},"li",{},[446,451],{"type":184,"tag":433,"props":447,"children":448},{},[449],{"type":190,"value":450},"通用主 Agent",{"type":190,"value":452},"：负责意图识别、对话管理、任务分发",{"type":184,"tag":443,"props":454,"children":455},{},[456,461],{"type":184,"tag":433,"props":457,"children":458},{},[459],{"type":190,"value":460},"业务领域 Agent",{"type":190,"value":462},"：专注特定业务领域（如订单、库存、客服）",{"type":184,"tag":443,"props":464,"children":465},{},[466,471],{"type":184,"tag":433,"props":467,"children":468},{},[469],{"type":190,"value":470},"后端服务",{"type":190,"value":472},"：通过 OpenAPI 提供业务逻辑，经 FunctionAI Toolset 接入",{"type":184,"tag":199,"props":474,"children":475},{},[476],{"type":184,"tag":433,"props":477,"children":478},{},[479],{"type":190,"value":480},"优势：",{"type":184,"tag":439,"props":482,"children":483},{},[484,494,504],{"type":184,"tag":443,"props":485,"children":486},{},[487,492],{"type":184,"tag":433,"props":488,"children":489},{},[490],{"type":190,"value":491},"业务解耦",{"type":190,"value":493},"：各业务线独立开发部署自己的 Agent",{"type":184,"tag":443,"props":495,"children":496},{},[497,502],{"type":184,"tag":433,"props":498,"children":499},{},[500],{"type":190,"value":501},"协议标准化",{"type":190,"value":503},"：通过 A2A 等协议实现跨系统协作",{"type":184,"tag":443,"props":505,"children":506},{},[507,512],{"type":184,"tag":433,"props":508,"children":509},{},[510],{"type":190,"value":511},"低摩擦集成",{"type":190,"value":513},"：现有 REST API 可快速转化为 Agent 工具",{"type":184,"tag":199,"props":515,"children":516},{},[517],{"type":184,"tag":433,"props":518,"children":519},{},[520],{"type":190,"value":521},"典型案例：",{"type":184,"tag":439,"props":523,"children":524},{},[525],{"type":184,"tag":443,"props":526,"children":527},{},[528,534],{"type":184,"tag":210,"props":529,"children":531},{"href":530},"/maps/_ai/agents/a2a",[532],{"type":190,"value":533},"希希咖啡店",{"type":190,"value":535}," - 基于 Google ADK + A2A 协议的咖啡点单与配送协同",{"type":184,"tag":340,"props":537,"children":539},{"id":538},"agent-协议选择",[540],{"type":190,"value":541},"Agent 协议选择",{"type":184,"tag":543,"props":544,"children":545},"table",{},[546,570],{"type":184,"tag":547,"props":548,"children":549},"thead",{},[550],{"type":184,"tag":551,"props":552,"children":553},"tr",{},[554,560,565],{"type":184,"tag":555,"props":556,"children":557},"th",{},[558],{"type":190,"value":559},"协议",{"type":184,"tag":555,"props":561,"children":562},{},[563],{"type":190,"value":564},"适用场景",{"type":184,"tag":555,"props":566,"children":567},{},[568],{"type":190,"value":569},"代表案例",{"type":184,"tag":571,"props":572,"children":573},"tbody",{},[574,593,611],{"type":184,"tag":551,"props":575,"children":576},{},[577,583,588],{"type":184,"tag":578,"props":579,"children":580},"td",{},[581],{"type":190,"value":582},"A2A",{"type":184,"t