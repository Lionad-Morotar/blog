91,198,204,235,241,246,273,279,284,311,317,322,333,338,343],{"type":184,"tag":185,"props":186,"children":188},"element","h1",{"id":187},"智能体-ai-agents",[189],{"type":190,"value":179},"text",{"type":184,"tag":192,"props":193,"children":195},"h2",{"id":194},"langchain构建-llm-应用的编排框架",[196],{"type":190,"value":197},"LangChain：构建 LLM 应用的编排框架",{"type":184,"tag":199,"props":200,"children":201},"p",{},[202],{"type":190,"value":203},"LangChain 提供构建 LLM 应用的标准组件：Chains（将多个 LLM 调用串联成工作流）、Agents（动态决策调用哪些工具）、Memory（对话历史管理）、Callbacks（日志、监控集成）。支持 ReAct（推理+行动交替）、Plan-and-Execute（先制定计划再执行）、Structured Chat（结构化输出解析）等 Agent 类型。是构建复杂 LLM 应用的首选框架。",{"type":184,"tag":199,"props":205,"children":206},{},[207,209,218,220,227,228],{"type":190,"value":208},"见：",{"type":184,"tag":210,"props":211,"children":215},"a",{"href":212,"rel":213},"https://langchain.com/",[214],"nofollow",[216],{"type":190,"value":217},"LangChain 官网",{"type":190,"value":219}," | ",{"type":184,"tag":210,"props":221,"children":224},{"href":222,"rel":223},"https://blog.langchain.com/react-agent-benchmarking/",[214],[225],{"type":190,"value":226},"ReAct Agent 基准测试",{"type":190,"value":219},{"type":184,"tag":210,"props":229,"children":232},{"href":230,"rel":231},"https://www.youtube.com/watch?v=Gi7nqB37WEY",[214],[233],{"type":190,"value":234},"LangChain Agents 教程",{"type":184,"tag":192,"props":236,"children":238},{"id":237},"llamaindex数据增强的-agent-开发框架",[239],{"type":190,"value":240},"LlamaIndex：数据增强的 Agent 开发框架",{"type":184,"tag":199,"props":242,"children":243},{},[244],{"type":190,"value":245},"LlamaIndex 专注于\"数据增强的 Agent\"——连接 LLM 与私有数据。提供 100+ Data Connectors（PDF、SQL、API 等数据源）、多种 Index Types（向量索引、树索引、图索引）、Query Engines（RAG、多文档问答）。Workflow 机制允许定义复杂的 Agent 协作流程，结合工具调用与检索能力，是 RAG 和知识库应用的首选。",{"type":184,"tag":199,"props":247,"children":248},{},[249,250,257,258,265,266],{"type":190,"value":208},{"type":184,"tag":210,"props":251,"children":254},{"href":252,"rel":253},"https://www.llamaindex.ai/",[214],[255],{"type":190,"value":256},"LlamaIndex 官网",{"type":190,"value":219},{"type":184,"tag":210,"props":259,"children":262},{"href":260,"rel":261},"https://developers.llamaindex.ai/python/framework/understanding/rag/",[214],[263],{"type":190,"value":264},"LlamaIndex RAG 指南",{"type":190,"value":219},{"type":184,"tag":210,"props":267,"children":270},{"href":268,"rel":269},"https://www.llamaindex.ai/blog/automate-workflows-with-document-agents-a-complete-tutorial-to-building-context-aware-AI",[214],[271],{"type":190,"value":272},"Document Agents 工作流",{"type":184,"tag":192,"props":274,"children":276},{"id":275},"crewai多-agent-协作框架",[277],{"type":190,"value":278},"CrewAI：多 Agent 协作框架",{"type":184,"tag":199,"props":280,"children":281},{},[282],{"type":190,"value":283},"CrewAI 将 Agent 定义为具有角色、目标和工具的\"数字员工\"，通过定义任务依赖实现协作。支持 Role-Playing Agents（专业化角色设定）、Autonomous Collaboration（自主协作）、Task Delegation（任务委托）。适合研究报告生成、代码审查流水线、客户服务自动化等需要多角色协作的场景。",{"type":184,"tag":199,"props":285,"children":286},{},[287,288,295,296,303,304],{"type":190,"value":208},{"type":184,"tag":210,"props":289,"children":292},{"href":290,"rel":291},"https://www.crewai.com/",[214],[293],{"type":190,"value":294},"CrewAI 官网",{"type":190,"value":219},{"type":184,"tag":210,"props":297,"children":300},{"href":298,"rel":299},"https://docs.crewai.com/en/introduction",[214],[301],{"type":190,"value":302},"CrewAI 文档",{"type":190,"value":219},{"type":184,"tag":210,"props":305,"children":308},{"href":306,"rel":307},"https://www.digitalocean.com/community/tutorials/crewai-crash-course-role-based-agent-orchestration",[214],[309],{"type":190,"value":310},"CrewAI 实战指南",{"type":184,"tag":192,"props":312,"children":314},{"id":313},"autogpt自主-agent-先驱",[315],{"type":190,"value":316},"AutoGPT：自主 Agent 先驱",{"type":184,"tag":199,"props":318,"children":319},{},[320],{"type":190,"value":321},"AutoGPT 是首个引发广泛关注的自主 Agent 项目，展示了 LLM 独立完成任务的可能性：目标分解将大目标拆分为可执行步骤、自主循环（观察-思考-行动-记忆）、工具使用（文件操作、网络搜索、代码执行）。但也面临循环陷阱、成本失控、可靠性等现实挑战，更多用于探索性任务。",{"type":184,"tag":199,"props":323,"children":324},{},[325,326],{"type":190,"value":208},{"type":184,"tag":210,"props":327,"children":330},{"href":328,"rel":329},"https://github.com/Significant-Gravitas/AutoGPT",[214],[331],{"type":190,"value":332},"AutoGPT GitHub",{"type":184,"tag":192,"props":334,"children":336},{"id":335},"框架选择指南",[337],{"type":190,"value":335},{"type":184,"tag":199,"props":339,"children":340},{},[341],{"type":190,"value":342},"LangChain 适合复杂 LLM 应用，学习曲线中等；LlamaIndex 适合 RAG 和知识库，学习曲线平缓；CrewAI 适合多角色协作场景，学习曲线平缓；AutoGPT 适合探索性任务，学习曲线陡峭。实际项目中常组合使用，如 LlamaIndex 负责数据检索，LangChain 负责工具编排，CrewAI 负责多 Agent 协作。",{"type":184,"tag":199,"props":344,"children":345},{},[346,347,354,355],{"type":190,"value":208},{"type":184,"tag":210,"props":348,"children":351},{"href":349,"rel":350},"https://damodev.csdn.net/69671cabea53844658f6afed.html",[214],[352],{"type":190,"value":353},"2025 主流 AI Agent 框架调研",{"type":190,"value":219},{"type":184,"tag":210,"props":356,"children":359},{"href":357,"rel":358},"https://draftnrun.com/en/blog/250915-ai-agent-frameworks-comparison/",[214],[360],{"type":190,"value":361},"LangChain vs LlamaIndex vs CrewAI 对比",{"title":178,"searchDepth":363,"depth":363,"links":364},2,[365,366,367,368,369],{"id":194,"depth":363,"text":197},{"id":237,"depth":363,"text":240},{"id":275,"depth":363,"text":278},{"id":313,"depth":363,"text":316},{"id":335,"depth":363,"text":335},"markdown","content:6.maps:_ai:agents.md","content","6.maps/_ai/agents.md","6.maps/_ai/agents","md",[377,379],{"_path":124,"title":123,"description":378},"一千个人有一千种无题",{"_path":380,"title":381,"description":382},"/maps/_ai/agents/a2ui","A2UI","Google 推出的声明式 UI 协议，让 AI Agent 能生成富交互界面",1771304523999]