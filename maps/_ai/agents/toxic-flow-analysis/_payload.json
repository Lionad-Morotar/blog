2,"value":1081},"落地建议：什么时候考虑、如何起步",{"type":186,"tag":219,"props":1083,"children":1085},{"id":1084},"适用场景与边界",[1086],{"type":192,"value":1084},{"type":186,"tag":195,"props":1088,"children":1089},{},[1090],{"type":192,"value":1091},"更适合引入 toxic flow analysis 的情况通常包括：",{"type":186,"tag":230,"props":1093,"children":1094},{},[1095,1113,1131],{"type":186,"tag":234,"props":1096,"children":1097},{},[1098,1100],{"type":192,"value":1099},"已经存在：\n",{"type":186,"tag":230,"props":1101,"children":1102},{},[1103,1108],{"type":186,"tag":234,"props":1104,"children":1105},{},[1106],{"type":192,"value":1107},"多个 LLM 代理相互调用；",{"type":186,"tag":234,"props":1109,"children":1110},{},[1111],{"type":192,"value":1112},"明确的 MCP server 或统一工具层；",{"type":186,"tag":234,"props":1114,"children":1115},{},[1116,1118],{"type":192,"value":1117},"同时具备：\n",{"type":186,"tag":230,"props":1119,"children":1120},{},[1121,1126],{"type":186,"tag":234,"props":1122,"children":1123},{},[1124],{"type":192,"value":1125},"对内部私有数据（用户、日志、业务数据）的访问能力；",{"type":186,"tag":234,"props":1127,"children":1128},{},[1129],{"type":192,"value":1130},"对外部世界（第三方 API、Webhook、邮件等）的输出能力；",{"type":186,"tag":234,"props":1132,"children":1133},{},[1134,1136],{"type":192,"value":1135},"并且：\n",{"type":186,"tag":230,"props":1137,"children":1138},{},[1139],{"type":186,"tag":234,"props":1140,"children":1141},{},[1142],{"type":192,"value":1143},"安全/合规要求较高（金融、企业内部系统、B2B 场景等）。",{"type":186,"tag":195,"props":1145,"children":1146},{},[1147],{"type":192,"value":1148},"相对不那么迫切的情况：",{"type":186,"tag":230,"props":1150,"children":1151},{},[1152,1157],{"type":186,"tag":234,"props":1153,"children":1154},{},[1155],{"type":192,"value":1156},"单一 LLM 应用，工具极少且无对外调用；",{"type":186,"tag":234,"props":1158,"children":1159},{},[1160],{"type":192,"value":1161},"所有输入都高度可信（例如仅内部专家使用，且无外部内容聚合）。",{"type":186,"tag":219,"props":1163,"children":1165},{"id":1164},"起步路径小步试点的一个合理形态",[1166],{"type":192,"value":1167},"起步路径（小步试点的一个合理形态）",{"type":186,"tag":195,"props":1169,"children":1170},{},[1171],{"type":192,"value":1172},"可以考虑按以下节奏推进：",{"type":186,"tag":281,"props":1174,"children":1175},{},[1176,1197,1231,1252],{"type":186,"tag":234,"props":1177,"children":1178},{},[1179,1184],{"type":186,"tag":413,"props":1180,"children":1181},{},[1182],{"type":192,"value":1183},"手工建模一个 MVP 调用图",{"type":186,"tag":230,"props":1185,"children":1186},{},[1187,1192],{"type":186,"tag":234,"props":1188,"children":1189},{},[1190],{"type":192,"value":1191},"先覆盖关键代理、敏感数据源和对外通道即可；",{"type":186,"tag":234,"props":1193,"children":1194},{},[1195],{"type":192,"value":1196},"用简单的图工具（甚至文本/表格）标出节点和调用边。",{"type":186,"tag":234,"props":1198,"children":1199},{},[1200,1205],{"type":186,"tag":413,"props":1201,"children":1202},{},[1203],{"type":192,"value":1204},"标注敏感源 / 不可信输入 / 外部 sink",{"type":186,"tag":230,"props":1206,"children":1207},{},[1208],{"type":186,"tag":234,"props":1209,"children":1210},{},[1211,1213],{"type":192,"value":1212},"粗粒度即可：\n",{"type":186,"tag":230,"props":1214,"children":1215},{},[1216,1221,1226],{"type":186,"tag":234,"props":1217,"children":1218},{},[1219],{"type":192,"value":1220},"「访问客户数据 = YES」",{"type":186,"tag":234,"props":1222,"children":1223},{},[1224],{"type":192,"value":1225},"「接收不可信输入 = YES」",{"type":186,"tag":234,"props":1227,"children":1228},{},[1229],{"type":192,"value":1230},"「可对外 HTTP 调用 = YES」。",{"type":186,"tag":234,"props":1232,"children":1233},{},[1234,1239],{"type":186,"tag":413,"props":1235,"children":1236},{},[1237],{"type":192,"value":1238},"先用人工方式找「明显有毒路径」",{"type":186,"tag":230,"props":1240,"children":1241},{},[1242,1247],{"type":186,"tag":234,"props":1243,"children":1244},{},[1245],{"type":192,"value":1246},"从敏感源开始，沿图手工追溯到外部 sink，看是否会经过易被注入的 LLM 节点；",{"type":186,"tag":234,"props":1248,"children":1249},{},[1250],{"type":192,"value":1251},"把这些路径拉出来做一次集中的安全评估和重构。",{"type":186,"tag":234,"props":1253,"children":1254},{},[1255,1260],{"type":186,"tag":413,"props":1256,"children":1257},{},[1258],{"type":192,"value":1259},"再考虑工具化和自动化",{"type":186,"tag":230,"props":1261,"children":1262},{},[1263],{"type":186,"tag":234,"props":1264,"children":1265},{},[1266,1268],{"type":192,"value":1267},"随着系统演进，可以：\n",{"type":186,"tag":230,"props":1269,"children":1270},{},[1271,1276,1281],{"type":186,"tag":234,"props":1272,"children":1273},{},[1274],{"type":192,"value":1275},"把代理和工具的元数据结构化（YAML/JSON）；",{"type":186,"tag":234,"props":1277,"children":1278},{},[1279],{"type":192,"value":1280},"在 CI 中加入「调用图生成 + 简单规则检查」；",{"type":186,"tag":234,"props":1282,"children":1283},{},[1284],{"type":192,"value":1285},"长远可以接入更复杂的图分析 / taint analysis 工具。",{"type":186,"tag":219,"props":1287,"children":1289},{"id":1288},"实施风险与注意点",[1290],{"type":192,"value":1288},{"type":186,"tag":195,"props":1292,"children":1293},{},[1294],{"type":192,"value":1295},"落地时需要注意：",{"type":186,"tag":230,"props":1297,"children":1298},{},[1299,1312,1325],{"type":186,"tag":234,"props":1300,"children":1301},{},[1302,1304],{"type":192,"value":1303},"准确性与完备性之间的平衡：\n",{"type":186,"tag":230,"props":1305,"children":1306},{},[1307],{"type":186,"tag":234,"props":1308,"children":1309},{},[1310],{"type":192,"value":1311},"初期不必追求「覆盖所有边缘路径」，优先把高风险路径纳入图中；",{"type":186,"tag":234,"props":1313,"children":1314},{},[1315,1317],{"type":192,"value":1316},"版本漂移问题：\n",{"type":186,"tag":230,"props":1318,"children":1319},{},[1320],{"type":186,"tag":234,"props":1321,"children":1322},{},[1323],{"type":192,"value":1324},"代理配置、工具列表变更频繁时，如果没有和配置管理/CI 打通，数据流图会快速过时；",{"type":186,"tag":234,"props":1326,"children":1327},{},[1328,1330],{"type":192,"value":1329},"过度依赖结构分析：\n",{"type":186,"tag":230,"props":1331,"children":1332},{},[1333,1338],{"type":186,"tag":234,"props":1334,"children":1335},{},[1336],{"type":192,"value":1337},"toxic flow analysis 识别的是「潜在危险结构」，不能替代运行时监控和异常检测；",{"type":186,"tag":234,"props":1339,"children":1340},{},[1341],{"type":192,"value":1342},"尤其是 LLM 行为的随机性，仍需要日志、审计和行为监控兜底。",{"type":186,"tag":195,"props":1344,"children":1345},{},[1346,1348,1353,1355,1359],{"type":192,"value":1347},"整体而言，原文强调的是：在多代理、MCP 等新型 LLM 系统中，",{"type":186,"tag":413,"props":1349,"children":1350},{},[1351],{"type":192,"value":1352},"有毒数据流是结构性风险，不能只靠单点防御",{"type":192,"value":1354},"。",{"type":186,"tag":1356,"props":1357,"children":1358},"br",{},[],{"type":192,"value":1360},"\ntoxic flow analysis 通过「数据流图 + 安全属性标注 + 路径分析」提供了一种系统化识别这类风险的早期方法，虽然仍在探索阶段，但已经值得架构和安全团队在设计和演进时主动纳入思考框架。",{"title":178,"searchDepth":1362,"depth":1362,"links":1363},2,[1364,1365],{"id":189,"depth":1362,"text":193},{"id":207,"depth":1362,"text":210,"children":1366},[1367,1369,1370,1371,1372,1373],{"id":214,"depth":1368,"text":217},3,{"id":378,"depth":1368,"text":381},{"id":539,"depth":1368,"text":542},{"id":784,"depth":1368,"text":787},{"id":927,"depth":1368,"text":930},{"id":1078,"depth":1368,"text":1081},"markdown","content:6.maps:_ai:agents:toxic-flow-analysis.md","content","6.maps/_ai/agents/toxic-flow-analysis.md","6.maps/_ai/agents/toxic-flow-analysis","md",[1381,1385],{"_path":1382,"title":1383,"description":1384},"/maps/_ai/agents/openai-agents-js-releases","OpenAI Agents SDK (JavaScript) 发布记录","OpenAI Agents SDK JavaScript/TypeScript 版本的完整发布历史与变更日志",{"_path":1386,"title":1387,"description":1388},"/maps/_ai/ai","Artificial Intelligence","Machine learning, large language models, AI agents, and AI engineering",1772504939351]