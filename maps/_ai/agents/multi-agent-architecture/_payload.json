cles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"body":181,"_type":975,"_id":976,"_source":977,"_file":978,"_stem":979,"_extension":980},"/maps/_ai/agents/multi-agent-architecture","agents",false,true,"","多智能体架构决策与工程实践","单/多智能体架构选择、Anthropic 工程实践、Cognition 上下文工程原则、Claude 官方决策指南",{"type":182,"children":183,"toc":966},"root",[184,193,199,205,212,217,222,227,263,268,273,283,297,307,320,325,335,353,358,364,369,374,388,394,399,404,410,415,438,443,448,531,536,569,574,627,633,639,644,655,660,665,688,693,699,711,716,728,734,739,745,750,755,793,804,810,822,840,857,862,874,884,890,895,900,905,910,928,933],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"为什么需要多智能体系统",[190],{"type":191,"value":192},"text","为什么需要多智能体系统？",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"随着大语言模型能力增强，单智能体的局限性逐渐暴露。现实问题往往需要多种专业能力协作、分工互补和思维碰撞，多智能体系统在这些场景下优势明显。",{"type":185,"tag":186,"props":200,"children":202},{"id":201},"单智能体-vs-多智能体架构选择",[203],{"type":191,"value":204},"单智能体 vs 多智能体架构选择",{"type":185,"tag":206,"props":207,"children":209},"h4",{"id":208},"决策原点单智能体优先",[210],{"type":191,"value":211},"决策原点：单智能体优先",{"type":185,"tag":194,"props":213,"children":214},{},[215],{"type":191,"value":216},"选择架构时，默认从单智能体开始。这是 Anthropic 强调的\"简单优先\"原则——只有当引入复杂性能够显著改善结果时，才应该考虑它。",{"type":185,"tag":206,"props":218,"children":220},{"id":219},"单智能体的三类硬性瓶颈",[221],{"type":191,"value":219},{"type":185,"tag":194,"props":223,"children":224},{},[225],{"type":191,"value":226},"当单智能体遇到以下瓶颈时，才考虑升级为多智能体：",{"type":185,"tag":228,"props":229,"children":230},"ol",{},[231,243,253],{"type":185,"tag":232,"props":233,"children":234},"li",{},[235,241],{"type":185,"tag":236,"props":237,"children":238},"strong",{},[239],{"type":191,"value":240},"上下文容量瓶颈",{"type":191,"value":242}," —— 单智能体的上下文窗口有限，处理海量信息（如同时分析几十个网页）时会被撑爆",{"type":185,"tag":232,"props":244,"children":245},{},[246,251],{"type":185,"tag":236,"props":247,"children":248},{},[249],{"type":191,"value":250},"单一路径依赖的高失败风险",{"type":191,"value":252}," —— 单智能体像侦探只能沿一条线索追查，一旦路径错误整个任务失败；多智能体可并行探索多条路径降低风险",{"type":185,"tag":232,"props":254,"children":255},{},[256,261],{"type":185,"tag":236,"props":257,"children":258},{},[259],{"type":191,"value":260},"效率瓶颈",{"type":191,"value":262}," —— 串行处理耗时过长，业务要求短时间完成时需要并行提速",{"type":185,"tag":206,"props":264,"children":266},{"id":265},"多智能体方案的双重过滤器",[267],{"type":191,"value":265},{"type":185,"tag":194,"props":269,"children":270},{},[271],{"type":191,"value":272},"即使发现瓶颈，启动评估不等于直接采用，还需通过两个过滤器：",{"type":185,"tag":194,"props":274,"children":275},{},[276,281],{"type":185,"tag":236,"props":277,"children":278},{},[279],{"type":191,"value":280},"技术可行性过滤器",{"type":191,"value":282}," —— 任务能否拆分为独立可并行的子任务？",{"type":185,"tag":284,"props":285,"children":286},"ul",{},[287,292],{"type":185,"tag":232,"props":288,"children":289},{},[290],{"type":191,"value":291},"适合：市场分析报告（可拆分为竞争对手研究、宏观趋势分析、用户反馈抓取）",{"type":185,"tag":232,"props":293,"children":294},{},[295],{"type":191,"value":296},"不适合：代码编写（需要强共享上下文，模块间依赖高，易产生冲突）",{"type":185,"tag":194,"props":298,"children":299},{},[300,305],{"type":185,"tag":236,"props":301,"children":302},{},[303],{"type":191,"value":304},"商业价值过滤器",{"type":191,"value":306}," —— 任务价值能否支撑高昂花费？",{"type":185,"tag":284,"props":308,"children":309},{},[310,315],{"type":185,"tag":232,"props":311,"children":312},{},[313],{"type":191,"value":314},"Anthropic 经验：多智能体架构 Token 消耗可能是普通聊天的 15 倍",{"type":185,"tag":232,"props":316,"children":317},{},[318],{"type":191,"value":319},"必须评估任务创造的价值是否值得如此高的成本",{"type":185,"tag":206,"props":321,"children":323},{"id":322},"决策框架",[324],{"type":191,"value":322},{"type":185,"tag":194,"props":326,"children":327},{},[328,333],{"type":185,"tag":236,"props":329,"children":330},{},[331],{"type":191,"value":332},"单智能体优先",{"type":191,"value":334},"作为基准方案，然后通过三步评估流程判断是否需要升级：",{"type":185,"tag":228,"props":336,"children":337},{},[338,343,348],{"type":185,"tag":232,"props":339,"children":340},{},[341],{"type":191,"value":342},"评估单智能体是否存在硬性瓶颈",{"type":185,"tag":232,"props":344,"children":345},{},[346],{"type":191,"value":347},"评估任务在技术上是否具备并行可行性",{"type":185,"tag":232,"props":349,"children":350},{},[351],{"type":191,"value":352},"评估方案在商业上是否具备足够价值",{"type":185,"tag":194,"props":354,"children":355},{},[356],{"type":191,"value":357},"只有当这三个条件全部满足时，我才会采用多智能体架构。因为多智能体方案不仅成本更高，对技术实现的要求以及系统的不稳定性也会相应增加。",{"type":185,"tag":186,"props":359,"children":361},{"id":360},"anthropic-research-工程实践",[362],{"type":191,"value":363},"Anthropic Research 工程实践",{"type":185,"tag":206,"props":365,"children":367},{"id":366},"研究的本质是信息压缩",[368],{"type":191,"value":366},{"type":185,"tag":194,"props":370,"children":371},{},[372],{"type":191,"value":373},"多智能体系统的核心价值在于通过并行化实现信息压缩。子智能体（Subagent）各自拥有独立上下文窗口，能够同时探索问题的不同维度，然后将最重要的信息浓缩返回给主研究智能体。每个子智能体提供关注点分离（Separation of Concerns）——不同的工具、提示词和探索路径，从而减少路径依赖，实现彻底且独立的调查。",{"type":185,"tag":194,"props":375,"children":376},{},[377,379],{"type":191,"value":378},"见：",{"type":185,"tag":380,"props":381,"children":385},"a",{"href":382,"rel":383},"https://www.anthropic.com/engineering/multi-agent-research-system",[384],"nofollow",[386],{"type":191,"value":387},"How we built our multi-agent research system",{"type":185,"tag":206,"props":389,"children":391},{"id":390},"token-消耗是性能的首要决定因素",[392],{"type":191,"value":393},"Token 消耗是性能的首要决定因素",{"type":185,"tag":194,"props":395,"children":396},{},[397],{"type":191,"value":398},"Anthropic 的内部评估显示，在 BrowseComp 评测中，三个因素解释了 95% 的性能方差：Token 使用量（单独解释 80% 方差）、工具调用次数、模型选择。这意味着多智能体架构本质上是通过分布式上下文窗口来增加并行推理能力。Claude 模型作为 Token 使用效率的乘数，升级到新版本模型的性能增益甚至超过在旧版本上翻倍 Token 预算。",{"type":185,"tag":194,"props":400,"children":401},{},[402],{"type":191,"value":403},"代价是多智能体系统消耗 Token 极快——典型情况下，智能体交互使用约 4 倍于普通聊天的 Token，而多智能体系统使用约 15 倍。因此，多智能体系统只适用于任务价值足以支付性能溢价的高价值场景。",{"type":185,"tag":206,"props":405,"children":407},{"id":406},"orchestrator-worker-架构设计",[408],{"type":191,"value":409},"Orchestrator-Worker 架构设计",{"type":185,"tag":194,"props":411,"children":412},{},[413],{"type":191,"value":414},"Claude Research 采用主从协调模式（Orchestrator-Worker Pattern）：",{"type":185,"tag":284,"props":416,"children":417},{},[418,428],{"type":185,"tag":232,"props":419,"children":420},{},[421,426],{"type":185,"tag":236,"props":422,"children":423},{},[424],{"type":191,"value":425},"Lead Agent（主智能体）",{"type":191,"value":427},"：分析查询、制定策略、协调子智能体",{"type":185,"tag":232,"props":429,"children":430},{},[431,436],{"type":185,"tag":236,"props":432,"children":433},{},[434],{"type":191,"value":435},"Subagents（子智能体）",{"type":191,"value":437},"：并行执行专门的研究任务，作为智能过滤器迭代使用搜索工具收集信息",{"type":185,"tag":194,"props":439,"children":440},{},[441],{"type":191,"value":442},"与静态检索的 RAG 不同，这种架构使用多步动态搜索，能够根据新发现自适应调整，并分析结果以生成高质量答案。主智能体将研究计划保存到 Memory 中以持久化上下文，因为当上下文超过 20 万 Token 时会被截断。",{"type":185,"tag":206,"props":444,"children":446},{"id":445},"提示工程八项原则",[447],{"type":191,"value":445},{"type":185,"tag":228,"props":449,"children":450},{},[451,461,471,481,491,501,511,521],{"type":185,"tag":232,"props":452,"children":453},{},[454,459],{"type":185,"tag":236,"props":455,"children":456},{},[457],{"type":191,"value":458},"像智能体一样思考",{"type":191,"value":460},"——通过模拟观察智能体逐步工作，建立准确的心理模型",{"type":185,"tag":232,"props":462,"children":463},{},[464,469],{"type":185,"tag":236,"props":465,"children":466},{},[467],{"type":191,"value":468},"教导协调者如何委派",{"type":191,"value":470},"——子智能体需要明确的目标、输出格式、工具指导和清晰的任务边界",{"type":185,"tag":232,"props":472,"children":473},{},[474,479],{"type":185,"tag":236,"props":475,"children":476},{},[477],{"type":191,"value":478},"根据查询复杂度调整投入",{"type":191,"value":480},"——简单事实查找 1 个智能体 3-10 次调用，复杂研究可能需要 10+ 子智能体",{"type":185,"tag":232,"props":482,"children":483},{},[484,489],{"type":185,"tag":236,"props":485,"children":486},{},[487],{"type":191,"value":488},"工具设计与选择至关重要",{"type":191,"value":490},"——工具描述质量直接影响智能体决策，糟糕的描述会将智能体引向错误路径",{"type":185,"tag":232,"props":492,"children":493},{},[494,499],{"type":185,"tag":236,"props":495,"children":496},{},[497],{"type":191,"value":498},"让智能体自我改进",{"type":191,"value":500},"——Claude 4 模型可以成为优秀的提示工程师，甚至能重写工具描述以减少失败，使任务完成时间减少 40%",{"type":185,"tag":232,"props":502,"children":503},{},[504,509],{"type":185,"tag":236,"props":505,"children":506},{},[507],{"type":191,"value":508},"先广后深",{"type":191,"value":510},"——搜索策略应模仿专家人类研究：先探索全景，再深入细节",{"type":185,"tag":232,"props":512,"children":513},{},[514,519],{"type":185,"tag":236,"props":515,"children":516},{},[517],{"type":191,"value":518},"引导思考过程",{"type":191,"value":520},"——扩展思考模式（Extended Thinking）可作为可控的草稿本，用于规划方法、评估工具适配性",{"type":185,"tag":232,"props":522,"children":523},{},[524,529],{"type":185,"tag":236,"props":525,"children":526},{},[527],{"type":191,"value":528},"并行工具调用改变速度与性能",{"type":191,"value":530},"——主智能体并行生成 3-5 个子智能体，子智能体并行使用 3+ 工具，可将研究时间缩短 90%",{"type":185,"tag":206,"props":532,"children":534},{"id":533},"多智能体系统的评估策略",[535],{"type":191,"value":533},{"type":185,"tag":284,"props":537,"children":538},{},[539,549,559],{"type":185,"tag":232,"props":540,"children":541},{},[542,547],{"type":185,"tag":236,"props":543,"children":544},{},[545],{"type":191,"value":546},"立即用小样本开始评估",{"type":191,"value":548},"——早期改动影响巨大，20 个代表性查询足以发现变化影响，不必等到构建数百个测试用例才开始",{"type":185,"tag":232,"props":550,"children":551},{},[552,557],{"type":185,"tag":236,"props":553,"children":554},{},[555],{"type":191,"value":556},"LLM-as-Judge 可扩展",{"type":191,"value":558},"——使用单一 LLM 调用输出 0.0-1.0 分数和通过/失败判定，评估事实准确性、引用准确性、完整性、来源质量和工具效率",{"type":185,"tag":232,"props":560,"children":561},{},[562,567],{"type":185,"tag":236,"props":563,"children":564},{},[565],{"type":191,"value":566},"人工评估捕捉自动化遗漏",{"type":191,"value":568},"——包括幻觉答案、系统故障、微妙来源选择偏见（如早期智能体倾向选择 SEO 优化的内容农场而非权威学术 PDF）",{"type":185,"tag":206,"props":570,"children":572},{"id":571},"生产可靠性的工程挑战",[573],{"type":191,"value":571},{"type":185,"tag":284,"props":575,"children":576},{},[577,587,597,607,617],{"type":185,"tag":232,"props":578,"children":579},{},[580,585],{"type":185,"tag":236,"props":581,"children":582},{},[583],{"type":191,"value":584},"状态持久化与错误恢复",{"type":191,"value":586},"——智能体可能运行很长时间，需要 durable execution 和从错误点恢复的能力，而非从头重启",{"type":185,"tag":232,"props":588,"children":589},{},[590,595],{"type":185,"tag":236,"props":591,"children":592},{},[593],{"type":191,"value":594},"调试需要新方法",{"type":191,"value":596},"——智能体决策是动态的、非确定性的，需要完整的生产追踪（Tracing）来诊断失败原因",{"type":185,"tag":232,"props":598,"children":599},{},[600,605],{"type":185,"tag":236,"props":601,"children":602},{},[603],{"type":191,"value":604},"彩虹部署（Rainbow Deployment）",{"type":191,"value":606},"——避免更新代码破坏运行中的智能体，通过逐渐将流量从旧版本转移到新版本",{"type":185,"tag":232,"props":608,"children":609},{},[610,615],{"type":185,"tag":236,"props":611,"children":612},{},[613],{"type":191,"value":614},"同步执行的瓶颈",{"type":191,"value":616},"——当前主智能体同步等待子智能体完成，异步执行将带来额外并行性但增加协调复杂度",{"type":185,"tag":232,"props":618,"children":619},{},[620,625],{"type":185,"tag":236,"props":621,"children":622},{},[623],{"type":191,"value":624},"长对话的上下文管理",{"type":191,"value":626},"——当对话跨越数百轮时，智能体需要总结已完成的工作阶段，将关键信息存储到外部记忆，并在接近上下文限制时生成具有干净上下文的新子智能体",{"type":185,"tag":186,"props":628,"children":630},{"id":629},"cognition-上下文工程原则",[631],{"type":191,"value":632},"Cognition 上下文工程原则",{"type":185,"tag":206,"props":634,"children":636},{"id":635},"上下文工程context-engineering是-agent-构建的核心",[637],{"type":191,"value":638},"上下文工程（Context Engineering）是 Agent 构建的核心",{"type":185,"tag":194,"props":640,"children":641},{},[642],{"type":191,"value":643},"\"Prompt engineering\" 是为聊天机器人编写理想格式的任务描述，而 \"Context engineering\" 是更高级的概念——在动态系统中自动完成这一过程。这是构建生产级 AI Agent 工程师的首要工作。即使是最聪明的模型，没有上下文也无法有效工作。",{"type":185,"tag":194,"props":645,"children":646},{},[647,648],{"type":191,"value":378},{"type":185,"tag":380,"props":649,"children":652},{"href":650,"rel":651},"https://cognition.ai/blog/dont-build-multi-agents",[384],[653],{"type":191,"value":654},"Don't Build Multi-Agents",{"type":185,"tag":206,"props":656,"children":658},{"id":657},"多智能体架构的根本缺陷",[659],{"type":191,"value":657},{"type":185,"tag":194,"props":661,"children":662},{},[663],{"type":191,"value":664},"典型的多智能体架构（主任务拆分为子任务，由子智能体并行执行，最后合并结果）非常脆弱。关键失败点在于：",{"type":185,"tag":228,"props":666,"children":667},{},[668,678],{"type":185,"tag":232,"props":669,"children":670},{},[671,676],{"type":185,"tag":236,"props":672,"children":673},{},[674],{"type":191,"value":675},"上下文丢失",{"type":191,"value":677},"——子智能体缺乏完整上下文，容易误解任务。例如\"构建 Flappy Bird 克隆\"被拆分为\"游戏背景\"和\"可移动的小鸟\"，但子智能体 1 可能误解为 Super Mario 风格",{"type":185,"tag":232,"props":679,"children":680},{},[681,686],{"type":185,"tag":236,"props":682,"children":683},{},[684],{"type":191,"value":685},"隐式决策冲突",{"type":191,"value":687},"——即使子智能体都收到完整任务描述，它们基于未被预先规定的冲突假设做出决策，导致结果不一致（如视觉风格完全不同）",{"type":185,"tag":194,"props":689,"children":690},{},[691],{"type":191,"value":692},"Cognition 认为这些原则如此关键，以至于默认应排除任何不遵守它们的 Agent 架构。",{"type":185,"tag":206,"props":694,"children":696},{"id":695},"单线程线性-agent-是默认选择",[697],{"type":191,"value":698},"单线程线性 Agent 是默认选择",{"type":185,"tag":194,"props":700,"children":701},{},[702,704,709],{"type":191,"value":703},"遵循上下文工程原则的最简单方式是使用",{"type":185,"tag":236,"props":705,"children":706},{},[707],{"type":191,"value":708},"单线程线性 Agent",{"type":191,"value":710},"——上下文连续传递，没有并行子任务带来的信息丢失风险。这种架构能应对大多数场景，Claude Code 就是典型例子：虽然会生成子任务，但从不与主 Agent 并行执行，且子 Agent 通常只负责回答问题而非编写代码。",{"type":185,"tag":206,"props":712,"children":714},{"id":713},"长上下文任务的压缩策略",[715],{"type":191,"value":713},{"type":185,"tag":194,"props":717,"children":718},{},[719,721,726],{"type":191,"value":720},"对于真正长时间运行的任务，可引入专门的 LLM 作为",{"type":185,"tag":236,"props":722,"children":723},{},[724],{"type":191,"value":725},"上下文压缩器",{"type":191,"value":727},"——将行动历史和对话压缩为关键细节、事件和决策。这很难做对，需要投入精力识别关键信息，甚至可能需要针对领域微调小型模型。收益是 Agent 能在更长上下文中保持有效，但终究会达到极限。",{"type":185,"tag":206,"props":729,"children":731},{"id":730},"_2025-年多智能体协作的现实局限",[732],{"type":191,"value":733},"2025 年多智能体协作的现实局限",{"type":185,"tag":194,"props":735,"children":736},{},[737],{"type":191,"value":738},"让多个决策者\"相互对话\"达成共识看似理想，但 2025 年的 Agent 尚不具备这种能力。人类能高效传递最重要的知识，但这种效率需要非平凡的智能。目前运行多 Agent 协作只会产生脆弱系统——决策过于分散，上下文无法在 Agent 间充分共享。只有当单线程 Agent 能更好地与人类沟通时，跨 Agent 上下文传递问题才会迎刃而解。",{"type":185,"tag":186,"props":740,"children":742},{"id":741},"claude-官方多智能体决策指南",[743],{"type":191,"value":744},"Claude 官方多智能体决策指南",{"type":185,"tag":206,"props":746,"children":748},{"id":747},"多智能体系统的三种适用场景",[749],{"type":191,"value":747},{"type":185,"tag":194,"props":751,"children":752},{},[753],{"type":191,"value":754},"文章明确指出，只有在以下三种情况下，多智能体系统才能持续优于单智能体：",{"type":185,"tag":228,"props":756,"children":757},{},[758,768,783],{"type":185,"tag":232,"props":759,"children":760},{},[761,766],{"type":185,"tag":236,"props":762,"children":763},{},[764],{"type":191,"value":765},"上下文保护（Context Protection）",{"type":191,"value":767},"——当子任务产生大量上下文（超过 1000 Token）但大部分信息与主任务无关时，子智能体提供隔离，每个在专注于特定任务的干净上下文中运行",{"type":185,"tag":232,"props":769,"children":770},{},[771,776,778],{"type":185,"tag":236,"props":772,"children":773},{},[774],{"type":191,"value":775},"并行化（Parallelization）",{"type":191,"value":777},"——并行运行多个智能体允许探索比单个智能体更大的搜索空间，特别适用于搜索和研究任务。主要收益是",{"type":185,"tag":236,"props":779,"children":780},{},[781],{"type":191,"value":782},"彻底性（thoroughness），而非速度",{"type":185,"tag":232,"props":784,"children":785},{},[786,791],{"type":185,"tag":236,"props":787,"children":788},{},[789],{"type":191,"value":790},"专业化（Specialization）",{"type":191,"value":792},"——不同任务有时需要不同的工具集、系统提示词或专业领域知识。工具数量过多（20+）、跨领域混淆、添加新工具降低现有任务性能时，考虑专业化",{"type":185,"tag":194,"props":794,"children":795},{},[796,797],{"type":191,"value":378},{"type":185,"tag":380,"props":798,"children":801},{"href":799,"rel":800},"https://claude.com/blog/building-multi-agent-systems-when-and-how-to-use-them",[384],[802],{"type":191,"value":803},"Building multi-agent systems: When and how to use them",{"type":185,"tag":206,"props":805,"children":807},{"id":806},"单智能体优先与-token-开销",[808],{"type":191,"value":809},"单智能体优先与 Token 开销",{"type":185,"tag":194,"props":811,"children":812},{},[813,815,820],{"type":191,"value":814},"多智能体系统引入开销：",{"type":185,"tag":236,"props":816,"children":817},{},[818],{"type":191,"value":819},"典型情况下比单智能体方法多使用 3-10 倍 Token",{"type":191,"value":821},"（早期 Anthropic 工程博客提到：智能体交互使用约 4 倍于普通聊天的 Token，而多智能体系统使用约 15 倍）。开销来源于：",{"type":185,"tag":284,"props":823,"children":824},{},[825,830,835],{"type":185,"tag":232,"props":826,"children":827},{},[828],{"type":191,"value":829},"跨智能体复制上下文",{"type":185,"tag":232,"props":831,"children":832},{},[833],{"type":191,"value":834},"智能体间的协调消息",{"type":185,"tag":232,"props":836,"children":837},{},[838],{"type":191,"value":839},"交接时总结结果",{"type":185,"tag":194,"props":841,"children":842},{},[843,848,850,855],{"type":185,"tag":236,"props":844,"children":845},{},[846],{"type":191,"value":847},"关键洞察",{"type":191,"value":849},"：采用",{"type":185,"tag":236,"props":851,"children":852},{},[853],{"type":191,"value":854},"以上下文为中心的视角",{"type":191,"value":856},"而非以问题为中心的视角进行分解。有效边界包括独立研究路径、具有清晰接口的独立组件、黑盒验证；问题边界包括同一工作的顺序阶段、紧耦合组件、需要共享状态的工作。",{"type":185,"tag":206,"props":858,"children":860},{"id":859},"验证子智能体模式",[861],{"type":191,"value":859},{"type":185,"tag":194,"props":863,"children":864},{},[865,867,872],{"type":191,"value":866},"一种始终有效的多智能体模式：",{"type":185,"tag":236,"props":868,"children":869},{},[870],{"type":191,"value":871},"专门负责测试或验证主智能体工作的独立智能体",{"type":191,"value":873},"。这之所以有效，是因为验证需要最少的上下文转移——验证者可以对系统进行黑盒测试，无需了解构建过程的完整历史。",{"type":185,"tag":194,"props":875,"children":876},{},[877,882],{"type":185,"tag":236,"props":878,"children":879},{},[880],{"type":191,"value":881},"最显著的失败模式",{"type":191,"value":883},"：未进行彻底测试就将输出标记为通过。缓解策略包括具体标准、全面检查、负面测试、明确指令。",{"type":185,"tag":206,"props":885,"children":887},{"id":886},"工具搜索工具tool-search-tool",[888],{"type":191,"value":889},"工具搜索工具（Tool Search Tool）",{"type":185,"tag":194,"props":891,"children":892},{},[893],{"type":191,"value":894},"在考虑多智能体之前，可尝试的缓解措施：让 Claude 动态发现工具而非预先加载所有定义，可将 Token 使用量减少多达 85%，同时提高工具选择准确性。",{"type":185,"tag":186,"props":896,"children":898},{"id":897},"未来发展趋势",[899],{"type":191,"value":897},{"type":185,"tag":206,"props":901,"children":903},{"id":902},"融合趋势",[904],{"type":191,"value":902},{"type":185,"tag":194,"props":906,"children":907},{},[908],{"type":191,"value":909},"框架间已出现融合苗头：",{"type":185,"tag":284,"props":911,"children":912},{},[913,918,923],{"type":185,"tag":232,"props":914,"children":915},{},[916],{"type":191,"value":917},"AutoGen 引入更结构化的控制机制",{"type":185,"tag":232,"props":919,"children":920},{},[921],{"type":191,"value":922},"DeepAgents 尝试变得更对话化、更灵活",{"type":185,"tag":232,"props":924,"children":925},{},[926],{"type":191,"value":927},"CrewAI 不断增强处理复杂任务的能力",{"type":185,"tag":206,"props":929,"children":931},{"id":930},"可能的演进方向",[932],{"type":191,"value":930},{"type":185,"tag":284,"props":934,"children":935},{},[936,946,956],{"type":185,"tag":232,"props":937,"children":938},{},[939,944],{"type":185,"tag":236,"props":940,"children":941},{},[942],{"type":191,"value":943},"混合架构",{"type":191,"value":945},"：既可对话驱动，也可计划驱动",{"type":185,"tag":232,"props":947,"children":948},{},[949,954],{"type":185,"tag":236,"props":950,"children":951},{},[952],{"type":191,"value":953},"自适应协作",{"type":191,"value":955},"：根据任务不同自动切换协作方式",{"type":185,"tag":232,"props":957,"children":958},{},[959,964],{"type":185,"tag":236,"props":960,"children":961},{},[962],{"type":191,"value":963},"跨框架互操作",{"type":191,"value":965},"：不同框架的智能体能无缝协作",{"title":178,"searchDepth":967,"depth":967,"links":968},2,[969,970,971,972,973,974],{"id":188,"depth":967,"text":192},{"id":201,"depth":967,"text":204},{"id":360,"depth":967,"text":363},{"id":629,"depth":967,"text":632},{"id":741,"depth":967,"text":744},{"id":897,"depth":967,"text":897},"markdown","content:6.maps:_ai:agents:multi-agent-architecture.md","content","6.maps/_ai/agents/multi-agent-architecture.md","6.maps/_ai/agents/multi-agent-architecture","md",[982,986],{"_path":983,"title":984,"description":985},"/maps/_ai/agents/goose/prompts","Goose Prompts","xxx",{"_path":987,"title":988,"description":989},"/maps/_ai/agents/multi-agent-frameworks","多智能体协作框架对比","AutoGen、DeepAgents、CrewAI、ElizaOS、OpenAI Swarm、AgentScope、LangGraph 等多智能体框架的核心设计、适用场景与选择建议",1772504962124]