ype":185,"tag":248,"props":277,"children":278},{},[279],{"type":191,"value":280},"1,385,648",{"type":185,"tag":248,"props":282,"children":283},{},[284],{"type":191,"value":285},"136,846",{"type":185,"tag":248,"props":287,"children":288},{},[289],{"type":191,"value":290},"10:1",{"type":185,"tag":216,"props":292,"children":293},{},[294,299,304,309],{"type":185,"tag":248,"props":295,"children":296},{},[297],{"type":191,"value":298},"GitHub Code（数据量）",{"type":185,"tag":248,"props":300,"children":301},{},[302],{"type":191,"value":303},"3.01 GB",{"type":185,"tag":248,"props":305,"children":306},{},[307],{"type":191,"value":308},"0.69 GB",{"type":185,"tag":248,"props":310,"children":311},{},[312],{"type":191,"value":313},"4.4:1",{"type":185,"tag":194,"props":315,"children":316},{},[317],{"type":191,"value":318},"这种失衡源于历史与生态因素：Bash 自 1989 年发布，而 PowerShell 直到 2016 年才跨平台；\n开源生态和 CI/CD 基础设施长期以 Linux/Bash 为主流，企业 Windows 环境的 PowerShell 脚本多存在于私有仓库，未进入公开训练数据。",{"type":185,"tag":186,"props":320,"children":322},{"id":321},"实际性能差异表现",[323],{"type":191,"value":321},{"type":185,"tag":194,"props":325,"children":326},{},[327],{"type":191,"value":328},"在 Claude Code 等 Agent 的实际运行中，Windows 原生 PowerShell 环境与 WSL/Linux 存在显著性能差距：",{"type":185,"tag":208,"props":330,"children":331},{},[332,353],{"type":185,"tag":212,"props":333,"children":334},{},[335],{"type":185,"tag":216,"props":336,"children":337},{},[338,343,348],{"type":185,"tag":220,"props":339,"children":340},{},[341],{"type":191,"value":342},"环境",{"type":185,"tag":220,"props":344,"children":345},{},[346],{"type":191,"value":347},"命令延迟",{"type":185,"tag":220,"props":349,"children":350},{},[351],{"type":191,"value":352},"相对性能",{"type":185,"tag":241,"props":354,"children":355},{},[356,374,392],{"type":185,"tag":216,"props":357,"children":358},{},[359,364,369],{"type":185,"tag":248,"props":360,"children":361},{},[362],{"type":191,"value":363},"原生 Linux",{"type":185,"tag":248,"props":365,"children":366},{},[367],{"type":191,"value":368},"\u003C1 秒",{"type":185,"tag":248,"props":370,"children":371},{},[372],{"type":191,"value":373},"基准",{"type":185,"tag":216,"props":375,"children":376},{},[377,382,387],{"type":185,"tag":248,"props":378,"children":379},{},[380],{"type":191,"value":381},"WSL2",{"type":185,"tag":248,"props":383,"children":384},{},[385],{"type":191,"value":386},"~1.5 秒",{"type":185,"tag":248,"props":388,"children":389},{},[390],{"type":191,"value":391},"接近原生",{"type":185,"tag":216,"props":393,"children":394},{},[395,400,408],{"type":185,"tag":248,"props":396,"children":397},{},[398],{"type":191,"value":399},"Windows 原生 PowerShell",{"type":185,"tag":248,"props":401,"children":402},{},[403],{"type":185,"tag":200,"props":404,"children":405},{},[406],{"type":191,"value":407},"10+ 秒/命令",{"type":185,"tag":248,"props":409,"children":410},{},[411],{"type":191,"value":412},"严重滞后",{"type":185,"tag":194,"props":414,"children":415},{},[416,418,423,425,432,434,440,441,447],{"type":191,"value":417},"文件系统操作方面，Windows NTFS 在文件搜索任务上比 Linux EXT4 慢约 ",{"type":185,"tag":200,"props":419,"children":420},{},[421],{"type":191,"value":422},"23%",{"type":191,"value":424},"。\nClaude Code 等工具底层依赖 Unix 工具链（",{"type":185,"tag":426,"props":427,"children":429},"code",{"className":428},[],[430],{"type":191,"value":431},"grep",{"type":191,"value":433},"、",{"type":185,"tag":426,"props":435,"children":437},{"className":436},[],[438],{"type":191,"value":439},"find",{"type":191,"value":433},{"type":185,"tag":426,"props":442,"children":444},{"className":443},[],[445],{"type":191,"value":446},"awk",{"type":191,"value":448},"），Windows 需通过 Git Bash 等兼容层提供支持，增加了子进程启动开销和路径转换复杂度。",{"type":185,"tag":186,"props":450,"children":452},{"id":451},"主流-benchmark-的平台倾向",[453],{"type":191,"value":454},"主流 Benchmark 的平台倾向",{"type":185,"tag":194,"props":456,"children":457},{},[458],{"type":191,"value":459},"现有 Coding Agent Benchmark 呈现明显的 Linux 中心化特征：",{"type":185,"tag":208,"props":461,"children":462},{},[463,484],{"type":185,"tag":212,"props":464,"children":465},{},[466],{"type":185,"tag":216,"props":467,"children":468},{},[469,474,479],{"type":185,"tag":220,"props":470,"children":471},{},[472],{"type":191,"value":473},"Benchmark",{"type":185,"tag":220,"props":475,"children":476},{},[477],{"type":191,"value":478},"原生平台",{"type":185,"tag":220,"props":480,"children":481},{},[482],{"type":191,"value":483},"Windows 支持",{"type":185,"tag":241,"props":485,"children":486},{},[487,505,523],{"type":185,"tag":216,"props":488,"children":489},{},[490,495,500],{"type":185,"tag":248,"props":491,"children":492},{},[493],{"type":191,"value":494},"OSWorld",{"type":185,"tag":248,"props":496,"children":497},{},[498],{"type":191,"value":499},"Ubuntu Linux",{"type":185,"tag":248,"props":501,"children":502},{},[503],{"type":191,"value":504},"WindowsAgentArena 扩展",{"type":185,"tag":216,"props":506,"children":507},{},[508,513,518],{"type":185,"tag":248,"props":509,"children":510},{},[511],{"type":191,"value":512},"SWE-bench",{"type":185,"tag":248,"props":514,"children":515},{},[516],{"type":191,"value":517},"Linux/Docker",{"type":185,"tag":248,"props":519,"children":520},{},[521],{"type":191,"value":522},"容器间接支持",{"type":185,"tag":216,"props":524,"children":525},{},[526,531,536],{"type":185,"tag":248,"props":527,"children":528},{},[529],{"type":191,"value":530},"SWE-agent",{"type":185,"tag":248,"props":532,"children":533},{},[534],{"type":191,"value":535},"Linux/Unix",{"type":185,"tag":248,"props":537,"children":538},{},[539],{"type":191,"value":540},"Docker 封装",{"type":185,"tag":194,"props":542,"children":543},{},[544],{"type":191,"value":545},"这些基准测试的设计假设与执行环境均以 Bash 工具链为基础，\nWindows 环境的评估要么缺失，要么通过 Docker/WSL 间接实现，掩盖了原生 PowerShell 场景的真实表现。",{"type":185,"tag":186,"props":547,"children":549},{"id":548},"关键洞见",[550],{"type":191,"value":548},{"type":185,"tag":194,"props":552,"children":553},{},[554,559],{"type":185,"tag":200,"props":555,"children":556},{},[557],{"type":191,"value":558},"训练语料 imbalance 转化为 runtime performance gap",{"type":191,"value":560},"。\n当 Agent 生成 PowerShell 命令时，由于语料 exposure 不足，更易出现：",{"type":185,"tag":562,"props":563,"children":564},"ul",{},[565,571,576],{"type":185,"tag":566,"props":567,"children":568},"li",{},[569],{"type":191,"value":570},"参数幻觉（编造不存在的参数）",{"type":185,"tag":566,"props":572,"children":573},{},[574],{"type":191,"value":575},"语法混淆（混用 Bash 语法写 PowerShell）",{"type":185,"tag":566,"props":577,"children":578},{},[579],{"type":191,"value":580},"工具链误用（假设存在 Unix 工具）",{"type":185,"tag":194,"props":582,"children":583},{},[584],{"type":191,"value":585},"这一现象揭示了当前 LLM 训练数据对 Windows 生态的系统性 under-representation，\n也意味着在 Windows 原生环境部署 Coding Agent 时，需预期更高的容错成本或优先考虑 WSL 方案。",{"type":185,"tag":194,"props":587,"children":588},{},[589,591,600,602,609,610],{"type":191,"value":590},"见：",{"type":185,"tag":592,"props":593,"children":597},"a",{"href":594,"rel":595},"https://arxiv.org/html/2405.06807v2",[596],"nofollow",[598],{"type":191,"value":599},"Execution-Based Evaluation of Natural Language to Bash and PowerShell",{"type":191,"value":601},"、\n",{"type":185,"tag":592,"props":603,"children":606},{"href":604,"rel":605},"https://github.com/xverse-ai/XVERSE-65B",[596],[607],{"type":191,"value":608},"XVERSE-65B Training Data",{"type":191,"value":601},{"type":185,"tag":592,"props":611,"children":614},{"href":612,"rel":613},"https://zenn.dev/sora_biz/articles/claude-code-windows-troubleshoot",[596],[615],{"type":191,"value":616},"Claude Code Windows Troubleshooting",{"title":178,"searchDepth":618,"depth":618,"links":619},2,[],"markdown","content:6.maps:_ai:agents:coding-agent-shell-bias.md","content","6.maps/_ai/agents/coding-agent-shell-bias.md","6.maps/_ai/agents/coding-agent-shell-bias","md",[627,631],{"_path":628,"title":629,"description":630},"/maps/_ai/agents/claude-agent-sdk-releases","Claude Agent SDK (TypeScript) 发布记录","Anthropic Claude Agent SDK TypeScript 版本的完整发布历史与变更日志",{"_path":632,"title":633,"description":634},"/maps/_ai/agents/docs/i18n","i18n 国际化实现","本博客的轻量级国际化（