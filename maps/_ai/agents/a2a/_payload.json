",{"type":182,"children":183,"toc":671},"root",[184,192,198,221,226,233,238,244,249,255,260,266,271,277,282,351,356,367,373,384,390,402,500,505,513,523,528,563,574,579,585,603,608,652],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"概述",[190],{"type":191,"value":188},"text",{"type":185,"tag":193,"props":194,"children":195},"p",{},[196],{"type":191,"value":197},"A2A（Agent-to-Agent）协议是 Google 于 2025 年 4 月发布的开放标准，旨在解决不同 AI 智能体之间的互操作性问题，允许不同供应商、框架和平台的智能体跨系统安全协作，打破\"信息孤岛\"。",{"type":185,"tag":193,"props":199,"children":200},{},[201,203,212,214],{"type":191,"value":202},"见：",{"type":185,"tag":204,"props":205,"children":209},"a",{"href":206,"rel":207},"https://developers.google.com/agent-to-agent",[208],"nofollow",[210],{"type":191,"value":211},"Google A2A 官方文档",{"type":191,"value":213}," | ",{"type":185,"tag":204,"props":215,"children":218},{"href":216,"rel":217},"https://github.com/google/A2A",[208],[219],{"type":191,"value":220},"A2A 协议规范",{"type":185,"tag":186,"props":222,"children":224},{"id":223},"核心设计原则",[225],{"type":191,"value":223},{"type":185,"tag":227,"props":228,"children":230},"h4",{"id":229},"能力发现capability-discovery",[231],{"type":191,"value":232},"能力发现（Capability Discovery）",{"type":185,"tag":193,"props":234,"children":235},{},[236],{"type":191,"value":237},"Agent 可动态发现其他 Agent 的能力，无需预先硬编码集成逻辑。通过标准化的能力描述格式，Agent 能理解其他 Agent 可以执行什么任务。",{"type":185,"tag":227,"props":239,"children":241},{"id":240},"任务管理task-management",[242],{"type":191,"value":243},"任务管理（Task Management）",{"type":185,"tag":193,"props":245,"children":246},{},[247],{"type":191,"value":248},"支持多 Agent 协作完成复杂任务，包含任务创建、状态跟踪、结果返回的全生命周期管理。",{"type":185,"tag":227,"props":250,"children":252},{"id":251},"多模态通信multimodal-communication",[253],{"type":191,"value":254},"多模态通信（Multimodal Communication）",{"type":185,"tag":193,"props":256,"children":257},{},[258],{"type":191,"value":259},"支持文本、图像、音频、视频等多种数据格式的交换，适应不同场景需求。",{"type":185,"tag":227,"props":261,"children":263},{"id":2