",{"type":182,"children":183,"toc":245},"root",[184,193,199,205,210,216,221,226,231],{"type":185,"tag":186,"props":187,"children":189},"element","h4",{"id":188},"用户界面正从-gui-向-lui-迁移",[190],{"type":191,"value":192},"text","用户界面正从 GUI 向 LUI 迁移",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"大模型具备自然语言处理、智能决策和工具调用三项能力，这些能力将推动用户界面从图形用户界面（GUI）向自然语言用户界面（LUI/NLUI）迁移。在 LUI 模式下，自然语言成为界面中枢，系统通过大模型调度、组装功能模块，而非呈现完整页面。GUI 和 LUI 将长期并存，满足不同场景需求。",{"type":185,"tag":186,"props":200,"children":202},{"id":201},"ai-agent-的全流程自动化能力",[203],{"type":191,"value":204},"AI Agent 的全流程自动化能力",{"type":185,"tag":194,"props":206,"children":207},{},[208],{"type":191,"value":209},"通用 AI Agent 已具备自主访问网页、操作界面、处理内容、整合多源数据并生成输出的全流程自动化能力。以 Playwright MCP 为例，Agent 可自主完成：打开浏览器 → 搜索信息 → 筛选结果 → 阅读文章 → 生成总结 → 创建并打开 HTML 报告，全程无需人工干预。",{"type":185,"tag":186,"props":211,"children":213},{"id":212},"企业服务将从网页向-apimcp-server-迁移",[214],{"type":191,"value":215},"企业服务将从网页向 API/MCP Server 迁移",{"type":185,"tag":194,"props":217,"children":218},{},[219],{"type":191,"value":220},"如果未来流量主要来自 AI Agent 而非人类用户，面向人类的用户界面重要性将下降。API 在系统间信息交互中的效率优势显著，企业提供服务的方式将逐步从\"提供网页\"向\"提供 API（MCP Server）\"迁移，以实现更灵活、可扩展的系统集成。",{"type":185,"tag":186,"props":222,"children":224},{"id":223},"泛前端角色的核心关注点",[225],{"type":191,"value":223},{"type":185,"tag":194,"props":227,"children":228},{},[229],{"type":191,"value":230},"泛前端开发处于\"理解用户需求\"与\"技术实现\"的中间地带，需同时关注用户体验和技术指标。其专业壁垒在于：既要理解用户诉求、将功能转化为可感知的服务，又要通过工程手段实现稳定、高性能的界面交付。",{"type":185,"tag":194,"props":232,"children":233},{},[234,236],{"type":191,"value":235},"见：",{"type":185,"tag":237,"props":238,"children":242},"a",{"href":239,"rel":240},"https://mp.weixin.qq.com/s?__biz=MzU1ODEzNjI2NA==&mid=2247574876&idx=1&sn=4b0bf1c1da0a1c3cd626ec6c308cb579",[241],"nofollow",[243],{"type":191,"value":244},"AI 在泛前端领域的思考和实践 @滴滴技术",{"title":178,"searchDepth":246,"depth":246,"links":247},2,[],"markdown","content:6.maps:_ai:frontend-impact.md","content","6.maps/_ai/frontend-impact.md","6.maps/_ai/frontend-impact","md",[255,259],{"_path":256,"title":257,"description":258},"/maps/_ai/framework/saif","SAIF","安全人工智能框架",{"_path":260,"title":261,"description":178},"/maps/_ai/image/stable-diffusion","Image Generator",1771696730007]