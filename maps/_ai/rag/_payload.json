35,241,246,273,279,284,311,317,322,349,355,360],{"type":184,"tag":185,"props":186,"children":188},"element","h1",{"id":187},"rag-检索增强生成",[189],{"type":190,"value":179},"text",{"type":184,"tag":192,"props":193,"children":195},"h2",{"id":194},"chroma轻量级嵌入式向量数据库",[196],{"type":190,"value":197},"Chroma：轻量级嵌入式向量数据库",{"type":184,"tag":199,"props":200,"children":201},"p",{},[202],{"type":190,"value":203},"Chroma 是最易上手的向量数据库，主打\"嵌入式\"——直接 pip 安装，无需额外服务。适合原型验证和中小规模应用（\u003C 1000 万向量），提供直观的 Python API，与 LangChain、LlamaIndex 无缝集成。对于需要快速启动的 AI 应用，Chroma 是零成本入门的首选。",{"type":184,"tag":199,"props":205,"children":206},{},[207,209,218,220,227,228],{"type":190,"value":208},"见：",{"type":184,"tag":210,"props":211,"children":215},"a",{"href":212,"rel":213},"https://www.trychroma.com/",[214],"nofollow",[216],{"type":190,"value":217},"Chroma 官网",{"type":190,"value":219}," | ",{"type":184,"tag":210,"props":221,"children":224},{"href":222,"rel":223},"https://www.truefoundry.com/blog/best-vector-databases",[214],[225],{"type":190,"value":226},"2025 最佳向量数据库",{"type":190,"value":219},{"type":184,"tag":210,"props":229,"children":232},{"href":230,"rel":231},"https://en.paperblog.com/vector-databases-for-rag-pinecone-vs-weaviate-vs-chroma-2025-comparison-guide-8014057/",[214],[233],{"type":190,"value":234},"RAG 向量数据库对比",{"type":184,"tag":192,"props":236,"children":238},{"id":237},"faissfacebook-高效相似度搜索库",[239],{"type":190,"value":240},"FAISS：Facebook 高效相似度搜索库",{"type":184,"tag":199,"props":242,"children":243},{},[244],{"type":190,"value":245},"FAISS 是 Facebook 开源的向量搜索库，提供多种索引算法：Flat（精确搜索，小数据集）、IVF（倒排文件索引，平衡速度/精度）、HNSW（图索引，高维大数据集最优）、PQ（乘积量化，极致压缩）。适合需要精细控制索引算法、已有数据基础设施只需向量搜索模块、大规模数据集（十亿级向量）的场景。",{"type":184,"tag":199,"props":247,"children":248},{},[249,250,257,258,265,266],{"type":190,"value":208},{"type":184,"tag":210,"props":251,"children":254},{"href":252,"rel":253},"https://github.com/facebookresearch/faiss",[214],[255],{"type":190,"value":256},"FAISS GitHub",{"type":190,"value":219},{"type":184,"tag":210,"props":259,"children":262},{"href":260,"rel":261},"https://github.com/facebookresearch/faiss/wiki/Guidelines-to-choose-an-index",[214],[263],{"type":190,"value":264},"FAISS 索引选择指南",{"type":190,"value":219},{"type":184,"tag":210,"props":267,"children":270},{"href":268,"rel":269},"https://milvus.io/blog/understanding-ivf-vector-index-how-It-works-and-when-to-choose-it-over-hnsw.md",[214],[271],{"type":190,"value":272},"HNSW vs IVF 对比",{"type":184,"tag":192,"props":274,"children":276},{"id":275},"qdrantrust-实现的开源向量数据库",[277],{"type":190,"value":278},"Qdrant：Rust 实现的开源向量数据库",{"type":184,"tag":199,"props":280,"children":281},{},[282],{"type":190,"value":283},"Qdrant 是用 Rust 编写的向量数据库，性能优异且功能丰富：过滤搜索（向量相似度 + 元数据过滤同时进行）、混合搜索（稀疏向量 + 密集向量结合）、量化（Scalar、Product 量化降低内存 97%）、分布式原生支持集群部署。适合生产级 RAG 应用。",{"type":184,"tag":199,"props":285,"children":286},{},[287,288,295,296,303,304],{"type":190,"value":208},{"type":184,"tag":210,"props":289,"children":292},{"href":290,"rel":291},"https://qdrant.tech/",[214],[293],{"type":190,"value":294},"Qdrant 官网",{"type":190,"value":219},{"type":184,"tag":210,"props":297,"children":300},{"href":298,"rel":299},"https://qdrant.tech/documentation/concepts/hybrid-queries/",[214],[301],{"type":190,"value":302},"Qdrant 混合搜索",{"type":190,"value":219},{"type":184,"tag":210,"props":305,"children":308},{"href":306,"rel":307},"https://qdrant.tech/documentation/guides/quantization/",[214],[309],{"type":190,"value":310},"Qdrant 量化指南",{"type":184,"tag":192,"props":312,"children":314},{"id":313},"sentence-transformers文本嵌入模型库",[315],{"type":190,"value":316},"Sentence Transformers：文本嵌入模型库",{"type":184,"tag":199,"props":318,"children":319},{},[320],{"type":190,"value":321},"Sentence Transformers（SBERT）是生成文本嵌入的事实标准库，提供预训练模型（all-MiniLM、all-mpnet 等）、多语言支持、微调接口，与向量数据库无缝集成。all-MiniLM-L6-v2 是最流行的轻量级模型，将句子映射到 384 维向量空间。",{"type":184,"tag":199,"props":323,"children":324},{},[325,326,333,334,341,342],{"type":190,"value":208},{"type":184,"tag":210,"props":327,"children":330},{"href":328,"rel":329},"https://www.sbert.net/",[214],[331],{"type":190,"value":332},"Sentence Transformers 文档",{"type":190,"value":219},{"type":184,"tag":210,"props":335,"children":338},{"href":336,"rel":337},"https://www.sbert.net/docs/sentence_transformer/pretrained_models.html",[214],[339],{"type":190,"value":340},"预训练模型列表",{"type":190,"value":219},{"type":184,"tag":210,"props":343,"children":346},{"href":344,"rel":345},"https://sbert.net/examples/sentence_transformer/training/multilingual/README.html",[214],[347],{"type":190,"value":348},"多语言模型",{"type":184,"tag":192,"props":350,"children":352},{"id":351},"rag-进阶技术",[353],{"type":190,"value":354},"RAG 进阶技术",{"type":184,"tag":199,"props":356,"children":357},{},[358],{"type":190,"value":359},"多向量检索：句子窗口（存储段落，检索句子 + 上下文）、父子块（小块用于匹配，大块用于生成）、摘要索引（用摘要辅助长文档检索）。查询优化：查询扩展（用 LLM 生成同义查询）、HyDE（生成假设文档，用其嵌入检索）、路由（根据查询类型选择不同检索策略）。Agentic RAG 结合 Agent 能力实现多跳推理、子问题分解、工具使用。",{"type":184,"tag":199,"props":361,"children":362},{},[363,364,370,371],{"type":190,"value":208},{"type":184,"tag":210,"props":365,"children":367},{"href":222,"rel":366},[214],[368],{"type":190,"value":369},"RAG 最佳实践指南",{"type":190,"value":219},{"type":184,"tag":210,"props":372,"children":375},{"href":373,"rel":374},"https://github.com/zilliztech/VectorDBBench",[214],[376],{"type":190,"value":377},"VectorDB Bench 性能测试",{"title":178,"searchDepth":379,"depth":379,"links":380},2,[381,382,383,384,385],{"id":194,"depth":379,"text":197},{"id":237,"depth":379,"text":240},{"id":275,"depth":379,"text":278},{"id":313,"depth":379,"text":316},{"id":351,"depth":379,"text":354},"markdown","content:6.maps:_ai:rag.md","content","6.maps/_ai/rag.md","6.maps/_ai/rag","md",[393,397],{"_path":394,"title":395,"description":396},"/maps/_ai/prompt/team-based-instructions","Team based Instructions","为软件团队策划和共享指令（Curated shared instructions for software teams）",{"_path":398,"title":399,"description":400},"/maps/_ai/rag/on-device-info-retrieval","设备端信息检索","在用户设备上进行信息检索以保障隐私和提升效率。",1771696738769]