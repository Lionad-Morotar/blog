":181,"tag":182,"props":183,"children":185},"element","h1",{"id":184},"rag-检索增强生成",[186],{"type":187,"value":176},"text",{"type":181,"tag":189,"props":190,"children":192},"h2",{"id":191},"chroma轻量级嵌入式向量数据库",[193],{"type":187,"value":194},"Chroma：轻量级嵌入式向量数据库",{"type":181,"tag":196,"props":197,"children":198},"p",{},[199],{"type":187,"value":200},"Chroma 是最易上手的向量数据库，主打\"嵌入式\"——直接 pip 安装，无需额外服务。适合原型验证和中小规模应用（\u003C 1000 万向量），提供直观的 Python API，与 LangChain、LlamaIndex 无缝集成。对于需要快速启动的 AI 应用，Chroma 是零成本入门的首选。",{"type":181,"tag":196,"props":202,"children":203},{},[204,206,215,217,224,225],{"type":187,"value":205},"见：",{"type":181,"tag":207,"props":208,"children":212},"a",{"href":209,"rel":210},"https://www.trychroma.com/",[211],"nofollow",[213],{"type":187,"value":214},"Chroma 官网",{"type":187,"value":216}," | ",{"type":181,"tag":207,"props":218,"children":221},{"href":219,"rel":220},"https://www.truefoundry.com/blog/best-vector-databases",[211],[222],{"type":187,"value":223},"2025 最佳向量数据库",{"type":187,"value":216},{"type":181,"tag":207,"props":226,"children":229},{"href":227,"rel":228},"https://en.paperblog.com/vector-databases-for-rag-pinecone-vs-weaviate-vs-chroma-2025-comparison-guide-8014057/",[211],[230],{"type":187,"value":231},"RAG 向量数据库对比",{"type":181,"tag":189,"props":233,"children":235},{"id":234},"faissfacebook-高效相似度搜索库",[236],{"type":187,"value":237},"FAISS：Facebook 高效相似度搜索库",{"type":181,"tag":196,"props":239,"children":240},{},[241],{"type":187,"value":242},"FAISS 是 Facebook 开源的向量搜索库，提供多种索引算法：Flat（精确搜索，小数据集）、IVF（倒排文件索引，平衡速度/精度）、HNSW（图索引，高维大数据集最优）、PQ（乘积量化，极致压缩）。适合需要精细控制索引算法、已有数据基础设施只需向量搜索模块、大规模数据集（十亿级向量）的场景。",{"type":181,"tag":196,"props":244,"children":245},{},[246,247,254,255,262,263],{"type":187,"value":205},{"type":181,"tag":207,"props":248,"children":251},{"href":249,"rel":250},"https://github.com/facebookresearch/faiss",[211],[252],{"type":187,"value":253},"FAISS GitHub",{"type":187,"value":216},{"type":181,"tag":207,"props":256,"children":259},{"href":257,"rel":258},"https://github.com/facebookresearch/faiss/wiki/Guidelines-to-choose-an-index",[211],[260],{"type":187,"value":261},"FAISS 索引选择指南",{"type":187,"value":216},{"type":181,"tag":207,"props":264,"children":267},{"href":265,"rel":266},"https://milvus.io/blog/understanding-ivf-vector-index-how-It-works-and-when-to-choose-it-over-hnsw.md",[211],[268],{"type":187,"value":269},"HNSW vs IVF 对比",{"type":181,"tag":189,"props":271,"children":273},{"id":272},"qdrantrust-实现的开源向量数据库",[274],{"type":187,"value":275},"Qdrant：Rust 实现的开源向量数据库",{"type":181,"tag":196,"props":277,"children":278},{},[279],{"type":187,"value":280},"Qdrant 是用 Rust 编写的向量数据库，性能优异且功能丰富：过滤搜索（向量相似度 + 元数据过滤同时进行）、混合搜索（稀疏向量 + 密集向量结合）、量化（Scalar、Product 量化降低内存 97%）、分布式原生支持集群部署。适合生产级 RAG 应用。",{"type":181,"tag":196,"props":282,"children":283},{},[284,285,292,293,300,301],{"type":187,"value":205},{"type":181,"tag":207,"props":286,"children":289},{"href":287,"rel":288},"https://qdrant.tech/",[211],[290],{"type":187,"value":291},"Qdrant 官网",{"type":187,"value":216},{"type":181,"tag":207,"props":294,"children":297},{"href":295,"rel":296},"https://qdrant.tech/documentation/concepts/hybrid-queries/",[211],[298],{"type":187,"value":299},"Qdrant 混合搜索",{"type":187,"value":216},{"type":181,"tag":207,"props":302,"children":305},{"href":303,"rel":304},"https://qdrant.tech/documentation/guides/quantization/",[211],[306],{"type":187,"value":307},"Qdrant 量化指南",{"type":181,"tag":189,"props":309,"children":311},{"id":310},"sentence-transformers文本嵌入模型库",[312],{"type":187,"value":313},"Sentence Transformers：文本嵌入模型库",{"type":181,"tag":196,"props":315,"children":316},{},[317],{"type":187,"value":318},"Sentence Transformers（SBERT）是生成文本嵌入的事实标准库，提供预训练模型（all-MiniLM、all-mpnet 等）、多语言支持、微调接口，与向量数据库无缝集成。all-MiniLM-L6-v2 是最流行的轻量级模型，将句子映射到 384 维向量空间。",{"type":181,"tag":196,"props":320,"children":321},{},[322,323,330,331,338,339],{"type":187,"value":205},{"type":181,"tag":207,"props":324,"children":327},{"href":325,"rel":326},"https://www.sbert.net/",[211],[328],{"type":187,"value":329},"Sentence Transformers 文档",{"type":187,"value":216},{"type":181,"tag":207,"props":332,"children":335},{"href":333,"rel":334},"https://www.sbert.net/docs/sentence_transformer/pretrained_models.html",[211],[336],{"type":187,"value":337},"预训练模型列表",{"type":187,"value":216},{"type":181,"tag":207,"props":340,"children":343},{"href":341,"rel":342},"https://sbert.net/examples/sentence_transformer/training/multilingual/README.html",[211],[344],{"type":187,"value":345},"多语言模型",{"type":181,"tag":189,"props":347,"children":349},{"id":348},"rag-进阶技术",[350],{"type":187,"value":351},"RAG 进阶技术",{"type":181,"tag":196,"props":353,"children":354},{},[355],{"type":187,"value":356},"多向量检索：句子窗口（存储段落，检索句子 + 上下文）、父子块（小块用于匹配，大块用于生成）、摘要索引（用摘要辅助长文档检索）。查询优化：查询扩展（用 LLM 生成同义查询）、HyDE（生成假设文档，用其嵌入检索）、路由（根据查询类型选择不同检索策略）。Agentic RAG 结合 Agent 能力实现多跳推理、子问题分解、工具使用。",{"type":181,"tag":196,"props":358,"children":359},{},[360,361,367,368],{"type":187,"value":205},{"type":181,"tag":207,"props":362,"children":364},{"href":219,"rel":363},[211],[365],{"type":187,"value":366},"RAG 最佳实践指南",{"type":187,"value":216},{"type":181,"tag":207,"props":369,"children":372},{"href":370,"rel":371},"https://github.com/zilliztech/VectorDBBench",[211],[373],{"type":187,"value":374},"VectorDB Bench 性能测试",{"title":175,"searchDepth":376,"depth":376,"links":377},2,[378,379,380,381,382],{"id":191,"depth":376,"text":194},{"id":234,"depth":376,"text":237},{"id":272,"depth":376,"text":275},{"id":310,"depth":376,"text":313},{"id":348,"depth":376,"text":351},"markdown","content:6.maps:_ai:rag.md","content","6.maps/_ai/rag.md","6.maps/_ai/rag","md",[390,394],{"_path":391,"title":392,"description":393},"/maps/_ai/prompt/team-based-instructions","Team based Instructions","为软件团队策划和共享指令（Curated shared instructions for software teams）",{"_path":395,"title":396,"description":397},"/maps/_ai/rag/on-device-info-retrieval","设备端信息检索","在用户设备上进行信息检索以保障隐私和提升效率。",1771264666067]