ntext Protocol）是 Anthropic 开源的标准协议，用于连接 AI 应用与外部系统，被誉为 AI 应用的 USB-C 接口。","_ai/mcp.md",{"type":183,"children":184,"toc":1140},"root",[185,194,200,214,220,225,250,256,261,295,302,308,356,361,367,378,416,421,427,432,438,467,478,484,490,495,528,533,539,544,600,606,611,617,622,640,646,804,817,823,829,834,839,850,856,899,905,1004,1009,1015,1048,1054,1064,1087,1096,1114,1120,1134],{"type":186,"tag":187,"props":188,"children":190},"element","h4",{"id":189},"mcp-是什么",[191],{"type":192,"value":193},"text","MCP 是什么？",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198],{"type":192,"value":199},"MCP 是 Model Context Protocol（模型上下文协议）的缩写，由 Anthropic 开源的一种标准协议，用于连接 AI 应用与外部系统。它就像 AI 应用的 USB-C 接口——USB-C 为电子设备提供了标准化的连接方式，而 MCP 为 AI 应用提供了标准化的方式来连接外部数据源、工具和工作流。",{"type":186,"tag":195,"props":201,"children":202},{},[203,205],{"type":192,"value":204},"见：",{"type":186,"tag":206,"props":207,"children":211},"a",{"href":208,"rel":209},"https://modelcontextprotocol.io/docs/getting-started/intro",[210],"nofollow",[212],{"type":192,"value":213},"MCP Introduction",{"type":186,"tag":187,"props":215,"children":217},{"id":216},"mcp-能解决什么问题",[218],{"type":192,"value":219},"MCP 能解决什么问题？",{"type":186,"tag":195,"props":221,"children":222},{},[223],{"type":192,"value":224},"AI 应用（如 Claude、ChatGPT）可以通过 MCP 访问本地文件、数据库、搜索引擎、计算器等外部资源，让 AI 从\"纯对话\"进化为\"能做事\"的智能助手。例如：",{"type":186,"tag":226,"props":227,"children":228},"ul",{},[229,235,240,245],{"type":186,"tag":230,"props":231,"children":232},"li",{},[233],{"type":192,"value":234},"个人助理可以访问你的 Google Calendar 和 Notion",{"type":186,"tag":230,"props":236,"children":237},{},[238],{"type":192,"value":239},"Claude Code 可以根据 Figma 设计直接生成 Web 应用",{"type":186,"tag":230,"props":241,"children":242},{},[243],{"type":192,"value":244},"企业聊天机器人能连接多个数据库进行数据分析",{"type":186,"tag":230,"props":246,"children":247},{},[248],{"type":192,"value":249},"AI 可以直接在 Blender 中创建 3D 设计并发送到 3D 打印机",{"type":186,"tag":187,"props":251,"children":253},{"id":252},"mcp-的价值分层",[254],{"type":192,"value":255},"MCP 的价值分层？",{"type":186,"tag":195,"props":257,"children":258},{},[259],{"type":192,"value":260},"对不同角色的价值各有不同：",{"type":186,"tag":226,"props":262,"children":263},{},[264,275,285],{"type":186,"tag":230,"props":265,"children":266},{},[267,273],{"type":186,"tag":268,"props":269,"children":270},"strong",{},[271],{"type":192,"value":272},"开发者",{"type":192,"value":274},"：降低构建/集成 AI 应用的开发时间和复杂度",{"type":186,"tag":230,"props":276,"children":277},{},[278,283],{"type":186,"tag":268,"props":279,"children":280},{},[281],{"type":192,"value":282},"AI 应用/Agent",{"type":192,"value":284},"：获得丰富的数据源和工具生态，增强能力",{"type":186,"tag":230,"props":286,"children":287},{},[288,293],{"type":186,"tag":268,"props":289,"children":290},{},[291],{"type":192,"value":292},"终端用户",{"type":192,"value":294},"：获得更智能、能访问个人数据并代行操作的 AI 体验",{"type":186,"tag":296,"props":297,"children":299},"h2",{"id":298},"tour",[300],{"type":192,"value":301},"Tour",{"type":186,"tag":296,"props":303,"children":305},{"id":304},"examples",[306],{"type":192,"value":307},"Examples",{"type":186,"tag":226,"props":309,"children":310},{},[311,332,344],{"type":186,"tag":230,"props":312,"children":313},{},[314,321,323,330],{"type":186,"tag":206,"props":315,"children":318},{"href":316,"rel":317},"https://github.com/eslint/rewrite/blob/main/packages/mcp/src/mcp-server.js",[210],[319],{"type":192,"value":320},"ESLint MCP",{"type":192,"value":322},"：ESLint MCP Server，Server 端直接调用 ",{"type":186,"tag":324,"props":325,"children":327},"code",{"className":326},[],[328],{"type":192,"value":329},"eslint ...",{"type":192,"value":331}," 来修复代码。",{"type":186,"tag":230,"props":333,"children":334},{},[335,342],{"type":186,"tag":206,"props":336,"children":339},{"href":337,"rel":338},"https://github.com/Lionad-Morotar/port-key/tree/main/packages/mcp",[210],[340],{"type":192,"value":341},"PortKey MCP",{"type":192,"value":343},"：根据项目名找一个端口号，功能简单，包含 Stdio、Streamable HTTP Server 及 Resource。",{"type":186,"tag":230,"props":345,"children":346},{},[347,354],{"type":186,"tag":206,"props":348,"children":351},{"href":349,"rel":350},"https://github.com/Panniantong/Agent-Reach",[210],[352],{"type":192,"value":353},"Agent Reach",{"type":192,"value":355},"：为 AI Agent 提供互联网访问能力的 MCP 工具脚手架，支持 Twitter、Reddit、YouTube、Bilibili、小红书等平台读取和搜索，零 API 费用",{"type":186,"tag":296,"props":357,"children":359},{"id":358},"工具",[360],{"type":192,"value":358},{"type":186,"tag":187,"props":362,"children":364},{"id":363},"mcp-inspector",[365],{"type":192,"value":366},"MCP Inspector",{"type":186,"tag":195,"props":368,"children":369},{},[370,376],{"type":186,"tag":206,"props":371,"children":374},{"href":372,"rel":373},"https://github.com/modelcontextprotocol/inspector",[210],[375],{"type":192,"value":366},{"type":192,"value":377}," 是用于测试和调试 MCP 服务器的开发者工具。",{"type":186,"tag":379,"props":380,"children":384},"pre",{"className":381,"code":382,"language":383,"meta":178,"style":178},"language-bash shiki shiki-themes material-theme-lighter github-light github-dark monokai","npx @modelcontextprotocol/inspector node build/index.js\n","bash",[385],{"type":186,"tag":324,"props":386,"children":387},{"__ignoreMap":178},[388],{"type":186,"tag":389,"props":390,"children":393},"span",{"class":391,"line":392},"line",1,[394,400,406,411],{"type":186,"tag":389,"props":395,"children":397},{"style":396},"--shiki-light:#E2931D;--shiki-default:#6F42C1;--shiki-dark:#B392F0;--shiki-sepia:#A6E22E",[398],{"type":192,"value":399},"npx",{"type":186,"tag":389,"props":401,"children":403},{"style":402},"--shiki-light:#91B859;--shiki-default:#032F62;--shiki-dark:#9ECBFF;--shiki-sepia:#E6DB74",[404],{"type":192,"value":405}," @modelcontextprotocol/inspector",{"type":186,"tag":389,"props":407,"children":408},{"style":402},[409],{"type":192,"value":410}," node",{"type":186,"tag":389,"props":412,"children":413},{"style":402},[414],{"type":192,"value":415}," build/index.js\n",{"type":186,"tag":296,"props":417,"children":419},{"id":418},"授权与安全",[420],{"type":192,"value":418},{"type":186,"tag":187,"props":422,"children":424},{"id":423},"mcp-授权机制基于-oauth-21",[425],{"type":192,"value":426},"MCP 授权机制基于 OAuth 2.1",{"type":186,"tag":195,"props":428,"children":429},{},[430],{"type":192,"value":431},"MCP 的授权架构建立在 OAuth 2.1 和 RFC 9728（OAuth 2.0 Protected Resource Metadata）标准之上。\n授权流程涉及四个核心角色：用户（User）、MCP 客户端（Client）、MCP 服务器（Resource Server）和授权服务器（Authorization Server）。\nMCP 服务器通过 Token Introspection（RFC 7662）验证访问令牌的有效性，确保只有持有有效令牌且受众（audience）匹配的请求才能访问受保护资源。",{"type":186,"tag":187,"props":433,"children":435},{"id":434},"mcp-服务器授权实现要点",[436],{"type":192,"value":437},"MCP 服务器授权实现要点",{"type":186,"tag":195,"props":439,"children":440},{},[441,443,449,451,457,459,465],{"type":192,"value":442},"TypeScript 实现使用 ",{"type":186,"tag":324,"props":444,"children":446},{"className":445},[],[447],{"type":192,"value":448},"@modelcontextprotocol/sdk/server/auth/router.js",{"type":192,"value":450}," 提供元数据端点，通过 ",{"type":186,"tag":324,"props":452,"children":454},{"className":453},[],[455],{"type":192,"value":456},"requireBearerAuth",{"type":192,"value":458}," 中间件保护 MCP 端点。\n需要实现 ",{"type":186,"tag":324,"props":460,"children":462},{"className":461},[],[463],{"type":192,"value":464},"verifyAccessToken",{"type":192,"value":466}," 函数进行令牌验证，包括调用授权服务器的 introspection 端点、验证令牌激活状态和受众匹配。",{"type":186,"tag":195,"props":468,"children":469},{},[470,471],{"type":192,"value":204},{"type":186,"tag":206,"props":472,"children":475},{"href":473,"rel":474},"https://modelcontextprotocol.io/docs/tutorials/security/authorization",[210],[476],{"type":192,"value":477},"MCP Authorization Tutorial",{"type":186,"tag":296,"props":479,"children":481},{"id":480},"tool-设计模式",[482],{"type":192,"value":483},"Tool 设计模式",{"type":186,"tag":187,"props":485,"children":487},{"id":486},"mcp-tool-设计的三维分类框架",[488],{"type":192,"value":489},"MCP Tool 设计的三维分类框架",{"type":186,"tag":195,"props":491,"children":492},{},[493],{"type":192,"value":494},"每个 MCP Tool 都可以用三个维度来定位，从而确定适用的设计模式：",{"type":186,"tag":226,"props":496,"children":497},{},[498,508,518],{"type":186,"tag":230,"props":499,"children":500},{},[501,506],{"type":186,"tag":268,"props":502,"children":503},{},[504],{"type":192,"value":505},"成熟度（Maturity）",{"type":192,"value":507},"：原子工具（单一操作）→ 编排工具（跨调用状态管理）",{"type":186,"tag":230,"props":509,"children":510},{},[511,516],{"type":186,"tag":268,"props":512,"children":513},{},[514],{"type":192,"value":515},"集成类型（Integration）",{"type":192,"value":517},"：API、数据库、文件系统、系统操作",{"type":186,"tag":230,"props":519,"children":520},{},[521,526],{"type":186,"tag":268,"props":522,"children":523},{},[524],{"type":192,"value":525},"访问模式（Access）",{"type":192,"value":527},"：同步、异步、流式、事件驱动",{"type":186,"tag":195,"props":529,"children":530},{},[531],{"type":192,"value":532},"这三个维度的组合决定了工具需要哪些设计模式。例如，数据库工具需要幂等操作模式，因为 Agent 会在超时后重试。",{"type":186,"tag":187,"props":534,"children":536},{"id":535},"agent-优先的设计原则",[537],{"type":192,"value":538},"Agent 优先的设计原则",{"type":186,"tag":195,"props":540,"children":541},{},[542],{"type":192,"value":543},"\"能工作\"不等于\"Agent 能用\"。Tool 设计必须面向 LLM 优化：",{"type":186,"tag":226,"props":545,"children":546},{},[547,557,590],{"type":186,"tag":230,"props":548,"children":549},{},[550,555],{"type":186,"tag":268,"props":551,"children":552},{},[553],{"type":192,"value":554},"描述清晰",{"type":192,"value":556},"：Tool 描述和参数名要便于 Agent 理解",{"type":186,"tag":230,"props":558,"children":559},{},[560,565,567,573,575,581,582,588],{"type":186,"tag":268,"props":561,"children":562},{},[563],{"type":192,"value":564},"参数强制转换（Parameter Coercion）",{"type":192,"value":566},"：接受 ",{"type":186,"tag":324,"props":568,"children":570},{"className":569},[],[571],{"type":192,"value":572},"\"2024-01-15\"",{"type":192,"value":574},"、",{"type":186,"tag":324,"props":576,"children":578},{"className":577},[],[579],{"type":192,"value":580},"\"January 15\"",{"type":192,"value":574},{"type":186,"tag":324,"props":583,"children":585},{"className":584},[],[586],{"type":192,"value":587},"\"yesterday\"",{"type":192,"value":589}," 等多种格式，内部统一归一化",{"type":186,"tag":230,"props":591,"children":592},{},[593,598],{"type":186,"tag":268,"props":594,"children":595},{},[596],{"type":192,"value":597},"错误引导恢复",{"type":192,"value":599},"：不要只返回 429，而是告诉 Agent \"速率受限，30 秒后重试或把批次大小减到 50\"",{"type":186,"tag":187,"props":601,"children":603},{"id":602},"安全边界prompt-表达意图代码强制执行规则",[604],{"type":192,"value":605},"安全边界：Prompt 表达意图，代码强制执行规则",{"type":186,"tag":195,"props":607,"children":608},{},[609],{"type":192,"value":610},"永远不要信任 Agent 来执行安全控制。授权和密钥必须通过服务端上下文传递（Context Injection 模式），绝不能经过 LLM。",{"type":186,"tag":187,"props":612,"children":614},{"id":613},"tool-组合原则",[615],{"type":192,"value":616},"Tool 组合原则",{"type":186,"tag":195,"props":618,"children":619},{},[620],{"type":192,"value":621},"Tool 应该像 Unix 管道一样良好组合，而非像命令链一样互相依赖。这意味着：",{"type":186,"tag":226,"props":623,"children":624},{},[625,630,635],{"type":186,"tag":230,"props":626,"children":627},{},[628],{"type":192,"value":629},"一致的响应格式，便于一个 Tool 的输出作为另一个的输入",{"type":186,"tag":230,"props":631,"children":632},{},[633],{"type":192,"value":634},"支持批处理，避免 Agent 逐个循环",{"type":186,"tag":230,"props":636,"children":637},{},[638],{"type":192,"value":639},"提供多层次的抽象，让 Agent 根据任务选择合适的粒度",{"type":186,"tag":187,"props":641,"children":643},{"id":642},"_54-个设计模式的-10-个分类",[644],{"type":192,"value":645},"54 个设计模式的 10 个分类",{"type":186,"tag":647,"props":648,"children":649},"table",{},[650,669],{"type":186,"tag":651,"props":652,"children":653},"thead",{},[654],{"type":186,"tag":655,"props":656,"children":657},"tr",{},[658,664],{"type":186,"tag":659,"props":660,"children":661},"th",{},[662],{"type":192,"value":663},"分类",{"type":186,"tag":659,"props":665,"children":666},{},[667],{"type":192,"value":668},"核心问题",{"type":186,"tag":670,"props":671,"children":672},"tbody",{},[673,687,700,713,726,739,752,765,778,791],{"type":186,"tag":655,"props":674,"children":675},{},[676,682],{"type":186,"tag":677,"props":678,"children":679},"td",{},[680],{"type":192,"value":681},"Tool Types",{"type":186,"tag":677,"props":683,"children":684},{},[685],{"type":192,"value":686},"Query、Command 还是 Discovery？",{"type":186,"tag":655,"props":688,"children":689},{},[690,695],{"type":186,"tag":677,"props":691,"children":692},{},[693],{"type":192,"value":694},"Tool Interface",{"type":186,"tag":677,"props":696,"children":697},{},[698],{"type":192,"value":699},"Agent 如何理解和调用？",{"type":186,"tag":655,"props":701,"children":702},{},[703,708],{"type":186,"tag":677,"props":704,"children":705},{},[706],{"type":192,"value":707},"Tool Discovery",{"type":186,"tag":677,"props":709,"children":710},{},[711],{"type":192,"value":712},"Agent 如何找到合适的 Tool？",{"type":186,"tag":655,"props":714,"children":715},{},[716,721],{"type":186,"tag":677,"props":717,"children":718},{},[719],{"type":192,"value":720},"Tool Composition",{"type":186,"tag":677,"props":722,"children":723},{},[724],{"type":192,"value":725},"是否应该捆绑多个操作？",{"type":186,"tag":655,"props":727,"children":728},{},[729,734],{"type":186,"tag":677,"props":730,"children":731},{},[732],{"type":192,"value":733},"Tool Execution",{"type":186,"tag":677,"props":735,"children":736},{},[737],{"type":192,"value":738},"同步、异步还是事务性？",{"type":186,"tag":655,"props":740,"children":741},{},[742,747],{"type":186,"tag":677,"props":743,"children":744},{},[745],{"type":192,"value":746},"Tool Response",{"type":186,"tag":677,"props":748,"children":749},{},[750],{"type":192,"value":751},"结果应该是什么样？",{"type":186,"tag":655,"props":753,"children":754},{},[755,760],{"type":186,"tag":677,"props":756,"children":757},{},[758],{"type":192,"value":759},"Tool Context",{"type":186,"tag":677,"props":761,"children":762},{},[763],{"type":192,"value":764},"身份和状态如何管理？",{"type":186,"tag":655,"props":766,"children":767},{},[768,773],{"type":186,"tag":677,"props":769,"children":770},{},[771],{"type":192,"value":772},"Tool Resilience",{"type":186,"tag":677,"props":774,"children":775},{},[776],{"type":192,"value":777},"如何从失败中恢复？",{"type":186,"tag":655,"props":779,"children":780},{},[781,786],{"type":186,"tag":677,"props":782,"children":783},{},[784],{"type":192,"value":785},"Tool Security",{"type":186,"tag":677,"props":787,"children":788},{},[789],{"type":192,"value":790},"如何控制访问？",{"type":186,"tag":655,"props":792,"children":793},{},[794,799],{"type":186,"tag":677,"props":795,"children":796},{},[797],{"type":192,"value":798},"Integration",{"type":186,"tag":677,"props":800,"children":801},{},[802],{"type":192,"value":803},"如何连接外部系统？",{"type":186,"tag":195,"props":805,"children":806},{},[807,808,815],{"type":192,"value":204},{"type":186,"tag":206,"props":809,"children":812},{"href":810,"rel":811},"https://www.arcade.dev/blog/mcp-tool-patterns",[210],[813],{"type":192,"value":814},"54 Patterns for Building Better MCP Tools",{"type":192,"value":816},"：Arcade 团队基于 8000+ 工具实践总结的设计模式",{"type":186,"tag":296,"props":818,"children":820},{"id":819},"webmcp",[821],{"type":192,"value":822},"WebMCP",{"type":186,"tag":187,"props":824,"children":826},{"id":825},"webmcp-是什么",[827],{"type":192,"value":828},"WebMCP 是什么？",{"type":186,"tag":195,"props":830,"children":831},{},[832],{"type":192,"value":833},"WebMCP 是 W3C Web Machine Learning 工作组的一个提案，由 Google 和 Microsoft 联合推动。\n它允许网页通过 JavaScript API 向 AI Agent 注册客户端工具（Tools），让网页成为\"在客户端实现工具的 MCP Server\"。",{"type":186,"tag":195,"props":835,"children":836},{},[837],{"type":192,"value":838},"与后端 MCP Server 不同，WebMCP 的工具在浏览器中执行，使 Agent 能够通过应用控制的 UI 与网页交互，\n提供共享上下文给应用、Agent 和用户三方。",{"type":186,"tag":195,"props":840,"children":841},{},[842,843],{"type":192,"value":204},{"type":186,"tag":206,"props":844,"children":847},{"href":845,"rel":846},"https://github.com/webmachinelearning/webmcp",[210],[848],{"type":192,"value":849},"WebMCP Proposal",{"type":186,"tag":187,"props":851,"children":853},{"id":852},"webmcp-的核心价值",[854],{"type":192,"value":855},"WebMCP 的核心价值",{"type":186,"tag":226,"props":857,"children":858},{},[859,869,879,889],{"type":186,"tag":230,"props":860,"children":861},{},[862,867],{"type":186,"tag":268,"props":863,"children":864},{},[865],{"type":192,"value":866},"复用现有业务逻辑",{"type":192,"value":868},"：企业无需重构产品来适配特定 Agent 的 API，可直接复用前端代码",{"type":186,"tag":230,"props":870,"children":871},{},[872,877],{"type":186,"tag":268,"props":873,"children":874},{},[875],{"type":192,"value":876},"人机协作（Human-in-the-loop）",{"type":192,"value":878},"：用户和 Agent 在同一界面协作，共享上下文",{"type":186,"tag":230,"props":880,"children":881},{},[882,887],{"type":186,"tag":268,"props":883,"children":884},{},[885],{"type":192,"value":886},"统一服务入口",{"type":192,"value":888},"：人类使用的 Web 界面和 Agent 访问的工具来自同一源头，避免服务碎片化",{"type":186,"tag":230,"props":890,"children":891},{},[892,897],{"type":186,"tag":268,"props":893,"children":894},{},[895],{"type":192,"value":896},"提升可访问性",{"type":192,"value":898},"：为辅助技术提供标准化的功能访问方式，超越传统无障碍树",{"type":186,"tag":187,"props":900,"children":902},{"id":901},"webmcp-与-mcp-的关系",[903],{"type":192,"value":904},"WebMCP 与 MCP 的关系",{"type":186,"tag":647,"props":906,"children":907},{},[908,929],{"type":186,"tag":651,"props":909,"children":910},{},[911],{"type":186,"tag":655,"props":912,"children":913},{},[914,919,924],{"type":186,"tag":659,"props":915,"children":916},{},[917],{"type":192,"value":918},"维度",{"type":186,"tag":659,"props":920,"children":921},{},[922],{"type":192,"value":923},"MCP（后端集成）",{"type":186,"tag":659,"props":925,"children":926},{},[927],{"type":192,"value":928},"WebMCP（客户端集成）",{"type":186,"tag":670,"props":930,"children":931},{},[932,950,968,986],{"type":186,"tag":655,"props":933,"children":934},{},[935,940,945],{"type":186,"tag":677,"props":936,"children":937},{},[938],{"type":192,"value":939},"执行位置",{"type":186,"tag":677,"props":941,"children":942},{},[943],{"type":192,"value":944},"服务器",{"type":186,"tag":677,"props":946,"children":947},{},[948],{"type":192,"value":949},"浏览器",{"type":186,"tag":655,"props":951,"children":952},{},[953,958,963],{"type":186,"tag":677,"props":954,"children":955},{},[956],{"type":192,"value":957},"交互方式",{"type":186,"tag":677,"props":959,"children":960},{},[961],{"type":192,"value":962},"直接 API 调用",{"type":186,"tag":677,"props":964,"children":965},{},[966],{"type":192,"value":967},"通过应用控制的 UI",{"type":186,"tag":655,"props":969,"children":970},{},[971,976,981],{"type":186,"tag":677,"props":972,"children":973},{},[974],{"type":192,"value":975},"用户参与",{"type":186,"tag":677,"props":977,"children":978},{},[979],{"type":192,"value":980},"完全委托给 Agent",{"type":186,"tag":677,"props":982,"children":983},{},[984],{"type":192,"value":985},"人机协作",{"type":186,"tag":655,"props":987,"children":988},{},[989,994,999],{"type":186,"tag":677,"props":990,"children":991},{},[992],{"type":192,"value":993},"适用场景",{"type":186,"tag":677,"props":995,"children":996},{},[997],{"type":192,"value":998},"完全自主的 Agent",{"type":186,"tag":677,"props":1000,"children":1001},{},[1002],{"type":192,"value":1003},"有人在环的本地浏览器工作流",{"type":186,"tag":195,"props":1005,"children":1006},{},[1007],{"type":192,"value":1008},"WebMCP 不是 MCP 的替代品，而是互补方案。它特别适合需要用户参与的场景，如购物、创意设计、代码审查等。",{"type":186,"tag":187,"props":1010,"children":1012},{"id":1011},"webmcp-的使用场景示例",[1013],{"type":192,"value":1014},"WebMCP 的使用场景示例",{"type":186,"tag":226,"props":1016,"children":1017},{},[1018,1028,1038],{"type":186,"tag":230,"props":1019,"children":1020},{},[1021,1026],{"type":186,"tag":268,"props":1022,"children":1023},{},[1024],{"type":192,"value":1025},"创意设计",{"type":192,"value":1027},"：用户在图形设计平台与 Agent 协作，Agent 帮助筛选模板、修改设计、批量生成变体",{"type":186,"tag":230,"props":1029,"children":1030},{},[1031,1036],{"type":186,"tag":268,"props":1032,"children":1033},{},[1034],{"type":192,"value":1035},"购物助手",{"type":192,"value":1037},"：Agent 帮助筛选商品、比较选项，但用户保持最终决策权",{"type":186,"tag":230,"props":1039,"children":1040},{},[1041,1046],{"type":186,"tag":268,"props":1042,"children":1043},{},[1044],{"type":192,"value":1045},"代码审查",{"type":192,"value":1047},"：Agent 通过专用工具获取构建状态、添加建议修改，用户审查后接受或拒绝",{"type":186,"tag":187,"props":1049,"children":1051},{"id":1050},"webmcp-的目标与非目标",[1052],{"ty