源的标准协议，用于连接 AI 应用与外部系统，被誉为 AI 应用的 USB-C 接口。",{"type":182,"children":183,"toc":427},"root",[184,193,199,213,219,224,249,255,260,294,301,307,343,348,354,365,403,409,421],{"type":185,"tag":186,"props":187,"children":189},"element","h4",{"id":188},"mcp-是什么",[190],{"type":191,"value":192},"text","MCP 是什么？",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"MCP 是 Model Context Protocol（模型上下文协议）的缩写，由 Anthropic 开源的一种标准协议，用于连接 AI 应用与外部系统。它就像 AI 应用的 USB-C 接口——USB-C 为电子设备提供了标准化的连接方式，而 MCP 为 AI 应用提供了标准化的方式来连接外部数据源、工具和工作流。",{"type":185,"tag":194,"props":200,"children":201},{},[202,204],{"type":191,"value":203},"见：",{"type":185,"tag":205,"props":206,"children":210},"a",{"href":207,"rel":208},"https://modelcontextprotocol.io/docs/getting-started/intro",[209],"nofollow",[211],{"type":191,"value":212},"MCP Introduction",{"type":185,"tag":186,"props":214,"children":216},{"id":215},"mcp-能解决什么问题",[217],{"type":191,"value":218},"MCP 能解决什么问题？",{"type":185,"tag":194,"props":220,"children":221},{},[222],{"type":191,"value":223},"AI 应用（如 Claude、ChatGPT）可以通过 MCP 访问本地文件、数据库、搜索引擎、计算器等外部资源，让 AI 从\"纯对话\"进化为\"能做事\"的智能助手。例如：",{"type":185,"tag":225,"props":226,"children":227},"ul",{},[228,234,239,244],{"type":185,"tag":229,"props":230,"children":231},"li",{},[232],{"type":191,"value":233},"个人助理可以访问你的 Google Calendar 和 Notion",{"type":185,"tag":229,"props":235,"children":236},{},[237],{"type":191,"value":238},"Claude Code 可以根据 Figma 设计直接生成 Web 应用",{"type":185,"tag":229,"props":240,"children":241},{},[242],{"type":191,"value":243},"企业聊天机器人能连接多个数据库进行数据分析",{"type":185,"tag":229,"props":245,"children":246},{},[247],{"type":191,"value":248},"AI 可以直接在 Blender 中创建 3D 设计并发送到 3D 打印机",{"type":185,"tag":186,"props":250,"children":252},{"id":251},"mcp-的价值分层",[253],{"type":191,"value":254},"MCP 的价值分层？",{"type":185,"tag":194,"props":256,"children":257},{},[258],{"type":191,"value":259},"对不同角色的价值各有不同：",{"type":185,"tag":225,"props":261,"children":262},{},[263,274,284],{"type":185,"tag":229,"props":264,"children":265},{},[266,272],{"type":185,"tag":267,"props":268,"children":269},"strong",{},[270],{"type":191,"value":271},"开发者",{"type":191,"value":273},"：降低构建/集成 AI 应用的开发时间和复杂度",{"type":185,"tag":229,"props":275,"children":276},{},[277,282],{"type":185,"tag":267,"props":278,"children":279},{},[280],{"type":191,"value":281},"AI 应用/Agent",{"type":191,"value":283},"：获得丰富的数据源和工具生态，增强能力",{"type":185,"tag":229,"props":285,"children":286},{},[287,292],{"type":185,"tag":267,"props":288,"children":289},{},[290],{"type":191,"value":291},"终端用户",{"type":191,"value":293},"：获得更智能、能访问个人数据并代行操作的 AI 体验",{"type":185,"tag":295,"props":296,"children":298},"h2",{"id":297},"tour",[299],{"type":191,"value":300},"Tour",{"type":185,"tag":295,"props":302,"children":304},{"id":303},"examples",[305],{"type":191,"value":306},"Examples",{"type":185,"tag":225,"props":308,"children":309},{},[310,331],{"type":185,"tag":229,"props":311,"children":312},{},[313,320,322,329],{"type":185,"tag":205,"props":314,"children":317},{"href":315,"rel":316},"https://github.com/eslint/rewrite/blob/main/packages/mcp/src/mcp-server.js",[209],[318],{"type":191,"value":319},"ESLint MCP",{"type":191,"value":321},"：ESLint MCP Server，Server 端直接调用 ",{"type":185,"tag":323,"props":324,"children":326},"code",{"className":325},[],[327],{"type":191,"value":328},"eslint ...",{"type":191,"value":330}," 来修复代码。",{"type":185,"tag":229,"props":332,"children":333},{},[334,341],{"type":185,"tag":205,"props":335,"children":338},{"href":336,"rel":337},"https://github.com/Lionad-Morotar/port-key/tree/main/packages/mcp",[209],[339],{"type":191,"value":340},"PortKey MCP",{"type":191,"value":342},"：根据项目名找一个端口号，功能简单，包含 Stdio、Streamable HTTP Server 及 Resource。",{"type":185,"tag":295,"props":344,"children":346},{"id":345},"工具",[347],{"type":191,"value":345},{"type":185,"tag":186,"props":349,"children":351},{"id":350},"mcp-inspector",[352],{"type":191,"value":353},"MCP Inspector",{"type":185,"tag":194,"props":355,"chi