otocol）是 Anthropic 开源的标准协议，用于连接 AI 应用与外部系统，被誉为 AI 应用的 USB-C 接口。","_ai/mcp.md",{"type":183,"children":184,"toc":502},"root",[185,194,200,214,220,225,250,256,261,295,302,308,344,349,355,366,404,409,415,420,426,455,466,472,496],{"type":186,"tag":187,"props":188,"children":190},"element","h4",{"id":189},"mcp-是什么",[191],{"type":192,"value":193},"text","MCP 是什么？",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198],{"type":192,"value":199},"MCP 是 Model Context Protocol（模型上下文协议）的缩写，由 Anthropic 开源的一种标准协议，用于连接 AI 应用与外部系统。它就像 AI 应用的 USB-C 接口——USB-C 为电子设备提供了标准化的连接方式，而 MCP 为 AI 应用提供了标准化的方式来连接外部数据源、工具和工作流。",{"type":186,"tag":195,"props":201,"children":202},{},[203,205],{"type":192,"value":204},"见：",{"type":186,"tag":206,"props":207,"children":211},"a",{"href":208,"rel":209},"https://modelcontextprotocol.io/docs/getting-started/intro",[210],"nofollow",[212],{"type":192,"value":213},"MCP Introduction",{"type":186,"tag":187,"props":215,"children":217},{"id":216},"mcp-能解决什么问题",[218],{"type":192,"value":219},"MCP 能解决什么问题？",{"type":186,"tag":195,"props":221,"children":222},{},[223],{"type":192,"value":224},"AI 应用（如 Claude、ChatGPT）可以通过 MCP 访问本地文件、数据库、搜索引擎、计算器等外部资源，让 AI 从\"纯对话\"进化为\"能做事\"的智能助手。例如：",{"type":186,"tag":226,"props":227,"children":228},"ul",{},[229,235,240,245],{"type":186,"tag":230,"props":231,"children":232},"li",{},[233],{"type":192,"value":234},"个人助理可以访问你的 Google Calendar 和 Notion",{"type":186,"tag":230,"props":236,"children":237},{},[238],{"type":192,"value":239},"Claude Code 可以根据 Figma 设计直接生成 Web 应用",{"type":186,"tag":230,"props":241,"children":242},{},[243],{"type":192,"value":244},"企业聊天机器人能连接多个数据库进行数据分析",{"type":186,"tag":230,"props":246,"children":247},{},[248],{"type":192,"value":249},"AI 可以直接在 Blender 中创建 3D 设计并发送到 3D 打印机",{"type":186,"tag":187,"props":251,"children":253},{"id":252},"mcp-的价值分层",[254],{"type":192,"value":255},"MCP 的价值分层？",{"type":186,"tag":195,"props":257,"children":258},{},[259],{"type":192,"value":260},"对不同角色的价值各有不同：",{"type":186,"tag":226,"props":262,"children":263},{},[264,275,285],{"type":186,"tag":230,"props":265,"children":266},{},[267,273],{"type":186,"tag":268,"props":269,"children":270},"strong",{},[271],{"type":192,"value":272},"开发者",{"type":192,"value":274},"：降低构建/集成 AI 应用的开发时间和复杂度",{"type":186,"tag":230,"props":276,"children":277},{},[278,283],{"type":186,"tag":268,"props":279,"children":280},{},[281],{"type":192,"value":282},"AI 应用/Agent",{"type":192,"value":284},"：获得丰富的数据源和工具生态，增强能力",{"type":186,"tag":230,"props":286,"children":287},{},[288,293],{"type":186,"tag":268,"props":289,"children":290},{},[291],{"type":192,"value":292},"终端用户",{"type":192,"value":294},"：获得更智能、能访问个人数据并代行操作的 AI 体验",{"type":186,"tag":296,"props":297,"children":299},"h2",{"id":298},"tour",[300],{"type":192,"value":301},"Tour",{"type":186,"tag":296,"props":303,"children":305},{"id":304},"examples",[306],{"type":192,"value":307},"Examples",{"type":186,"tag":226,"props":309,"children":310},{},[311,332],{"type":186,"tag":230,"props":312,"children":313},{},[314,321,323,330],{"type":186,"tag":206,"props":315,"children":318},{"href":316,"rel":317},"https://github.com/eslint/rewrite/blob/main/packages/mcp/src/mcp-server.js",[210],[319],{"type":192,"value":320},"ESLint MCP",{"type":192,"value":322},"：ESLint MCP Server，Server 端直接调用 ",{"type":186,"tag":324,"props":325,"children":327},"code",{"className":326},[],[328],{"type":192,"value":329},"eslint ...",{"type":192,"value":331}," 来修复代码。",{"type":186,"tag":230,"props":333,"children":334},{},[335,342],{"type":186,"tag":206,"props":336,"children":339},{"href":337,"rel":338},"https://github.com/Lionad-Morotar/port-key/tree/main/packages/mcp",[210],[340],{"type":192,"value":341},"PortKey MCP",{"type":192,"value":343},"：根据项目名找一个端口号，功能简单，包含 Stdio、Streamable HTTP Server 及 Resource。",{"type":186,"tag":296,"props":345,"children":347},{"id":346},"工具",[348],{"type":192,"value":346},{"type":186,"tag":187,"props":350,"children":352},{"id":351},"mcp-inspector",[353],{"type":192,"value":354},"MCP Inspector",{"type":186,"tag":195,"props":356,"children":357},{},[358,364],{"type":186,"tag":206,"props":359,"children":362},{"href":360,"rel":361},"https://github.com/modelcontextprotocol/inspector",[210],[363],{"type":192,"value":354},{"type":192,"value":365}," 是用于测试和调试 MCP 服务器的开发者工具。",{"type":186,"tag":367,"props":368,"children":372},"pre",{"className":369,"code":370,"language":371,"meta":178,"style":178},"language-bash shiki shiki-themes material-theme-lighter github-light github-dark monokai","npx @modelcontextprotocol/inspector node build/index.js\n","bash",[373],{"type":186,"tag":324,"props":374,"children":375},{"__ignoreMap":178},[376],{"type":186,"tag":377,"props":378,"children":381},"span",{"class":379,"line":380},"line",1,[382,388,394,399],{"type":186,"tag":377,"props":383,"children":385},{"style":384},"--shiki-light:#E2931D;--shiki-default:#6F42C1;--shiki-dark:#B392F0;--shiki-sepia:#A6E22E",[386],{"type":192,"value":387},"npx",{"type":186,"tag":377,"props":389,"children":391},{"style":390},"--shiki-light:#91B859;--shiki-default:#032F62;--shiki-dark:#9ECBFF;--shiki-sepia:#E6DB74",[392],{"type":192,"value":393}," @modelcontextprotocol/inspector",{"type":186,"tag":377,"props":395,"children":396},{"style":390},[397],{"type":192,"value":398}," node",{"type":186,"tag":377,"props":400,"children":401},{"style":390},[402],{"type":192,"value":403}," build/index.js\n",{"type":186,"tag":296,"props":405,"children":407},{"id":406},"授权与安全",[408],{"type":192,"value":406},{"type":186,"tag":187,"props":410,"children":412},{"id":411},"mcp-授权机制基于-oauth-21",[413],{"type":192,"value":414},"MCP 授权机制基于 OAuth 2.1",{"type":186,"tag":195,"props":416,"children":417},{},[418],{"type":192,"value":419},"MCP 的授权架构建立在 OAuth 2.1 和 RFC 9728（OAuth 2.0 Protected Resource Metadata）标准之上。\n授权流程涉及四个核心角色：用户（User）、MCP 客户端（Client）、MCP 服务器（Resource Server）和授权服务器（Authorization Server）。\nMCP 服务器通过 Token Introspection（RFC 7662）验证访问令牌的有效性，确保只有持有有效令牌且受众（audience）匹配的请求才能访问受保护资源。",{"type":186,"tag":187,"props":421,"children":423},{"id":422},"mcp-服务器授权实现要点",[424],{"type":192,"value":425},"MCP 服务器授权实现要点",{"type":186,"tag":195,"props":427,"children":428},{},[429,431,437,439,445,447,453],{"type":192,"value":430},"TypeScript 实现使用 ",{"type":186,"tag":324,"props":432,"children":434},{"className":433},[],[435],{"type":192,"value":436},"@modelcontextprotocol/sdk/server/auth/router.js",{"type":192,"value":438}," 提供元数据端点，通过 ",{"type":186,"tag":324,"props":440,"children":442},{"className":441},[],[443],{"type":192,"value":444},"requireBearerAuth",{"type":192,"value":446}," 中间件保护 MCP 端点。\n需要实现 ",{"type":186,"tag":324,"props":448,"children":450},{"className":449},[],[451],{"type":192,"value":452},"verifyAccessToken",{"type":192,"value":454}," 函数进行令牌验证，包括调用授权服务器的 introspection 端点、验证令牌激活状态和受众匹配。",{"type":186,"tag":195,"props":456,"children":457},{},[458,459],{"type":192,"value":204},{"type":186,"tag":206,"props":460,"children":463},{"href":461,"rel":462},"https://modelcontextprotocol.io/docs/tutorials/security/authorization",[210],[464],{"type":192,"value":465},"MCP Authorization Tutorial",{"type":186,"tag":296,"props":467,"children":469},{"id":468},"domain",[470],{"type":192,"value":471},"Domain",{"type":186,"tag":226,"props":473,"children":474},{},[475,484],{"type":186,"tag":230,"props":476,"children":477},{},[478],{"type":186,"tag":206,"props":479,"children":481},{"href":480},"/maps/_ai/mcp/native-api-to-mcp",[482],{"type":192,"value":483},"Native API to MCP",{"type":186,"tag":230,"props":485,"children":486},{},[487,494],{"type":186,"tag":206,"props":488,"children":491},{"href":489,"rel":490},"https://github.com/webmachinelearning/webmcp",[210],[492],{"type":192,"value":493},"WebMCP",{"type":192,"value":495}," - W3C 提案，允许网页向 AI 代理注册客户端工具（Google & Microsoft 联合推动）",{"type":186,"tag":497,"props":498,"children":499},"style",{},[500],{"type":192,"value":501},"html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font