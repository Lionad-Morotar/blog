ren":183,"toc":312},"root",[184,193,199,213,219,224,249,258,264,269,303],{"type":185,"tag":186,"props":187,"children":189},"element","h4",{"id":188},"mcp-是什么",[190],{"type":191,"value":192},"text","MCP 是什么？",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"MCP 是 Model Context Protocol（模型上下文协议）的缩写，由 Anthropic 开源的一种标准协议，用于连接 AI 应用与外部系统。它就像 AI 应用的 USB-C 接口——USB-C 为电子设备提供了标准化的连接方式，而 MCP 为 AI 应用提供了标准化的方式来连接外部数据源、工具和工作流。",{"type":185,"tag":194,"props":200,"children":201},{},[202,204],{"type":191,"value":203},"见：",{"type":185,"tag":205,"props":206,"children":210},"a",{"href":207,"rel":208},"https://modelcontextprotocol.io/docs/getting-started/intro",[209],"nofollow",[211],{"type":191,"value":212},"MCP 官方文档",{"type":185,"tag":186,"props":214,"children":216},{"id":215},"mcp-能解决什么问题",[217],{"type":191,"value":218},"MCP 能解决什么问题？",{"type":185,"tag":194,"props":220,"children":221},{},[222],{"type":191,"value":223},"AI 应用（如 Claude、ChatGPT）可以通过 MCP 访问本地文件、数据库、搜索引擎、计算器等外部资源，让 AI 从\"纯对话\"进化为\"能做事\"的智能助手。例如：",{"type":185,"tag":225,"props":226,"children":227},"ul",{},[228,234,239,244],{"type":185,"tag":229,"props":230,"children":231},"li",{},[232],{"type":191,"value":233},"个人助理可以访问你的 Google Calendar 和 Notion",{"type":185,"tag":229,"props":235,"children":236},{},[237],{"type":191,"value":238},"Claude Code 可以根据 Figma 设计直接生成 Web 应用",{"type":185,"tag":229,"props":240,"children":241},{},[242],{"type":191,"value":243},"企业聊天机器人能连接多个数据库进行数据分析",{"type":185,"tag":229,"props":245,"children":246},{},[247],{"type":191,"value":248},"AI 可以直接在 Blender 中创建 3D 设计并发送到 3D 打印机",{"type":185,"tag":194,"props":250,"children":251},{},[252,253],{"type":191,"value":203},{"type":185,"tag":205,"props":254,"children":256},{"href":207,"rel":255},[209],[257],{"type":191,"value":212},{"type":185,"tag":186,"props":259,"children":261},{"id":260},"mcp-的价值分层",[262],{"type":191,"value":263},"MCP 的价值分层？",{"type":185,"tag":194,"props":265,"children":266},{},[267],{"type":191,"value":268},"对不同角色的价值各有不同：",{"type":185,"tag":225,"props":270,"children":271},{},[272,283,293],{"type":185,"tag":229,"props":273,"children":274},{},[275,281],{"type":185,"tag":276,"props":277,"children":278},"strong",{},[279],{"type":191,"value":280},"开发者",{"type":191,"value":282},"：降低构建/集成 AI 应用的开发时间和复杂度",{"type":185,"tag":229,"props":284,"children":285},{},[286,291],{"type":185,"tag":276,"props":287,"children":288},{},[289],{"type":191,"value":290},"AI 应用/Agent",{"type":191,"value":292},"：获得丰富的数据源和工具生态，增强能力",{"type":185,"tag":229,"props":294,"children":295},{},[296,301],{"type":185,"tag":276,"props":297,"children":298},{},[299],{"type":191,"value":300},"终端用户",{"type":191,"value":302},"：获得更智能、能访问个人数据并代行操作的 AI 体验",{"type":185,"tag":194,"props":304,"children":305},{},[306,307],{"type":191,"value":203},{"type":185,"tag":205,"props":308,"children":310},{"href":207,"rel":309},[209],[311],{"type":191,"value":212},{"title":178,"searchDepth":313,"depth":313,"links":314},2,[],"markdown","content:6.maps:_ai:mcp.md","content","6.maps/_ai/mcp.md","6.maps/_ai/mcp","md",[322,325],{"_path":323,"title":324,"description":178},"/maps/_ai/llm/structured-output","结构化输出",{"_path":326,"title":327,"description":328},"/maps/_ai/mcp/mcp","Model Context Protocol","MCP（Model Context Protocol）是一种用于管理和优化大型语言模型（LLM）上下文信息的协议，旨在提升模型在处理复杂任务时的效率和准确性。",1771304555091]