[{"data":1,"prerenderedAt":1199},["ShallowReactive",2],{"navigation":3,"/maps/_ai/mcp/native-api-to-mcp":170,"/maps/_ai/mcp/native-api-to-mcp-surround":1190},[4,35,92,98,125,131,155,161],{"title":5,"_path":6,"children":7},"心流思绪 / Heart Flows","/flows",[8,11,14,17,20,23,26,29,32],{"title":9,"_path":10},"📕 狮子的书单推荐","/flows/books",{"title":12,"_path":13},"🚝 四十二篇系列","/flows/forty-two",{"title":15,"_path":16},"🌃 长夜梦","/flows/long-night-dream",{"title":18,"_path":19},"🌌 万物联结与幸福感","/flows/everything",{"title":21,"_path":22},"⌛ 偷取时间","/flows/stealing-time-from-god",{"title":24,"_path":25},"🌆 表达和孤独","/flows/expression-and-loneliness",{"title":27,"_path":28},"🌧️ 我的腼腆","/flows/shy",{"title":30,"_path":31},"🥛 新工作，喝新饮料","/flows/drinking-while-thinking",{"title":33,"_path":34},"📝 心流归档","/flows/archive",{"title":36,"_path":37,"children":38},"技术博客 / Coder","/articles",[39,41,44,47,50,53,56,59,62,65,68,71,74,77,80,83,86,89],{"title":40,"_path":37},"🦁 欢迎",{"title":42,"_path":43},"📦 一个简单有效的端口命名策略：","/articles/simple-naming-method",{"title":45,"_path":46},"🌪️ Tailwind v4 如何兼容预处理器","/articles/tailwind4-with-sass",{"title":48,"_path":49},"🥞 在 tailwind 中使用现代化 CSS Layers","/articles/tailwind-sass-and-css-layer",{"title":51,"_path":52},"💻 本地部署 Qwen 翻译网页","/articles/local-translator",{"title":54,"_path":55},"🧊 模板解析器轻考古","/articles/micro-templating",{"title":57,"_path":58},"Ⓜ️ Mini CSS Parser","/articles/mini-css-parser",{"title":60,"_path":61},"🚩 向AI咨询前端问题","/articles/use-gpt-learn-complex-frontend",{"title":63,"_path":64},"⛸️ 怎样定制复杂组件的自定义滚动条？","/articles/use-scrollbars",{"title":66,"_path":67},"⚖️ 统一多组件库的层叠顺序","/articles/zindex-manager",{"title":69,"_path":70},"🕷️ 滑动验证码破解思路","/articles/crack-the-slider",{"title":72,"_path":73},"🌟 探秘 CSS 光影效果","/articles/css-light-travel",{"title":75,"_path":76},"🍲 设计模式与 JS 魔法锅","/articles/design-patterns-and-js-magic-pot",{"title":78,"_path":79},"🌐 Anysort：灵活、优雅的多属性排序","/articles/anysort-2th",{"title":81,"_path":82},"💫 CSS 幻术 | 抗锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133,"children":134},"造物 / Make","/tools",[135,137,140,143,146,149,152],{"title":136,"_path":133},"🧰 工具收集",{"title":138,"_path":139},"📕 博客","/tools/blog",{"title":141,"_path":142},"🥥 Coconut","/tools/coconut",{"title":144,"_path":145},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":147,"_path":148},"🌐 AnySort","/tools/anysort",{"title":150,"_path":151},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":153,"_path":154},"👓 Crapto","/tools/crypto-inline",{"title":156,"_path":157,"children":158},"我 / About","/hire",[159],{"title":160,"_path":157},"📬 技术简历",{"title":162,"_path":163,"children":164},"En","/en",[165],{"title":166,"_path":167,"children":168},"🦁 Welcome","/en/articles",[169],{"title":166,"_path":167},{"_path":171,"_dir":172,"_draft":173,"_partial":174,"_locale":175,"title":176,"description":177,"body":178,"_type":1184,"_id":1185,"_source":1186,"_file":1187,"_stem":1188,"_extension":1189},"/maps/_ai/mcp/native-api-to-mcp","mcp",false,true,"","反对「直接把内部 API 暴露成 MCP」的天真做法","原文反对将现有内部 API 直接转换为 MCP，建议为代理场景专门设计安全的 MCP 服务层。",{"type":179,"children":180,"toc":1171},"root",[181,190,196,201,206,211,216,222,229,236,256,261,274,280,285,303,308,312,318,324,329,347,352,404,409,415,420,449,454,472,477,511,524,530,535,582,592,595,601,607,612,628,633,667,673,678,735,745,748,754,760,796,802,833,838,841,847,853,887,893,927,933,983,986,992,998,1003,1021,1026,1039,1045,1050,1098,1103,1109,1114,1166],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"brief",[187],{"type":188,"value":189},"text","Brief",{"type":182,"tag":191,"props":192,"children":193},"p",{},[194],{"type":188,"value":195},"许多组织都希望让 AI 代理能够与现有系统交互，常见做法是尝试将内部 API「无缝、直接」转换为 Model Context Protocol (MCP)。市面上也出现了越来越多支持这种转换的工具，例如 MCP link 和 FastAPI-MCP。",{"type":182,"tag":191,"props":197,"children":198},{},[199],{"type":188,"value":200},"我们不建议采用这种天真的 API→MCP 转换方式。绝大多数 API 是为人类开发者设计的，通常由粒度很细的原子操作构成。如果让 AI 通过 MCP 直接调用这些接口并串联使用，往往会导致 Token 过度消耗、上下文被严重污染，以及整体代理性能不佳。",{"type":182,"tag":191,"props":202,"children":203},{},[204],{"type":188,"value":205},"此外，这类 API——尤其是内部 API——经常会暴露敏感数据，或具备破坏性操作能力。对于人类开发者，这些风险通常通过架构模式和代码评审来缓解；但一旦通过 MCP 将这些接口原样暴露给 AI 代理，就没有可靠且确定性的方式来防止自主代理误用这些端点。",{"type":182,"tag":191,"props":207,"children":208},{},[209],{"type":188,"value":210},"因此，我们建议：在现有 API 之上，专门面向代理工作流构建一个安全的、面向场景设计的 MCP 服务器，而不是做简单的 API 到 MCP 的一一映射。",{"type":182,"tag":191,"props":212,"children":213},{},[214],{"type":188,"value":215},"来源：技术雷达",{"type":182,"tag":183,"props":217,"children":219},{"id":218},"details",[220],{"type":188,"value":221},"Details",{"type":182,"tag":223,"props":224,"children":226},"h3",{"id":225},"一背景与现状为什么大家想一键-apimcp",[227],{"type":188,"value":228},"一、背景与现状：为什么大家想「一键 API→MCP」",{"type":182,"tag":230,"props":231,"children":233},"h4",{"id":232},"_1-组织的直觉诉求",[234],{"type":188,"value":235},"1. 组织的直觉诉求",{"type":182,"tag":237,"props":238,"children":239},"ul",{},[240,246,251],{"type":182,"tag":241,"props":242,"children":243},"li",{},[244],{"type":188,"value":245},"业务侧目标：让 AI 代理能「真正干活」，不仅仅是问答，而是能下单、改配置、拉报表、触发自动化流程。",{"type":182,"tag":241,"props":247,"children":248},{},[249],{"type":188,"value":250},"技术侧现状：已有大量内部 REST / gRPC / GraphQL API，已经承载了各类业务操作。",{"type":182,"tag":241,"props":252,"children":253},{},[254],{"type":188,"value":255},"自然的想法：既然已有 API，就「顺手」通过 MCP 暴露出去，让代理像人类开发者一样调用即可。",{"type":182,"tag":191,"props":257,"children":258},{},[259],{"type":188,"value":260},"这种思路催生出：",{"type":182,"tag":237,"props":262,"children":263},{},[264,269],{"type":182,"tag":241,"props":265,"children":266},{},[267],{"type":188,"value":268},"通用「API to MCP」适配器（如 MCP link、FastAPI-MCP 等），主打「低改造成本、快速暴露能力」；",{"type":182,"tag":241,"props":270,"children":271},{},[272],{"type":188,"value":273},"理想状态：几乎不改业务，只加一层转换，代理就能访问所有能力。",{"type":182,"tag":230,"props":275,"children":277},{"id":276},"_2-mcp-的预期角色",[278],{"type":188,"value":279},"2. MCP 的预期角色",{"type":182,"tag":191,"props":281,"children":282},{},[283],{"type":188,"value":284},"在多数架构设想中，MCP 被视为：",{"type":182,"tag":237,"props":286,"children":287},{},[288,293,298],{"type":182,"tag":241,"props":289,"children":290},{},[291],{"type":188,"value":292},"「代理世界」和「企业系统世界」之间的接口协议；",{"type":182,"tag":241,"props":294,"children":295},{},[296],{"type":188,"value":297},"把工具/服务抽象成统一的「能力」，供 LLM Agent 调度；",{"type":182,"tag":241,"props":299,"children":300},{},[301],{"type":188,"value":302},"支撑多 Agent / 多工具协作，而不是一个简单的 HTTP 包装层。",{"type":182,"tag":191,"props":304,"children":305},{},[306],{"type":188,"value":307},"直接把内部 API 映射为 MCP，看起来是加速路径，实际却埋下系统性风险。",{"type":182,"tag":309,"props":310,"children":311},"hr",{},[],{"type":182,"tag":223,"props":313,"children":315},{"id":314},"二问题与风险为什么原样暴露-api是不负责任的设计",[316],{"type":188,"value":317},"二、问题与风险：为什么「原样暴露 API」是不负责任的设计",{"type":182,"tag":230,"props":319,"children":321},{"id":320},"_1-粒度问题为人类设计的-api不适合直接给代理用",[322],{"type":188,"value":323},"1. 粒度问题：为人类设计的 API，不适合直接给代理用",{"type":182,"tag":191,"props":325,"children":326},{},[327],{"type":188,"value":328},"内部 API 的典型特征：",{"type":182,"tag":237,"props":330,"children":331},{},[332,337,342],{"type":182,"tag":241,"props":333,"children":334},{},[335],{"type":188,"value":336},"颗粒度细：大量「查一条记录」「更新一个字段」「写一条日志」这类原子操作；",{"type":182,"tag":241,"props":338,"children":339},{},[340],{"type":188,"value":341},"接口组合逻辑：真正的业务价值由上层服务/应用通过多次调用组合出来；",{"type":182,"tag":241,"props":343,"children":344},{},[345],{"type":188,"value":346},"默认前提：调用者是有上下文、懂业务语义的人类开发者。",{"type":182,"tag":191,"props":348,"children":349},{},[350],{"type":188,"value":351},"对代理而言，这会带来几个问题：",{"type":182,"tag":237,"props":353,"children":354},{},[355,368,386],{"type":182,"tag":241,"props":356,"children":357},{},[358,360],{"type":188,"value":359},"需要大量调用链组合才能完成一个业务任务：\n",{"type":182,"tag":237,"props":361,"children":362},{},[363],{"type":182,"tag":241,"props":364,"children":365},{},[366],{"type":188,"value":367},"例如：先查用户信息 → 再查订单 → 再更新状态 → 再写审计日志 → 再发通知；",{"type":182,"tag":241,"props":369,"children":370},{},[371,373],{"type":188,"value":372},"每次调用都要在 Prompt/工具调用规范里编码参数和上下文，导致：\n",{"type":182,"tag":237,"props":374,"children":375},{},[376,381],{"type":182,"tag":241,"props":377,"children":378},{},[379],{"type":188,"value":380},"Token 消耗迅速放大；",{"type":182,"tag":241,"props":382,"children":383},{},[384],{"type":188,"value":385},"上下文里充斥大量低层细节（context pollution），挤压对任务本身的建模空间；",{"type":182,"tag":241,"props":387,"children":388},{},[389,391],{"type":188,"value":390},"代理在链式调用中容易迷失：\n",{"type":182,"tag":237,"props":392,"children":393},{},[394,399],{"type":182,"tag":241,"props":395,"children":396},{},[397],{"type":188,"value":398},"难以维护一个稳定的一致状态模型；",{"type":182,"tag":241,"props":400,"children":401},{},[402],{"type":188,"value":403},"微小的解析、规划错误就可能放大成错误序列。",{"type":182,"tag":191,"props":405,"children":406},{},[407],{"type":188,"value":408},"总结：为人类设计的「细颗粒度 API」，直接暴露给代理，结构上就不匹配其规划和推理方式。",{"type":182,"tag":230,"props":410,"children":412},{"id":411},"_2-安全与破坏性操作人类有守门人代理没有",[413],{"type":188,"value":414},"2. 安全与破坏性操作：人类有「守门人」，代理没有",{"type":182,"tag":191,"props":416,"children":417},{},[418],{"type":188,"value":419},"内部 API 通常包含：",{"type":182,"tag":237,"props":421,"children":422},{},[423,436],{"type":182,"tag":241,"props":424,"children":425},{},[426,428],{"type":188,"value":427},"读取敏感数据的能力：\n",{"type":182,"tag":237,"props":429,"children":430},{},[431],{"type":182,"tag":241,"props":432,"children":433},{},[434],{"type":188,"value":435},"用户隐私、业务机密、运营指标等；",{"type":182,"tag":241,"props":437,"children":438},{},[439,441],{"type":188,"value":440},"具备破坏性的写操作：\n",{"type":182,"tag":237,"props":442,"children":443},{},[444],{"type":182,"tag":241,"props":445,"children":446},{},[447],{"type":188,"value":448},"删除、批量更新、触发外部系统执行等。",{"type":182,"tag":191,"props":450,"children":451},{},[452],{"type":188,"value":453},"在人类开发流程里，这些风险被缓冲在：",{"type":182,"tag":237,"props":455,"children":456},{},[457,462,467],{"type":182,"tag":241,"props":458,"children":459},{},[460],{"type":188,"value":461},"架构分层与访问控制：只有特定服务 / 角色才能调用；",{"type":182,"tag":241,"props":463,"children":464},{},[465],{"type":188,"value":466},"代码评审与上线流程：危险调用往往需要多人评审、灰度、回滚预案；",{"type":182,"tag":241,"props":468,"children":469},{},[470],{"type":188,"value":471},"运行时观测与告警：异常模式会被运维体系发现。",{"type":182,"tag":191,"props":473,"children":474},{},[475],{"type":188,"value":476},"一旦通过 MCP 直接暴露给自主代理：",{"type":182,"tag":237,"props":478,"children":479},{},[480,493,498],{"type":182,"tag":241,"props":481,"children":482},{},[483,485],{"type":188,"value":484},"代理可能在看似合理的任务规划中误用这些能力：\n",{"type":182,"tag":237,"props":486,"children":487},{},[488],{"type":182,"tag":241,"props":489,"children":490},{},[491],{"type":188,"value":492},"比如「清理无效账号」被误解为「批量删除活跃用户」；",{"type":182,"tag":241,"props":494,"children":495},{},[496],{"type":188,"value":497},"我们很难用传统 ACL/鉴权表达「在这个对话/任务上下文下，哪些具体调用是可接受的」；",{"type":182,"tag":241,"props":499,"children":500},{},[501,503],{"type":188,"value":502},"缺少确定性的防线：\n",{"type":182,"tag":237,"props":504,"children":505},{},[506],{"type":182,"tag":241,"props":507,"children":508},{},[509],{"type":188,"value":510},"即使加了一些 Rule/Guardrail，也很难穷举所有危险组合，特别是在多步规划场景下。",{"type":182,"tag":191,"props":512,"children":513},{},[514,516,522],{"type":188,"value":515},"原文的关键判断是：",{"type":182,"tag":517,"props":518,"children":519},"strong",{},[520],{"type":188,"value":521},"没有可靠、确定性的方式保证代理不会误用这些端点",{"type":188,"value":523},"，安全基线无法接受。",{"type":182,"tag":230,"props":525,"children":527},{"id":526},"_3-代理性能与工程可维护性",[528],{"type":188,"value":529},"3. 代理性能与工程可维护性",{"type":182,"tag":191,"props":531,"children":532},{},[533],{"type":188,"value":534},"把低层 API 直接暴露为 MCP 工具，还会带来工程性问题：",{"type":182,"tag":237,"props":536,"children":537},{},[538,551,564],{"type":182,"tag":241,"props":539,"children":540},{},[541,543],{"type":188,"value":542},"工具爆炸：\n",{"type":182,"tag":237,"props":544,"children":545},{},[546],{"type":182,"tag":241,"props":547,"children":548},{},[549],{"type":188,"value":550},"MCP 层可能出现几十、上百个工具，增加代理工具选择复杂度；",{"type":182,"tag":241,"props":552,"children":553},{},[554,556],{"type":188,"value":555},"规划困难：\n",{"type":182,"tag":237,"props":557,"children":558},{},[559],{"type":182,"tag":241,"props":560,"children":561},{},[562],{"type":188,"value":563},"LLM 很难从一堆「原子接口」中推导出稳健的业务流程；",{"type":182,"tag":241,"props":565,"children":566},{},[567,569],{"type":188,"value":568},"调试困难：\n",{"type":182,"tag":237,"props":570,"children":571},{},[572,577],{"type":182,"tag":241,"props":573,"children":574},{},[575],{"type":188,"value":576},"排查「为什么代理做了这串调用」成本极高；",{"type":182,"tag":241,"props":578,"children":579},{},[580],{"type":188,"value":581},"很难做到稳定的回归和演进。",{"type":182,"tag":191,"props":583,"children":584},{},[585,587],{"type":188,"value":586},"结果是：",{"type":182,"tag":517,"props":588,"children":589},{},[590],{"type":188,"value":591},"看似「很能干」的代理，实际在关键场景下非常不稳定且难以调优。",{"type":182,"tag":309,"props":593,"children":594},{},[],{"type":182,"tag":223,"props":596,"children":598},{"id":597},"三建议的模式在现有-api-之上设计面向代理的-mcp-服务器",[599],{"type":188,"value":600},"三、建议的模式：在现有 API 之上设计「面向代理的 MCP 服务器」",{"type":182,"tag":230,"props":602,"children":604},{"id":603},"_1-核心思路在-api-与-agent-之间再加一层agent-oriented-service",[605],{"type":188,"value":606},"1. 核心思路：在 API 与 Agent 之间，再加一层「Agent-Oriented Service」",{"type":182,"tag":191,"props":608,"children":609},{},[610],{"type":188,"value":611},"原文的推荐是：",{"type":182,"tag":613,"props":614,"children":615},"blockquote",{},[616],{"type":182,"tag":191,"props":617,"children":618},{},[619,621,626],{"type":188,"value":620},"基于现有 API，架构一个",{"type":182,"tag":517,"props":622,"children":623},{},[624],{"type":188,"value":625},"专门为代理工作流设计的、安全的 MCP 服务器",{"type":188,"value":627},"。",{"type":182,"tag":191,"props":629,"children":630},{},[631],{"type":188,"value":632},"其内涵包括：",{"type":182,"tag":237,"props":634,"children":635},{},[636,649],{"type":182,"tag":241,"props":637,"children":638},{},[639,641],{"type":188,"value":640},"MCP 工具不是「一一映射 API」，而是抽象为业务级能力：\n",{"type":182,"tag":237,"props":642,"children":643},{},[644],{"type":182,"tag":241,"props":645,"children":646},{},[647],{"type":188,"value":648},"例如「生成用户月度账单摘要」「创建工单并记录审计 Trail」；",{"type":182,"tag":241,"props":650,"children":651},{},[652,654],{"type":188,"value":653},"内部通过组合/编排调用多个原子 API：\n",{"type":182,"tag":237,"props":655,"children":656},{},[657,662],{"type":182,"tag":241,"props":658,"children":659},{},[660],{"type":188,"value":661},"API 仍然被人类开发者掌控在内部服务中；",{"type":182,"tag":241,"props":663,"children":664},{},[665],{"type":188,"value":666},"MCP 只暴露经过设计与审查的「高层动作」。",{"type":182,"tag":230,"props":668,"children":670},{"id":669},"_2-设计要点为-agent-定制的接口形态",[671],{"type":188,"value":672},"2. 设计要点：为 Agent 定制的接口形态",{"type":182,"tag":191,"props":674,"children":675},{},[676],{"type":188,"value":677},"为代理设计的 MCP 工具/服务，通常应具备几个特征：",{"type":182,"tag":237,"props":679,"children":680},{},[681,699,717],{"type":182,"tag":241,"props":682,"children":683},{},[684,686],{"type":188,"value":685},"高层任务语义：\n",{"type":182,"tag":237,"props":687,"children":688},{},[689,694],{"type":182,"tag":241,"props":690,"children":691},{},[692],{"type":188,"value":693},"输入/输出以业务对象为中心，而不是单表字段；",{"type":182,"tag":241,"props":695,"children":696},{},[697],{"type":188,"value":698},"避免让代理自己去拼细粒度步骤。",{"type":182,"tag":241,"props":700,"children":701},{},[702,704],{"type":188,"value":703},"内嵌安全与约束：\n",{"type":182,"tag":237,"props":705,"children":706},{},[707,712],{"type":182,"tag":241,"props":708,"children":709},{},[710],{"type":188,"value":711},"在 MCP 服务器内部实现必要的校验、限流、审计；",{"type":182,"tag":241,"props":713,"children":714},{},[715],{"type":188,"value":716},"对敏感操作引入显式的参数和约束，而不是「任意执行」。",{"type":182,"tag":241,"props":718,"children":719},{},[720,722],{"type":188,"value":721},"为可观测性设计：\n",{"type":182,"tag":237,"props":723,"children":724},{},[725,730],{"type":182,"tag":241,"props":726,"children":727},{},[728],{"type":188,"value":729},"每个 MCP 工具调用天然带有审计信息；",{"type":182,"tag":241,"props":731,"children":732},{},[733],{"type":188,"value":734},"便于在事后还原代理行为和排查问题。",{"type":182,"tag":191,"props":736,"children":737},{},[738,740],{"type":188,"value":739},"相当于：",{"type":182,"tag":517,"props":741,"children":742},{},[743],{"type":188,"value":744},"为代理提供的是「受限的、可观测的业务能力接口」，而非整个内部系统的裸露 API 面。",{"type":182,"tag":309,"props":746,"children":747},{},[],{"type":182,"tag":223,"props":749,"children":751},{"id":750},"四旧做法-vs-新模式如何理解这次转向",[752],{"type":188,"value":753},"四、旧做法 vs 新模式：如何理解这次转向",{"type":182,"tag":230,"props":755,"children":757},{"id":756},"_1-naive-模式api-as-mcp",[758],{"type":188,"value":759},"1. Naive 模式：API as MCP",{"type":182,"tag":237,"props":761,"children":762},{},[763,768,773],{"type":182,"tag":241,"props":764,"children":765},{},[766],{"type":188,"value":767},"目标：0 成本接入，让代理立刻可用所有内部 API；",{"type":182,"tag":241,"props":769,"children":770},{},[771],{"type":188,"value":772},"假设：代理是「廉价的高级开发者」，可以理解并正确使用这些接口；",{"type":182,"tag":241,"props":774,"children":775},{},[776,778],{"type":188,"value":777},"现实：\n",{"type":182,"tag":237,"props":779,"children":780},{},[781,786,791],{"type":182,"tag":241,"props":782,"children":783},{},[784],{"type":188,"value":785},"高调用成本（Token + 调用次数）；",{"type":182,"tag":241,"props":787,"chil