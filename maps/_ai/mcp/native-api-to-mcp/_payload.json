},[880,885],{"type":185,"tag":244,"props":881,"children":882},{},[883],{"type":191,"value":884},"哪些是可对话式触发的业务能力；",{"type":185,"tag":244,"props":886,"children":887},{},[888],{"type":191,"value":889},"哪些仍应限制在传统服务/后台任务里。",{"type":185,"tag":233,"props":891,"children":893},{"id":892},"_2-对安全治理的影响",[894],{"type":191,"value":895},"2. 对安全治理的影响",{"type":185,"tag":240,"props":897,"children":898},{},[899,917],{"type":185,"tag":244,"props":900,"children":901},{},[902,904],{"type":191,"value":903},"安全边界重构：\n",{"type":185,"tag":240,"props":905,"children":906},{},[907,912],{"type":185,"tag":244,"props":908,"children":909},{},[910],{"type":191,"value":911},"不再是「所有有 Token 的客户端都能调 API」；",{"type":185,"tag":244,"props":913,"children":914},{},[915],{"type":191,"value":916},"而是「代理只能通过经过审计的 MCP 工具访问特定能力」；",{"type":185,"tag":244,"props":918,"children":919},{},[920,922],{"type":191,"value":921},"新的风险管理方式：\n",{"type":185,"tag":240,"props":923,"children":924},{},[925],{"type":185,"tag":244,"props":926,"children":927},{},[928],{"type":191,"value":929},"重点从「单个请求的权限校验」转为「整条代理行为链的审计和约束」。",{"type":185,"tag":233,"props":931,"children":933},{"id":932},"_3-对工程效率和协作的影响",[934],{"type":191,"value":935},"3. 对工程效率和协作的影响",{"type":185,"tag":240,"props":937,"children":938},{},[939,952],{"type":185,"tag":244,"props":940,"children":941},{},[942,944],{"type":191,"value":943},"短期：\n",{"type":185,"tag":240,"props":945,"children":946},{},[947],{"type":185,"tag":244,"props":948,"children":949},{},[950],{"type":191,"value":951},"放弃「直接暴露 API」会增加前期设计和实现成本；",{"type":185,"tag":244,"props":953,"children":954},{},[955,957],{"type":191,"value":956},"中长期：\n",{"type":185,"tag":240,"props":958,"children":959},{},[960,973],{"type":185,"tag":244,"props":961,"children":962},{},[963,965],{"type":191,"value":964},"MCP 工具变成团队内部的「能力目录」：\n",{"type":185,"tag":240,"props":966,"children":967},{},[968],{"type":185,"tag":244,"props":969,"children":970},{},[971],{"type":191,"value":972},"产品、架构、平台可以围绕这些能力讨论代理能做什么；",{"type":185,"tag":244,"props":974,"children":975},{},[976,978],{"type":191,"value":977},"便于分层演进：\n",{"type":185,"tag":240,"props":979,"children":980},{},[981],{"type":185,"tag":244,"props":982,"children":983},{},[984],{"type":191,"value":985},"内部 API 可以演化，而 MCP 能力接口保持相对稳定。",{"type":185,"tag":312,"props":987,"children":988},{},[],{"type":185,"tag":226,"props":990,"children":992},{"id":991},"六落地建议如何在团队里实践非天真的-mcp-设计",[993],{"type":191,"value":994},"六、落地建议：如何在团队里实践「非天真」的 MCP 设计",{"type":185,"tag":233,"props":996,"children":998},{"id":997},"_1-适用场景与前提",[999],{"type":191,"value":1000},"1. 适用场景与前提",{"type":185,"tag":194,"props":1002,"children":1003},{},[1004],{"type":191,"value":1005},"更适合尝试专门 MCP 服务器的典型场景：",{"type":185,"tag":240,"props":1007,"children":1008},{},[1009,1014,1019],{"type":185,"tag":244,"props":1010,"children":1011},{},[1012],{"type":191,"value":1013},"计划在关键业务流程引入自主或半自主代理；",{"type":185,"tag":244,"props":1015,"children":1016},{},[1017],{"type":191,"value":1018},"内部 API 规模大、敏感操作多，安全与审计要求高；",{"type":185,"tag":244,"props":1020,"children":1021},{},[1022],{"type":191,"value":1023},"有意将「AI 能力」沉淀为长期的架构组成部分，而非临时试验。",{"type":185,"tag":194,"props":1025,"children":1026},{},[1027],{"type":191,"value":1028},"前提条件通常包括：",{"type":185,"tag":240,"props":1030,"children":1031},{},[1032,1037],{"type":185,"tag":244,"props":1033,"children":1034},{},[1035],{"type":191,"value":1036},"有一定的 API 治理和文档基础；",{"type":185,"tag":244,"props":1038,"children":1039},{},[1040],{"type":191,"value":1041},"有能力抽象出跨系统的业务能力，而不仅是表层 CRUD。",{"type":185,"tag":233,"props":1043,"children":1045},{"id":1044},"_2-初始路径从场景而不是api-列表出发",[1046],{"type":191,"value":1047},"2. 初始路径：从「场景」而不是「API 列表」出发",{"type":185,"tag":194,"props":1049,"children":1050},{},[1051],{"type":191,"value":1052},"推荐的推进方式：",{"type":185,"tag":1054,"props":1055,"children":1056},"ol",{},[1057,1070,1083],{"type":185,"tag":244,"props":1058,"children":1059},{},[1060,1062],{"type":191,"value":1061},"选一个小而有价值的闭环场景：\n",{"type":185,"tag":240,"props":1063,"children":1064},{},[1065],{"type":185,"tag":244,"props":1066,"children":1067},{},[1068],{"type":191,"value":1069},"比如：生成运营日报并落库、创建/更新工单并记录完整审计；",{"type":185,"tag":244,"props":1071,"children":1072},{},[1073,1075],{"type":191,"value":1074},"自顶向下设计 MCP 工具：\n",{"type":185,"tag":240,"props":1076,"children":1077},{},[1078],{"type":185,"tag":244,"props":1079,"children":1080},{},[1081],{"type":191,"value":1082},"抽象 2～5 个高层任务能力，而不是 20 个底层接口；",{"type":185,"tag":244,"props":1084,"children":1085},{},[1086,1088],{"type":191,"value":1087},"在 MCP 服务器内部编排现有 API：\n",{"type":185,"tag":240,"props":1089,"children":1090},{},[1091,1096],{"type":185,"tag":244,"props":1092,"children":1093},{},[1094],{"type":191,"value":1095},"保留所有安全校验、幂等、防错逻辑；",{"type":185,"tag":244,"props":1097,"children":1098},{},[1099],{"type":191,"value":1100},"明确什么情况要失败、什么情况要人工介入。",{"type":185,"tag":194,"props":1102,"children":1103},{},[1104],{"type":191,"value":1105},"在这个过程中，可以逐步积累：工具命名规范、输入输出约定、审计字段标准等。",{"type":185,"tag":233,"props":1107,"children":1109},{"id":1108},"_3-防范典型风险的工程手段",[1110],{"type":191,"value":1111},"3. 防范典型风险的工程手段",{"type":185,"tag":194,"props":1113,"children":1114},{},[1115],{"type":191,"value":1116},"在不改变原文立场的前提下，常见可行的缓解思路包括：",{"type":185,"tag":240,"props":1118,"children":1119},{},[1120,1138,1156],{"type":185,"tag":244,"props":1121,"children":1122},{},[1123,1125],{"type":191,"value":1124},"严格限制 MCP 工具集合：\n",{"type":185,"tag":240,"props":1126,"children":1127},{},[1128,1133],{"type":185,"tag":244,"props":1129,"children":1130},{},[1131],{"type":191,"value":1132},"初期只开放只读或低风险能力；",{"type":185,"tag":244,"props":1134,"children":1135},{},[1136],{"type":191,"value":1137},"高风险操作必须具备明确的「安全护栏」和回滚机制。",{"type":185,"tag":244,"props":1139,"children":1140},{},[1141,1143],{"type":191,"value":1142},"增强观测与审计：\n",{"type":185,"tag":240,"props":1144,"children":1145},{},[1146,1151],{"type":185,"tag":244,"props":1147,"children":1148},{},[1149],{"type":191,"value":1150},"对每次 MCP 调用记录任务上下文、调用参数和结果摘要；",{"type":185,"tag":244,"props":1152,"children":1153},{},[1154],{"type":191,"value":1155},"增加面向「代理行为」的监控视图。",{"type":185,"tag":244,"props":1157,"children":1158},{},[1159,1161],{"type":191,"value":1160},"控制自治度：\n",{"type":185,"tag":240,"props":1162,"children":1163},{},[1164],{"type":185,"tag":244,"props":1165,"children":1166},{},[1167],{"type":191,"value":1168},"在高风险场景中，更偏向「人机协同」，例如：\n- 代理生成操作计划和命令草案；\n- 人类确认后才执行对应 MCP 工具调用。",{"type":185,"tag":194,"props":1170,"children":1171},{},[1172],{"type":191,"value":1173},"整体而言，原文的姿态是「强烈不建议天真地把现有 API 原样暴露为 MCP」。如果要让代理真正、安全地接入企业系统，应当投入工程资源，围绕具体业务场景设计一层专门的、安全的 MCP 服务，而不是依赖自动适配工具做简单转换。",{"title":178,"searchDepth":1175,"depth":1175,"links":1176},2,[1177,1178],{"id":188,"depth":1175,"text":192},{"id":221,"depth":1175,"text":224,"children":1179},[1180,1182,1183,1184,1185,1186],{"id":228,"depth":1181,"text":231},3,{"id":317,"depth":1181,"text":320},{"id":600,"depth":1181,"text":603},{"id":753,"depth":1181,"text":756},{"id":846,"depth":1181,"text":849},{"id":991,"depth":1181,"text":994},"markdown","content:6.maps:_ai:mcp:native-api-to-mcp.md","content","6.maps/_ai/mcp/native-api-to-mcp.md","6.maps/_ai/mcp/native-api-to-mcp","md",[1194,1198],{"_path":1195,"title":1196,"description":1197},"/maps/_ai/mcp/mcp","Model Context Protocol","MCP（Model Context Protocol）是 Anthropic 开源的标准协议，用于连接 AI 应用与外部系统，被誉为 AI 应用的 USB-C 接口。",{"_path":1199,"title":1200,"description":178},"/maps/_ai/mechanistic-interpretability","机制可解释性 (Mechanistic Interpretability)",1771693737799]