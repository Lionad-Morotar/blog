":879},{},[880],{"type":188,"value":881},"哪些是可对话式触发的业务能力；",{"type":182,"tag":241,"props":883,"children":884},{},[885],{"type":188,"value":886},"哪些仍应限制在传统服务/后台任务里。",{"type":182,"tag":230,"props":888,"children":890},{"id":889},"_2-对安全治理的影响",[891],{"type":188,"value":892},"2. 对安全治理的影响",{"type":182,"tag":237,"props":894,"children":895},{},[896,914],{"type":182,"tag":241,"props":897,"children":898},{},[899,901],{"type":188,"value":900},"安全边界重构：\n",{"type":182,"tag":237,"props":902,"children":903},{},[904,909],{"type":182,"tag":241,"props":905,"children":906},{},[907],{"type":188,"value":908},"不再是「所有有 Token 的客户端都能调 API」；",{"type":182,"tag":241,"props":910,"children":911},{},[912],{"type":188,"value":913},"而是「代理只能通过经过审计的 MCP 工具访问特定能力」；",{"type":182,"tag":241,"props":915,"children":916},{},[917,919],{"type":188,"value":918},"新的风险管理方式：\n",{"type":182,"tag":237,"props":920,"children":921},{},[922],{"type":182,"tag":241,"props":923,"children":924},{},[925],{"type":188,"value":926},"重点从「单个请求的权限校验」转为「整条代理行为链的审计和约束」。",{"type":182,"tag":230,"props":928,"children":930},{"id":929},"_3-对工程效率和协作的影响",[931],{"type":188,"value":932},"3. 对工程效率和协作的影响",{"type":182,"tag":237,"props":934,"children":935},{},[936,949],{"type":182,"tag":241,"props":937,"children":938},{},[939,941],{"type":188,"value":940},"短期：\n",{"type":182,"tag":237,"props":942,"children":943},{},[944],{"type":182,"tag":241,"props":945,"children":946},{},[947],{"type":188,"value":948},"放弃「直接暴露 API」会增加前期设计和实现成本；",{"type":182,"tag":241,"props":950,"children":951},{},[952,954],{"type":188,"value":953},"中长期：\n",{"type":182,"tag":237,"props":955,"children":956},{},[957,970],{"type":182,"tag":241,"props":958,"children":959},{},[960,962],{"type":188,"value":961},"MCP 工具变成团队内部的「能力目录」：\n",{"type":182,"tag":237,"props":963,"children":964},{},[965],{"type":182,"tag":241,"props":966,"children":967},{},[968],{"type":188,"value":969},"产品、架构、平台可以围绕这些能力讨论代理能做什么；",{"type":182,"tag":241,"props":971,"children":972},{},[973,975],{"type":188,"value":974},"便于分层演进：\n",{"type":182,"tag":237,"props":976,"children":977},{},[978],{"type":182,"tag":241,"props":979,"children":980},{},[981],{"type":188,"value":982},"内部 API 可以演化，而 MCP 能力接口保持相对稳定。",{"type":182,"tag":309,"props":984,"children":985},{},[],{"type":182,"tag":223,"props":987,"children":989},{"id":988},"六落地建议如何在团队里实践非天真的-mcp-设计",[990],{"type":188,"value":991},"六、落地建议：如何在团队里实践「非天真」的 MCP 设计",{"type":182,"tag":230,"props":993,"children":995},{"id":994},"_1-适用场景与前提",[996],{"type":188,"value":997},"1. 适用场景与前提",{"type":182,"tag":191,"props":999,"children":1000},{},[1001],{"type":188,"value":1002},"更适合尝试专门 MCP 服务器的典型场景：",{"type":182,"tag":237,"props":1004,"children":1005},{},[1006,1011,1016],{"type":182,"tag":241,"props":1007,"children":1008},{},[1009],{"type":188,"value":1010},"计划在关键业务流程引入自主或半自主代理；",{"type":182,"tag":241,"props":1012,"children":1013},{},[1014],{"type":188,"value":1015},"内部 API 规模大、敏感操作多，安全与审计要求高；",{"type":182,"tag":241,"props":1017,"children":1018},{},[1019],{"type":188,"value":1020},"有意将「AI 能力」沉淀为长期的架构组成部分，而非临时试验。",{"type":182,"tag":191,"props":1022,"children":1023},{},[1024],{"type":188,"value":1025},"前提条件通常包括：",{"type":182,"tag":237,"props":1027,"children":1028},{},[1029,1034],{"type":182,"tag":241,"props":1030,"children":1031},{},[1032],{"type":188,"value":1033},"有一定的 API 治理和文档基础；",{"type":182,"tag":241,"props":1035,"children":1036},{},[1037],{"type":188,"value":1038},"有能力抽象出跨系统的业务能力，而不仅是表层 CRUD。",{"type":182,"tag":230,"props":1040,"children":1042},{"id":1041},"_2-初始路径从场景而不是api-列表出发",[1043],{"type":188,"value":1044},"2. 初始路径：从「场景」而不是「API 列表」出发",{"type":182,"tag":191,"props":1046,"children":1047},{},[1048],{"type":188,"value":1049},"推荐的推进方式：",{"type":182,"tag":1051,"props":1052,"children":1053},"ol",{},[1054,1067,1080],{"type":182,"tag":241,"props":1055,"children":1056},{},[1057,1059],{"type":188,"value":1058},"选一个小而有价值的闭环场景：\n",{"type":182,"tag":237,"props":1060,"children":1061},{},[1062],{"type":182,"tag":241,"props":1063,"children":1064},{},[1065],{"type":188,"value":1066},"比如：生成运营日报并落库、创建/更新工单并记录完整审计；",{"type":182,"tag":241,"props":1068,"children":1069},{},[1070,1072],{"type":188,"value":1071},"自顶向下设计 MCP 工具：\n",{"type":182,"tag":237,"props":1073,"children":1074},{},[1075],{"type":182,"tag":241,"props":1076,"children":1077},{},[1078],{"type":188,"value":1079},"抽象 2～5 个高层任务能力，而不是 20 个底层接口；",{"type":182,"tag":241,"props":1081,"children":1082},{},[1083,1085],{"type":188,"value":1084},"在 MCP 服务器内部编排现有 API：\n",{"type":182,"tag":237,"props":1086,"children":1087},{},[1088,1093],{"type":182,"tag":241,"props":1089,"children":1090},{},[1091],{"type":188,"value":1092},"保留所有安全校验、幂等、防错逻辑；",{"type":182,"tag":241,"props":1094,"children":1095},{},[1096],{"type":188,"value":1097},"明确什么情况要失败、什么情况要人工介入。",{"type":182,"tag":191,"props":1099,"children":1100},{},[1101],{"type":188,"value":1102},"在这个过程中，可以逐步积累：工具命名规范、输入输出约定、审计字段标准等。",{"type":182,"tag":230,"props":1104,"children":1106},{"id":1105},"_3-防范典型风险的工程手段",[1107],{"type":188,"value":1108},"3. 防范典型风险的工程手段",{"type":182,"tag":191,"props":1110,"children":1111},{},[1112],{"type":188,"value":1113},"在不改变原文立场的前提下，常见可行的缓解思路包括：",{"type":182,"tag":237,"props":1115,"children":1116},{},[1117,1135,1153],{"type":182,"tag":241,"props":1118,"children":1119},{},[1120,1122],{"type":188,"value":1121},"严格限制 MCP 工具集合：\n",{"type":182,"tag":237,"props":1123,"children":1124},{},[1125,1130],{"type":182,"tag":241,"props":1126,"children":1127},{},[1128],{"type":188,"value":1129},"初期只开放只读或低风险能力；",{"type":182,"tag":241,"props":1131,"children":1132},{},[1133],{"type":188,"value":1134},"高风险操作必须具备明确的「安全护栏」和回滚机制。",{"type":182,"tag":241,"props":1136,"children":1137},{},[1138,1140],{"type":188,"value":1139},"增强观测与审计：\n",{"type":182,"tag":237,"props":1141,"children":1142},{},[1143,1148],{"type":182,"tag":241,"props":1144,"children":1145},{},[1146],{"type":188,"value":1147},"对每次 MCP 调用记录任务上下文、调用参数和结果摘要；",{"type":182,"tag":241,"props":1149,"children":1150},{},[1151],{"type":188,"value":1152},"增加面向「代理行为」的监控视图。",{"type":182,"tag":241,"props":1154,"children":1155},{},[1156,1158],{"type":188,"value":1157},"控制自治度：\n",{"type":182,"tag":237,"props":1159,"children":1160},{},[1161],{"type":182,"tag":241,"props":1162,"children":1163},{},[1164],{"type":188,"value":1165},"在高风险场景中，更偏向「人机协同」，例如：\n- 代理生成操作计划和命令草案；\n- 人类确认后才执行对应 MCP 工具调用。",{"type":182,"tag":191,"props":1167,"children":1168},{},[1169],{"type":188,"value":1170},"整体而言，原文的姿态是「强烈不建议天真地把现有 API 原样暴露为 MCP」。如果要让代理真正、安全地接入企业系统，应当投入工程资源，围绕具体业务场景设计一层专门的、安全的 MCP 服务，而不是依赖自动适配工具做简单转换。",{"title":175,"searchDepth":1172,"depth":1172,"links":1173},2,[1174,1175],{"id":185,"depth":1172,"text":189},{"id":218,"depth":1172,"text":221,"children":1176},[1177,1179,1180,1181,1182,1183],{"id":225,"depth":1178,"text":228},3,{"id":314,"depth":1178,"text":317},{"id":597,"depth":1178,"text":600},{"id":750,"depth":1178,"text":753},{"id":843,"depth":1178,"text":846},{"id":988,"depth":1178,"text":991},"markdown","content:6.maps:_ai:mcp:native-api-to-mcp.md","content","6.maps/_ai/mcp/native-api-to-mcp.md","6.maps/_ai/mcp/native-api-to-mcp","md",[1191,1195],{"_path":1192,"title":1193,"description":1194},"/maps/_ai/mcp/mcp","Model Context Protocol","MCP（Model Context Protocol）是一种用于管理和优化大型语言模型（LLM）上下文信息的协议，旨在提升模型在处理复杂任务时的效率和准确性。",{"_path":1196,"title":1197,"description":1198},"/maps/_ai/prompt/context-engineering","Context Engineering","Context Engineering 是一种优化与大型语言模型（LLM）交互的技术，旨在通过提供结构化和相关的上下文信息，提高模型生成内容的准确性和相关性。",1771214974237]