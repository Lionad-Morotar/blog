itle":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"body":181,"_type":1187,"_id":1188,"_source":1189,"_file":1190,"_stem":1191,"_extension":1192},"/maps/_ai/mcp/native-api-to-mcp","mcp",false,true,"","反对「直接把内部 API 暴露成 MCP」的天真做法","原文反对将现有内部 API 直接转换为 MCP，建议为代理场景专门设计安全的 MCP 服务层。",{"type":182,"children":183,"toc":1174},"root",[184,193,199,204,209,214,219,225,232,239,259,264,277,283,288,306,311,315,321,327,332,350,355,407,412,418,423,452,457,475,480,514,527,533,538,585,595,598,604,610,615,631,636,670,676,681,738,748,751,757,763,799,805,836,841,844,850,856,890,896,930,936,986,989,995,1001,1006,1024,1029,1042,1048,1053,1101,1106,1112,1117,1169],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"brief",[190],{"type":191,"value":192},"text","Brief",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"许多组织都希望让 AI 代理能够与现有系统交互，常见做法是尝试将内部 API「无缝、直接」转换为 Model Context Protocol (MCP)。市面上也出现了越来越多支持这种转换的工具，例如 MCP link 和 FastAPI-MCP。",{"type":185,"tag":194,"props":200,"children":201},{},[202],{"type":191,"value":203},"我们不建议采用这种天真的 API→MCP 转换方式。绝大多数 API 是为人类开发者设计的，通常由粒度很细的原子操作构成。如果让 AI 通过 MCP 直接调用这些接口并串联使用，往往会导致 Token 过度消耗、上下文被严重污染，以及整体代理性能不佳。",{"type":185,"tag":194,"props":205,"children":206},{},[207],{"type":191,"value":208},"此外，这类 API——尤其是内部 API——经常会暴露敏感数据，或具备破坏性操作能力。对于人类开发者，这些风险通常通过架构模式和代码评审来缓解；但一旦通过 MCP 将这些接口原样暴露给 AI 代理，就没有可靠且确定性的方式来防止自主代理误用这些端点。",{"type":185,"tag":194,"props":210,"children":211},{},[212],{"type":191,"value":213},"因此，我们建议：在现有 API 之上，专门面向代理工作流构建一个安全的、面向场景设计的 MCP 服务器，而不是做简单的 API 到 MCP 的一一映射。",{"type":185,"tag":194,"props":215,"children":216},{},[217],{"type":191,"value":218},"来源：技术雷达",{"type":185,"tag":186,"props":220,"children":222},{"id":221},"details",[223],{"type":191,"value":224},"Details",{"type":185,"tag":226,"props":227,"children":229},"h3",{"id":228},"一背景与现状为什么大家想一键-apimcp",[230],{"type":191,"value":231},"一、背景与现状：为什么大家想「一键 API→MCP」",{"type":185,"tag":233,"props":234,"children":236},"h4",{"id":235},"_1-组织的直觉诉求",[237],{"type":191,"value":238},"1. 组织的直觉诉求",{"type":185,"tag":240,"props":241,"children":242},"ul",{},[243,249,254],{"type":185,"tag":244,"props":245,"children":246},"li",{},[247],{"type":191,"value":248},"业务侧目标：让 AI 代理能「真正干活」，不仅仅是问答，而是能下单、改配置、拉报表、触发自动化流程。",{"type":185,"tag":244,"props":250,"children":251},{},[252],{"type":191,"value":253},"技术侧现状：已有大量内部 REST / gRPC / GraphQL API，已经承载了各类业务操作。",{"type":185,"tag":244,"props":255,"children":256},{},[257],{"type":191,"value":258},"自然的想法：既然已有 API，就「顺手」通过 MCP 暴露出去，让代理像人类开发者一样调用即可。",{"type":185,"tag":194,"props":260,"children":261},{},[262],{"type":191,"value":263},"这种思路催生出：",{"type":185,"tag":240,"props":265,"children":266},{},[267,272],{"type":185,"tag":244,"props":268,"children":269},{},[270],{"type":191,"value":271},"通用「API to MCP」适配器（如 MCP link、FastAPI-MCP 等），主打「低改造成本、快速暴露能力」；",{"type":185,"tag":244,"props":273,"children":274},{},[275],{"type":191,"value":276},"理想状态：几乎不改业务，只加一层转换，代理就能访问所有能力。",{"type":185,"tag":233,"props":278,"children":280},{"id":279},"_2-mcp-的预期角色",[281],{"type":191,"value":282},"2. MCP 的预期角色",{"type":185,"tag":194,"props":284,"children":285},{},[286],{"type":191,"value":287},"在多数架构设想中，MCP 被视为：",{"type":185,"tag":240,"props":289,"children":290},{},[291,296,301],{"type":185,"tag":244,"props":292,"children":293},{},[294],{"type":191,"value":295},"「代理世界」和「企业系统世界」之间的接口协议；",{"type":185,"tag":244,"props":297,"children":298},{},[299],{"type":191,"value":300},"把工具/服务抽象成统一的「能力」，供 LLM Agent 调度；",{"type":185,"tag":244,"props":302,"children":303},{},[304],{"type":191,"value":305},"支撑多 Agent / 多工具协作，而不是一个简单的 HTTP 包装层。",{"type":185,"tag":194,"props":307,"children":308},{},[309],{"type":191,"value":310},"直接把内部 API 映射为 MCP，看起来是加速路径，实际却埋下系统性风险。",{"type":185,"tag":312,"props":313,"children":314},"hr",{},[],{"type":185,"tag":226,"props":316,"children":318},{"id":317},"二问题与风险为什么原样暴露-api是不负责任的设计",[319],{"type":191,"value":320},"二、问题与风险：为什么「原样暴露 API」是不负责任的设计",{"type":185,"tag":233,"props":322,"children":324},{"id":323},"_1-粒度问题为人类设计的-api不适合直接给代理用",[325],{"type":191,"value":326},"1. 粒度问题：为人类设计的 API，不适合直接给代理用",{"type":185,"tag":194,"props":328,"children":329},{},[330],{"type":191,"value":331},"内部 API 的典型特征：",{"type":185,"tag":240,"props":333,"children":334},{},[335,340,345],{"type":185,"tag":244,"props":336,"children":337},{},[338],{"type":191,"value":339},"颗粒度细：大量「查一条记录」「更新一个字段」「写一条日志」这类原子操作；",{"type":185,"tag":244,"props":341,"children":342},{},[343],{"type":191,"value":344},"接口组合逻辑：真正的业务价值由上层服务/应用通过多次调用组合出来；",{"type":185,"tag":244,"props":346,"children":347},{},[348],{"type":191,"value":349},"默认前提：调用者是有上下文、懂业务语义的人类开发者。",{"type":185,"tag":194,"props":351,"children":352},{},[353],{"type":191,"value":354},"对代理而言，这会带来几个问题：",{"type":185,"tag":240,"props":356,"children":357},{},[358,371,389],{"type":185,"tag":244,"props":359,"children":360},{},[361,363],{"type":191,"value":362},"需要大量调用链组合才能完成一个业务任务：\n",{"type":185,"tag":240,"props":364,"children":365},{},[366],{"type":185,"tag":244,"props":367,"children":368},{},[369],{"type":191,"value":370},"例如：先查用户信息 → 再查订单 → 再更新状态 → 再写审计日志 → 再发通知；",{"type":185,"tag":244,"props":372,"children":373},{},[374,376],{"type":191,"value":375},"每次调用都要在 Prompt/工具调用规范里编码参数和上下文，导致：\n",{"type":185,"tag":240,"props":377,"children":378},{},[379,384],{"type":185,"tag":244,"props":380,"children":381},{},[382],{"type":191,"value":383},"Token 消耗迅速放大；",{"type":185,"tag":244,"props":385,"children":386},{},[387],{"type":191,"value":388},"上下文里充斥大量低层细节（context pollution），挤压对任务本身的建模空间；",{"type":185,"tag":244,"props":390,"children":391},{},[392,394],{"type":191,"value":393},"代理在链式调用中容易迷失：\n",{"type":185,"tag":240,"props":395,"children":396},{},[397,402],{"type":185,"tag":244,"props":398,"children":399},{},[400],{"type":191,"value":401},"难以维护一个稳定的一致状态模型；",{"type":185,"tag":244,"props":403,"children":404},{},[405],{"type":191,"value":406},"微小的解析、规划错误就可能放大成错误序列。",{"type":185,"tag":194,"props":408,"children":409},{},[410],{"type":191,"value":411},"总结：为人类设计的「细颗粒度 API」，直接暴露给代理，结构上就不匹配其规划和推理方式。",{"type":185,"tag":233,"props":413,"children":415},{"id":414},"_2-安全与破坏性操作人类有守门人代理没有",[416],{"type":191,"value":417},"2. 安全与破坏性操作：人类有「守门人」，代理没有",{"type":185,"tag":194,"props":419,"children":420},{},[421],{"type":191,"value":422},"内部 API 通常包含：",{"type":185,"tag":240,"props":424,"children":425},{},[426,439],{"type":185,"tag":244,"props":427,"children":428},{},[429,431],{"type":191,"value":430},"读取敏感数据的能力：\n",{"type":185,"tag":240,"props":432,"children":433},{},[434],{"type":185,"tag":244,"props":435,"children":436},{},[437],{"type":191,"value":438},"用户隐私、业务机密、运营指标等；",{"type":185,"tag":244,"props":440,"children":441},{},[442,444],{"type":191,"value":443},"具备破坏性的写操作：\n",{"type":185,"tag":240,"props":445,"children":446},{},[447],{"type":185,"tag":244,"props":448,"children":449},{},[450],{"type":191,"value":451},"删除、批量更新、触发外部系统执行等。",{"type":185,"tag":194,"props":453,"children":454},{},[455],{"type":191,"value":456},"在人类开发流程里，这些风险被缓冲在：",{"type":185,"tag":240,"props":458,"children":459},{},[460,465,470],{"type":185,"tag":244,"props":461,"children":462},{},[463],{"type":191,"value":464},"架构分层与访问控制：只有特定服务 / 角色才能调用；",{"type":185,"tag":244,"props":466,"children":467},{},[468],{"type":191,"value":469},"代码评审与上线流程：危险调用往往需要多人评审、灰度、回滚预案；",{"type":185,"tag":244,"props":471,"children":472},{},[473],{"type":191,"value":474},"运行时观测与告警：异常模式会被运维体系发现。",{"type":185,"tag":194,"props":476,"children":477},{},[478],{"type":191,"value":479},"一旦通过 MCP 直接暴露给自主代理：",{"type":185,"tag":240,"props":481,"children":482},{},[483,496,501],{"type":185,"tag":244,"props":484,"children":485},{},[486,488],{"type":191,"value":487},"代理可能在看似合理的任务规划中误用这些能力：\n",{"type":185,"tag":240,"props":489,"children":490},{},[491],{"type":185,"tag":244,"props":492,"children":493},{},[494],{"type":191,"value":495},"比如「清理无效账号」被误解为「批量删除活跃用户」；",{"type":185,"tag":244,"props":497,"children":498},{},[499],{"type":191,"value":500},"我们很难用传统 ACL/鉴权表达「在这个对话/任务上下文下，哪些具体调用是可接受的」；",{"type":185,"tag":244,"props":502,"children":503},{},[504,506],{"type":191,"value":505},"缺少确定性的防线：\n",{"type":185,"tag":240,"props":507,"children":508},{},[509],{"type":185,"tag":244,"props":510,"children":511},{},[512],{"type":191,"value":513},"即使加了一些 Rule/Guardrail，也很难穷举所有危险组合，特别是在多步规划场景下。",{"type":185,"tag":194,"props":515,"children":516},{},[517,519,525],{"type":191,"value":518},"原文的关键判断是：",{"type":185,"tag":520,"props":521,"children":522},"strong",{},[523],{"type":191,"value":524},"没有可靠、确定性的方式保证代理不会误用这些端点",{"type":191,"value":526},"，安全基线无法接受。",{"type":185,"tag":233,"props":528,"children":530},{"id":529},"_3-代理性能与工程可维护性",[531],{"type":191,"value":532},"3. 代理性能与工程可维护性",{"type":185,"tag":194,"props":534,"children":535},{},[536],{"type":191,"value":537},"把低层 API 直接暴露为 MCP 工具，还会带来工程性问题：",{"type":185,"tag":240,"props":539,"children":540},{},[541,554,567],{"type":185,"tag":244,"props":542,"children":543},{},[544,546],{"type":191,"value":545},"工具爆炸：\n",{"type":185,"tag":240,"props":547,"children":548},{},[549],{"type":185,"tag":244,"props":550,"children":551},{},[552],{"type":191,"value":553},"MCP 层可能出现几十、上百个工具，增加代理工具选择复杂度；",{"type":185,"tag":244,"props":555,"children":556},{},[557,559],{"type":191,"value":558},"规划困难：\n",{"type":185,"tag":240,"props":560,"children":561},{},[562],{"type":185,"tag":244,"props":563,"children":564},{},[565],{"type":191,"value":566},"LLM 很难从一堆「原子接口」中推导出稳健的业务流程；",{"type":185,"tag":244,"props":568,"children":569},{},[570,572],{"type":191,"value":571},"调试困难：\n",{"type":185,"tag":240,"props":573,"children":574},{},[575,580],{"type":185,"tag":244,"props":576,"children":577},{},[578],{"type":191,"value":579},"排查「为什么代理做了这串调用」成本极高；",{"type":185,"tag":244,"props":581,"children":582},{},[583],{"type":191,"value":584},"很难做到稳定的回归和演进。",{"type":185,"tag":194,"props":586,"children":587},{},[588,590],{"type":191,"value":589},"结果是：",{"type":185,"tag":520,"props":591,"children":592},{},[593],{"type":191,"value":594},"看似「很能干」的代理，实际在关键场景下非常不稳定且难以调优。",{"type":185,"tag":312,"props":596,"children":597},{},[],{"type":185,"tag":226,"props":599,"children":601},{"id":600},"三建议的模式在现有-api-之上设计面向代理的-mcp-服务器",[602],{"type":191,"value":603},"三、建议的模式：在现有 API 之上设计「面向代理的 MCP 服务器」",{"type":185,"tag":233,"props":605,"c