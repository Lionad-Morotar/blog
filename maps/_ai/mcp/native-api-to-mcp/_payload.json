"type":186,"tag":241,"props":879,"children":880},{},[881,886],{"type":186,"tag":245,"props":882,"children":883},{},[884],{"type":192,"value":885},"哪些是可对话式触发的业务能力；",{"type":186,"tag":245,"props":887,"children":888},{},[889],{"type":192,"value":890},"哪些仍应限制在传统服务/后台任务里。",{"type":186,"tag":234,"props":892,"children":894},{"id":893},"_2-对安全治理的影响",[895],{"type":192,"value":896},"2. 对安全治理的影响",{"type":186,"tag":241,"props":898,"children":899},{},[900,918],{"type":186,"tag":245,"props":901,"children":902},{},[903,905],{"type":192,"value":904},"安全边界重构：\n",{"type":186,"tag":241,"props":906,"children":907},{},[908,913],{"type":186,"tag":245,"props":909,"children":910},{},[911],{"type":192,"value":912},"不再是「所有有 Token 的客户端都能调 API」；",{"type":186,"tag":245,"props":914,"children":915},{},[916],{"type":192,"value":917},"而是「代理只能通过经过审计的 MCP 工具访问特定能力」；",{"type":186,"tag":245,"props":919,"children":920},{},[921,923],{"type":192,"value":922},"新的风险管理方式：\n",{"type":186,"tag":241,"props":924,"children":925},{},[926],{"type":186,"tag":245,"props":927,"children":928},{},[929],{"type":192,"value":930},"重点从「单个请求的权限校验」转为「整条代理行为链的审计和约束」。",{"type":186,"tag":234,"props":932,"children":934},{"id":933},"_3-对工程效率和协作的影响",[935],{"type":192,"value":936},"3. 对工程效率和协作的影响",{"type":186,"tag":241,"props":938,"children":939},{},[940,953],{"type":186,"tag":245,"props":941,"children":942},{},[943,945],{"type":192,"value":944},"短期：\n",{"type":186,"tag":241,"props":946,"children":947},{},[948],{"type":186,"tag":245,"props":949,"children":950},{},[951],{"type":192,"value":952},"放弃「直接暴露 API」会增加前期设计和实现成本；",{"type":186,"tag":245,"props":954,"children":955},{},[956,958],{"type":192,"value":957},"中长期：\n",{"type":186,"tag":241,"props":959,"children":960},{},[961,974],{"type":186,"tag":245,"props":962,"children":963},{},[964,966],{"type":192,"value":965},"MCP 工具变成团队内部的「能力目录」：\n",{"type":186,"tag":241,"props":967,"children":968},{},[969],{"type":186,"tag":245,"props":970,"children":971},{},[972],{"type":192,"value":973},"产品、架构、平台可以围绕这些能力讨论代理能做什么；",{"type":186,"tag":245,"props":975,"children":976},{},[977,979],{"type":192,"value":978},"便于分层演进：\n",{"type":186,"tag":241,"props":980,"children":981},{},[982],{"type":186,"tag":245,"props":983,"children":984},{},[985],{"type":192,"value":986},"内部 API 可以演化，而 MCP 能力接口保持相对稳定。",{"type":186,"tag":313,"props":988,"children":989},{},[],{"type":186,"tag":227,"props":991,"children":993},{"id":992},"六落地建议如何在团队里实践非天真的-mcp-设计",[994],{"type":192,"value":995},"六、落地建议：如何在团队里实践「非天真」的 MCP 设计",{"type":186,"tag":234,"props":997,"children":999},{"id":998},"_1-适用场景与前提",[1000],{"type":192,"value":1001},"1. 适用场景与前提",{"type":186,"tag":195,"props":1003,"children":1004},{},[1005],{"type":192,"value":1006},"更适合尝试专门 MCP 服务器的典型场景：",{"type":186,"tag":241,"props":1008,"children":1009},{},[1010,1015,1020],{"type":186,"tag":245,"props":1011,"children":1012},{},[1013],{"type":192,"value":1014},"计划在关键业务流程引入自主或半自主代理；",{"type":186,"tag":245,"props":1016,"children":1017},{},[1018],{"type":192,"value":1019},"内部 API 规模大、敏感操作多，安全与审计要求高；",{"type":186,"tag":245,"props":1021,"children":1022},{},[1023],{"type":192,"value":1024},"有意将「AI 能力」沉淀为长期的架构组成部分，而非临时试验。",{"type":186,"tag":195,"props":1026,"children":1027},{},[1028],{"type":192,"value":1029},"前提条件通常包括：",{"type":186,"tag":241,"props":1031,"children":1032},{},[1033,1038],{"type":186,"tag":245,"props":1034,"children":1035},{},[1036],{"type":192,"value":1037},"有一定的 API 治理和文档基础；",{"type":186,"tag":245,"props":1039,"children":1040},{},[1041],{"type":192,"value":1042},"有能力抽象出跨系统的业务能力，而不仅是表层 CRUD。",{"type":186,"tag":234,"props":1044,"children":1046},{"id":1045},"_2-初始路径从场景而不是api-列表出发",[1047],{"type":192,"value":1048},"2. 初始路径：从「场景」而不是「API 列表」出发",{"type":186,"tag":195,"props":1050,"children":1051},{},[1052],{"type":192,"value":1053},"推荐的推进方式：",{"type":186,"tag":1055,"props":1056,"children":1057},"ol",{},[1058,1071,1084],{"type":186,"tag":245,"props":1059,"children":1060},{},[1061,1063],{"type":192,"value":1062},"选一个小而有价值的闭环场景：\n",{"type":186,"tag":241,"props":1064,"children":1065},{},[1066],{"type":186,"tag":245,"props":1067,"children":1068},{},[1069],{"type":192,"value":1070},"比如：生成运营日报并落库、创建/更新工单并记录完整审计；",{"type":186,"tag":245,"props":1072,"children":1073},{},[1074,1076],{"type":192,"value":1075},"自顶向下设计 MCP 工具：\n",{"type":186,"tag":241,"props":1077,"children":1078},{},[1079],{"type":186,"tag":245,"props":1080,"children":1081},{},[1082],{"type":192,"value":1083},"抽象 2～5 个高层任务能力，而不是 20 个底层接口；",{"type":186,"tag":245,"props":1085,"children":1086},{},[1087,1089],{"type":192,"value":1088},"在 MCP 服务器内部编排现有 API：\n",{"type":186,"tag":241,"props":1090,"children":1091},{},[1092,1097],{"type":186,"tag":245,"props":1093,"children":1094},{},[1095],{"type":192,"value":1096},"保留所有安全校验、幂等、防错逻辑；",{"type":186,"tag":245,"props":1098,"children":1099},{},[1100],{"type":192,"value":1101},"明确什么情况要失败、什么情况要人工介入。",{"type":186,"tag":195,"props":1103,"children":1104},{},[1105],{"type":192,"value":1106},"在这个过程中，可以逐步积累：工具命名规范、输入输出约定、审计字段标准等。",{"type":186,"tag":234,"props":1108,"children":1110},{"id":1109},"_3-防范典型风险的工程手段",[1111],{"type":192,"value":1112},"3. 防范典型风险的工程手段",{"type":186,"tag":195,"props":1114,"children":1115},{},[1116],{"type":192,"value":1117},"在不改变原文立场的前提下，常见可行的缓解思路包括：",{"type":186,"tag":241,"props":1119,"children":1120},{},[1121,1139,1157],{"type":186,"tag":245,"props":1122,"children":1123},{},[1124,1126],{"type":192,"value":1125},"严格限制 MCP 工具集合：\n",{"type":186,"tag":241,"props":1127,"children":1128},{},[1129,1134],{"type":186,"tag":245,"props":1130,"children":1131},{},[1132],{"type":192,"value":1133},"初期只开放只读或低风险能力；",{"type":186,"tag":245,"props":1135,"children":1136},{},[1137],{"type":192,"value":1138},"高风险操作必须具备明确的「安全护栏」和回滚机制。",{"type":186,"tag":245,"props":1140,"children":1141},{},[1142,1144],{"type":192,"value":1143},"增强观测与审计：\n",{"type":186,"tag":241,"props":1145,"children":1146},{},[1147,1152],{"type":186,"tag":245,"props":1148,"children":1149},{},[1150],{"type":192,"value":1151},"对每次 MCP 调用记录任务上下文、调用参数和结果摘要；",{"type":186,"tag":245,"props":1153,"children":1154},{},[1155],{"type":192,"value":1156},"增加面向「代理行为」的监控视图。",{"type":186,"tag":245,"props":1158,"children":1159},{},[1160,1162],{"type":192,"value":1161},"控制自治度：\n",{"type":186,"tag":241,"props":1163,"children":1164},{},[1165],{"type":186,"tag":245,"props":1166,"children":1167},{},[1168],{"type":192,"value":1169},"在高风险场景中，更偏向「人机协同」，例如：\n- 代理生成操作计划和命令草案；\n- 人类确认后才执行对应 MCP 工具调用。",{"type":186,"tag":195,"props":1171,"children":1172},{},[1173],{"type":192,"value":1174},"整体而言，原文的姿态是「强烈不建议天真地把现有 API 原样暴露为 MCP」。如果要让代理真正、安全地接入企业系统，应当投入工程资源，围绕具体业务场景设计一层专门的、安全的 MCP 服务，而不是依赖自动适配工具做简单转换。",{"title":178,"searchDepth":1176,"depth":1176,"links":1177},2,[1178,1179],{"id":189,"depth":1176,"text":193},{"id":222,"depth":1176,"text":225,"children":1180},[1181,1183,1184,1185,1186,1187],{"id":229,"depth":1182,"text":232},3,{"id":318,"depth":1182,"text":321},{"id":601,"depth":1182,"text":604},{"id":754,"depth":1182,"text":757},{"id":847,"depth":1182,"text":850},{"id":992,"depth":1182,"text":995},"markdown","content:6.maps:_ai:mcp:native-api-to-mcp.md","content","6.maps/_ai/mcp/native-api-to-mcp.md","6.maps/_ai/mcp/native-api-to-mcp","md",[1195,1199],{"_path":1196,"title":1197,"description":1198},"/maps/_ai/mcp/mcp","Model Context Protocol","MCP（Model Context Protocol）是 Anthropic 开源的标准协议，用于连接 AI 应用与外部系统，被誉为 AI 应用的 USB-C 接口。",{"_path":1200,"title":1201,"description":1202},"/maps/_ai/models/inference","Inference","Model inference and serving techniques",1772504966487]