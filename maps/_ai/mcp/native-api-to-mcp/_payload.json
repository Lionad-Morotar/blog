itle":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"original_path":181,"body":182,"_type":1188,"_id":1189,"_source":1190,"_file":1191,"_stem":1192,"_extension":1193},"/maps/_ai/mcp/native-api-to-mcp","mcp",false,true,"","反对「直接把内部 API 暴露成 MCP」的天真做法","原文反对将现有内部 API 直接转换为 MCP，建议为代理场景专门设计安全的 MCP 服务层","_ai/mcp/native-api-to-mcp.md",{"type":183,"children":184,"toc":1175},"root",[185,194,200,205,210,215,220,226,233,240,260,265,278,284,289,307,312,316,322,328,333,351,356,408,413,419,424,453,458,476,481,515,528,534,539,586,596,599,605,611,616,632,637,671,677,682,739,749,752,758,764,800,806,837,842,845,851,857,891,897,931,937,987,990,996,1002,1007,1025,1030,1043,1049,1054,1102,1107,1113,1118,1170],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"brief",[191],{"type":192,"value":193},"text","Brief",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198],{"type":192,"value":199},"许多组织都希望让 AI 代理能够与现有系统交互，常见做法是尝试将内部 API「无缝、直接」转换为 Model Context Protocol (MCP)。市面上也出现了越来越多支持这种转换的工具，例如 MCP link 和 FastAPI-MCP。",{"type":186,"tag":195,"props":201,"children":202},{},[203],{"type":192,"value":204},"我们不建议采用这种天真的 API→MCP 转换方式。绝大多数 API 是为人类开发者设计的，通常由粒度很细的原子操作构成。如果让 AI 通过 MCP 直接调用这些接口并串联使用，往往会导致 Token 过度消耗、上下文被严重污染，以及整体代理性能不佳。",{"type":186,"tag":195,"props":206,"children":207},{},[208],{"type":192,"value":209},"此外，这类 API——尤其是内部 API——经常会暴露敏感数据，或具备破坏性操作能力。对于人类开发者，这些风险通常通过架构模式和代码评审来缓解；但一旦通过 MCP 将这些接口原样暴露给 AI 代理，就没有可靠且确定性的方式来防止自主代理误用这些端点。",{"type":186,"tag":195,"props":211,"children":212},{},[213],{"type":192,"value":214},"因此，我们建议：在现有 API 之上，专门面向代理工作流构建一个安全的、面向场景设计的 MCP 服务器，而不是做简单的 API 到 MCP 的一一映射。",{"type":186,"tag":195,"props":216,"children":217},{},[218],{"type":192,"value":219},"来源：技术雷达",{"type":186,"tag":187,"props":221,"children":223},{"id":222},"details",[224],{"type":192,"value":225},"Details",{"type":186,"tag":227,"props":228,"children":230},"h3",{"id":229},"一背景与现状为什么大家想一键-apimcp",[231],{"type":192,"value":232},"一、背景与现状：为什么大家想「一键 API→MCP」",{"type":186,"tag":234,"props":235,"children":237},"h4",{"id":236},"_1-组织的直觉诉求",[238],{"type":192,"value":239},"1. 组织的直觉诉求",{"type":186,"tag":241,"props":242,"children":243},"ul",{},[244,250,255],{"type":186,"tag":245,"props":246,"children":247},"li",{},[248],{"type":192,"value":249},"业务侧目标：让 AI 代理能「真正干活」，不仅仅是问答，而是能下单、改配置、拉报表、触发自动化流程。",{"type":186,"tag":245,"props":251,"children":252},{},[253],{"type":192,"value":254},"技术侧现状：已有大量内部 REST / gRPC / GraphQL API，已经承载了各类业务操作。",{"type":186,"tag":245,"props":256,"children":257},{},[258],{"type":192,"value":259},"自然的想法：既然已有 API，就「顺手」通过 MCP 暴露出去，让代理像人类开发者一样调用即可。",{"type":186,"tag":195,"props":261,"children":262},{},[263],{"type":192,"value":264},"这种思路催生出：",{"type":186,"tag":241,"props":266,"children":267},{},[268,273],{"type":186,"tag":245,"props":269,"children":270},{},[271],{"type":192,"value":272},"通用「API to MCP」适配器（如 MCP link、FastAPI-MCP 等），主打「低改造成本、快速暴露能力」；",{"type":186,"tag":245,"props":274,"children":275},{},[276],{"type":192,"value":277},"理想状态：几乎不改业务，只加一层转换，代理就能访问所有能力。",{"type":186,"tag":234,"props":279,"children":281},{"id":280},"_2-mcp-的预期角色",[282],{"type":192,"value":283},"2. MCP 的预期角色",{"type":186,"tag":195,"props":285,"children":286},{},[287],{"type":192,"value":288},"在多数架构设想中，MCP 被视为：",{"type":186,"tag":241,"props":290,"children":291},{},[292,297,302],{"type":186,"tag":245,"props":293,"children":294},{},[295],{"type":192,"value":296},"「代理世界」和「企业系统世界」之间的接口协议；",{"type":186,"tag":245,"props":298,"children":299},{},[300],{"type":192,"value":301},"把工具/服务抽象成统一的「能力」，供 LLM Agent 调度；",{"type":186,"tag":245,"props":303,"children":304},{},[305],{"type":192,"value":306},"支撑多 Agent / 多工具协作，而不是一个简单的 HTTP 包装层。",{"type":186,"tag":195,"props":308,"children":309},{},[310],{"type":192,"value":311},"直接把内部 API 映射为 MCP，看起来是加速路径，实际却埋下系统性风险。",{"type":186,"tag":313,"props":314,"children":315},"hr",{},[],{"type":186,"tag":227,"props":317,"children":319},{"id":318},"二问题与风险为什么原样暴露-api是不负责任的设计",[320],{"type":192,"value":321},"二、问题与风险：为什么「原样暴露 API」是不负责任的设计",{"type":186,"tag":234,"props":323,"children":325},{"id":324},"_1-粒度问题为人类设计的-api不适合直接给代理用",[326],{"type":192,"value":327},"1. 粒度问题：为人类设计的 API，不适合直接给代理用",{"type":186,"tag":195,"props":329,"children":330},{},[331],{"type":192,"value":332},"内部 API 的典型特征：",{"type":186,"tag":241,"props":334,"children":335},{},[336,341,346],{"type":186,"tag":245,"props":337,"children":338},{},[339],{"type":192,"value":340},"颗粒度细：大量「查一条记录」「更新一个字段」「写一条日志」这类原子操作；",{"type":186,"tag":245,"props":342,"children":343},{},[344],{"type":192,"value":345},"接口组合逻辑：真正的业务价值由上层服务/应用通过多次调用组合出来；",{"type":186,"tag":245,"props":347,"children":348},{},[349],{"type":192,"value":350},"默认前提：调用者是有上下文、懂业务语义的人类开发者。",{"type":186,"tag":195,"props":352,"children":353},{},[354],{"type":192,"value":355},"对代理而言，这会带来几个问题：",{"type":186,"tag":241,"props":357,"children":358},{},[359,372,390],{"type":186,"tag":245,"props":360,"children":361},{},[362,364],{"type":192,"value":363},"需要大量调用链组合才能完成一个业务任务：\n",{"type":186,"tag":241,"props":365,"children":366},{},[367],{"type":186,"tag":245,"props":368,"children":369},{},[370],{"type":192,"value":371},"例如：先查用户信息 → 再查订单 → 再更新状态 → 再写审计日志 → 再发通知；",{"type":186,"tag":245,"props":373,"children":374},{},[375,377],{"type":192,"value":376},"每次调用都要在 Prompt/工具调用规范里编码参数和上下文，导致：\n",{"type":186,"tag":241,"props":378,"children":379},{},[380,385],{"type":186,"tag":245,"props":381,"children":382},{},[383],{"type":192,"value":384},"Token 消耗迅速放大；",{"type":186,"tag":245,"props":386,"children":387},{},[388],{"type":192,"value":389},"上下文里充斥大量低层细节（context pollution），挤压对任务本身的建模空间；",{"type":186,"tag":245,"props":391,"children":392},{},[393,395],{"type":192,"value":394},"代理在链式调用中容易迷失：\n",{"type":186,"tag":241,"props":396,"children":397},{},[398,403],{"type":186,"tag":245,"props":399,"children":400},{},[401],{"type":192,"value":402},"难以维护一个稳定的一致状态模型；",{"type":186,"tag":245,"props":404,"children":405},{},[406],{"type":192,"value":407},"微小的解析、规划错误就可能放大成错误序列。",{"type":186,"tag":195,"props":409,"children":410},{},[411],{"type":192,"value":412},"总结：为人类设计的「细颗粒度 API」，直接暴露给代理，结构上就不匹配其规划和推理方式。",{"type":186,"tag":234,"props":414,"children":416},{"id":415},"_2-安全与破坏性操作人类有守门人代理没有",[417],{"type":192,"value":418},"2. 安全与破坏性操作：人类有「守门人」，代理没有",{"type":186,"tag":195,"props":420,"children":421},{},[422],{"type":192,"value":423},"内部 API 通常包含：",{"type":186,"tag":241,"props":425,"children":426},{},[427,440],{"type":186,"tag":245,"props":428,"children":429},{},[430,432],{"type":192,"value":431},"读取敏感数据的能力：\n",{"type":186,"tag":241,"props":433,"children":434},{},[435],{"type":186,"tag":245,"props":436,"children":437},{},[438],{"type":192,"value":439},"用户隐私、业务机密、运营指标等；",{"type":186,"tag":245,"props":441,"children":442},{},[443,445],{"type":192,"value":444},"具备破坏性的写操作：\n",{"type":186,"tag":241,"props":446,"children":447},{},[448],{"type":186,"tag":245,"props":449,"children":450},{},[451],{"type":192,"value":452},"删除、批量更新、触发外部系统执行等。",{"type":186,"tag":195,"props":454,"children":455},{},[456],{"type":192,"value":457},"在人类开发流程里，这些风险被缓冲在：",{"type":186,"tag":241,"props":459,"children":460},{},[461,466,471],{"type":186,"tag":245,"props":462,"children":463},{},[464],{"type":192,"value":465},"架构分层与访问控制：只有特定服务 / 角色才能调用；",{"type":186,"tag":245,"props":467,"children":468},{},[469],{"type":192,"value":470},"代码评审与上线流程：危险调用往往需要多人评审、灰度、回滚预案；",{"type":186,"tag":245,"props":472,"children":473},{},[474],{"type":192,"value":475},"运行时观测与告警：异常模式会被运维体系发现。",{"type":186,"tag":195,"props":477,"children":478},{},[479],{"type":192,"value":480},"一旦通过 MCP 直接暴露给自主代理：",{"type":186,"tag":241,"props":482,"children":483},{},[484,497,502],{"type":186,"tag":245,"props":485,"children":486},{},[487,489],{"type":192,"value":488},"代理可能在看似合理的任务规划中误用这些能力：\n",{"type":186,"tag":241,"props":490,"children":491},{},[492],{"type":186,"tag":245,"props":493,"children":494},{},[495],{"type":192,"value":496},"比如「清理无效账号」被误解为「批量删除活跃用户」；",{"type":186,"tag":245,"props":498,"children":499},{},[500],{"type":192,"value":501},"我们很难用传统 ACL/鉴权表达「在这个对话/任务上下文下，哪些具体调用是可接受的」；",{"type":186,"tag":245,"props":503,"children":504},{},[505,507],{"type":192,"value":506},"缺少确定性的防线：\n",{"type":186,"tag":241,"props":508,"children":509},{},[510],{"type":186,"tag":245,"props":511,"children":512},{},[513],{"type":192,"value":514},"即使加了一些 Rule/Guardrail，也很难穷举所有危险组合，特别是在多步规划场景下。",{"type":186,"tag":195,"props":516,"children":517},{},[518,520,526],{"type":192,"value":519},"原文的关键判断是：",{"type":186,"tag":521,"props":522,"children":523},"strong",{},[524],{"type":192,"value":525},"没有可靠、确定性的方式保证代理不会误用这些端点",{"type":192,"value":527},"，安全基线无法接受。",{"type":186,"tag":234,"props":529,"children":531},{"id":530},"_3-代理性能与工程可维护性",[532],{"type":192,"value":533},"3. 代理性能与工程可维护性",{"type":186,"tag":195,"props":535,"children":536},{},[537],{"type":192,"value":538},"把低层 API 直接暴露为 MCP 工具，还会带来工程性问题：",{"type":186,"tag":241,"props":540,"children":541},{},[542,555,568],{"type":186,"tag":245,"props":543,"children":544},{},[545,547],{"type":192,"value":546},"工具爆炸：\n",{"type":186,"tag":241,"props":548,"children":549},{},[550],{"type":186,"tag":245,"props":551,"children":552},{},[553],{"type":192,"value":554},"MCP 层可能出现几十、上百个工具，增加代理工具选择复杂度；",{"type":186,"tag":245,"props":556,"children":557},{},[558,560],{"type":192,"value":559},"规划困难：\n",{"type":186,"tag":241,"props":561,"children":562},{},[563],{"type":186,"tag":245,"props":564,"children":565},{},[566],{"type":192,"value":567},"LLM 很难从一堆「原子接口」中推导出稳健的业务流程；",{"type":186,"tag":245,"props":569,"children":570},{},[571,573],{"type":192,"value":572},"调试困难：\n",{"type":186,"tag":241,"props":574,"children":575},{},[576,581],{"type":186,"tag":245,"props":577,"children":578},{},[579],{"type":192,"value":580},"排查「为什么代理做了这串调用」成本极高；",{"type":186,"tag":245,"props":582,"children":583},{},[584],{"type":192,"value":585},"很难做到稳定的回归和演进。",{"type":186,"tag":195,"props":587,"children":588},{},[589,591],{"type":192,"value":590},"结果是：",{"type":186,"tag":521,"props":592,"children":593},{},[594],{"type":192,"value":595},"看似「很能干」的代理，实际在关键场景下非常不稳定且难以调优。",{"type":186,"tag":313,"props":597,"children":598},{},[],{"type":186,"tag":227,"props":600,"children":602},{"id":601},"三建议的模式在现有-api-之上设计面向代理的-mcp-服务器",[603],{"type":192,"value":604},"三、建议的模式：在现有 API 之上设计「面向