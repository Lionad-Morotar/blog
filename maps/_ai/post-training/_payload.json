,"toc":384},"root",[183,191,198,204,235,241,246,273,279,284,311,317,322,333,339,344,362,368,373],{"type":184,"tag":185,"props":186,"children":188},"element","h1",{"id":187},"后训练-post-training",[189],{"type":190,"value":179},"text",{"type":184,"tag":192,"props":193,"children":195},"h2",{"id":194},"dpo直接偏好优化的对齐革命",[196],{"type":190,"value":197},"DPO：直接偏好优化的对齐革命",{"type":184,"tag":199,"props":200,"children":201},"p",{},[202],{"type":190,"value":203},"DPO（Direct Preference Optimization）将 RLHF 的两阶段流程（训练 Reward Model + PPO 优化）压缩为单阶段。它直接在偏好数据上优化策略，数学上等价于带 KL 约束的 RL，但实现更简单、训练更稳定。无需强化学习，只需监督学习即可完成对齐，大大降低了后训练门槛。",{"type":184,"tag":199,"props":205,"children":206},{},[207,209,218,220,227,228],{"type":190,"value":208},"见：",{"type":184,"tag":210,"props":211,"children":215},"a",{"href":212,"rel":213},"https://arxiv.org/abs/2305.18290",[214],"nofollow",[216],{"type":190,"value":217},"DPO 论文",{"type":190,"value":219}," | ",{"type":184,"tag":210,"props":221,"children":224},{"href":222,"rel":223},"https://cameronrwolfe.substack.com/p/direct-preference-optimization",[214],[225],{"type":190,"value":226},"DPO 详解 - Deep Learning Focus",{"type":190,"value":219},{"type":184,"tag":210,"props":229,"children":232},{"href":230,"rel":231},"https://www.philschmid.de/rl-with-llms-in-2025-dpo",[214],[233],{"type":190,"value":234},"2025 DPO 对齐指南",{"type":184,"tag":192,"props":236,"children":238},{"id":237},"grpodeepseek-r1-的推理突破关键",[239],{"type":190,"value":240},"GRPO：DeepSeek-R1 的推理突破关键",{"type":184,"tag":199,"props":242,"children":243},{},[244],{"type":190,"value":245},"GRPO（Group Relative Policy Optimization）是 DeepSeek-R1 实现 reasoning 能力突破的核心技术。与传统 PPO 需要独立的 Critic 模型不同，GRPO 通过组内采样估计 baseline——对同一问题生成多组回答，以组内得分的相对排名作为优势估计，显存开销降低 50%，让超长思维链（Chain-of-Thought）的训练成为可能。",{"type":184,"tag":199,"props":247,"children":248},{},[249,250,257,258,265,266],{"type":190,"value":208},{"type":184,"tag":210,"props":251,"children":254},{"href":252,"rel":253},"https://arxiv.org/pdf/2501.12948",[214],[255],{"type":190,"value":256},"DeepSeek-R1 技术报告",{"type":190,"value":219},{"type":184,"tag":210,"props":259,"children":262},{"href":260,"rel":261},"https://medium.com/@sahin.samia/the-math-behind-deepseek-a-deep-dive-into-group-relative-policy-optimization-grpo-8a75007491ba",[214],[263],{"type":190,"value":264},"GRPO 数学原理",{"type":190,"value":219},{"type":184,"tag":210,"props":267,"children":270},{"href":268,"rel":269},"https://unsloth.ai/blog/r1-reasoning",[214],[271],{"type":190,"value":272},"Unsloth GRPO 本地训练",{"type":184,"tag":192,"props":274,"children":276},{"id":275},"orposft-与对齐的合并",[277],{"type":190,"value":278},"ORPO：SFT 与对齐的合并",{"type":184,"tag":199,"props":280,"children":281},{},[282],{"type":190,"value":283},"ORPO（Odds Ratio Preference Optimization）将传统两阶段流程（先 SFT 再 DPO）合并为单阶段。它用一个损失函数同时优化指令跟随和偏好对齐，训练效率提升一倍，且无需参考模型。这是目前最高效的后训练方法之一。",{"type":184,"tag":199,"props":285,"children":286},{},[287,288,295,296,303,304],{"type":190,"value":208},{"type":184,"tag":210,"props":289,"children":292},{"href":290,"rel":291},"https://arxiv.org/abs/2403.07691",[214],[293],{"type":190,"value":294},"ORPO 论文",{"type":190,"value":219},{"type":184,"tag":210,"props":297,"children":300},{"href":298,"rel":299},"https://huggingface.co/docs/trl/en/orpo_trainer",[214],[301],{"type":190,"value":302},"Hugging Face ORPO Trainer",{"type":190,"value":219},{"type":184,"tag":210,"props":305,"children":308},{"href":306,"rel":307},"https://www.analyticsvidhya.com/blog/2024/05/finetuning-llama-3-with-odds-ratio-preference-optimization/",[214],[309],{"type":190,"value":310},"Llama 3 ORPO 微调",{"type":184,"tag":192,"props":312,"children":314},{"id":313},"simpo更简单直接的偏好优化",[315],{"type":190,"value":316},"SimPO：更简单直接的偏好优化",{"type":184,"tag":199,"props":318,"children":319},{},[320],{"type":190,"value":321},"SimPO 进一步简化 DPO，移除参考模型，直接优化响应间的胜率。它引入\"长度归一化\"，避免模型生成冗长但空洞的回复，是对 DPO 的实用改进。",{"type":184,"tag":199,"props":323,"children":324},{},[325,326],{"type":190,"value":208},{"type":184,"tag":210,"props":327,"children":330},{"href":328,"rel":329},"https://huggingface.co/docs/trl/en/index",[214],[331],{"type":190,"value":332},"SimPO 介绍",{"type":184,"tag":192,"props":334,"children":336},{"id":335},"trl后训练的一站式解决方案",[337],{"type":190,"value":338},"TRL：后训练的一站式解决方案",{"type":184,"tag":199,"props":340,"children":341},{},[342],{"type":190,"value":343},"TRL（Transformer Reinforcement Learning）是 Hugging Face 生态中的后训练全栈库，集成 SFT、DPO、PPO、GRPO、Reward Modeling 等方法。它与 transformers、peft、datasets 无缝协作，是入门后训练的首选工具。",{"type":184,"tag":199,"props":345,"children":346},{},[347,348,355,356],{"type":190,"value":208},{"type":184,"tag":210,"props":349,"children":352},{"href":350,"rel":351},"https://github.com/huggingface/trl",[214],[353],{"type":190,"value":354},"TRL GitHub",{"type":190,"value":219},{"type":184,"tag":210,"props":357,"children":359},{"href":328,"rel":358},[214],[360],{"type":190,"value":361},"TRL 文档",{"type":184,"tag":192,"props":363,"children":365},{"id":364},"后训练最佳实践数据质量-数量",[366],{"type":190,"value":367},"后训练最佳实践：数据质量 > 数量",{"type":184,"tag":199,"props":369,"children":370},{},[371],{"type":190,"value":372},"偏好对的质量远胜于数量——1000 条精心标注的偏好对 > 10000 条噪声数据。推荐流程：冷启动（高质量 SFT 建立基础指令跟随能力）→ 多轮对齐（SFT → DPO → RL，逐步逼近目标分布）→ 能力保持（定期在基础能力测试集上评估，防止对齐税）。",{"type":184,"tag":199,"props":374,"children":375},{},[376,377],{"type":190,"value":208},{"type":184,"tag":210,"props":378,"children":381},{"href":379,"rel":380},"https://www.53ai.com/news/finetuning/2026010417029.html",[214],[382],{"type":190,"value":383},"LLM 微调全指南",{"title":178,"searchDepth":385,"depth":385,"links":386},2,[387,388,389,390,391,392],{"id":194,"depth":385,"text":197},{"id":237,"depth":385,"text":240},{"id":275,"depth":385,"text":278},{"id":313,"depth":385,"text":316},{"id":335,"depth":385,"text":338},{"id":364,"depth":385,"text":367},"markdown","content:6.maps:_ai:post-training.md","content","6.maps/_ai/post-training.md","6.maps/_ai/post-training","md",[400,403],{"_path":401,"title":402,"description":178},"/maps/_ai/paper-writing","ML 论文写作 (ML Paper Writing)",{"_path":404,"title":405,"description":178},"/maps/_ai/prompt-engineering","提示工程 (Prompt Engineering)",1771521532358]