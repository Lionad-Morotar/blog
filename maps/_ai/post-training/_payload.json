6,281,308,314,319,330,336,341,359,365,370],{"type":181,"tag":182,"props":183,"children":185},"element","h1",{"id":184},"后训练-post-training",[186],{"type":187,"value":176},"text",{"type":181,"tag":189,"props":190,"children":192},"h2",{"id":191},"dpo直接偏好优化的对齐革命",[193],{"type":187,"value":194},"DPO：直接偏好优化的对齐革命",{"type":181,"tag":196,"props":197,"children":198},"p",{},[199],{"type":187,"value":200},"DPO（Direct Preference Optimization）将 RLHF 的两阶段流程（训练 Reward Model + PPO 优化）压缩为单阶段。它直接在偏好数据上优化策略，数学上等价于带 KL 约束的 RL，但实现更简单、训练更稳定。无需强化学习，只需监督学习即可完成对齐，大大降低了后训练门槛。",{"type":181,"tag":196,"props":202,"children":203},{},[204,206,215,217,224,225],{"type":187,"value":205},"见：",{"type":181,"tag":207,"props":208,"children":212},"a",{"href":209,"rel":210},"https://arxiv.org/abs/2305.18290",[211],"nofollow",[213],{"type":187,"value":214},"DPO 论文",{"type":187,"value":216}," | ",{"type":181,"tag":207,"props":218,"children":221},{"href":219,"rel":220},"https://cameronrwolfe.substack.com/p/direct-preference-optimization",[211],[222],{"type":187,"value":223},"DPO 详解 - Deep Learning Focus",{"type":187,"value":216},{"type":181,"tag":207,"props":226,"children":229},{"href":227,"rel":228},"https://www.philschmid.de/rl-with-llms-in-2025-dpo",[211],[230],{"type":187,"value":231},"2025 DPO 对齐指南",{"type":181,"tag":189,"props":233,"children":235},{"id":234},"grpodeepseek-r1-的推理突破关键",[236],{"type":187,"value":237},"GRPO：DeepSeek-R1 的推理突破关键",{"type":181,"tag":196,"props":239,"children":240},{},[241],{"type":187,"value":242},"GRPO（Group Relative Policy Optimization）是 DeepSeek-R1 实现 reasoning 能力突破的核心技术。与传统 PPO 需要独立的 Critic 模型不同，GRPO 通过组内采样估计 baseline——对同一问题生成多组回答，以组内得分的相对排名作为优势估计，显存开销降低 50%，让超长思维链（Chain-of-Thought）的训练成为可能。",{"type":181,"tag":196,"props":244,"children":245},{},[246,247,254,255,262,263],{"type":187,"value":205},{"type":181,"tag":207,"props":248,"children":251},{"href":249,"rel":250},"https://arxiv.org/pdf/2501.12948",[211],[252],{"type":187,"value":253},"DeepSeek-R1 技术报告",{"type":187,"value":216},{"type":181,"tag":207,"props":256,"children":259},{"href":257,"rel":258},"https://medium.com/@sahin.samia/the-math-behind-deepseek-a-deep-dive-into-group-relative-policy-optimization-grpo-8a75007491ba",[211],[260],{"type":187,"value":261},"GRPO 数学原理",{"type":187,"value":216},{"type":181,"tag":207,"props":264,"children":267},{"href":265,"rel":266},"https://unsloth.ai/blog/r1-reasoning",[211],[268],{"type":187,"value":269},"Unsloth GRPO 本地训练",{"type":181,"tag":189,"props":271,"children":273},{"id":272},"orposft-与对齐的合并",[274],{"type":187,"value":275},"ORPO：SFT 与对齐的合并",{"type":181,"tag":196,"props":277,"children":278},{},[279],{"type":187,"value":280},"ORPO（Odds Ratio Preference Optimization）将传统两阶段流程（先 SFT 再 DPO）合并为单阶段。它用一个损失函数同时优化指令跟随和偏好对齐，训练效率提升一倍，且无需参考模型。这是目前最高效的后训练方法之一。",{"type":181,"tag":196,"props":282,"children":283},{},[284,285,292,293,300,301],{"type":187,"value":205},{"type":181,"tag":207,"props":286,"children":289},{"href":287,"rel":288},"https://arxiv.org/abs/2403.07691",[211],[290],{"type":187,"value":291},"ORPO 论文",{"type":187,"value":216},{"type":181,"tag":207,"props":294,"children":297},{"href":295,"rel":296},"https://huggingface.co/docs/trl/en/orpo_trainer",[211],[298],{"type":187,"value":299},"Hugging Face ORPO Trainer",{"type":187,"value":216},{"type":181,"tag":207,"props":302,"children":305},{"href":303,"rel":304},"https://www.analyticsvidhya.com/blog/2024/05/finetuning-llama-3-with-odds-ratio-preference-optimization/",[211],[306],{"type":187,"value":307},"Llama 3 ORPO 微调",{"type":181,"tag":189,"props":309,"children":311},{"id":310},"simpo更简单直接的偏好优化",[312],{"type":187,"value":313},"SimPO：更简单直接的偏好优化",{"type":181,"tag":196,"props":315,"children":316},{},[317],{"type":187,"value":318},"SimPO 进一步简化 DPO，移除参考模型，直接优化响应间的胜率。它引入\"长度归一化\"，避免模型生成冗长但空洞的回复，是对 DPO 的实用改进。",{"type":181,"tag":196,"props":320,"children":321},{},[322,323],{"type":187,"value":205},{"type":181,"tag":207,"props":324,"children":327},{"href":325,"rel":326},"https://huggingface.co/docs/trl/en/index",[211],[328],{"type":187,"value":329},"SimPO 介绍",{"type":181,"tag":189,"props":331,"children":333},{"id":332},"trl后训练的一站式解决方案",[334],{"type":187,"value":335},"TRL：后训练的一站式解决方案",{"type":181,"tag":196,"props":337,"children":338},{},[339],{"type":187,"value":340},"TRL（Transformer Reinforcement Learning）是 Hugging Face 生态中的后训练全栈库，集成 SFT、DPO、PPO、GRPO、Reward Modeling 等方法。它与 transformers、peft、datasets 无缝协作，是入门后训练的首选工具。",{"type":181,"tag":196,"props":342,"children":343},{},[344,345,352,353],{"type":187,"value":205},{"type":181,"tag":207,"props":346,"children":349},{"href":347,"rel":348},"https://github.com/huggingface/trl",[211],[350],{"type":187,"value":351},"TRL GitHub",{"type":187,"value":216},{"type":181,"tag":207,"props":354,"children":356},{"href":325,"rel":355},[211],[357],{"type":187,"value":358},"TRL 文档",{"type":181,"tag":189,"props":360,"children":362},{"id":361},"后训练最佳实践数据质量-数量",[363],{"type":187,"value":364},"后训练最佳实践：数据质量 > 数量",{"type":181,"tag":196,"props":366,"children":367},{},[368],{"type":187,"value":369},"偏好对的质量远胜于数量——1000 条精心标注的偏好对 > 10000 条噪声数据。推荐流程：冷启动（高质量 SFT 建立基础指令跟随能力）→ 多轮对齐（SFT → DPO → RL，逐步逼近目标分布）→ 能力保持（定期在基础能力测试集上评估，防止对齐税）。",{"type":181,"tag":196,"props":371,"children":372},{},[373,374],{"type":187,"value":205},{"type":181,"tag":207,"props":375,"children":378},{"href":376,"rel":377},"https://www.53ai.com/news/finetuning/2026010417029.html",[211],[379],{"type":187,"value":380},"LLM 微调全指南",{"title":175,"searchDepth":382,"depth":382,"links":383},2,[384,385,386,387,388,389],{"id":191,"depth":382,"text":194},{"id":234,"depth":382,"text":237},{"id":272,"depth":382,"text":275},{"id":310,"depth":382,"text":313},{"id":332,"depth":382,"text":335},{"id":361,"depth":382,"text":364},"markdown","content:6.maps:_ai:post-training.md","content","6.maps/_ai/post-training.md","6.maps/_ai/post-training","md",[397,400],{"_path":398,"title":399,"description":175},"/maps/_ai/paper-writing","ML 论文写作 (ML Paper Writing)",{"_path":401,"title":402,"description":175},"/maps/_ai/prompt-engineering","提示工程 (Prompt Engineering)",1771264679730]