2,"toc":370},"root",[183,191,198,204,235,241,246,273,279,284,311,317,322,341,346,351],{"type":184,"tag":185,"props":186,"children":188},"element","h1",{"id":187},"分布式-distributed-training",[189],{"type":190,"value":179},"text",{"type":184,"tag":192,"props":193,"children":195},"h2",{"id":194},"deepspeedzero-优化器的显存革命",[196],{"type":190,"value":197},"DeepSpeed：ZeRO 优化器的显存革命",{"type":184,"tag":199,"props":200,"children":201},"p",{},[202],{"type":190,"value":203},"DeepSpeed 是微软开源的深度学习优化库，核心是 ZeRO（Zero Redundancy Optimizer）技术。通过三个阶段逐步释放显存压力：ZeRO-1 优化器状态分片节省 4x 显存，ZeRO-2 梯度分片再节省 2x，ZeRO-3 参数分片再节省 2x 并支持单卡加载超大模型。它是训练 100B+ 参数模型的首选方案，支持流水线并行、张量并行与 ZeRO 的组合。",{"type":184,"tag":199,"props":205,"children":206},{},[207,209,218,220,227,228],{"type":190,"value":208},"见：",{"type":184,"tag":210,"props":211,"children":215},"a",{"href":212,"rel":213},"https://github.com/deepspeedai/DeepSpeed",[214],"nofollow",[216],{"type":190,"value":217},"DeepSpeed GitHub",{"type":190,"value":219}," | ",{"type":184,"tag":210,"props":221,"children":224},{"href":222,"rel":223},"https://www.microsoft.com/en-us/research/blog/zero-deepspeed-new-system-optimizations-enable-training-models-with-over-100-billion-parameters/",[214],[225],{"type":190,"value":226},"ZeRO 论文",{"type":190,"value":219},{"type":184,"tag":210,"props":229,"children":232},{"href":230,"rel":231},"https://www.deepspeed.ai/",[214],[233],{"type":190,"value":234},"DeepSpeed 官网",{"type":184,"tag":192,"props":236,"children":238},{"id":237},"fsdppytorch-原生全分片数据并行",[239],{"type":190,"value":240},"FSDP：PyTorch 原生全分片数据并行",{"type":184,"tag":199,"props":242,"children":243},{},[244],{"type":190,"value":245},"FSDP（Fully Sharded Data Parallel）是 PyTorch 官方的大模型分布式方案，设计理念与 DeepSpeed ZeRO-3 类似，但集成更紧密。它将模型参数、梯度和优化器状态分片到多个 GPU 上，在保持通信开销不变的同时显著降低单卡内存占用。API 简洁，与 PyTorch 生态无缝集成，适合快速迭代的研究场景。",{"type":184,"tag":199,"props":247,"children":248},{},[249,250,257,258,265,266],{"type":190,"value":208},{"type":184,"tag":210,"props":251,"children":254},{"href":252,"rel":253},"https://docs.pytorch.org/tutorials/intermediate/FSDP_advanced_tutorial.html",[214],[255],{"type":190,"value":256},"PyTorch FSDP 文档",{"type":190,"value":219},{"type":184,"tag":210,"props":259,"children":262},{"href":260,"rel":261},"https://pytorch.org/blog/introducing-pytorch-fully-sharded-data-parallel-api/",[214],[263],{"type":190,"value":264},"FSDP 介绍",{"type":190,"value":219},{"type":184,"tag":210,"props":267,"children":270},{"href":268,"rel":269},"https://huggingface.co/docs/accelerate/en/concept_guides/fsdp_and_deepspeed",[214],[271],{"type":190,"value":272},"FSDP vs DeepSpeed 对比",{"type":184,"tag":192,"props":274,"children":276},{"id":275},"megatron-core万亿参数模型的训练框架",[277],{"type":190,"value":278},"Megatron-Core：万亿参数模型的训练框架",{"type":184,"tag":199,"props":280,"children":281},{},[282],{"type":190,"value":283},"Megatron-Core 是 NVIDIA 专为万亿参数模型设计的训练框架，提供张量并行（层内切分，适合单节点多卡）、流水线并行（层间切分，适合多节点）、序列并行（长序列场景降低激活显存）的原生实现。通过 8 路张量并行和 8 路流水线并行，可在 1024 张 A100 上训练 175B 参数的 GPT-3 模型。",{"type":184,"tag":199,"props":285,"children":286},{},[287,288,295,296,303,304],{"type":190,"value":208},{"type":184,"tag":210,"props":289,"children":292},{"href":290,"rel":291},"https://github.com/NVIDIA/Megatron-LM",[214],[293],{"type":190,"value":294},"Megatron-LM GitHub",{"type":190,"value":219},{"type":184,"tag":210,"props":297,"children":300},{"href":298,"rel":299},"https://docs.nvidia.com/megatron-core/developer-guide/latest/user-guide/parallelism-guide.html",[214],[301],{"type":190,"value":302},"Megatron 并行策略指南",{"type":190,"value":219},{"type":184,"tag":210,"props":305,"children":308},{"href":306,"rel":307},"https://developer.nvidia.com/blog/scaling-language-model-training-to-a-trillion-parameters-using-megatron/",[214],[309],{"type":190,"value":310},"万亿参数训练",{"type":184,"tag":192,"props":312,"children":314},{"id":313},"acceleratehugging-face-分布式封装",[315],{"type":190,"value":316},"Accelerate：Hugging Face 分布式封装",{"type":184,"tag":199,"props":318,"children":319},{},[320],{"type":190,"value":321},"Accelerate 是 Hugging Face 提供的分布式训练封装库，让单卡代码几乎零改动扩展到多卡/多机。只需几行代码即可完成模型、优化器、数据加载器的分布式准备。支持 DeepSpeed、FSDP、Megatron 等多种后端，提供统一的配置界面，是研究实验快速迭代的利器。",{"type":184,"tag":199,"props":323,"children":324},{},[325,326,333,334],{"type":190,"value":208},{"type":184,"tag":210,"props":327,"children":330},{"href":328,"rel":329},"https://huggingface.co/docs/accelerate/index",[214],[331],{"type":190,"value":332},"Accelerate 文档",{"type":190,"value":219},{"type":184,"tag":210,"props":335,"children":338},{"href":336,"rel":337},"https://github.com/huggingface/accelerate",[214],[339],{"type":190,"value":340},"Accelerate GitHub",{"type":184,"tag":192,"props":342,"children":344},{"id":343},"分布式训练选择指南",[345],{"type":190,"value":343},{"type":184,"tag":199,"props":347,"children":348},{},[349],{"type":190,"value":350},"模型规模决定并行策略：\u003C 7B 单卡或 DDP 足够，7B-70B 使用 FSDP 或 DeepSpeed ZeRO-3，70B+ 需要 Megatron-Core 配合多种并行组合。场景偏好：研究/实验推荐 Accelerate + FSDP 快速迭代，生产部署选择 DeepSpeed 功能全面，超大规模训练使用 Megatron-Core 配合 NVIDIA 优化。",{"type":184,"tag":199,"props":352,"children":353},{},[354,355,362,363],{"type":190,"value":208},{"type":184,"tag":210,"props":356,"children":359},{"href":357,"rel":358},"https://sumanthrh.com/post/distributed-and-efficient-finetuning/",[214],[360],{"type":190,"value":361},"分布式训练完整指南",{"type":190,"value":219},{"type":184,"tag":210,"props":364,"children":367},{"href":365,"rel":366},"https://llamafactory.readthedocs.io/en/latest/advanced/distributed.html",[214],[368],{"type":190,"value":369},"LLaMA-Factory 分布式",{"title":178,"searchDepth":371,"depth":371,"links":372},2,[373,374,375,376,377],{"id":194,"depth":371,"text":197},{"id":237,"depth":371,"text":240},{"id":275,"depth":371,"text":278},{"id":313,"depth":371,"text":316},{"id":343,"depth":371,"text":343},"markdown","content:6.maps:_ai:distributed.md","content","6.maps/_ai/distributed.md","6.maps/_ai/distributed","md",[385,388],{"_path":386,"title":387,"description":178},"/maps/_ai/data-processing","数据处理 (Data Processing)",{"_path":389,"title":390,"description":178},"/maps/_ai/emerging","新兴技术 (Emerging Technologies)",1771521533787]