76,281,308,314,319,338,343,348],{"type":181,"tag":182,"props":183,"children":185},"element","h1",{"id":184},"分布式-distributed-training",[186],{"type":187,"value":176},"text",{"type":181,"tag":189,"props":190,"children":192},"h2",{"id":191},"deepspeedzero-优化器的显存革命",[193],{"type":187,"value":194},"DeepSpeed：ZeRO 优化器的显存革命",{"type":181,"tag":196,"props":197,"children":198},"p",{},[199],{"type":187,"value":200},"DeepSpeed 是微软开源的深度学习优化库，核心是 ZeRO（Zero Redundancy Optimizer）技术。通过三个阶段逐步释放显存压力：ZeRO-1 优化器状态分片节省 4x 显存，ZeRO-2 梯度分片再节省 2x，ZeRO-3 参数分片再节省 2x 并支持单卡加载超大模型。它是训练 100B+ 参数模型的首选方案，支持流水线并行、张量并行与 ZeRO 的组合。",{"type":181,"tag":196,"props":202,"children":203},{},[204,206,215,217,224,225],{"type":187,"value":205},"见：",{"type":181,"tag":207,"props":208,"children":212},"a",{"href":209,"rel":210},"https://github.com/deepspeedai/DeepSpeed",[211],"nofollow",[213],{"type":187,"value":214},"DeepSpeed GitHub",{"type":187,"value":216}," | ",{"type":181,"tag":207,"props":218,"children":221},{"href":219,"rel":220},"https://www.microsoft.com/en-us/research/blog/zero-deepspeed-new-system-optimizations-enable-training-models-with-over-100-billion-parameters/",[211],[222],{"type":187,"value":223},"ZeRO 论文",{"type":187,"value":216},{"type":181,"tag":207,"props":226,"children":229},{"href":227,"rel":228},"https://www.deepspeed.ai/",[211],[230],{"type":187,"value":231},"DeepSpeed 官网",{"type":181,"tag":189,"props":233,"children":235},{"id":234},"fsdppytorch-原生全分片数据并行",[236],{"type":187,"value":237},"FSDP：PyTorch 原生全分片数据并行",{"type":181,"tag":196,"props":239,"children":240},{},[241],{"type":187,"value":242},"FSDP（Fully Sharded Data Parallel）是 PyTorch 官方的大模型分布式方案，设计理念与 DeepSpeed ZeRO-3 类似，但集成更紧密。它将模型参数、梯度和优化器状态分片到多个 GPU 上，在保持通信开销不变的同时显著降低单卡内存占用。API 简洁，与 PyTorch 生态无缝集成，适合快速迭代的研究场景。",{"type":181,"tag":196,"props":244,"children":245},{},[246,247,254,255,262,263],{"type":187,"value":205},{"type":181,"tag":207,"props":248,"children":251},{"href":249,"rel":250},"https://docs.pytorch.org/tutorials/intermediate/FSDP_advanced_tutorial.html",[211],[252],{"type":187,"value":253},"PyTorch FSDP 文档",{"type":187,"value":216},{"type":181,"tag":207,"props":256,"children":259},{"href":257,"rel":258},"https://pytorch.org/blog/introducing-pytorch-fully-sharded-data-parallel-api/",[211],[260],{"type":187,"value":261},"FSDP 介绍",{"type":187,"value":216},{"type":181,"tag":207,"props":264,"children":267},{"href":265,"rel":266},"https://huggingface.co/docs/accelerate/en/concept_guides/fsdp_and_deepspeed",[211],[268],{"type":187,"value":269},"FSDP vs DeepSpeed 对比",{"type":181,"tag":189,"props":271,"children":273},{"id":272},"megatron-core万亿参数模型的训练框架",[274],{"type":187,"value":275},"Megatron-Core：万亿参数模型的训练框架",{"type":181,"tag":196,"props":277,"children":278},{},[279],{"type":187,"value":280},"Megatron-Core 是 NVIDIA 专为万亿参数模型设计的训练框架，提供张量并行（层内切分，适合单节点多卡）、流水线并行（层间切分，适合多节点）、序列并行（长序列场景降低激活显存）的原生实现。通过 8 路张量并行和 8 路流水线并行，可在 1024 张 A100 上训练 175B 参数的 GPT-3 模型。",{"type":181,"tag":196,"props":282,"children":283},{},[284,285,292,293,300,301],{"type":187,"value":205},{"type":181,"tag":207,"props":286,"children":289},{"href":287,"rel":288},"https://github.com/NVIDIA/Megatron-LM",[211],[290],{"type":187,"value":291},"Megatron-LM GitHub",{"type":187,"value":216},{"type":181,"tag":207,"props":294,"children":297},{"href":295,"rel":296},"https://docs.nvidia.com/megatron-core/developer-guide/latest/user-guide/parallelism-guide.html",[211],[298],{"type":187,"value":299},"Megatron 并行策略指南",{"type":187,"value":216},{"type":181,"tag":207,"props":302,"children":305},{"href":303,"rel":304},"https://developer.nvidia.com/blog/scaling-language-model-training-to-a-trillion-parameters-using-megatron/",[211],[306],{"type":187,"value":307},"万亿参数训练",{"type":181,"tag":189,"props":309,"children":311},{"id":310},"acceleratehugging-face-分布式封装",[312],{"type":187,"value":313},"Accelerate：Hugging Face 分布式封装",{"type":181,"tag":196,"props":315,"children":316},{},[317],{"type":187,"value":318},"Accelerate 是 Hugging Face 提供的分布式训练封装库，让单卡代码几乎零改动扩展到多卡/多机。只需几行代码即可完成模型、优化器、数据加载器的分布式准备。支持 DeepSpeed、FSDP、Megatron 等多种后端，提供统一的配置界面，是研究实验快速迭代的利器。",{"type":181,"tag":196,"props":320,"children":321},{},[322,323,330,331],{"type":187,"value":205},{"type":181,"tag":207,"props":324,"children":327},{"href":325,"rel":326},"https://huggingface.co/docs/accelerate/index",[211],[328],{"type":187,"value":329},"Accelerate 文档",{"type":187,"value":216},{"type":181,"tag":207,"props":332,"children":335},{"href":333,"rel":334},"https://github.com/huggingface/accelerate",[211],[336],{"type":187,"value":337},"Accelerate GitHub",{"type":181,"tag":189,"props":339,"children":341},{"id":340},"分布式训练选择指南",[342],{"type":187,"value":340},{"type":181,"tag":196,"props":344,"children":345},{},[346],{"type":187,"value":347},"模型规模决定并行策略：\u003C 7B 单卡或 DDP 足够，7B-70B 使用 FSDP 或 DeepSpeed ZeRO-3，70B+ 需要 Megatron-Core 配合多种并行组合。场景偏好：研究/实验推荐 Accelerate + FSDP 快速迭代，生产部署选择 DeepSpeed 功能全面，超大规模训练使用 Megatron-Core 配合 NVIDIA 优化。",{"type":181,"tag":196,"props":349,"children":350},{},[351,352,359,360],{"type":187,"value":205},{"type":181,"tag":207,"props":353,"children":356},{"href":354,"rel":355},"https://sumanthrh.com/post/distributed-and-efficient-finetuning/",[211],[357],{"type":187,"value":358},"分布式训练完整指南",{"type":187,"value":216},{"type":181,"tag":207,"props":361,"children":364},{"href":362,"rel":363},"https://llamafactory.readthedocs.io/en/latest/advanced/distributed.html",[211],[365],{"type":187,"value":366},"LLaMA-Factory 分布式",{"title":175,"searchDepth":368,"depth":368,"links":369},2,[370,371,372,373,374],{"id":191,"depth":368,"text":194},{"id":234,"depth":368,"text":237},{"id":272,"depth":368,"text":275},{"id":310,"depth":368,"text":313},{"id":340,"depth":368,"text":340},"markdown","content:6.maps:_ai:distributed.md","content","6.maps/_ai/distributed.md","6.maps/_ai/distributed","md",[382,385],{"_path":383,"title":384,"description":175},"/maps/_ai/data-processing","数据处理 (Data Processing)",{"_path":386,"title":387,"description":175},"/maps/_ai/emerging","新兴技术 (Emerging Technologies)",1771264681032]