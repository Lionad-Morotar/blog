2,287,306,312,317,336,342,347,358,364,369],{"type":181,"tag":182,"props":183,"children":185},"element","h1",{"id":184},"多模态-multimodal",[186],{"type":187,"value":176},"text",{"type":181,"tag":189,"props":190,"children":192},"h2",{"id":191},"gpt-4o端到端多模态标杆",[193],{"type":187,"value":194},"GPT-4o：端到端多模态标杆",{"type":181,"tag":196,"props":197,"children":198},"p",{},[199],{"type":187,"value":200},"GPT-4o 是 OpenAI 的端到端多模态模型，\"o\"代表 Omni（全能）。不同于传统的拼接式架构，它在单一神经网络中统一处理文本、图像、音频，实现真正的跨模态理解和生成。在视觉理解、数学推理、语言理解等基准上全面领先，是 2025 年商业多模态模型的事实标准。",{"type":181,"tag":196,"props":202,"children":203},{},[204,206,215,217],{"type":187,"value":205},"见：",{"type":181,"tag":207,"props":208,"children":212},"a",{"href":209,"rel":210},"https://openai.com/index/hello-gpt-4o/",[211],"nofollow",[213],{"type":187,"value":214},"GPT-4o 技术报告",{"type":187,"value":216}," | ",{"type":181,"tag":207,"props":218,"children":221},{"href":219,"rel":220},"https://www.linkedin.com/pulse/gpt-4o-vs-google-gemini-ultimate-ai-showdown-2025-gary-fowler-octpe",[211],[222],{"type":187,"value":223},"GPT-4o vs Gemini 对比",{"type":181,"tag":189,"props":225,"children":227},{"id":226},"gemini-15-pro长上下文多模态王者",[228],{"type":187,"value":229},"Gemini 1.5 Pro：长上下文多模态王者",{"type":181,"tag":196,"props":231,"children":232},{},[233],{"type":187,"value":234},"Google DeepMind 的 Gemini 1.5 Pro 支持百万级 Token 上下文，可一次性处理数小时视频、整本书籍或多张高分辨率图像。采用 Mixture-of-Experts (MoE) 架构，在多模态推理和长文档理解上表现优异，是企业级多模态应用的首选。",{"type":181,"tag":196,"props":236,"children":237},{},[238,239],{"type":187,"value":205},{"type":181,"tag":207,"props":240,"children":243},{"href":241,"rel":242},"https://deepmind.google/technologies/gemini/pro/",[211],[244],{"type":187,"value":245},"Gemini 1.5 Pro 技术报告",{"type":181,"tag":189,"props":247,"children":249},{"id":248},"qwen25-vl开源视觉语言模型领先者",[250],{"type":187,"value":251},"Qwen2.5-VL：开源视觉语言模型领先者",{"type":181,"tag":196,"props":253,"children":254},{},[255],{"type":187,"value":256},"阿里云的 Qwen2.5-VL 系列是开源视觉语言模型的标杆，覆盖 3B 到 72B 参数规模。支持图像、视频、文档理解，在 OCR、图表解析、视觉推理等任务上媲美商业模型。2025 年推出的 Qwen3-VL 进一步提升了多模态推理能力，是开源社区的首选方案。",{"type":181,"tag":196,"props":258,"children":259},{},[260,261,268,269],{"type":187,"value":205},{"type":181,"tag":207,"props":262,"children":265},{"href":263,"rel":264},"https://github.com/QwenLM/Qwen2.5-VL",[211],[266],{"type":187,"value":267},"Qwen2.5-VL GitHub",{"type":187,"value":216},{"type":181,"tag":207,"props":270,"children":273},{"href":271,"rel":272},"https://www.bentoml.com/blog/multimodal-ai-a-guide-to-open-source-vision-language-models",[211],[274],{"type":187,"value":275},"Qwen3-VL 介绍",{"type":181,"tag":189,"props":277,"children":279},{"id":278},"llava-next学术界的开源先锋",[280],{"type":187,"value":281},"LLaVA-NeXT：学术界的开源先锋",{"type":181,"tag":196,"props":283,"children":284},{},[285],{"type":187,"value":286},"LLaVA（Large Language and Vision Assistant）将 CLIP 视觉编码器与 LLM 连接，开创了开源视觉问答的先河。LLaVA-NeXT 支持更高分辨率（336x336+）、多帧视频理解、LoRA 微调。2025 年的 LLaVA-OneVision 进一步优化了视频理解能力，是学术研究和快速原型开发的首选。",{"type":181,"tag":196,"props":288,"children":289},{},[290,291,298,299],{"type":187,"value":205},{"type":181,"tag":207,"props":292,"children":295},{"href":293,"rel":294},"https://github.com/LLaVA-VL/LLaVA-NeXT",[211],[296],{"type":187,"value":297},"LLaVA-NeXT GitHub",{"type":187,"value":216},{"type":181,"tag":207,"props":300,"children":303},{"href":301,"rel":302},"https://arxiv.org/html/2509.23661v3",[211],[304],{"type":187,"value":305},"LLaVA-OneVision 论文",{"type":181,"tag":189,"props":307,"children":309},{"id":308},"生成模型stable-diffusion-与-audiocraft",[310],{"type":187,"value":311},"生成模型：Stable Diffusion 与 AudioCraft",{"type":181,"tag":196,"props":313,"children":314},{},[315],{"type":187,"value":316},"Stable Diffusion 3 是开源文本到图像生成的标杆，采用改进的 Diffusion 架构，支持 ControlNet 可控生成和 LoRA 快速定制。AudioCraft 是 Meta 的音频生成套件，包含 MusicGen（文本生成音乐）、AudioGen（文本生成音效）和 EnCodec（神经音频编解码），开源了完整的音频生成流程。",{"type":181,"tag":196,"props":318,"children":319},{},[320,321,328,329],{"type":187,"value":205},{"type":181,"tag":207,"props":322,"children":325},{"href":323,"rel":324},"https://stability.ai/",[211],[326],{"type":187,"value":327},"Stable Diffusion",{"type":187,"value":216},{"type":181,"tag":207,"props":330,"children":333},{"href":331,"rel":332},"https://github.com/facebookresearch/audiocraft",[211],[334],{"type":187,"value":335},"AudioCraft GitHub",{"type":181,"tag":189,"props":337,"children":339},{"id":338},"语音识别whisper",[340],{"type":187,"value":341},"语音识别：Whisper",{"type":181,"tag":196,"props":343,"children":344},{},[345],{"type":187,"value":346},"OpenAI 的 Whisper 是开源语音识别的标杆，支持 99 种语言的多语言语音识别和语音翻译。鲁棒性优异，能处理口音、背景噪音和技术术语。v3 版本进一步提升了多语言性能和推理速度，是语音应用的基础设施。",{"type":181,"tag":196,"props":348,"children":349},{},[350,351],{"type":187,"value":205},{"type":181,"tag":207,"props":352,"children":355},{"href":353,"rel":354},"https://github.com/openai/whisper",[211],[356],{"type":187,"value":357},"Whisper GitHub",{"type":181,"tag":189,"props":359,"children":361},{"id":360},"多模态-rag-与-agent",[362],{"type":187,"value":363},"多模态 RAG 与 Agent",{"type":181,"tag":196,"props":365,"children":366},{},[367],{"type":187,"value":368},"多模态与 RAG、Agent 结合是 2025 年的前沿方向。CLIP 和向量数据库实现图像语义检索，Qwen2.5-VL 和 GPT-4o 实现视觉感知 Agent，可处理 UI 自动化、文档分析、视频监控等复杂任务。",{"type":181,"tag":196,"props":370,"children":371},{},[372,373,380,381],{"type":187,"value":205},{"type":181,"tag":207,"props":374,"children":377},{"href":375,"rel":376},"https://arxiv.org/html/2507.01925v1",[211],[378],{"type":187,"value":379},"Vision-Language-Action Models 综述",{"type":187,"value":216},{"type":181,"tag":207,"props":382,"children":385},{"href":383,"rel":384},"https://blog.csdn.net/qq_51175703/article/details/148561284",[211],[386],{"type":187,"value":387},"多模态学习路线",{"title":175,"searchDepth":389,"depth":389,"links":390},2,[391,392,393,394,395,396,397],{"id":191,"depth":389,"text":194},{"id":226,"depth":389,"text":229},{"id":248,"depth":389,"text":251},{"id":278,"depth":389,"text":281},{"id":308,"depth":389,"text":311},{"id":338,"depth":389,"text":341},{"id":360,"depth":389,"text":363},"markdown","content:6.maps:_ai:multimodal.md","content","6.maps/_ai/multimodal.md","6.maps/_ai/multimodal","md",[405,408],{"_path":406,"title":407,"description":175},"/maps/_ai/mlops","MLOps",{"_path":409,"title":410,"description":175},"/maps/_ai/observability","可观测性 (Observability)",1771264682477]