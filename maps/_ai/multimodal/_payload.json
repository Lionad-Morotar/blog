"root",[183,191,198,204,227,233,238,249,255,260,279,285,290,309,315,320,339,345,350,361,367,372],{"type":184,"tag":185,"props":186,"children":188},"element","h1",{"id":187},"多模态-multimodal",[189],{"type":190,"value":179},"text",{"type":184,"tag":192,"props":193,"children":195},"h2",{"id":194},"gpt-4o端到端多模态标杆",[196],{"type":190,"value":197},"GPT-4o：端到端多模态标杆",{"type":184,"tag":199,"props":200,"children":201},"p",{},[202],{"type":190,"value":203},"GPT-4o 是 OpenAI 的端到端多模态模型，\"o\"代表 Omni（全能）。不同于传统的拼接式架构，它在单一神经网络中统一处理文本、图像、音频，实现真正的跨模态理解和生成。在视觉理解、数学推理、语言理解等基准上全面领先，是 2025 年商业多模态模型的事实标准。",{"type":184,"tag":199,"props":205,"children":206},{},[207,209,218,220],{"type":190,"value":208},"见：",{"type":184,"tag":210,"props":211,"children":215},"a",{"href":212,"rel":213},"https://openai.com/index/hello-gpt-4o/",[214],"nofollow",[216],{"type":190,"value":217},"GPT-4o 技术报告",{"type":190,"value":219}," | ",{"type":184,"tag":210,"props":221,"children":224},{"href":222,"rel":223},"https://www.linkedin.com/pulse/gpt-4o-vs-google-gemini-ultimate-ai-showdown-2025-gary-fowler-octpe",[214],[225],{"type":190,"value":226},"GPT-4o vs Gemini 对比",{"type":184,"tag":192,"props":228,"children":230},{"id":229},"gemini-15-pro长上下文多模态王者",[231],{"type":190,"value":232},"Gemini 1.5 Pro：长上下文多模态王者",{"type":184,"tag":199,"props":234,"children":235},{},[236],{"type":190,"value":237},"Google DeepMind 的 Gemini 1.5 Pro 支持百万级 Token 上下文，可一次性处理数小时视频、整本书籍或多张高分辨率图像。采用 Mixture-of-Experts (MoE) 架构，在多模态推理和长文档理解上表现优异，是企业级多模态应用的首选。",{"type":184,"tag":199,"props":239,"children":240},{},[241,242],{"type":190,"value":208},{"type":184,"tag":210,"props":243,"children":246},{"href":244,"rel":245},"https://deepmind.google/technologies/gemini/pro/",[214],[247],{"type":190,"value":248},"Gemini 1.5 Pro 技术报告",{"type":184,"tag":192,"props":250,"children":252},{"id":251},"qwen25-vl开源视觉语言模型领先者",[253],{"type":190,"value":254},"Qwen2.5-VL：开源视觉语言模型领先者",{"type":184,"tag":199,"props":256,"children":257},{},[258],{"type":190,"value":259},"阿里云的 Qwen2.5-VL 系列是开源视觉语言模型的标杆，覆盖 3B 到 72B 参数规模。支持图像、视频、文档理解，在 OCR、图表解析、视觉推理等任务上媲美商业模型。2025 年推出的 Qwen3-VL 进一步提升了多模态推理能力，是开源社区的首选方案。",{"type":184,"tag":199,"props":261,"children":262},{},[263,264,271,272],{"type":190,"value":208},{"type":184,"tag":210,"props":265,"children":268},{"href":266,"rel":267},"https://github.com/QwenLM/Qwen2.5-VL",[214],[269],{"type":190,"value":270},"Qwen2.5-VL GitHub",{"type":190,"value":219},{"type":184,"tag":210,"props":273,"children":276},{"href":274,"rel":275},"https://www.bentoml.com/blog/multimodal-ai-a-guide-to-open-source-vision-language-models",[214],[277],{"type":190,"value":278},"Qwen3-VL 介绍",{"type":184,"tag":192,"props":280,"children":282},{"id":281},"llava-next学术界的开源先锋",[283],{"type":190,"value":284},"LLaVA-NeXT：学术界的开源先锋",{"type":184,"tag":199,"props":286,"children":287},{},[288],{"type":190,"value":289},"LLaVA（Large Language and Vision Assistant）将 CLIP 视觉编码器与 LLM 连接，开创了开源视觉问答的先河。LLaVA-NeXT 支持更高分辨率（336x336+）、多帧视频理解、LoRA 微调。2025 年的 LLaVA-OneVision 进一步优化了视频理解能力，是学术研究和快速原型开发的首选。",{"type":184,"tag":199,"props":291,"children":292},{},[293,294,301,302],{"type":190,"value":208},{"type":184,"tag":210,"props":295,"children":298},{"href":296,"rel":297},"https://github.com/LLaVA-VL/LLaVA-NeXT",[214],[299],{"type":190,"value":300},"LLaVA-NeXT GitHub",{"type":190,"value":219},{"type":184,"tag":210,"props":303,"children":306},{"href":304,"rel":305},"https://arxiv.org/html/2509.23661v3",[214],[307],{"type":190,"value":308},"LLaVA-OneVision 论文",{"type":184,"tag":192,"props":310,"children":312},{"id":311},"生成模型stable-diffusion-与-audiocraft",[313],{"type":190,"value":314},"生成模型：Stable Diffusion 与 AudioCraft",{"type":184,"tag":199,"props":316,"children":317},{},[318],{"type":190,"value":319},"Stable Diffusion 3 是开源文本到图像生成的标杆，采用改进的 Diffusion 架构，支持 ControlNet 可控生成和 LoRA 快速定制。AudioCraft 是 Meta 的音频生成套件，包含 MusicGen（文本生成音乐）、AudioGen（文本生成音效）和 EnCodec（神经音频编解码），开源了完整的音频生成流程。",{"type":184,"tag":199,"props":321,"children":322},{},[323,324,331,332],{"type":190,"value":208},{"type":184,"tag":210,"props":325,"children":328},{"href":326,"rel":327},"https://stability.ai/",[214],[329],{"type":190,"value":330},"Stable Diffusion",{"type":190,"value":219},{"type":184,"tag":210,"props":333,"children":336},{"href":334,"rel":335},"https://github.com/facebookresearch/audiocraft",[214],[337],{"type":190,"value":338},"AudioCraft GitHub",{"type":184,"tag":192,"props":340,"children":342},{"id":341},"语音识别whisper",[343],{"type":190,"value":344},"语音识别：Whisper",{"type":184,"tag":199,"props":346,"children":347},{},[348],{"type":190,"value":349},"OpenAI 的 Whisper 是开源语音识别的标杆，支持 99 种语言的多语言语音识别和语音翻译。鲁棒性优异，能处理口音、背景噪音和技术术语。v3 版本进一步提升了多语言性能和推理速度，是语音应用的基础设施。",{"type":184,"tag":199,"props":351,"children":352},{},[353,354],{"type":190,"value":208},{"type":184,"tag":210,"props":355,"children":358},{"href":356,"rel":357},"https://github.com/openai/whisper",[214],[359],{"type":190,"value":360},"Whisper GitHub",{"type":184,"tag":192,"props":362,"children":364},{"id":363},"多模态-rag-与-agent",[365],{"type":190,"value":366},"多模态 RAG 与 Agent",{"type":184,"tag":199,"props":368,"children":369},{},[370],{"type":190,"value":371},"多模态与 RAG、Agent 结合是 2025 年的前沿方向。CLIP 和向量数据库实现图像语义检索，Qwen2.5-VL 和 GPT-4o 实现视觉感知 Agent，可处理 UI 自动化、文档分析、视频监控等复杂任务。",{"type":184,"tag":199,"props":373,"children":374},{},[375,376,383,384],{"type":190,"value":208},{"type":184,"tag":210,"props":377,"children":380},{"href":378,"rel":379},"https://arxiv.org/html/2507.01925v1",[214],[381],{"type":190,"value":382},"Vision-Language-Action Models 综述",{"type":190,"value":219},{"type":184,"tag":210,"props":385,"children":388},{"href":386,"rel":387},"https://blog.csdn.net/qq_51175703/article/details/148561284",[214],[389],{"type":190,"value":390},"多模态学习路线",{"title":178,"searchDepth":392,"depth":392,"links":393},2,[394,395,396,397,398,399,400],{"id":194,"depth":392,"text":197},{"id":229,"depth":392,"text":232},{"id":251,"depth":392,"text":254},{"id":281,"depth":392,"text":284},{"id":311,"depth":392,"text":314},{"id":341,"depth":392,"text":344},{"id":363,"depth":392,"text":366},"markdown","content:6.maps:_ai:multimodal.md","content","6.maps/_ai/multimodal.md","6.maps/_ai/multimodal","md",[408,411],{"_path":409,"title":410,"description":178},"/maps/_ai/mlops","MLOps",{"_path":412,"title":413,"description":178},"/maps/_ai/observability","可观测性 (Observability)",1771695832890]