mark","日常使用的简单基准测试","_ai/benchmark/simple.md",{"type":183,"children":184,"toc":372},"root",[185,194,200,243,248,257,263,271,276,284,289,302,309,314,327,332,338,346,359],{"type":186,"tag":187,"props":188,"children":190},"element","h4",{"id":189},"_2025-12",[191],{"type":192,"value":193},"text","2025-12",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198],{"type":192,"value":199},"使用老朋友测 Kimi K2 Thinking、GPT-5 和 DeepSeek V3.2：",{"type":186,"tag":201,"props":202,"children":203},"ul",{},[204,219,231],{"type":186,"tag":205,"props":206,"children":207},"li",{},[208,217],{"type":186,"tag":209,"props":210,"children":214},"a",{"href":211,"rel":212},"https://www.kimi.com/share/19af7152-2b22-8e9f-8000-000016cfd092",[213],"nofollow",[215],{"type":192,"value":216},"Kimi K2 Thinking",{"type":192,"value":218},"：没有展示抽象能力，但通过少量枚举，意外地找到了几组不错的答案。",{"type":186,"tag":205,"props":220,"children":221},{},[222,229],{"type":186,"tag":209,"props":223,"children":226},{"href":224,"rel":225},"https://chat.deepseek.com/share/bpg5qaiwq5fuk7addd",[213],[227],{"type":192,"value":228},"DeepSeek V3.2",{"type":192,"value":230},"：通过数万token的枚举，找到了几组不错的答案，此外衍生出了关于“含义对立”的思路。",{"type":186,"tag":205,"props":232,"children":233},{},[234,241],{"type":186,"tag":209,"props":235,"children":238},{"href":236,"rel":237},"https://www.maxai.co/share?id=a5222cc57cbc97e4830bf86724d1b1b8851ebc3d0614f2112961e160",[213],[239],{"type":192,"value":240},"GPT-5",{"type":192,"value":242},"：第一轮就找到了不错的答案，此外思路绝佳。",{"type":186,"tag":195,"props":244,"children":245},{},[246],{"type":192,"value":247},"无论我的系统提示词是什么，本地 Qwen3 Next 直接拒绝了我的任务，除非我把 GPT-5 的思路拔下来告诉他要怎么找答案。本地的 Qwen3 Next Thinking 则是花了四分钟烧掉 1w token，找到两个错误答案和一个“诺/no”。",{"type":186,"tag":195,"props":249,"children":250},{},[251],{"type":186,"tag":252,"props":253,"children":256},"img",{"alt":254,"src":255},"Local Qwen3 Next","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20251208131758762.png",[],{"type":186,"tag":187,"props":258,"children":260},{"id":259},"_2025-03",[261],{"type":192,"value":262},"2025-03",{"type":186,"tag":201,"props":264,"children":265},{},[266],{"type":186,"tag":205,"props":267,"children":268},{},[269],{"type":192,"value":270},"SVD 的全称",{"type":186,"tag":195,"props":272,"children":273},{},[274],{"type":192,"value":275},"在一个关于“教材”的变量名隐喻中，如果 SVD 中 D 的解释是 Director，那么全称可能是什么？正确答案是什么？4o、QwQ 和 Kimi 把答案导向了数学，但经过追问，话题相关低代码、组件、编译原理之类的，和数学没有关系。那么 SVD 是什么？4o 说是 Structure View Director，即数据结构视图导演。我觉得这个回答接近正确答案，而其他两个乱答。",{"type":186,"tag":195,"props":277,"children":278},{},[279],{"type":186,"tag":252,"props":280,"children":283},{"alt":281,"src":282},"翻译问题","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202503182351515.png",[],{"type":186,"tag":195,"props":285,"children":286},{},[287],{"type":192,"value":288},"GPT-4o（MaxAI）关于“billion”的翻译犯了很明显的错误。",{"type":186,"tag":201,"props":290,"children":291},{},[292],{"type":186,"tag":205,"props":293,"children":294},{},[295],{"type":186,"tag":209,"props":296,"children":299},{"href":297,"rel":298},"https://chat.qwen.ai/s/2efd38e7-c682-493b-a479-8c1f31e0a2f5",[213],[300],{"type":192,"value":301},"找到一个中文单词，和某个英文单词读音相近，但是意思完全相反 @QwQ-32B",{"type":186,"tag":195,"props":303,"children":304},{},[305],{"type":186,"tag":252,"props":306,"children":308},{"alt":178,"src":307},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202503070241843.png",[],{"type":186,"tag":195,"props":310,"children":311},{},[312],{"type":192,"value":313},"非联网。在很开头就找到了\"buy\"和\"卖\"，但是居然没有从这里推理出正确结果（尽管最终答案包含\"buy\"和\"卖\"）。继续问相同的问题，经过 2 分半的思考，找到了“爱”和“hate”，不算是可接受的答案。下次直接试试：“找十组中文单词，这些中文单词和某个英文单词的发音相近，但两者的意思完全相反”。",{"type":186,"tag":201,"props":315,"children":316},{},[317],{"type":186,"tag":205,"props":318,"children":319},{},[320],{"type":186,"tag":209,"props":321,"children":324},{"href":322,"rel":323},"https://metaso.cn/s/IpfAIch",[213],[325],{"type":192,"value":326},"如何解读：Business is Business @metaso",{"type":186,"tag":195,"props":328,"children":329},{},[330],{"type":192,"value":331},"搜索资料选的是“学术”，但是表现出乎意料的差，根本没有把握句子的意思。",{"type":186,"tag":187,"props":333,"children":335},{"id":334},"_2024-11",[336],{"type":192,"value":337},"2024-11",{"type":186,"tag":201,"props":339,"children":340},{},[341],{"type":186,"tag":205,"props":342,"children":343},{},[344],{"type":192,"value":345},"全文背诵前赤壁赋",{"type":186,"tag":201,"props":347,"children":348},{},[349,354],{"type":186,"tag":205,"props":350,"children":351},{},[352],{"type":192,"value":353},"闭源模型：gemini-pro、gpt4-turbo",{"type":186,"tag":205,"props":355,"children":356},{},[357],{"type":192,"value":358},"开源模型：llama2、qwen",{"type":186,"tag":195,"props":360,"children":361},{},[362,367],{"type":186,"tag":252,"props":363,"children":366},{"alt":364,"src":365},"llama & qwen","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202411282330132.png",[],{"type":186,"tag":252,"props":368,"children":371},{"alt":369,"src":370},"gemini-pro & gpt4-turbo","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202411282331378.png",[],{"title":178,"searchDepth":373,"depth":373,"links":374},2,[],"markdown","content:6.maps:_ai:benchmark:simple.md","content","6.maps/_ai/benchmark/simple.md","6.maps/_ai/benchmark/simple","md",[382,386],{"_path":383,"title":384,"description":385},"/maps/_ai/benchmark/cl-bench","CL-Bench","LLM 智能体持续学习基准测试框架",{"_path":387,"title":388,"description":389},"/maps/_ai/evaluation/evaluation","Evaluation","AI 系统评估与测试方法论，涵盖模型评估框架、可观测性平台和可重复性实践。",1772185506644]