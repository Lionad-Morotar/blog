196,239,244,253,259,267,272,280,285,298,305,310,323,328,334,342,355],{"type":182,"tag":183,"props":184,"children":186},"element","h4",{"id":185},"_2025-12",[187],{"type":188,"value":189},"text","2025-12",{"type":182,"tag":191,"props":192,"children":193},"p",{},[194],{"type":188,"value":195},"使用老朋友测 Kimi K2 Thinking、GPT-5 和 DeepSeek V3.2：",{"type":182,"tag":197,"props":198,"children":199},"ul",{},[200,215,227],{"type":182,"tag":201,"props":202,"children":203},"li",{},[204,213],{"type":182,"tag":205,"props":206,"children":210},"a",{"href":207,"rel":208},"https://www.kimi.com/share/19af7152-2b22-8e9f-8000-000016cfd092",[209],"nofollow",[211],{"type":188,"value":212},"Kimi K2 Thinking",{"type":188,"value":214},"：没有展示抽象能力，但通过少量枚举，意外地找到了几组不错的答案。",{"type":182,"tag":201,"props":216,"children":217},{},[218,225],{"type":182,"tag":205,"props":219,"children":222},{"href":220,"rel":221},"https://chat.deepseek.com/share/bpg5qaiwq5fuk7addd",[209],[223],{"type":188,"value":224},"DeepSeek V3.2",{"type":188,"value":226},"：通过数万token的枚举，找到了几组不错的答案，此外衍生出了关于“含义对立”的思路。",{"type":182,"tag":201,"props":228,"children":229},{},[230,237],{"type":182,"tag":205,"props":231,"children":234},{"href":232,"rel":233},"https://www.maxai.co/share?id=a5222cc57cbc97e4830bf86724d1b1b8851ebc3d0614f2112961e160",[209],[235],{"type":188,"value":236},"GPT-5",{"type":188,"value":238},"：第一轮就找到了不错的答案，此外思路绝佳。",{"type":182,"tag":191,"props":240,"children":241},{},[242],{"type":188,"value":243},"无论我的系统提示词是什么，本地 Qwen3 Next 直接拒绝了我的任务，除非我把 GPT-5 的思路拔下来告诉他要怎么找答案。本地的 Qwen3 Next Thinking 则是花了四分钟烧掉 1w token，找到两个错误答案和一个“诺/no”。",{"type":182,"tag":191,"props":245,"children":246},{},[247],{"type":182,"tag":248,"props":249,"children":252},"img",{"alt":250,"src":251},"Local Qwen3 Next","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20251208131758762.png",[],{"type":182,"tag":183,"props":254,"children":256},{"id":255},"_2025-03",[257],{"type":188,"value":258},"2025-03",{"type":182,"tag":197,"props":260,"children":261},{},[262],{"type":182,"tag":201,"props":263,"children":264},{},[265],{"type":188,"value":266},"SVD 的全称",{"type":182,"tag":191,"props":268,"children":269},{},[270],{"type":188,"value":271},"在一个关于“教材”的变量名隐喻中，如果 SVD 中 D 的解释是 Director，那么全称可能是什么？正确答案是什么？4o、QwQ 和 Kimi 把答案导向了数学，但经过追问，话题相关低代码、组件、编译原理之类的，和数学没有关系。那么 SVD 是什么？4o 说是 Structure View Director，即数据结构视图导演。我觉得这个回答接近正确答案，而其他两个乱答。",{"type":182,"tag":191,"props":273,"children":274},{},[275],{"type":182,"tag":248,"props":276,"children":279},{"alt":277,"src":278},"翻译问题","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202503182351515.png",[],{"type":182,"tag":191,"props":281,"children":282},{},[283],{"type":188,"value":284},"GPT-4o（MaxAI）关于“billion”的翻译犯了很明显的错误。",{"type":182,"tag":197,"props":286,"children":287},{},[288],{"type":182,"tag":201,"props":289,"children":290},{},[291],{"type":182,"tag":205,"props":292,"children":295},{"href":293,"rel":294},"https://chat.qwen.ai/s/2efd38e7-c682-493b-a479-8c1f31e0a2f5",[209],[296],{"type":188,"value":297},"找到一个中文单词，和某个英文单词读音相近，但是意思完全相反 @QwQ-32B",{"type":182,"tag":191,"props":299,"children":300},{},[301],{"type":182,"tag":248,"props":302,"children":304},{"alt":175,"src":303},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202503070241843.png",[],{"type":182,"tag":191,"props":306,"children":307},{},[308],{"type":188,"value":309},"非联网。在很开头就找到了\"buy\"和\"卖\"，但是居然没有从这里推理出正确结果（尽管最终答案包含\"buy\"和\"卖\"）。继续问相同的问题，经过 2 分半的思考，找到了“爱”和“hate”，不算是可接受的答案。下次直接试试：“找十组中文单词，这些中文单词和某个英文单词的发音相近，但两者的意思完全相反”。",{"type":182,"tag":197,"props":311,"children":312},{},[313],{"type":182,"tag":201,"props":314,"children":315},{},[316],{"type":182,"tag":205,"props":317,"children":320},{"href":318,"rel":319},"https://metaso.cn/s/IpfAIch",[209],[321],{"type":188,"value":322},"如何解读：Business is Business @metaso",{"type":182,"tag":191,"props":324,"children":325},{},[326],{"type":188,"value":327},"搜索资料选的是“学术”，但是表现出乎意料的差，根本没有把握句子的意思。",{"type":182,"tag":183,"props":329,"children":331},{"id":330},"_2