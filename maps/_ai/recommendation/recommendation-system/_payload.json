锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"original_path":181,"date":182,"tags":183,"body":190,"_type":387,"_id":388,"_source":389,"_file":390,"_stem":391,"_extension":392},"/maps/_ai/recommendation/recommendation-system","recommendation",false,true,"","推荐系统演进：从零到上瘾算法","推荐系统演进历程：从流行度排序、协同过滤、矩阵分解到双塔模型与深度学习的完整指南。","_ai/recommendation/recommendation-system.md","2026-02-13",[184,185,186,187,188,189],"推荐系统","机器学习","算法","协同过滤","矩阵分解","双塔模型",{"type":191,"children":192,"toc":384},"root",[193,202,208,214,227,233,245,268,274,279,290,296,315,342,348,353,359],{"type":194,"tag":195,"props":196,"children":198},"element","h4",{"id":197},"推荐系统的演进从简单规则到深度智能",[199],{"type":200,"value":201},"text","推荐系统的演进：从简单规则到深度智能",{"type":194,"tag":203,"props":204,"children":205},"p",{},[206],{"type":200,"value":207},"推荐系统的本质是一个持续演进的\"打怪升级\"过程。从冷启动时代的流行度排序，到协同过滤的记忆能力，再到矩阵分解的抽象理解，最终抵达双塔模型与深度学习的实时智能——每一代算法都在解决前一代的致命短板，同时暴露新的局限。这种螺旋式上升揭示了一个核心真理：没有完美的算法，只有不断逼近用户真实需求的迭代。现代推荐系统早已超越\"猜你喜欢\"的范畴，进化为理解时间、场景、情绪的综合决策引擎。",{"type":194,"tag":195,"props":209,"children":211},{"id":210},"冷启动流行度排序的朴素智慧",[212],{"type":200,"value":213},"冷启动：流行度排序的朴素智慧",{"type":194,"tag":203,"props":215,"children":216},{},[217,219,225],{"type":200,"value":218},"App 刚上线时，系统对新用户一无所知，此时流行度排序是最务实的策略。通过一个手写公式（如 0.5×完播率 + 0.2×点赞 + 0.1×分享 − 时间衰减）对所有视频排序，将大众偏好的内容（如舞蹈、搞笑、萌宠）推给所有人。这看似简单，却能保证用户打开 App 八成能看到感兴趣的内容。更重要的是，这个阶段的核心任务是",{"type":194,"tag":220,"props":221,"children":222},"strong",{},[223],{"type":200,"value":224},"攒数据",{"type":200,"value":226},"——记录谁看完了哪个视频、谁点赞、谁一秒划走，这些数据是未来算法的金矿。冷启动的本质是\"用确定性换数据，用数据换个性化\"。",{"type":194,"tag":195,"props":228,"children":230},{"id":229},"协同过滤基于相似性的推荐",[231],{"type":200,"value":232},"协同过滤：基于相似性的推荐",{"type":194,"tag":203,"props":234,"children":235},{},[236,238,243],{"type":200,"value":237},"当积累了几天数据后，系统进入协同过滤（Collaborative Filtering）阶段。原理直观：与你喜好相似的人看过的内容，你可能也喜欢。如果用户 A 和用户 B 都点赞了视频 X、Y、Z，而 B 还点赞了视频 W，那么 A 很可能也会喜欢 W。这种方法上手快、几行代码即可实现，但致命缺陷是",{"type":194,"tag":220,"props":239,"children":240},{},[241],{"type":200,"value":242},"只会死记硬背，不会泛化",{"type":200,"value":244},"——即使你看了十条 PAPI 酱和十条脱口秀，它依然看不出你喜欢\"搞笑\"这个潜在因子，只会机械地推荐\"相似用户\"看过的具体视频。",{"type":194,"tag":203,"props":246,"children":247},{},[248,250,259,261],{"type":200,"value":249},"见：",{"type":194,"tag":251,"props":252,"children":256},"a",{"href":253,"rel":254},"https://zhuanlan.zhihu.com/p/693675380",[255],"nofollow",[257],{"type":200,"value":258},"推荐系统中的矩阵分解详解",{"type":200,"value":260},"、",{"type":194,"tag":251,"props":262,"children":265},{"href":263,"rel":264},"https://blog.csdn.net/super_chiry/article/details/102988919",[255],[266],{"type":200,"value":267},"协同过滤算法原理与实践",{"type":194,"tag":195,"props":269,"children":271},{"id":270},"矩阵分解提取潜在因子的必杀技",[272],{"type":200,"value":273},"矩阵分解：提取潜在因子的必杀技",{"type":194,"tag":203,"props":275,"children":276},{},[277],{"type":200,"value":278},"为了让系统\"开悟\"、学会理解抽象口味，矩阵分解（Matrix Factorization）应运而生。将用户-视频的交互数据（完播率、点赞、转发等融合成评分）构成大矩阵，然后分解为两个低维矩阵：用户喜好矩阵和视频风格矩阵。每个用户被抽象成一个向量（如 0.8 搞笑 + 0.6 萌宠 + 0.1 新闻），每个视频也被编码为类似向量。通过计算向量点积判断匹配度——用户向量和视频向量的点积越高，推荐优先级越高。训练时使用 SGD 迭代优化，让两个小矩阵的乘积逼近原始大矩阵。这种方法解决了数据稀疏问题，并能捕捉到\"0.8 搞笑 + 0.6 萌宠\"的细腻组合，而非\"搞笑/不搞笑\"的一刀切。",{"type":194,"tag":203,"props":280,"children":281},{},[282,283],{"type":200,"value":249},{"type":194,"tag":251,"props":284,"children":287},{"href":285,"rel":286},"https://lumingdong.cn/recommendation-algorithm-based-on-matrix-decomposition.html",[255],[288],{"type":200,"value":289},"基于矩阵分解的推荐算法",{"type":194,"tag":195,"props":291,"children":293},{"id":292},"双塔模型-ann捕捉非线性的深度智能",[294],{"type":200,"value":295},"双塔模型 + ANN：捕捉非线性的深度智能",{"type":194,"tag":203,"props":297,"children":298},{},[299,301,306,308,313],{"type":200,"value":300},"矩阵分解的局限在于只能做简单的\"口味×风格\"线性匹配，无法处理时间、场景、人群的复杂组合。第三代推荐系统引入神经网络和双塔架构：",{"type":194,"tag":220,"props":302,"children":303},{},[304],{"type":200,"value":305},"视频塔",{"type":200,"value":307},"用神经网络将标题、封面、BGM、点赞数等离线转换为视频向量；",{"type":194,"tag":220,"props":309,"children":310},{},[311],{"type":200,"value":312},"用户塔",{"type":200,"value":314},"实时将用户历史行为、搜索词、设备、城市、时间等信息编码为用户向量。当用户请求时，实时计算用户向量，通过 ANN（近似最近邻）算法快速找到最接近的视频候选，完成召回。随后进入精排阶段，用更复杂的模型对这 1000 个候选打分，选出最终推荐。这种架构能理解\"通勤时看新闻、午休时看知识、晚上看搞笑\"的场景化需求，实现真正的千人千面。",{"type":194,"tag":203,"props":316,"children":317},{},[318,319,326,327,334,335],{"type":200,"value":249},{"type":194,"tag":251,"props":320,"children":323},{"href":321,"rel":322},"https://zhuanlan.zhihu.com/p/601743047",[255],[324],{"type":200,"value":325},"双塔模型基本原理与实践",{"type":200,"value":260},{"type":194,"tag":251,"props":328,"children":331},{"href":329,"rel":330},"https://bbs.huaweicloud.com/blogs/353252",[255],[332],{"type":200,"value":333},"DSSM 双塔模型浅析",{"type":200,"value":260},{"type":194,"tag":251,"props":336,"children":339},{"href":337,"rel":338},"https://github.com/datawhalechina/easy-vecdb/blob/main/docs/base/chapter5/ANN%E6%90%9C%E7%B4%A2%E7%AE%97%E6%B3%95.md",[255],[340],{"type":200,"value":341},"ANN 近似最近邻搜索算法",{"type":194,"tag":195,"props":343,"children":345},{"id":344},"召回与精排推荐系统的招聘流程",[346],{"type":200,"value":347},"召回与精排：推荐系统的\"招聘流程\"",{"type":194,"tag":203,"props":349,"children":350},{},[351],{"type":200,"value":352},"现代推荐系统的工程架构模仿大厂招聘流程：先召回（从百万视频中筛出 1000 候选），再精排（从 1000 中选出 20 个最终推荐）。召回追求速度快、覆盖面广，精排追求精度高、体验好。双塔模型负责召回，用向量相似度快速粗筛；深度神经网络负责精排，融合更多特征精细打分。这种分层设计解决了\"算力无限、时间有限\"的矛盾——无法在几百万视频上都跑一遍复杂模型，于是先用轻量方法缩小范围，再集中算力精细决策。召回+精排的分层思想是工业级推荐系统的标配。",{"type":194,"tag":195,"props":354,"children":356},{"id":355},"为什么你会刷到天亮",[357],{"type":200,"value":358},"为什么你会刷到天亮？",{"type":194,"tag":203,"props":360,"children":361},{},[362,364,369,371,376,377,382],{"type":200,"value":363},"顶级推荐系统的可怕之处在于：它不仅懂你喜欢什么类型，还懂你在什么",{"type":194,"tag":220,"props":365,"children":366},{},[367],{"type":200,"value":368},"时间",{"type":200,"value":370},"、什么",{"type":194,"tag":220,"props":372,"children":373},{},[374],{"type":200,"value":375},"地点",{"type":200,"value":370},{"type":194,"tag":220,"props":378,"children":379},{},[380],{"type":200,"value":381},"心情",{"type":200,"value":383},"下想看什么。通过双塔模型捕捉实时上下文，通过精排模型预测完播概率，系统精准推给你\"此刻最想看到\"的内容。每一次滑动都在产生新的行为数据，数据又实时反馈到模型，形成\"越刷越懂你、越懂你越刷\"的强化循环。这就是明明只想刷 5 分钟，抬头却发现天亮的底层机制——不是一个魔法，而是一整套从数据积累、特征工程到深度学习的技术栈在共同作用。",{"title":178,"searchDepth":385,"depth":385,"links":386},2,[],"markdown","content:6.maps:_ai:recommendation:recommendation-system.md","content","6.maps/_ai/recommendation/recommendation-system.md","6.maps/_ai/recommendation/recommendation-system","md",[394,398],{"_path":395,"title":396,"description":397},"/maps/_ai/recommendation/recommendation","Recommendation Systems","AI 推荐系统技术与演进，从协同过滤到深度学习的推荐算法实践。",{"_path":399,"title":400,"description":401},"/maps/_ai/safety/safety","AI Safety","AI 安全研究、风险治理与相关事件",1772185511425]