锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133,"children":134},"造物 / Make","/tools",[135,137,140,143,146,149,152],{"title":136,"_path":133},"🧰 工具收集",{"title":138,"_path":139},"📕 博客","/tools/blog",{"title":141,"_path":142},"🥥 Coconut","/tools/coconut",{"title":144,"_path":145},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":147,"_path":148},"🌐 AnySort","/tools/anysort",{"title":150,"_path":151},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":153,"_path":154},"👓 Crapto","/tools/crypto-inline",{"title":156,"_path":157,"children":158},"我 / About","/hire",[159],{"title":160,"_path":157},"📬 技术简历",{"title":162,"_path":163,"children":164},"En","/en",[165],{"title":166,"_path":167,"children":168},"🦁 Welcome","/en/articles",[169],{"title":166,"_path":167},{"_path":171,"_dir":172,"_draft":173,"_partial":174,"_locale":175,"title":176,"description":177,"date":178,"tags":179,"body":186,"_type":383,"_id":384,"_source":385,"_file":386,"_stem":387,"_extension":388},"/maps/_ai/recommendation/recommendation-system","recommendation",false,true,"","推荐系统演进：从零到上瘾算法","https://www.bilibili.com/video/BV1eqagzSECT/","2026-02-13",[180,181,182,183,184,185],"推荐系统","机器学习","算法","协同过滤","矩阵分解","双塔模型",{"type":187,"children":188,"toc":380},"root",[189,198,204,210,223,229,241,264,270,275,286,292,311,338,344,349,355],{"type":190,"tag":191,"props":192,"children":194},"element","h4",{"id":193},"推荐系统的演进从简单规则到深度智能",[195],{"type":196,"value":197},"text","推荐系统的演进：从简单规则到深度智能",{"type":190,"tag":199,"props":200,"children":201},"p",{},[202],{"type":196,"value":203},"推荐系统的本质是一个持续演进的\"打怪升级\"过程。从冷启动时代的流行度排序，到协同过滤的记忆能力，再到矩阵分解的抽象理解，最终抵达双塔模型与深度学习的实时智能——每一代算法都在解决前一代的致命短板，同时暴露新的局限。这种螺旋式上升揭示了一个核心真理：没有完美的算法，只有不断逼近用户真实需求的迭代。现代推荐系统早已超越\"猜你喜欢\"的范畴，进化为理解时间、场景、情绪的综合决策引擎。",{"type":190,"tag":191,"props":205,"children":207},{"id":206},"冷启动流行度排序的朴素智慧",[208],{"type":196,"value":209},"冷启动：流行度排序的朴素智慧",{"type":190,"tag":199,"props":211,"children":212},{},[213,215,221],{"type":196,"value":214},"App 刚上线时，系统对新用户一无所知，此时流行度排序是最务实的策略。通过一个手写公式（如 0.5×完播率 + 0.2×点赞 + 0.1×分享 − 时间衰减）对所有视频排序，将大众偏好的内容（如舞蹈、搞笑、萌宠）推给所有人。这看似简单，却能保证用户打开 App 八成能看到感兴趣的内容。更重要的是，这个阶段的核心任务是",{"type":190,"tag":216,"props":217,"children":218},"strong",{},[219],{"type":196,"value":220},"攒数据",{"type":196,"value":222},"——记录谁看完了哪个视频、谁点赞、谁一秒划走，这些数据是未来算法的金矿。冷启动的本质是\"用确定性换数据，用数据换个性化\"。",{"type":190,"tag":191,"props":224,"children":226},{"id":225},"协同过滤基于相似性的推荐",[227],{"type":196,"value":228},"协同过滤：基于相似性的推荐",{"type":190,"tag":199,"props":230,"children":231},{},[232,234,239],{"type":196,"value":233},"当积累了几天数据后，系统进入协同过滤（Collaborative Filtering）阶段。原理直观：与你喜好相似的人看过的内容，你可能也喜欢。如果用户 A 和用户 B 都点赞了视频 X、Y、Z，而 B 还点赞了视频 W，那么 A 很可能也会喜欢 W。这种方法上手快、几行代码即可实现，但致命缺陷是",{"type":190,"tag":216,"props":235,"children":236},{},[237],{"type":196,"value":238},"只会死记硬背，不会泛化",{"type":196,"value":240},"——即使你看了十条 PAPI 酱和十条脱口秀，它依然看不出你喜欢\"搞笑\"这个潜在因子，只会机械地推荐\"相似用户\"看过的具体视频。",{"type":190,"tag":199,"props":242,"children":243},{},[244,246,255,257],{"type":196,"value":245},"见：",{"type":190,"tag":247,"props":248,"children":252},"a",{"href":249,"rel":250},"https://zhuanlan.zhihu.com/p/693675380",[251],"nofollow",[253],{"type":196,"value":254},"推荐系统中的矩阵分解详解",{"type":196,"value":256},"、",{"type":190,"tag":247,"props":258,"children":261},{"href":259,"rel":260},"https://blog.csdn.net/super_chiry/article/details/102988919",[251],[262],{"type":196,"value":263},"协同过滤算法原理与实践",{"type":190,"tag":191,"props":265,"children":267},{"id":266},"矩阵分解提取潜在因子的必杀技",[268],{"type":196,"value":269},"矩阵分解：提取潜在因子的必杀技",{"type":190,"tag":199,"props":271,"children":272},{},[273],{"type":196,"value":274},"为了让系统\"开悟\"、学会理解抽象口味，矩阵分解（Matrix Factorization）应运而生。将用户-视频的交互数据（完播率、点赞、转发等融合成评分）构成大矩阵，然后分解为两个低维矩阵：用户喜好矩阵和视频风格矩阵。每个用户被抽象成一个向量（如 0.8 搞笑 + 0.6 萌宠 + 0.1 新闻），每个视频也被编码为类似向量。通过计算向量点积判断匹配度——用户向量和视频向量的点积越高，推荐优先级越高。训练时使用 SGD 迭代优化，让两个小矩阵的乘积逼近原始大矩阵。这种方法解决了数据稀疏问题，并能捕捉到\"0.8 搞笑 + 0.6 萌宠\"的细腻组合，而非\"搞笑/不搞笑\"的一刀切。",{"type":190,"tag":199,"props":276,"children":277},{},[278,279],{"type":196,"value":245},{"type":190,"tag":247,"props":280,"children":283},{"href":281,"rel":282},"https://lumingdong.cn/recommendation-algorithm-based-on-matrix-decomposition.html",[251],[284],{"type":196,"value":285},"基于矩阵分解的推荐算法",{"type":190,"tag":191,"props":287,"children":289},{"id":288},"双塔模型-ann捕捉非线性的深度智能",[290],{"type":196,"value":291},"双塔模型 + ANN：捕捉非线性的深度智能",{"type":190,"tag":199,"props":293,"children":294},{},[295,297,302,304,309],{"type":196,"value":296},"矩阵分解的局限在于只能做简单的\"口味×风格\"线性匹配，无法处理时间、场景、人群的复杂组合。第三代推荐系统引入神经网络和双塔架构：",{"type":190,"tag":216,"props":298,"children":299},{},[300],{"type":196,"value":301},"视频塔",{"type":196,"value":303},"用神经网络将标题、封面、BGM、点赞数等离线转换为视频向量；",{"type":190,"tag":216,"props":305,"children":306},{},[307],{"type":196,"value":308},"用户塔",{"type":196,"value":310},"实时将用户历史行为、搜索词、设备、城市、时间等信息编码为用户向量。当用户请求时，实时计算用户向量，通过 ANN（近似最近邻）算法快速找到最接近的视频候选，完成召回。随后进入精排阶段，用更复杂的模型对这 1000 个候选打分，选出最终推荐。这种架构能理解\"通勤时看新闻、午休时看知识、晚上看搞笑\"的场景化需求，实现真正的千人千面。",{"type":190,"tag":199,"props":312,"children":313},{},[314,315,322,323,330,331],{"type":196,"value":245},{"type":190,"tag":247,"props":316,"children":319},{"href":317,"rel":318},"https://zhuanlan.zhihu.com/p/601743047",[251],[320],{"type":196,"value":321},"双塔模型基本原理与实践",{"type":196,"value":256},{"type":190,"tag":247,"props":324,"children":327},{"href":325,"rel":326},"https://bbs.huaweicloud.com/blogs/353252",[251],[328],{"type":196,"value":329},"DSSM 双塔模型浅析",{"type":196,"value":256},{"type":190,"tag":247,"props":332,"children":335},{"href":333,"rel":334},"https://github.com/datawhalechina/easy-vecdb/blob/main/docs/base/chapter5/ANN%E6%90%9C%E7%B4%A2%E7%AE%97%E6%B3%95.md",[251],[336],{"type":196,"value":337},"ANN 近似最近邻搜索算法",{"type":190,"tag":191,"props":339,"children":341},{"id":340},"召回与精排推荐系统的招聘流程",[342],{"type":196,"value":343},"召回与精排：推荐系统的\"招聘流程\"",{"type":190,"tag":199,"props":345,"children":346},{},[347],{"type":196,"value":348},"现代推荐系统的工程架构模仿大厂招聘流程：先召回（从百万视频中筛出 1000 候选），再精排（从 1000 中选出 20 个最终推荐）。召回追求速度快、覆盖面广，精排追求精度高、体验好。双塔模型负责召回，用向量相似度快速粗筛；深度神经网络负责精排，融合更多特征精细打分。这种分层设计解决了\"算力无限、时间有限\"的矛盾——无法在几百万视频上都跑一遍复杂模型，于是先用轻量方法缩小范围，再集中算力精细决策。召回+精排的分层思想是工业级推荐系统的标配。",{"type":190,"tag":191,"props":350,"children":352},{"id":351},"为什么你会刷到天亮",[353],{"type":196,"value":354},"为什么你会刷到天亮？",{"type":190,"tag":199,"props":356,"children":357},{},[358,360,365,367,372,373,378],{"type":196,"value":359},"顶级推荐系统的可怕之处在于：它不仅懂你喜欢什么类型，还懂你在什么",{"type":190,"tag":216,"props":361,"children":362},{},[363],{"type":196,"value":364},"时间",{"type":196,"value":366},"、什么",{"type":190,"tag":216,"props":368,"children":369},{},[370],{"type":196,"value":371},"地点",{"type":196,"value":366},{"type":190,"tag":216,"props":374,"children":375},{},[376],{"type":196,"value":377},"心情",{"type":196,"value":379},"下想看什么。通过双塔模型捕捉实时上下文，通过精排模型预测完播概率，系统精准推给你\"此刻最想看到\"的内容。每一次滑动都在产生新的行为数据，数据又实时反馈到模型，形成\"越刷越懂你、越懂你越刷\"的强化循环。这就是明明只想刷 5 分钟，抬头却发现天亮的底层机制——不是一个魔法，而是一整套从数据积累、特征工程到深度学习的技术栈在共同作用。",{"title":175,"searchDepth":381,"depth":381,"links":382},2,[],"markdown","content:6.maps:_ai:recommendation:recommendation-system.md","content","6.maps/_ai/recommendation/recommendation-system.md","6.maps/_ai/recommendation/recommendation-system","md",[390,394],{"_path":391,"title":392,"description":393},"/maps/_ai/rag/rag","RAG","检索增强生成模型",{"_path":395,"title":396,"description":397},"/maps/_ai/skills/create-a-skill","如何编写 Agent Skills","如何编写 Agent Skills - 完整指南",1771071683771]