锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"date":181,"tags":182,"body":189,"_type":386,"_id":387,"_source":388,"_file":389,"_stem":390,"_extension":391},"/maps/_ai/recommendation/recommendation-system","recommendation",false,true,"","推荐系统演进：从零到上瘾算法","https://www.bilibili.com/video/BV1eqagzSECT/","2026-02-13",[183,184,185,186,187,188],"推荐系统","机器学习","算法","协同过滤","矩阵分解","双塔模型",{"type":190,"children":191,"toc":383},"root",[192,201,207,213,226,232,244,267,273,278,289,295,314,341,347,352,358],{"type":193,"tag":194,"props":195,"children":197},"element","h4",{"id":196},"推荐系统的演进从简单规则到深度智能",[198],{"type":199,"value":200},"text","推荐系统的演进：从简单规则到深度智能",{"type":193,"tag":202,"props":203,"children":204},"p",{},[205],{"type":199,"value":206},"推荐系统的本质是一个持续演进的\"打怪升级\"过程。从冷启动时代的流行度排序，到协同过滤的记忆能力，再到矩阵分解的抽象理解，最终抵达双塔模型与深度学习的实时智能——每一代算法都在解决前一代的致命短板，同时暴露新的局限。这种螺旋式上升揭示了一个核心真理：没有完美的算法，只有不断逼近用户真实需求的迭代。现代推荐系统早已超越\"猜你喜欢\"的范畴，进化为理解时间、场景、情绪的综合决策引擎。",{"type":193,"tag":194,"props":208,"children":210},{"id":209},"冷启动流行度排序的朴素智慧",[211],{"type":199,"value":212},"冷启动：流行度排序的朴素智慧",{"type":193,"tag":202,"props":214,"children":215},{},[216,218,224],{"type":199,"value":217},"App 刚上线时，系统对新用户一无所知，此时流行度排序是最务实的策略。通过一个手写公式（如 0.5×完播率 + 0.2×点赞 + 0.1×分享 − 时间衰减）对所有视频排序，将大众偏好的内容（如舞蹈、搞笑、萌宠）推给所有人。这看似简单，却能保证用户打开 App 八成能看到感兴趣的内容。更重要的是，这个阶段的核心任务是",{"type":193,"tag":219,"props":220,"children":221},"strong",{},[222],{"type":199,"value":223},"攒数据",{"type":199,"value":225},"——记录谁看完了哪个视频、谁点赞、谁一秒划走，这些数据是未来算法的金矿。冷启动的本质是\"用确定性换数据，用数据换个性化\"。",{"type":193,"tag":194,"props":227,"children":229},{"id":228},"协同过滤基于相似性的推荐",[230],{"type":199,"value":231},"协同过滤：基于相似性的推荐",{"type":193,"tag":202,"props":233,"children":234},{},[235,237,242],{"type":199,"value":236},"当积累了几天数据后，系统进入协同过滤（Collaborative Filtering）阶段。原理直观：与你喜好相似的人看过的内容，你可能也喜欢。如果用户 A 和用户 B 都点赞了视频 X、Y、Z，而 B 还点赞了视频 W，那么 A 很可能也会喜欢 W。这种方法上手快、几行代码即可实现，但致命缺陷是",{"type":193,"tag":219,"props":238,"children":239},{},[240],{"type":199,"value":241},"只会死记硬背，不会泛化",{"type":199,"value":243},"——即使你看了十条 PAPI 酱和十条脱口秀，它依然看不出你喜欢\"搞笑\"这个潜在因子，只会机械地推荐\"相似用户\"看过的具体视频。",{"type":193,"tag":202,"props":245,"children":246},{},[247,249,258,260],{"type":199,"value":248},"见：",{"type":193,"tag":250,"props":251,"children":255},"a",{"href":252,"rel":253},"https://zhuanlan.zhihu.com/p/693675380",[254],"nofollow",[256],{"type":199,"value":257},"推荐系统中的矩阵分解详解",{"type":199,"value":259},"、",{"type":193,"tag":250,"props":261,"children":264},{"href":262,"rel":263},"https://blog.csdn.net/super_chiry/article/details/102988919",[254],[265],{"type":199,"value":266},"协同过滤算法原理与实践",{"type":193,"tag":194,"props":268,"children":270},{"id":269},"矩阵分解提取潜在因子的必杀技",[271],{"type":199,"value":272},"矩阵分解：提取潜在因子的必杀技",{"type":193,"tag":202,"props":274,"children":275},{},[276],{"type":199,"value":277},"为了让系统\"开悟\"、学会理解抽象口味，矩阵分解（Matrix Factorization）应运而生。将用户-视频的交互数据（完播率、点赞、转发等融合成评分）构成大矩阵，然后分解为两个低维矩阵：用户喜好矩阵和视频风格矩阵。每个用户被抽象成一个向量（如 0.8 搞笑 + 0.6 萌宠 + 0.1 新闻），每个视频也被编码为类似向量。通过计算向量点积判断匹配度——用户向量和视频向量的点积越高，推荐优先级越高。训练时使用 SGD 迭代优化，让两个小矩阵的乘积逼近原始大矩阵。这种方法解决了数据稀疏问题，并能捕捉到\"0.8 搞笑 + 0.6 萌宠\"的细腻组合，而非\"搞笑/不搞笑\"的一刀切。",{"type":193,"tag":202,"props":279,"children":280},{},[281,282],{"type":199,"value":248},{"type":193,"tag":250,"props":283,"children":286},{"href":284,"rel":285},"https://lumingdong.cn/recommendation-algorithm-based-on-matrix-decomposition.html",[254],[287],{"type":199,"value":288},"基于矩阵分解的推荐算法",{"type":193,"tag":194,"props":290,"children":292},{"id":291},"双塔模型-ann捕捉非线性的深度智能",[293],{"type":199,"value":294},"双塔模型 + ANN：捕捉非线性的深度智能",{"type":193,"tag":202,"props":296,"children":297},{},[298,300,305,307,312],{"type":199,"value":299},"矩阵分解的局限在于只能做简单的\"口味×风格\"线性匹配，无法处理时间、场景、人群的复杂组合。第三代推荐系统引入神经网络和双塔架构：",{"type":193,"tag":219,"props":301,"children":302},{},[303],{"type":199,"value":304},"视频塔",{"type":199,"value":306},"用神经网络将标题、封面、BGM、点赞数等离线转换为视频向量；",{"type":193,"tag":219,"props":308,"children":309},{},[310],{"type":199,"value":311},"用户塔",{"type":199,"value":313},"实时将用户历史行为、搜索词、设备、城市、时间等信息编码为用户向量。当用户请求时，实时计算用户向量，通过 ANN（近似最近邻）算法快速找到最接近的视频候选，完成召回。随后进入精排阶段，用更复杂的模型对这 1000 个候选打分，选出最终推荐。这种架构能理解\"通勤时看新闻、午休时看知识、晚上看搞笑\"的场景化需求，实现真正的千人千面。",{"type":193,"tag":202,"props":315,"children":316},{},[317,318,325,326,333,334],{"type":199,"value":248},{"type":193,"tag":250,"props":319,"children":322},{"href":320,"rel":321},"https://zhuanlan.zhihu.com/p/601743047",[254],[323],{"type":199,"value":324},"双塔模型基本原理与实践",{"type":199,"value":259},{"type":193,"tag":250,"props":327,"children":330},{"href":328,"rel":329},"https://bbs.huaweicloud.com/blogs/353252",[254],[331],{"type":199,"value":332},"DSSM 双塔模型浅析",{"type":199,"value":259},{"type":193,"tag":250,"props":335,"children":338},{"href":336,"rel":337},"https://github.com/datawhalechina/easy-vecdb/blob/main/docs/base/chapter5/ANN%E6%90%9C%E7%B4%A2%E7%AE%97%E6%B3%95.md",[254],[339],{"type":199,"value":340},"ANN 近似最近邻搜索算法",{"type":193,"tag":194,"props":342,"children":344},{"id":343},"召回与精排推荐系统的招聘流程",[345],{"type":199,"value":346},"召回与精排：推荐系统的\"招聘流程\"",{"type":193,"tag":202,"props":348,"children":349},{},[350],{"type":199,"value":351},"现代推荐系统的工程架构模仿大厂招聘流程：先召回（从百万视频中筛出 1000 候选），再精排（从 1000 中选出 20 个最终推荐）。召回追求速度快、覆盖面广，精排追求精度高、体验好。双塔模型负责召回，用向量相似度快速粗筛；深度神经网络负责精排，融合更多特征精细打分。这种分层设计解决了\"算力无限、时间有限\"的矛盾——无法在几百万视频上都跑一遍复杂模型，于是先用轻量方法缩小范围，再集中算力精细决策。召回+精排的分层思想是工业级推荐系统的标配。",{"type":193,"tag":194,"props":353,"children":355},{"id":354},"为什么你会刷到天亮",[356],{"type":199,"value":357},"为什么你会刷到天亮？",{"type":193,"tag":202,"props":359,"children":360},{},[361,363,368,370,375,376,381],{"type":199,"value":362},"顶级推荐系统的可怕之处在于：它不仅懂你喜欢什么类型，还懂你在什么",{"type":193,"tag":219,"props":364,"children":365},{},[366],{"type":199,"value":367},"时间",{"type":199,"value":369},"、什么",{"type":193,"tag":219,"props":371,"children":372},{},[373],{"type":199,"value":374},"地点",{"type":199,"value":369},{"type":193,"tag":219,"props":377,"children":378},{},[379],{"type":199,"value":380},"心情",{"type":199,"value":382},"下想看什么。通过双塔模型捕捉实时上下文，通过精排模型预测完播概率，系统精准推给你\"此刻最想看到\"的内容。每一次滑动都在产生新的行为数据，数据又实时反馈到模型，形成\"越刷越懂你、越懂你越刷\"的强化循环。这就是明明只想刷 5 分钟，抬头却发现天亮的底层机制——不是一个魔法，而是一整套从数据积累、特征工程到深度学习的技术栈在共同作用。",{"title":178,"searchDepth":384,"depth":384,"links":385},2,[],"markdown","content:6.maps:_ai:recommendation:recommendation-system.md","content","6.maps/_ai/recommendation/recommendation-system.md","6.maps/_ai/recommendation/recommendation-system","md",[393,397],{"_path":394,"title":395,"description":396},"/maps/_ai/rag/rag","RAG","检索增强生成模型",{"_path":398,"title":399,"description":178},"/maps/_ai/safety","安全 (Safety)",1771521510939]