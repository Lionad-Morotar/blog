言模型（LLM）交互的技术，旨在通过提供结构化和相关的上下文信息，提高模型生成内容的准确性和相关性。",{"type":179,"children":180,"toc":1064},"root",[181,190,196,201,206,292,298,303,341,346,354,369,379,412,417,425,435,453,463,486,501,510,515,525,530,538,556,564,582,590,608,613,623,641,646,654,685,693,724,732,755,760,778,783,793,811,816,824,842,850,863,871,884,889,907,915,920,956,961,1005,1010,1059],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"brief",[187],{"type":188,"value":189},"text","Brief",{"type":182,"tag":191,"props":192,"children":193},"p",{},[194],{"type":188,"value":195},"上下文工程是指在推理阶段，对提供给大语言模型的信息进行系统化的设计与优化，从而稳定地产生期望输出。它的核心是对各种情境要素进行结构化、选择和排序——例如提示词、检索到的数据、记忆、指令以及环境信号等——以便让模型的内部层次在一种最优状态下运行。",{"type":182,"tag":191,"props":197,"children":198},{},[199],{"type":188,"value":200},"与只关注提示词措辞的提示工程不同，上下文工程关心的是“情境”的完整配置：相关知识、指令和历史上下文是如何被组织和投递的，以便实现最有效的结果。",{"type":182,"tag":191,"props":202,"children":203},{},[204],{"type":188,"value":205},"目前，工程师会使用一系列离散的技术，这些技术大致可以分为三个方向：",{"type":182,"tag":207,"props":208,"children":209},"ol",{},[210,241,269],{"type":182,"tag":211,"props":212,"children":213},"li",{},[214,216,220,222],{"type":188,"value":215},"情境搭建（Context setup）",{"type":182,"tag":217,"props":218,"children":219},"br",{},[],{"type":188,"value":221},"\n主要关注“上下文的初始配置与精简”，包括：",{"type":182,"tag":223,"props":224,"children":225},"ul",{},[226,231,236],{"type":182,"tag":211,"props":227,"children":228},{},[229],{"type":188,"value":230},"使用极简的系统提示词",{"type":182,"tag":211,"props":232,"children":233},{},[234],{"type":188,"value":235},"使用规范化（canonical）的少样本示例",{"type":182,"tag":211,"props":237,"children":238},{},[239],{"type":188,"value":240},"使用高效利用 token 的工具来支持果断行动",{"type":182,"tag":211,"props":242,"children":243},{},[244,246,249,251],{"type":188,"value":245},"情境管理（Context management for long-horizon tasks）",{"type":182,"tag":217,"props":247,"children":248},{},[],{"type":188,"value":250},"\n面向长周期任务，解决有限上下文窗口的问题，包括：",{"type":182,"tag":223,"props":252,"children":253},{},[254,259,264],{"type":182,"tag":211,"props":255,"children":256},{},[257],{"type":188,"value":258},"上下文摘要，将较长历史压缩成关键信息",{"type":182,"tag":211,"props":260,"children":261},{},[262],{"type":188,"value":263},"结构化笔记，用外部持久化记忆记录关键过程与结论",{"type":182,"tag":211,"props":265,"children":266},{},[267],{"type":188,"value":268},"子代理架构，将复杂任务拆解为子任务，并在子任务层面进行隔离与摘要",{"type":182,"tag":211,"props":270,"children":271},{},[272,274,277,279],{"type":188,"value":273},"动态信息检索（Dynamic information retrieval）",{"type":182,"tag":217,"props":275,"children":276},{},[],{"type":188,"value":278},"\n依赖“即时（Just-in-Time, JIT）上下文检索”：",{"type":182,"tag":223,"props":280,"children":281},{},[282,287],{"type":182,"tag":211,"props":283,"children":284},{},[285],{"type":188,"value":286},"只有在确实需要时，智能体才自主加载外部数据",{"type":182,"tag":211,"props":288,"children":289},{},[290],{"type":188,"value":291},"通过这种按需拉取的方式，最大化信息利用效率与推理精度",{"type":182,"tag":183,"props":293,"children":295},{"id":294},"details",[296],{"type":188,"value":297},"Details",{"type":182,"tag":191,"props":299,"children":300},{},[301],{"type":188,"value":302},"目录",{"type":182,"tag":207,"props":304,"children":305},{},[306,311,316,336],{"type":182,"tag":211,"props":307,"children":308},{},[309],{"type":188,"value":310},"什么是上下文工程",{"type":182,"tag":211,"props":312,"children":313},{},[314],{"type":188,"value":315},"上下文工程 vs 提示工程",{"type":182,"tag":211,"props":317,"children":318},{},[319,321,324,326,329,331,334],{"type":188,"value":320},"上下文工程的三大方向（架构颗粒度）",{"type":182,"tag":217,"props":322,"children":323},{},[],{"type":188,"value":325},"\n3.1 情境搭建（Context Setup）",{"type":182,"tag":217,"props":327,"children":328},{},[],{"type":188,"value":330},"\n3.2 情境管理：长周期任务（Context Management）",{"type":182,"tag":217,"props":332,"children":333},{},[],{"type":188,"value":335},"\n3.3 动态信息检索（Dynamic Information Retrieval）",{"type":182,"tag":211,"props":337,"children":338},{},[339],{"type":188,"value":340},"实践要点与落地建议",{"type":182,"tag":191,"props":342,"children":343},{},[344],{"type":188,"value":345},"——————————",{"type":182,"tag":207,"props":347,"children":348},{},[349],{"type":182,"tag":211,"props":350,"children":351},{},[352],{"type":188,"value":353},"什么是上下文工程（Context Engineering）",{"type":182,"tag":191,"props":355,"children":356},{},[357,359,362,364,367],{"type":188,"value":358},"1.1 概念",{"type":182,"tag":217,"props":360,"children":361},{},[],{"type":188,"value":363},"\n上下文工程是在推理阶段，对“喂给大模型的所有信息”进行整体设计和优化的一套方法论与工程实践。",{"type":182,"tag":217,"props":365,"children":366},{},[],{"type":188,"value":368},"\n它关心的是整个“上下文配置”如何影响模型内部状态，从而影响输出质量和稳定性。",{"type":182,"tag":191,"props":370,"children":371},{},[372,374,377],{"type":188,"value":373},"1.2 对象范围",{"type":182,"tag":217,"props":375,"children":376},{},[],{"type":188,"value":378},"\n上下文工程覆盖但不限于：",{"type":182,"tag":223,"props":380,"children":381},{},[382,387,392,397,402,407],{"type":182,"tag":211,"props":383,"children":384},{},[385],{"type":188,"value":386},"系统提示词与角色设定",{"type":182,"tag":211,"props":388,"children":389},{},[390],{"type":188,"value":391},"用户指令与任务描述",{"type":182,"tag":211,"props":393,"children":394},{},[395],{"type":188,"value":396},"少样本示例与模板",{"type":182,"tag":211,"props":398,"children":399},{},[400],{"type":188,"value":401},"从外部系统检索到的数据",{"type":182,"tag":211,"props":403,"children":404},{},[405],{"type":188,"value":406},"会话历史与外部记忆（notes、知识库等）",{"type":182,"tag":211,"props":408,"children":409},{},[410],{"type":188,"value":411},"环境信号（如工具调用结果、系统状态等）",{"type":182,"tag":191,"props":413,"children":414},{},[415],{"type":188,"value":416},"这些都被视作“情境元素”，需要被合理组织和调度。",{"type":182,"tag":207,"props":418,"children":420},{"start":419},2,[421],{"type":182,"tag":211,"props":422,"children":423},{},[424],{"type":188,"value":315},{"type":182,"tag":191,"props":426,"children":427},{},[428,430,433],{"type":188,"value":429},"2.1 提示工程关注点",{"type":182,"tag":217,"props":431,"children":432},{},[],{"type":188,"value":434},"\n提示工程主要聚焦在一句或若干句“prompt”的写法：",{"type":182,"tag":223,"props":436,"children":437},{},[438,443,448],{"type":182,"tag":211,"props":439,"children":440},{},[441],{"type":188,"value":442},"如何更清晰地描述任务",{"type":182,"tag":211,"props":444,"children":445},{},[446],{"type":188,"value":447},"如何减少歧义",{"type":182,"tag":211,"props":449,"children":450},{},[451],{"type":188,"value":452},"如何通过措辞影响模型行为",{"type":182,"tag":191,"props":454,"children":455},{},[456,458,461],{"type":188,"value":457},"2.2 上下文工程关注点",{"type":182,"tag":217,"props":459,"children":460},{},[],{"type":188,"value":462},"\n上下文工程则关注：",{"type":182,"tag":223,"props":464,"children":465},{},[466,471,476,481],{"type":182,"tag":211,"props":467,"children":468},{},[469],{"type":188,"value":470},"用哪些信息：信息源选择、过滤、裁剪",{"type":182,"tag":211,"props":472,"children":473},{},[474],{"type":188,"value":475},"以什么结构组织：分块、层级、标签、模板化",{"type":182,"tag":211,"props":477,"children":478},{},[479],{"type":188,"value":480},"以什么顺序喂给模型：先指令、后知识，或先总结、后追问等",{"type":182,"tag":211,"props":482,"children":483},{},[484],{"type":188,"value":485},"在整个任务生命周期内，如何滚动维护与更新上下文",{"type":182,"tag":191,"props":487,"children":488},{},[489,491,494,496,499],{"type":188,"value":490},"可以理解为：",{"type":182,"tag":217,"props":492,"children":493},{},[],{"type":188,"value":495},"\n提示工程是“怎么说这句话”，",{"type":182,"tag":217,"props":497,"children":498},{},[],{"type":188,"value":500},"\n上下文工程是“说什么、按什么结构说、在什么时机说，以及说给谁（哪个子代理）听”。",{"type":182,"tag":207,"props":502,"children":504},{"start":503},3,[505],{"type":182,"tag":211,"props":506,"children":507},{},[508],{"type":188,"value":509},"上下文工程的三大方向",{"type":182,"tag":191,"props":511,"children":512},{},[513],{"type":188,"value":514},"3.1 情境搭建（Context Setup）",{"type":182,"tag":191,"props":516,"children":517},{},[518,520,523],{"type":188,"value":519},"3.1.1 目标",{"type":182,"tag":217,"props":521,"children":522},{},[],{"type":188,"value":524},"\n在模型开始处理任务之前，搭建一个“干净、明确、轻量”的初始上下文，让后续推理在良好约束下进行。",{"type":182,"tag":191,"props":526,"children":527},{},[528],{"type":188,"value":529},"3.1.2 关键实践",{"type":182,"tag":207,"props":531,"children":532},{},[533],{"type":182,"tag":211,"props":534,"children":535},{},[536],{"type":188,"value":537},"极简系统提示词",{"type":182,"tag":223,"props":539,"children":540},{},[541,546,551],{"type":182,"tag":211,"props":542,"children":543},{},[544],{"type":188,"value":545},"避免在系统提示里堆积过多要求",{"type":182,"tag":211,"props":547,"children":548},{},[549],{"type":188,"value":550},"只保留核心角色设定和关键约束",{"type":182,"tag":211,"props":552,"children":553},{},[554],{"type":188,"value":555},"其他细节通过工具、模板或后续指令承载",{"type":182,"tag":207,"props":557,"children":558},{"start":419},[559],{"type":182,"tag":211,"props":560,"children":561},{},[562],{"type":188,"value":563},"规范化少样本示例（Canonical Few-shot）",{"type":182,"tag":223,"props":565,"children":566},{},[567,572,577],{"type":182,"tag":211,"props":568,"children":569},{},[570],{"type":188,"value":571},"为高频任务设计标准示例集",{"type":182,"tag":211,"props":573,"children":574},{},[575],{"type":188,"value":576},"示例结构统一：输入格式、思考过程、输出格式",{"type":182,"tag":211,"props":578,"children":579},{},[580],{"type":188,"value":581},"通过“几个高质量样例”塑造模型行为，而不是大量杂乱样例",{"type":182,"tag":207,"props":583,"children":584},{"start":503},[585],{"type":182,"tag":211,"props":586,"children":587},{},[588],{"type":188,"value":589},"token 高效的工具与结构",{"type":182,"tag":223,"props":591,"children":592},{},[593,598,603],{"type":182,"tag":211,"props":594,"children":595},{},[596],{"type":188,"value":597},"将复杂逻辑下沉到工具（代码、API），让模型通过自然语言调用",{"type":182,"tag":211,"props":599,"children":600},{},[601],{"type":188,"value":602},"用紧凑的数据表示（ID、引用、索引）替代冗长文本",{"type":182,"tag":211,"props":604,"children":605},{},[606],{"type":188,"value":607},"用模板化结构（JSON、表格样式文本）减少解释成本",{"type":182,"tag":191,"props":609,"children":610},{},[611],{"type":188,"value":612},"3.2 情境管理：长周期任务（Context Management for Long-horizon Tasks）",{"type":182,"tag":191,"props":614,"children":615},{},[616,618,621],{"type":188,"value":617},"3.2.1 问题背景",{"type":182,"tag":217,"props":619,"children":620},{},[],{"type":188,"value":622},"\n在长周期、多轮对话或复杂流程中：",{"type":182,"tag":223,"props":624,"children":625},{},[626,631,636],{"type":182,"tag":211,"props":627,"children":628},{},[629],{"type":188,"value":630},"模型的上下文窗口有限",{"type":182,"tag":211,"props":632,"children":633},{},[634],{"type":188,"value":635},"历史信息会不断被新内容挤出",{"type":182,"tag":211,"props":637,"children":638},{},[639],{"type":188,"value":640},"重要决策、约定和中间结论容易丢失",{"type":182,"tag":191,"props":642,"children":643},{},[644],{"type":188,"value":645},"3.2.2 关键实践",{"type":182,"tag":207,"props":647,"children":648},{},[649],{"type":182,"tag":211,"props":650,"children":651},{},[652],{"type":188,"value":653},"上下文摘要",{"type":182,"tag":223,"props":655,"children":656},{},[657,680],{"type":182,"tag":211,"props":658,"children":659},{},[660,662],{"type":188,"value":661},"周期性地对对话/步骤做总结，保留：\n",{"type":182,"tag":223,"props":663,"children":664},{},[665,670,675],{"type":182,"tag":211,"props":666,"children":667},{},[668],{"type":188,"value":669},"关键决策",{"type":182,"tag":211,"props":671,"children":672},{},[673],{"type":188,"value":674},"重要中间结论",{"type":182,"tag":211,"props":676,"children":677},{},[678],{"type":188,"value":679},"未解决的问题与假设",{"type":182,"tag":211,"props":681,"children":682},{},[683],{"type":188,"value":684},"用摘要替换长对话原文，以压缩 token",{"type":182,"tag":207,"props":686,"children":687},{"start":419},[688],{"type":182,"tag":211,"props":689,"children":690},{},[691],{"type":188,"value":692},"结构化笔记 / 外部记忆",{"type":182,"tag":223,"props":694,"children":695},{},[696,719],{"type":182,"tag":211,"props":697,"children":698},{},[699,701],{"type":188,"value":700},"将重要信息写入外部结构：\n",{"type":182,"tag":223,"props":702,"children":703},{},[704,709,714],{"type":182,"tag":211,"props":705,"children":706},{},[707],{"type":188,"value":708},"任务目标与约束",{"type":182,"tag":211,"props":710,"children":711},{},[712],{"type":188,"value":713},"当前状态与进度",{"type":182,"tag":211,"props":715,"children":716},{},[717],{"type":188,"value":718},"已完成与待办列表",{"type":182,"tag":211,"props":720,"children":721},{},[722],{"type":188,"value":723},"以“笔记”形式重新注入上下文，而不是反复传入全部历史对话",{"type":182,"tag":207,"props":725,"children":726},{"start":503},[727],{"type":182,"tag":211,"props":728,"children":729},{},[730],{"type":188,"value":731},"子代理架构（Sub-agent Architectures）",{"type":182,"tag":223,"props":733,"children":734},{},[735,740,745,750],{"type":182,"tag":211,"props":736,"children":737},{},[738],{"type":188,"value":739},"将复杂任务拆解为多类子任务：分析、规划、执行、评审等",{"type":182,"tag":211,"props":741,"children":742},{},[743],{"type":188,"value":744},"每个子代理只保留与自己子任务强相关的局部上下文",{"type":182,"tag":211,"props":746,"children":747},{},[748],{"type":188,"value":749},"对子代理输出进行摘要，再汇总给主代理",{"type":182,"tag":211,"props":751,"children":752},{},[753],{"type":188,"value":754},"通过“隔离 + 摘要”控制整体上下文体积与噪音",{"type":182,"tag":191,"props":756,"children":757},{},[758],{"type":188,"value":759},"3.2.3 效果",{"type":182,"tag":223,"props":761,"children":762},{},[763,768,773],{"type":182,"tag":211,"props":764,"children":765},{},[766],{"type":188,"value":767},"减少无关历史对当前推理的干扰",{"type":182,"tag":211,"props":769,"children":770},{},[771],{"type":188,"value":772},"在有限上下文内维持对长期任务的一致理解",{"type":182,"tag":211,"props":774,"children":775},{},[776],{"type":188,"value":777},"提升长流程、多阶段系统的稳定性和可追溯性",{"type":182,"tag":191,"props":779,"children":780},{},[781],{"type":188,"value":782},"3.3 动态信息检索（Dynamic Information Retrieval）",{"type":182,"tag":191,"props":784,"children":785},{},[786,788,791],{"type":188,"value":787},"3.3.1 核心思想：JIT（Just-in-Time）",{"type":182,"tag":217,"props":789,"children":790},{},[],{"type":188,"value":792},"\n动态信息检索强调“按需加载”：",{"type":182,"tag":223,"props":794,"children":795},{},[796,801,806],{"type":182,"tag":211,"props":797,"children":798},{},[799],{"type":188,"value":800},"不在一开始就把所有可能相关的信息塞给模型",{"type":182,"tag":211,"props":802,"children":803},{},[804],{"type":188,"value":805},"由智能体在推理过程中判断何时需要外部知识",{"type":182,"tag":211,"props":807,"children":808},{},[809],{"type":188,"value":810},"只在“当下这一步”真的需要时，才发起检索或工具调用",{"type":182,"tag":191,"props":812,"children":813},{},[814],{"type":188,"value":815},"3.3.2 关键实践",{"type":182,"tag":207,"props":817,"children":818},{},[819],{"type":182,"tag":211,"props":820,"children":821},{},[822],{"type":188,"value":823},"JIT 检索策略",{"type":182,"tag":223,"props":825,"children":826},{},[827,832,837],{"type":182,"tag":211,"props":828,"children":829},{},[830],{"type":188,"value":831},"让代理先进行初步思考，识别信息缺口",{"type":182,"tag":211,"props":833,"children":834},{},[835],{"type":188,"value":836},"在识别缺口后，触发检索：知识库、数据库、API、搜索等",{"type":182,"tag":211,"props":838,"children":839},{},[840],{"type":188,"value":841},"将检索结果以结构化方式注入后续上下文",{"type":182,"tag":207,"props":843,"children":844},{"start":419},[845],{"type":182,"tag":211,"props":846,"children":847},{},[848],{"type":188,"value":849},"精准匹配与裁剪",{"type":182,"tag":223,"props":851,"children":852},{},[853,858],{"type":182,"tag":211,"props":854,"children":855},{},[856],{"type":188,"value":857},"使用向量检索 / 结构化查询，尽量只返回“最相关的少量片段”",{"type":182,"tag":211,"props":859,"children":860},{},[861],{"type":188,"value":862},"对检索结果做二次过滤与摘要，降低噪音和 token 消耗",{"type":182,"tag":207,"props":864,"children":865},{"start":503},[866],{"type":182,"tag":211,"props":867,"children":868},{},[869],{"type":188,"value":870},"与工具生态结合",{"type":182,"tag":223,"props":872,"children":873},{},[874,879],{"type":182,"tag":211,"props":875,"children":876},{},[877],{"type":188,"value":878},"把外部系统封装成“可调用工具”，由代理按需调用",{"type":182,"tag":211,"props":880,"children":881},{},[882],{"type":188,"value":883},"工具返回数据尽量结构化（JSON 等），便于后处理与复用",{"type":182,"tag":191,"props":885,"children":886},{},[887],{"type":188,"value":888},"3.3.3 目标效果",{"type":182,"tag":223,"props":890,"children":891},{},[892,897,902],{"type":182,"tag":211,"props":893,"children":894},{},[895],{"type":188,"value":896},"在保持结果质量的前提下，最小化上下文体积",{"type":182,"tag":211,"props":898,"children":899},{},[900],{"type":188,"value":901},"避免信息过载导致模型“跑偏”或陷入无关细节",{"type":182,"tag":211,"props":903,"children":904},{},[905],{"type":188,"value":906},"实现更高的时效性和更好的领域适配（通过实时数据源）",{"type":182,"tag":207,"props":908,"children":910},{"start":909},4,[911],{"type":182,"tag":211,"props":912,"children":913},{},[914],{"type":188,"value":340},{"type":182,"tag":191,"props":916,"children":917},{},[918],{"type":188,"value":919},"4.1 设计层面",{"type":182,"tag":223,"props":921,"children":922},{},[923,928,951],{"type":182,"tag":211,"props":924,"children":925},{},[926],{"type":188,"value":927},"把“上下文”当成系统的一等公民来建模，而不是零散的 prompt 文本",{"type":182,"tag":211,"props":929,"children":930},{},[931,933],{"type":188,"value":932},"明确区分：\n",{"type":182,"tag":223,"props":934,"children":935},{},[936,941,946],{"type":182,"tag":211,"props":937,"children":938},{},[939],{"type":188,"value":940},"固定长期配置：角色、全局约束",{"type":182,"tag":211,"props":942,"children":943},{},[944],{"type":188,"value":945},"任务级配置：目标、输入、成功标准",{"type":182,"tag":211,"props":947,"children":948},{},[949],{"type":188,"value":950},"步骤级配置：当前子任务相关信息",{"type":182,"tag":211,"props":952,"children":953},{},[954],{"type":188,"value":955},"为这三层分别设计结构与更新策略",{"type":182,"tag":191,"props":957,"children":958},{},[959],{"type":188,"value":960},"4.2 工程实现层面",{"type":182,"tag":223,"props":962,"children":963},{},[964,982],{"type":182,"tag":211,"props":965,"children":966},{},[967,969],{"type":188,"value":968},"引入“上下文编排层”：\n",{"type":182,"tag":223,"props":970,"children":971},{},[972,977],{"type":182,"tag":211,"props":973,"children":974},{},[975],{"type":188,"value":976},"负责收集、过滤、排序各种信息源",{"type":182,"tag":211,"props":978,"children":979},{},[980],{"type":188,"value":981},"输出给模型的是一个结构化、可解释的最终上下文",{"type":182,"tag":211,"props":983,"children":984},{},[985,987],{"type":188,"value":986},"内置常用能力模块：\n",{"type":182,"tag":223,"props":988,"children":989},{},[990,995,1000],{"type":182,"tag":211,"props":991,"children":992},{},[993],{"type":188,"value":994},"摘要模块（对历史、对子代理输出）",{"type":182,"tag":211,"props":996,"children":997},{},[998],{"type":188,"value":999},"检索模块（向量、全文、结构化）",{"type":182,"tag":211,"props":1001,"children":1002},{},[1003],{"type":188,"value":1004},"记忆模块（长期笔记、会话级存储）",{"type":182,"tag":191,"props":1006,"children":1007},{},[1008],{"type":188,"value":1009},"4.3 评估与优化",{"type":182,"tag":223,"props":1011,"children":1012},{},[1013,1036],{"type":182,"tag":211,"props":1014,"children":1015},{},[1016,1018],{"type":188,"value":1017},"不只评估“单轮回答质量”，还要评估：\n",{"type":182,"tag":223,"props":1019,"children":1020},{},[1021,1026,1031],{"type":182,"tag":211,"props":1022,"children":1023},{},[1024],{"type":188,"value":1025},"长任务中的一致性",{"type":182,"tag":211,"props":1027,"children":1028},{},[1029],{"type":188,"value":1030},"信息利用率（用到的 vs 提供的）",{"type":182,"tag":211,"props":1032,"children":1033},{},[1034],{"type":188,"value":1035},"token 成本和延迟",{"type":182,"tag":211,"props":1037,"children":1038},{},[1039,1041],{"type":188,"value":1040},"用实验对比不同情境策略：\n",{"type":182,"tag":223,"props":1042,"children":1043},{},[1044,1049,1054],{"type":182,"tag":211,"props":1045,"children":1046},{},[1047],{"type":188,"value":1048},"不同摘要粒度",{"type":182,"tag":211,"props":1050,"children":1051},{},[1052],{"type":188,"value":1053},"不同检索阈值",{"type":182,"tag":211,"props":1055,"children":1056},{},[1057],{"type":188,"value":1058},"不同子代理拆分方式",{"type":182,"tag":191,"props":1060,"children":1061},{},[1062],{"type":188,"value":1063},"通过将以上三大方向（情境搭建、情境管理、动态检索）纳入统一架构设计，可以从“单次 prompt 调优”升级为“上下文系统工程”，在复杂场景下显著提高大模型应用的可靠性、效率与可维护性。",{"title":175,"searchDepth":419,"depth":419,"links":1065},[1066,1067],{"id":185,"depth":419,"text":189},{"id":294,"depth":419,"text":297},"markdown","content:6.maps:_ai:prompt:context-engineering.md","content","6.maps/_ai/prompt/context-engineering.md","6.maps/_ai/prompt/context-engineering","md",[1075,1079],{"_path":1076,"title":1077,"description":1078},"/maps/_ai/mcp/native-api-to-mcp","反对「直接把内部 API 暴露成 MCP」的天真做法","原文反对将现有内部 API 直接转换为 MCP，建议为代理场景专门设计安全的 MCP 服务层。",{"_path":1080,"title":1081,"description":1082},"/maps/_ai/prompt/prompt","Prompt","Prompt 是与 AI 模型交互的指令或问题，旨在引导模型生成特定的响应或执行特定的任务。它们可以是简单的查询，也可以是复杂的任务描述。",1771214958131]