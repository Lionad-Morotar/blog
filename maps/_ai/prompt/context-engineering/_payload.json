","Context Engineering","Context Engineering 是一种优化与大型语言模型（LLM）交互的技术，旨在通过提供结构化和相关的上下文信息，提高模型生成内容的准确性和相关性。",{"type":182,"children":183,"toc":1067},"root",[184,193,199,204,209,295,301,306,344,349,357,372,382,415,420,428,438,456,466,489,504,513,518,528,533,541,559,567,585,593,611,616,626,644,649,657,688,696,727,735,758,763,781,786,796,814,819,827,845,853,866,874,887,892,910,918,923,959,964,1008,1013,1062],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"brief",[190],{"type":191,"value":192},"text","Brief",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"上下文工程是指在推理阶段，对提供给大语言模型的信息进行系统化的设计与优化，从而稳定地产生期望输出。它的核心是对各种情境要素进行结构化、选择和排序——例如提示词、检索到的数据、记忆、指令以及环境信号等——以便让模型的内部层次在一种最优状态下运行。",{"type":185,"tag":194,"props":200,"children":201},{},[202],{"type":191,"value":203},"与只关注提示词措辞的提示工程不同，上下文工程关心的是“情境”的完整配置：相关知识、指令和历史上下文是如何被组织和投递的，以便实现最有效的结果。",{"type":185,"tag":194,"props":205,"children":206},{},[207],{"type":191,"value":208},"目前，工程师会使用一系列离散的技术，这些技术大致可以分为三个方向：",{"type":185,"tag":210,"props":211,"children":212},"ol",{},[213,244,272],{"type":185,"tag":214,"props":215,"children":216},"li",{},[217,219,223,225],{"type":191,"value":218},"情境搭建（Context setup）",{"type":185,"tag":220,"props":221,"children":222},"br",{},[],{"type":191,"value":224},"\n主要关注“上下文的初始配置与精简”，包括：",{"type":185,"tag":226,"props":227,"children":228},"ul",{},[229,234,239],{"type":185,"tag":214,"props":230,"children":231},{},[232],{"type":191,"value":233},"使用极简的系统提示词",{"type":185,"tag":214,"props":235,"children":236},{},[237],{"type":191,"value":238},"使用规范化（canonical）的少样本示例",{"type":185,"tag":214,"props":240,"children":241},{},[242],{"type":191,"value":243},"使用高效利用 token 的工具来支持果断行动",{"type":185,"tag":214,"props":245,"children":246},{},[247,249,252,254],{"type":191,"value":248},"情境管理（Context management for long-horizon tasks）",{"type":185,"tag":220,"props":250,"children":251},{},[],{"type":191,"value":253},"\n面向长周期任务，解决有限上下文窗口的问题，包括：",{"type":185,"tag":226,"props":255,"children":256},{},[257,262,267],{"type":185,"tag":214,"props":258,"children":259},{},[260],{"type":191,"value":261},"上下文摘要，将较长历史压缩成关键信息",{"type":185,"tag":214,"props":263,"children":264},{},[265],{"type":191,"value":266},"结构化笔记，用外部持久化记忆记录关键过程与结论",{"type":185,"tag":214,"props":268,"children":269},{},[270],{"type":191,"value":271},"子代理架构，将复杂任务拆解为子任务，并在子任务层面进行隔离与摘要",{"type":185,"tag":214,"props":273,"children":274},{},[275,277,280,282],{"type":191,"value":276},"动态信息检索（Dynamic information retrieval）",{"type":185,"tag":220,"props":278,"children":279},{},[],{"type":191,"value":281},"\n依赖“即时（Just-in-Time, JIT）上下文检索”：",{"type":185,"tag":226,"props":283,"children":284},{},[285,290],{"type":185,"tag":214,"props":286,"children":287},{},[288],{"type":191,"value":289},"只有在确实需要时，智能体才自主加载外部数据",{"type":185,"tag":214,"props":291,"children":292},{},[293],{"type":191,"value":294},"通过这种按需拉取的方式，最大化信息利用效率与推理精度",{"type":185,"tag":186,"props":296,"children":298},{"id":297},"details",[299],{"type":191,"value":300},"Details",{"type":185,"tag":194,"props":302,"children":303},{},[304],{"type":191,"value":305},"目录",{"type":185,"tag":210,"props":307,"children":308},{},[309,314,319,339],{"type":185,"tag":214,"props":310,"children":311},{},[312],{"type":191,"value":313},"什么是上下文工程",{"type":185,"tag":214,"props":315,"children":316},{},[317],{"type":191,"value":318},"上下文工程 vs 提示工程",{"type":185,"tag":214,"props":320,"children":321},{},[322,324,327,329,332,334,337],{"type":191,"value":323},"上下文工程的三大方向（架构颗粒度）",{"type":185,"tag":220,"props":325,"children":326},{},[],{"type":191,"value":328},"\n3.1 情境搭建（Context Setup）",{"type":185,"tag":220,"props":330,"children":331},{},[],{"type":191,"value":333},"\n3.2 情境管理：长周期任务（Context Management）",{"type":185,"tag":220,"props":335,"children":336},{},[],{"type":191,"value":338},"\n3.3 动态信息检索（Dynamic Information Retrieval）",{"type":185,"tag":214,"props":340,"children":341},{},[342],{"type":191,"value":343},"实践要点与落地建议",{"type":185,"tag":194,"props":345,"children":346},{},[347],{"type":191,"value":348},"——————————",{"type":185,"tag":210,"props":350,"children":351},{},[352],{"type":185,"tag":214,"props":353,"children":354},{},[355],{"type":191,"value":356},"什么是上下文工程（Context Engineering）",{"type":185,"tag":194,"props":358,"children":359},{},[360,362,365,367,370],{"type":191,"value":361},"1.1 概念",{"type":185,"tag":220,"props":363,"children":364},{},[],{"type":191,"value":366},"\n上下文工程是在推理阶段，对“喂给大模型的所有信息”进行整体设计和优化的一套方法论与工程实践。",{"type":185,"tag":220,"props":368,"children":369},{},[],{"type":191,"value":371},"\n它关心的是整个“上下文配置”如何影响模型内部状态，从而影响输出质量和稳定性。",{"type":185,"tag":194,"props":373,"children":374},{},[375,377,380],{"type":191,"value":376},"1.2 对象范围",{"type":185,"tag":220,"props":378,"children":379},{},[],{"type":191,"value":381},"\n上下文工程覆盖但不限于：",{"type":185,"tag":226,"props":383,"children":384},{},[385,390,395,400,405,410],{"type":185,"tag":214,"props":386,"children":387},{},[388],{"type":191,"value":389},"系统提示词与角色设定",{"type":185,"tag":214,"props":391,"children":392},{},[393],{"type":191,"value":394},"用户指令与任务描述",{"type":185,"tag":214,"props":396,"children":397},{},[398],{"type":191,"value":399},"少样本示例与模板",{"type":185,"tag":214,"props":401,"children":402},{},[403],{"type":191,"value":404},"从外部系统检索到的数据",{"type":185,"tag":214,"props":406,"children":407},{},[408],{"type":191,"value":409},"会话历史与外部记忆（notes、知识库等）",{"type":185,"tag":214,"props":411,"children":412},{},[413],{"type":191,"value":414},"环境信号（如工具调用结果、系统状态等）",{"type":185,"tag":194,"props":416,"children":417},{},[418],{"type":191,"value":419},"这些都被视作“情境元素”，需要被合理组织和调度。",{"type":185,"tag":210,"props":421,"children":423},{"start":422},2,[424],{"type":185,"tag":214,"props":425,"children":426},{},[427],{"type":191,"value":318},{"type":185,"tag":194,"props":429,"children":430},{},[431,433,436],{"type":191,"value":432},"2.1 提示工程关注点",{"type":185,"tag":220,"props":434,"children":435},{},[],{"type":191,"value":437},"\n提示工程主要聚焦在一句或若干句“prompt”的写法：",{"type":185,"tag":226,"props":439,"children":440},{},[441,446,451],{"type":185,"tag":214,"props":442,"children":443},{},[444],{"type":191,"value":445},"如何更清晰地描述任务",{"type":185,"tag":214,"props":447,"children":448},{},[449],{"type":191,"value":450},"如何减少歧义",{"type":185,"tag":214,"props":452,"children":453},{},[454],{"type":191,"value":455},"如何通过措辞影响模型行为",{"type":185,"tag":194,"props":457,"children":458},{},[459,461,464],{"type":191,"value":460},"2.2 上下文工程关注点",{"type":185,"tag":220,"props":462,"children":463},{},[],{"type":191,"value":465},"\n上下文工程则关注：",{"type":185,"tag":226,"props":467,"children":468},{},[469,474,479,484],{"type":185,"tag":214,"props":470,"children":471},{},[472],{"type":191,"value":473},"用哪些信息：信息源选择、过滤、裁剪",{"type":185,"tag":214,"props":475,"children":476},{},[477],{"type":191,"value":478},"以什么结构组织：分块、层级、标签、模板化",{"type":185,"tag":214,"props":480,"children":481},{},[482],{"type":191,"value":483},"以什么顺序喂给模型：先指令、后知识，或先总结、后追问等",{"type":185,"tag":214,"props":485,"children":486},{},[487],{"type":191,"value":488},"在整个任务生命周期内，如何滚动维护与更新上下文",{"type":185,"tag":194,"props":490,"children":491},{},[492,494,497,499,502],{"type":191,"value":493},"可以理解为：",{"type":185,"tag":220,"props":495,"children":496},{},[],{"type":191,"value":498},"\n提示工程是“怎么说这句话”，",{"type":185,"tag":220,"props":500,"children":501},{},[],{"type":191,"value":503},"\n上下文工程是“说什么、按什么结构说、在什么时机说，以及说给谁（哪个子代理）听”。",{"type":185,"tag":210,"props":505,"children":507},{"start":506},3,[508],{"type":185,"tag":214,"props":509,"children":510},{},[511],{"type":191,"value":512},"上下文工程的三大方向",{"type":185,"tag":194,"props":514,"children":515},{},[516],{"type":191,"value":517},"3.1 情境搭建（Context Setup）",{"type":185,"tag":194,"props":519,"children":520},{},[521,523,526],{"type":191,"value":522},"3.1.1 目标",{"type":185,"tag":220,"props":524,"children":525},{},[],{"type":191,"value":527},"\n在模型开始处理任务之前，搭建一个“干净、明确、轻量”的初始上下文，让后续推理在良好约束下进行。",{"type":185,"tag":194,"props":529,"children":530},{},[531],{"type":191,"value":532},"3.1.2 关键实践",{"type":185,"tag":210,"props":534,"children":535},{},[536],{"type":185,"tag":214,"props":537,"children":538},{},[539],{"type":191,"value":540},"极简系统提示词",{"type":185,"tag":226,"props":542,"children":543},{},[544,549,554],{"type":185,"tag":214,"props":545,"children":546},{},[547],{"type":191,"value":548},"避免在系统提示里堆积过多要求",{"type":185,"tag":214,"props":550,"children":551},{},[552],{"type":191,"value":553},"只保留核心角色设定和关键约束",{"type":185,"tag":214,"props":555,"children":556},{},[557],{"type":191,"value":558},"其他细节通过工具、模板或后续指令承载",{"type":185,"tag":210,"props":560,"children":561},{"start":422},[562],{"type":185,"tag":214,"props":563,"children":564},{},[565],{"type":191,"value":566},"规范化少样本示例（Canonical Few-shot）",{"type":185,"tag":226,"props":568,"children":569},{},[570,575,580],{"type":185,"tag":214,"props":571,"children":572},{},[573],{"type":191,"value":574},"为高频任务设计标准示例集",{"type":185,"tag":214,"props":576,"children":577},{},[578],{"type":191,"value":579},"示例结构统一：输入格式、思考过程、输出格式",{"type":185,"tag":214,"props":581,"children":582},{},[583],{"type":191,"value":584},"通过“几个高质量样例”塑造模型行为，而不是大量杂乱样例",{"type":185,"tag":210,"props":586,"children":587},{"start":506},[588],{"type":185,"tag":214,"props":589,"children":590},{},[591],{"type":191,"value":592},"token 高效的工具与结构",{"type":185,"tag":226,"props":594,"children":595},{},[596,601,606],{"type":185,"tag":214,"props":597,"children":598},{},[599],{"type":191,"value":600},"将复杂逻辑下沉到工具（代码、API），让模型通过自然语言调用",{"type":185,"tag":214,"props":602,"children":603},{},[604],{"type":191,"value":605},"用紧凑的数据表示（ID、引用、索引）替代冗长文本",{"type":185,"tag":214,"props":607,"children":608},{},[609],{"type":191,"value":610},"用模板化结构（JSON、表格样式文本）减少解释成本",{"type":185,"tag":194,"props":612,"children":613},{},[614],{"type":191,"value":615},"3.2 情境管理：长周期任务（Context Management for Long-horizon Tasks）",{"type":185,"tag":194,"props":617,"children":618},{},[619,621,624],{"type":191,"value":620},"3.2.1 问题背景",{"type":185,"tag":220,"props":622,"children":623},{},[],{"type":191,"value":625},"\n在长周期、多轮对话或复杂流程中：",{"type":185,"tag":226,"props":627,"children":628},{},[629,634,639],{"type":185,"tag":214,"props":630,"children":631},{},[632],{"type":191,"value":633},"模型的上下文窗口有限",{"type":185,"tag":214,"props":635,"children":636},{},[637],{"type":191,"value":638},"历史信息会不断被新内容挤出",{"type":185,"tag":214,"props":640,"children":641},{},[642],{"type":191,"value":643},"重要决策、约定和中间结论容易丢失",{"type":185,"tag":194,"props":645,"children":646},{},[647],{"type":191,"value":648},"3.2.2 关键实践",{"type":185,"tag":210,"props":650,"children":651},{},[652],{"type":185,"tag":214,"props":653,"children":654},{},[655],{"type":191,"value":656},"上下文摘要",{"type":185,"tag":226,"props":658,"children":659},{},[660,683],{"type":185,"tag":214,"props":661,"children":662},{},[663,665],{"type":191,"value":664},"周期性地对对话/步骤做总结，保留：\n",{"type":185,"tag":226,"props":666,"children":667},{},[668,673,678],{"type":185,"tag":214,"props":669,"children":670},{},[671],{"type":191,"value":672},"关键决策",{"type":185,"tag":214,"props":674,"children":675},{},[676],{"type":191,"value":677},"重要中间结论",{"type":185,"tag":214,"props":679,"children":680},{},[681],{"type":191,"value":682},"未解决的问题与假设",{"type":185,"tag":214,"props":684,"children":685},{},[686],{"type":191,"value":687},"用摘要替换长对话原文，以压缩 token",{"type":185,"tag":210,"props":689,"children":690},{"start":422},[691],{"type":185,"tag":214,"props":692,"children":693},{},[694],{"type":191,"value":695},"结构化笔记 / 外部记忆",{"type":185,"tag":226,"props":697,"children":698},{},[699,722],{"type":185,"tag":214,"props":700,"children":701},{},[702,704],{"type":191,"value":703},"将重要信息写入外部结构：\n",{"type":185,"tag":226,"props":705,"children":706},{},[707,712,717],{"type":185,"tag":214,"props":708,"children":709},{},[710],{"type":191,"value":711},"任务目标与约束",{"type":185,"tag":214,"props":713,"children":714},{},[715],{"type":191,"value":716},"当前状态与进度",{"type":185,"tag":214,"props":718,"children":719},{},[720],{"type":191,"value":721},"已完成与待办列表",{"type":185,"tag":214,"props":723,"children":724},{},[725],{"type":191,"value":726},"以“笔记”形式重新注入上下文，而不是反复传入全部历史对话",{"type":185,"tag":210,"props":728,"children":729},{"start":506},[730],{"type":185,"tag":214,"props":731,"children":732},{},[733],{"type":191,"value":734},"子代理架构（Sub-agent Architectures）",{"type":185,"tag":226,"props":736,"children":737},{},[738,743,748,753],{"type":185,"tag":214,"props":739,"children":740},{},[741],{"type":191,"value":742},"将复杂任务拆解为多类子任务：分析、规划、执行、评审等",{"type":185,"tag":214,"props":744,"children":745},{},[746],{"type":191,"value":747},"每个子代理只保留与自己子任务强相关的局部上下文",{"type":185,"tag":214,"props":749,"children":750},{},[751],{"type":191,"value":752},"对子代理输出进行摘要，再汇总给主代理",{"type":185,"tag":214,"props":754,"children":755},{},[756],{"type":191,"value":757},"通过“隔离 + 摘要”控制整体上下文体积与噪音",{"type":185,"tag":194,"props":759,"children":760},{},[761],{"type":191,"value":762},"3.2.3 效果",{"type":185,"tag":226,"props":764,"children":765},{},[766,771,776],{"type":185,"tag":214,"props":767,"children":768},{},[769],{"type":191,"value":770},"减少无关历史对当前推理的干扰",{"type":185,"tag":214,"props":772,"children":773},{},[774],{"type":191,"value":775},"在有限上下文内维持对长期任务的一致理解",{"type":185,"tag":214,"props":777,"children":778},{},[779],{"type":191,"value":780},"提升长流程、多阶段系统的稳定性和可追溯性",{"type":185,"tag":194,"props":782,"children":783},{},[784],{"type":191,"value":785},"3.3 动态信息检索（Dynamic Information Retrieval）",{"type":185,"tag":194,"props":787,"children":788},{},[789,791,794],{"type":191,"value":790},"3.3.1 核心思想：JIT（Just-in-Time）",{"type":185,"tag":220,"props":792,"children":793},{},[],{"type":191,"value":795},"\n动态信息检索强调“按需加载”：",{"type":185,"tag":226,"props":797,"children":798},{},[799,804,809],{"type":185,"tag":214,"props":800,"children":801},{},[802],{"type":191,"value":803},"不在一开始就把所有可能相关的信息塞给模型",{"type":185,"tag":214,"props":805,"children":806},{},[807],{"type":191,"value":808},"由智能体在推理过程中判断何时需要外部知识",{"type":185,"tag":214,"props":810,"children":811},{},[812],{"type":191,"value":813},"只在“当下这一步”真的需要时，才发起检索或工具调用",{"type":185,"tag":194,"props":815,"children":816},{},[817],{"type":191,"value":818},"3.3.2 关键实践",{"type":185,"tag":210,"props":820,"children":821},{},[822],{"type":185,"tag":214,"props":823,"children":824},{},[825],{"type":191,"value":826},"JIT 检索策略",{"type":185,"tag":226,"props":828,"children":829},{},[830,835,840],{"type":185,"tag":214,"props":831,"children":832},{},[833],{"type":191,"value":834},"让代理先进行初步思考，识别信息缺口",{"type":185,"tag":214,"props":836,"children":837},{},[838],{"type":191,"value":839},"在识别缺口后，触发检索：知识库、数据库、API、搜索等",{"type":185,"tag":214,"props":841,"children":842},{},[843],{"type":191,"value":844},"将检索结果以结构化方式注入后续上下文",{"type":185,"tag":210,"props":846,"children":847},{"start":422},[848],{"type":185,"tag":214,"props":849,"children":850},{},[851],{"type":191,"value":852},"精准匹配与裁剪",{"type":185,"tag":226,"props":854,"children":855},{},[856,861],{"type":185,"tag":214,"props":857,"children":858},{},[859],{"type":191,"value":860},"使用向量检索 / 结构化查询，尽量只返回“最相关的少量片段”",{"type":185,"tag":214,"props":862,"children":863},{},[864],{"type":191,"value":865},"对检索结果做二次过滤与摘要，降低噪音和 token 消耗",{"type":185,"tag":210,"props":867,"children":868},{"start":506},[869],{"type":185,"tag":214,"props":870,"children":871},{},[872],{"type":191,"value":873},"与工具生态结合",{"type":185,"tag":226,"props":875,"children":876},{},[877,882],{"type":185,"tag":214,"props":878,"children":879},{},[880],{"type":191,"value":881},"把外部系统封装成“可调用工具”，由代理按需调用",{"type":185,"tag":214,"props":883,"children":884},{},[885],{"type":191,"value":886},"工具返回数据尽量结构化（JSON 等），便于后处理与复用",{"type":185,"tag":194,"props":888,"children":889},{},[890],{"type":191,"value":891},"3.3.3 目标效果",{"type":185,"tag":226,"props":893,"children":894},{},[895,900,905],{"type":185,"tag":214,"props":896,"children":897},{},[898],{"type":191,"value":899},"在保持结果质量的前提下，最小化上下文体积",{"type":185,"tag":214,"props":901,"children":902},{},[903],{"type":191,"value":904},"避免信息过载导致模型“跑偏”或陷入无关细节",{"type":185,"tag":214,"props":906,"children":907},{},[908],{"type":191,"value":909},"实现更高的时效性和更好的领域适配（通过实时数据源）",{"type":185,"tag":210,"props":911,"children":913},{"start":912},4,[914],{"type":185,"tag":214,"props":915,"children":916},{},[917],{"type":191,"value":343},{"type":185,"tag":194,"props":919,"children":920},{},[921],{"type":191,"value":922},"4.1 设计层面",{"type":185,"tag":226,"props":924,"children":925},{},[926,931,954],{"type":185,"tag":214,"props":927,"children":928},{},[929],{"type":191,"value":930},"把“上下文”当成系统的一等公民来建模，而不是零散的 prompt 文本",{"type":185,"tag":214,"props":932,"children":933},{},[934,936],{"type":191,"value":935},"明确区分：\n",{"type":185,"tag":226,"props":937,"children":938},{},[939,944,949],{"type":185,"tag":214,"props":940,"children":941},{},[942],{"type":191,"value":943},"固定长期配置：角色、全局约束",{"type":185,"tag":214,"props":945,"children":946},{},[947],{"type":191,"value":948},"任务级配置：目标、输入、成功标准",{"type":185,"tag":214,"props":950,"children":951},{},[952],{"type":191,"value":953},"步骤级配置：当前子任务相关信息",{"type":185,"tag":214,"props":955,"children":956},{},[957],{"type":191,"value":958},"为这三层分别设计结构与更新策略",{"type":185,"tag":194,"props":960,"children":961},{},[962],{"type":191,"value":963},"4.2 工程实现层面",{"type":185,"tag":226,"props":965,"children":966},{},[967,985],{"type":185,"tag":214,"props":968,"children":969},{},[970,972],{"type":191,"value":971},"引入“上下文编排层”：\n",{"type":185,"tag":226,"props":973,"children":974},{},[975,980],{"type":185,"tag":214,"props":976,"children":977},{},[978],{"type":191,"value":979},"负责收集、过滤、排序各种信息源",{"type":185,"tag":214,"props":981,"children":982},{},[983],{"type":191,"value":984},"输出给模型的是一个结构化、可解释的最终上下文",{"type":185,"tag":214,"props":986,"children":987},{},[988,990],{"type":191,"value":989},"内置常用能力模块：\n",{"type":185,"tag":226,"props":991,"children":992},{},[993,998,1003],{"type":185,"tag":214,"props":994,"children":995},{},[996],{"type":191,"value":997},"摘要模块（对历史、对子代理输出）",{"type":185,"tag":214,"props":999,"children":1000},{},[1001],{"type":191,"value":1002},"检索模块（向量、全文、结构化）",{"type":185,"tag":214,"props":1004,"children":1005},{},[1006],{"type":191,"value":1007},"记忆模块（长期笔记、会话级存储）",{"type":185,"tag":194,"props":1009,"children":1010},{},[1011],{"type":191,"value":1012},"4.3 评估与优化",{"type":185,"tag":226,"props":1014,"children":1015},{},[1016,1039],{"type":185,"tag":214,"props":1017,"children":1018},{},[1019,1021],{"type":191,"value":1020},"不只评估“单轮回答质量”，还要评估：\n",{"type":185,"tag":226,"props":1022,"children":1023},{},[1024,1029,1034],{"type":185,"tag":214,"props":1025,"children":1026},{},[1027],{"type":191,"value":1028},"长任务中的一致性",{"type":185,"tag":214,"props":1030,"children":1031},{},[1032],{"type":191,"value":1033},"信息利用率（用到的 vs 提供的）",{"type":185,"tag":214,"props":1035,"children":1036},{},[1037],{"type":191,"value":1038},"token 成本和延迟",{"type":185,"tag":214,"props":1040,"children":1041},{},[1042,1044],{"type":191,"value":1043},"用实验对比不同情境策略：\n",{"type":185,"tag":226,"props":1045,"children":1046},{},[1047,1052,1057],{"type":185,"tag":214,"props":1048,"children":1049},{},[1050],{"type":191,"value":1051},"不同摘要粒度",{"type":185,"tag":214,"props":1053,"children":1054},{},[1055],{"type":191,"value":1056},"不同检索阈值",{"type":185,"tag":214,"props":1058,"children":1059},{},[1060],{"type":191,"value":1061},"不同子代理拆分方式",{"type":185,"tag":194,"props":1063,"children":1064},{},[1065],{"type":191,"value":1066},"通过将以上三大方向（情境搭建、情境管理、动态检索）纳入统一架构设计，可以从“单次 prompt 调优”升级为“上下文系统工程”，在复杂场景下显著提高大模型应用的可靠性、效率与可维护性。",{"title":178,"searchDepth":422,"depth":422,"links":1068},[1069,1070],{"id":188,"depth":422,"text":192},{"id":297,"depth":422,"text":300},"markdown","content:6.maps:_ai:prompt:context-engineering.md","content","6.maps/_ai/prompt/context-engineering.md","6.maps/_ai/prompt/context-engineering","md",[1078,1081],{"_path":1079,"title":1080,"description":178},"/maps/_ai/prompt-engineering","提示工程 (Prompt Engineering)",{"_path":1082,"title":1083,"description":1084},"/maps/_ai/prompt/prompt","Prompt","Prompt 是与 AI 模型交互的指令或问题，旨在引导模型生成特定的响应或执行特定的任务。它们可以是简单的查询，也可以是复杂的任务描述。",1771693722931]