prompt",false,true,"","Context Engineering","Context Engineering 是一种优化与大型语言模型（LLM）交互的技术，旨在通过提供结构化和相关的上下文信息，提高模型生成内容的准确性和相关性。","_ai/prompt/context-engineering.md",{"type":183,"children":184,"toc":1068},"root",[185,194,200,205,210,296,302,307,345,350,358,373,383,416,421,429,439,457,467,490,505,514,519,529,534,542,560,568,586,594,612,617,627,645,650,658,689,697,728,736,759,764,782,787,797,815,820,828,846,854,867,875,888,893,911,919,924,960,965,1009,1014,1063],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"brief",[191],{"type":192,"value":193},"text","Brief",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198],{"type":192,"value":199},"上下文工程是指在推理阶段，对提供给大语言模型的信息进行系统化的设计与优化，从而稳定地产生期望输出。它的核心是对各种情境要素进行结构化、选择和排序——例如提示词、检索到的数据、记忆、指令以及环境信号等——以便让模型的内部层次在一种最优状态下运行。",{"type":186,"tag":195,"props":201,"children":202},{},[203],{"type":192,"value":204},"与只关注提示词措辞的提示工程不同，上下文工程关心的是“情境”的完整配置：相关知识、指令和历史上下文是如何被组织和投递的，以便实现最有效的结果。",{"type":186,"tag":195,"props":206,"children":207},{},[208],{"type":192,"value":209},"目前，工程师会使用一系列离散的技术，这些技术大致可以分为三个方向：",{"type":186,"tag":211,"props":212,"children":213},"ol",{},[214,245,273],{"type":186,"tag":215,"props":216,"children":217},"li",{},[218,220,224,226],{"type":192,"value":219},"情境搭建（Context setup）",{"type":186,"tag":221,"props":222,"children":223},"br",{},[],{"type":192,"value":225},"\n主要关注“上下文的初始配置与精简”，包括：",{"type":186,"tag":227,"props":228,"children":229},"ul",{},[230,235,240],{"type":186,"tag":215,"props":231,"children":232},{},[233],{"type":192,"value":234},"使用极简的系统提示词",{"type":186,"tag":215,"props":236,"children":237},{},[238],{"type":192,"value":239},"使用规范化（canonical）的少样本示例",{"type":186,"tag":215,"props":241,"children":242},{},[243],{"type":192,"value":244},"使用高效利用 token 的工具来支持果断行动",{"type":186,"tag":215,"props":246,"children":247},{},[248,250,253,255],{"type":192,"value":249},"情境管理（Context management for long-horizon tasks）",{"type":186,"tag":221,"props":251,"children":252},{},[],{"type":192,"value":254},"\n面向长周期任务，解决有限上下文窗口的问题，包括：",{"type":186,"tag":227,"props":256,"children":257},{},[258,263,268],{"type":186,"tag":215,"props":259,"children":260},{},[261],{"type":192,"value":262},"上下文摘要，将较长历史压缩成关键信息",{"type":186,"tag":215,"props":264,"children":265},{},[266],{"type":192,"value":267},"结构化笔记，用外部持久化记忆记录关键过程与结论",{"type":186,"tag":215,"props":269,"children":270},{},[271],{"type":192,"value":272},"子代理架构，将复杂任务拆解为子任务，并在子任务层面进行隔离与摘要",{"type":186,"tag":215,"props":274,"children":275},{},[276,278,281,283],{"type":192,"value":277},"动态信息检索（Dynamic information retrieval）",{"type":186,"tag":221,"props":279,"children":280},{},[],{"type":192,"value":282},"\n依赖“即时（Just-in-Time, JIT）上下文检索”：",{"type":186,"tag":227,"props":284,"children":285},{},[286,291],{"type":186,"tag":215,"props":287,"children":288},{},[289],{"type":192,"value":290},"只有在确实需要时，智能体才自主加载外部数据",{"type":186,"tag":215,"props":292,"children":293},{},[294],{"type":192,"value":295},"通过这种按需拉取的方式，最大化信息利用效率与推理精度",{"type":186,"tag":187,"props":297,"children":299},{"id":298},"details",[300],{"type":192,"value":301},"Details",{"type":186,"tag":195,"props":303,"children":304},{},[305],{"type":192,"value":306},"目录",{"type":186,"tag":211,"props":308,"children":309},{},[310,315,320,340],{"type":186,"tag":215,"props":311,"children":312},{},[313],{"type":192,"value":314},"什么是上下文工程",{"type":186,"tag":215,"props":316,"children":317},{},[318],{"type":192,"value":319},"上下文工程 vs 提示工程",{"type":186,"tag":215,"props":321,"children":322},{},[323,325,328,330,333,335,338],{"type":192,"value":324},"上下文工程的三大方向（架构颗粒度）",{"type":186,"tag":221,"props":326,"children":327},{},[],{"type":192,"value":329},"\n3.1 情境搭建（Context Setup）",{"type":186,"tag":221,"props":331,"children":332},{},[],{"type":192,"value":334},"\n3.2 情境管理：长周期任务（Context Management）",{"type":186,"tag":221,"props":336,"children":337},{},[],{"type":192,"value":339},"\n3.3 动态信息检索（Dynamic Information Retrieval）",{"type":186,"tag":215,"props":341,"children":342},{},[343],{"type":192,"value":344},"实践要点与落地建议",{"type":186,"tag":195,"props":346,"children":347},{},[348],{"type":192,"value":349},"——————————",{"type":186,"tag":211,"props":351,"children":352},{},[353],{"type":186,"tag":215,"props":354,"children":355},{},[356],{"type":192,"value":357},"什么是上下文工程（Context Engineering）",{"type":186,"tag":195,"props":359,"children":360},{},[361,363,366,368,371],{"type":192,"value":362},"1.1 概念",{"type":186,"tag":221,"props":364,"children":365},{},[],{"type":192,"value":367},"\n上下文工程是在推理阶段，对“喂给大模型的所有信息”进行整体设计和优化的一套方法论与工程实践。",{"type":186,"tag":221,"props":369,"children":370},{},[],{"type":192,"value":372},"\n它关心的是整个“上下文配置”如何影响模型内部状态，从而影响输出质量和稳定性。",{"type":186,"tag":195,"props":374,"children":375},{},[376,378,381],{"type":192,"value":377},"1.2 对象范围",{"type":186,"tag":221,"props":379,"children":380},{},[],{"type":192,"value":382},"\n上下文工程覆盖但不限于：",{"type":186,"tag":227,"props":384,"children":385},{},[386,391,396,401,406,411],{"type":186,"tag":215,"props":387,"children":388},{},[389],{"type":192,"value":390},"系统提示词与角色设定",{"type":186,"tag":215,"props":392,"children":393},{},[394],{"type":192,"value":395},"用户指令与任务描述",{"type":186,"tag":215,"props":397,"children":398},{},[399],{"type":192,"value":400},"少样本示例与模板",{"type":186,"tag":215,"props":402,"children":403},{},[404],{"type":192,"value":405},"从外部系统检索到的数据",{"type":186,"tag":215,"props":407,"children":408},{},[409],{"type":192,"value":410},"会话历史与外部记忆（notes、知识库等）",{"type":186,"tag":215,"props":412,"children":413},{},[414],{"type":192,"value":415},"环境信号（如工具调用结果、系统状态等）",{"type":186,"tag":195,"props":417,"children":418},{},[419],{"type":192,"value":420},"这些都被视作“情境元素”，需要被合理组织和调度。",{"type":186,"tag":211,"props":422,"children":424},{"start":423},2,[425],{"type":186,"tag":215,"props":426,"children":427},{},[428],{"type":192,"value":319},{"type":186,"tag":195,"props":430,"children":431},{},[432,434,437],{"type":192,"value":433},"2.1 提示工程关注点",{"type":186,"tag":221,"props":435,"children":436},{},[],{"type":192,"value":438},"\n提示工程主要聚焦在一句或若干句“prompt”的写法：",{"type":186,"tag":227,"props":440,"children":441},{},[442,447,452],{"type":186,"tag":215,"props":443,"children":444},{},[445],{"type":192,"value":446},"如何更清晰地描述任务",{"type":186,"tag":215,"props":448,"children":449},{},[450],{"type":192,"value":451},"如何减少歧义",{"type":186,"tag":215,"props":453,"children":454},{},[455],{"type":192,"value":456},"如何通过措辞影响模型行为",{"type":186,"tag":195,"props":458,"children":459},{},[460,462,465],{"type":192,"value":461},"2.2 上下文工程关注点",{"type":186,"tag":221,"props":463,"children":464},{},[],{"type":192,"value":466},"\n上下文工程则关注：",{"type":186,"tag":227,"props":468,"children":469},{},[470,475,480,485],{"type":186,"tag":215,"props":471,"children":472},{},[473],{"type":192,"value":474},"用哪些信息：信息源选择、过滤、裁剪",{"type":186,"tag":215,"props":476,"children":477},{},[478],{"type":192,"value":479},"以什么结构组织：分块、层级、标签、模板化",{"type":186,"tag":215,"props":481,"children":482},{},[483],{"type":192,"value":484},"以什么顺序喂给模型：先指令、后知识，或先总结、后追问等",{"type":186,"tag":215,"props":486,"children":487},{},[488],{"type":192,"value":489},"在整个任务生命周期内，如何滚动维护与更新上下文",{"type":186,"tag":195,"props":491,"children":492},{},[493,495,498,500,503],{"type":192,"value":494},"可以理解为：",{"type":186,"tag":221,"props":496,"children":497},{},[],{"type":192,"value":499},"\n提示工程是“怎么说这句话”，",{"type":186,"tag":221,"props":501,"children":502},{},[],{"type":192,"value":504},"\n上下文工程是“说什么、按什么结构说、在什么时机说，以及说给谁（哪个子代理）听”。",{"type":186,"tag":211,"props":506,"children":508},{"start":507},3,[509],{"type":186,"tag":215,"props":510,"children":511},{},[512],{"type":192,"value":513},"上下文工程的三大方向",{"type":186,"tag":195,"props":515,"children":516},{},[517],{"type":192,"value":518},"3.1 情境搭建（Context Setup）",{"type":186,"tag":195,"props":520,"children":521},{},[522,524,527],{"type":192,"value":523},"3.1.1 目标",{"type":186,"tag":221,"props":525,"children":526},{},[],{"type":192,"value":528},"\n在模型开始处理任务之前，搭建一个“干净、明确、轻量”的初始上下文，让后续推理在良好约束下进行。",{"type":186,"tag":195,"props":530,"children":531},{},[532],{"type":192,"value":533},"3.1.2 关键实践",{"type":186,"tag":211,"props":535,"children":536},{},[537],{"type":186,"tag":215,"props":538,"children":539},{},[540],{"type":192,"value":541},"极简系统提示词",{"type":186,"tag":227,"props":543,"children":544},{},[545,550,555],{"type":186,"tag":215,"props":546,"children":547},{},[548],{"type":192,"value":549},"避免在系统提示里堆积过多要求",{"type":186,"tag":215,"props":551,"children":552},{},[553],{"type":192,"value":554},"只保留核心角色设定和关键约束",{"type":186,"tag":215,"props":556,"children":557},{},[558],{"type":192,"value":559},"其他细节通过工具、模板或后续指令承载",{"type":186,"tag":211,"props":561,"children":562},{"start":423},[563],{"type":186,"tag":215,"props":564,"children":565},{},[566],{"type":192,"value":567},"规范化少样本示例（Canonical Few-shot）",{"type":186,"tag":227,"props":569,"children":570},{},[571,576,581],{"type":186,"tag":215,"props":572,"children":573},{},[574],{"type":192,"value":575},"为高频任务设计标准示例集",{"type":186,"tag":215,"props":577,"children":578},{},[579],{"type":192,"value":580},"示例结构统一：输入格式、思考过程、输出格式",{"type":186,"tag":215,"props":582,"children":583},{},[584],{"type":192,"value":585},"通过“几个高质量样例”塑造模型行为，而不是大量杂乱样例",{"type":186,"tag":211,"props":587,"children":588},{"start":507},[589],{"type":186,"tag":215,"props":590,"children":591},{},[592],{"type":192,"value":593},"token 高效的工具与结构",{"type":186,"tag":227,"props":595,"children":596},{},[597,602,607],{"type":186,"tag":215,"props":598,"children":599},{},[600],{"type":192,"value":601},"将复杂逻辑下沉到工具（代码、API），让模型通过自然语言调用",{"type":186,"tag":215,"props":603,"children":604},{},[605],{"type":192,"value":606},"用紧凑的数据表示（ID、引用、索引）替代冗长文本",{"type":186,"tag":215,"props":608,"children":609},{},[610],{"type":192,"value":611},"用模板化结构（JSON、表格样式文本）减少解释成本",{"type":186,"tag":195,"props":613,"children":614},{},[615],{"type":192,"value":616},"3.2 情境管理：长周期任务（Context Management for Long-horizon Tasks）",{"type":186,"tag":195,"props":618,"children":619},{},[620,622,625],{"type":192,"value":621},"3.2.1 问题背景",{"type":186,"tag":221,"props":623,"children":624},{},[],{"type":192,"value":626},"\n在长周期、多轮对话或复杂流程中：",{"type":186,"tag":227,"props":628,"children":629},{},[630,635,640],{"type":186,"tag":215,"props":631,"children":632},{},[633],{"type":192,"value":634},"模型的上下文窗口有限",{"type":186,"tag":215,"props":636,"children":637},{},[638],{"type":192,"value":639},"历史信息会不断被新内容挤出",{"type":186,"tag":215,"props":641,"children":642},{},[643],{"type":192,"value":644},"重要决策、约定和中间结论容易丢失",{"type":186,"tag":195,"props":646,"children":647},{},[648],{"type":192,"value":649},"3.2.2 关键实践",{"type":186,"tag":211,"props":651,"children":652},{},[653],{"type":186,"tag":215,"props":654,"children":655},{},[656],{"type":192,"value":657},"上下文摘要",{"type":186,"tag":227,"props":659,"children":660},{},[661,684],{"type":186,"tag":215,"props":662,"children":663},{},[664,666],{"type":192,"value":665},"周期性地对对话/步骤做总结，保留：\n",{"type":186,"tag":227,"props":667,"children":668},{},[669,674,679],{"type":186,"tag":215,"props":670,"children":671},{},[672],{"type":192,"value":673},"关键决策",{"type":186,"tag":215,"props":675,"children":676},{},[677],{"type":192,"value":678},"重要中间结论",{"type":186,"tag":215,"props":680,"children":681},{},[682],{"type":192,"value":683},"未解决的问题与假设",{"type":186,"tag":215,"props":685,"children":686},{},[687],{"type":192,"value":688},"用摘要替换长对话原文，以压缩 token",{"type":186,"tag":211,"props":690,"children":691},{"start":423},[692],{"type":186,"tag":215,"props":693,"children":694},{},[695],{"type":192,"value":696},"结构化笔记 / 外部记忆",{"type":186,"tag":227,"props":698,"children":699},{},[700,723],{"type":186,"tag":215,"props":701,"children":702},{},[703,705],{"type":192,"value":704},"将重要信息写入外部结构：\n",{"type":186,"tag":227,"props":706,"children":707},{},[708,713,718],{"type":186,"tag":215,"props":709,"children":710},{},[711],{"type":192,"value":712},"任务目标与约束",{"type":186,"tag":215,"props":714,"children":715},{},[716],{"type":192,"value":717},"当前状态与进度",{"type":186,"tag":215,"props":719,"children":720},{},[721],{"type":192,"value":722},"已完成与待办列表",{"type":186,"tag":215,"props":724,"children":725},{},[726],{"type":192,"value":727},"以“笔记”形式重新注入上下文，而不是反复传入全部历史对话",{"type":186,"tag":211,"props":729,"children":730},{"start":507},[731],{"type":186,"tag":215,"props":732,"children":733},{},[734],{"type":192,"value":735},"子代理架构（Sub-agent Architectures）",{"type":186,"tag":227,"props":737,"children":738},{},[739,744,749,754],{"type":186,"tag":215,"props":740,"children":741},{},[742],{"type":192,"value":743},"将复杂任务拆解为多类子任务：分析、规划、执行、评审等",{"type":186,"tag":215,"props":745,"children":746},{},[747],{"type":192,"value":748},"每个子代理只保留与自己子任务强相关的局部上下文",{"type":186,"tag":215,"props":750,"children":751},{},[752],{"type":192,"value":753},"对子代理输出进行摘要，再汇总给主代理",{"type":186,"tag":215,"props":755,"children":756},{},[757],{"type":192,"value":758},"通过“隔离 + 摘要”控制整体上下文体积与噪音",{"type":186,"tag":195,"props":760,"children":761},{},[762],{"type":192,"value":763},"3.2.3 效果",{"type":186,"tag":227,"props":765,"children":766},{},[767,772,777],{"type":186,"tag":215,"props":768,"children":769},{},[770],{"type":192,"value":771},"减少无关历史对当前推理的干扰",{"type":186,"tag":215,"props":773,"children":774},{},[775],{"type":192,"value":776},"在有限上下文内维持对长期任务的一致理解",{"type":186,"tag":215,"props":778,"children":779},{},[780],{"type":192,"value":781},"提升长流程、多阶段系统的稳定性和可追溯性",{"type":186,"tag":195,"props":783,"children":784},{},[785],{"type":192,"value":786},"3.3 动态信息检索（Dynamic Information Retrieval）",{"type":186,"tag":195,"props":788,"children":789},{},[790,792,795],{"type":192,"value":791},"3.3.1 核心思想：JIT（Just-in-Time）",{"type":186,"tag":221,"props":793,"children":794},{},[],{"type":192,"value":796},"\n动态信息检索强调“按需加载”：",{"type":186,"tag":227,"props":798,"children":799},{},[800,805,810],{"type":186,"tag":215,"props":801,"children":802},{},[803],{"type":192,"value":804},"不在一开始就把所有可能相关的信息塞给模型",{"type":186,"tag":215,"props":806,"children":807},{},[808],{"type":192,"value":809},"由智能体在推理过程中判断何时需要外部知识",{"type":186,"tag":215,"props":811,"children":812},{},[813],{"type":192,"value":814},"只在“当下这一步”真的需要时，才发起检索或工具调用",{"type":186,"tag":195,"props":816,"children":817},{},[818],{"type":192,"value":819},"3.3.2 关键实践",{"type":186,"tag":211,"props":821,"children":822},{},[823],{"type":186,"tag":215,"props":824,"children":825},{},[826],{"type":192,"value":827},"JIT 检索策略",{"type":186,"tag":227,"props":829,"children":830},{},[831,836,841],{"type":186,"tag":215,"props":832,"children":833},{},[834],{"type":192,"value":835},"让代理先进行初步思考，识别信息缺口",{"type":186,"tag":215,"props":837,"children":838},{},[839],{"type":192,"value":840},"在识别缺口后，触发检索：知识库、数据库、API、搜索等",{"type":186,"tag":215,"props":842,"children":843},{},[844],{"type":192,"value":845},"将检索结果以结构化方式注入后续上下文",{"type":186,"tag":211,"props":847,"children":848},{"start":423},[849],{"type":186,"tag":215,"props":850,"children":851},{},[852],{"type":192,"value":853},"精准匹配与裁剪",{"type":186,"tag":227,"props":855,"children":856},{},[857,862],{"type":186,"tag":215,"props":858,"children":859},{},[860],{"type":192,"value":861},"使用向量检索 / 结构化查询，尽量只返回“最相关的少量片段”",{"type":186,"tag":215,"props":863,"children":864},{},[865],{"type":192,"value":866},"对检索结果做二次过滤与摘要，降低噪音和 token 消耗",{"type":186,"tag":211,"props":868,"children":869},{"start":507},[870],{"type":186,"tag":215,"props":871,"children":872},{},[873],{"type":192,"value":874},"与工具生态结合",{"type":186,"tag":227,"props":876,"children":877},{},[878,883],{"type":186,"tag":215,"props":879,"children":880},{},[881],{"type":192,"value":882},"把外部系统封装成“可调用工具”，由代理按需调用",{"type":186,"tag":215,"props":884,"children":885},{},[886],{"type":192,"value":887},"工具返回数据尽量结构化（JSON 等），便于后处理与复用",{"type":186,"tag":195,"props":889,"children":890},{},[891],{"type":192,"value":892},"3.3.3 目标效果",{"type":186,"tag":227,"props":894,"children":895},{},[896,901,906],{"type":186,"tag":215,"props":897,"children":898},{},[899],{"type":192,"value":900},"在保持结果质量的前提下，最小化上下文体积",{"type":186,"tag":215,"props":902,"children":903},{},[904],{"type":192,"value":905},"避免信息过载导致模型“跑偏”或陷入无关细节",{"type":186,"tag":215,"props":907,"children":908},{},[909],{"type":192,"value":910},"实现更高的时效性和更好的领域适配（通过实时数据源）",{"type":186,"tag":211,"props":912,"children":914},{"start":913},4,[915],{"type":186,"tag":215,"props":916,"children":917},{},[918],{"type":192,"value":344},{"type":186,"tag":195,"props":920,"children":921},{},[922],{"type":192,"value":923},"4.1 设计层面",{"type":186,"tag":227,"props":925,"children":926},{},[927,932,955],{"type":186,"tag":215,"props":928,"children":929},{},[930],{"type":192,"value":931},"把“上下文”当成系统的一等公民来建模，而不是零散的 prompt 文本",{"type":186,"tag":215,"props":933,"children":934},{},[935,937],{"type":192,"value":936},"明确区分：\n",{"type":186,"tag":227,"props":938,"children":939},{},[940,945,950],{"type":186,"tag":215,"props":941,"children":942},{},[943],{"type":192,"value":944},"固定长期配置：角色、全局约束",{"type":186,"tag":215,"props":946,"children":947},{},[948],{"type":192,"value":949},"任务级配置：目标、输入、成功标准",{"type":186,"tag":215,"props":951,"children":952},{},[953],{"type":192,"value":954},"步骤级配置：当前子任务相关信息",{"type":186,"tag":215,"props":956,"children":957},{},[958],{"type":192,"value":959},"为这三层分别设计结构与更新策略",{"type":186,"tag":195,"props":961,"children":962},{},[963],{"type":192,"value":964},"4.2 工程实现层面",{"type":186,"tag":227,"props":966,"children":967},{},[968,986],{"type":186,"tag":215,"props":969,"children":970},{},[971,973],{"type":192,"value":972},"引入“上下文编排层”：\n",{"type":186,"tag":227,"props":974,"children":975},{},[976,981],{"type":186,"tag":215,"props":977,"children":978},{},[979],{"type":192,"value":980},"负责收集、过滤、排序各种信息源",{"type":186,"tag":215,"props":982,"children":983},{},[984],{"type":192,"value":985},"输出给模型的是一个结构化、可解释的最终上下文",{"type":186,"tag":215,"props":987,"children":988},{},[989,991],{"type":192,"value":990},"内置常用能力模块：\n",{"type":186,"tag":227,"props":992,"children":993},{},[994,999,1004],{"type":186,"tag":215,"props":995,"children":996},{},[997],{"type":192,"value":998},"摘要模块（对历史、对子代理输出）",{"type":186,"tag":215,"props":1000,"children":1001},{},[1002],{"type":192,"value":1003},"检索模块（向量、全文、结构化）",{"typ