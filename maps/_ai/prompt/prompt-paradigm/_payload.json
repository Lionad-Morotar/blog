","提示词分化：描述性 vs 指令性","图像生成提示词的两种范式及其适用场景","_ai/prompt/prompt-paradigm.md",{"type":183,"children":184,"toc":410},"root",[185,194,200,205,225,230,236,241,245,263,268,273,378,383,396],{"type":186,"tag":187,"props":188,"children":190},"element","h4",{"id":189},"描述性提示词精确控制美学",[191],{"type":192,"value":193},"text","描述性提示词：精确控制美学",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198],{"type":192,"value":199},"通过详细描述光影、色彩、材质、构图等视觉元素，让模型\"复现\"特定的视觉风格。",{"type":186,"tag":195,"props":201,"children":202},{},[203],{"type":192,"value":204},"典型特征：",{"type":186,"tag":206,"props":207,"children":208},"ul",{},[209,215,220],{"type":186,"tag":210,"props":211,"children":212},"li",{},[213],{"type":192,"value":214},"使用摄影/美术专业术语（如\"直闪质感\"\"低饱和中性色\"\"胶片颗粒\"）",{"type":186,"tag":210,"props":216,"children":217},{},[218],{"type":192,"value":219},"强调光源位置、色温、阴影层次",{"type":186,"tag":210,"props":221,"children":222},{},[223],{"type":192,"value":224},"描述面料纹理、表面反射、空间透视",{"type":186,"tag":195,"props":226,"children":227},{},[228],{"type":192,"value":229},"适用场景：专业摄影、时尚大片、概念艺术等对视觉精度要求高的领域。",{"type":186,"tag":187,"props":231,"children":233},{"id":232},"指令性提示词快速实现意图",[234],{"type":192,"value":235},"指令性提示词：快速实现意图",{"type":186,"tag":195,"props":237,"children":238},{},[239],{"type":192,"value":240},"通过简洁的操作指令，让模型执行明确的转换动作。",{"type":186,"tag":195,"props":242,"children":243},{},[244],{"type":192,"value":204},{"type":186,"tag":206,"props":246,"children":247},{},[248,253,258],{"type":186,"tag":210,"props":249,"children":250},{},[251],{"type":192,"value":252},"使用动词开头（如\"转成...\"\"变成...\"\"加上...\"）",{"type":186,"tag":210,"props":254,"children":255},{},[256],{"type":192,"value":257},"指定目标风格或介质（如\"乐高风格\"\"手办效果\"）",{"type":186,"tag":210,"props":259,"children":260},{},[261],{"type":192,"value":262},"描述空间关系（如\"贴在易拉罐上\"\"挂在包包上\"）",{"type":186,"tag":195,"props":264,"children":265},{},[266],{"type":192,"value":267},"适用场景：快速原型、趣味生成、社交媒体内容等对效率要求高的场景。",{"type":186,"tag":187,"props":269,"children":271},{"id":270},"范式选择的核心考量",[272],{"type":192,"value":270},{"type":186,"tag":274,"props":275,"children":276},"table",{},[277,301],{"type":186,"tag":278,"props":279,"children":280},"thead",{},[281],{"type":186,"tag":282,"props":283,"children":284},"tr",{},[285,291,296],{"type":186,"tag":286,"props":287,"children":288},"th",{},[289],{"type":192,"value":290},"维度",{"type":186,"tag":286,"props":292,"children":293},{},[294],{"type":192,"value":295},"描述性",{"type":186,"tag":286,"props":297,"children":298},{},[299],{"type":192,"value":300},"指令性",{"type":186,"tag":302,"props":303,"children":304},"tbody",{},[305,324,342,360],{"type":186,"tag":282,"props":306,"children":307},{},[308,314,319],{"type":186,"tag":309,"props":310,"children":311},"td",{},[312],{"type":192,"value":313},"控制权",{"type":186,"tag":309,"props":315,"children":316},{},[317],{"type":192,"value":318},"高（精确到像素级审美）",{"type":186,"tag":309,"props":320,"children":321},{},[322],{"type":192,"value":323},"低（接受模型的默认诠释）",{"type":186,"tag":282,"props":325,"children":326},{},[327,332,337],{"type":186,"tag":309,"props":328,"children":329},{},[330],{"type":192,"value":331},"学习成本",{"type":186,"tag":309,"props":333,"children":334},{},[335],{"type":192,"value":336},"高（需掌握视觉专业术语）",{"type":186,"tag":309,"props":338,"children":339},{},[340],{"type":192,"value":341},"低（自然语言即可）",{"type":186,"tag":282,"props":343,"children":344},{},[345,350,355],{"type":186,"tag":309,"props":346,"children":347},{},[348],{"type":192,"value":349},"迭代次数",{"type":186,"tag":309,"props":351,"children":352},{},[353],{"type":192,"value":354},"多（需反复调试细节）",{"type":186,"tag":309,"props":356,"children":357},{},[358],{"type":192,"value":359},"少（通常一次到位）",{"type":186,"tag":282,"props":361,"children":362},{},[363,368,373],{"type":186,"tag":309,"props":364,"children":365},{},[366],{"type":192,"value":367},"一致性",{"type":186,"tag":309,"props":369,"children":370},{},[371],{"type":192,"value":372},"易保持（锁定具体参数）",{"type":186,"tag":309,"props":374,"children":375},{},[376],{"type":192,"value":377},"难保证（依赖模型理解）",{"type":186,"tag":187,"props":379,"children":381},{"id":380},"双轨制的未来",[382],{"type":192,"value":380},{"type":186,"tag":195,"props":384,"children":385},{},[386,388,394],{"type":192,"value":387},"两类提示词并非对立，而是代表了",{"type":186,"tag":389,"props":390,"children":391},"strong",{},[392],{"type":192,"value":393},"同一技术能力的不同抽象层级",{"type":192,"value":395},"。\n专业用户用描述性语言控制美学底线，普通用户用指令性语言快速实现创意——\n这种\"双轨制\"可能是图像生成界面演进的方向。",{"type":186,"tag":195,"props":397,"children":398},{},[399,401],{"type":192,"value":400},"见：",{"type":186,"tag":402,"props":403,"children":407},"a",{"href":404,"rel":405},"https://github.com/ZHO-ZHO-ZHO/ZHO-nano-banana-Creation",[406],"nofollow",[408],{"type":192,"value":409},"ZHO-nano-banana-Creation",{"title":178,"searchDepth":411,"depth":411,"links":412},2,[],"markdown","content:6.maps:_ai:prompt:prompt-paradigm.md","content","6.maps/_ai/prompt/prompt-paradigm.md","6.maps/_ai/prompt/prompt-paradigm","md",[420,424],{"_path":421,"title":422,"description":423},"/maps/_ai/prompt/prompt-engineering","提示工程","指的是根据所需的任务目标，有意识地设计、优化和调整输入语言（即”提示”）的过程，以引导AI模型输出更高质量、符合期望和语境的内容，包含上下文设置、提示设计、提示调优、多模型适配等核心过程。",{"_path":425,"title":426,"description":427},"/maps/_ai/prompt/team-based-instructions","Team based Instructions","为软件团队策划和共享指令（Curated shared instructions for software teams）",1772504952571]