ue,"","Team based Instructions","为软件团队策划和共享指令（Curated shared instructions for software teams）",{"type":182,"children":183,"toc":791},"root",[184,193,205,215,225,230,236,243,248,268,273,291,296,302,307,503,509,514,636,642],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"brief",[190],{"type":191,"value":192},"text","Brief",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197,199,203],{"type":191,"value":198},"对在软件交付过程中已经积极使用 AI 的团队来说，下一步要做的不只是依赖个人的临时提示（prompt），而是要为整个软件团队建立一套经过策划的共享指令体系。",{"type":185,"tag":200,"props":201,"children":202},"br",{},[],{"type":191,"value":204},"\n这种实践可以帮助你把 AI 有效应用到所有交付任务中——不仅仅是写代码——通过共享那些已经被验证过的、高质量的指令来实现。",{"type":185,"tag":194,"props":206,"children":207},{},[208,210,213],{"type":191,"value":209},"最直接的落地方式，就是在项目代码仓库中提交专门的指令文件，比如新建一个 $$AGENTS.md$$。",{"type":185,"tag":200,"props":211,"children":212},{},[],{"type":191,"value":214},"\n目前大多数 AI 编码工具——包括 Cursor、Windsurf 和 Claude Code——都支持通过自定义斜杠命令（slash commands）或工作流（workflows）来共享这些指令。",{"type":185,"tag":194,"props":216,"children":217},{},[218,220,223],{"type":191,"value":219},"对于非编码类任务，你可以在组织层面建立统一的提示词（prompt）库，让团队随时调用。",{"type":185,"tag":200,"props":221,"children":222},{},[],{"type":191,"value":224},"\n这种系统化的方式可以实现持续改进：一旦某条提示被优化，整个团队就都能立刻受益，并且始终都能访问到当前最优的 AI 使用指令。",{"type":185,"tag":194,"props":226,"children":227},{},[228],{"type":191,"value":229},"来源：技术雷达",{"type":185,"tag":186,"props":231,"children":233},{"id":232},"guide",[234],{"type":191,"value":235},"Guide",{"type":185,"tag":237,"props":238,"children":240},"h3",{"id":239},"_1-为什么需要团队级指令而不是只靠个人-prompt",[241],{"type":191,"value":242},"1. 为什么需要“团队级指令”，而不是只靠个人 prompt？",{"type":185,"tag":194,"props":244,"children":245},{},[246],{"type":191,"value":247},"如果只依赖个人经验，每个人在用 AI 时都会：",{"type":185,"tag":249,"props":250,"children":251},"ul",{},[252,258,263],{"type":185,"tag":253,"props":254,"children":255},"li",{},[256],{"type":191,"value":257},"自己摸索一套提示语，“效果只在自己头上生效”",{"type":185,"tag":253,"props":259,"children":260},{},[261],{"type":191,"value":262},"新同事要从零开始学习如何跟 AI 协作",{"type":185,"tag":253,"props":264,"children":265},{},[266],{"type":191,"value":267},"同一个问题，不同人问法不同，效果差异大，难以复现",{"type":185,"tag":194,"props":269,"children":270},{},[271],{"type":191,"value":272},"而“策划并共享指令”（curated shared instructions）的目标是：",{"type":185,"tag":249,"props":274,"children":275},{},[276,281,286],{"type":185,"tag":253,"props":277,"children":278},{},[279],{"type":191,"value":280},"把“用 AI 做这类任务的最佳问法”固化下来",{"type":185,"tag":253,"props":282,"children":283},{},[284],{"type":191,"value":285},"每个成员都能一键复用，不需要重新踩坑",{"type":185,"tag":253,"props":287,"children":288},{},[289],{"type":191,"value":290},"项目级别的“使用 AI 方式”变得标准、可复用、可改进",{"type":185,"tag":194,"props":292,"children":293},{},[294],{"type":191,"value":295},"可以理解为：给 AI 建一本“团队操作手册”，而不是靠每个人即兴发挥。",{"type":185,"tag":237,"props":297,"children":299},{"id":298},"_2-agentsmd-可以写什么",[300],{"type":191,"value":301},"2. $$AGENTS.md$$ 可以写什么？",{"type":185,"tag":194,"props":303,"children":304},{},[305],{"type":191,"value":306},"一个典型的 $$AGENTS.md$$ 文件，可以长这样（示例结构）：",{"type":185,"tag":308,"props":309,"children":310},"ol",{},[311,338,443,469],{"type":185,"tag":253,"props":312,"children":313},{},[314,320],{"type":185,"tag":315,"props":316,"children":317},"strong",{},[318],{"type":191,"value":319},"全局原则（For all agents）",{"type":185,"tag":249,"props":321,"children":322},{},[323,328,333],{"type":185,"tag":253,"props":324,"children":325},{},[326],{"type":191,"value":327},"代码风格（缩进、命名规则、语言版本等）",{"type":185,"tag":253,"props":329,"children":330},{},[331],{"type":191,"value":332},"安全与合规要求（比如不得引入 GPL 代码、不得上传隐私数据）",{"type":185,"tag":253,"props":334,"children":335},{},[336],{"type":191,"value":337},"输出格式要求（是否必须带测试用例、是否必须解释关键设计决策）",{"type":185,"tag":253,"props":339,"children":340},{},[341,346],{"type":185,"tag":315,"props":342,"children":343},{},[344],{"type":191,"value":345},"按角色划分的 AI 代理（Agents）",{"type":185,"tag":249,"props":347,"children":348},{},[349,382,404,421,438],{"type":185,"tag":253,"props":350,"children":351},{},[352,357,359],{"type":185,"tag":315,"props":353,"children":354},{},[355],{"type":191,"value":356},"Code Reviewer Agent",{"type":191,"value":358},"：\n",{"type":185,"tag":249,"props":360,"children":361},{},[362,367,372,377],{"type":185,"tag":253,"props":363,"children":364},{},[365],{"type":191,"value":366},"任务：代码审查",{"type":185,"tag":253,"props":368,"children":369},{},[370],{"type":191,"value":371},"输入：PR diff / 关键文件列表",{"type":185,"tag":253,"props":373,"children":374},{},[375],{"type":191,"value":376},"要求：必须检查哪些问题（性能、安全、边界条件、文档注释等）",{"type":185,"tag":253,"props":378,"children":379},{},[380],{"type":191,"value":381},"输出模板：先总体结论，再按文件列出问题，再给出建议修改方案",{"type":185,"tag":253,"props":383,"children":384},{},[385,390,391],{"type":185,"tag":315,"props":386,"children":387},{},[388],{"type":191,"value":389},"Refactoring Agent",{"type":191,"value":358},{"type":185,"tag":249,"props":392,"children":393},{},[394,399],{"type":185,"tag":253,"props":395,"children":396},{},[397],{"type":191,"value":398},"任务：重构老代码",{"type":185,"tag":253,"props":400,"children":401},{},[402],{"type":191,"value":403},"指令：保持对外行为不变；优先消除重复逻辑；建议拆分函数；给出重构后结构说明",{"type":185,"tag":253,"props":405,"children":406},{},[407,412,413],{"type":185,"tag":315,"props":408,"children":409},{},[410],{"type":191,"value":411},"Spec Writer Agent",{"type":191,"value":358},{"type":185,"tag":249,"props":414,"children":415},{},[416],{"type":185,"tag":253,"props":417,"children":418},{},[419],{"type":191,"value":420},"任务：根据产品需求写技术设计说明 / 接口规格文档",{"type":185,"tag":253,"props":422,"children":423},{},[424,429,430],{"type":185,"tag":315,"props":425,"children":426},{},[427],{"type":191,"value":428},"Test Writer Agent",{"type":191,"value":358},{"type":185,"tag":249,"props":431,"children":432},{},[433],{"type":185,"tag":253,"props":434,"children":435},{},[436],{"type":191,"value":437},"任务：为给定代码编写单元测试 / 集成测试用例",{"type":185,"tag":253,"props":439,"children":440},{},[441],{"type":191,"value":442},"…可根据团队情况扩展",{"type":185,"tag":253,"props":444,"children":445},{},[446,451],{"type":185,"tag":315,"props":447,"children":448},{},[449],{"type":191,"value":450},"常用 prompt 模板",{"type":185,"tag":249,"props":452,"children":453},{},[454,459,464],{"type":185,"tag":253,"props":455,"children":456},{},[457],{"type":191,"value":458},"“请帮我评审这段代码，重点关注性能和安全：…”",{"type":185,"tag":253,"props":460,"children":461},{},[462],{"type":191,"value":463},"“请根据以下用户故事，输出技术设计文档模板：…”",{"type":185,"tag":253,"props":465,"children":466},{},[467],{"type":191,"value":468},"“请基于下面 API 代码，生成接口文档（OpenAPI/Markdown）：…”",{"type":185,"tag":253,"props":470,"children":471},{},[472,477],{"type":185,"tag":315,"props":473,"children":474},{},[475],{"type":191,"value":476},"使用指南",{"type":185,"tag":249,"props":478,"children":479},{},[480,485,498],{"type":185,"tag":253,"props":481,"children":482},{},[483],{"type":191,"value":484},"在 Cursor/Windsurf/Claude Code 中如何调用这些指令",{"type":185,"tag":253,"props":486,"children":487},{},[488,490],{"type":191,"value":489},"推荐工作流：\n",{"type":185,"tag":249,"props":491,"children":492},{},[493],{"type":185,"tag":253,"props":494,"children":495},{},[496],{"type":191,"value":497},"写完功能 → 调用 Test Writer 生成测试 → 调用 Reviewer 审查",{"type":185,"tag":253,"props":499,"children":500},{},[501],{"type":191,"value":502},"注意事项：哪些任务必须人工复核，哪些可以完全交给 AI",{"type":185,"tag":237,"props":504,"children":506},{"id":505},"_3-如何在工具里落地共享指令",[507],{"type":191,"value":508},"3. 如何在工具里落地共享指令？",{"type":185,"tag":194,"props":510,"children":511},{},[512],{"type":191,"value":513},"以几类常见工具为例（思路，不依赖具体实现细节）：",{"type":185,"tag":308,"props":515,"children":516},{},[517,556,605],{"type":185,"tag":253,"props":518,"children":519},{},[520,525],{"type":185,"tag":315,"props":521,"children":522},{},[523],{"type":191,"value":524},"Cursor / Windsurf / Claude Code 里",{"type":185,"tag":249,"props":526,"children":527},{},[528,551],{"type":185,"tag":253,"props":529,"children":530},{},[531,533],{"type":191,"value":532},"利用“自定义 Slash 命令”功能，比如：\n",{"type":185,"tag":249,"props":534,"children":535},{},[536,541,546],{"type":185,"tag":253,"props":537,"children":538},{},[539],{"type":191,"value":540},"$$/review$$ → 自动调用 Code Reviewer 模板",{"type":185,"tag":253,"props":542,"children":543},{},[544],{"type":191,"value":545},"$$/tests$$ → 使用 Test Writer 模板",{"type":185,"tag":253,"props":547,"children":548},{},[549],{"type":191,"value":550},"$$/refactor$$ → 使用 Refactoring Agent 模板",{"type":185,"tag":253,"props":552,"children":553},{},[554],{"type":191,"value":555},"把这些命令及其含义写进 $$AGENTS.md$$，保证团队共识。",{"type":185,"tag":253,"props":557,"children":558},{},[559,564],{"type":185,"tag":315,"props":560,"children":561},{},[562],{"type":191,"value":563},"非编码任务（产品、设计、运营等）",{"type":185,"tag":249,"props":565,"children":566},{},[567,600],{"type":185,"tag":253,"props":568,"children":569},{},[570,572,575,577],{"type":191,"value":571},"在公司知识库（如 Confluence、Notion、飞书文档）建立",{"type":185,"tag":200,"props":573,"children":574},{},[],{"type":191,"value":576},"\n“Prompt Library” 或 “AI 使用手册” 页面：\n",{"type":185,"tag":249,"props":578,"children":579},{},[580,585,590,595],{"type":185,"tag":253,"props":581,"children":582},{},[583],{"type":191,"value":584},"产品需求分析模板",{"type":185,"tag":253,"props":586,"children":587},{},[588],{"type":191,"value":589},"用户访谈纪要整理模板",{"type":185,"tag":253,"props":591,"children":592},{},[593],{"type":191,"value":594},"PRD 规范模板",{"type":185,"tag":253,"props":596,"children":597},{},[598],{"type":191,"value":599},"市场调研 / 竞品分析的结构化问题清单",{"type":185,"tag":253,"props":601,"children":602},{},[603],{"type":191,"value":604},"把这些模板复制-粘贴到任意 AI 工具即可使用，不依赖具体 IDE。",{"type":185,"tag":253,"props":606,"children":607},{},[608,613],{"type":185,"tag":315,"props":609,"children":610},{},[611],{"type":191,"value":612},"通过版本控制实现“持续改进”",{"type":185,"tag":249,"props":614,"children":615},{},[616,621,626,631],{"type":185,"tag":253,"props":617,"children":618},{},[619],{"type":191,"value":620},"$$AGENTS.md$$ 放在代码仓库，和源码一起版本管理",{"type":185,"tag":253,"props":622,"children":623},{},[624],{"type":191,"value":625},"团队成员可以通过 PR 改进这些指令（就像改代码一样）",{"type":185,"tag":253,"props":627,"children":628},{},[629],{"type":191,"value":630},"变更记录可追踪，讨论也可在 Review 中完成",{"type":185,"tag":253,"props":632,"children":633},{},[634],{"type":191,"value":635},"“最优 prompt”不再是某个人脑子里的经验，而是团队资产",{"type":185,"tag":237,"props":637,"children":639},{"id":638},"_4-建设这套体系时的实用建议",[640],{"type":191,"value":641},"4. 建设这套体系时的实用建议",{"type":185,"tag":308,"props":643,"children":644},{},[645,684,723,757],{"type":185,"tag":253,"props":646,"children":647},{},[648,653],{"type":185,"tag":315,"props":649,"children":650},{},[651],{"type":191,"value":652},"从高频场景入手，不要一开始做得太大",{"type":185,"tag":249,"props":654,"children":655},{},[656,679],{"type":185,"tag":253,"props":657,"children":658},{},[659,661],{"type":191,"value":660},"先选 2–3 个最常见、最耗时的场景：\n",{"type":185,"tag":249,"props":662,"children":663},{},[664,669,674],{"type":185,"tag":253,"props":665,"children":666},{},[667],{"type":191,"value":668},"代码审查",{"type":185,"tag":253,"props":670,"children":671},{},[672],{"type":191,"value":673},"编写测试",{"type":185,"tag":253,"props":675,"children":676},{},[677],{"type":191,"value":678},"阅读和总结 legacy 代码",{"type":185,"tag":253,"props":680,"children":681},{},[682],{"type":191,"value":683},"先把这几类的 prompt 固化到 $$AGENTS.md$$，再逐步扩展。",{"type":185,"tag":253,"props":685,"children":686},{},[687,692],{"type":185,"tag":315,"props":688,"children":689},{},[690],{"type":191,"value":691},"为每条指令加上“适用范围 + 示例”",{"type":185,"tag":249,"props":693,"children":694},{},[695,718],{"type":185,"tag":253,"props":696,"children":697},{},[698,700],{"type":191,"value":699},"每个 Agent 或模板下，加一段：\n",{"type":185,"tag":249,"props":701,"children":702},{},[703,708,713],{"type":185,"tag":253,"props":704,"children":705},{},[706],{"type":191,"value":707},"什么时候用？",{"type":185,"tag":253,"props":709,"children":710},{},[711],{"type":191,"value":712},"输入示例",{"type":185,"tag":253,"props":714,"children":715},{},[716],{"type":191,"value":717},"输出示例（缩略版即可）",{"type":185,"tag":253,"props":719,"children":720},{},[721],{"type":191,"value":722},"让新人看一眼就知道怎么用。",{"type":185,"tag":253,"props":724,"children":725},{},[726,731],{"type":185,"tag":315,"props":727,"children":728},{},[729],{"type":191,"value":730},"明确“AI 能做什么 + 必须人工把关什么”",{"type":185,"tag":249,"props":732,"children":733},{},[734,752],{"type":185,"tag":253,"props":735,"children":736},{},[737,739],{"type":191,"value":738},"比如：\n",{"type":185,"tag":249,"props":740,"children":741},{},[742,747],{"type":185,"tag":253,"props":743,"children":744},{},[745],{"type":191,"value":746},"AI 可以起草代码 / 文档，但安全相关逻辑必须人工复查",{"type":185,"tag":253,"props":748,"children":749},{},[750],{"type":191,"value":751},"合同、法律文本必须由法律同事最终审阅",{"type":185,"tag":253,"props":753,"children":754},{},[755],{"type":191,"value":756},"在 $$AGENTS.md$$ 或 Prompt Library 顶部写清楚，避免滥用 AI。",{"type":185,"tag":253,"props":758,"children":759},{},[760,765],{"type":185,"tag":315,"props":761,"children":762},{},[763],{"type":191,"value":764},"定期“回顾和升级”指令",{"type":185,"tag":249,"props":766,"children":767},{},[768,786],{"type":185,"tag":253,"props":769,"children":770},{},[771,773],{"type":191,"value":772},"每 1–2 个月开一个轻量的“AI 使用回顾”\n",{"type":185,"tag":249,"props":774,"children":775},{},[776,781],{"type":185,"tag":253,"props":777,"children":778},{},[779],{"type":191,"value":780},"哪些 prompt 真有用？",{"type":185,"tag":253,"props":782,"children":783},{},[784],{"type":191,"value":785},"哪些场景 AI 表现不好，需要改写指令？",{"type":185,"tag":253,"props":787,"children":788},{},[789],{"type":191,"value":790},"把会议输出直接转化为对 $$AGENTS.md$$ 和 Prompt Library 的修改。",{"title":178,"searchDepth":792,"depth":792,"links":793},2,[794,795],{"id":188,"depth":792,"text":192},{"id":232,"depth":792,"text":235,"children":796},[797,799,800,801],{"id":239,"depth":798,"text":242},3,{"id":298,"depth":798,"text":301},{"id":505,"depth":798,"text":508},{"id":638,"depth":798,"text":641},"markdown","content:6.maps:_ai:prompt:team-based-instructions.md","content","6.maps/_ai/prompt/team-based-instructions.md","6.maps/_ai/prompt/team-based-instructions","md",[809,813],{"_path":810,"title":811,"description":812},"/maps/_ai/prompt/prompt-engineering","提示工程","指的是根据所需的任务目标，有意识地设计、优化和调整输入语言（即“提示”）的过程，以引导AI模型输出更高质量、符合期望和语境的内容，包含上下文设置、提示设计、提示调优、多模型适配等核心过程。",{"_path":814,"title":815,"description":178},"/maps/_ai/rag","RAG (检索增强生成)",1771693713889]