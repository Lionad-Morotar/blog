s","prompt",false,true,"","Team based Instructions","为软件团队策划和共享指令（Curated shared instructions for software teams）","_ai/prompt/team-based-instructions.md",{"type":183,"children":184,"toc":792},"root",[185,194,206,216,226,231,237,244,249,269,274,292,297,303,308,504,510,515,637,643],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"brief",[191],{"type":192,"value":193},"text","Brief",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198,200,204],{"type":192,"value":199},"对在软件交付过程中已经积极使用 AI 的团队来说，下一步要做的不只是依赖个人的临时提示（prompt），而是要为整个软件团队建立一套经过策划的共享指令体系。",{"type":186,"tag":201,"props":202,"children":203},"br",{},[],{"type":192,"value":205},"\n这种实践可以帮助你把 AI 有效应用到所有交付任务中——不仅仅是写代码——通过共享那些已经被验证过的、高质量的指令来实现。",{"type":186,"tag":195,"props":207,"children":208},{},[209,211,214],{"type":192,"value":210},"最直接的落地方式，就是在项目代码仓库中提交专门的指令文件，比如新建一个 $$AGENTS.md$$。",{"type":186,"tag":201,"props":212,"children":213},{},[],{"type":192,"value":215},"\n目前大多数 AI 编码工具——包括 Cursor、Windsurf 和 Claude Code——都支持通过自定义斜杠命令（slash commands）或工作流（workflows）来共享这些指令。",{"type":186,"tag":195,"props":217,"children":218},{},[219,221,224],{"type":192,"value":220},"对于非编码类任务，你可以在组织层面建立统一的提示词（prompt）库，让团队随时调用。",{"type":186,"tag":201,"props":222,"children":223},{},[],{"type":192,"value":225},"\n这种系统化的方式可以实现持续改进：一旦某条提示被优化，整个团队就都能立刻受益，并且始终都能访问到当前最优的 AI 使用指令。",{"type":186,"tag":195,"props":227,"children":228},{},[229],{"type":192,"value":230},"来源：技术雷达",{"type":186,"tag":187,"props":232,"children":234},{"id":233},"guide",[235],{"type":192,"value":236},"Guide",{"type":186,"tag":238,"props":239,"children":241},"h3",{"id":240},"_1-为什么需要团队级指令而不是只靠个人-prompt",[242],{"type":192,"value":243},"1. 为什么需要“团队级指令”，而不是只靠个人 prompt？",{"type":186,"tag":195,"props":245,"children":246},{},[247],{"type":192,"value":248},"如果只依赖个人经验，每个人在用 AI 时都会：",{"type":186,"tag":250,"props":251,"children":252},"ul",{},[253,259,264],{"type":186,"tag":254,"props":255,"children":256},"li",{},[257],{"type":192,"value":258},"自己摸索一套提示语，“效果只在自己头上生效”",{"type":186,"tag":254,"props":260,"children":261},{},[262],{"type":192,"value":263},"新同事要从零开始学习如何跟 AI 协作",{"type":186,"tag":254,"props":265,"children":266},{},[267],{"type":192,"value":268},"同一个问题，不同人问法不同，效果差异大，难以复现",{"type":186,"tag":195,"props":270,"children":271},{},[272],{"type":192,"value":273},"而“策划并共享指令”（curated shared instructions）的目标是：",{"type":186,"tag":250,"props":275,"children":276},{},[277,282,287],{"type":186,"tag":254,"props":278,"children":279},{},[280],{"type":192,"value":281},"把“用 AI 做这类任务的最佳问法”固化下来",{"type":186,"tag":254,"props":283,"children":284},{},[285],{"type":192,"value":286},"每个成员都能一键复用，不需要重新踩坑",{"type":186,"tag":254,"props":288,"children":289},{},[290],{"type":192,"value":291},"项目级别的“使用 AI 方式”变得标准、可复用、可改进",{"type":186,"tag":195,"props":293,"children":294},{},[295],{"type":192,"value":296},"可以理解为：给 AI 建一本“团队操作手册”，而不是靠每个人即兴发挥。",{"type":186,"tag":238,"props":298,"children":300},{"id":299},"_2-agentsmd-可以写什么",[301],{"type":192,"value":302},"2. $$AGENTS.md$$ 可以写什么？",{"type":186,"tag":195,"props":304,"children":305},{},[306],{"type":192,"value":307},"一个典型的 $$AGENTS.md$$ 文件，可以长这样（示例结构）：",{"type":186,"tag":309,"props":310,"children":311},"ol",{},[312,339,444,470],{"type":186,"tag":254,"props":313,"children":314},{},[315,321],{"type":186,"tag":316,"props":317,"children":318},"strong",{},[319],{"type":192,"value":320},"全局原则（For all agents）",{"type":186,"tag":250,"props":322,"children":323},{},[324,329,334],{"type":186,"tag":254,"props":325,"children":326},{},[327],{"type":192,"value":328},"代码风格（缩进、命名规则、语言版本等）",{"type":186,"tag":254,"props":330,"children":331},{},[332],{"type":192,"value":333},"安全与合规要求（比如不得引入 GPL 代码、不得上传隐私数据）",{"type":186,"tag":254,"props":335,"children":336},{},[337],{"type":192,"value":338},"输出格式要求（是否必须带测试用例、是否必须解释关键设计决策）",{"type":186,"tag":254,"props":340,"children":341},{},[342,347],{"type":186,"tag":316,"props":343,"children":344},{},[345],{"type":192,"value":346},"按角色划分的 AI 代理（Agents）",{"type":186,"tag":250,"props":348,"children":349},{},[350,383,405,422,439],{"type":186,"tag":254,"props":351,"children":352},{},[353,358,360],{"type":186,"tag":316,"props":354,"children":355},{},[356],{"type":192,"value":357},"Code Reviewer Agent",{"type":192,"value":359},"：\n",{"type":186,"tag":250,"props":361,"children":362},{},[363,368,373,378],{"type":186,"tag":254,"props":364,"children":365},{},[366],{"type":192,"value":367},"任务：代码审查",{"type":186,"tag":254,"props":369,"children":370},{},[371],{"type":192,"value":372},"输入：PR diff / 关键文件列表",{"type":186,"tag":254,"props":374,"children":375},{},[376],{"type":192,"value":377},"要求：必须检查哪些问题（性能、安全、边界条件、文档注释等）",{"type":186,"tag":254,"props":379,"children":380},{},[381],{"type":192,"value":382},"输出模板：先总体结论，再按文件列出问题，再给出建议修改方案",{"type":186,"tag":254,"props":384,"children":385},{},[386,391,392],{"type":186,"tag":316,"props":387,"children":388},{},[389],{"type":192,"value":390},"Refactoring Agent",{"type":192,"value":359},{"type":186,"tag":250,"props":393,"children":394},{},[395,400],{"type":186,"tag":254,"props":396,"children":397},{},[398],{"type":192,"value":399},"任务：重构老代码",{"type":186,"tag":254,"props":401,"children":402},{},[403],{"type":192,"value":404},"指令：保持对外行为不变；优先消除重复逻辑；建议拆分函数；给出重构后结构说明",{"type":186,"tag":254,"props":406,"children":407},{},[408,413,414],{"type":186,"tag":316,"props":409,"children":410},{},[411],{"type":192,"value":412},"Spec Writer Agent",{"type":192,"value":359},{"type":186,"tag":250,"props":415,"children":416},{},[417],{"type":186,"tag":254,"props":418,"children":419},{},[420],{"type":192,"value":421},"任务：根据产品需求写技术设计说明 / 接口规格文档",{"type":186,"tag":254,"props":423,"children":424},{},[425,430,431],{"type":186,"tag":316,"props":426,"children":427},{},[428],{"type":192,"value":429},"Test Writer Agent",{"type":192,"value":359},{"type":186,"tag":250,"props":432,"children":433},{},[434],{"type":186,"tag":254,"props":435,"children":436},{},[437],{"type":192,"value":438},"任务：为给定代码编写单元测试 / 集成测试用例",{"type":186,"tag":254,"props":440,"children":441},{},[442],{"type":192,"value":443},"…可根据团队情况扩展",{"type":186,"tag":254,"props":445,"children":446},{},[447,452],{"type":186,"tag":316,"props":448,"children":449},{},[450],{"type":192,"value":451},"常用 prompt 模板",{"type":186,"tag":250,"props":453,"children":454},{},[455,460,465],{"type":186,"tag":254,"props":456,"children":457},{},[458],{"type":192,"value":459},"“请帮我评审这段代码，重点关注性能和安全：…”",{"type":186,"tag":254,"props":461,"children":462},{},[463],{"type":192,"value":464},"“请根据以下用户故事，输出技术设计文档模板：…”",{"type":186,"tag":254,"props":466,"children":467},{},[468],{"type":192,"value":469},"“请基于下面 API 代码，生成接口文档（OpenAPI/Markdown）：…”",{"type":186,"tag":254,"props":471,"children":472},{},[473,478],{"type":186,"tag":316,"props":474,"children":475},{},[476],{"type":192,"value":477},"使用指南",{"type":186,"tag":250,"props":479,"children":480},{},[481,486,499],{"type":186,"tag":254,"props":482,"children":483},{},[484],{"type":192,"value":485},"在 Cursor/Windsurf/Claude Code 中如何调用这些指令",{"type":186,"tag":254,"props":487,"children":488},{},[489,491],{"type":192,"value":490},"推荐工作流：\n",{"type":186,"tag":250,"props":492,"children":493},{},[494],{"type":186,"tag":254,"props":495,"children":496},{},[497],{"type":192,"value":498},"写完功能 → 调用 Test Writer 生成测试 → 调用 Reviewer 审查",{"type":186,"tag":254,"props":500,"children":501},{},[502],{"type":192,"value":503},"注意事项：哪些任务必须人工复核，哪些可以完全交给 AI",{"type":186,"tag":238,"props":505,"children":507},{"id":506},"_3-如何在工具里落地共享指令",[508],{"type":192,"value":509},"3. 如何在工具里落地共享指令？",{"type":186,"tag":195,"props":511,"children":512},{},[513],{"type":192,"value":514},"以几类常见工具为例（思路，不依赖具体实现细节）：",{"type":186,"tag":309,"props":516,"children":517},{},[518,557,606],{"type":186,"tag":254,"props":519,"children":520},{},[521,526],{"type":186,"tag":316,"props":522,"children":523},{},[524],{"type":192,"value":525},"Cursor / Windsurf / Claude Code 里",{"type":186,"tag":250,"props":527,"children":528},{},[529,552],{"type":186,"tag":254,"props":530,"children":531},{},[532,534],{"type":192,"value":533},"利用“自定义 Slash 命令”功能，比如：\n",{"type":186,"tag":250,"props":535,"children":536},{},[537,542,547],{"type":186,"tag":254,"props":538,"children":539},{},[540],{"type":192,"value":541},"$$/review$$ → 自动调用 Code Reviewer 模板",{"type":186,"tag":254,"props":543,"children":544},{},[545],{"type":192,"value":546},"$$/tests$$ → 使用 Test Writer 模板",{"type":186,"tag":254,"props":548,"children":549},{},[550],{"type":192,"value":551},"$$/refactor$$ → 使用 Refactoring Agent 模板",{"type":186,"tag":254,"props":553,"children":554},{},[555],{"type":192,"value":556},"把这些命令及其含义写进 $$AGENTS.md$$，保证团队共识。",{"type":186,"tag":254,"props":558,"children":559},{},[560,565],{"type":186,"tag":316,"props":561,"children":562},{},[563],{"type":192,"value":564},"非编码任务（产品、设计、运营等）",{"type":186,"tag":250,"props":566,"children":567},{},[568,601],{"type":186,"tag":254,"props":569,"children":570},{},[571,573,576,578],{"type":192,"value":572},"在公司知识库（如 Confluence、Notion、飞书文档）建立",{"type":186,"tag":201,"props":574,"children":575},{},[],{"type":192,"value":577},"\n“Prompt Library” 或 “AI 使用手册” 页面：\n",{"type":186,"tag":250,"props":579,"children":580},{},[581,586,591,596],{"type":186,"tag":254,"props":582,"children":583},{},[584],{"type":192,"value":585},"产品需求分析模板",{"type":186,"tag":254,"props":587,"children":588},{},[589],{"type":192,"value":590},"用户访谈纪要整理模板",{"type":186,"tag":254,"props":592,"children":593},{},[594],{"type":192,"value":595},"PRD 规范模板",{"type":186,"tag":254,"props":597,"children":598},{},[599],{"type":192,"value":600},"市场调研 / 竞品分析的结构化问题清单",{"type":186,"tag":254,"props":602,"children":603},{},[604],{"type":192,"value":605},"把这些模板复制-粘贴到任意 AI 工具即可使用，不依赖具体 IDE。",{"type":186,"tag":254,"props":607,"children":608},{},[609,614],{"type":186,"tag":316,"props":610,"children":611},{},[612],{"type":192,"value":613},"通过版本控制实现“持续改进”",{"type":186,"tag":250,"props":615,"children":616},{},[617,622,627,632],{"type":186,"tag":254,"props":618,"children":619},{},[620],{"type":192,"value":621},"$$AGENTS.md$$ 放在代码仓库，和源码一起版本管理",{"type":186,"tag":254,"props":623,"children":624},{},[625],{"type":192,"value":626},"团队成员可以通过 PR 改进这些指令（就像改代码一样）",{"type":186,"tag":254,"props":628,"children":629},{},[630],{"type":192,"value":631},"变更记录可追踪，讨论也可在 Review 中完成",{"type":186,"tag":254,"props":633,"children":634},{},[635],{"type":192,"value":636},"“最优 prompt”不再是某个人脑子里的经验，而是团队资产",{"type":186,"tag":238,"props":638,"children":640},{"id":639},"_4-建设这套体系时的实用建议",[641],{"type":192,"value":642},"4. 建设这套体系时的实用建议",{"type":186,"tag":309,"props":644,"children":645},{},[646,685,724,758],{"type":186,"tag":254,"props":647,"children":648},{},[649,654],{"type":186,"tag":316,"props":650,"children":651},{},[652],{"type":192,"value":653},"从高频场景入手，不要一开始做得太大",{"type":186,"tag":250,"props":655,"children":656},{},[657,680],{"type":186,"tag":254,"props":658,"children":659},{},[660,662],{"type":192,"value":661},"先选 2–3 个最常见、最耗时的场景：\n",{"type":186,"tag":250,"props":663,"children":664},{},[665,670,675],{"type":186,"tag":254,"props":666,"children":667},{},[668],{"type":192,"value":669},"代码审查",{"type":186,"tag":254,"props":671,"children":672},{},[673],{"type":192,"value":674},"编写测试",{"type":186,"tag":254,"props":676,"children":677},{},[678],{"type":192,"value":679},"阅读和总结 legacy 代码",{"type":186,"tag":254,"props":681,"children":682},{},[683],{"type":192,"value":684},"先把这几类的 prompt 固化到 $$AGENTS.md$$，再逐步扩展。",{"type":186,"tag":254,"props":686,"children":687},{},[688,693],{"type":186,"tag":316,"props":689,"children":690},{},[691],{"type":192,"value":692},"为每条指令加上“适用范围 + 示例”",{"type":186,"tag":250,"props":694,"children":695},{},[696,719],{"type":186,"tag":254,"props":697,"children":698},{},[699,701],{"type":192,"value":700},"每个 Agent 或模板下，加一段：\n",{"type":186,"tag":250,"props":702,"children":703},{},[704,709,714],{"type":186,"tag":254,"props":705,"children":706},{},[707],{"type":192,"value":708},"什么时候用？",{"type":186,"tag":254,"props":710,"children":711},{},[712],{"type":192,"value":713},"输入示例",{"type":186,"tag":254,"props":715,"children":716},{},[717],{"type":192,"value":718},"输出示例（缩略版即可）",{"type":186,"tag":254,"props":720,"children":721},{},[722],{"type":192,"value":723},"让新人看一眼就知道怎么用。",{"type":186,"tag":254,"props":725,"children":726},{},[727,732],{"type":186,"tag":316,"props":728,"children":729},{},[730],{"type":192,"value":731},"明确“AI 能做什么 + 必须人工把关什么”",{"type":186,"tag":250,"props":733,"children":734},{},[735,753],{"type":186,"tag":254,"props":736,"children":737},{},[738,740],{"type":192,"value":739},"比如：\n",{"type":186,"tag":250,"props":741,"children":742},{},[743,748],{"type":186,"tag":254,"props":744,"children":745},{},[746],{"type":192,"value":747},"AI 可以起草代码 / 文档，但安全相关逻辑必须人工复查",{"type":186,"tag":254,"props":749,"children":750},{},[751],{"type":192,"value":752},"合同、法律文本必须由法律同事最终审阅",{"type":186,"tag":254,"props":754,"children":755},{},[756],{"type":192,"value":757},"在 $$AGENTS.md$$ 或 Prompt Library 顶部写清楚，避免滥用 AI。",{"type":186,"tag":254,"props":759,"children":760},{},[761,766],{"type":186,"tag":316,"props":762,"children":763},{},[764],{"type":192,"value":765},"定期“回顾和升级”指令",{"type":186,"tag":250,"props":767,"children":768},{},[769,787],{"type":186,"tag":254,"props":770,"children":771},{},[772,774],{"type":192,"value":773},"每 1–2 个月开一个轻量的“AI 使用回顾”\n",{"type":186,"tag":250,"props":775,"children":776},{},[777,782],{"type":186,"tag":254,"props":778,"children":779},{},[780],{"type":192,"value":781},"哪些 prompt 真有用？",{"type":186,"tag":254,"props":783,"children":784},{},[785],{"type":192,"value":786},"哪些场景 AI 表现不好，需要改写指令？",{"type":186,"tag":254,"props":788,"children":789},{},[790],{"type":192,"value":791},"把会议输出直接转化为对 $$AGENTS.md$$ 和 Prompt Library 的修改。",{"title":178,"searchDepth":793,"depth":793,"links":794},2,[795,796],{"id":189,"depth":793,"text":193},{"id":233,"depth":793,"text":236,"children":797},[798,800,801,802],{"id":240,"depth":799,"text":243},3,{"id":299,"depth":799,"text":302},{"id":506,"depth":799,"text":509},{"id":639,"depth":799,"text":642},"markdown","content: