shared instructions for software teams）",{"type":179,"children":180,"toc":788},"root",[181,190,202,212,222,227,233,240,245,265,270,288,293,299,304,500,506,511,633,639],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"brief",[187],{"type":188,"value":189},"text","Brief",{"type":182,"tag":191,"props":192,"children":193},"p",{},[194,196,200],{"type":188,"value":195},"对在软件交付过程中已经积极使用 AI 的团队来说，下一步要做的不只是依赖个人的临时提示（prompt），而是要为整个软件团队建立一套经过策划的共享指令体系。",{"type":182,"tag":197,"props":198,"children":199},"br",{},[],{"type":188,"value":201},"\n这种实践可以帮助你把 AI 有效应用到所有交付任务中——不仅仅是写代码——通过共享那些已经被验证过的、高质量的指令来实现。",{"type":182,"tag":191,"props":203,"children":204},{},[205,207,210],{"type":188,"value":206},"最直接的落地方式，就是在项目代码仓库中提交专门的指令文件，比如新建一个 $$AGENTS.md$$。",{"type":182,"tag":197,"props":208,"children":209},{},[],{"type":188,"value":211},"\n目前大多数 AI 编码工具——包括 Cursor、Windsurf 和 Claude Code——都支持通过自定义斜杠命令（slash commands）或工作流（workflows）来共享这些指令。",{"type":182,"tag":191,"props":213,"children":214},{},[215,217,220],{"type":188,"value":216},"对于非编码类任务，你可以在组织层面建立统一的提示词（prompt）库，让团队随时调用。",{"type":182,"tag":197,"props":218,"children":219},{},[],{"type":188,"value":221},"\n这种系统化的方式可以实现持续改进：一旦某条提示被优化，整个团队就都能立刻受益，并且始终都能访问到当前最优的 AI 使用指令。",{"type":182,"tag":191,"props":223,"children":224},{},[225],{"type":188,"value":226},"来源：技术雷达",{"type":182,"tag":183,"props":228,"children":230},{"id":229},"guide",[231],{"type":188,"value":232},"Guide",{"type":182,"tag":234,"props":235,"children":237},"h3",{"id":236},"_1-为什么需要团队级指令而不是只靠个人-prompt",[238],{"type":188,"value":239},"1. 为什么需要“团队级指令”，而不是只靠个人 prompt？",{"type":182,"tag":191,"props":241,"children":242},{},[243],{"type":188,"value":244},"如果只依赖个人经验，每个人在用 AI 时都会：",{"type":182,"tag":246,"props":247,"children":248},"ul",{},[249,255,260],{"type":182,"tag":250,"props":251,"children":252},"li",{},[253],{"type":188,"value":254},"自己摸索一套提示语，“效果只在自己头上生效”",{"type":182,"tag":250,"props":256,"children":257},{},[258],{"type":188,"value":259},"新同事要从零开始学习如何跟 AI 协作",{"type":182,"tag":250,"props":261,"children":262},{},[263],{"type":188,"value":264},"同一个问题，不同人问法不同，效果差异大，难以复现",{"type":182,"tag":191,"props":266,"children":267},{},[268],{"type":188,"value":269},"而“策划并共享指令”（curated shared instructions）的目标是：",{"type":182,"tag":246,"props":271,"children":272},{},[273,278,283],{"type":182,"tag":250,"props":274,"children":275},{},[276],{"type":188,"value":277},"把“用 AI 做这类任务的最佳问法”固化下来",{"type":182,"tag":250,"props":279,"children":280},{},[281],{"type":188,"value":282},"每个成员都能一键复用，不需要重新踩坑",{"type":182,"tag":250,"props":284,"children":285},{},[286],{"type":188,"value":287},"项目级别的“使用 AI 方式”变得标准、可复用、可改进",{"type":182,"tag":191,"props":289,"children":290},{},[291],{"type":188,"value":292},"可以理解为：给 AI 建一本“团队操作手册”，而不是靠每个人即兴发挥。",{"type":182,"tag":234,"props":294,"children":296},{"id":295},"_2-agentsmd-可以写什么",[297],{"type":188,"value":298},"2. $$AGENTS.md$$ 可以写什么？",{"type":182,"tag":191,"props":300,"children":301},{},[302],{"type":188,"value":303},"一个典型的 $$AGENTS.md$$ 文件，可以长这样（示例结构）：",{"type":182,"tag":305,"props":306,"children":307},"ol",{},[308,335,440,466],{"type":182,"tag":250,"props":309,"children":310},{},[311,317],{"type":182,"tag":312,"props":313,"children":314},"strong",{},[315],{"type":188,"value":316},"全局原则（For all agents）",{"type":182,"tag":246,"props":318,"children":319},{},[320,325,330],{"type":182,"tag":250,"props":321,"children":322},{},[323],{"type":188,"value":324},"代码风格（缩进、命名规则、语言版本等）",{"type":182,"tag":250,"props":326,"children":327},{},[328],{"type":188,"value":329},"安全与合规要求（比如不得引入 GPL 代码、不得上传隐私数据）",{"type":182,"tag":250,"props":331,"children":332},{},[333],{"type":188,"value":334},"输出格式要求（是否必须带测试用例、是否必须解释关键设计决策）",{"type":182,"tag":250,"props":336,"children":337},{},[338,343],{"type":182,"tag":312,"props":339,"children":340},{},[341],{"type":188,"value":342},"按角色划分的 AI 代理（Agents）",{"type":182,"tag":246,"props":344,"children":345},{},[346,379,401,418,435],{"type":182,"tag":250,"props":347,"children":348},{},[349,354,356],{"type":182,"tag":312,"props":350,"children":351},{},[352],{"type":188,"value":353},"Code Reviewer Agent",{"type":188,"value":355},"：\n",{"type":182,"tag":246,"props":357,"children":358},{},[359,364,369,374],{"type":182,"tag":250,"props":360,"children":361},{},[362],{"type":188,"value":363},"任务：代码审查",{"type":182,"tag":250,"props":365,"children":366},{},[367],{"type":188,"value":368},"输入：PR diff / 关键文件列表",{"type":182,"tag":250,"props":370,"children":371},{},[372],{"type":188,"value":373},"要求：必须检查哪些问题（性能、安全、边界条件、文档注释等）",{"type":182,"tag":250,"props":375,"children":376},{},[377],{"type":188,"value":378},"输出模板：先总体结论，再按文件列出问题，再给出建议修改方案",{"type":182,"tag":250,"props":380,"children":381},{},[382,387,388],{"type":182,"tag":312,"props":383,"children":384},{},[385],{"type":188,"value":386},"Refactoring Agent",{"type":188,"value":355},{"type":182,"tag":246,"props":389,"children":390},{},[391,396],{"type":182,"tag":250,"props":392,"children":393},{},[394],{"type":188,"value":395},"任务：重构老代码",{"type":182,"tag":250,"props":397,"children":398},{},[399],{"type":188,"value":400},"指令：保持对外行为不变；优先消除重复逻辑；建议拆分函数；给出重构后结构说明",{"type":182,"tag":250,"props":402,"children":403},{},[404,409,410],{"type":182,"tag":312,"props":405,"children":406},{},[407],{"type":188,"value":408},"Spec Writer Agent",{"type":188,"value":355},{"type":182,"tag":246,"props":411,"children":412},{},[413],{"type":182,"tag":250,"props":414,"children":415},{},[416],{"type":188,"value":417},"任务：根据产品需求写技术设计说明 / 接口规格文档",{"type":182,"tag":250,"props":419,"children":420},{},[421,426,427],{"type":182,"tag":312,"props":422,"children":423},{},[424],{"type":188,"value":425},"Test Writer Agent",{"type":188,"value":355},{"type":182,"tag":246,"props":428,"children":429},{},[430],{"type":182,"tag":250,"props":431,"children":432},{},[433],{"type":188,"value":434},"任务：为给定代码编写单元测试 / 集成测试用例",{"type":182,"tag":250,"props":436,"children":437},{},[438],{"type":188,"value":439},"…可根据团队情况扩展",{"type":182,"tag":250,"props":441,"children":442},{},[443,448],{"type":182,"tag":312,"props":444,"children":445},{},[446],{"type":188,"value":447},"常用 prompt 模板",{"type":182,"tag":246,"props":449,"children":450},{},[451,456,461],{"type":182,"tag":250,"props":452,"children":453},{},[454],{"type":188,"value":455},"“请帮我评审这段代码，重点关注性能和安全：…”",{"type":182,"tag":250,"props":457,"children":458},{},[459],{"type":188,"value":460},"“请根据以下用户故事，输出技术设计文档模板：…”",{"type":182,"tag":250,"props":462,"children":463},{},[464],{"type":188,"value":465},"“请基于下面 API 代码，生成接口文档（OpenAPI/Markdown）：…”",{"type":182,"tag":250,"props":467,"children":468},{},[469,474],{"type":182,"tag":312,"props":470,"children":471},{},[472],{"type":188,"value":473},"使用指南",{"type":182,"tag":246,"props":475,"children":476},{},[477,482,495],{"type":182,"tag":250,"props":478,"children":479},{},[480],{"type":188,"value":481},"在 Cursor/Windsurf/Claude Code 中如何调用这些指令",{"type":182,"tag":250,"props":483,"children":484},{},[485,487],{"type":188,"value":486},"推荐工作流：\n",{"type":182,"tag":246,"props":488,"children":489},{},[490],{"type":182,"tag":250,"props":491,"children":492},{},[493],{"type":188,"value":494},"写完功能 → 调用 Test Writer 生成测试 → 调用 Reviewer 审查",{"type":182,"tag":250,"props":496,"children":497},{},[498],{"type":188,"value":499},"注意事项：哪些任务必须人工复核，哪些可以完全交给 AI",{"type":182,"tag":234,"props":501,"children":503},{"id":502},"_3-如何在工具里落地共享指令",[504],{"type":188,"value":505},"3. 如何在工具里落地共享指令？",{"type":182,"tag":191,"props":507,"children":508},{},[509],{"type":188,"value":510},"以几类常见工具为例（思路，不依赖具体实现细节）：",{"type":182,"tag":305,"props":512,"children":513},{},[514,553,602],{"type":182,"tag":250,"props":515,"children":516},{},[517,522],{"type":182,"tag":312,"props":518,"children":519},{},[520],{"type":188,"value":521},"Cursor / Windsurf / Claude Code 里",{"type":182,"tag":246,"props":523,"children":524},{},[525,548],{"type":182,"tag":250,"props":526,"children":527},{},[528,530],{"type":188,"value":529},"利用“自定义 Slash 命令”功能，比如：\n",{"type":182,"tag":246,"props":531,"children":532},{},[533,538,543],{"type":182,"tag":250,"props":534,"children":535},{},[536],{"type":188,"value":537},"$$/review$$ → 自动调用 Code Reviewer 模板",{"type":182,"tag":250,"props":539,"children":540},{},[541],{"type":188,"value":542},"$$/tests$$ → 使用 Test Writer 模板",{"type":182,"tag":250,"props":544,"children":545},{},[546],{"type":188,"value":547},"$$/refactor$$ → 使用 Refactoring Agent 模板",{"type":182,"tag":250,"props":549,"children":550},{},[551],{"type":188,"value":552},"把这些命令及其含义写进 $$AGENTS.md$$，保证团队共识。",{"type":182,"tag":250,"props":554,"children":555},{},[556,561],{"type":182,"tag":312,"props":557,"children":558},{},[559],{"type":188,"value":560},"非编码任务（产品、设计、运营等）",{"type":182,"tag":246,"props":562,"children":563},{},[564,597],{"type":182,"tag":250,"props":565,"children":566},{},[567,569,572,574],{"type":188,"value":568},"在公司知识库（如 Confluence、Notion、飞书文档）建立",{"type":182,"tag":197,"props":570,"children":571},{},[],{"type":188,"value":573},"\n“Prompt Library” 或 “AI 使用手册” 页面：\n",{"type":182,"tag":246,"props":575,"children":576},{},[577,582,587,592],{"type":182,"tag":250,"props":578,"children":579},{},[580],{"type":188,"value":581},"产品需求分析模板",{"type":182,"tag":250,"props":583,"children":584},{},[585],{"type":188,"value":586},"用户访谈纪要整理模板",{"type":182,"tag":250,"props":588,"children":589},{},[590],{"type":188,"value":591},"PRD 规范模板",{"type":182,"tag":250,"props":593,"children":594},{},[595],{"type":188,"value":596},"市场调研 / 竞品分析的结构化问题清单",{"type":182,"tag":250,"props":598,"children":599},{},[600],{"type":188,"value":601},"把这些模板复制-粘贴到任意 AI 工具即可使用，不依赖具体 IDE。",{"type":182,"tag":250,"props":603,"children":604},{},[605,610],{"type":182,"tag":312,"props":606,"children":607},{},[608],{"type":188,"value":609},"通过版本控制实现“持续改进”",{"type":182,"tag":246,"props":611,"children":612},{},[613,618,623,628],{"type":182,"tag":250,"props":614,"children":615},{},[616],{"type":188,"value":617},"$$AGENTS.md$$ 放在代码仓库，和源码一起版本管理",{"type":182,"tag":250,"props":619,"children":620},{},[621],{"type":188,"value":622},"团队成员可以通过 PR 改进这些指令（就像改代码一样）",{"type":182,"tag":250,"props":624,"children":625},{},[626],{"type":188,"value":627},"变更记录可追踪，讨论也可在 Review 中完成",{"type":182,"tag":250,"props":629,"children":630},{},[631],{"type":188,"value":632},"“最优 prompt”不再是某个人脑子里的经验，而是团队资产",{"type":182,"tag":234,"props":634,"children":636},{"id":635},"_4-建设这套体系时的实用建议",[637],{"type":188,"value":638},"4. 建设这套体系时的实用建议",{"type":182,"tag":305,"props":640,"children":641},{},[642,681,720,754],{"type":182,"tag":250,"props":643,"children":644},{},[645,650],{"type":182,"tag":312,"props":646,"children":647},{},[648],{"type":188,"value":649},"从高频场景入手，不要一开始做得太大",{"type":182,"tag":246,"props":651,"children":652},{},[653,676],{"type":182,"tag":250,"props":654,"children":655},{},[656,658],{"type":188,"value":657},"先选 2–3 个最常见、最耗时的场景：\n",{"type":182,"tag":246,"props":659,"children":660},{},[661,666,671],{"type":182,"tag":250,"props":662,"children":663},{},[664],{"type":188,"value":665},"代码审查",{"type":182,"tag":250,"props":667,"children":668},{},[669],{"type":188,"value":670},"编写测试",{"type":182,"tag":250,"props":672,"children":673},{},[674],{"type":188,"value":675},"阅读和总结 legacy 代码",{"type":182,"tag":250,"props":677,"children":678},{},[679],{"type":188,"value":680},"先把这几类的 prompt 固化到 $$AGENTS.md$$，再逐步扩展。",{"type":182,"tag":250,"props":682,"children":683},{},[684,689],{"type":182,"tag":312,"props":685,"children":686},{},[687],{"type":188,"value":688},"为每条指令加上“适用范围 + 示例”",{"type":182,"tag":246,"props":690,"children":691},{},[692,715],{"type":182,"tag":250,"props":693,"children":694},{},[695,697],{"type":188,"value":696},"每个 Agent 或模板下，加一段：\n",{"type":182,"tag":246,"props":698,"children":699},{},[700,705,710],{"type":182,"tag":250,"props":701,"children":702},{},[703],{"type":188,"value":704},"什么时候用？",{"type":182,"tag":250,"props":706,"children":707},{},[708],{"type":188,"value":709},"输入示例",{"type":182,"tag":250,"props":711,"children":712},{},[713],{"type":188,"value":714},"输出示例（缩略版即可）",{"type":182,"tag":250,"props":716,"children":717},{},[718],{"type":188,"value":719},"让新人看一眼就知道怎么用。",{"type":182,"tag":250,"props":721,"children":722},{},[723,728],{"type":182,"tag":312,"props":724,"children":725},{},[726],{"type":188,"value":727},"明确“AI 能做什么 + 必须人工把关什么”",{"type":182,"tag":246,"props":729,"children":730},{},[731,749],{"type":182,"tag":250,"props":732,"children":733},{},[734,736],{"type":188,"value":735},"比如：\n",{"type":182,"tag":246,"props":737,"children":738},{},[739,744],{"type":182,"tag":250,"props":740,"children":741},{},[742],{"type":188,"value":743},"AI 可以起草代码 / 文档，但安全相关逻辑必须人工复查",{"type":182,"tag":250,"props":745,"children":746},{},[747],{"type":188,"value":748},"合同、法律文本必须由法律同事最终审阅",{"type":182,"tag":250,"props":750,"children":751},{},[752],{"type":188,"value":753},"在 $$AGENTS.md$$ 或 Prompt Library 顶部写清楚，避免滥用 AI。",{"type":182,"tag":250,"props":755,"children":756},{},[757,762],{"type":182,"tag":312,"props":758,"children":759},{},[760],{"type":188,"value":761},"定期“回顾和升级”指令",{"type":182,"tag":246,"props":763,"children":764},{},[765,783],{"type":182,"tag":250,"props":766,"children":767},{},[768,770],{"type":188,"value":769},"每 1–2 个月开一个轻量的“AI 使用回顾”\n",{"type":182,"tag":246,"props":771,"children":772},{},[773,778],{"type":182,"tag":250,"props":774,"children":775},{},[776],{"type":188,"value":777},"哪些 prompt 真有用？",{"type":182,"tag":250,"props":779,"children":780},{},[781],{"type":188,"value":782},"哪些场景 AI 表现不好，需要改写指令？",{"type":182,"tag":250,"props":784,"children":785},{},[786],{"type":188,"value":787},"把会议输出直接转化为对 $$AGENTS.md$$ 和 Prompt Library 的修改。",{"title":175,"searchDepth":789,"depth":789,"links":790},2,[791,792],{"id":185,"depth":789,"text":189},{"id":229,"depth":789,"text":232,"children":793},[794,796,797,798],{"id":236,"depth":795,"text":239},3,{"id":295,"depth":795,"text":298},{"id":502,"depth":795,"text":505},{"id":635,"depth":795,"text":638},"markdown","content:6.maps:_ai:prompt:team-based-instructions.md","content","6.maps/_ai/prompt/team-based-instructions.md","6.maps/_ai/prompt/team-based-instructions","md",[806,810],{"_path":807,"title":808,"description":809},"/maps/_ai/prompt/prompt-engineering","提示工程","指的是根据所需的任务目标，有意识地设计、优化和调整输入语言（即“提示”）的过程，以引导AI模型输出更高质量、符合期望和语境的内容，包含上下文设置、提示设计、提示调优、多模型适配等核心过程。",{"_path":811,"title":812,"description":813},"/maps/_ai/rag/on-device-info-retrieval","设备端信息检索","在用户设备上进行信息检索以保障隐私和提升效率。",1771214948662]