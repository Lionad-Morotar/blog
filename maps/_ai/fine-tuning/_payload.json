❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133,"children":134},"造物 / Make","/tools",[135,137,140,143,146,149,152],{"title":136,"_path":133},"🧰 工具收集",{"title":138,"_path":139},"📕 博客","/tools/blog",{"title":141,"_path":142},"🥥 Coconut","/tools/coconut",{"title":144,"_path":145},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":147,"_path":148},"🌐 AnySort","/tools/anysort",{"title":150,"_path":151},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":153,"_path":154},"👓 Crapto","/tools/crypto-inline",{"title":156,"_path":157,"children":158},"我 / About","/hire",[159],{"title":160,"_path":157},"📬 技术简历",{"title":162,"_path":163,"children":164},"En","/en",[165],{"title":166,"_path":167,"children":168},"🦁 Welcome","/en/articles",[169],{"title":166,"_path":167},{"_path":171,"_dir":172,"_draft":173,"_partial":174,"_locale":175,"title":176,"description":175,"body":177,"_type":383,"_id":384,"_source":385,"_file":386,"_stem":387,"_extension":388},"/maps/_ai/fine-tuning","_ai",false,true,"","微调 (Fine-tuning)",{"type":178,"children":179,"toc":374},"root",[180,188,195,201,224,230,235,254,260,265,284,290,295,314,320,325,344,350,355],{"type":181,"tag":182,"props":183,"children":185},"element","h1",{"id":184},"微调-fine-tuning",[186],{"type":187,"value":176},"text",{"type":181,"tag":189,"props":190,"children":192},"h2",{"id":191},"axolotlyaml-配置驱动的微调框架",[193],{"type":187,"value":194},"Axolotl：YAML 配置驱动的微调框架",{"type":181,"tag":196,"props":197,"children":198},"p",{},[199],{"type":187,"value":200},"Axolotl 的核心理念是\"用 YAML 定义整个训练流程\"——从数据预处理、模型加载、训练配置到导出部署，全部收敛在一个配置文件中。这种声明式接口降低了微调门槛，支持 LoRA/QLoRA、全参数微调、多模态微调和持续预训练。2025 年 2 月新增 LoRA 优化，在单 GPU 和多 GPU 训练中进一步降低内存占用并提升训练速度。",{"type":181,"tag":196,"props":202,"children":203},{},[204,206,215,217],{"type":187,"value":205},"见：",{"type":181,"tag":207,"props":208,"children":212},"a",{"href":209,"rel":210},"https://github.com/axolotl-ai-cloud/axolotl",[211],"nofollow",[213],{"type":187,"value":214},"Axolotl GitHub",{"type":187,"value":216}," | ",{"type":181,"tag":207,"props":218,"children":221},{"href":219,"rel":220},"https://docs.axolotl.ai/",[211],[222],{"type":187,"value":223},"Axolotl 官方文档",{"type":181,"tag":189,"props":225,"children":227},{"id":226},"llama-factory一站式-llm-训练与部署平台",[228],{"type":187,"value":229},"LLaMA-Factory：一站式 LLM 训练与部署平台",{"type":181,"tag":196,"props":231,"children":232},{},[233],{"type":187,"value":234},"LLaMA-Factory 是目前最全面的开源微调框架，支持 100+ 模型架构，提供 Web UI 界面让非技术人员也能轻松操作。其特色是集成了模型量化、合并、导出等全流程工具，微调完成后可直接生成 GGUF、vLLM 等部署格式。通过可扩展的模块统一了多种高效微调方法，让大模型微调真正普及。",{"type":181,"tag":196,"props":236,"children":237},{},[238,239,246,247],{"type":187,"value":205},{"type":181,"tag":207,"props":240,"children":243},{"href":241,"rel":242},"https://github.com/hiyouga/LLaMA-Factory",[211],[244],{"type":187,"value":245},"LLaMA-Factory GitHub",{"type":187,"value":216},{"type":181,"tag":207,"props":248,"children":251},{"href":249,"rel":250},"https://zhuanlan.zhihu.com/p/694047673",[211],[252],{"type":187,"value":253},"LLaMA-Factory 使用指南",{"type":181,"tag":189,"props":255,"children":257},{"id":256},"lora低秩适配的参数高效微调",[258],{"type":187,"value":259},"LoRA：低秩适配的参数高效微调",{"type":181,"tag":196,"props":261,"children":262},{},[263],{"type":187,"value":264},"LoRA（Low-Rank Adaptation）冻结预训练模型权重，注入可训练的秩分解矩阵到每一层：W = W_0 + BA，其中 W_0 冻结，B 和 A 可训练且秩远小于 W。这种方法将训练参数量减少 10000 倍，同时保持与全参数微调相当的性能，是在消费级 GPU 上微调大模型的标准选择。",{"type":181,"tag":196,"props":266,"children":267},{},[268,269,276,277],{"type":187,"value":205},{"type":181,"tag":207,"props":270,"children":273},{"href":271,"rel":272},"https://arxiv.org/abs/2106.09685",[211],[274],{"type":187,"value":275},"LoRA 论文",{"type":187,"value":216},{"type":181,"tag":207,"props":278,"children":281},{"href":279,"rel":280},"https://huggingface.co/learn/llm-course/en/chapter11/4",[211],[282],{"type":187,"value":283},"Hugging Face LoRA 教程",{"type":181,"tag":189,"props":285,"children":287},{"id":286},"qlora量化-lora-的极致内存优化",[288],{"type":187,"value":289},"QLoRA：量化 + LoRA 的极致内存优化",{"type":181,"tag":196,"props":291,"children":292},{},[293],{"type":187,"value":294},"QLoRA 将 4-bit 量化与 LoRA 结合，实现最大内存效率。全参数微调 70 亿参数模型需要 100-120GB 显存，而 QLoRA 仅需约 10GB，让消费级 GPU 也能微调大模型。量化后的模型权重以低精度存储，计算时动态反量化，配合 LoRA 的可训练适配器，在效率和效果之间取得完美平衡。",{"type":181,"tag":196,"props":296,"children":297},{},[298,299,306,307],{"type":187,"value":205},{"type":181,"tag":207,"props":300,"children":303},{"href":301,"rel":302},"https://www.redhat.com/en/topics/ai/lora-vs-qlora",[211],[304],{"type":187,"value":305},"LoRA vs QLoRA - RedHat",{"type":187,"value":216},{"type":181,"tag":207,"props":308,"children":311},{"href":309,"rel":310},"https://www.ibm.com/docs/en/watsonx/w-and-w/2.1.0?topic=tuning-qlora-fine",[211],[312],{"type":187,"value":313},"IBM QLoRA 文档",{"type":181,"tag":189,"props":315,"children":317},{"id":316},"pefthugging-face-参数高效微调库",[318],{"type":187,"value":319},"PEFT：Hugging Face 参数高效微调库",{"type":181,"tag":196,"props":321,"children":322},{},[323],{"type":187,"value":324},"PEFT（Parameter-Efficient Fine-Tuning）是 Hugging Face 开源的参数高效微调库，集成了 LoRA、Prefix Tuning、Prompt Tuning、IA³、Adapter 等多种方法。它让研究者可以用统一接口尝试不同微调策略，无需修改模型代码即可切换方法，极大简化了实验流程。",{"type":181,"tag":196,"props":326,"children":327},{},[328,329,336,337],{"type":187,"value":205},{"type":181,"tag":207,"props":330,"children":333},{"href":331,"rel":332},"https://github.com/huggingface/peft",[211],[334],{"type":187,"value":335},"PEFT GitHub",{"type":187,"value":216},{"type":181,"tag":207,"props":338,"children":341},{"href":339,"rel":340},"https://huggingface.co/docs/peft/en/conceptual_guides/adapter",[211],[342],{"type":187,"value":343},"PEFT 方法概览",{"type":181,"tag":189,"props":345,"children":347},{"id":346},"unsloth手写-cuda-内核的极速微调",[348],{"type":187,"value":349},"Unsloth：手写 CUDA 内核的极速微调",{"type":181,"tag":196,"props":351,"children":352},{},[353],{"type":187,"value":354},"Unsloth 通过手写 CUDA 内核和算法优化，在保持精度的前提下将微调速度提升 2-5 倍，显存占用降低 50%+。它针对 LLM 训练中的热点操作（RoPE、LayerNorm、Cross-Entropy）定制 CUDA 实现，支持与 PEFT 完全兼容，只需修改几行导入语句即可加速现有 LoRA/QLoRA 训练代码。",{"type":181,"tag":196,"props":356,"children":357},{},[358,359,366,367],{"type":187,"value":205},{"type":181,"tag":207,"props":360,"children":363},{"href":361,"rel":362},"https://unsloth.ai/",[211],[364],{"type":187,"value":365},"Unsloth 官网",{"type":187,"value":216},{"type":181,"tag":207,"props":368,"children":371},{"href":369,"rel":370},"https://unsloth.ai/blog",[211],[372],{"type":187,"value":373},"Unsloth 博客",{"title":175,"searchDepth":375,"depth":375,"links":376},2,[377,378,379,380,381,382],{"id":191,"depth":375,"text":194},{"id":226,"depth":375,"text":229},{"id":256,"depth":375,"text":259},{"id":286,"depth":375,"text":289},{"id":316,"depth":375,"text":319},{"id":346,"depth":375,"text":349},"markdown","content:6.maps:_ai:fine-tuning.md","content","6.maps/_ai/fine-tuning.md","6.maps/_ai/fine-tuning","md",[390,393],{"_path":391,"title":392,"description":175},"/maps/_ai/evaluation","评估 (Evaluation)",{"_path":394,"title":395,"description":396},"/maps/_ai/framework/saif","SAIF","安全人工智能框架",1771264674025]