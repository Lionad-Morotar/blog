7},"root",[183,191,198,204,227,233,238,257,263,268,287,293,298,317,323,328,347,353,358],{"type":184,"tag":185,"props":186,"children":188},"element","h1",{"id":187},"微调-fine-tuning",[189],{"type":190,"value":179},"text",{"type":184,"tag":192,"props":193,"children":195},"h2",{"id":194},"axolotlyaml-配置驱动的微调框架",[196],{"type":190,"value":197},"Axolotl：YAML 配置驱动的微调框架",{"type":184,"tag":199,"props":200,"children":201},"p",{},[202],{"type":190,"value":203},"Axolotl 的核心理念是\"用 YAML 定义整个训练流程\"——从数据预处理、模型加载、训练配置到导出部署，全部收敛在一个配置文件中。这种声明式接口降低了微调门槛，支持 LoRA/QLoRA、全参数微调、多模态微调和持续预训练。2025 年 2 月新增 LoRA 优化，在单 GPU 和多 GPU 训练中进一步降低内存占用并提升训练速度。",{"type":184,"tag":199,"props":205,"children":206},{},[207,209,218,220],{"type":190,"value":208},"见：",{"type":184,"tag":210,"props":211,"children":215},"a",{"href":212,"rel":213},"https://github.com/axolotl-ai-cloud/axolotl",[214],"nofollow",[216],{"type":190,"value":217},"Axolotl GitHub",{"type":190,"value":219}," | ",{"type":184,"tag":210,"props":221,"children":224},{"href":222,"rel":223},"https://docs.axolotl.ai/",[214],[225],{"type":190,"value":226},"Axolotl 官方文档",{"type":184,"tag":192,"props":228,"children":230},{"id":229},"llama-factory一站式-llm-训练与部署平台",[231],{"type":190,"value":232},"LLaMA-Factory：一站式 LLM 训练与部署平台",{"type":184,"tag":199,"props":234,"children":235},{},[236],{"type":190,"value":237},"LLaMA-Factory 是目前最全面的开源微调框架，支持 100+ 模型架构，提供 Web UI 界面让非技术人员也能轻松操作。其特色是集成了模型量化、合并、导出等全流程工具，微调完成后可直接生成 GGUF、vLLM 等部署格式。通过可扩展的模块统一了多种高效微调方法，让大模型微调真正普及。",{"type":184,"tag":199,"props":239,"children":240},{},[241,242,249,250],{"type":190,"value":208},{"type":184,"tag":210,"props":243,"children":246},{"href":244,"rel":245},"https://github.com/hiyouga/LLaMA-Factory",[214],[247],{"type":190,"value":248},"LLaMA-Factory GitHub",{"type":190,"value":219},{"type":184,"tag":210,"props":251,"children":254},{"href":252,"rel":253},"https://zhuanlan.zhihu.com/p/694047673",[214],[255],{"type":190,"value":256},"LLaMA-Factory 使用指南",{"type":184,"tag":192,"props":258,"children":260},{"id":259},"lora低秩适配的参数高效微调",[261],{"type":190,"value":262},"LoRA：低秩适配的参数高效微调",{"type":184,"tag":199,"props":264,"children":265},{},[266],{"type":190,"value":267},"LoRA（Low-Rank Adaptation）冻结预训练模型权重，注入可训练的秩分解矩阵到每一层：W = W_0 + BA，其中 W_0 冻结，B 和 A 可训练且秩远小于 W。这种方法将训练参数量减少 10000 倍，同时保持与全参数微调相当的性能，是在消费级 GPU 上微调大模型的标准选择。",{"type":184,"tag":199,"props":269,"children":270},{},[271,272,279,280],{"type":190,"value":208},{"type":184,"tag":210,"props":273,"children":276},{"href":274,"rel":275},"https://arxiv.org/abs/2106.09685",[214],[277],{"type":190,"value":278},"LoRA 论文",{"type":190,"value":219},{"type":184,"tag":210,"props":281,"children":284},{"href":282,"rel":283},"https://huggingface.co/learn/llm-course/en/chapter11/4",[214],[285],{"type":190,"value":286},"Hugging Face LoRA 教程",{"type":184,"tag":192,"props":288,"children":290},{"id":289},"qlora量化-lora-的极致内存优化",[291],{"type":190,"value":292},"QLoRA：量化 + LoRA 的极致内存优化",{"type":184,"tag":199,"props":294,"children":295},{},[296],{"type":190,"value":297},"QLoRA 将 4-bit 量化与 LoRA 结合，实现最大内存效率。全参数微调 70 亿参数模型需要 100-120GB 显存，而 QLoRA 仅需约 10GB，让消费级 GPU 也能微调大模型。量化后的模型权重以低精度存储，计算时动态反量化，配合 LoRA 的可训练适配器，在效率和效果之间取得完美平衡。",{"type":184,"tag":199,"props":299,"children":300},{},[301,302,309,310],{"type":190,"value":208},{"type":184,"tag":210,"props":303,"children":306},{"href":304,"rel":305},"https://www.redhat.com/en/topics/ai/lora-vs-qlora",[214],[307],{"type":190,"value":308},"LoRA vs QLoRA - RedHat",{"type":190,"value":219},{"type":184,"tag":210,"props":311,"children":314},{"href":312,"rel":313},"https://www.ibm.com/docs/en/watsonx/w-and-w/2.1.0?topic=tuning-qlora-fine",[214],[315],{"type":190,"value":316},"IBM QLoRA 文档",{"type":184,"tag":192,"props":318,"children":320},{"id":319},"pefthugging-face-参数高效微调库",[321],{"type":190,"value":322},"PEFT：Hugging Face 参数高效微调库",{"type":184,"tag":199,"props":324,"children":325},{},[326],{"type":190,"value":327},"PEFT（Parameter-Efficient Fine-Tuning）是 Hugging Face 开源的参数高效微调库，集成了 LoRA、Prefix Tuning、Prompt Tuning、IA³、Adapter 等多种方法。它让研究者可以用统一接口尝试不同微调策略，无需修改模型代码即可切换方法，极大简化了实验流程。",{"type":184,"tag":199,"props":329,"children":330},{},[331,332,339,340],{"type":190,"value":208},{"type":184,"tag":210,"props":333,"children":336},{"href":334,"rel":335},"https://github.com/huggingface/peft",[214],[337],{"type":190,"value":338},"PEFT GitHub",{"type":190,"value":219},{"type":184,"tag":210,"props":341,"children":344},{"href":342,"rel":343},"https://huggingface.co/docs/peft/en/conceptual_guides/adapter",[214],[345],{"type":190,"value":346},"PEFT 方法概览",{"type":184,"tag":192,"props":348,"children":350},{"id":349},"unsloth手写-cuda-内核的极速微调",[351],{"type":190,"value":352},"Unsloth：手写 CUDA 内核的极速微调",{"type":184,"tag":199,"props":354,"children":355},{},[356],{"type":190,"value":357},"Unsloth 通过手写 CUDA 内核和算法优化，在保持精度的前提下将微调速度提升 2-5 倍，显存占用降低 50%+。它针对 LLM 训练中的热点操作（RoPE、LayerNorm、Cross-Entropy）定制 CUDA 实现，支持与 PEFT 完全兼容，只需修改几行导入语句即可加速现有 LoRA/QLoRA 训练代码。",{"type":184,"tag":199,"props":359,"children":360},{},[361,362,369,370],{"type":190,"value":208},{"type":184,"tag":210,"props":363,"children":366},{"href":364,"rel":365},"https://unsloth.ai/",[214],[367],{"type":190,"value":368},"Unsloth 官网",{"type":190,"value":219},{"type":184,"tag":210,"props":371,"children":374},{"href":372,"rel":373},"https://unsloth.ai/blog",[214],[375],{"type":190,"value":376},"Unsloth 博客",{"title":178,"searchDepth":378,"depth":378,"links":379},2,[380,381,382,383,384,385],{"id":194,"depth":378,"text":197},{"id":229,"depth":378,"text":232},{"id":259,"depth":378,"text":262},{"id":289,"depth":378,"text":292},{"id":319,"depth":378,"text":322},{"id":349,"depth":378,"text":352},"markdown","content:6.maps:_ai:fine-tuning.md","content","6.maps/_ai/fine-tuning.md","6.maps/_ai/fine-tuning","md",[393,396],{"_path":394,"title":395,"description":178},"/maps/_ai/evaluation","评估 (Evaluation)",{"_path":397,"title":398,"description":399},"/maps/_ai/framework/saif","SAIF","安全人工智能框架",1771521526441]