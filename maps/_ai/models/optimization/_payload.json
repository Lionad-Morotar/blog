zation","Model optimization techniques","_ai/optimization.md",{"type":183,"children":184,"toc":374},"root",[185,194,201,207,238,244,249,268,274,279,298,304,309,336,342,347],{"type":186,"tag":187,"props":188,"children":190},"element","h1",{"id":189},"优化-optimization",[191],{"type":192,"value":193},"text","优化 (Optimization)",{"type":186,"tag":195,"props":196,"children":198},"h2",{"id":197},"flash-attention内存高效的注意力计算",[199],{"type":192,"value":200},"Flash Attention：内存高效的注意力计算",{"type":186,"tag":202,"props":203,"children":204},"p",{},[205],{"type":192,"value":206},"Flash Attention 由 Tri Dao 开发，通过分块计算（tiling）和重计算（recomputation）策略，将注意力计算从 O(N²) 内存复杂度降至 O(N)，同时保持计算精度不变。Flash Attention-3 进一步优化 Hopper GPU，利用 Tensor Core 异步执行，支持 2-4 倍更长序列，实际计算速度提升 2-4 倍。",{"type":186,"tag":202,"props":208,"children":209},{},[210,212,221,223,230,231],{"type":192,"value":211},"见：",{"type":186,"tag":213,"props":214,"children":218},"a",{"href":215,"rel":216},"https://github.com/Dao-AILab/flash-attention",[217],"nofollow",[219],{"type":192,"value":220},"Flash Attention GitHub",{"type":192,"value":222}," | ",{"type":186,"tag":213,"props":224,"children":227},{"href":225,"rel":226},"https://tridao.me/blog/2024/flash3/",[217],[228],{"type":192,"value":229},"Flash Attention-3 博客",{"type":192,"value":222},{"type":186,"tag":213,"props":232,"children":235},{"href":233,"rel":234},"https://arxiv.org/abs/2205.14135",[217],[236],{"type":192,"value":237},"Flash Attention 论文",{"type":186,"tag":195,"props":239,"children":241},{"id":240},"bitsandbytes8-bit4-bit-量化训练",[242],{"type":192,"value":243},"bitsandbytes：8-bit/4-bit 量化训练",{"type":186,"tag":202,"props":245,"children":246},{},[247],{"type":192,"value":248},"bitsandbytes 是 Hugging Face 生态的量化训练库，提供 8-bit AdamW、4-bit 量化训练等功能。与 PEFT 结合实现 QLoRA——4-bit 量化基础模型权重，冻结量化权重，训练 LoRA 适配器，训练时动态反量化，推理时保持量化。让 7B 模型能在消费级 GPU（如 RTX 3090）上微调。",{"type":186,"tag":202,"props":250,"children":251},{},[252,253,260,261],{"type":192,"value":211},{"type":186,"tag":213,"props":254,"children":257},{"href":255,"rel":256},"https://github.com/bitsandbytes-foundation/bitsandbytes",[217],[258],{"type":192,"value":259},"bitsandbytes GitHub",{"type":192,"value":222},{"type":186,"tag":213,"props":262,"children":265},{"href":263,"rel":264},"https://arxiv.org/abs/2305.14314",[217],[266],{"type":192,"value":267},"QLoRA 论文",{"type":186,"tag":195,"props":269,"children":271},{"id":270},"gptq训练后-int4-量化",[272],{"type":192,"value":273},"GPTQ：训练后 INT4 量化",{"type":186,"tag":202,"props":275,"children":276},{},[277],{"type":192,"value":278},"GPTQ 是训练后量化（PTQ）方法，通过逐层量化并补偿误差，将模型压缩至 INT4 精度。适合部署场景，无需重新训练。广泛应用于 llama.cpp、Ollama 等本地推理框架，可在单卡加载 2-3 倍大的模型。",{"type":186,"tag":202,"props":280,"children":281},{},[282,283,290,291],{"type":192,"value":211},{"type":186,"tag":213,"props":284,"children":287},{"href":285,"rel":286},"https://arxiv.org/abs/2210.17323",[217],[288],{"type":192,"value":289},"GPTQ 论文",{"type":192,"value":222},{"type":186,"tag":213,"props":292,"children":295},{"href":293,"rel":294},"https://www.newline.co/@zaoyang/gptq-vs-awq-quantization--d792476e",[217],[296],{"type":192,"value":297},"GPTQ vs AWQ 对比",{"type":186,"tag":195,"props":299,"children":301},{"id":300},"awq激活感知权重量化",[302],{"type":192,"value":303},"AWQ：激活感知权重量化",{"type":186,"tag":202,"props":305,"children":306},{},[307],{"type":192,"value":308},"AWQ（Activation-aware Weight Quantization）发现\"并非所有权重的贡献相同\"——保护对激活值影响大的权重通道，可以显著减少量化损失。相比 GPTQ，perplexity 损失更小，支持 INT4 乘加指令，吞吐提升 2-3 倍，与 TensorRT-LLM、vLLM 集成良好。",{"type":186,"tag":202,"props":310,"children":311},{},[312,313,320,321,328,329],{"type":192,"value":211},{"type":186,"tag":213,"props":314,"children":317},{"href":315,"rel":316},"https://arxiv.org/abs/2306.00978",[217],[318],{"type":192,"value":319},"AWQ 论文",{"type":192,"value":222},{"type":186,"tag":213,"props":322,"children":325},{"href":323,"rel":324},"https://github.com/mit-han-lab/llm-awq",[217],[326],{"type":192,"value":327},"AWQ GitHub",{"type":192,"value":222},{"type":186,"tag":213,"props":330,"children":333},{"href":331,"rel":332},"https://leimao.github.io/blog/AWQ-Activation-Aware-Weight-Quantization/",[217],[334],{"type":192,"value":335},"AWQ 深度解析",{"type":186,"tag":195,"props":337,"children":339},{"id":338},"ggufllamacpp-本地推理格式",[340],{"type":192,"value":341},"GGUF：llama.cpp 本地推理格式",{"type":186,"tag":202,"props":343,"children":344},{},[345],{"type":192,"value":346},"GGUF（GPT-Generated Unified Format）是 llama.cpp 项目的模型格式，专为本地 CPU/GPU 推理优化。支持多种量化方案：Q4_0（极致压缩）、Q4_K_M（平衡选择）、Q5_K_M（质量优先）、Q8_0（接近无损）。是 Ollama、LM Studio 等本地 LLM 工具的标准格式。",{"type":186,"tag":202,"props":348,"children":349},{},[350,351,358,359,366,367],{"type":192,"value":211},{"type":186,"tag":213,"props":352,"children":355},{"href":353,"rel":354},"https://github.com/ggerganov/ggml/blob/master/docs/gguf.md",[217],[356],{"type":192,"value":357},"GGUF 格式规范",{"type":192,"value":222},{"type":186,"tag":213,"props":360,"children":363},{"href":361,"rel":362},"https://kaitchup.substack.com/p/choosing-a-gguf-model-k-quants-i",[217],[364],{"type":192,"value":365},"GGUF 量化选择指南",{"type":192,"value":222},{"type":186,"tag":213,"props":368,"children":371},{"href":369,"rel":370},"https://arxiv.org/pdf/2601.14277",[217],[372],{"type":192,"value":373},"llama.cpp 量化论文",{"title":178,"searchDepth":375,"depth":375,"links":376},2,[377,378,379,380,381],{"id":197,"depth":375,"text":200},{"id":240,"depth":375,"text":243},{"id":270,"depth":375,"text":273},{"id":300,"depth":375,"text":303},{"id":338,"depth":375,"text":341},"markdown","content:6.maps:_ai:models:optimization.md","content","6.maps/_ai/models/optimization.md","6.maps/_ai/models/optimization","md",[389,393],{"_path":390,"title":391,"description":392},"/maps/_ai/models/multimodal","Multimodal Models","Vision, language, and multimodal AI systems",{"_path":394,"title":395,"description":396},"/maps/_ai/models/tokenization","Tokenization","Text tokenization and encoding",1772504959610]