odels","Vision, language, and multimodal AI systems","_ai/multimodal.md",{"type":183,"children":184,"toc":394},"root",[185,194,201,207,230,236,241,252,258,263,282,288,293,312,318,323,342,348,353,364,370,375],{"type":186,"tag":187,"props":188,"children":190},"element","h1",{"id":189},"多模态-multimodal",[191],{"type":192,"value":193},"text","多模态 (Multimodal)",{"type":186,"tag":195,"props":196,"children":198},"h2",{"id":197},"gpt-4o端到端多模态标杆",[199],{"type":192,"value":200},"GPT-4o：端到端多模态标杆",{"type":186,"tag":202,"props":203,"children":204},"p",{},[205],{"type":192,"value":206},"GPT-4o 是 OpenAI 的端到端多模态模型，\"o\"代表 Omni（全能）。不同于传统的拼接式架构，它在单一神经网络中统一处理文本、图像、音频，实现真正的跨模态理解和生成。在视觉理解、数学推理、语言理解等基准上全面领先，是 2025 年商业多模态模型的事实标准。",{"type":186,"tag":202,"props":208,"children":209},{},[210,212,221,223],{"type":192,"value":211},"见：",{"type":186,"tag":213,"props":214,"children":218},"a",{"href":215,"rel":216},"https://openai.com/index/hello-gpt-4o/",[217],"nofollow",[219],{"type":192,"value":220},"GPT-4o 技术报告",{"type":192,"value":222}," | ",{"type":186,"tag":213,"props":224,"children":227},{"href":225,"rel":226},"https://www.linkedin.com/pulse/gpt-4o-vs-google-gemini-ultimate-ai-showdown-2025-gary-fowler-octpe",[217],[228],{"type":192,"value":229},"GPT-4o vs Gemini 对比",{"type":186,"tag":195,"props":231,"children":233},{"id":232},"gemini-15-pro长上下文多模态王者",[234],{"type":192,"value":235},"Gemini 1.5 Pro：长上下文多模态王者",{"type":186,"tag":202,"props":237,"children":238},{},[239],{"type":192,"value":240},"Google DeepMind 的 Gemini 1.5 Pro 支持百万级 Token 上下文，可一次性处理数小时视频、整本书籍或多张高分辨率图像。采用 Mixture-of-Experts (MoE) 架构，在多模态推理和长文档理解上表现优异，是企业级多模态应用的首选。",{"type":186,"tag":202,"props":242,"children":243},{},[244,245],{"type":192,"value":211},{"type":186,"tag":213,"props":246,"children":249},{"href":247,"rel":248},"https://deepmind.google/technologies/gemini/pro/",[217],[250],{"type":192,"value":251},"Gemini 1.5 Pro 技术报告",{"type":186,"tag":195,"props":253,"children":255},{"id":254},"qwen25-vl开源视觉语言模型领先者",[256],{"type":192,"value":257},"Qwen2.5-VL：开源视觉语言模型领先者",{"type":186,"tag":202,"props":259,"children":260},{},[261],{"type":192,"value":262},"阿里云的 Qwen2.5-VL 系列是开源视觉语言模型的标杆，覆盖 3B 到 72B 参数规模。支持图像、视频、文档理解，在 OCR、图表解析、视觉推理等任务上媲美商业模型。2025 年推出的 Qwen3-VL 进一步提升了多模态推理能力，是开源社区的首选方案。",{"type":186,"tag":202,"props":264,"children":265},{},[266,267,274,275],{"type":192,"value":211},{"type":186,"tag":213,"props":268,"children":271},{"href":269,"rel":270},"https://github.com/QwenLM/Qwen2.5-VL",[217],[272],{"type":192,"value":273},"Qwen2.5-VL GitHub",{"type":192,"value":222},{"type":186,"tag":213,"props":276,"children":279},{"href":277,"rel":278},"https://www.bentoml.com/blog/multimodal-ai-a-guide-to-open-source-vision-language-models",[217],[280],{"type":192,"value":281},"Qwen3-VL 介绍",{"type":186,"tag":195,"props":283,"children":285},{"id":284},"llava-next学术界的开源先锋",[286],{"type":192,"value":287},"LLaVA-NeXT：学术界的开源先锋",{"type":186,"tag":202,"props":289,"children":290},{},[291],{"type":192,"value":292},"LLaVA（Large Language and Vision Assistant）将 CLIP 视觉编码器与 LLM 连接，开创了开源视觉问答的先河。LLaVA-NeXT 支持更高分辨率（336x336+）、多帧视频理解、LoRA 微调。2025 年的 LLaVA-OneVision 进一步优化了视频理解能力，是学术研究和快速原型开发的首选。",{"type":186,"tag":202,"props":294,"children":295},{},[296,297,304,305],{"type":192,"value":211},{"type":186,"tag":213,"props":298,"children":301},{"href":299,"rel":300},"https://github.com/LLaVA-VL/LLaVA-NeXT",[217],[302],{"type":192,"value":303},"LLaVA-NeXT GitHub",{"type":192,"value":222},{"type":186,"tag":213,"props":306,"children":309},{"href":307,"rel":308},"https://arxiv.org/html/2509.23661v3",[217],[310],{"type":192,"value":311},"LLaVA-OneVision 论文",{"type":186,"tag":195,"props":313,"children":315},{"id":314},"生成模型stable-diffusion-与-audiocraft",[316],{"type":192,"value":317},"生成模型：Stable Diffusion 与 AudioCraft",{"type":186,"tag":202,"props":319,"children":320},{},[321],{"type":192,"value":322},"Stable Diffusion 3 是开源文本到图像生成的标杆，采用改进的 Diffusion 架构，支持 ControlNet 可控生成和 LoRA 快速定制。AudioCraft 是 Meta 的音频生成套件，包含 MusicGen（文本生成音乐）、AudioGen（文本生成音效）和 EnCodec（神经音频编解码），开源了完整的音频生成流程。",{"type":186,"tag":202,"props":324,"children":325},{},[326,327,334,335],{"type":192,"value":211},{"type":186,"tag":213,"props":328,"children":331},{"href":329,"rel":330},"https://stability.ai/",[217],[332],{"type":192,"value":333},"Stable Diffusion",{"type":192,"value":222},{"type":186,"tag":213,"props":336,"children":339},{"href":337,"rel":338},"https://github.com/facebookresearch/audiocraft",[217],[340],{"type":192,"value":341},"AudioCraft GitHub",{"type":186,"tag":195,"props":343,"children":345},{"id":344},"语音识别whisper",[346],{"type":192,"value":347},"语音识别：Whisper",{"type":186,"tag":202,"props":349,"children":350},{},[351],{"type":192,"value":352},"OpenAI 的 Whisper 是开源语音识别的标杆，支持 99 种语言的多语言语音识别和语音翻译。鲁棒性优异，能处理口音、背景噪音和技术术语。v3 版本进一步提升了多语言性能和推理速度，是语音应用的基础设施。",{"type":186,"tag":202,"props":354,"children":355},{},[356,357],{"type":192,"value":211},{"type":186,"tag":213,"props":358,"children":361},{"href":359,"rel":360},"https://github.com/openai/whisper",[217],[362],{"type":192,"value":363},"Whisper GitHub",{"type":186,"tag":195,"props":365,"children":367},{"id":366},"多模态-rag-与-agent",[368],{"type":192,"value":369},"多模态 RAG 与 Agent",{"type":186,"tag":202,"props":371,"children":372},{},[373],{"type":192,"value":374},"多模态与 RAG、Agent 结合是 2025 年的前沿方向。CLIP 和向量数据库实现图像语义检索，Qwen2.5-VL 和 GPT-4o 实现视觉感知 Agent，可处理 UI 自动化、文档分析、视频监控等复杂任务。",{"type":186,"tag":202,"props":376,"children":377},{},[378,379,386,387],{"type":192,"value":211},{"type":186,"tag":213,"props":380,"children":383},{"href":381,"rel":382},"https://arxiv.org/html/2507.01925v1",[217],[384],{"type":192,"value":385},"Vision-Language-Action Models 综述",{"type":192,"value":222},{"type":186,"tag":213,"props":388,"children":391},{"href":389,"rel":390},"https://blog.csdn.net/qq_51175703/article/details/148561284",[217],[392],{"type":192,"value":393},"多模态学习路线",{"title":178,"searchDepth":395,"depth":395,"links":396},2,[397,398,399,400,401,402,403],{"id":197,"depth":395,"text":200},{"id":232,"depth":395,"text":235},{"id":254,"depth":395,"text":257},{"id":284,"depth":395,"text":287},{"id":314,"depth":395,"text":317},{"id":344,"depth":395,"text":347},{"id":366,"depth":395,"text":369},"markdown","content:6.maps:_ai:models:multimodal.md","content","6.maps/_ai/models/multimodal.md","6.maps/_ai/models/multimodal","md",[411,415],{"_path":412,"title":413,"description":414},"/maps/_ai/models/models","AI Models","Model internals, inference, optimization, and interpretability",{"_path":416,"title":417,"description":418},"/maps/_ai/models/optimization","Optimization","Model optimization techniques",1772185504761]