el inference and serving techniques","_ai/inference.md",{"type":183,"children":184,"toc":528},"root",[185,194,201,207,238,244,249,276,282,287,306,312,317,328,334,339,345,350,386,405,411,416,421,439,445,450,483,488,499,504,509],{"type":186,"tag":187,"props":188,"children":190},"element","h1",{"id":189},"推理-inference",[191],{"type":192,"value":193},"text","推理 (Inference)",{"type":186,"tag":195,"props":196,"children":198},"h2",{"id":197},"vllmpagedattention-高吞吐服务框架",[199],{"type":192,"value":200},"vLLM：PagedAttention 高吞吐服务框架",{"type":186,"tag":202,"props":203,"children":204},"p",{},[205],{"type":192,"value":206},"vLLM 由伯克利 Sky Computing Lab 开发，核心贡献是 PagedAttention 技术。借鉴操作系统的虚拟内存分页机制，将 KV Cache 分块管理，实现近 100% 的内存利用率（传统实现仅 20-40%）。支持 Continuous Batching（动态批处理）和流水线并行，吞吐提升 2-4 倍，是开源 LLM 服务的事实标准，全球超过 40 万 GPU 部署。",{"type":186,"tag":202,"props":208,"children":209},{},[210,212,221,223,230,231],{"type":192,"value":211},"见：",{"type":186,"tag":213,"props":214,"children":218},"a",{"href":215,"rel":216},"https://github.com/vllm-project/vllm",[217],"nofollow",[219],{"type":192,"value":220},"vLLM GitHub",{"type":192,"value":222}," | ",{"type":186,"tag":213,"props":224,"children":227},{"href":225,"rel":226},"https://dl.acm.org/doi/10.1145/3600006.3613165",[217],[228],{"type":192,"value":229},"PagedAttention 论文",{"type":192,"value":222},{"type":186,"tag":213,"props":232,"children":235},{"href":233,"rel":234},"https://github.com/vllm-project/vllm/issues/20336",[217],[236],{"type":192,"value":237},"vLLM 1.0 路线图",{"type":186,"tag":195,"props":239,"children":241},{"id":240},"sglang结构化生成语言运行时",[242],{"type":192,"value":243},"SGLang：结构化生成语言运行时",{"type":186,"tag":202,"props":245,"children":246},{},[247],{"type":192,"value":248},"SGLang 是伯克利推出的新一代推理框架，特色是结构化生成语言——用编程方式定义 LLM 调用流程，自动批处理多个请求。核心创新 RadixAttention 跨多个 LLM 生成调用自动高效重用 KV 缓存。社区测试显示在某些场景下吞吐比 vLLM 高 50-150%，特别是在多轮对话和结构化输出场景。xAI 生产环境部署超过 10 万 GPU。",{"type":186,"tag":202,"props":250,"children":251},{},[252,253,260,261,268,269],{"type":192,"value":211},{"type":186,"tag":213,"props":254,"children":257},{"href":255,"rel":256},"https://github.com/sgl-project/sglang",[217],[258],{"type":192,"value":259},"SGLang GitHub",{"type":192,"value":222},{"type":186,"tag":213,"props":262,"children":265},{"href":263,"rel":264},"https://arxiv.org/abs/2312.07104",[217],[266],{"type":192,"value":267},"SGLang 论文",{"type":192,"value":222},{"type":186,"tag":213,"props":270,"children":273},{"href":271,"rel":272},"https://lmsys.org/blog/2024-01-17-sglang/",[217],[274],{"type":192,"value":275},"RadixAttention 介绍",{"type":186,"tag":195,"props":277,"children":279},{"id":278},"llamacpp本地-cpugpu-推理引擎",[280],{"type":192,"value":281},"llama.cpp：本地 CPU/GPU 推理引擎",{"type":186,"tag":202,"props":283,"children":284},{},[285],{"type":192,"value":286},"llama.cpp 是纯 C++ 实现的推理引擎，目标是让 LLM 能在消费级硬件上运行。支持 ARM NEON、AVX 指令集优化，GGUF 格式量化（Q4 到 Q8），跨平台（Windows、macOS、Linux、iOS、Android），无依赖单二进制文件即可运行。是本地开发测试、边缘设备部署、隐私敏感应用的首选方案。",{"type":186,"tag":202,"props":288,"children":289},{},[290,291,298,299],{"type":192,"value":211},{"type":186,"tag":213,"props":292,"children":295},{"href":293,"rel":294},"https://github.com/ggml-org/llama.cpp",[217],[296],{"type":192,"value":297},"llama.cpp GitHub",{"type":192,"value":222},{"type":186,"tag":213,"props":300,"children":303},{"href":301,"rel":302},"https://medium.com/@nikheelvs/running-llms-on-edge-devices-a-step-by-step-guide-8cf1b3d74193",[217],[304],{"type":192,"value":305},"llama.cpp 边缘部署",{"type":186,"tag":195,"props":307,"children":309},{"id":308},"tensorrt-llmnvidia-推理优化库",[310],{"type":192,"value":311},"TensorRT-LLM：NVIDIA 推理优化库",{"type":186,"tag":202,"props":313,"children":314},{},[315],{"type":192,"value":316},"TensorRT-LLM 是 NVIDIA 的闭源推理优化方案，针对自家 GPU 深度优化：Kernel 融合减少显存带宽瓶颈，FP8 支持 Hopper GPU 原生低精度推理，In-flight Batching 更激进的批处理策略。在 NVIDIA GPU 上吞吐最高，但仅支持 NVIDIA 且配置复杂，适合追求极致性能且有工程投入能力的场景。",{"type":186,"tag":202,"props":318,"children":319},{},[320,321],{"type":192,"value":211},{"type":186,"tag":213,"props":322,"children":325},{"href":323,"rel":324},"https://developer.nvidia.com/tensorrt-llm",[217],[326],{"type":192,"value":327},"TensorRT-LLM 文档",{"type":186,"tag":195,"props":329,"children":331},{"id":330},"商业推理优化案例codex-spark-的实时协作优化",[332],{"type":192,"value":333},"商业推理优化案例：Codex-Spark 的实时协作优化",{"type":186,"tag":202,"props":335,"children":336},{},[337],{"type":192,"value":338},"OpenAI 在 GPT-5.3-Codex-Spark 中展示了面向实时协作场景的推理优化实践。该模型专为低延迟编程任务设计，生成速度超过 1200 tokens/秒。",{"type":186,"tag":340,"props":341,"children":343},"h4",{"id":342},"端到端延迟优化的维度",[344],{"type":192,"value":342},{"type":186,"tag":202,"props":346,"children":347},{},[348],{"type":192,"value":349},"对于实时协作场景，模型推理速度只是核心要素之一，还需要优化整个请求-响应链路的延迟。OpenAI 通过以下工程改进实现显著延迟降低：",{"type":186,"tag":351,"props":352,"children":353},"ul",{},[354,366,376],{"type":186,"tag":355,"props":356,"children":357},"li",{},[358,364],{"type":186,"tag":359,"props":360,"children":361},"strong",{},[362],{"type":192,"value":363},"WebSocket 持久连接",{"type":192,"value":365},"：替代传统 HTTP 请求，客户端与服务器往返开销降低 80%",{"type":186,"tag":355,"props":367,"children":368},{},[369,374],{"type":186,"tag":359,"props":370,"children":371},{},[372],{"type":192,"value":373},"推理栈重写",{"type":192,"value":375},"：精简流式传输逻辑，单 token 传输开销降低 30%",{"type":186,"tag":355,"props":377,"children":378},{},[379,384],{"type":186,"tag":359,"props":380,"children":381},{},[382],{"type":192,"value":383},"会话初始化重构",{"type":192,"value":385},"：优化首字延迟（Time-to-first-token），缩短 50%",{"type":186,"tag":202,"props":387,"children":388},{},[389,390,397,398],{"type":192,"value":211},{"type":186,"tag":213,"props":391,"children":394},{"href":392,"rel":393},"https://openai.com/zh-Hans-CN/index/introducing-gpt-5-3-codex-spark/",[217],[395],{"type":192,"value":396},"OpenAI 官方发布",{"type":192,"value":222},{"type":186,"tag":213,"props":399,"children":402},{"href":400,"rel":401},"https://www.landiannews.com/archives/111836.html",[217],[403],{"type":192,"value":404},"蓝点网报道",{"type":186,"tag":340,"props":406,"children":408},{"id":407},"专用-ai-加速器在超低延迟场景的应用",[409],{"type":192,"value":410},"专用 AI 加速器在超低延迟场景的应用",{"type":186,"tag":202,"props":412,"children":413},{},[414],{"type":192,"value":415},"GPT-5.3-Codex-Spark 运行在 Cerebras WSE-3（Wafer Scale Engine 3）晶圆级引擎上。与 GPU 集群相比，Cerebras 通过将所有计算资源集成在单个晶圆级处理器上，针对\"延迟优先\"工作流优化。这种架构选择使模型能够达到超过 1000 tokens/秒的生成速度，适合需要即时反馈的实时协作场景。",{"type":186,"tag":202,"props":417,"children":418},{},[419],{"type":192,"value":420},"值得注意的是，GPU 仍是 OpenAI 训练与推理管线的主力，Cerebras 作为补充方案，在极致低延迟场景提供差异化能力。",{"type":186,"tag":202,"props":422,"children":423},{},[424,425,432,433],{"type":192,"value":211},{"type":186,"tag":213,"props":426,"children":429},{"href":427,"rel":428},"https://ai-bio.cn/gpt-5-3-codex-spark/",[217],[430],{"type":192,"value":431},"AI-Bio 技术解析",{"type":192,"value":222},{"type":186,"tag":213,"props":434,"children":436},{"href":392,"rel":435},[217],[437],{"type":192,"value":438},"OpenAI 官方说明",{"type":186,"tag":340,"props":440,"children":442},{"id":441},"实时协作-llm-的设计权衡",[443],{"type":192,"value":444},"实时协作 LLM 的设计权衡",{"type":186,"tag":202,"props":446,"children":447},{},[448],{"type":192,"value":449},"Codex-Spark 采用轻量级工作风格以换取极致的交互流畅性：",{"type":186,"tag":351,"props":451,"children":452},{},[453,463,473],{"type":186,"tag":355,"props":454,"children":455},{},[456,461],{"type":186,"tag":359,"props":457,"children":458},{},[459],{"type":192,"value":460},"最小化编辑策略",{"type":192,"value":462},"：默认只做精准局部修改，不自动运行测试",{"type":186,"tag":355,"props":464,"children":465},{},[466,471],{"type":186,"tag":359,"props":467,"children":468},{},[469],{"type":192,"value":470},"减少自主性换取速度",{"type":192,"value":472},"：除非用户明确要求，否则不主动扩展任务范围",{"type":186,"tag":355,"props":474,"children":475},{},[476,481],{"type":186,"tag":359,"props":477,"children":478},{},[479],{"type":192,"value":480},"128K 上下文窗口",{"type":192,"value":482},"：保持足够长的代码上下文理解能力",{"type":186,"tag":202,"props":484,"children":485},{},[486],{"type":192,"value":487},"后续优化更新中，该模型速度进一步提升约 30%，达到每秒 1200+ tokens（@thsottiaux）。",{"type":186,"tag":202,"props":489,"children":490},{},[491,492],{"type":192,"value":211},{"type":186,"tag":213,"props":493,"children":496},{"href":494,"rel":495},"https://x.com/thsottiaux/status/2024947946849186064",[217],[497],{"type":192,"value":498},"Twitter 更新",{"type":186,"tag":195,"props":500,"children":502},{"id":501},"推理框架选择指南",[503],{"type":192,"value":501},{"type":186,"tag":202,"props":505,"children":506},{},[507],{"type":192,"value":508},"vLLM 是通用在线服务的首选，易用性高且吞吐优秀；TensorRT-LLM 适合极致性能需求但仅支持 NVIDIA；llama.cpp 是本地/边缘部署的标准，跨平台且轻量；SGLang 在结构化生成和多轮对话场景表现突出。选择应权衡延迟、吞吐、易用性、硬件限制和具体应用场景。",{"type":186,"tag":202,"props":510,"children":511},{},[512,513,520,521],{"type":192,"value":211},{"type":186,"tag":213,"props":514,"children":517},{"href":515,"rel":516},"https://www.arxiv.org/pdf/2505.01658v1",[217],[518],{"type":192,"value":519},"LLM 推理框架综述",{"type":192,"value":222},{"type":186,"tag":213,"props":522,"children":525},{"href":523,"rel":524},"https://tensorfuse.io/blog/llm-throughput-vllm-vs-sglang",[217],[526],{"type":192,"value":527},"vLLM vs SGLang 对比",{"title":178,"searchDepth":529,"depth":529,"links":530},2,[531,532,533,534,535,536],{"id":197,"depth":529,"text":200},{"id":240,"depth":529,"text":243},{"id":278,"depth":529,"text":281},{"id":308,"depth":529,"text":311},{"id":330,"depth":529,"text":333},{"id":501,"depth":529,"text":501},"markdown","content:6.maps:_ai:models:inference.md","content","6.maps/_ai/models/inference.md","6.maps/_ai/models/inference","md",[544,548],{"_path":545,"title":546,"description":547},"/maps/_ai/mcp/native-api-to-mcp","反对「直接把内部 API 暴露成 MCP」的天真做法","原文反对将现有内部 API 直接转换为 MCP，建议为代理场景专门设计安全的 MCP 服务层",{"_path":549,"title":550,"description":551},"/maps/_ai/models/mechanistic-interpretability","Mechanistic Interpretability","Understanding model internals and interpretability methods",1772185504812]