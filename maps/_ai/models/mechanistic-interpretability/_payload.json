interpretability","models",false,true,"","Mechanistic Interpretability","Understanding model internals and interpretability methods","_ai/mechanistic-interpretability.md",{"type":183,"children":184,"toc":374},"root",[185,194,201,207,238,244,249,276,282,287,314,320,325,344,350,355],{"type":186,"tag":187,"props":188,"children":190},"element","h1",{"id":189},"机制可解释性-mechanistic-interpretability",[191],{"type":192,"value":193},"text","机制可解释性 (Mechanistic Interpretability)",{"type":186,"tag":195,"props":196,"children":198},"h2",{"id":197},"transformerlens逆向工程-gpt-风格模型的标准工具",[199],{"type":192,"value":200},"TransformerLens：逆向工程 GPT 风格模型的标准工具",{"type":186,"tag":202,"props":203,"children":204},"p",{},[205],{"type":192,"value":206},"TransformerLens 由 Neel Nanda 开发，是机制可解释性领域的事实标准工具。它提供对 GPT 风格语言模型内部的深度访问能力，包括激活缓存、注意力模式分析、因果追踪和激活修补（Activation Patching）。使用它可以重现经典研究：归纳头（Induction Heads）负责 few-shot 学习的注意力回路、间接对象识别（IOI）解析代词指代消解的电路、以及定位执行简单数学运算的子网络。",{"type":186,"tag":202,"props":208,"children":209},{},[210,212,221,223,230,231],{"type":192,"value":211},"见：",{"type":186,"tag":213,"props":214,"children":218},"a",{"href":215,"rel":216},"https://github.com/TransformerLensOrg/TransformerLens",[217],"nofollow",[219],{"type":192,"value":220},"TransformerLens GitHub",{"type":192,"value":222}," | ",{"type":186,"tag":213,"props":224,"children":227},{"href":225,"rel":226},"https://neelnanda-io.github.io/TransformerLens/",[217],[228],{"type":192,"value":229},"TransformerLens 教程",{"type":192,"value":222},{"type":186,"tag":213,"props":232,"children":235},{"href":233,"rel":234},"https://arxiv.org/html/2404.15255v1",[217],[236],{"type":192,"value":237},"Activation Patching 论文",{"type":186,"tag":195,"props":239,"children":241},{"id":240},"稀疏自动编码器将神经元分解为可解释特征",[242],{"type":192,"value":243},"稀疏自动编码器：将神经元分解为可解释特征",{"type":186,"tag":202,"props":245,"children":246},{},[247],{"type":192,"value":248},"稀疏自动编码器（SAE）是当前可解释性研究的热点方向。它将高维激活向量分解为稀疏的、可解释的\"特征\"基向量，这些特征往往对应人类可理解的概念：数字、颜色、语法结构、甚至抽象的情感概念。Anthropic 在 Claude 3 Sonnet 上的研究发现，约 70% 的 SAE 特征可被人类解释，实现了从\"多义神经元\"到\"单语义特征\"的突破。",{"type":186,"tag":202,"props":250,"children":251},{},[252,253,260,261,268,269],{"type":192,"value":211},{"type":186,"tag":213,"props":254,"children":257},{"href":255,"rel":256},"https://transformer-circuits.pub/2024/scaling-monosemanticity/",[217],[258],{"type":192,"value":259},"Anthropic SAE 研究",{"type":192,"value":222},{"type":186,"tag":213,"props":262,"children":265},{"href":263,"rel":264},"https://nickjiang.substack.com/p/a-primer-on-sparse-autoencoders",[217],[266],{"type":192,"value":267},"SAE 入门指南",{"type":192,"value":222},{"type":186,"tag":213,"props":270,"children":273},{"href":271,"rel":272},"https://github.com/jbloomAus/SAELens",[217],[274],{"type":192,"value":275},"SAELens GitHub",{"type":186,"tag":195,"props":277,"children":279},{"id":278},"nnsight-与-ndif远程可解释性实验基础设施",[280],{"type":192,"value":281},"nnsight 与 NDIF：远程可解释性实验基础设施",{"type":186,"tag":202,"props":283,"children":284},{},[285],{"type":192,"value":286},"传统可解释性工具受限于单机 GPU 显存，难以分析 70B+ 参数模型。nnsight 通过远程执行架构解决了这个问题——本地编写干预逻辑，远程在大型 GPU 集群执行，只返回分析结果。National Deep Inference Facility (NDIF) 为研究者提供免费的远程可解释性计算资源，让任何研究者都能分析 Llama-2-70B 级别的模型。",{"type":186,"tag":202,"props":288,"children":289},{},[290,291,298,299,306,307],{"type":192,"value":211},{"type":186,"tag":213,"props":292,"children":295},{"href":293,"rel":294},"https://nnsight.net/",[217],[296],{"type":192,"value":297},"nnsight 文档",{"type":192,"value":222},{"type":186,"tag":213,"props":300,"children":303},{"href":301,"rel":302},"https://github.com/ndif-team/nnsight",[217],[304],{"type":192,"value":305},"nnsight GitHub",{"type":192,"value":222},{"type":186,"tag":213,"props":308,"children":311},{"href":309,"rel":310},"https://ndif.us/",[217],[312],{"type":192,"value":313},"NDIF 官网",{"type":186,"tag":195,"props":315,"children":317},{"id":316},"归纳头few-shot-学习的注意力回路",[318],{"type":192,"value":319},"归纳头：Few-shot 学习的注意力回路",{"type":186,"tag":202,"props":321,"children":322},{},[323],{"type":192,"value":324},"归纳头是 Transformer 中一种特殊的注意力头模式，负责识别序列中的重复模式并进行 few-shot 学习。当一个 token 在序列中重复出现时，归纳头能够\"复制\"之前出现的模式，这是大模型上下文学习能力的重要机制。通过 TransformerLens 的激活修补技术，可以精确定位这些回路并研究其工作机制。",{"type":186,"tag":202,"props":326,"children":327},{},[328,329,336,337],{"type":192,"value":211},{"type":186,"tag":213,"props":330,"children":333},{"href":331,"rel":332},"https://aclanthology.org/2025.acl-long.442.pdf",[217],[334],{"type":192,"value":335},"Circuit Stability 论文",{"type":192,"value":222},{"type":186,"tag":213,"props":338,"children":341},{"href":339,"rel":340},"https://www.alignmentforum.org/posts/jP9KDyMkchuv6tHwm/how-to-become-a-mechanistic-interpretability-researcher",[217],[342],{"type":192,"value":343},"如何成为可解释性研究员",{"type":186,"tag":195,"props":345,"children":347},{"id":346},"表征工程主动修改模型内部行为",[348],{"type":192,"value":349},"表征工程：主动修改模型内部行为",{"type":186,"tag":202,"props":351,"children":352},{},[353],{"type":192,"value":354},"表征工程（Representation Engineering）是通过定位和修改模型内部表征来实现特定行为的技术。包括增强诚实性（检测并抑制模型幻觉）、提升有用性（增强指令遵循能力）、以及改善安全性（抑制有害输出）。这为 AI 对齐提供了一条不同于 RLHF 的技术路径——直接操作模型的内部表征而非仅仅调整输出分布。",{"type":186,"tag":202,"props":356,"children":357},{},[358,359,366,367],{"type":192,"value":211},{"type":186,"tag":213,"props":360,"children":363},{"href":361,"rel":362},"https://www.anthropic.com/research/transformer-circuits",[217],[364],{"type":192,"value":365},"Anthropic 可解释性研究",{"type":192,"value":222},{"type":186,"tag":213,"props":368,"children":371},{"href":369,"rel":370},"https://arena-chapter1-transformer-interp.streamlit.app/",[217],[372],{"type":192,"value":373},"ARENA 可解释性教程",{"title":178,"searchDepth":375,"depth":375,"links":376},2,[377,378,379,380,381],{"id":197,"depth":375,"text":200},{"id":240,"depth":375,"text":243},{"id":278,"depth":375,"text":281},{"id":316,"depth":375,"text":319},{"id":346,"depth":375,"text":349},"markdown","content:6.maps:_ai:models:mechanistic-interpretability.md","content","6.maps/_ai/models/mechanistic-interpretability.md","6.maps/_ai/models/mechanistic-interpretability","md",[389,393],{"_path":390,"title":391,"description":392},"/maps/_ai/models/inference","Inference","Model inference and serving techniques",{"_path":394,"title":395,"description":396},"/maps/_ai/models/models","AI Models","Model internals, inference, optimization, and interpretability",1772504959545]