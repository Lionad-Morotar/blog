zation","Text tokenization and encoding","_ai/tokenization.md",{"type":183,"children":184,"toc":348},"root",[185,194,201,207,230,236,241,260,266,271,282,288,293,304,310,315,326,332,337],{"type":186,"tag":187,"props":188,"children":190},"element","h1",{"id":189},"分词-tokenization",[191],{"type":192,"value":193},"text","分词 (Tokenization)",{"type":186,"tag":195,"props":196,"children":198},"h2",{"id":197},"huggingface-tokenizersrust-实现的高性能分词",[199],{"type":192,"value":200},"HuggingFace Tokenizers：Rust 实现的高性能分词",{"type":186,"tag":202,"props":203,"children":204},"p",{},[205],{"type":192,"value":206},"HuggingFace Tokenizers 基于 Rust 实现，提供 Python 绑定，在训练和推理速度上都显著优于纯 Python 实现。在 GB 级语料上训练 tokenizer，它比纯 Python 实现快 10-100 倍，内存占用更低。支持 BPE、Byte-Level BPE、WordPiece、Unigram 等主流算法，与 transformers 生态无缝集成。",{"type":186,"tag":202,"props":208,"children":209},{},[210,212,221,223],{"type":192,"value":211},"见：",{"type":186,"tag":213,"props":214,"children":218},"a",{"href":215,"rel":216},"https://github.com/huggingface/tokenizers",[217],"nofollow",[219],{"type":192,"value":220},"HuggingFace Tokenizers GitHub",{"type":192,"value":222}," | ",{"type":186,"tag":213,"props":224,"children":227},{"href":225,"rel":226},"https://huggingface.co/docs/tokenizers/index",[217],[228],{"type":192,"value":229},"Tokenizers 文档",{"type":186,"tag":195,"props":231,"children":233},{"id":232},"sentencepiece语言无关的无监督分词器",[234],{"type":192,"value":235},"SentencePiece：语言无关的无监督分词器",{"type":186,"tag":202,"props":237,"children":238},{},[239],{"type":192,"value":240},"SentencePiece 由 Google 开发，采用\"语言无关\"的设计理念——不依赖预定义的单词边界（如空格），直接从原始文本学习子词单元。这让它在处理中文、日文等没有空格分隔的语言时特别有效，无需预先分词。支持 BPE、Unigram、Char、Word 四种模式。",{"type":186,"tag":202,"props":242,"children":243},{},[244,245,252,253],{"type":192,"value":211},{"type":186,"tag":213,"props":246,"children":249},{"href":247,"rel":248},"https://github.com/google/sentencepiece",[217],[250],{"type":192,"value":251},"SentencePiece GitHub",{"type":192,"value":222},{"type":186,"tag":213,"props":254,"children":257},{"href":255,"rel":256},"https://aclanthology.org/D18-2012.pdf",[217],[258],{"type":192,"value":259},"SentencePiece 论文",{"type":186,"tag":195,"props":261,"children":263},{"id":262},"bpe从小到大的子词合并算法",[264],{"type":192,"value":265},"BPE：从小到大的子词合并算法",{"type":186,"tag":202,"props":267,"children":268},{},[269],{"type":192,"value":270},"BPE（Byte-Pair Encoding）是 GPT 系列使用的分词算法，从字符开始逐步合并高频子串。训练方向是\"从小到大\"，每次选择频率最高的字符对合并，直到达到目标词表大小。优点是简单高效，能很好地平衡词表大小和序列长度。",{"type":186,"tag":202,"props":272,"children":273},{},[274,275],{"type":192,"value":211},{"type":186,"tag":213,"props":276,"children":279},{"href":277,"rel":278},"https://zhuanlan.zhihu.com/p/716655053",[217],[280],{"type":192,"value":281},"BPE 分词算法详解",{"type":186,"tag":195,"props":283,"children":285},{"id":284},"wordpiece基于似然增益的分词策略",[286],{"type":192,"value":287},"WordPiece：基于似然增益的分词策略",{"type":186,"tag":202,"props":289,"children":290},{},[291],{"type":192,"value":292},"WordPiece 是 BERT 使用的分词算法，与 BPE 类似也是从小到大合并，但选择策略不同——不是选频率最高的对，而是选似然增益最大的对。训练目标是最大化训练数据的似然概率，在数学上更加严谨。",{"type":186,"tag":202,"props":294,"children":295},{},[296,297],{"type":192,"value":211},{"type":186,"tag":213,"props":298,"children":301},{"href":299,"rel":300},"https://huggingface.co/learn/llm-course/en/chapter6/6",[217],[302],{"type":192,"value":303},"WordPiece tokenization - Hugging Face",{"type":186,"tag":195,"props":305,"children":307},{"id":306},"byte-level-bpe从根本上消除-oov",[308],{"type":192,"value":309},"Byte-level BPE：从根本上消除 OOV",{"type":186,"tag":202,"props":311,"children":312},{},[313],{"type":192,"value":314},"GPT-2 引入的 Byte-level BPE 将词表基础单元从字符降为字节，任何 Unicode 字符都可表示为 1-4 个字节序列，从根本上消除了 OOV（未登录词）问题。代价是序列长度略有增加，但对于现代 Transformer 的长上下文能力而言，这是可接受的权衡。",{"type":186,"tag":202,"props":316,"children":317},{},[318,319],{"type":192,"value":211},{"type":186,"tag":213,"props":320,"children":323},{"href":321,"rel":322},"https://blog.csdn.net/u013172930/article/details/147045833",[217],[324],{"type":192,"value":325},"字节级 BPE 详解",{"type":186,"tag":195,"props":327,"children":329},{"id":328},"中文分词词表扩充是关键",[330],{"type":192,"value":331},"中文分词：词表扩充是关键",{"type":186,"tag":202,"props":333,"children":334},{},[335],{"type":192,"value":336},"LLaMA 原生 tokenizer 仅包含少量中文字符，导致一个汉字被切分成 2-3 个 token，显著降低编码效率。使用 SentencePiece 训练中文扩展词表是中文 LLM 开发的必要步骤。推荐词表大小：32K-50K 用于通用英语，100K+ 用于多语言，200K+ 用于文本+代码混合。",{"type":186,"tag":202,"props":338,"children":339},{},[340,341],{"type":192,"value":211},{"type":186,"tag":213,"props":342,"children":345},{"href":343,"rel":344},"https://zhuanlan.zhihu.com/p/630696264",[217],[346],{"type":192,"value":347},"大模型词表扩充必备工具",{"title":178,"searchDepth":349,"depth":349,"links":350},2,[351,352,353,354,355,356],{"id":197,"depth":349,"text":200},{"id":232,"depth":349,"text":235},{"id":262,"depth":349,"text":265},{"id":284,"depth":349,"text":287},{"id":306,"depth":349,"text":309},{"id":328,"depth":349,"text":331},"markdown","content:6.maps:_ai:models:tokenization.md","content","6.maps/_ai/models/tokenization.md","6.maps/_ai/models/tokenization","md",[364,368],{"_path":365,"title":366,"description":367},"/maps/_ai/models/optimization","Optimization","Model optimization techniques",{"_path":369,"title":370,"description":371},"/maps/_ai/operations/data-processing","Data Processing","AI 数据处理技术与最佳实践，包括 NeMo Curator、Ray Data、MinHash + LSH 等工具和方法。",1772504959619]