g":195,"props":274,"children":275},{},[276,287,297],{"type":186,"tag":199,"props":277,"children":278},{},[279],{"type":186,"tag":203,"props":280,"children":284},{"href":281,"rel":282},"https://zhuanlan.zhihu.com/p/1899948583878394136",[283],"nofollow",[285],{"type":192,"value":286},"《图解大模型》配套阅读——大模型面试题 200 问",{"type":186,"tag":199,"props":288,"children":289},{},[290],{"type":186,"tag":203,"props":291,"children":294},{"href":292,"rel":293},"https://github.com/naginoa/LLMs_interview_notes",[283],[295],{"type":192,"value":296},"About LLMs interview notes and answers",{"type":186,"tag":199,"props":298,"children":299},{},[300,307],{"type":186,"tag":203,"props":301,"children":304},{"href":302,"rel":303},"https://github.com/changyeyu/LLM-RL-Visualized",[283],[305],{"type":192,"value":306},"LLM/RL 可视化原理图",{"type":192,"value":308},": 《大模型算法》作者整理的 100+ 张原创架构图，涵盖 LLM 结构、SFT、DPO、RLHF、PPO、GRPO 等",{"type":186,"tag":268,"props":310,"children":312},{"id":311},"如何下载模型",[313],{"type":192,"value":314},"如何下载模型？",{"type":186,"tag":316,"props":317,"children":318},"p",{},[319],{"type":192,"value":320},"可以使用 python 的 huggingface-hub 包下载 huggingface 上的模型；国内用户可以使用镜像源 hf-mirror 加速下载。",{"type":186,"tag":268,"props":322,"children":324},{"id":323},"price",[325],{"type":192,"value":326},"Price",{"type":186,"tag":316,"props":328,"children":329},{},[330],{"type":192,"value":331},"常用的官方定价入口（随时可能更新，以官网为准）：",{"type":186,"tag":195,"props":333,"children":334},{},[335,345,355,365,375,385,395],{"type":186,"tag":199,"props":336,"children":337},{},[338],{"type":186,"tag":203,"props":339,"children":342},{"href":340,"rel":341},"https://platform.openai.com/docs/pricing",[283],[343],{"type":192,"value":344},"OpenAI API Pricing",{"type":186,"tag":199,"props":346,"children":347},{},[348],{"type":186,"tag":203,"props":349,"children":352},{"href":350,"rel":351},"https://platform.claude.com/docs/en/about-claude/pricing",[283],[353],{"type":192,"value":354},"Anthropic Claude API Pricing",{"type":186,"tag":199,"props":356,"children":357},{},[358],{"type":186,"tag":203,"props":359,"children":362},{"href":360,"rel":361},"https://ai.google.dev/gemini-api/docs/pricing",[283],[363],{"type":192,"value":364},"Gemini Developer API pricing",{"type":186,"tag":199,"props":366,"children":367},{},[368],{"type":186,"tag":203,"props":369,"children":372},{"href":370,"rel":371},"https://azure.microsoft.com/en-us/pricing/details/azure-openai/",[283],[373],{"type":192,"value":374},"Azure OpenAI Service - Pricing",{"type":186,"tag":199,"props":376,"children":377},{},[378],{"type":186,"tag":203,"props":379,"children":382},{"href":380,"rel":381},"https://aws.amazon.com/bedrock/pricing/",[283],[383],{"type":192,"value":384},"Amazon Bedrock Pricing",{"type":186,"tag":199,"props":386,"children":387},{},[388],{"type":186,"tag":203,"props":389,"children":392},{"href":390,"rel":391},"https://platform.openai.com/tokenizer",[283],[393],{"type":192,"value":394},"OpenAI Tokenizer（估算 token / 成本）",{"type":186,"tag":199,"props":396,"children":397},{},[398,405],{"type":186,"tag":203,"props":399,"children":402},{"href":400,"rel":401},"https://console.volcengine.com/ark/region:ark+cn-beijing/openManagement",[283],[403],{"type":192,"value":404},"火山引擎 Ark 控制台",{"type":192,"value":406},"：国内 LLM API 用量与订阅管理",{"type":186,"tag":268,"props":408,"children":410},{"id":409},"benchmark",[411],{"type":192,"value":244},{"type":186,"tag":195,"props":413,"children":414},{},[415,423],{"type":186,"tag":199,"props":416,"children":417},{},[418],{"type":186,"tag":203,"props":419,"children":420},{"href":241},[421],{"type":192,"value":422},"LLM Benchmark",{"type":186,"tag":199,"props":424,"children":425},{},[426],{"type":186,"tag":203,"props":427,"children":429},{"href":428},"/maps/_ai/benchmark/simple",[430],{"type":192,"value":431},"simple-benchmark",{"type":186,"tag":268,"props":433,"children":435},{"id":434},"prompt",[436],{"type":192,"value":437},"Prompt",{"type":186,"tag":195,"props":439,"children":440},{},[441,449,458],{"type":186,"tag":199,"props":442,"children":443},{},[444],{"type":186,"tag":203,"props":445,"children":447},{"href":446},"/maps/_ai/prompt/prompt",[448],{"type":192,"value":437},{"type":186,"tag":199,"props":450,"children":451},{},[452],{"type":186,"tag":203,"props":453,"children":455},{"href":454},"/maps/_ai/prompt/prompt-collections",[456],{"type":192,"value":457},"Prompt Collections",{"type":186,"tag":199,"props":459,"children":460},{},[461],{"type":186,"tag":203,"props":462,"children":464},{"href":463},"/maps/_ai/image/stable-diffusion",[465],{"type":192,"value":466},"Stable Diffusion Prompt",{"type":186,"tag":187,"props":468,"children":470},{"id":469},"核心概念",[471],{"type":192,"value":469},{"type":186,"tag":268,"props":473,"children":475},{"id":474},"llm-训练的三阶段流程",[476],{"type":192,"value":477},"LLM 训练的三阶段流程？",{"type":186,"tag":316,"props":479,"children":480},{},[481],{"type":186,"tag":482,"props":483,"children":484},"strong",{},[485],{"type":192,"value":486},"预训练（Pre-training）",{"type":186,"tag":316,"props":488,"children":489},{},[490],{"type":192,"value":491},"从互联网大规模获取知识，将海量文本压缩到神经网络参数中。使用 FineWeb 等数据集，通过\"预测下一个词\"的任务迫使模型学习世界知识。这是一个有损压缩过程——模型学到的是文本的\"格式塔\"而非精确复制。",{"type":186,"tag":316,"props":493,"children":494},{},[495],{"type":186,"tag":482,"props":496,"children":497},{},[498],{"type":192,"value":499},"监督微调（SFT）",{"type":186,"tag":316,"props":501,"children":502},{},[503],{"type":192,"value":504},"通过人工标注的指令-回复对，教模型如何以助手的方式回应。OpenAI 等公司雇佣数据标注员，编写理想的助手回复示例。这是模型\"个性\"形成的关键阶段——模型本质上是数据标注员的神经网络模拟。",{"type":186,"tag":316,"props":506,"children":507},{},[508],{"type":186,"tag":482,"props":509,"children":510},{},[511],{"type":192,"value":512},"强化学习（RL）",{"type":186,"tag":316,"props":514,"children":515},{},[516],{"type":192,"value":517},"思考型模型（如 o3-mini、o1）通过强化学习发现新的思考策略。在可验证领域（数学、代码）中练习时，模型可能发展出人类从未想过的解法，类似 AlphaGo 的\"第37手\"。这是模型超越单纯模仿、展现涌现能力的关键阶段。",{"type":186,"tag":316,"props":519,"children":520},{},[521,523],{"type":192,"value":522},"见：",{"type":186,"tag":203,"props":524,"children":527},{"href":525,"rel":526},"https://www.youtube.com/watch?v=bZQun8Y4L2A",[283],[528],{"type":192,"value":529},"State of GPT - Andrej Karpathy",{"type":186,"tag":268,"props":531,"children":533},{"id":532},"瑞士奶酪能力模型",[534],{"type":192,"value":535},"瑞士奶酪能力模型？",{"type":186,"tag":316,"props":537,"children":538},{},[539],{"type":192,"value":540},"LLM 的能力分布像瑞士奶酪一样有洞——某些方面表现惊艳（写作、翻译、知识问答），却会在出人意料的简单任务上失败（计数字母、比较小数大小、简单算术）。",{"type":186,"tag":316,"props":542,"children":543},{},[544],{"type":192,"value":545},"这种不均匀性源于：",{"type":186,"tag":195,"props":547,"children":548},{},[549,559,569],{"type":186,"tag":199,"props":550,"children":551},{},[552,557],{"type":186,"tag":482,"props":553,"children":554},{},[555],{"type":192,"value":556},"有限计算预算",{"type":192,"value":558},"：每次生成 token 只能进行固定量的计算",{"type":186,"tag":199,"props":560,"children":561},{},[562,567],{"type":186,"tag":482,"props":563,"children":564},{},[565],{"type":192,"value":566},"有损压缩",{"type":192,"value":568},"：模型学到的是统计模式而非精确规则",{"type":186,"tag":199,"props":570,"children":571},{},[572,577],{"type":186,"tag":482,"props":573,"children":574},{},[575],{"type":192,"value":576},"训练分布偏差",{"type":192,"value":578},"：互联网文本中某些技能被过度/不足代表",{"type":186,"tag":316,"props":580,"children":581},{},[582],{"type":192,"value":583},"这意味着不应盲目信任模型输出，尤其在需要精确性的场景。建议将 LLM 视为\"工具箱中的一员\"，用于灵感启发和初稿生成，但始终需要人工验证。",{"type":186,"tag":316,"props":585,"children":586},{},[587,588],{"type":192,"value":522},{"type":186,"tag":203,"props":589,"children":592},{"href":590,"rel":591},"https://www.youtube.com/watch?v=EWvNQjAaOHw",[283],[593],{"type":192,"value":594},"How I use LLM - Andrej Karpathy",{"type":186,"tag":187,"props":596,"children":598},{"id":597},"使用反思",[599],{"type":192,"value":597},{"type":186,"tag":268,"props":601,"children":603},{"id":602},"即时知识获取的浅薄化代价",[604],{"type":192,"value":605},"即时知识获取的\"浅薄化\"代价",{"type":186,"tag":316,"props":607,"children":608},{},[609],{"type":192,"value":610},"通过 LLM 获取知识消除了传统学习的\"摩擦\"——无需翻阅资料、无需追踪引用、无需建立知识间的连接。但这种便利带来了知识的\"零食化\"特质：从电池原理跳到汽车稳定杆再到加州公路，浅尝辄止，知识变得像社交媒体动态一样可丢弃。",{"type":186,"tag":316,"props":612,"children":613},{},[614],{"type":192,"value":615},"学习的努力本是深度理解的必要过程。与花数周研究安倍晋三遇刺案、通过维基百科和日文资料层层追踪的体验相比——尽管没有获得明确答案，但建立了远更丰富的理解。品格和专业知识来自\"寻找信息的 hunt\"，而非摘要。",{"type":186,"tag":316,"props":617,"children":618},{},[619],{"type":192,"value":620},"此外，一个根本性的使用困境是：你几乎无法发现幻觉，除非它涉及你已经掌握知识的领域。",{"type":186,"tag":316,"props":622,"children":623},{},[624,625],{"type":192,"value":522},{"type":186,"tag":203,"props":626,"children":629},{"href":627,"rel":628},"https://idiallo.com/blog/access-to-knowledge-is-no-longer-a-limitation",[283],[630],{"type":192,"value":631},"When access to knowledge is no longer the limitation",{"title":178,"searchDepth":633,"depth":633,"links":634},2,[635,636,637,638,639,640],{"id":189,"depth":633,"text":193},{"id":211,"depth":633,"text":214},{"id":247,"depth":633,"text":247},{"id":264,"depth":633,"text":264},{"id":469,"depth":633,"text":469},{"id":597,"depth":633,"text":597},"markdown","content:6.maps:_ai:llm:llm.md","content","6.maps/_ai/llm/llm.md","6.maps/_ai/llm/llm","md",[648,650],{"_path":205,"title":208,"description":649},"LLM Embeddings 的核心概念、演进历史与实践",{"_path":232,"title":651,"description":652},"LLM 作为评审者（LLM as a judge）","讨论用 LLM 自动评估生成式系统输出的现状、问题与建议",1772504939575]