,".forEach(x => x.remove()) -->",{"type":185,"tag":249,"props":889,"children":891},{"id":890},"benchmark",[892],{"type":191,"value":225},{"type":185,"tag":194,"props":894,"children":895},{},[896,904],{"type":185,"tag":198,"props":897,"children":898},{},[899],{"type":185,"tag":202,"props":900,"children":901},{"href":222},[902],{"type":191,"value":903},"LLM Benchmark",{"type":185,"tag":198,"props":905,"children":906},{},[907],{"type":185,"tag":202,"props":908,"children":910},{"href":909},"/maps/_ai/benchmark/simple",[911],{"type":191,"value":912},"simple-benchmark",{"type":185,"tag":249,"props":914,"children":916},{"id":915},"prompt",[917],{"type":191,"value":918},"Prompt",{"type":185,"tag":194,"props":920,"children":921},{},[922,930,939],{"type":185,"tag":198,"props":923,"children":924},{},[925],{"type":185,"tag":202,"props":926,"children":928},{"href":927},"/maps/_ai/prompt/prompt",[929],{"type":191,"value":918},{"type":185,"tag":198,"props":931,"children":932},{},[933],{"type":185,"tag":202,"props":934,"children":936},{"href":935},"/maps/_ai/prompt/prompt-collections",[937],{"type":191,"value":938},"Prompt Collections",{"type":185,"tag":198,"props":940,"children":941},{},[942],{"type":185,"tag":202,"props":943,"children":945},{"href":944},"/maps/_ai/image/stable-diffusion",[946],{"type":191,"value":947},"Stable Diffusion Prompt",{"type":185,"tag":186,"props":949,"children":951},{"id":950},"核心概念",[952],{"type":191,"value":950},{"type":185,"tag":249,"props":954,"children":956},{"id":955},"llm-训练的三阶段流程",[957],{"type":191,"value":958},"LLM 训练的三阶段流程？",{"type":185,"tag":285,"props":960,"children":961},{},[962],{"type":185,"tag":963,"props":964,"children":965},"strong",{},[966],{"type":191,"value":967},"预训练（Pre-training）",{"type":185,"tag":285,"props":969,"children":970},{},[971],{"type":191,"value":972},"从互联网大规模获取知识，将海量文本压缩到神经网络参数中。使用 FineWeb 等数据集，通过\"预测下一个词\"的任务迫使模型学习世界知识。这是一个有损压缩过程——模型学到的是文本的\"格式塔\"而非精确复制。",{"type":185,"tag":285,"props":974,"children":975},{},[976],{"type":185,"tag":963,"props":977,"children":978},{},[979],{"type":191,"value":980},"监督微调（SFT）",{"type":185,"tag":285,"props":982,"children":983},{},[984],{"type":191,"value":985},"通过人工标注的指令-回复对，教模型如何以助手的方式回应。OpenAI 等公司雇佣数据标注员，编写理想的助手回复示例。这是模型\"个性\"形成的关键阶段——模型本质上是数据标注员的神经网络模拟。",{"type":185,"tag":285,"props":987,"children":988},{},[989],{"type":185,"tag":963,"props":990,"children":991},{},[992],{"type":191,"value":993},"强化学习（RL）",{"type":185,"tag":285,"props":995,"children":996},{},[997],{"type":191,"value":998},"思考型模型（如 o3-mini、o1）通过强化学习发现新的思考策略。在可验证领域（数学、代码）中练习时，模型可能发展出人类从未想过的解法，类似 AlphaGo 的\"第37手\"。这是模型超越单纯模仿、展现涌现能力的关键阶段。",{"type":185,"tag":285,"props":1000,"children":1001},{},[1002,1003],{"type":191,"value":867},{"type":185,"tag":202,"props":1004,"children":1007},{"href":1005,"rel":1006},"https://www.youtube.com/watch?v=bZQun8Y4L2A",[264],[1008],{"type":191,"value":1009},"State of GPT - Andrej Karpathy",{"type":185,"tag":249,"props":1011,"children":1013},{"id":1012},"瑞士奶酪能力模型",[1014],{"type":191,"value":1015},"瑞士奶酪能力模型？",{"type":185,"tag":285,"props":1017,"children":1018},{},[1019],{"type":191,"value":1020},"LLM 的能力分布像瑞士奶酪一样有洞——某些方面表现惊艳（写作、翻译、知识问答），却会在出人意料的简单任务上失败（计数字母、比较小数大小、简单算术）。",{"type":185,"tag":285,"props":1022,"children":1023},{},[1024],{"type":191,"value":1025},"这种不均匀性源于：",{"type":185,"tag":194,"props":1027,"children":1028},{},[1029,1039,1049],{"type":185,"tag":198,"props":1030,"children":1031},{},[1032,1037],{"type":185,"tag":963,"props":1033,"children":1034},{},[1035],{"type":191,"value":1036},"有限计算预算",{"type":191,"value":1038},"：每次生成 token 只能进行固定量的计算",{"type":185,"tag":198,"props":1040,"children":1041},{},[1042,1047],{"type":185,"tag":963,"props":1043,"children":1044},{},[1045],{"type":191,"value":1046},"有损压缩",{"type":191,"value":1048},"：模型学到的是统计模式而非精确规则",{"type":185,"tag":198,"props":1050,"children":1051},{},[1052,1057],{"type":185,"tag":963,"props":1053,"children":1054},{},[1055],{"type":191,"value":1056},"训练分布偏差",{"type":191,"value":1058},"：互联网文本中某些技能被过度/不足代表",{"type":185,"tag":285,"props":1060,"children":1061},{},[1062],{"type":191,"value":1063},"这意味着不应盲目信任模型输出，尤其在需要精确性的场景。建议将 LLM 视为\"工具箱中的一员\"，用于灵感启发和初稿生成，但始终需要人工验证。",{"type":185,"tag":285,"props":1065,"children":1066},{},[1067,1068],{"type":191,"value":867},{"type":185,"tag":202,"props":1069,"children":1072},{"href":1070,"rel":1071},"https://www.youtube.com/watch?v=EWvNQjAaOHw",[264],[1073],{"type":191,"value":1074},"How I use LLM - Andrej Karpathy",{"title":178,"searchDepth":1076,"depth":1076,"links":1077},2,[1078,1079,1080,1081],{"id":188,"depth":1076,"text":192},{"id":228,"depth":1076,"text":228},{"id":245,"depth":1076,"text":245},{"id":950,"depth":1076,"text":950},"markdown","content:6.maps:_ai:llm:llm.md","content","6.maps/_ai/llm/llm.md","6.maps/_ai/llm/llm","md",[1089,1091],{"_path":239,"title":242,"description":1090},"为 LLM 与 Agent 工作流提供端到端追踪、监控与诊断，融入 Datadog APM 体系；对已用 Datadog 的团队较友好，但埋点与协同要求高。",{"_path":213,"title":1092,"description":1093},"LLM 作为评审者（LLM as a judge）","讨论用 LLM 自动评估生成式系统输出的现状、问题与建议.",1771690618891]