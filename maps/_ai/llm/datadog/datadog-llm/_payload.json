"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"body":181,"_type":586,"_id":587,"_source":588,"_file":589,"_stem":590,"_extension":591},"/maps/_ai/llm/datadog/datadog-llm","datadog",false,true,"","Datadog LLM Observability","为 LLM 与 Agent 工作流提供端到端追踪、监控与诊断，融入 Datadog APM 体系；对已用 Datadog 的团队较友好，但埋点与协同要求高。",{"type":182,"children":183,"toc":573},"root",[184,193,199,204,209,215,221,228,248,253,258,286,291,296,314,319,342,348,366,371,389,394,400,418,423,428,451,456,469,474,479,492,497,515,521,540,545,568],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"brief",[190],{"type":191,"value":192},"text","Brief",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"Datadog LLM Observability 为大语言模型与 Agent 型应用的工作流提供端到端的追踪、监控与诊断。它将每个提示、工具调用与中间步骤映射为 spans 与 traces；跟踪时延、Token 用量、错误与质量指标；并与 Datadog 更广泛的 APM 与可观测性套件集成。",{"type":185,"tag":194,"props":200,"children":201},{},[202],{"type":191,"value":203},"对于已在使用 Datadog、熟悉其成本结构的组织而言，只要工作负载能够被正确埋点，LLM 可观测性功能是获取 AI 工作负载可见性的直接路径。然而，LLM 埋点的配置与使用需要谨慎，且要求对工作负载及其实现有扎实理解。我们建议数据工程与运维团队在部署时密切协作。另参见我们关于避免“独立数据工程团队”的建议。",{"type":185,"tag":194,"props":205,"children":206},{},[207],{"type":191,"value":208},"来源：技术雷达",{"type":185,"tag":186,"props":210,"children":212},{"id":211},"details",[213],{"type":191,"value":214},"Details",{"type":185,"tag":216,"props":217,"children":219},"h3",{"id":218},"背景与现状",[220],{"type":191,"value":218},{"type":185,"tag":222,"props":223,"children":225},"h4",{"id":224},"为什么现在需要-llm-可观测性",[226],{"type":191,"value":227},"为什么现在需要 LLM 可观测性",{"type":185,"tag":229,"props":230,"children":231},"ul",{},[232,238,243],{"type":185,"tag":233,"props":234,"children":235},"li",{},[236],{"type":191,"value":237},"LLM 与 Agent 的执行链路多跳、多工具，错误与延迟来源分散，传统日志难以还原根因。",{"type":185,"tag":233,"props":239,"children":240},{},[241],{"type":191,"value":242},"业务开始关注“质量/成本/延迟”的三角平衡，需要可度量、可回溯的数据来支撑优化与治理。",{"type":185,"tag":233,"props":244,"children":245},{},[246],{"type":191,"value":247},"已采用 Datadog 的组织希望在既有 APM/指标/告警框架内统一治理 AI 工作负载。",{"type":185,"tag":216,"props":249,"children":251},{"id":250},"问题与风险",[252],{"type":191,"value":250},{"type":185,"tag":222,"props":254,"children":256},{"id":255},"典型痛点与结构性矛盾",[257],{"type":191,"value":255},{"type":185,"tag":229,"props":259,"children":260},{},[261,266,271,276,281],{"type":185,"tag":233,"props":262,"children":263},{},[264],{"type":191,"value":265},"黑盒链路：提示模板、模型版本、工具调用与外部依赖交织，缺乏统一 Trace 视角。",{"type":185,"tag":233,"props":267,"children":268},{},[269],{"type":191,"value":270},"成本不透明：高频调用与高基数标签可能放大观测成本与数据基建开销。",{"type":185,"tag":233,"props":272,"children":273},{},[274],{"type":191,"value":275},"质量不可证：离线评测与线上表现常不一致，缺少面向场景的线上质量度量。",{"type":185,"tag":233,"props":277,"children":278},{},[279],{"type":191,"value":280},"数据敏感性：提示/上下文可能含敏感信息，原样上报带来合规与泄露风险。",{"type":185,"tag":233,"props":282,"children":283},{},[284],{"type":191,"value":285},"变更不可控：Prompt/模型/工具变更缺乏版本化与灰度策略，出现“回不去”的质量回退。",{"type":185,"tag":216,"props":287,"children":289},{"id":288},"模式与原理",[290],{"type":191,"value":288},{"type":185,"tag":222,"props":292,"children":294},{"id":293},"端到端追踪的核心抽象",[295],{"type":191,"value":293},{"type":185,"tag":229,"props":297,"children":298},{},[299,304,309],{"type":185,"tag":233,"props":300,"children":301},{},[302],{"type":191,"value":303},"Trace 代表一次业务请求或 Agent 任务；Span 对应关键阶段：Prompt、Tool 调用、检索、Rerank、模型推理等。",{"type":185,"tag":233,"props":305,"children":306},{},[307],{"type":191,"value":308},"关键维度建议：model 与版本、prompt 模板哈希、调用角色（system/user/assistant）、工具名称、数据来源、采样率、租户/业务线、请求规模（tokens in/out）。",{"type":185,"tag":233,"props":310,"children":311},{},[312],{"type":191,"value":313},"关键事件：超时、重试、截断、Rate Limit、供应商错误码、Guardrail 触发、回退策略命中。",{"type":185,"tag":222,"props":315,"children":317},{"id":316},"指标与质量度量",[318],{"type":191,"value":316},{"type":185,"tag":229,"props":320,"children":321},{},[322,327,332,337],{"type":185,"tag":233,"props":323,"children":324},{},[325],{"type":191,"value":326},"性能：P50/P95/P99 时延；队列等待与推理时延拆分；工具调用成功率与尾部延迟。",{"type":185,"tag":233,"props":328,"children":329},{},[330],{"type":191,"value":331},"成本：输入/输出 Token、推理时长、供应商计费单位；按租户/场景聚合。",{"type":185,"tag":233,"props":333,"children":334},{},[335],{"type":191,"value":336},"质量：规则型指标（拒识率/敏感命中率/格式合规率）、业务型指标（任务成功率/人工复核通过率）、系统性指标（对话步数、回退率）。",{"type":185,"tag":233,"props":338,"children":339},{},[340],{"type":191,"value":341},"关联：将线上评审样本与 Trace 绑定，形成“问题案例可复现”的闭环。",{"type":185,"tag":222,"props":343,"children":345},{"id":344},"与-apm-的集成方式",[346],{"type":191,"value":347},"与 APM 的集成方式",{"type":185,"tag":229,"props":349,"children":350},{},[351,356,361],{"type":185,"tag":233,"props":352,"children":353},{},[354],{"type":191,"value":355},"传递 Trace/Span 上下文贯穿 Web/API → 编排层 → 工具/检索 → 模型调用。",{"type":185,"tag":233,"props":357,"children":358},{},[359],{"type":191,"value":360},"统一告警与 SLO：以业务成功率、P99 延迟、成本预算为主指标，结合异常分布与错误比率。",{"type":185,"tag":233,"props":362,"children":363},{},[364],{"type":191,"value":365},"看板与探索：按模型/版本、Prompt 哈希、工具类型、租户维度钻取，定位“谁最贵/最慢/最不稳定”。",{"type":185,"tag":222,"props":367,"children":369},{"id":368},"成本与数据治理",[370],{"type":191,"value":368},{"type":185,"tag":229,"props":372,"children":373},{},[374,379,384],{"type":185,"tag":233,"props":375,"children":376},{},[377],{"type":191,"value":378},"采样优先：对低风险流量进行采样，对错误/高延迟/高成本请求提升采样比。",{"type":185,"tag":233,"props":380,"children":381},{},[382],{"type":191,"value":383},"降基数：对长文本做哈希/指纹化，只保留可检索的摘要或模板标识。",{"type":185,"tag":233,"props":385,"children":386},{},[387],{"type":191,"value":388},"脱敏与最小化：敏感字段上报前脱敏/截断；仅在需要时捕获原文，并控制留存周期。",{"type":185,"tag":216,"props":390,"children":392},{"id":391},"对比与演进",[393],{"type":191,"value":391},{"type":185,"tag":222,"props":395,"children":397},{"id":396},"从日志拼接到apm-级-llm-可观测性",[398],{"type":191,"value":399},"从“日志拼接”到“APM 级 LLM 可观测性”",{"type":185,"tag":229,"props":401,"children":402},{},[403,408,413],{"type":185,"tag":233,"props":404,"children":405},{},[406],{"type":191,"value":407},"仅日志：低门槛但难以还原全链路，跨组件关联弱，难做 SLO。",{"type":185,"tag":233,"props":409,"children":410},{},[411],{"type":191,"value":412},"APM 集成：以 Trace 为主线，统一指标/日志/事件；能面向业务做聚合与告警。",{"type":185,"tag":233,"props":414,"children":415},{},[416],{"type":191,"value":417},"专用 LLMOps 平台：更强评测/对齐/数据管理能力，但与现有 APM 体系割裂。对已深度使用 Datadog 的团队，优先用 APM 集成形成“可运行的最小闭环”，再按需补齐评测与数据资产能力。",{"type":185,"tag":216,"props":419,"children":421},{"id":420},"系统性影响",[422],{"type":191,"value":420},{"type":185,"tag":222,"props":424,"children":426},{"id":425},"架构与工程效率",[427],{"type":191,"value":425},{"type":185,"tag":229,"props":429,"children":430},{},[431,436,441,446],{"type":185,"tag":233,"props":432,"children":433},{},[434],{"type":191,"value":435},"标准化编排：推动将 Prompt/检索/工具封装为可观测的“阶段组件”，提升可维护性与灰度能力。",{"type":185,"tag":233,"props":437,"children":438},{},[439],{"type":191,"value":440},"质量文化：从“感觉可用”转向“可度量与可回溯”，促进问题复盘与模板治理。",{"type":185,"tag":233,"props":442,"children":443},{},[444],{"type":191,"value":445},"技术栈治理：促使模型与 Prompt 版本化、灰度发布、回退策略纳入变更管理。",{"type":185,"tag":233,"props":447,"children":448},{},[449],{"type":191,"value":450},"安全与合规：引入统一脱敏策略、最小化上报原则与留存策略。",{"type":185,"tag":222,"props":452,"children":454},{"id":453},"组织协作",[455],{"type":191,"value":453},{"type":185,"tag":229,"props":457,"children":458},{},[459,464],{"type":185,"tag":233,"props":460,"children":461},{},[462],{"type":191,"value":463},"数据工程 × 运维 × 应用团队协作上云；避免“独立数据工程团队”形成割裂，优先嵌入式协同与平台化支持。",{"type":185,"tag":233,"props":465,"children":466},{},[467],{"type":191,"value":468},"角色分工：平台/运维定义可观测性标准与落地框架；应用团队按标准埋点；数据工程支持质量数据管线与评测闭环。",{"type":185,"tag":216,"props":470,"children":472},{"id":471},"落地建议",[473],{"type":191,"value":471},{"type":185,"tag":222,"props":475,"children":477},{"id":476},"适用与边界",[478],{"type":191,"value":476},{"type":185,"tag":229,"props":480,"children":481},{},[482,487],{"type":185,"tag":233,"props":483,"children":484},{},[485],{"type":191,"value":486},"更适用：已有 Datadog 基础、AI 流量稳定增长、对质量/成本有明确 SLO 的团队。",{"type":185,"tag":233,"props":488,"children":489},{},[490],{"type":191,"value":491},"谨慎或不适用：强合规场景无法脱敏上报；对成本极敏感但无法采样/降基数的业务。",{"type":185,"tag":222,"props":493,"children":495},{"id":494},"前置条件",[496],{"type":191,"value":494},{"type":185,"tag":229,"props":498,"children":499},{},[500,505,510],{"type":185,"tag":233,"props":501,"children":502},{},[503],{"type":191,"value":504},"基线规范：Trace 贯穿、必备标签（模型/版本/模板哈希/工具名/租户）、统一错误码与重试策略。",{"type":185,"tag":233,"props":506,"children":507},{},[508],{"type":191,"value":509},"数据安全：脱敏白名单、敏感字段识别与拦截、留存与访问控制。",{"type":185,"tag":233,"props":511,"children":512},{},[513],{"type":191,"value":514},"成本控制：采样策略、指标与日志配额、看板与预算告警。",{"type":185,"tag":222,"props":516,"children":518},{"id":517},"试点路径建议三步",[519],{"type":191,"value":520},"试点路径（建议三步）",{"type":185,"tag":522,"props":523,"children":524},"ol",{},[525,530,535],{"type":185,"tag":233,"props":526,"children":527},{},[528],{"type":191,"value":529},"最小闭环：选一个关键用例，打通端到端 Trace，接入时延/错误/Token 指标与基础告警。",{"type":185,"tag":233,"props":531,"children":532},{},[533],{"type":191,"value":534},"质量落地：接入规则型质量指标与人工复核样本回流，建立问题样本库与复盘机制。",{"type":185,"tag":233,"props":536,"children":537},{},[538],{"type":191,"value":539},"扩展与治理：推广到多场景，完善版本化/灰度/回退；引入成本看板与预算 SLO。",{"type":185,"tag":222,"props":541,"children":543},{"id":542},"常见风险与对策",[544],{"type":191,"value":542},{"type":185,"tag":229,"props":546,"children":547},{},[548,553,558,563],{"type":185,"tag":233,"props":549,"children":550},{},[551],{"type":191,"value":552},"数据爆炸与账单上升：强制采样与降基数，聚焦关键维度与异常加样。",{"type":185,"tag":233,"props":554,"children":555},{},[556],{"type":191,"value":557},"隐私泄露：默认脱敏与模板哈希，仅在受控渠道保存原文。",{"type":185,"tag":233,"props":559,"children":560},{},[561],{"type":191,"value":562},"误观测与误判：将离线评测与线上指标结合，定期校验质量指标与业务目标的相关性。",{"type":185,"tag":233,"props":564,"children":565},{},[566],{"type":191,"value":567},"难以推广：以平台能力与脚手架降低埋点成本，提供示例与校验工具，配合变更流程与 Code Review 守门。",{"type":185,"tag":194,"props":569,"children":570},{},[571],{"type":191,"value":572},"总体而言，Datadog LLM Observability 能将 LLM/Agent 链路纳入现有 APM 体系，快速建立“可观测的最小闭环”。关键在于：标准化埋点、成本/安全守护、以及数据工程与运维的紧密协作。",{"title":178,"searchDepth":574,"depth":574,"links":575},2,[576,577],{"id":188,"depth":574,"text":192},{"id":211,"depth":574,"text":214,"children":578},[579,581,582,583,584,585],{"id":218,"depth":580,"text":218},3,{"id":250,"depth":580,"text":250},{"id":288,"depth":580,"text":288},{"id":391,"depth":580,"text":391},{"id":420,"depth":580,"text":420},{"id":471,"depth":580,"text":471},"markdown","content:6.maps:_ai:llm:datadog:datadog-llm.md","content","6.maps/_ai/llm/datadog/datadog-llm.md","6.maps/_ai/llm/datadog/datadog-llm","md",[593,597],{"_path":594,"title":595,"description":596},"/maps/_ai/image/stable-diffusion","Image Generator","Stable Diffusion 图像生成提示词与风格指南。",{"_path":598,"title":599,"description":600},"/maps/_ai/llm/embeddings","Embeddings 入门指南","LLM Embeddings 的核心概念、演进历史与实践",1772504962884]