[{"data":1,"prerenderedAt":597},["ShallowReactive",2],{"navigation":3,"/maps/_ai/llm/datadog/datadog-llm":170,"/maps/_ai/llm/datadog/datadog-llm-surround":589},[4,35,92,98,125,131,155,161],{"title":5,"_path":6,"children":7},"心流思绪 / Heart Flows","/flows",[8,11,14,17,20,23,26,29,32],{"title":9,"_path":10},"📕 狮子的书单推荐","/flows/books",{"title":12,"_path":13},"🚝 四十二篇系列","/flows/forty-two",{"title":15,"_path":16},"🌃 长夜梦","/flows/long-night-dream",{"title":18,"_path":19},"🌌 万物联结与幸福感","/flows/everything",{"title":21,"_path":22},"⌛ 偷取时间","/flows/stealing-time-from-god",{"title":24,"_path":25},"🌆 表达和孤独","/flows/expression-and-loneliness",{"title":27,"_path":28},"🌧️ 我的腼腆","/flows/shy",{"title":30,"_path":31},"🥛 新工作，喝新饮料","/flows/drinking-while-thinking",{"title":33,"_path":34},"📝 心流归档","/flows/archive",{"title":36,"_path":37,"children":38},"技术博客 / Coder","/articles",[39,41,44,47,50,53,56,59,62,65,68,71,74,77,80,83,86,89],{"title":40,"_path":37},"🦁 欢迎",{"title":42,"_path":43},"📦 一个简单有效的端口命名策略：","/articles/simple-naming-method",{"title":45,"_path":46},"🌪️ Tailwind v4 如何兼容预处理器","/articles/tailwind4-with-sass",{"title":48,"_path":49},"🥞 在 tailwind 中使用现代化 CSS Layers","/articles/tailwind-sass-and-css-layer",{"title":51,"_path":52},"💻 本地部署 Qwen 翻译网页","/articles/local-translator",{"title":54,"_path":55},"🧊 模板解析器轻考古","/articles/micro-templating",{"title":57,"_path":58},"Ⓜ️ Mini CSS Parser","/articles/mini-css-parser",{"title":60,"_path":61},"🚩 向AI咨询前端问题","/articles/use-gpt-learn-complex-frontend",{"title":63,"_path":64},"⛸️ 怎样定制复杂组件的自定义滚动条？","/articles/use-scrollbars",{"title":66,"_path":67},"⚖️ 统一多组件库的层叠顺序","/articles/zindex-manager",{"title":69,"_path":70},"🕷️ 滑动验证码破解思路","/articles/crack-the-slider",{"title":72,"_path":73},"🌟 探秘 CSS 光影效果","/articles/css-light-travel",{"title":75,"_path":76},"🍲 设计模式与 JS 魔法锅","/articles/design-patterns-and-js-magic-pot",{"title":78,"_path":79},"🌐 Anysort：灵活、优雅的多属性排序","/articles/anysort-2th",{"title":81,"_path":82},"💫 CSS 幻术 | 抗锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133,"children":134},"造物 / Make","/tools",[135,137,140,143,146,149,152],{"title":136,"_path":133},"🧰 工具收集",{"title":138,"_path":139},"📕 博客","/tools/blog",{"title":141,"_path":142},"🥥 Coconut","/tools/coconut",{"title":144,"_path":145},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":147,"_path":148},"🌐 AnySort","/tools/anysort",{"title":150,"_path":151},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":153,"_path":154},"👓 Crapto","/tools/crypto-inline",{"title":156,"_path":157,"children":158},"我 / About","/hire",[159],{"title":160,"_path":157},"📬 技术简历",{"title":162,"_path":163,"children":164},"En","/en",[165],{"title":166,"_path":167,"children":168},"🦁 Welcome","/en/articles",[169],{"title":166,"_path":167},{"_path":171,"_dir":172,"_draft":173,"_partial":174,"_locale":175,"title":176,"description":177,"body":178,"_type":583,"_id":584,"_source":585,"_file":586,"_stem":587,"_extension":588},"/maps/_ai/llm/datadog/datadog-llm","datadog",false,true,"","Datadog LLM Observability","为 LLM 与 Agent 工作流提供端到端追踪、监控与诊断，融入 Datadog APM 体系；对已用 Datadog 的团队较友好，但埋点与协同要求高。",{"type":179,"children":180,"toc":570},"root",[181,190,196,201,206,212,218,225,245,250,255,283,288,293,311,316,339,345,363,368,386,391,397,415,420,425,448,453,466,471,476,489,494,512,518,537,542,565],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"brief",[187],{"type":188,"value":189},"text","Brief",{"type":182,"tag":191,"props":192,"children":193},"p",{},[194],{"type":188,"value":195},"Datadog LLM Observability 为大语言模型与 Agent 型应用的工作流提供端到端的追踪、监控与诊断。它将每个提示、工具调用与中间步骤映射为 spans 与 traces；跟踪时延、Token 用量、错误与质量指标；并与 Datadog 更广泛的 APM 与可观测性套件集成。",{"type":182,"tag":191,"props":197,"children":198},{},[199],{"type":188,"value":200},"对于已在使用 Datadog、熟悉其成本结构的组织而言，只要工作负载能够被正确埋点，LLM 可观测性功能是获取 AI 工作负载可见性的直接路径。然而，LLM 埋点的配置与使用需要谨慎，且要求对工作负载及其实现有扎实理解。我们建议数据工程与运维团队在部署时密切协作。另参见我们关于避免“独立数据工程团队”的建议。",{"type":182,"tag":191,"props":202,"children":203},{},[204],{"type":188,"value":205},"来源：技术雷达",{"type":182,"tag":183,"props":207,"children":209},{"id":208},"details",[210],{"type":188,"value":211},"Details",{"type":182,"tag":213,"props":214,"children":216},"h3",{"id":215},"背景与现状",[217],{"type":188,"value":215},{"type":182,"tag":219,"props":220,"children":222},"h4",{"id":221},"为什么现在需要-llm-可观测性",[223],{"type":188,"value":224},"为什么现在需要 LLM 可观测性",{"type":182,"tag":226,"props":227,"children":228},"ul",{},[229,235,240],{"type":182,"tag":230,"props":231,"children":232},"li",{},[233],{"type":188,"value":234},"LLM 与 Agent 的执行链路多跳、多工具，错误与延迟来源分散，传统日志难以还原根因。",{"type":182,"tag":230,"props":236,"children":237},{},[238],{"type":188,"value":239},"业务开始关注“质量/成本/延迟”的三角平衡，需要可度量、可回溯的数据来支撑优化与治理。",{"type":182,"tag":230,"props":241,"children":242},{},[243],{"type":188,"value":244},"已采用 Datadog 的组织希望在既有 APM/指标/告警框架内统一治理 AI 工作负载。",{"type":182,"tag":213,"props":246,"children":248},{"id":247},"问题与风险",[249],{"type":188,"value":247},{"type":182,"tag":219,"props":251,"children":253},{"id":252},"典型痛点与结构性矛盾",[254],{"type":188,"value":252},{"type":182,"tag":226,"props":256,"children":257},{},[258,263,268,273,278],{"type":182,"tag":230,"props":259,"children":260},{},[261],{"type":188,"value":262},"黑盒链路：提示模板、模型版本、工具调用与外部依赖交织，缺乏统一 Trace 视角。",{"type":182,"tag":230,"props":264,"children":265},{},[266],{"type":188,"value":267},"成本不透明：高频调用与高基数标签可能放大观测成本与数据基建开销。",{"type":182,"tag":230,"props":269,"children":270},{},[271],{"type":188,"value":272},"质量不可证：离线评测与线上表现常不一致，缺少面向场景的线上质量度量。",{"type":182,"tag":230,"props":274,"children":275},{},[276],{"type":188,"value":277},"数据敏感性：提示/上下文可能含敏感信息，原样上报带来合规与泄露风险。",{"type":182,"tag":230,"props":279,"children":280},{},[281],{"type":188,"value":282},"变更不可控：Prompt/模型/工具变更缺乏版本化与灰度策略，出现“回不去”的质量回退。",{"type":182,"tag":213,"props":284,"children":286},{"id":285},"模式与原理",[287],{"type":188,"value":285},{"type":182,"tag":219,"props":289,"children":291},{"id":290},"端到端追踪的核心抽象",[292],{"type":188,"value":290},{"type":182,"tag":226,"props":294,"children":295},{},[296,301,306],{"type":182,"tag":230,"props":297,"children":298},{},[299],{"type":188,"value":300},"Trace 代表一次业务请求或 Agent 任务；Span 对应关键阶段：Prompt、Tool 调用、检索、Rerank、模型推理等。",{"type":182,"tag":230,"props":302,"children":303},{},[304],{"type":188,"value":305},"关键维度建议：model 与版本、prompt 模板哈希、调用角色（system/user/assistant）、工具名称、数据来源、采样率、租户/业务线、请求规模（tokens in/out）。",{"type":182,"tag":230,"props":307,"children":308},{},[309],{"type":188,"value":310},"关键事件：超时、重试、截断、Rate Limit、供应商错误码、Guardrail 触发、回退策略命中。",{"type":182,"tag":219,"props":312,"children":314},{"id":313},"指标与质量度量",[315],{"type":188,"value":313},{"type":182,"tag":226,"props":317,"children":318},{},[319,324,329,334],{"type":182,"tag":230,"props":320,"children":321},{},[322],{"type":188,"value":323},"性能：P50/P95/P99 时延；队列等待与推理时延拆分；工具调用成功率与尾部延迟。",{"type":182,"tag":230,"props":325,"children":326},{},[327],{"type":188,"value":328},"成本：输入/输出 Token、推理时长、供应商计费单位；按租户/场景聚合。",{"type":182,"tag":230,"props":330,"children":331},{},[332],{"type":188,"value":333},"质量：规则型指标（拒识率/敏感命中率/格式合规率）、业务型指标（任务成功率/人工复核通过率）、系统性指标（对话步数、回退率）。",{"type":182,"tag":230,"props":335,"children":336},{},[337],{"type":188,"value":338},"关联：将线上评审样本与 Trace 绑定，形成“问题案例可复现”的闭环。",{"type":182,"tag":219,"props":340,"children":342},{"id":341},"与-apm-的集成方式",[343],{"type":188,"value":344},"与 APM 的集成方式",{"type":182,"tag":226,"props":346,"children":347},{},[348,353,358],{"type":182,"tag":230,"props":349,"children":350},{},[351],{"type":188,"value":352},"传递 Trace/Span 上下文贯穿 Web/API → 编排层 → 工具/检索 → 模型调用。",{"type":182,"tag":230,"props":354,"children":355},{},[356],{"type":188,"value":357},"统一告警与 SLO：以业务成功率、P99 延迟、成本预算为主指标，结合异常分布与错误比率。",{"type":182,"tag":230,"props":359,"children":360},{},[361],{"type":188,"value":362},"看板与探索：按模型/版本、Prompt 哈希、工具类型、租户维度钻取，定位“谁最贵/最慢/最不稳定”。",{"type":182,"tag":219,"props":364,"children":366},{"id":365},"成本与数据治理",[367],{"type":188,"value":365},{"type":182,"tag":226,"props":369,"children":370},{},[371,376,381],{"type":182,"tag":230,"props":372,"children":373},{},[374],{"type":188,"value":375},"采样优先：对低风险流量进行采样，对错误/高延迟/高成本请求提升采样比。",{"type":182,"tag":230,"props":377,"children":378},{},[379],{"type":188,"value":380},"降基数：对长文本做哈希/指纹化，只保留可检索的摘要或模板标识。",{"type":182,"tag":230,"props":382,"children":383},{},[384],{"type":188,"value":385},"脱敏与最小化：敏感字段上报前脱敏/截断；仅在需要时捕获原文，并控制留存周期。",{"type":182,"tag":213,"props":387,"children":389},{"id":388},"对比与演进",[390],{"type":188,"value":388},{"type":182,"tag":219,"props":392,"children":394},{"id":393},"从日志拼接到apm-级-llm-可观测性",[395],{"type":188,"value":396},"从“日志拼接”到“APM 级 LLM 可观测性”",{"type":182,"tag":226,"props":398,"children":399},{},[400,405,410],{"type":182,"tag":230,"props":401,"children":402},{},[403],{"type":188,"value":404},"仅日志：低门槛但难以还原全链路，跨组件关联弱，难做 SLO。",{"type":182,"tag":230,"props":406,"children":407},{},[408],{"type":188,"value":409},"APM 集成：以 Trace 为主线，统一指标/日志/事件；能面向业务做聚合与告警。",{"type":182,"tag":230,"props":411,"children":412},{},[413],{"type":188,"value":414},"专用 LLMOps 平台：更强评测/对齐/数据管理能力，但与现有 APM 体系割裂。对已深度使用 Datadog 的团队，优先用 APM 集成形成“可运行的最小闭环”，再按需补齐评测与数据资产能力。",{"type":182,"tag":213,"props":416,"children":418},{"id":417},"系统性影响",[419],{"type":188,"value":417},{"type":182,"tag":219,"props":421,"children":423},{"id":422},"架构与工程效率",[424],{"type":188,"value":422},{"type":182,"tag":226,"props":426,"children":427},{},[428,433,438,443],{"type":182,"tag":230,"props":429,"children":430},{},[431],{"type":188,"value":432},"标准化编排：推动将 Prompt/检索/工具封装为可观测的“阶段组件”，提升可维护性与灰度能力。",{"type":182,"tag":230,"props":434,"children":435},{},[436],{"type":188,"value":437},"质量文化：从“感觉可用”转向“可度量与可回溯”，促进问题复盘与模板治理。",{"type":182,"tag":230,"props":439,"children":440},{},[441],{"type":188,"value":442},"技术栈治理：促使模型与 Prompt 版本化、灰度发布、回退策略纳入变更管理。",{"type":182,"tag":230,"props":444,"children":445},{},[446],{"type":188,"value":447},"安全与合规：引入统一脱敏策略、最小化上报原则与留存策略。",{"type":182,"tag":219,"props":449,"children":451},{"id":450},"组织协作",[452],{"type":188,"value":450},{"type":182,"tag":226,"props":454,"children":455},{},[456,461],{"type":182,"tag":230,"props":457,"children":458},{},[459],{"type":188,"value":460},"数据工程 × 运维 × 应用团队协作上云；避免“独立数据工程团队”形成割裂，优先嵌入式协同与平台化支持。",{"type":182,"tag":230,"props":462,"children":463},{},[464],{"type":188,"value":465},"角色分工：平台/运维定义可观测性标准与落地框架；应用团队按标准埋点；数据工程支持质量数据管线与评测闭环。",{"type":182,"tag":213,"props":467,"children":469},{"id":468},"落地建议",[470],{"type":188,"value":468},{"type":182,"tag":219,"props":472,"children":474},{"id":473},"适用与边界",[475],{"type":188,"value":473},{"type":182,"tag":226,"props":477,"children":478},{},[479,484],{"type":182,"tag":230,"props":480,"children":481},{},[482],{"type":188,"value":483},"更适用：已有 Datadog 基础、AI 流量稳定增长、对质量/成本有明确 SLO 的团队。",{"type":182,"tag":230,"props":485,"children":486},{},[487],{"type":188,"value":488},"谨慎或不适用：强合规场景无法脱敏上报；对成本极敏感但无法采样/降基数的业务。",{"type":182,"tag":219,"props":490,"children":492},{"id":491},"前置条件",[493],{"type":188,"value":491},{"type":182,"tag":226,"props":495,"children":496},{},[497,502,507],{"type":182,"tag":230,"props":498,"children":499},{},[500],{"type":188,"value":501},"基线规范：Trace 贯穿、必备标签（模型/版本/模板哈希/工具名/租户）、统一错误码与重试策略。",{"type":182,"tag":230,"props":503,"children":504},{},[505],{"type":188,"value":506},"数据安全：脱敏白名单、敏感字段识别与拦截、留存与访问控制。",{"type":182,"tag":230,"props":508,"children":509},{},[510],{"type":188,"value":511},"成本控制：采样策略、指标与日志配额、看板与预算告警。",{"type":182,"tag":219,"props":513,"children":515},{"id":514},"试点路径建议三步",[516],{"type":188,"value":517},"试点路径（建议三步）",{"type":182,"tag":519,"props":520,"children":521},"ol",{},[522,527,532],{"type":182,"tag":230,"props":523,"children":524},{},[525],{"type":188,"value":526},"最小闭环：选一个关键用例，打通端到端 Trace，接入时延/错误/Token 指标与基础告警。",{"type":182,"tag":230,"props":528,"children":529},{},[530],{"type":188,"value":531},"质量落地：接入规则型质量指标与人工复核样本回流，建立问题样本库与复盘机制。",{"type":182,"tag":230,"props":533,"children":534},{},[535],{"type":188,"value":536},"扩展与治理：推广到多场景，完善版本化/灰度/回退；引入成本看板与预算 SLO。",{"type":182,"tag":219,"props":538,"children":540},{"id":539},"常见风险与对策",[541],{"type":188,"value":539},{"type":182,"tag":226,"props":543,"children":544},{},[545,550,555,560],{"type":182,"tag":230,"props":546,"children":547},{},[548],{"type":188,"value":549},"数据爆炸与账单上升：强制采样与降基数，聚焦关键维度与异常加样。",{"type":182,"tag":230,"props":551,"children":552},{},[553],{"type":188,"value":554},"隐私泄露：默认脱敏与模板哈希，仅在受控渠道保存原文。",{"type":182,"tag":230,"props":556,"children":557},{},[558],{"type":188,"value":559},"误观测与误判：将离线评测与线上指标结合，定期校验质量指标与业务目标的相关性。",{"type":182,"tag":230,"props":561,"children":562},{},[563],{"type":188,"value":564},"难以推广：以平台能力与脚手架降低埋点成本，提供示例与校验工具，配合变更流程与 Code Review 守门。",{"type":182,"tag":191,"props":566,"children":567},{},[568],{"type":188,"value":569},"总体而言，Datadog LLM Observability 能将 LLM/Agent 链路纳入现有 APM 体系，快速建立“可观测的最小闭环”。关键在于：标准化埋点、成本/安全守护、以及数据工程与运维的紧密协作。",{"title":175,"searchDepth":571,"depth":571,"links":572},2,[573,574],{"id":185,"depth":571,"text":189},{"id":208,"depth":571,"text":211,"children":575},[576,578,579,580,581,582],{"id":215,"depth":577,"text":215},3,{"id":247,"depth":577,"text":247},{"id":285,"depth":577,"text":285},{"id":388,"depth":577,"text":388},{"id":417,"depth":577,"text":417},{"id":468,"depth":577,"text":468},"markdown","content:6.maps:_ai:llm:datadog:datadog-llm.md","content","6.maps/_ai/llm/datadog/datadog-llm.md","6.maps/_ai/llm/datadog/datadog-llm","md",[590,593],{"_path":591,"title":592,"description":175},"/maps/_ai/image/stable-diffusion","Image Generator",{"_path":594,"title":595,"description":596},"/maps/_ai/llm/llm","Large Language Models","large language models related",1771071696826]