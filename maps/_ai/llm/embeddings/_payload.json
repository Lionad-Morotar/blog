beddings 的核心概念、演进历史与实践","_ai/llm/embeddings.md",{"type":183,"children":184,"toc":599},"root",[185,193,199,206,232,238,261,266,272,277,300,310,316,321,344,349,359,365,370,413,418,441,451,457,471,476,481,487,492,509,515,520,525,565,570],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"核心概念",[191],{"type":192,"value":189},"text",{"type":186,"tag":194,"props":195,"children":196},"p",{},[197],{"type":192,"value":198},"Embeddings（词向量/嵌入）是将文本转换为数值向量的技术，是 LLM 理解语言的语义基础。当文本进入模型时，首先被转换为高维向量空间中的点，语义关系变为数学关系。",{"type":186,"tag":200,"props":201,"children":203},"h4",{"id":202},"好的-embedding-有什么特征",[204],{"type":192,"value":205},"好的 Embedding 有什么特征？",{"type":186,"tag":207,"props":208,"children":209},"ul",{},[210,222],{"type":186,"tag":211,"props":212,"children":213},"li",{},[214,220],{"type":186,"tag":215,"props":216,"children":217},"strong",{},[218],{"type":192,"value":219},"语义表示",{"type":192,"value":221},"：语义相近的词在向量空间中距离更近。如 \"cat\" 和 \"dog\" 的向量应比 \"dog\" 和 \"strawberry\" 更相似",{"type":186,"tag":211,"props":223,"children":224},{},[225,230],{"type":186,"tag":215,"props":226,"children":227},{},[228],{"type":192,"value":229},"维度权衡",{"type":192,"value":231},"：低维度向量（50-300）存储和计算效率高，高维度向量（768-7168）能捕获更复杂关系但易过拟合。GPT-2 最小 768 维，DeepSeek-V3 达 7168 维",{"type":186,"tag":200,"props":233,"children":235},{"id":234},"静态-vs-动态-embeddings",[236],{"type":192,"value":237},"静态 vs 动态 Embeddings",{"type":186,"tag":207,"props":239,"children":240},{},[241,251],{"type":186,"tag":211,"props":242,"children":243},{},[244,249],{"type":186,"tag":215,"props":245,"children":246},{},[247],{"type":192,"value":248},"静态 Embeddings",{"type":192,"value":250},"：Token 在输入层获得的固定向量，每个 token 有唯一的嵌入向量",{"type":186,"tag":211,"props":252,"children":253},{},[254,259],{"type":186,"tag":215,"props":255,"children":256},{},[257],{"type":192,"value":258},"动态/上下文 Embeddings",{"type":192,"value":260},"：经过 Transformer 层处理后，融入上下文信息的表示。\"银行\"在\"河岸\"和\"银行抢劫\"中静态 embedding 相同，但动态 embedding 会根据上下文分化",{"type":186,"tag":187,"props":262,"children":264},{"id":263},"技术演进",[265],{"type":192,"value":263},{"type":186,"tag":200,"props":267,"children":269},{"id":268},"tf-idf词频-逆文档频率",[270],{"type":192,"value":271},"TF-IDF（词频-逆文档频率）",{"type":186,"tag":194,"props":273,"children":274},{},[275],{"type":192,"value":276},"基于统计的方法，通过计算词在文档中的重要性生成嵌入：",{"type":186,"tag":207,"props":278,"children":279},{},[280,290],{"type":186,"tag":211,"props":281,"children":282},{},[283,288],{"type":186,"tag":215,"props":284,"children":285},{},[286],{"type":192,"value":287},"TF（词频）",{"type":192,"value":289},"：词在文档中出现频率，越高越重要",{"type":186,"tag":211,"props":291,"children":292},{},[293,298],{"type":186,"tag":215,"props":294,"children":295},{},[296],{"type":192,"value":297},"IDF（逆文档频率）",{"type":192,"value":299},"：词在所有文档中的稀缺程度，常见词（如\"的\"）权重低",{"type":186,"tag":194,"props":301,"children":302},{},[303,308],{"type":186,"tag":215,"props":304,"children":305},{},[306],{"type":192,"value":307},"局限性",{"type":192,"value":309},"：词在向量空间中的距离与语义无关，仅反映共现频率。大多数词的 embedding 聚集在同一区域，缺乏区分度。",{"type":186,"tag":200,"props":311,"children":313},{"id":312},"word2vec",[314],{"type":192,"value":315},"Word2Vec",{"type":186,"tag":194,"props":317,"children":318},{},[319],{"type":192,"value":320},"神经网络驱动的嵌入方法，核心思想是通过上下文预测词（或反之）：",{"type":186,"tag":207,"props":322,"children":323},{},[324,334],{"type":186,"tag":211,"props":325,"children":326},{},[327,332],{"type":186,"tag":215,"props":328,"children":329},{},[330],{"type":192,"value":331},"CBOW",{"type":192,"value":333},"：根据上下文词预测目标词",{"type":186,"tag":211,"props":335,"children":336},{},[337,342],{"type":186,"tag":215,"props":338,"children":339},{},[340],{"type":192,"value":341},"Skip-gram",{"type":192,"value":343},"：根据目标词预测上下文词",{"type":186,"tag":194,"props":345,"children":346},{},[347],{"type":192,"value":348},"网络结构简单：输入层 → 隐藏层（存储 embeddings）→ 输出层。训练完成后丢弃输出层，隐藏层即为词向量。通过 Negative Sampling 优化大规模词汇表的训练效率。",{"type":186,"tag":194,"props":350,"children":351},{},[352,357],{"type":186,"tag":215,"props":353,"children":354},{},[355],{"type":192,"value":356},"优势",{"type":192,"value":358},"：能捕获语义关系，支持向量运算（如 king - man + woman ≈ queen）。",{"type":186,"tag":200,"props":360,"children":362},{"id":361},"bert",[363],{"type":192,"value":364},"BERT",{"type":186,"tag":194,"props":366,"children":367},{},[368],{"type":192,"value":369},"首个基于 Transformer 的上下文嵌入模型， encoder-only 架构：",{"type":186,"tag":207,"props":371,"children":372},{},[373,383,393,403],{"type":186,"tag":211,"props":374,"children":375},{},[376,381],{"type":186,"tag":215,"props":377,"children":378},{},[379],{"type":192,"value":380},"Tokenizer",{"type":192,"value":382},"：将文本分割为 token 序列",{"type":186,"tag":211,"props":384,"children":385},{},[386,391],{"type":186,"tag":215,"props":387,"children":388},{},[389],{"type":192,"value":390},"Embedding",{"type":192,"value":392},"：将 token 转为向量",{"type":186,"tag":211,"props":394,"children":395},{},[396,401],{"type":186,"tag":215,"props":397,"children":398},{},[399],{"type":192,"value":400},"Encoder",{"type":192,"value":402},"：多层自注意力 + 前馈网络，融合上下文",{"type":186,"tag":211,"props":404,"children":405},{},[406,411],{"type":186,"tag":215,"props":407,"children":408},{},[409],{"type":192,"value":410},"Task Head",{"type":192,"value":412},"：任务特定的输出层",{"type":186,"tag":194,"props":414,"children":415},{},[416],{"type":192,"value":417},"预训练任务：",{"type":186,"tag":207,"props":419,"children":420},{},[421,431],{"type":186,"tag":211,"props":422,"children":423},{},[424,429],{"type":186,"tag":215,"props":425,"children":426},{},[427],{"type":192,"value":428},"Masked Language Modeling",{"type":192,"value":430},"：预测被遮蔽的词",{"type":186,"tag":211,"props":432,"children":433},{},[434,439],{"type":186,"tag":215,"props":435,"children":436},{},[437],{"type":192,"value":438},"Next Sentence Prediction",{"type":192,"value":440},"：判断两句子是否连续",{"type":186,"tag":194,"props":442,"children":443},{},[444,449],{"type":186,"tag":215,"props":445,"children":446},{},[447],{"type":192,"value":448},"突破",{"type":192,"value":450},"：同一词在不同上下文中产生不同表示，解决了多义词问题。",{"type":186,"tag":200,"props":452,"children":454},{"id":453},"现代-llm-的-embeddings",[455],{"type":192,"value":456},"现代 LLM 的 Embeddings",{"type":186,"tag":194,"props":458,"children":459},{},[460,462,469],{"type":192,"value":461},"LLM 的 embedding 层作为查找表（Look-up Table）工作：给定 token ID，返回对应的嵌入向量。",{"type":186,"tag":463,"props":464,"children":466},"code",{"className":465},[],[467],{"type":192,"value":468},"torch.nn.Embedding",{"type":192,"value":470}," 本质上是接收索引而非 one-hot 编码的线性层。",{"type":186,"tag":194,"props":472,"children":473},{},[474],{"type":192,"value":475},"Embedding 在 LLM 训练中与模型参数一起优化，而非使用预训练的 Word2Vec——这样 embedding 能针对特定任务和数据定制。",{"type":186,"tag":187,"props":477,"children":479},{"id":478},"可视化与分析",[480],{"type":192,"value":478},{"type":186,"tag":200,"props":482,"children":484},{"id":483},"embedding-atlas",[485],{"type":192,"value":486},"Embedding Atlas",{"type":186,"tag":194,"props":488,"children":489},{},[490],{"type":192,"value":491},"将词汇 embedding 映射到二维/三维空间可视化，语义相近的词会聚集。例如 \"bridge\"、\"bridges\"、\"桥\"、\"橋\" 在空间中距离很近，反映了跨语言的语义相似性。",{"type":186,"tag":207,"props":493,"children":494},{},[495],{"type":186,"tag":211,"props":496,"children":497},{},[498,507],{"type":186,"tag":499,"props":500,"children":504},"a",{"href":501,"rel":502},"https://apple.github.io/embedding-atlas/",[503],"nofollow",[505],{"type":192,"value":506},"Apple Embedding Atlas",{"type":192,"value":508}," - Apple 开源的大规模嵌入可视化工具，支持自动聚类、实时搜索、WebGPU 渲染",{"type":186,"tag":200,"props":510,"children":512},{"id":511},"embedding-graph",[513],{"type":192,"value":514},"Embedding Graph",{"type":186,"tag":194,"props":516,"children":517},{},[518],{"type":192,"value":519},"将 embedding 空间建模为图网络：token 为节点，向量相近的 token 之间建立边。可用于分析词汇的语义邻域结构。",{"type":186,"tag":187,"props":521,"children":523},{"id":522},"实践工具",[524],{"type":192,"value":522},{"type":186,"tag":207,"props":526,"children":527},{},[528,547],{"type":186,"tag":211,"props":529,"children":530},{},[531,536,538,545],{"type":186,"t