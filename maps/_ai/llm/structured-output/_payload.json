le":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"original_path":181,"body":182,"_type":452,"_id":453,"_source":454,"_file":455,"_stem":456,"_extension":457},"/maps/_ai/llm/structured-output","llm",false,true,"","结构化输出","LLM 结构化输出技术，约束模型生成预定义格式的响应。","_ai/llm/structured-output.md",{"type":183,"children":184,"toc":439},"root",[185,194,200,205,211,217,223,228,233,238,243,248,253,258,263,268,273,278,283,297,302,308,333,338,343,348,353,358,363,368,373,378,383,388],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"brief",[191],{"type":192,"value":193},"text","Brief",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198],{"type":192,"value":199},"LLM 结构化输出是指约束大语言模型生成预定义格式（如 JSON 或特定编程类）的响应。该技术对构建可靠生产级应用至关重要，将 LLM 通常不可预测的文本转换为机器可读、确定性的数据契约。基于实际生产验证，此技术已从评估阶段进入试验阶段。方法包括简单提示格式化、模型原生结构化输出，以及使用 Outlines 和 Instructor 等工具进行受限解码以确保有效输出。我们已成功应用此技术从多样文档中提取复杂非结构化数据，转换为结构化 JSON 供下游业务逻辑使用。",{"type":186,"tag":195,"props":201,"children":202},{},[203],{"type":192,"value":204},"来源：技术雷达",{"type":186,"tag":187,"props":206,"children":208},{"id":207},"details",[209],{"type":192,"value":210},"Details",{"type":186,"tag":212,"props":213,"children":215},"h3",{"id":214},"背景与现状",[216],{"type":192,"value":214},{"type":186,"tag":218,"props":219,"children":221},"h4",{"id":220},"技术背景和典型场景",[222],{"type":192,"value":220},{"type":186,"tag":195,"props":224,"children":225},{},[226],{"type":192,"value":227},"LLM 的原始输出通常是非结构化文本，缺乏机器可读性，在生产环境中直接使用时容易导致下游系统故障。典型场景包括从 PDF、文档或用户输入中提取数据后，需无缝集成到业务流程（如数据库写入、API 响应生成或自动化工作流）。这类场景下，原始文本的随机性和格式不一致问题会显著增加系统脆弱性。",{"type":186,"tag":218,"props":229,"children":231},{"id":230},"产业实践现状",[232],{"type":192,"value":230},{"type":186,"tag":195,"props":234,"children":235},{},[236],{"type":192,"value":237},"当前多数团队依赖手工解析或简单正则表达式处理 LLM 输出，但这种方式在复杂数据场景下维护成本高、错误率高。随着生产环境验证逐渐成熟，结构化输出已成为从“评估”转向“试验”的关键技术方向，反映了工程实践对可靠性的迫切需求。",{"type":186,"tag":212,"props":239,"children":241},{"id":240},"问题与风险",[242],{"type":192,"value":240},{"type":186,"tag":218,"props":244,"children":246},{"id":245},"现状痛点",[247],{"type":192,"value":245},{"type":186,"tag":195,"props":249,"children":250},{},[251],{"type":192,"value":252},"未结构化输出导致频繁的下游系统异常，例如 JSON 解析失败、字段缺失或类型错误。这迫使开发团队投入大量时间编写额外的文本解析逻辑，不仅拖慢迭代速度，还因隐性错误引发生产事故。同时，手动调试非结构化文本的过程不可重复，增加了系统维护的不确定性。",{"type":186,"tag":218,"props":254,"children":256},{"id":255},"长期结构性风险",[257],{"type":192,"value":255},{"type":186,"tag":195,"props":259,"children":260},{},[261],{"type":192,"value":262},"若持续依赖非结构化输出，技术债务将快速积累：数据契约缺乏一致性会阻碍微服务间协作，测试覆盖率不足导致问题在生产阶段才暴露。更严重的是，当业务逻辑依赖复杂文本处理时，系统扩展性和可维护性将受制约，长期可能成为技术演进的瓶颈。",{"type":186,"tag":212,"props":264,"children":266},{"id":265},"模式与原理",[267],{"type":192,"value":265},{"type":186,"tag":218,"props":269,"children":271},{"id":270},"核心机制",[272],{"type":192,"value":270},{"type":186,"tag":195,"props":274,"children":275},{},[276],{"type":192,"value":277},"结构化输出的核心是通过语法约束将 LLM 输出控制在预定义 Schema 内，确保每次生成都符合机器可读格式。这并非简单文本过滤，而是将 LLM 的生成过程转化为确定性数据生产——基于输入约束强制输出格式正确，而非依赖后期修复。",{"type":186,"tag":218,"props":279,"children":281},{"id":280},"关键工具与角色",[282],{"type":192,"value":280},{"type":186,"tag":195,"props":284,"children":285},{},[286,288,295],{"type":192,"value":287},"主要实现方式包括：提示工程（通过指令引导格式化输出）、模型原生支持（如 OpenAI 的 ",{"type":186,"tag":289,"props":290,"children":292},"code",{"className":291},[],[293],{"type":192,"value":294},"response_format",{"type":192,"value":296}," 参数），以及高级工具如 Outlines 和 Instructor。这些工具通过有限状态机（FSM）动态验证输出结构，在解码阶段实时约束词元选择，从源头保证有效性。关键角色涉及提示工程师（设计 Schema）、后端开发者（定义数据契约）和 SRE（监控输出合规性）。",{"type":186,"tag":212,"props":298,"children":300},{"id":299},"对比与演进",[301],{"type":192,"value":299},{"type":186,"tag":218,"props":303,"children":305},{"id":304},"传统方法-vs-结构化输出",[306],{"type":192,"value":307},"传统方法 vs 结构化输出",{"type":186,"tag":309,"props":310,"children":311},"ul",{},[312,324],{"type":186,"tag":313,"props":314,"children":315},"li",{},[316,322],{"type":186,"tag":317,"props":318,"children":319},"strong",{},[320],{"type":192,"value":321},"传统方式",{"type":192,"value":323},"：依赖文本解析（如正则表达式或 NLP 模型），需额外开发校验层，处理步骤多且易漏边界情况（如嵌套结构或特殊字符）。典型风险是解析逻辑与 LLM 输出漂移，导致系统间断性故障。",{"type":186,"tag":313,"props":325,"children":326},{},[327,331],{"type":186,"tag":317,"props":328,"children":329},{},[330],{"type":192,"value":179},{"type":192,"value":332},"：直接生成机器可读数据，减少中间转换层。例如，用 Schema 定义字段类型后，LLM 输出自动符合约定，无需额外解析代码。这显著降低错误率，提升端到端可靠性。",{"type":186,"tag":218,"props":334,"children":336},{"id":335},"演进趋势",[337],{"type":192,"value":335},{"type":186,"tag":195,"props":339,"children":340},{},[341],{"type":192,"value":342},"从简单提示格式化向工具化、自动化演进：初期仅用提示词约束，但难以处理复杂结构；当前主流方案结合工具（如 Outlines）的 FSM 约束，支持嵌套 JSON 或类实例生成；未来可能深度集成到 LLM 框架层，实现 Schema 驱动的训练微调，进一步降低使用门槛。",{"type":186,"tag":212,"props":344,"children":346},{"id":345},"系统影响",[347],{"type":192,"value":345},{"type":186,"tag":218,"props":349,"children":351},{"id":350},"架构一致性与工程效率",[352],{"type":192,"value":350},{"type":186,"tag":195,"props":354,"children":355},{},[356],{"type":192,"value":357},"结构化输出能统一数据契约，减少微服务间的数据转换层，提升系统整体一致性。工程效率方面：下游业务逻辑可直接消费结构化数据，省去解析环节，加速开发迭代；同时简化测试用例设计（只需验证 Schema 合规性而非文本解析逻辑）。",{"type":186,"tag":218,"props":359,"children":361},{"id":360},"技术治理与安全考量",[362],{"type":192,"value":360},{"type":186,"tag":195,"props":364,"children":365},{},[366],{"type":192,"value":367},"在技术栈治理上，需建立统一的 Schema 管理规范（如通过 JSON Schema 注册中心），避免各团队各自为政。安全层面：结构化输出减少注入攻击风险（如 XML/JSON 处理漏洞），但需警惕 Schema 设计缺陷——若未严格校验输入字段，可能引入数据泄漏或格式化漏洞。",{"type":186,"tag":212,"props":369,"children":371},{"id":370},"落地实践建议",[372],{"type":192,"value":370},{"type":186,"tag":218,"props":374,"children":376},{"id":375},"适用场景界定",[377],{"type":192,"value":375},{"type":186,"tag":195,"props":379,"children":380},{},[381],{"type":192,"value":382},"适用于需高可靠性结构化数据的场景：如文档信息提取、表单生成、API 响应构造或数据管道初始化。不适用于创作型任务（如自由文本生成、创意内容），因结构化约束会牺牲输出多样性。团队协作阶段需注意：当 LLM 输出直接关联核心业务逻辑时，结构化输出价值最高；若仅为简单查询结果，则优先考虑轻量级方案。",{"type":186,"tag":218,"props":384,"children":386},{"id":385},"实施步骤与风险规避",[387],{"type":192,"value":385},{"type":186,"tag":309,"props":389,"children":390},{},[391,401,429],{"type":186,"tag":313,"props":392,"children":393},{},[394,399],{"type":186,"tag":317,"props":395,"children":396},{},[397],{"type":192,"value":398},"实施路径",{"type":192,"value":400},"：先定义下游需要的 Schema（如 JSON Schema），用简单提示测试基础格式；逐步引入工具（Instructor 或 Outlines）处理复杂结构，最终集成到 CI/CD 管道进行自动化验证。",{"type":186,"tag":313,"props":402,"children":403},{},[404,409,411],{"type":186,"tag":317,"props":405,"children":406},{},[407],{"type":192,"value":408},"关键风险规避",{"type":192,"value":410},"：\n",{"type":186,"tag":309,"props":412,"children":413},{},[414,419,424],{"type":186,"tag":313,"props":415,"children":416},{},[417],{"type":192,"value":418},"Schema 设计错误可能导致输出无效，必须通过边界测试覆盖极端输入（如超长字段、非法字符）；",{"type":186,"tag":313,"props":420,"children":421},{},[422],{"type":192,"value":423},"性能开销：受限解码可能增加推理延迟，需监控生成耗时并设置超时阈值；",{"type":186,"tag":313,"props":425,"children":426},{},[427],{"type":192,"value":428},"工具依赖风险：避免过度耦合特定工具（如 Outlines），保持 Schema 定义与实现解耦，便于后续迁移。",{"type":186,"tag":313,"props":430,"children":431},{},[432,437],{"type":186,"tag":317,"props":433,"children":434},{},[435],{"type":192,"value":436},"落地建议",{"type":192,"value":438},"：从小规模试点开始（如单个文档处理流程），监控输出合规率和系统错误指标；建立 Schema 审查机制，确保与业务需求对齐后再推广。",{"title":178,"searchDepth":440,"depth":440,"links":441},2,[442,443],{"id":189,"depth":440,"text":193},{"id":207,"depth":440,"text":210,"children":444},[445,447,448,449,450,451],{"id":214,"depth":446,"text":214},3,{"id":240,"depth":446,"text":240},{"id":265,"depth":446,"text":265},{"id":299,"depth":446,"text":299},{"id":345,"depth":446,"text":345},{"id":370,"depth":446,"text":370},"markdown","content:6.maps:_ai:llm:structured-output.md","content","6.maps/_ai/llm/structured-output.md","6.maps/_ai/llm/structured-output","md",[459,463],{"_path":460,"title":461,"description":462},"/maps/_ai/llm/slm","小型语言模型（SLM）","小型语言模型（SLM）相关技术与应用场景",{"_path":464,"title":465,"description":466},"/maps/_ai/mcp/mcp","Model Context Protocol","MCP（Model Context Protocol）是 Anthropic 开源的标准协议，用于连接 AI 应用与外部系统，被誉为 AI 应用的 USB-C 接口。",1772504962733]