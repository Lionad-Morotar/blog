le":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":178,"body":180,"_type":450,"_id":451,"_source":452,"_file":453,"_stem":454,"_extension":455},"/maps/_ai/llm/structured-output","llm",false,true,"","结构化输出",{"type":181,"children":182,"toc":437},"root",[183,192,198,203,209,215,221,226,231,236,241,246,251,256,261,266,271,276,281,295,300,306,331,336,341,346,351,356,361,366,371,376,381,386],{"type":184,"tag":185,"props":186,"children":188},"element","h2",{"id":187},"brief",[189],{"type":190,"value":191},"text","Brief",{"type":184,"tag":193,"props":194,"children":195},"p",{},[196],{"type":190,"value":197},"LLM 结构化输出是指约束大语言模型生成预定义格式（如 JSON 或特定编程类）的响应。该技术对构建可靠生产级应用至关重要，将 LLM 通常不可预测的文本转换为机器可读、确定性的数据契约。基于实际生产验证，此技术已从评估阶段进入试验阶段。方法包括简单提示格式化、模型原生结构化输出，以及使用 Outlines 和 Instructor 等工具进行受限解码以确保有效输出。我们已成功应用此技术从多样文档中提取复杂非结构化数据，转换为结构化 JSON 供下游业务逻辑使用。",{"type":184,"tag":193,"props":199,"children":200},{},[201],{"type":190,"value":202},"来源：技术雷达",{"type":184,"tag":185,"props":204,"children":206},{"id":205},"details",[207],{"type":190,"value":208},"Details",{"type":184,"tag":210,"props":211,"children":213},"h3",{"id":212},"背景与现状",[214],{"type":190,"value":212},{"type":184,"tag":216,"props":217,"children":219},"h4",{"id":218},"技术背景和典型场景",[220],{"type":190,"value":218},{"type":184,"tag":193,"props":222,"children":223},{},[224],{"type":190,"value":225},"LLM 的原始输出通常是非结构化文本，缺乏机器可读性，在生产环境中直接使用时容易导致下游系统故障。典型场景包括从 PDF、文档或用户输入中提取数据后，需无缝集成到业务流程（如数据库写入、API 响应生成或自动化工作流）。这类场景下，原始文本的随机性和格式不一致问题会显著增加系统脆弱性。",{"type":184,"tag":216,"props":227,"children":229},{"id":228},"产业实践现状",[230],{"type":190,"value":228},{"type":184,"tag":193,"props":232,"children":233},{},[234],{"type":190,"value":235},"当前多数团队依赖手工解析或简单正则表达式处理 LLM 输出，但这种方式在复杂数据场景下维护成本高、错误率高。随着生产环境验证逐渐成熟，结构化输出已成为从“评估”转向“试验”的关键技术方向，反映了工程实践对可靠性的迫切需求。",{"type":184,"tag":210,"props":237,"children":239},{"id":238},"问题与风险",[240],{"type":190,"value":238},{"type":184,"tag":216,"props":242,"children":244},{"id":243},"现状痛点",[245],{"type":190,"value":243},{"type":184,"tag":193,"props":247,"children":248},{},[249],{"type":190,"value":250},"未结构化输出导致频繁的下游系统异常，例如 JSON 解析失败、字段缺失或类型错误。这迫使开发团队投入大量时间编写额外的文本解析逻辑，不仅拖慢迭代速度，还因隐性错误引发生产事故。同时，手动调试非结构化文本的过程不可重复，增加了系统维护的不确定性。",{"type":184,"tag":216,"props":252,"children":254},{"id":253},"长期结构性风险",[255],{"type":190,"value":253},{"type":184,"tag":193,"props":257,"children":258},{},[259],{"type":190,"value":260},"若持续依赖非结构化输出，技术债务将快速积累：数据契约缺乏一致性会阻碍微服务间协作，测试覆盖率不足导致问题在生产阶段才暴露。更严重的是，当业务逻辑依赖复杂文本处理时，系统扩展性和可维护性将受制约，长期可能成为技术演进的瓶颈。",{"type":184,"tag":210,"props":262,"children":264},{"id":263},"模式与原理",[265],{"type":190,"value":263},{"type":184,"tag":216,"props":267,"children":269},{"id":268},"核心机制",[270],{"type":190,"value":268},{"type":184,"tag":193,"props":272,"children":273},{},[274],{"type":190,"value":275},"结构化输出的核心是通过语法约束将 LLM 输出控制在预定义 Schema 内，确保每次生成都符合机器可读格式。这并非简单文本过滤，而是将 LLM 的生成过程转化为确定性数据生产——基于输入约束强制输出格式正确，而非依赖后期修复。",{"type":184,"tag":216,"props":277,"children":279},{"id":278},"关键工具与角色",[280],{"type":190,"value":278},{"type":184,"tag":193,"props":282,"children":283},{},[284,286,293],{"type":190,"value":285},"主要实现方式包括：提示工程（通过指令引导格式化输出）、模型原生支持（如 OpenAI 的 ",{"type":184,"tag":287,"props":288,"children":290},"code",{"className":289},[],[291],{"type":190,"value":292},"response_format",{"type":190,"value":294}," 参数），以及高级工具如 Outlines 和 Instructor。这些工具通过有限状态机（FSM）动态验证输出结构，在解码阶段实时约束词元选择，从源头保证有效性。关键角色涉及提示工程师（设计 Schema）、后端开发者（定义数据契约）和 SRE（监控输出合规性）。",{"type":184,"tag":210,"props":296,"children":298},{"id":297},"对比与演进",[299],{"type":190,"value":297},{"type":184,"tag":216,"props":301,"children":303},{"id":302},"传统方法-vs-结构化输出",[304],{"type":190,"value":305},"传统方法 vs 结构化输出",{"type":184,"tag":307,"props":308,"children":309},"ul",{},[310,322],{"type":184,"tag":311,"props":312,"children":313},"li",{},[314,320],{"type":184,"tag":315,"props":316,"children":317},"strong",{},[318],{"type":190,"value":319},"传统方式",{"type":190,"value":321},"：依赖文本解析（如正则表达式或 NLP 模型），需额外开发校验层，处理步骤多且易漏边界情况（如嵌套结构或特殊字符）。典型风险是解析逻辑与 LLM 输出漂移，导致系统间断性故障。",{"type":184,"tag":311,"props":323,"children":324},{},[325,329],{"type":184,"tag":315,"props":326,"children":327},{},[328],{"type":190,"value":179},{"type":190,"value":330},"：直接生成机器可读数据，减少中间转换层。例如，用 Schema 定义字段类型后，LLM 输出自动符合约定，无需额外解析代码。这显著降低错误率，提升端到端可靠性。",{"type":184,"tag":216,"props":332,"children":334},{"id":333},"演进趋势",[335],{"type":190,"value":333},{"type":184,"tag":193,"props":337,"children":338},{},[339],{"type":190,"value":340},"从简单提示格式化向工具化、自动化演进：初期仅用提示词约束，但难以处理复杂结构；当前主流方案结合工具（如 Outlines）的 FSM 约束，支持嵌套 JSON 或类实例生成；未来可能深度集成到 LLM 框架层，实现 Schema 驱动的训练微调，进一步降低使用门槛。",{"type":184,"tag":210,"props":342,"children":344},{"id":343},"系统影响",[345],{"type":190,"value":343},{"type":184,"tag":216,"props":347,"children":349},{"id":348},"架构一致性与工程效率",[350],{"type":190,"value":348},{"type":184,"tag":193,"props":352,"children":353},{},[354],{"type":190,"value":355},"结构化输出能统一数据契约，减少微服务间的数据转换层，提升系统整体一致性。工程效率方面：下游业务逻辑可直接消费结构化数据，省去解析环节，加速开发迭代；同时简化测试用例设计（只需验证 Schema 合规性而非文本解析逻辑）。",{"type":184,"tag":216,"props":357,"children":359},{"id":358},"技术治理与安全考量",[360],{"type":190,"value":358},{"type":184,"tag":193,"props":362,"children":363},{},[364],{"type":190,"value":365},"在技术栈治理上，需建立统一的 Schema 管理规范（如通过 JSON Schema 注册中心），避免各团队各自为政。安全层面：结构化输出减少注入攻击风险（如 XML/JSON 处理漏洞），但需警惕 Schema 设计缺陷——若未严格校验输入字段，可能引入数据泄漏或格式化漏洞。",{"type":184,"tag":210,"props":367,"children":369},{"id":368},"落地实践建议",[370],{"type":190,"value":368},{"type":184,"tag":216,"props":372,"children":374},{"id":373},"适用场景界定",[375],{"type":190,"value":373},{"type":184,"tag":193,"props":377,"children":378},{},[379],{"type":190,"value":380},"适用于需高可靠性结构化数据的场景：如文档信息提取、表单生成、API 响应构造或数据管道初始化。不适用于创作型任务（如自由文本生成、创意内容），因结构化约束会牺牲输出多样性。团队协作阶段需注意：当 LLM 输出直接关联核心业务逻辑时，结构化输出价值最高；若仅为简单查询结果，则优先考虑轻量级方案。",{"type":184,"tag":216,"props":382,"children":384},{"id":383},"实施步骤与风险规避",[385],{"type":190,"value":383},{"type":184,"tag":307,"props":387,"children":388},{},[389,399,427],{"type":184,"tag":311,"props":390,"children":391},{},[392,397],{"type":184,"tag":315,"props":393,"children":394},{},[395],{"type":190,"value":396},"实施路径",{"type":190,"value":398},"：先定义下游需要的 Schema（如 JSON Schema），用简单提示测试基础格式；逐步引入工具（Instructor 或 Outlines）处理复杂结构，最终集成到 CI/CD 管道进行自动化验证。",{"type":184,"tag":311,"props":400,"children":401},{},[402,407,409],{"type":184,"tag":315,"props":403,"children":404},{},[405],{"type":190,"value":406},"关键风险规避",{"type":190,"value":408},"：\n",{"type":184,"tag":307,"props":410,"children":411},{},[412,417,422],{"type":184,"tag":311,"props":413,"children":414},{},[415],{"type":190,"value":416},"Schema 设计错误可能导致输出无效，必须通过边界测试覆盖极端输入（如超长字段、非法字符）；",{"type":184,"tag":311,"props":418,"children":419},{},[420],{"type":190,"value":421},"性能开销：受限解码可能增加推理延迟，需监控生成耗时并设置超时阈值；",{"type":184,"tag":311,"props":423,"children":424},{},[425],{"type":190,"value":426},"工具依赖风险：避免过度耦合特定工具（如 Outlines），保持 Schema 定义与实现解耦，便于后续迁移。",{"type":184,"tag":311,"props":428,"children":429},{},[430,435],{"type":184,"tag":315,"props":431,"children":432},{},[433],{"type":190,"value":434},"落地建议",{"type":190,"value":436},"：从小规模试点开始（如单个文档处理流程），监控输出合规率和系统错误指标；建立 Schema 审查机制，确保与业务需求对齐后再推广。",{"title":178,"searchDepth":438,"depth":438,"links":439},2,[440,441],{"id":187,"depth":438,"text":191},{"id":205,"depth":438,"text":208,"children":442},[443,445,446,447,448,449],{"id":212,"depth":444,"text":212},3,{"id":238,"depth":444,"text":238},{"id":263,"depth":444,"text":263},{"id":297,"depth":444,"text":297},{"id":343,"depth":444,"text":343},{"id":368,"depth":444,"text":368},"markdown","content:6.maps:_ai:llm:structured-output.md","content","6.maps/_ai/llm/structured-output.md","6.maps/_ai/llm/structured-output","md",[457,461],{"_path":458,"title":459,"description":460},"/maps/_ai/llm/slm","小型语言模型（SLM）","small language models related",{"_path":462,"title":463,"description":464},"/maps/_ai/mcp/mcp","Model Context Protocol","MCP（Model Context Protocol）是 Anthropic 开源的标准协议，用于连接 AI 应用与外部系统，被誉为 AI 应用的 USB-C 接口。",1771690631504]