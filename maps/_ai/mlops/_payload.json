5,241,246,273,279,284,295,301,306],{"type":184,"tag":185,"props":186,"children":188},"element","h1",{"id":187},"mlops",[189],{"type":190,"value":179},"text",{"type":184,"tag":192,"props":193,"children":195},"h2",{"id":194},"weights-biases商业-mlops-平台事实标准",[196],{"type":190,"value":197},"Weights & Biases：商业 MLOps 平台事实标准",{"type":184,"tag":199,"props":200,"children":201},"p",{},[202],{"type":190,"value":203},"W&B 是商业 MLOps 平台的事实标准，提供实验跟踪、超参搜索、模型管理、协作报告等一站式能力。核心功能包括自动记录超参/指标/输出、Artifact 版本追踪、Sweeps 分布式超参搜索、交互式实验报告。是 LLM 微调实验跟踪的首选工具。",{"type":184,"tag":199,"props":205,"children":206},{},[207,209,218,220,227,228],{"type":190,"value":208},"见：",{"type":184,"tag":210,"props":211,"children":215},"a",{"href":212,"rel":213},"https://wandb.ai/",[214],"nofollow",[216],{"type":190,"value":217},"W&B 官网",{"type":190,"value":219}," | ",{"type":184,"tag":210,"props":221,"children":224},{"href":222,"rel":223},"https://wandb.ai/site/solutions/llm-fine-tuning/",[214],[225],{"type":190,"value":226},"W&B LLM 专项功能",{"type":190,"value":219},{"type":184,"tag":210,"props":229,"children":232},{"href":230,"rel":231},"https://wandb.ai/site/experiment-tracking/",[214],[233],{"type":190,"value":234},"W&B 实验跟踪",{"type":184,"tag":192,"props":236,"children":238},{"id":237},"mlflow开源-ml-生命周期管理",[239],{"type":190,"value":240},"MLflow：开源 ML 生命周期管理",{"type":184,"tag":199,"props":242,"children":243},{},[244],{"type":190,"value":245},"MLflow 是 Databricks 开源的 MLOps 平台，模块化设计可独立使用各组件：Tracking（实验记录）、Projects（可复现工作流打包）、Models（模型格式标准化）、Registry（模型版本管理）。完全开源、自建托管，适合需要数据主权和成本控制的企业。",{"type":184,"tag":199,"props":247,"children":248},{},[249,250,257,258,265,266],{"type":190,"value":208},{"type":184,"tag":210,"props":251,"children":254},{"href":252,"rel":253},"https://mlflow.org/",[214],[255],{"type":190,"value":256},"MLflow 官网",{"type":190,"value":219},{"type":184,"tag":210,"props":259,"children":262},{"href":260,"rel":261},"https://mlflow.org/docs/latest/ml/model-registry/",[214],[263],{"type":190,"value":264},"MLflow Model Registry",{"type":190,"value":219},{"type":184,"tag":210,"props":267,"children":270},{"href":268,"rel":269},"https://github.com/mlflow/mlflow",[214],[271],{"type":190,"value":272},"MLflow GitHub",{"type":184,"tag":192,"props":274,"children":276},{"id":275},"tensorboard基础可视化工具",[277],{"type":190,"value":278},"TensorBoard：基础可视化工具",{"type":184,"tag":199,"props":280,"children":281},{},[282],{"type":190,"value":283},"TensorBoard 是 TensorFlow 配套的可视化工具，也支持 PyTorch（通过 torch.utils.tensorboard）。适合小规模实验快速可视化、训练曲线和学习率监控、嵌入向量降维可视化。轻量易用，是调试训练过程的常用工具。",{"type":184,"tag":199,"props":285,"children":286},{},[287,288],{"type":190,"value":208},{"type":184,"tag":210,"props":289,"children":292},{"href":290,"rel":291},"https://www.tensorflow.org/tensorboard",[214],[293],{"type":190,"value":294},"TensorBoard 文档",{"type":184,"tag":192,"props":296,"children":298},{"id":297},"llm-专项-mlops-挑战",[299],{"type":190,"value":300},"LLM 专项 MLOps 挑战",{"type":184,"tag":199,"props":302,"children":303},{},[304],{"type":190,"value":305},"LLM 带来独特挑战：模型文件巨大（7B 模型 14GB，版本管理困难）、训练周期长（需要断点续训和容错）、评估复杂（多维度基准测试）、对齐流程多阶段（SFT → DPO → RLHF）。解决方案包括模型注册表（MLflow Model Registry、W&B Artifacts）、分布式跟踪（Ray Train + W&B 集成）、评估集成（lm-eval-harness 结果自动记录）、Prompt 版本管理（W&B Prompts）。",{"type":184,"tag":199,"props":307,"children":308},{},[309,310,317,318],{"type":190,"value":208},{"type":184,"tag":210,"props":311,"children":314},{"href":312,"rel":313},"https://github.com/tensorchord/Awesome-LLMOps",[214],[315],{"type":190,"value":316},"LLMOps 工具集",{"type":190,"value":219},{"type":184,"tag":210,"props":319,"children":322},{"href":320,"rel":321},"https://www.datacamp.com/blog/top-mlops-tools",[214],[323],{"type":190,"value":324},"2025 MLOps 工具榜单",{"title":178,"searchDepth":326,"depth":326,"links":327},2,[328,329,330,331],{"id":194,"depth":326,"text":197},{"id":237,"depth":326,"text":240},{"id":275,"depth":326,"text":278},{"id":297,"depth":326,"text":300},"markdown","content:6.maps:_ai:mlops.md","content","6.maps/_ai/mlops.md",