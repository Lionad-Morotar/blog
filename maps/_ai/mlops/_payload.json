82,"props":183,"children":185},"element","h1",{"id":184},"mlops",[186],{"type":187,"value":176},"text",{"type":181,"tag":189,"props":190,"children":192},"h2",{"id":191},"weights-biases商业-mlops-平台事实标准",[193],{"type":187,"value":194},"Weights & Biases：商业 MLOps 平台事实标准",{"type":181,"tag":196,"props":197,"children":198},"p",{},[199],{"type":187,"value":200},"W&B 是商业 MLOps 平台的事实标准，提供实验跟踪、超参搜索、模型管理、协作报告等一站式能力。核心功能包括自动记录超参/指标/输出、Artifact 版本追踪、Sweeps 分布式超参搜索、交互式实验报告。是 LLM 微调实验跟踪的首选工具。",{"type":181,"tag":196,"props":202,"children":203},{},[204,206,215,217,224,225],{"type":187,"value":205},"见：",{"type":181,"tag":207,"props":208,"children":212},"a",{"href":209,"rel":210},"https://wandb.ai/",[211],"nofollow",[213],{"type":187,"value":214},"W&B 官网",{"type":187,"value":216}," | ",{"type":181,"tag":207,"props":218,"children":221},{"href":219,"rel":220},"https://wandb.ai/site/solutions/llm-fine-tuning/",[211],[222],{"type":187,"value":223},"W&B LLM 专项功能",{"type":187,"value":216},{"type":181,"tag":207,"props":226,"children":229},{"href":227,"rel":228},"https://wandb.ai/site/experiment-tracking/",[211],[230],{"type":187,"value":231},"W&B 实验跟踪",{"type":181,"tag":189,"props":233,"children":235},{"id":234},"mlflow开源-ml-生命周期管理",[236],{"type":187,"value":237},"MLflow：开源 ML 生命周期管理",{"type":181,"tag":196,"props":239,"children":240},{},[241],{"type":187,"value":242},"MLflow 是 Databricks 开源的 MLOps 平台，模块化设计可独立使用各组件：Tracking（实验记录）、Projects（可复现工作流打包）、Models（模型格式标准化）、Registry（模型版本管理）。完全开源、自建托管，适合需要数据主权和成本控制的企业。",{"type":181,"tag":196,"props":244,"children":245},{},[246,247,254,255,262,263],{"type":187,"value":205},{"type":181,"tag":207,"props":248,"children":251},{"href":249,"rel":250},"https://mlflow.org/",[211],[252],{"type":187,"value":253},"MLflow 官网",{"type":187,"value":216},{"type":181,"tag":207,"props":256,"children":259},{"href":257,"rel":258},"https://mlflow.org/docs/latest/ml/model-registry/",[211],[260],{"type":187,"value":261},"MLflow Model Registry",{"type":187,"value":216},{"type":181,"tag":207,"props":264,"children":267},{"href":265,"rel":266},"https://github.com/mlflow/mlflow",[211],[268],{"type":187,"value":269},"MLflow GitHub",{"type":181,"tag":189,"props":271,"children":273},{"id":272},"tensorboard基础可视化工具",[274],{"type":187,"value":275},"TensorBoard：基础可视化工具",{"type":181,"tag":196,"props":277,"children":278},{},[279],{"type":187,"value":280},"TensorBoard 是 TensorFlow 配套的可视化工具，也支持 PyTorch（通过 torch.utils.tensorboard）。适合小规模实验快速可视化、训练曲线和学习率监控、嵌入向量降维可视化。轻量易用，是调试训练过程的常用工具。",{"type":181,"tag":196,"props":282,"children":283},{},[284,285],{"type":187,"value":205},{"type":181,"tag":207,"props":286,"children":289},{"href":287,"rel":288},"https://www.tensorflow.org/tensorboard",[211],[290],{"type":187,"value":291},"TensorBoard 文档",{"type":181,"tag":189,"props":293,"children":295},{"id":294},"llm-专项-mlops-挑战",[296],{"type":187,"value":297},"LLM 专项 MLOps 挑战",{"type":181,"tag":196,"props":299,"children":300},{},[301],{"type":187,"value":302},"LLM 带来独特挑战：模型文件巨大（7B 模型 14GB，版本管理困难）、训练周期长（需要断点续训和容错）、评估复杂（多维度基准测试）、对齐流程多阶段（SFT → DPO → RLHF）。解决方案包括模型注册表（MLflow Model Registry、W&B Artifacts）、分布式跟踪（Ray Train + W&B 集成）、评估集成（lm-eval-harness 结果自动记录）、Prompt 版本管理（W&B Prompts）。",{"type":181,"tag":196,"props":304,"children":305},{},[306,307,314,315],{"type":187,"value":205},{"type":181,"tag":207,"props":308,"children":311},{"href":309,"rel":310},"https://github.com/tensorchord/Awesome-LLMOps",[211],[312],{"type":187,"value":313},"LLMOps 工具集",{"type":187,"value":216},{"type":181,"tag":207,"props":316,"children":319},{"href":317,"rel":318},"https://www.datacamp.com/blog/top-mlops-tools",[211],[320],{"type":187,"value":321},"2025 MLOps 工具榜单",{"title":175,"searchDepth":323,"depth":323,"links":324},2,[325,326,327,328],{"id":191,"depth":323,"text":194},{"id":234,"depth":323,"text":237},{"id":272,"depth":323,"text":275},{"id":294,"depth":323,"text":297},"markdown","content:6.maps:_ai:mlops.md","content","6.maps/_ai/mlops.md","6.maps/_ai/mlops","md",[336,339],{"_path":337,"title"