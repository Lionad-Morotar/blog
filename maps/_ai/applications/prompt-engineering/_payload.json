ring","applications",false,true,"","提示工程","提示工程框架与工具，包括 DSPy、Instructor、Guidance、Outlines 等声明式提示编程方案。","_ai/prompt-engineering.md",{"type":183,"children":184,"toc":445},"root",[185,194,201,207,238,244,249,268,274,279,290,296,301,320,325,330,349,354,360,365,370,384,393,398,403,429,434],{"type":186,"tag":187,"props":188,"children":190},"element","h1",{"id":189},"提示工程-prompt-engineering",[191],{"type":192,"value":193},"text","提示工程 (Prompt Engineering)",{"type":186,"tag":195,"props":196,"children":198},"h2",{"id":197},"dspy声明式提示编程框架",[199],{"type":192,"value":200},"DSPy：声明式提示编程框架",{"type":186,"tag":202,"props":203,"children":204},"p",{},[205],{"type":192,"value":206},"DSPy 是斯坦福 NLP 团队开源的框架，将提示工程从\"手工调优\"转变为\"编程优化\"。核心抽象包括 Signature（声明输入输出语义）、Module（可组合的计算单元）、Optimizer（自动优化提示和权重）、Teleprompter（少样本示例编译器）。开发者只需描述任务逻辑，DSPy 自动优化提示词、选择示例、微调小模型，在多跳问答等任务上超越手工提示。",{"type":186,"tag":202,"props":208,"children":209},{},[210,212,221,223,230,231],{"type":192,"value":211},"见：",{"type":186,"tag":213,"props":214,"children":218},"a",{"href":215,"rel":216},"https://github.com/stanfordnlp/dspy",[217],"nofollow",[219],{"type":192,"value":220},"DSPy GitHub",{"type":192,"value":222}," | ",{"type":186,"tag":213,"props":224,"children":227},{"href":225,"rel":226},"https://dspy.ai/",[217],[228],{"type":192,"value":229},"DSPy 文档",{"type":192,"value":222},{"type":186,"tag":213,"props":232,"children":235},{"href":233,"rel":234},"https://arxiv.org/abs/2310.03714",[217],[236],{"type":192,"value":237},"DSPy 论文",{"type":186,"tag":195,"props":239,"children":241},{"id":240},"instructor结构化输出解析库",[242],{"type":192,"value":243},"Instructor：结构化输出解析库",{"type":186,"tag":202,"props":245,"children":246},{},[247],{"type":192,"value":248},"Instructor 基于 Pydantic 构建，解决 LLM 输出结构化的问题。通过定义数据模型类，自动将 LLM 的文本响应解析为强类型对象，内置重试、验证、流式处理。支持 OpenAI、Anthropic、Gemini 等主流模型，是生产环境中类型安全调用 LLM 的首选方案。",{"type":186,"tag":202,"props":250,"children":251},{},[252,253,260,261],{"type":192,"value":211},{"type":186,"tag":213,"props":254,"children":257},{"href":255,"rel":256},"https://github.com/jxnl/instructor",[217],[258],{"type":192,"value":259},"Instructor GitHub",{"type":192,"value":222},{"type":186,"tag":213,"props":262,"children":265},{"href":263,"rel":264},"https://python.useinstructor.com/",[217],[266],{"type":192,"value":267},"Instructor 文档",{"type":186,"tag":195,"props":269,"children":271},{"id":270},"guidance约束生成控制模板",[272],{"type":192,"value":273},"Guidance：约束生成控制模板",{"type":186,"tag":202,"props":275,"children":276},{},[277],{"type":192,"value":278},"Guidance 提供模板语法控制 LLM 的生成过程，支持在生成中强制特定格式（JSON、正则匹配）、动态选择分支、变量插值。通过控制流与生成交错，大幅减少无效输出和后续解析失败，适合需要严格输出格式的场景。",{"type":186,"tag":202,"props":280,"children":281},{},[282,283],{"type":192,"value":211},{"type":186,"tag":213,"props":284,"children":287},{"href":285,"rel":286},"https://github.com/guidance-ai/guidance",[217],[288],{"type":192,"value":289},"Guidance GitHub",{"type":186,"tag":195,"props":291,"children":293},{"id":292},"outlines可靠的文本结构化生成",[294],{"type":192,"value":295},"Outlines：可靠的文本结构化生成",{"type":186,"tag":202,"props":297,"children":298},{},[299],{"type":192,"value":300},"Outlines 通过预编译正则表达式或 JSON Schema 到高效索引结构，实现完全符合格式的生成。与 Guidance 相比更轻量、性能更高，支持批量生成和多种模型后端，是结构化生成的现代替代方案。",{"type":186,"tag":202,"props":302,"children":303},{},[304,305,312,313],{"type":192,"value":211},{"type":186,"tag":213,"props":306,"children":309},{"href":307,"rel":308},"https://github.com/outlines-dev/outlines",[217],[310],{"type":192,"value":311},"Outlines GitHub",{"type":192,"value":222},{"type":186,"tag":213,"props":314,"children":317},{"href":315,"rel":316},"https://dottxt-ai.github.io/outlines/",[217],[318],{"type":192,"value":319},"Outlines 文档",{"type":186,"tag":195,"props":321,"children":323},{"id":322},"工具选型指南",[324],{"type":192,"value":322},{"type":186,"tag":202,"props":326,"children":327},{},[328],{"type":192,"value":329},"选择取决于控制粒度：Instructor 适合\"解析已知格式的响应\"，Pydantic 验证确保类型安全；Guidance/Outlines 适合\"强制模型按格式生成\"，从源头约束输出结构。DSPy 则用于系统级优化，自动迭代提示策略。实际项目中常组合使用：Outlines 控制格式，Instructor 验证解析，DSPy 优化整体流程。",{"type":186,"tag":202,"props":331,"children":332},{},[333,334,341,342],{"type":192,"value":211},{"type":186,"tag":213,"props":335,"children":338},{"href":336,"rel":337},"https://www.linkedin.com/pulse/dspy-vs-instructor-pydantic-ai-which-one-right-you-answer-sancare-phdie",[217],[339],{"type":192,"value":340},"DSPy vs Instructor 对比",{"type":192,"value":222},{"type":186,"tag":213,"props":343,"children":346},{"href":344,"rel":345},"https://github.com/outlines-dev/outlines/blob/main/benchmarks/benchmark_readme.md",[217],[347],{"type":192,"value":348},"Outlines vs Guidance 性能对比",{"type":186,"tag":195,"props":350,"children":352},{"id":351},"提示工程实践技巧",[353],{"type":192,"value":351},{"type":186,"tag":355,"props":356,"children":358},"h4",{"id":357},"利用上下文窗口优于依赖模型记忆",[359],{"type":192,"value":357},{"type":186,"tag":202,"props":361,"children":362},{},[363],{"type":192,"value":364},"当需要模型处理特定内容时，直接将其粘贴到提示中，而非依赖模型的\"知识\"。例如，与其问\"总结《傲慢与偏见》第一章\"，不如将第一章文本粘贴到提示中再要求总结。当内容在上下文窗口中时，模型拥有直接访问权，生成的质量显著高于依赖记忆召回。",{"type":186,"tag":355,"props":366,"children":368},{"id":367},"使用分隔符组织多部分输入",[369],{"type":192,"value":367},{"type":186,"tag":202,"props":371,"children":372},{},[373,375,382],{"type":192,"value":374},"当提示包含多个部分（指令、背景、参考资料）时，使用清晰的分隔符（如 ",{"type":186,"tag":376,"props":377,"children":379},"code",{"className":378},[],[380],{"type":192,"value":381},"---",{"type":192,"value":383},"、XML 标签）帮助模型区分不同区域：",{"type":186,"tag":385,"props":386,"children":388},"pre",{"code":387},"请总结以下文本：\n\n---\n[粘贴的文本内容]\n---\n",[389],{"type":186,"tag":376,"props":390,"children":391},{"__ignoreMap":178},[392],{"type":192,"value":387},{"type":186,"tag":355,"props":394,"children":396},{"id":395},"思考型模型的选择策略",[397],{"type":192,"value":395},{"type":186,"tag":202,"props":399,"children":400},{},[401],{"type":192,"value":402},"不同模型适合不同任务类型：",{"type":186,"tag":404,"props":405,"children":406},"ul",{},[407,419],{"type":186,"tag":408,"props":409,"children":410},"li",{},[411,417],{"type":186,"tag":412,"props":413,"children":414},"strong",{},[415],{"type":192,"value":416},"普通模型（GPT-4o、Claude Sonnet）",{"type":192,"value":418},"：适合创意写作、一般问答、日常对话",{"type":186,"tag":408,"props":420,"children":421},{},[422,427],{"type":186,"tag":412,"props":423,"children":424},{},[425],{"type":192,"value":426},"思考型模型（o3-mini、o1）",{"type":192,"value":428},"：适合数学、代码、逻辑推理等需要深度思考的任务",{"type":186,"tag":202,"props":430,"children":431},{},[432],{"type":192,"value":433},"思考型模型通过强化学习训练，会在回答前进行内部\"思考链\"推理。但对于创意类任务，这种思考不一定带来提升，反而可能让输出显得过于机械。",{"type":186,"tag":202,"props":435,"children":436},{},[437,438],{"type":192,"value":211},{"type":186,"tag":213,"props":439,"children":442},{"href":440,"rel":441},"https://www.youtube.com/watch?v=EWvNQjAaOHw",[217],[443],{"type":192,"value":444},"How I use LLM - Andrej Karpathy",{"title":178,"searchDepth":446,"depth":446,"links":447},2,[448,449,450,451,452,453],{"id":197,"depth":446,"text":200},{"id":240,"depth":446,"text":243},{"id":270,"depth":446,"text":273},{"id":292,"depth":446,"text":295},{"id":322,"depth":446,"text":322},{"id":351,"depth":446,"text":351},"markdown","content:6.maps:_ai:applications:prompt-engineering.md","content","6.maps/_ai/applications/prompt-engineering.md","6.maps/_ai/applications/prompt-engineering","md",[461,465],{"_path":462,"title":463,"description":464},"/maps/_ai/applications/paper-writing","ML 论文写作","机器学习学术论文写作指南，包括 LaTeX 工具、文献管理与可复现性实践。",{"_path":466,"title":467,"description":468},"/maps/_ai/benchmark/benchmark","LLM Benchmark","各类大语言模型的基准测试结果与排行榜资源。",1772504959383]