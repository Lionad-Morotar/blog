",[183,191,198,204,235,241,246,273,279,284,303,309,314,325,330,335],{"type":184,"tag":185,"props":186,"children":188},"element","h1",{"id":187},"推理-inference",[189],{"type":190,"value":179},"text",{"type":184,"tag":192,"props":193,"children":195},"h2",{"id":194},"vllmpagedattention-高吞吐服务框架",[196],{"type":190,"value":197},"vLLM：PagedAttention 高吞吐服务框架",{"type":184,"tag":199,"props":200,"children":201},"p",{},[202],{"type":190,"value":203},"vLLM 由伯克利 Sky Computing Lab 开发，核心贡献是 PagedAttention 技术。借鉴操作系统的虚拟内存分页机制，将 KV Cache 分块管理，实现近 100% 的内存利用率（传统实现仅 20-40%）。支持 Continuous Batching（动态批处理）和流水线并行，吞吐提升 2-4 倍，是开源 LLM 服务的事实标准，全球超过 40 万 GPU 部署。",{"type":184,"tag":199,"props":205,"children":206},{},[207,209,218,220,227,228],{"type":190,"value":208},"见：",{"type":184,"tag":210,"props":211,"children":215},"a",{"href":212,"rel":213},"https://github.com/vllm-project/vllm",[214],"nofollow",[216],{"type":190,"value":217},"vLLM GitHub",{"type":190,"value":219}," | ",{"type":184,"tag":210,"props":221,"children":224},{"href":222,"rel":223},"https://dl.acm.org/doi/10.1145/3600006.3613165",[214],[225],{"type":190,"value":226},"PagedAttention 论文",{"type":190,"value":219},{"type":184,"tag":210,"props":229,"children":232},{"href":230,"rel":231},"https://github.com/vllm-project/vllm/issues/20336",[214],[233],{"type":190,"value":234},"vLLM 1.0 路线图",{"type":184,"tag":192,"props":236,"children":238},{"id":237},"sglang结构化生成语言运行时",[239],{"type":190,"value":240},"SGLang：结构化生成语言运行时",{"type":184,"tag":199,"props":242,"children":243},{},[244],{"type":190,"value":245},"SGLang 是伯克利推出的新一代推理框架，特色是结构化生成语言——用编程方式定义 LLM 调用流程，自动批处理多个请求。核心创新 RadixAttention 跨多个 LLM 生成调用自动高效重用 KV 缓存。社区测试显示在某些场景下吞吐比 vLLM 高 50-150%，特别是在多轮对话和结构化输出场景。xAI 生产环境部署超过 10 万 GPU。",{"type":184,"tag":199,"props":247,"children":248},{},[249,250,257,258,265,266],{"type":190,"value":208},{"type":184,"tag":210,"props":251,"children":254},{"href":252,"rel":253},"https://github.com/sgl-project/sglang",[214],[255],{"type":190,"value":256},"SGLang GitHub",{"type":190,"value":219},{"type":184,"tag":210,"props":259,"children":262},{"href":260,"rel":261},"https://arxiv.org/abs/2312.07104",[214],[263],{"type":190,"value":264},"SGLang 论文",{"type":190,"value":219},{"type":184,"tag":210,"props":267,"children":270},{"href":268,"rel":269},"https://lmsys.org/blog/2024-01-17-sglang/",[214],[271],{"type":190,"value":272},"RadixAttention 介绍",{"type":184,"tag":192,"props":274,"children":276},{"id":275},"llamacpp本地-cpugpu-推理引擎",[277],{"type":190,"value":278},"llama.cpp：本地 CPU/GPU 推理引擎",{"type":184,"tag":199,"props":280,"children":281},{},[282],{"type":190,"value":283},"llama.cpp 是纯 C++ 实现的推理引擎，目标是让 LLM 能在消费级硬件上运行。支持 ARM NEON、AVX 指令集优化，GGUF 格式量化（Q4 到 Q8），跨平台（Windows、macOS、Linux、iOS、Android），无依赖单二进制文件即可运行。是本地开发测试、边缘设备部署、隐私敏感应用的首选方案。",{"type":184,"tag":199,"props":285,"children":286},{},[287,288,295,296],{"type":190,"value":208},{"type":184,"tag":210,"props":289,"children":292},{"href":290,"rel":291},"https://github.com/ggml-org/llama.cpp",[214],[293],{"type":190,"value":294},"llama.cpp GitHub",{"type":190,"value":219},{"type":184,"tag":210,"props":297,"children":300},{"href":298,"rel":299},"https://medium.com/@nikheelvs/running-llms-on-edge-devices-a-step-by-step-guide-8cf1b3d74193",[214],[301],{"type":190,"value":302},"llama.cpp 边缘部署",{"type":184,"tag":192,"props":304,"children":306},{"id":305},"tensorrt-llmnvidia-推理优化库",[307],{"type":190,"value":308},"TensorRT-LLM：NVIDIA 推理优化库",{"type":184,"tag":199,"props":310,"children":311},{},[312],{"type":190,"value":313},"TensorRT-LLM 是 NVIDIA 的闭源推理优化方案，针对自家 GPU 深度优化：Kernel 融合减少显存带宽瓶颈，FP8 支持 Hopper GPU 原生低精度推理，In-flight Batching 更激进的批处理策略。在 NVIDIA GPU 上吞吐最高，但仅支持 NVIDIA 且配置复杂，适合追求极致性能且有工程投入能力的场景。",{"type":184,"tag":199,"props":315,"children":316},{},[317,318],{"type":190,"value":208},{"type":184,"tag":210,"props":319,"children":322},{"href":320,"rel":321},"https://developer.nvidia.com/tensorrt-llm",[214],[323],{"type":190,"value":324},"TensorRT-LLM 文档",{"type":184,"tag":192,"props":326,"children":328},{"id":327},"推理框架选择指南",[329],{"type":190,"value":327},{"type":184,"tag":199,"props":331,"children":332},{},[333],{"type":190,"value":334},"vLLM 是通用在线服务的首选，易用性高且吞吐优秀；TensorRT-LLM 适合极致性能需求但仅支持 NVIDIA；llama.cpp 是本地/边缘部署的标准，跨平台且轻量；SGLang 在结构化生成和多轮对话场景表现突出。选择应权衡延迟、吞吐、易用性、硬件限制和具体应用场景。",{"type":184,"tag":199,"props":336,"children":337},{},[338,339,346,347],{"type":190,"value":208},{"type":184,"tag":210,"props":340,"children":343},{"href":341,"rel":342},"https://www.arxiv.org/pdf/2505.01658v1",[214],[344],{"type":190,"value":345},"LLM 推理框架综述",{"type":190,"value":219},{"type":184,"tag":210,"props":348,"children":351},{"href":349,"rel":350},"https://tensorfuse.io/blog/llm-throughput-vllm-vs-sglang",[214],[352],{"type":190,"value":353},"vLLM vs SGLang 对比",{"title":178,"searchDepth":355,"depth":355,"links":356},2,[357,358,359,360,361],{"id":194,"depth":355,"text":197},{"id":237,"depth":355,"text":240},{"id":275,"depth":355,"text":278},{"id":305,"depth":355,"text":308},{"id":327,"depth":355,"text":327},"markdown","content:6.maps:_ai:inference.md","content","6.maps/_ai/inference.md","6.maps/_ai/inference","md",[369,372],{"_path":370,"title":371,"description":178},"/maps/_ai/image/stable-diffusion","Image Generator",{"_path":373,"title":374,"description":178},"/maps/_ai/infrastructure","基础设施 (Infrastructure)",1771693743247]