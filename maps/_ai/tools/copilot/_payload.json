38,251,257,266,323,328,336,341,348,355,360,367,372,379,385,396,405,417,431,436,459,467],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"domain",[187],{"type":188,"value":189},"text","Domain",{"type":182,"tag":191,"props":192,"children":193},"ul",{},[194,205],{"type":182,"tag":195,"props":196,"children":197},"li",{},[198],{"type":182,"tag":199,"props":200,"children":202},"a",{"href":201},"/maps/_ai/prompt/team-based-instructions",[203],{"type":188,"value":204},"Team based Instructions",{"type":182,"tag":195,"props":206,"children":207},{},[208],{"type":182,"tag":199,"props":209,"children":211},{"href":210},"/maps/_ai/prompt/context-engineering",[212],{"type":188,"value":213},"Context Engineering",{"type":182,"tag":183,"props":215,"children":217},{"id":216},"cross-domain",[218],{"type":188,"value":219},"Cross Domain",{"type":182,"tag":191,"props":221,"children":222},{},[223],{"type":182,"tag":195,"props":224,"children":225},{},[226],{"type":182,"tag":199,"props":227,"children":229},{"href":228},"/maps/_programming/dx/genai-for-legacy-codebases",[230],{"type":188,"value":231},"GenAI for Legacy Codebases",{"type":182,"tag":183,"props":233,"children":235},{"id":234},"gists",[236],{"type":188,"value":237},"Gists",{"type":182,"tag":239,"props":240,"children":242},"h4",{"id":241},"团队-ai-编码率稳步提升到-892-的-ai-coding-实践分享",[243],{"type":182,"tag":199,"props":244,"children":248},{"href":245,"rel":246},"https://mp.weixin.qq.com/s/dq87Orqr8SyeyECZg3BMfA",[247],"nofollow",[249],{"type":188,"value":250},"团队 AI 编码率稳步提升到 89.2% 的 AI Coding 实践分享",{"type":182,"tag":252,"props":253,"children":254},"p",{},[255],{"type":188,"value":256},"饿了么团队把 AI 编码采纳率从 9.6% 提到 89.2%，需求交付效率提升 23.6%。",{"type":182,"tag":252,"props":258,"children":259},{},[260],{"type":182,"tag":261,"props":262,"children":263},"q",{},[264],{"type":188,"value":265},"幻觉是AI的天性，不可避免，只能尽量减少。而我们要的是AI给我们生成确定性的、高质量的内容。这就需要从两方面入手，一方面需要保障我们输入给AI的内容质量；另一方面我们需要提出规范及要求让AI按照我们的预期生成内容，保障AI输出给我们的质量。",{"type":182,"tag":191,"props":267,"children":268},{},[269,287,305],{"type":182,"tag":195,"props":270,"children":271},{},[272,274],{"type":188,"value":273},"统一上下文",{"type":182,"tag":191,"props":275,"children":276},{},[277,282],{"type":182,"tag":195,"props":278,"children":279},{},[280],{"type":188,"value":281},"三层架构模板：数据-逻辑-应用层固定目录结构，先让 AI 生成“地图”再写代码。",{"type":182,"tag":195,"props":283,"children":284},{},[285],{"type":188,"value":286},"技术方案模版：把需求拆成“领域功能+应用服务+业务规则+数据模型”四格表，人工只填业务，其余交给 AI。",{"type":182,"tag":195,"props":288,"children":289},{},[290,292],{"type":188,"value":291},"结构化 Prompt",{"type":182,"tag":191,"props":293,"children":294},{},[295,300],{"type":182,"tag":195,"props":296,"children":297},{},[298],{"type":188,"value":299},"分层提示：按“架构层-模块-类-函数”四级写要求，不含任何业务词，保证跨需求复用。",{"type":182,"tag":195,"props":301,"children":302},{},[303],{"type":188,"value":304},"增量调优：每周收一次 bad case，把新规则写进 Prompt，版本号随 CI 自动升级。",{"type":182,"tag":195,"props":306,"children":307},{},[308,310],{"type":188,"value":309},"任务粒度控制",{"type":182,"tag":191,"props":311,"children":312},{},[313,318],{"type":182,"tag":195,"props":314,"children":315},{},[316],{"type":188,"value":317},"类级单元：一次请求只生成一个完整类，过大再拆接口-实现两份。",{"type":182,"tag":195,"props":319,"children":320},{},[321],{"type":188,"value":322},"先方案后代码：PRD→AI 生成技术方案→人工 Review→AI 按方案写代码，防止幻觉跑偏。",{"type":182,"tag":252,"props":324,"children":325},{},[326],{"type":188,"value":327},"阶段总结，形成了一套高质量的体系化的AI+Prompt+技术方案模版+工程结构的AI编码方案。",{"type":182,"tag":252,"props":329,"children":330},{},[331],{"type":182,"tag":332,"props":333,"children":335},"img",{"alt":175,"src":334},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20251204113817450.png",[],{"type":182,"tag":252,"props":337,"children":338},{},[339],{"type":188,"value":340},"接口类提示词设计：",{"type":182,"tag":252,"props":342,"children":343},{},[344],{"type":182,"tag":332,"props":345,"children":347},{"alt":175,"src":346},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20251204114413996.png",[],{"type":182,"tag":252,"props":349,"children":350},{},[351],{"type":182,"tag":332,"props":352,"children":354},{"alt":175,"src":353},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20251204114154426.png",[],{"type":182,"tag":252,"props":356,"children":357},{},[358],{"type":188,"value":359},"修改类需求示例：",{"type":182,"tag":252,"props":361,"children":362},{},[363],{"type":182,"tag":332,"props":364,"children":366},{"alt":175,"src":365},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20251204114245732.png",[],{"type":182,"tag":252,"props":368,"children":369},{},[370],{"type":188,"value":371},"修改类需求生成结果：",{"type":182,"tag":252,"props":373,"children":374},{},[375],{"type":182,"tag":332,"props":376,"children":378},{"alt":175,"src":377},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20251204114023507.png",[],{"type":182,"tag":239,"props":380,"children":382},{"id":381},"why-test-driven-development-and-pair-programming-are-perfect-companions-for-github-copilot",[383],{"type":188,"value":384},"Why test-driven development and pair programming are perfect companions for GitHub Copilot",{"type":182,"tag":252,"props":386,"children":387},{},[388,390],{"type":188,"value":389},"为什么测试驱动开发和结对编程是 GitHub Copilot 的完美伴侣，Source: ",{"type":182,"tag":199,"props":391,"children":394},{"href":392,"rel":393},"https://www.thoughtworks.com/insights/blog/generative-ai/tdd-and-pair-programming-the-perfect-companions-for-copilot",[247],[395],{"type":188,"value":384},{"type":182,"tag":397,"props":398,"children":399},"blockquote",{},[400],{"type":182,"tag":252,"props":401,"children":402},{},[403],{"type":188,"value":404},"Context poisoning, Automation Bias, Sunk Cost Fallacy, Anchoring Effect and Auto-completion on steroids. We term these incorrect behaviors AI 'smells'.",{"type":182,"tag":252,"props":406,"children":407},{},[408,410],{"type":188,"value":409},"代码中的 AI 味，",{"type":182,"tag":199,"props":411,"children":414},{"href":412,"rel":413},"https://martinfowler.com/articles/exploring-gen-ai.html#memo-04",[247],[415],{"type":188,"value":416},"Exploring Generative AI",{"type":182,"tag":418,"props":419,"children":420},"ol",{},[421,426],{"type":182,"tag":195,"props":422,"children":423},{},[424],{"type":188,"value":425},"放大不良或过时的做法，Amplification of bad or outdated practices",{"type":182,"tag":195,"props":427,"children":428},{},[429],{"type":188,"value":430},"回顾疲劳和自满，Review fatigue and complacency",{"type":182,"tag":252,"props":432,"children":433},{},[434],{"type":188,"value":435},"作者给这两个现象提供了非常有意思的重命名，并带来了新的现象模式：",{"type":182,"tag":418,"props":437,"children":438},{},[439,444,449,454],{"type":182,"tag":195,"props":440,"children":441},{},[442],{"type":188,"value":443},"上下文中毒，Context poisoning: continues to suggest stale implementations or bad patterns.",{"type":182,"tag":195,"props":445,"children":446},{},[447],{"type":188,"value":448},"类固醇自动完成，Auto-completion on steroids: This refers to the unfortunate tendency to switch off the brain and accept everything, in an infinite Tab/Enter loop.",{"type":182,"tag":195,"props":450,"children":451},{},[452],{"type":188,"value":453},"沉没成本谬误，Sunk-cost fallacy: we’re hesitant to delete GitHub Copilot generated code, even though coding an alternative from scratch would yield a better long-term solution.",{"type":182,"tag":195,"props":455,"children":456},{},[457],{"type":188,"value":458},"锚定效果，Anchoring effect: we find it harder to develop alternative code implementations once we’ve seen a suggestion from Copilot.",{"type":182,"tag":397,"props":460,"children":461},{},[462],{"type":182,"tag":252,"props":463,"children":464},{},[465],{"type":188,"value":466},"Pair programming is a technique in software development where two programmers work together on a single computer or remotely, each taking turns to be the driver and the navigator. The driver is responsible for typing code, while the navigator is responsible for guiding the implementation, giving feedback and suggesting improvements ... GitHub Copilot lacks the ability to question or challenge your assumptions, so it cannot give you alternative perspectives the way a human being can when pairing.",{"type":182,"tag":252,"props":468,"children":469},{},[470],{"type":188,"value":471},"目前来说是的，GitHub Copilot 充当我的代码助手，而不是向我提出质疑。刚开始使用时，我还会仔细检查它的代码，但是随着时间推移，信任感加深后，这种检查反而丢失了。",{"title":175,"searchDepth":473,"depth":473,"links":474},2,[475,476,477],{"id":185,"depth":473,"text":189},{"id":216,"depth":473,"text":219},{"id":234,"depth":473,"text":237},"markdown","content:6.maps:_ai:tools:copilot.md","content","6.maps/_ai/tools/copilot.md","6.maps/_ai/tools/copilot","md",[485,489],{"_path":486,"title":487,"description":488},"/maps/_ai/tools/claude-code","Claude Code","Anthropic 官方的 AI 编码助手，支持从描述构建功能、调试问题、导航代码库和自动化繁琐任务。",{"_path":490,"title":491,"description":492},"/maps/_ai/training/topology-aware-scheduling","拓扑感知调度","拓扑感知调度是一种在分布式计算环境中，根据硬件拓扑结构和网络性能来优化任务调度和资源分配的方法，以提高整体系统的效率和性能。",1771264630813]