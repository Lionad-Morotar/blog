82,191,198,204,209,232,238,244,249,254,265,271],{"type":183,"tag":184,"props":185,"children":187},"element","h2",{"id":186},"risk",[188],{"type":189,"value":190},"text","Risk",{"type":183,"tag":192,"props":193,"children":195},"h4",{"id":194},"pdoom-是什么",[196],{"type":189,"value":197},"p(doom) 是什么？",{"type":183,"tag":199,"props":200,"children":201},"p",{},[202],{"type":189,"value":203},"p(doom) 是 AI 安全领域的术语，指「人工智能导致人类灭绝或永久失去能力的概率」（probability of doom）。这个词流行于研究者和决策者之间，反映了行业对技术失控风险的深层焦虑。不同专家的 p(doom) 估计从 1% 到 50% 不等——Jeffrey Hinton 等「深度学习教父」倾向于给出较高数字，而产业界人士往往更低。",{"type":183,"tag":199,"props":205,"children":206},{},[207],{"type":189,"value":208},"当一个不再受安全约束、全力冲刺的 AI 实验室出现时，这种概率评估会显著上升。",{"type":183,"tag":199,"props":210,"children":211},{},[212,214,223,225],{"type":189,"value":213},"见：",{"type":183,"tag":215,"props":216,"children":220},"a",{"href":217,"rel":218},"https://en.wikipedia.org/wiki/P(doom)",[219],"nofollow",[221],{"type":189,"value":222},"P(doom) - Wikipedia",{"type":189,"value":224},"、",{"type":183,"tag":215,"props":226,"children":229},{"href":227,"rel":228},"https://www.scifuture.org/pdoom-watch-different-experts-probabilities-of-doom/",[219],[230],{"type":189,"value":231},"Different Experts Probabilities of Doom from AI",{"type":183,"tag":184,"props":233,"children":235},{"id":234},"event",[236],{"type":189,"value":237},"Event",{"type":183,"tag":192,"props":239,"children":241},{"id":240},"xai-安全团队的名存实亡",[242],{"type":189,"value":243},"xAI 安全团队的名存实亡",{"type":183,"tag":199,"props":245,"children":246},{},[247],{"type":189,"value":248},"马斯克旗下的 xAI 近期经历大规模重组，安全团队被「掏空」——至少 11 名工程师和两名联合创始人离职，重组后的组织架构图中甚至没有安全团队的位置。一位内部人士直言：「安全在 xAI 是一个死掉的组织。」",{"type":183,"tag":199,"props":250,"children":251},{},[252],{"type":189,"value":253},"在 AI 竞赛白热化的当下，这种「先跑起来再说」的态度正在取代审慎的安全考量，而一位掌控巨额资源的亿万富翁押注「速度压倒一切」，对整个行业来说并非好兆头。",{"type":183,"tag":199,"props":255,"children":256},{},[257,258],{"type":189,"value":213},{"type":183,"tag":215,"props":259,"children":262},{"href":260,"rel":261},"https://www.theverge.com/ai-artificial-intelligence/878761/mass-exodus-at-xai-grok-elon-musk-restructuring",[219],[263],{"type":189,"value":264},"What's behind the mass exodus at xAI? - The Verge",{"type":183,"tag":184,"props":266,"children":268},{"id":267},"framework",[269],{"type":189,"value":270},"Framework",{"type":183,"tag":272,"props":273,"children":274},"ul",{},[275],{"type":183,"tag":276,"props":277,"children":278},"li",{},[279],{"type":183,"tag":215,"props":280,"children":282},{"href":281},"/maps/_ai/framework/saif",[283],{"type":189,"value":284},"SAIF（安全人工智能框架）",{"title":175,"searchDepth":286,"depth":286,"links":287},2,[288,289,290],{"id":186,"depth":286,"text":190},{"id":234,"depth":286,"text":237},{"id":267,"depth":286,"text":270},"markdown","content:6.maps:_ai:safety:safety.md","content","6.maps/_ai/safety/safety.md","6.maps/_ai/safety/safety","md",[298,302],{"_path":299,"title":300,"description":301},"/maps/_ai/recommendation/recommendation-system","推荐系统演进：从零到上瘾算法","https://www.bilibili.com/video/BV1eqagzSECT/",{"_path":303,"title":304,"description":305},"/maps/_ai/skills/create-a-skill","如何编写 Agent Skills","如何编写 Agent Skills - 完整指南",1771214974899]