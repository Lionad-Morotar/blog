AI 安全",{"type":183,"children":184,"toc":288},"root",[185,194,201,207,212,235,241,247,252,257,268,274],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"risk",[191],{"type":192,"value":193},"text","Risk",{"type":186,"tag":195,"props":196,"children":198},"h4",{"id":197},"pdoom-是什么",[199],{"type":192,"value":200},"p(doom) 是什么？",{"type":186,"tag":202,"props":203,"children":204},"p",{},[205],{"type":192,"value":206},"p(doom) 是 AI 安全领域的术语，指「人工智能导致人类灭绝或永久失去能力的概率」（probability of doom）。这个词流行于研究者和决策者之间，反映了行业对技术失控风险的深层焦虑。不同专家的 p(doom) 估计从 1% 到 50% 不等——Jeffrey Hinton 等「深度学习教父」倾向于给出较高数字，而产业界人士往往更低。",{"type":186,"tag":202,"props":208,"children":209},{},[210],{"type":192,"value":211},"当一个不再受安全约束、全力冲刺的 AI 实验室出现时，这种概率评估会显著上升。",{"type":186,"tag":202,"props":213,"children":214},{},[215,217,226,228],{"type":192,"value":216},"见：",{"type":186,"tag":218,"props":219,"children":223},"a",{"href":220,"rel":221},"https://en.wikipedia.org/wiki/P(doom)",[222],"nofollow",[224],{"type":192,"value":225},"P(doom) - Wikipedia",{"type":192,"value":227},"、",{"type":186,"tag":218,"props":229,"children":232},{"href":230,"rel":231},"https://www.scifuture.org/pdoom-watch-different-experts-probabilities-of-doom/",[222],[233],{"type":192,"value":234},"Different Experts Probabilities of Doom from AI",{"type":186,"tag":187,"props":236,"children":238},{"id":237},"event",[239],{"type":192,"value":240},"Event",{"type":186,"tag":195,"props":242,"children":244},{"id":243},"xai-安全团队的名存实亡",[245],{"type":192,"value":246},"xAI 安全团队的名存实亡",{"type":186,"tag":202,"props":248,"children":249},{},[250],{"type":192,"value":251},"马斯克旗下的 xAI 近期经历大规模重组，安全团队被「掏空」——至少 11 名工程师和两名联合创始人离职，重组后的组织架构图中甚至没有安全团队的位置。一位内部人士直言：「安全在 xAI 是一个死掉的组织。」",{"type":186,"tag":202,"props":253,"children":254},{},[255],{"type":192,"value":256},"在 AI 竞赛白热化的当下，这种「先跑起来再说」的态度正在取代审慎的安全考量，而一位掌控巨额资源的亿万富翁押注「速度压倒一切」，对整个行业来说并非好兆头。",{"type":186,"tag":202,"props":258,"children":259},{},[260,261],{"type":192,"value":216},{"type":186,"tag":218,"props":262,"children":265},{"href":263,"rel":264},"https://www.theverge.com/ai-artificial-intelligence/878761/mass-exodus-at-xai-grok-elon-musk-restructuring",[222],[266],{"type":192,"value":267},"What's behind the mass exodus at xAI? - The Verge",{"type":186,"tag":187,"props":269,"children":271},{"id":270},"framework",[272],{"type":192,"value":273},"Framework",{"type":186,"tag":275,"props":276,"children":277},"ul",{},[278],{"type":186,"tag":279,"props":280,"children":281},"li",{},[282],{"type":186,"tag":218,"props":283,"children":285},{"href":284},"/maps/_ai/framework/saif",[286],{"type":192,"value":287},"SAIF（安全人工智能框架）",{"title":178,"searchDepth":289,"depth":289,"links":290},2,[291,292,293],{"id":189,"depth":289,"text":193},{"id":237,"depth":289,"text":240},{"id":270,"depth":289,"text":273},"markdown","content:6.maps:_ai:safety:safety.md","content","6.maps/_ai/safety/safety.md","6.maps/_ai/safety/safety","md",[301,305],{"_path":302,"title":303,"description":304},"/maps/_ai/recommendation/recommendation-system","推荐系统演进：从零到上瘾算法","推荐系统演进历程：从流行度排序、协同过滤、矩阵分解到双塔模型与深度学习的完整指南。",{"_path":306,"title":307,"description":308},"/maps/_ai/skills/create-a-skill","如何编写 Agent Skills","如何编写 Agent Skills - 完整指南",1772185486998]