98,204,235,241,246,273,279,284,311,317,322,349,355,360],{"type":184,"tag":185,"props":186,"children":188},"element","h1",{"id":187},"安全-safety",[189],{"type":190,"value":179},"text",{"type":184,"tag":192,"props":193,"children":195},"h2",{"id":194},"constitutional-ai价值观对齐的宪法方法",[196],{"type":190,"value":197},"Constitutional AI：价值观对齐的宪法方法",{"type":184,"tag":199,"props":200,"children":201},"p",{},[202],{"type":190,"value":203},"Constitutional AI 由 Anthropic 提出，核心思想是让模型遵循一组\"宪法原则\"进行自我修正。不同于 RLHF 需要大量人工标注，它通过 AI 自我批评和修订实现价值观对齐——模型生成回答后根据宪法原则自我批评并改进，再用改进后的回答训练偏好模型。这种方法减少了对人工反馈的依赖，更易扩展到多语言、多文化场景。",{"type":184,"tag":199,"props":205,"children":206},{},[207,209,218,220,227,228],{"type":190,"value":208},"见：",{"type":184,"tag":210,"props":211,"children":215},"a",{"href":212,"rel":213},"https://arxiv.org/abs/2212.08073",[214],"nofollow",[216],{"type":190,"value":217},"Constitutional AI 论文",{"type":190,"value":219}," | ",{"type":184,"tag":210,"props":221,"children":224},{"href":222,"rel":223},"https://www.anthropic.com/constitution",[214],[225],{"type":190,"value":226},"Claude's Constitution",{"type":190,"value":219},{"type":184,"tag":210,"props":229,"children":232},{"href":230,"rel":231},"https://blog.bluedot.org/p/what-is-constitutional-ai",[214],[233],{"type":190,"value":234},"BlueDot 解读",{"type":184,"tag":192,"props":236,"children":238},{"id":237},"llamaguard输入输出内容审核模型",[239],{"type":190,"value":240},"LlamaGuard：输入输出内容审核模型",{"type":184,"tag":199,"props":242,"children":243},{},[244],{"type":190,"value":245},"LlamaGuard 是 Meta 开源的输入/输出内容审核模型，基于 Llama 架构微调，可对对话内容进行安全风险分类。覆盖暴力与犯罪、仇恨言论、自残、性相关内容、恶意软件、欺诈/诈骗、隐私侵犯等 7 大类风险。最新 Llama Guard 3 支持多模态（图像理解）内容审核，是构建安全 AI 系统的关键组件。",{"type":184,"tag":199,"props":247,"children":248},{},[249,250,257,258,265,266],{"type":190,"value":208},{"type":184,"tag":210,"props":251,"children":254},{"href":252,"rel":253},"https://arxiv.org/abs/2312.06674",[214],[255],{"type":190,"value":256},"LlamaGuard 论文",{"type":190,"value":219},{"type":184,"tag":210,"props":259,"children":262},{"href":260,"rel":261},"https://ai.meta.com/research/publications/llama-guard-llm-based-input-output-safeguard-for-human-ai-conversations/",[214],[263],{"type":190,"value":264},"Meta AI 发布",{"type":190,"value":219},{"type":184,"tag":210,"props":267,"children":270},{"href":268,"rel":269},"https://ai.meta.com/research/publications/llama-guard-3-vision-safeguarding-human-ai-image-understanding-conversations/",[214],[271],{"type":190,"value":272},"Llama Guard 3 Vision",{"type":184,"tag":192,"props":274,"children":276},{"id":275},"nemo-guardrails三层防护对话安全框架",[277],{"type":190,"value":278},"NeMo Guardrails：三层防护对话安全框架",{"type":184,"tag":199,"props":280,"children":281},{},[282],{"type":190,"value":283},"NeMo Guardrails 是 NVIDIA 推出的对话安全框架，提供输入防护（检测并拦截恶意提示）、对话管理（控制对话流程防止话题偏离）、输出防护（审核模型回复过滤不安全内容）三层防护。与 LlamaGuard、Cleanlab TLM 集成，支持 LangChain、LlamaIndex 等主流框架，是可编程的 LLM 安全工具包。",{"type":184,"tag":199,"props":285,"children":286},{},[287,288,295,296,303,304],{"type":190,"value":208},{"type":184,"tag":210,"props":289,"children":292},{"href":290,"rel":291},"https://docs.nvidia.com/nemo/guardrails/latest/index.html",[214],[293],{"type":190,"value":294},"NeMo Guardrails 文档",{"type":190,"value":219},{"type":184,"tag":210,"props":297,"children":300},{"href":298,"rel":299},"https://developer.nvidia.com/blog/content-moderation-and-safety-checks-with-nvidia-nemo-guardrails/",[214],[301],{"type":190,"value":302},"NVIDIA 博客",{"type":190,"value":219},{"type":184,"tag":210,"props":305,"children":308},{"href":306,"rel":307},"https://github.com/NVIDIA-NeMo/Guardrails",[214],[309],{"type":190,"value":310},"GitHub",{"type":184,"tag":192,"props":312,"children":314},{"id":313},"prompt-guard提示注入与越狱检测",[315],{"type":190,"value":316},"Prompt Guard：提示注入与越狱检测",{"type":184,"tag":199,"props":318,"children":319},{},[320],{"type":190,"value":321},"Prompt Guard 是 Meta 专门用于检测提示注入（Prompt Injection）和越狱（Jailbreak）攻击的模型。Prompt Guard 2 有两个版本：86M（支持多语言攻击检测）和 22M（超轻量版适合边缘部署）。两者都经过大量已知漏洞语料训练，可检测直接注入（用户试图覆盖系统提示）、间接注入（通过外部数据源注入恶意指令）和越狱攻击。",{"type":184,"tag":199,"props":323,"children":324},{},[325,326,333,334,341,342],{"type":190,"value":208},{"type":184,"tag":210,"props":327,"children":330},{"href":328,"rel":329},"https://huggingface.co/meta-llama/Llama-Prompt-Guard-2-86M",[214],[331],{"type":190,"value":332},"Prompt Guard 86M",{"type":190,"value":219},{"type":184,"tag":210,"props":335,"children":338},{"href":336,"rel":337},"https://huggingface.co/meta-llama/Llama-Prompt-Guard-2-22M",[214],[339],{"type":190,"value":340},"Prompt Guard 22M",{"type":190,"value":219},{"type":184,"tag":210,"props":343,"children":346},{"href":344,"rel":345},"https://ai.meta.com/blog/ai-defenders-program-llama-protection-tools/",[214],[347],{"type":190,"value":348},"Meta 发布说明",{"type":184,"tag":192,"props":350,"children":352},{"id":351},"多层防御安全不能依赖单点",[353],{"type":190,"value":354},"多层防御：安全不能依赖单点",{"type":184,"tag":199,"props":356,"children":357},{},[358],{"type":190,"value":359},"有效的 LLM 安全需要多层防御架构：输入层使用 Prompt Guard 检测注入攻击，内容层使用 LlamaGuard 进行风险分类，输出层再次审核过滤不安全内容。永远不要依赖单一防线，攻击者总能找到绕过单个防护的方法。定期红队测试、记录分析被拒绝的请求、建立人工审核机制处理边界案例，是持续保持安全性的关键。",{"type":184,"tag":199,"props":361,"children":362},{},[363,364,371,372,379,380],{"type":190,"value":208},{"type":184,"tag":210,"props":365,"children":368},{"href":366,"rel":367},"https://www.datocms-assets.com/75231/1752004377-llm-security-best-practices-v2.pdf",[214],[369],{"type":190,"value":370},"LLM 安全最佳实践",{"type":190,"value":219},{"type":184,"tag":210,"props":373,"children":376},{"href":374,"rel":375},"https://www.datadoghq.com/blog/llm-guardrails-best-practices/",[214],[377],{"type":190,"value":378},"Datadog Guardrails 指南",{"type":190,"value":219},{"type":184,"tag":210,"props":381,"children":384},{"href":382,"rel":383},"https://www.sentinelone.com/cybersecurity-101/cybersecurity/defense-in-depth-ai-cybersecurity/",[214],[385],{"type":190,"value":386},"Defense in Depth 指南",{"title":178,"searchDepth":388,"depth":388,"links":389},2,[390,391,392,393,394],{"id":194,"depth":388,"text":197},{"id":237,"depth":388,"text":240},{"id":275,"depth":388,"text":278},{"id":313,"depth":388,"text":316},{"id":351,"depth":388,"text":354},"markdown","content:6.maps:_ai:safety.md","content","6.maps/_ai/safety.md","6.maps/_ai/safety","md",[402,406],{"_path":403,"title":404,"description":405},"/maps/_ai/recommendation/recommendation-system","推荐系统演进：从零到上瘾算法","https://www.bilibili.com/video/BV1eqagzSECT/",{"_path":407,"title":408,"description":409},"/maps/_ai/safety/safety","AI Safety","AI 安全研究、风险治理与相关事件",1771693738764]