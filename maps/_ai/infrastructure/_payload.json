70,276,281,308,313,318],{"type":181,"tag":182,"props":183,"children":185},"element","h1",{"id":184},"基础设施-infrastructure",[186],{"type":187,"value":176},"text",{"type":181,"tag":189,"props":190,"children":192},"h2",{"id":191},"modalpython-原生的-serverless-gpu-平台",[193],{"type":187,"value":194},"Modal：Python 原生的 Serverless GPU 平台",{"type":181,"tag":196,"props":197,"children":198},"p",{},[199],{"type":187,"value":200},"Modal 是面向 AI/ML 工程师的 Serverless 计算平台，核心卖点是\"Python-native\"——用纯 Python 代码定义计算任务，自动处理容器化、调度、扩缩容。支持从 0 到数百 GPU 的秒级扩容，按秒计费，用后即焚。内置高性能分布式文件系统，大模型权重秒级加载。适合快速原型验证和推理服务部署。",{"type":181,"tag":196,"props":202,"children":203},{},[204,206,215,217,224,225],{"type":187,"value":205},"见：",{"type":181,"tag":207,"props":208,"children":212},"a",{"href":209,"rel":210},"https://modal.com/",[211],"nofollow",[213],{"type":187,"value":214},"Modal 官网",{"type":187,"value":216}," | ",{"type":181,"tag":207,"props":218,"children":221},{"href":219,"rel":220},"https://modal.com/docs",[211],[222],{"type":187,"value":223},"Modal 文档",{"type":187,"value":216},{"type":181,"tag":207,"props":226,"children":229},{"href":227,"rel":228},"https://modal.com/blog/serverless-gpu-article",[211],[230],{"type":187,"value":231},"Serverless GPU 对比",{"type":181,"tag":189,"props":233,"children":235},{"id":234},"lambda-labs高性价比-ai-云服务商",[236],{"type":187,"value":237},"Lambda Labs：高性价比 AI 云服务商",{"type":181,"tag":196,"props":239,"children":240},{},[241],{"type":187,"value":242},"Lambda Labs 是专注 AI 工作负载的云服务商，以高性价比 GPU 实例著称。相比 AWS/GCP，Lambda 的 GPU 价格通常低 50%+，且提供即时可用的实例（无需排队）。支持 NVIDIA B200、H100、A100、GH200 等最新 GPU，提供按小时计费的 GPU 实例和长期租用的私有集群，是训练任务的性价比之选。",{"type":181,"tag":196,"props":244,"children":245},{},[246,247,254,255,262,263],{"type":187,"value":205},{"type":181,"tag":207,"props":248,"children":251},{"href":249,"rel":250},"https://lambda.ai/",[211],[252],{"type":187,"value":253},"Lambda Labs 官网",{"type":187,"value":216},{"type":181,"tag":207,"props":256,"children":259},{"href":257,"rel":258},"https://lambda.ai/pricing",[211],[260],{"type":187,"value":261},"Lambda 定价",{"type":187,"value":216},{"type":181,"tag":207,"props":264,"children":267},{"href":265,"rel":266},"https://lambda.ai/blog/deepchat-3-step-training-at-scale-nvidia-h100-sxm5-vs-a100-sxm4",[211],[268],{"type":187,"value":269},"H100 vs A100 对比",{"type":181,"tag":189,"props":271,"children":273},{"id":272},"skypilot多云-ai-编排框架",[274],{"type":187,"value":275},"SkyPilot：多云 AI 编排框架",{"type":181,"tag":196,"props":277,"children":278},{},[279],{"type":187,"value":280},"SkyPilot 是伯克利大学 Sky Computing Lab 开源的多云编排工具，目标是\"Run AI on Any Infrastructure\"。它抽象了不同云厂商的差异，支持 AWS、GCP、Azure、Lambda、Kubernetes、Slurm 等多种基础设施，自动选择最便宜的可用区域和实例类型，实例被抢占时自动迁移，让用户专注算法而非基础设施。",{"type":181,"tag":196,"props":282,"children":283},{},[284,285,292,293,300,301],{"type":187,"value":205},{"type":181,"tag":207,"props":286,"children":289},{"href":287,"rel":288},"https://skypilot.co/",[211],[290],{"type":187,"value":291},"SkyPilot 官网",{"type":187,"value":216},{"type":181,"tag":207,"props":294,"children":297},{"href":295,"rel":296},"https://docs.skypilot.co/",[211],[298],{"type":187,"value":299},"SkyPilot 文档",{"type":187,"value":216},{"type":181,"tag":207,"props":302,"children":305},{"href":303,"rel":304},"https://www.usenix.org/system/files/nsdi23-yang-zongheng.pdf",[211],[306],{"type":187,"value":307},"SkyPilot 论文",{"type":181,"tag":189,"props":309,"children":311},{"id":310},"基础设施选型指南",[312],{"type":187,"value":310},{"type":181,"tag":196,"props":314,"children":315},{},[316],{"type":187,"value":317},"快速原型和推理服务推荐 Modal，开发效率最高；长期训练任务推荐 Lambda Labs，性价比最优；多云和混合云场景推荐 SkyPilot，避免厂商锁定；企业级需求选择 AWS/GCP/Azure，生态最完善。实际选择应权衡开发效率、成本、可迁移性和合规要求。",{"type":181,"tag":196,"props":319,"children":320},{},[321,322,329,330],{"type":187,"value":205},{"type":181,"tag":207,"props":323,"children":326},{"href":324,"rel":325},"https://fullstackdeeplearning.com/cloud-gpus/",[211],[327],{"type":187,"value":328},"Cloud GPUs 完整对比",{"type":187,"value":216},{"type":181,"tag":207,"props":331,"children":334},{"href":332,"rel":333},"https://www.linkedin.com/pulse/skypilotvllmaws-vs-modal-which-platform-should-power-ai-ramkumar-zqghe",[211],[335],{"type":187,"value":336},"SkyPilot vs Modal 对比",{"title":175,"searchDepth":338,"depth":338,"links":339},2,[340,341,342,343],{"id":191,"depth":338,"text":194},{"id":234,"depth":338,"text":237},{"id":272,"depth":338,"text":275},{"id":310,"depth":338,"text":310},"markdown","content:6.maps:_ai:infrastructure.md","content","6.maps/_ai/infrastructure.md","6.maps/_ai/infrastructure","md",[351,354],{"_path":352,"title":353,"description":175},"/maps/_ai/inference","推理 (Inference)",{"_path":355,"title":356,"description":357},"/maps/_ai/llm/datadog/datadog-llm","Datadog LLM Observability","为 LLM 与 Agent 工作流提供端到端追踪、监控与诊断，融入 Datadog APM 体系；对已用 Datadog 的团队较友好，但埋点与协同要求高。",1771264678732]