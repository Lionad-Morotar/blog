ing","workflow",false,true,"","Agentic Engineering","超越 Vibe Coding 的 AI 辅助工程方法论","_ai/workflow/agentic-engineering.md",{"type":183,"children":184,"toc":1010},"root",[185,194,215,234,248,254,265,270,297,302,325,336,342,350,355,363,368,376,381,387,392,400,423,431,449,454,465,471,483,488,506,515,521,526,551,559,565,570,666,674,679,712,723,729,748,753,765,776,781,794,827,854,866,875,880,892,897,915,927,939,948,953,958,963,989,1001],{"type":186,"tag":187,"props":188,"children":190},"element","h4",{"id":189},"是什么",[191],{"type":192,"value":193},"text","是什么？",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198,200,206,208,213],{"type":192,"value":199},"Agentic Engineering 指使用能够",{"type":186,"tag":201,"props":202,"children":203},"strong",{},[204],{"type":192,"value":205},"生成并执行代码",{"type":192,"value":207},"的 coding agents（如 Claude Code、OpenAI Codex）来构建软件的工程实践。\n核心特征是 agents 可以",{"type":186,"tag":201,"props":209,"children":210},{},[211],{"type":192,"value":212},"独立测试和迭代代码",{"type":192,"value":214},"，无需人类逐轮指导。",{"type":186,"tag":195,"props":216,"children":217},{},[218,220,225,227,232],{"type":192,"value":219},"与 ",{"type":186,"tag":201,"props":221,"children":222},{},[223],{"type":192,"value":224},"vibe coding",{"type":192,"value":226},"（原定义为\"完全不关注代码\"的编程方式，常用于非程序员使用 LLM 写代码的场景）形成对比，\nAgentic Engineering 代表另一个极端：专业软件工程师利用 coding agents ",{"type":186,"tag":201,"props":228,"children":229},{},[230],{"type":192,"value":231},"放大现有专业知识",{"type":192,"value":233},"。",{"type":186,"tag":195,"props":235,"children":236},{},[237,239],{"type":192,"value":238},"见：",{"type":186,"tag":240,"props":241,"children":245},"a",{"href":242,"rel":243},"https://simonwillison.net/2026/Feb/23/agentic-engineering-patterns/",[244],"nofollow",[246],{"type":192,"value":247},"Writing about Agentic Engineering Patterns",{"type":186,"tag":187,"props":249,"children":251},{"id":250},"agentic-engineering-patterns-项目",[252],{"type":192,"value":253},"Agentic Engineering Patterns 项目",{"type":186,"tag":195,"props":255,"children":256},{},[257,259,264],{"type":192,"value":258},"Simon Willison 于 2026 年 2 月启动的开源文档项目，旨在系统性地收集和记录 Agentic Engineering 的",{"type":186,"tag":201,"props":260,"children":261},{},[262],{"type":192,"value":263},"编码实践和模式",{"type":192,"value":233},{"type":186,"tag":195,"props":266,"children":267},{},[268],{"type":192,"value":269},"项目特点：",{"type":186,"tag":271,"props":272,"children":273},"ul",{},[274,287,292],{"type":186,"tag":275,"props":276,"children":277},"li",{},[278,280,285],{"type":192,"value":279},"采用 ",{"type":186,"tag":201,"props":281,"children":282},{},[283],{"type":192,"value":284},"guide/chapter",{"type":192,"value":286}," 内容形式：guide 是可更新的章节集合，每个 chapter 类似博客文章但支持持续更新",{"type":186,"tag":275,"props":288,"children":289},{},[290],{"type":192,"value":291},"灵感源自 1994 年的《Design Patterns》经典书籍格式",{"type":186,"tag":275,"props":293,"children":294},{},[295],{"type":192,"value":296},"计划以每周 1-2 章的速度扩展",{"type":186,"tag":195,"props":298,"children":299},{},[300],{"type":192,"value":301},"已发布章节：",{"type":186,"tag":271,"props":303,"children":304},{},[305,315],{"type":186,"tag":275,"props":306,"children":307},{},[308,313],{"type":186,"tag":201,"props":309,"children":310},{},[311],{"type":192,"value":312},"\"Writing code is cheap now\"",{"type":192,"value":314},"：讨论初始代码成本趋近于零对个体和团队工作直觉的影响",{"type":186,"tag":275,"props":316,"children":317},{},[318,323],{"type":186,"tag":201,"props":319,"children":320},{},[321],{"type":192,"value":322},"\"Red/green TDD\"",{"type":192,"value":324},"：测试优先开发如何帮助 agents 编写更简洁可靠的代码",{"type":186,"tag":195,"props":326,"children":327},{},[328,329],{"type":192,"value":238},{"type":186,"tag":240,"props":330,"children":333},{"href":331,"rel":332},"https://simonwillison.net/guides/agentic-engineering-patterns/",[244],[334],{"type":192,"value":335},"Agentic Engineering Patterns",{"type":186,"tag":187,"props":337,"children":339},{"id":338},"核心实践",[340],{"type":192,"value":341},"核心实践？",{"type":186,"tag":195,"props":343,"children":344},{},[345],{"type":186,"tag":201,"props":346,"children":347},{},[348],{"type":192,"value":349},"并行工作流",{"type":186,"tag":195,"props":351,"children":352},{},[353],{"type":192,"value":354},"同时运行 5-10 个 agents 处理不同模块，单日可合并 600+ commits。",{"type":186,"tag":195,"props":356,"children":357},{},[358],{"type":186,"tag":201,"props":359,"children":360},{},[361],{"type":192,"value":362},"对话式迭代",{"type":186,"tag":195,"props":364,"children":365},{},[366],{"type":192,"value":367},"与 AI \"讨论\"而非直接下指令——先让它探索多种方案，理解后再决定方向。",{"type":186,"tag":195,"props":369,"children":370},{},[371],{"type":186,"tag":201,"props":372,"children":373},{},[374],{"type":192,"value":375},"系统架构思维",{"type":186,"tag":195,"props":377,"children":378},{},[379],{"type":192,"value":380},"自己不写代码，但深度把控架构方向。关注产品感觉（taste）而非代码细节。",{"type":186,"tag":187,"props":382,"children":384},{"id":383},"redgreen-tdd-与-coding-agents",[385],{"type":192,"value":386},"Red/green TDD 与 Coding Agents",{"type":186,"tag":195,"props":388,"children":389},{},[390],{"type":192,"value":391},"在与 coding agent 协作时，\"use red/green TDD\" 是一句极其高效的 prompt。",{"type":186,"tag":195,"props":393,"children":394},{},[395],{"type":186,"tag":201,"props":396,"children":397},{},[398],{"type":192,"value":399},"Red/green 的含义：",{"type":186,"tag":271,"props":401,"children":402},{},[403,413],{"type":186,"tag":275,"props":404,"children":405},{},[406,411],{"type":186,"tag":201,"props":407,"children":408},{},[409],{"type":192,"value":410},"Red",{"type":192,"value":412},"：先写测试，确认测试失败",{"type":186,"tag":275,"props":414,"children":415},{},[416,421],{"type":186,"tag":201,"props":417,"children":418},{},[419],{"type":192,"value":420},"Green",{"type":192,"value":422},"：实现代码，让测试通过",{"type":186,"tag":195,"props":424,"children":425},{},[426],{"type":186,"tag":201,"props":427,"children":428},{},[429],{"type":192,"value":430},"为何适合 coding agents：",{"type":186,"tag":271,"props":432,"children":433},{},[434,439,444],{"type":186,"tag":275,"props":435,"children":436},{},[437],{"type":192,"value":438},"防止写出无法工作的代码",{"type":186,"tag":275,"props":440,"children":441},{},[442],{"type":192,"value":443},"避免构建不必要的功能",{"type":186,"tag":275,"props":445,"children":446},{},[447],{"type":192,"value":448},"同步建立回归测试防护网",{"type":186,"tag":195,"props":450,"children":451},{},[452],{"type":192,"value":453},"\"red/green TDD\" 已成为模型理解的简写——无需展开解释完整流程，\nagent 会自动遵循\"先写测试→确认失败→实现通过\"的循环。",{"type":186,"tag":195,"props":455,"children":456},{},[457,458],{"type":192,"value":238},{"type":186,"tag":240,"props":459,"children":462},{"href":460,"rel":461},"https://simonwillison.net/guides/agentic-engineering-patterns/red-green-tdd/",[244],[463],{"type":192,"value":464},"Red/green TDD - Agentic Engineering Patterns",{"type":186,"tag":187,"props":466,"children":468},{"id":467},"closing-the-loop",[469],{"type":192,"value":470},"Closing the Loop",{"type":186,"tag":195,"props":472,"children":473},{},[474,476,481],{"type":192,"value":475},"AI 擅长编码而不擅长写作的原因是：",{"type":186,"tag":201,"props":477,"children":478},{},[479],{"type":192,"value":480},"代码可以被验证",{"type":192,"value":482},"（编译、运行测试、检查输出）。",{"type":186,"tag":195,"props":484,"children":485},{},[486],{"type":192,"value":487},"设计\"可验证的架构\"：",{"type":186,"tag":271,"props":489,"children":490},{},[491,496,501],{"type":186,"tag":275,"props":492,"children":493},{},[494],{"type":192,"value":495},"让 AI 能自我测试、自我调试",{"type":186,"tag":275,"props":497,"children":498},{},[499],{"type":192,"value":500},"本地运行测试比 CI 更快（10 分钟 → 几分钟）",{"type":186,"tag":275,"props":502,"children":503},{},[504],{"type":192,"value":505},"代码结构要便于验证",{"type":186,"tag":507,"props":508,"children":509},"blockquote",{},[510],{"type":186,"tag":195,"props":511,"children":512},{},[513],{"type":192,"value":514},"\"写更少代码反而让你成为更好的架构师，因为你必须设计易于验证的系统。\"",{"type":186,"tag":187,"props":516,"children":518},{"id":517},"从-pr-到-prompt-request",[519],{"type":192,"value":520},"从 PR 到 Prompt Request",{"type":186,"tag":195,"props":522,"children":523},{},[524],{"type":192,"value":525},"Peter 将 GitHub PR 重新定义为 \"Prompt Request\"：",{"type":186,"tag":271,"props":527,"children":528},{},[529,534,546],{"type":186,"tag":275,"props":530,"children":531},{},[532],{"type":192,"value":533},"几乎不阅读 PR 中的代码",{"type":186,"tag":275,"props":535,"children":536},{},[537,539,544],{"type":192,"value":538},"更关注 ",{"type":186,"tag":201,"props":540,"children":541},{},[542],{"type":192,"value":543},"prompt",{"type":192,"value":545}," 本身——\"你是怎么让 AI 做到这个的？\"",{"type":186,"tag":275,"props":547,"children":548},{},[549],{"type":192,"value":550},"常用 workflow：看到 PR → 用 Codex 重新实现（融入自己的架构 vision）→ 合并",{"type":186,"tag":195,"props":552,"children":553},{},[554],{"type":186,"tag":201,"props":555,"children":556},{},[557],{"type":192,"value":558},"重要的不是代码是什么，而是如何得到这段代码的思考过程。",{"type":186,"tag":187,"props":560,"children":562},{"id":561},"为什么-cli-mcp",[563],{"type":192,"value":564},"为什么 CLI > MCP",{"type":186,"tag":195,"props":566,"children":567},{},[568],{"type":192,"value":569},"Peter 对 MCP（Model Context Protocol）持怀疑态度：",{"type":186,"tag":571,"props":572,"children":573},"table",{},[574,598],{"type":186,"tag":575,"props":576,"children":577},"thead",{},[578],{"type":186,"tag":579,"props":580,"children":581},"tr",{},[582,588,593],{"type":186,"tag":583,"props":584,"children":585},"th",{},[586],{"type":192,"value":587},"维度",{"type":186,"tag":583,"props":589,"children":590},{},[591],{"type":192,"value":592},"MCP",{"type":186,"tag":583,"props":594,"children":595},{},[596],{"type":192,"value":597},"CLI",{"type":186,"tag":599,"props":600,"children":601},"tbody",{},[602,621,639],{"type":186,"tag":579,"props":603,"children":604},{},[605,611,616],{"type":186,"tag":606,"props":607,"children":608},"td",{},[609],{"type":192,"value":610},"上下文",{"type":186,"tag":606,"props":612,"children":613},{},[614],{"type":192,"value":615},"预加载所有函数定义，污染上下文",{"type":186,"tag":606,"props":617,"children":618},{},[619],{"type":192,"value":620},"按需调用，精确控制",{"type":186,"tag":579,"props":622,"children":623},{},[624,629,634],{"type":186,"tag":606,"props":625,"children":626},{},[627],{"type":192,"value":628},"链式调用",{"type":186,"tag":606,"props":630,"children":631},{},[632],{"type":192,"value":633},"无法链式组合",{"type":186,"tag":606,"props":635,"children":636},{},[637],{"type":192,"value":638},"可用管道（|）灵活组合",{"type":186,"tag":579,"props":640,"children":641},{},[642,647,652],{"type":186,"tag":606,"props":643,"children":644},{},[645],{"type":192,"value":646},"过滤",{"type":186,"tag":606,"props":648,"children":649},{},[650],{"type":192,"value":651},"返回所有字段，模型必须消化全部",{"type":186,"tag":606,"props":653,"children":654},{},[655,657,664],{"type":192,"value":656},"可用 ",{"type":186,"tag":658,"props":659,"children":661},"code",{"className":660},[],[662],{"type":192,"value":663},"jq",{"type":192,"value":665}," 精确过滤所需字段",{"type":186,"tag":507,"props":667,"children":668},{},[669],{"type":186,"tag":195,"props":670,"children":671},{},[672],{"type":192,"value":673},"\"MCP 是临时拐杖。模型非常擅长使用 bash。\"",{"type":186,"tag":187,"props":675,"children":677},{"id":676},"给新人的建议",[678],{"type":192,"value":676},{"type":186,"tag":271,"props":680,"children":681},{},[682,692,702],{"type":186,"tag":275,"props":683,"children":684},{},[685,690],{"type":186,"tag":201,"props":686,"children":687},{},[688],{"type":192,"value":689},"无限好奇心",{"type":192,"value":691},"：不懂就问 AI，它是无限耐心的老师",{"type":186,"tag":275,"props":693,"children":694},{},[695,700],{"type":186,"tag":201,"props":696,"children":697},{},[698],{"type":192,"value":699},"动手建造",{"type":192,"value":701},"：通过建造获得经验，而非只写代码",{"type":186,"tag":275,"props":703,"children":704},{},[705,710],{"type":186,"tag":201,"props":706,"children":707},{},[708],{"type":192,"value":709},"玩这个游戏",{"type":192,"value":711},"：把学习 AI 辅助开发当作乐器或游戏，越练越上瘾",{"type":186,"tag":195,"props":713,"children":714},{},[715,716],{"type":192,"value":238},{"type":186,"tag":240,"props":717,"children":720},{"href":718,"rel":719},"https://podcasts.apple.com/us/podcast/the-pragmatic-engineer/id1457313865",[244],[721],{"type":192,"value":722},"The Pragmatic Engineer Podcast - Peter Steinberger Interview",{"type":186,"tag":187,"props":724,"children":726},{"id":725},"agent-first-工程方法论",[727],{"type":192,"value":728},"Agent-First 工程方法论",{"type":186,"tag":195,"props":730,"children":731},{},[732,734,739,741,746],{"type":192,"value":733},"OpenAI 团队在 5 个月内用",{"type":186,"tag":201,"props":735,"children":736},{},[737],{"type":192,"value":738},"0 行手写代码",{"type":192,"value":740},"构建了一个内部产品，所有代码（应用逻辑、测试、CI 配置、文档、可观测性工具）均由 Codex 生成。核心原则是\"",{"type":186,"tag":201,"props":742,"children":743},{},[744],{"type":192,"value":745},"人类掌舵，Agents 执行",{"type":192,"value":747},"\"。",{"type":186,"tag":195,"props":749,"children":750},{},[751],{"type":192,"value":752},"团队从 3 名工程师扩展到 7 名，累计提交约 1500 个 PR，平均每人每天 3.5 个 PR，且吞吐量随团队规模增长而提升。产品已有数百名内部用户，包括日常重度使用者。",{"type":186,"tag":195,"props":754,"children":755},{},[756,758,763],{"type":192,"value":757},"关键转变是工程师角色从\"写代码\"转向\"",{"type":186,"tag":201,"props":759,"children":760},{},[761],{"type":192,"value":762},"设计环境、明确意图、构建反馈循环",{"type":192,"value":764},"\"，让 Codex agents 能可靠地完成工作。",{"type":186,"tag":195,"props":766,"children":767},{},[768,769],{"type":192,"value":238},{"type":186,"tag":240,"props":770,"children":773},{"href":771,"rel":772},"https://openai.com/index/harness-engineering/",[244],[774],{"type":192,"value":775},"Harness engineering: leveraging Codex in an agent-first world",{"type":186,"tag":187,"props":777,"children":779},{"id":778},"知识的渐进式披露原则",[780],{"type":192,"value":778},{"type":186,"tag":195,"props":782,"children":783},{},[784,786,792],{"type":192,"value":785},"OpenAI 团队发现将大量指令塞入 ",{"type":186,"tag":658,"props":787,"children":789},{"className":788},[],[790],{"type":192,"value":791},"AGENTS.md",{"type":192,"value":793}," 会产生反效果：",{"type":186,"tag":271,"props":795,"children":796},{},[797,807,817],{"type":186,"tag":275,"props":798,"children":799},{},[800,805],{"type":186,"tag":201,"props":801,"children":802},{},[803],{"type":192,"value":804},"上下文是稀缺资源",{"type":192,"value":806}," - 巨大的指令文件会挤占任务、代码和文档的空间",{"type":186,"tag":275,"props":808,"children":809},{},[810,815],{"type":186,"tag":201,"props":811,"children":812},{},[813],{"type":192,"value":814},"过度指导等于无指导",{"type":192,"value":816}," - 当一切都\"重要\"，agents 会局部模式匹配而非全局导航",{"type":186,"tag":275,"props":818,"children":819},{},[820,825],{"type":186,"tag":201,"props":821,"children":822},{},[823],{"type":192,"value":824},"文档快速腐烂",{"type":192,"value":826}," - 单体手册变成陈旧规则的坟场，难以验证和维护",{"type":186,"tag":195,"props":828,"children":829},{},[830,832,837,839,844,846,852],{"type":192,"value":831},"解决方案是将 ",{"type":186,"tag":658,"props":833,"children":835},{"className":834},[],[836],{"type":192,"value":791},{"type":192,"value":838}," 视为",{"type":186,"tag":201,"props":840,"children":841},{},[842],{"type":192,"value":843},"目录而非百科全书",{"type":192,"value":845},"（约 100 行），真正的知识库存储在结构化的 ",{"type":186,"tag":658,"props":847,"children":849},{"className":848},[],[850],{"type":192,"value":851},"docs/",{"type":192,"value":853}," 目录中，作为系统的真实数据源。",{"type":186,"tag":195,"props":855,"children":856},{},[857,859,864],{"type":192,"value":858},"这实现了",{"type":186,"tag":201,"props":860,"children":861},{},[862],{"type":192,"value":863},"渐进式披露",{"type":192,"value":865},"：agents 从小型稳定的入口点开始，学习下一步去哪里查找，而非一开始就被淹没。",{"type":186,"tag":195,"props":867,"children":868},{},[869,870],{"type":192,"value":238},{"type":186,"tag":240,"props":871,"children":873},{"href":771,"rel":872},[244],[874],{"type":192,"value":775},{"type":186,"tag":187,"props":876,"children":878},{"id":877},"架构约束优于实现细节",[879],{"type":192,"value":877},{"type":186,"tag":195,"props":881,"children":882},{},[883,885,890],{"type":192,"value":884},"在 agent-first 环境中，架构规则通过",{"type":186,"tag":201,"props":886,"children":887},{},[888],{"type":192,"value":889},"机械执行的不变量",{"type":192,"value":891},"来保证一致性，而非微管理实现。",{"type":186,"tag":195,"props":893,"children":894},{},[895],{"type":192,"value":896},"OpenAI 采用刚性架构模型：",{"type":186,"tag":271,"props":898,"children":899},{},[900,905,910],{"type":186,"tag":275,"props":901,"children":902},{},[903],{"type":192,"value":904},"每个业务域分为固定层次（Types → Config → Repo → Service → Runtime → UI）",{"type":186,"tag":275,"props":906,"children":907},{},[908],{"type":192,"value":909},"依赖方向严格验证，跨域关注点（认证、连接器、遥测）通过单一接口进入",{"type":186,"tag":275,"props":911,"children":912},{},[913],{"type":192,"value":914},"使用自定义 linter 和结构化测试强制执行",{"type":186,"tag":195,"props":916,"children":917},{},[918,920,925],{"type":192,"value":919},"这类架构通常在数百名工程师规模时才引入，但在 coding agents 环境中是",{"type":186,"tag":201,"props":921,"children":922},{},[923],{"type":192,"value":924},"早期前提条件",{"type":192,"value":926}," - 约束是速度无衰减或架构腐化的保障。",{"type":186,"tag":195,"props":928,"children":929},{},[930,932,937],{"type":192,"value":931},"错误信息也设计为将",{"type":186,"tag":201,"props":933,"children":934},{},[935],{"type":192,"value":936},"补救指令注入 agent 上下文",{"type":192,"value":938},"，人类品味通过审查评论、重构 PR 和 bug 报告持续反馈到系统中。",{"type":186,"tag":195,"props":940,"children":941},{},[942,943],{"type":192,"value":238},{"type":186,"tag":240,"props":944,"children":946},{"href":771,"rel":945},[244],[947],{"type":192,"value":775},{"type":186,"tag":187,"props":949,"children":951},{"id":950},"自动化品味编码",[952],{"type":192,"value":950},{"type":186,"tag":195,"props":954,"children":955},{},[956],{"type":192,"value":957},"完全自主的 agents 会复制仓库中的现有模式，即使是次优模式，导致熵增。",{"type":186,"tag":195,"props":959,"children":960},{},[961],{"type":192,"value":962},"OpenAI 初期每周五花 20% 时间清理\"AI 垃圾\"，但这不可扩展。解决方案是：",{"type":186,"tag":964,"props":965,"children":966},"ol",{},[967,979,984],{"type":186,"tag":275,"props":968,"children":969},{},[970,972,977],{"type":192,"value":971},"将\"",{"type":186,"tag":201,"props":973,"children":974},{},[975],{"type":192,"value":976},"黄金原则",{"type":192,"value":978},"\"（如优先共享工具包而非手写 helpers、验证边界而非 YOLO 式探测）编码到仓库",{"type":186,"tag":275,"props":980,"children":981},{},[982],{"type":192,"value":983},"建立定期清理流程 - 后台 Codex 任务扫描偏差、更新质量等级、开立重构 PR",{"type":186,"tag":275,"props":985,"children":986},{},[987],{"type":192,"value":988},"大多数重构 PR 可在 1 分钟内审查并自动合并",{"type":186,"tag":195,"props":990,"children":991},{},[992,994,999],{"type":192,"value":993},"这类似",{"type":186,"tag":201,"props":995,"children":996},{},[997],{"type":192,"value":998},"垃圾回收",{"type":192,"value":1000},"：技术债务像高息贷款，持续小额偿还有助于避免复利累积。人类品味一次性捕获，然后在每行代码上持续执行。",{"type":186,"tag":195,"props":1002,"children":1003},{},[1004,1005],{"type":192,"value":238},{"type":186,"tag":240,"props":1006,"children":1008},{"href":771,"rel":1007},[244],[1009],{"type":192,"value":775},{"title":178,"searchDepth":1011,"depth":1011,"links":1012},2,[],"markdown","content:6.maps:_ai:workflow:agentic-engineering.md","content","6.maps/_ai/workflow/agentic-engineering.md","6.maps/_ai/workflow/agentic-engineering","md",[1020,1024],{"_path":1021,"title":1022,"description":1023},"/maps/_ai/workflow","Workflow","AI 辅助开发工作流与方法论",{"_path":1025,"title":1026,"description":1027},"/maps/_ai/workflow/sdd","Spec-Driven Development (SDD)","规格驱动开发方法论与工具对比",1772504954475]