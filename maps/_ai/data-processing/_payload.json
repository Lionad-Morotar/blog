dren":182,"toc":355},"root",[183,191,198,204,235,241,246,265,271,276,295,301,306,325,331,336],{"type":184,"tag":185,"props":186,"children":188},"element","h1",{"id":187},"数据处理-data-processing",[189],{"type":190,"value":179},"text",{"type":184,"tag":192,"props":193,"children":195},"h2",{"id":194},"nemo-curatorgpu-加速的企业级数据整理",[196],{"type":190,"value":197},"NeMo Curator：GPU 加速的企业级数据整理",{"type":184,"tag":199,"props":200,"children":201},"p",{},[202],{"type":190,"value":203},"NeMo Curator 是 NVIDIA 推出的企业级数据整理工具包，专为大规模生成式 AI 训练设计。它利用 RAPIDS 库（cuDF、cuML、cuGraph）实现 GPU 加速，配合 Ray 支持多节点分布式扩展。在 DGX 系统上可在数小时内处理 TB 级语料，比传统 CPU 方案快 10-100 倍。支持文档提取、文本清洗、精确/模糊去重、质量评分和 PII 检测等模块化管道。",{"type":184,"tag":199,"props":205,"children":206},{},[207,209,218,220,227,228],{"type":190,"value":208},"见：",{"type":184,"tag":210,"props":211,"children":215},"a",{"href":212,"rel":213},"https://github.com/NVIDIA-NeMo/Curator",[214],"nofollow",[216],{"type":190,"value":217},"NeMo Curator GitHub",{"type":190,"value":219}," | ",{"type":184,"tag":210,"props":221,"children":224},{"href":222,"rel":223},"https://docs.nvidia.com/nemo/curator/",[214],[225],{"type":190,"value":226},"NVIDIA 官方文档",{"type":190,"value":219},{"type":184,"tag":210,"props":229,"children":232},{"href":230,"rel":231},"https://developer.nvidia.cn/blog/streamlining-data-processing-for-domain-adaptive-pretraining-with-nvidia-nemo-curator/",[214],[233],{"type":190,"value":234},"ChipNeMo 案例",{"type":184,"tag":192,"props":236,"children":238},{"id":237},"ray-data分布式数据加载与预处理",[239],{"type":190,"value":240},"Ray Data：分布式数据加载与预处理",{"type":184,"tag":199,"props":242,"children":243},{},[244],{"type":190,"value":245},"Ray Data 是 Ray 生态系统中的数据层，提供可扩展的数据加载、转换和传输能力。它与 PyTorch、TensorFlow、HuggingFace 无缝集成，支持从单机扩展到千节点集群。关键特性包括流式处理（无需全部载入内存）、自动分片（与分布式训练对齐）、以及 CPU 预处理 + GPU 训练的流水线并行。",{"type":184,"tag":199,"props":247,"children":248},{},[249,250,257,258],{"type":190,"value":208},{"type":184,"tag":210,"props":251,"children":254},{"href":252,"rel":253},"https://docs.ray.io/en/latest/data/data.html",[214],[255],{"type":190,"value":256},"Ray Data 文档",{"type":190,"value":219},{"type":184,"tag":210,"props":259,"children":262},{"href":260,"rel":261},"https://www.anyscale.com/blog/fast-flexible-scalable-data-loading-for-ml-training-with-ray-data",[214],[263],{"type":190,"value":264},"Ray Data 博客",{"type":184,"tag":192,"props":266,"children":268},{"id":267},"minhash-lsh大规模近似去重",[269],{"type":190,"value":270},"MinHash + LSH：大规模近似去重",{"type":184,"tag":199,"props":272,"children":273},{},[274],{"type":190,"value":275},"MinHash 结合局部敏感哈希（LSH）是大规模数据集去重的标准算法。通过计算文档的签名并比较相似度，可以高效识别重复或高度相似的文档。研究表明这是 LLM 预训练数据去重的最合适算法，Data-Juicer 的实现在 8 节点 1280 CPU 核心上可在 3 小时内完成 TB 级数据集去重。",{"type":184,"tag":199,"props":277,"children":278},{},[279,280,287,288],{"type":190,"value":208},{"type":184,"tag":210,"props":281,"children":284},{"href":282,"rel":283},"https://dl.acm.org/doi/10.1007/978-3-031-82481-4_27",[214],[285],{"type":190,"value":286},"MinHash LSH 去重研究",{"type":190,"value":219},{"type":184,"tag":210,"props":289,"children":292},{"href":290,"rel":291},"https://zilliz.com/blog/data-deduplication-at-trillion-scale-solve-the-biggest-bottleneck-of-llm-training",[214],[293],{"type":190,"value":294},"Zilliz 万亿级去重",{"type":184,"tag":192,"props":296,"children":298},{"id":297},"数据质量分层tier-1-3-体系",[299],{"type":190,"value":300},"数据质量分层：Tier 1-3 体系",{"type":184,"tag":199,"props":302,"children":303},{},[304],{"type":190,"value":305},"高质量数据应分为多个层级训练：Tier 1 是人工精选（Wikipedia、书籍、学术论文），Tier 2 是自动过滤后的 Web 数据（Common Crawl 子集），Tier 3 是代码、对话等专项数据。训练时按不同比例混合各层级数据，可显著提升模型泛化能力并减少数据污染。",{"type":184,"tag":199,"props":307,"children":308},{},[309,310,317,318],{"type":190,"value":208},{"type":184,"tag":210,"props":311,"children":314},{"href":312,"rel":313},"https://arxiv.org/abs/2107.06499",[214],[315],{"type":190,"value":316},"Deduplicating Training Data 论文",{"type":190,"value":219},{"type":184,"tag":210,"props":319,"children":322},{"href":320,"rel":321},"https://arxiv.org/abs/2101.00027",[214],[323],{"type":190,"value":324},"The Pile 数据集论文",{"type":184,"tag":192,"props":326,"children":328},{"id":327},"数据混合策略决定模型能力的关键",[329],{"type":190,"value":330},"数据混合策略：决定模型能力的关键",{"type":184,"tag":199,"props":332,"children":333},{},[334],{"type":190,"value":335},"不同来源数据的比例对模型能力有显著影响：代码数据比例提升会增强推理能力，对话数据比例提升会增强指令遵循能力，Web 数据比例提升会扩展知识广度但引入噪声。精心设计的数据混合策略是训练高性能模型的核心 secret sauce。",{"type":184,"tag":199,"props":337,"children":338},{},[339,340,347,348],{"type":190,"value":208},{"type":184,"tag":210,"props":341,"children":344},{"href":342,"rel":343},"https://huggingface.co/spaces/HuggingFaceFW/blogpost-fineweb-v1",[214],[345],{"type":190,"value":346},"FineWeb 技术报告",{"type":190,"value":219},{"type":184,"tag":210,"props":349,"children":352},{"href":350,"rel":351},"https://datacomp.ai/",[214],[353],{"type":190,"value":354},"DataComp 基准",{"title":178,"searchDepth":356,"depth":356,"links":357},2,[358,359,360,361,362],{"id":194,"depth":356,"text":197},{"id":237,"depth":356,"text":240},{"id":267,"depth":356,"text":270},{"id":297,"depth":356,"text":300},{"id":327,"depth":356,"text":330},"markdown","content:6.maps:_ai:data-processing.md","content","6.maps/_ai/data-processing.md","6.maps/_ai/data-processing","md",[370,374],{"_path":371,"title":372,"description":373},"/maps/_ai/benchmark/simple","Simple Benchmark","日常使用的简单基准测试",{"_path":375,"title":376,"description":178},"/maps/_ai/distributed","分布式 (Distributed Training)",1771695828736]