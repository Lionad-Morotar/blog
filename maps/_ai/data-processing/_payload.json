43,262,268,273,292,298,303,322,328,333],{"type":181,"tag":182,"props":183,"children":185},"element","h1",{"id":184},"数据处理-data-processing",[186],{"type":187,"value":176},"text",{"type":181,"tag":189,"props":190,"children":192},"h2",{"id":191},"nemo-curatorgpu-加速的企业级数据整理",[193],{"type":187,"value":194},"NeMo Curator：GPU 加速的企业级数据整理",{"type":181,"tag":196,"props":197,"children":198},"p",{},[199],{"type":187,"value":200},"NeMo Curator 是 NVIDIA 推出的企业级数据整理工具包，专为大规模生成式 AI 训练设计。它利用 RAPIDS 库（cuDF、cuML、cuGraph）实现 GPU 加速，配合 Ray 支持多节点分布式扩展。在 DGX 系统上可在数小时内处理 TB 级语料，比传统 CPU 方案快 10-100 倍。支持文档提取、文本清洗、精确/模糊去重、质量评分和 PII 检测等模块化管道。",{"type":181,"tag":196,"props":202,"children":203},{},[204,206,215,217,224,225],{"type":187,"value":205},"见：",{"type":181,"tag":207,"props":208,"children":212},"a",{"href":209,"rel":210},"https://github.com/NVIDIA-NeMo/Curator",[211],"nofollow",[213],{"type":187,"value":214},"NeMo Curator GitHub",{"type":187,"value":216}," | ",{"type":181,"tag":207,"props":218,"children":221},{"href":219,"rel":220},"https://docs.nvidia.com/nemo/curator/",[211],[222],{"type":187,"value":223},"NVIDIA 官方文档",{"type":187,"value":216},{"type":181,"tag":207,"props":226,"children":229},{"href":227,"rel":228},"https://developer.nvidia.cn/blog/streamlining-data-processing-for-domain-adaptive-pretraining-with-nvidia-nemo-curator/",[211],[230],{"type":187,"value":231},"ChipNeMo 案例",{"type":181,"tag":189,"props":233,"children":235},{"id":234},"ray-data分布式数据加载与预处理",[236],{"type":187,"value":237},"Ray Data：分布式数据加载与预处理",{"type":181,"tag":196,"props":239,"children":240},{},[241],{"type":187,"value":242},"Ray Data 是 Ray 生态系统中的数据层，提供可扩展的数据加载、转换和传输能力。它与 PyTorch、TensorFlow、HuggingFace 无缝集成，支持从单机扩展到千节点集群。关键特性包括流式处理（无需全部载入内存）、自动分片（与分布式训练对齐）、以及 CPU 预处理 + GPU 训练的流水线并行。",{"type":181,"tag":196,"props":244,"children":245},{},[246,247,254,255],{"type":187,"value":205},{"type":181,"tag":207,"props":248,"children":251},{"href":249,"rel":250},"https://docs.ray.io/en/latest/data/data.html",[211],[252],{"type":187,"value":253},"Ray Data 文档",{"type":187,"value":216},{"type":181,"tag":207,"props":256,"children":259},{"href":257,"rel":258},"https://www.anyscale.com/blog/fast-flexible-scalable-data-loading-for-ml-training-with-ray-data",[211],[260],{"type":187,"value":261},"Ray Data 博客",{"type":181,"tag":189,"props":263,"children":265},{"id":264},"minhash-lsh大规模近似去重",[266],{"type":187,"value":267},"MinHash + LSH：大规模近似去重",{"type":181,"tag":196,"props":269,"children":270},{},[271],{"type":187,"value":272},"MinHash 结合局部敏感哈希（LSH）是大规模数据集去重的标准算法。通过计算文档的签名并比较相似度，可以高效识别重复或高度相似的文档。研究表明这是 LLM 预训练数据去重的最合适算法，Data-Juicer 的实现在 8 节点 1280 CPU 核心上可在 3 小时内完成 TB 级数据集去重。",{"type":181,"tag":196,"props":274,"children":275},{},[276,277,284,285],{"type":187,"value":205},{"type":181,"tag":207,"props":278,"children":281},{"href":279,"rel":280},"https://dl.acm.org/doi/10.1007/978-3-031-82481-4_27",[211],[282],{"type":187,"value":283},"MinHash LSH 去重研究",{"type":187,"value":216},{"type":181,"tag":207,"props":286,"children":289},{"href":287,"rel":288},"https://zilliz.com/blog/data-deduplication-at-trillion-scale-solve-the-biggest-bottleneck-of-llm-training",[211],[290],{"type":187,"value":291},"Zilliz 万亿级去重",{"type":181,"tag":189,"props":293,"children":295},{"id":294},"数据质量分层tier-1-3-体系",[296],{"type":187,"value":297},"数据质量分层：Tier 1-3 体系",{"type":181,"tag":196,"props":299,"children":300},{},[301],{"type":187,"value":302},"高质量数据应分为多个层级训练：Tier 1 是人工精选（Wikipedia、书籍、学术论文），Tier 2 是自动过滤后的 Web 数据（Common Crawl 子集），Tier 3 是代码、对话等专项数据。训练时按不同比例混合各层级数据，可显著提升模型泛化能力并减少数据污染。",{"type":181,"tag":196,"props":304,"children":305},{},[306,307,314,315],{"type":187,"value":205},{"type":181,"tag":207,"props":308,"children":311},{"href":309,"rel":310},"https://arxiv.org/abs/2107.06499",[211],[312],{"type":187,"value":313},"Deduplicating Training Data 论文",{"type":187,"value":216},{"type":181,"tag":207,"props":316,"children":319},{"href":317,"rel":318},"https://arxiv.org/abs/2101.00027",[211],[320],{"type":187,"value":321},"The Pile 数据集论文",{"type":181,"tag":189,"props":323,"children":325},{"id":324},"数据混合策略决定模型能力的关键",[326],{"type":187,"value":327},"数据混合策略：决定模型能力的关键",{"type":181,"tag":196,"props":329,"children":330},{},[331],{"type":187,"value":332},"不同来源数据的比例对模型能力有显著影响：代码数据比例提升会增强推理能力，对话数据比例提升会增强指令遵循能力，Web 数据比例提升会扩展知识广度但引入噪声。精心设计的数据混合策略是训练高性能模型的核心 secret sauce。",{"type":181,"tag":196,"props":334,"children":335},{},[336,337,344,345],{"type":187,"value":205},{"type":181,"tag":207,"props":338,"children":341},{"href":339,"rel":340},"https://huggingface.co/spaces/HuggingFaceFW/blogpost-fineweb-v1",[211],[342],{"type":187,"value":343},"FineWeb 技术报告",{"type":187,"value":216},{"type":181,"tag":207,"props":346,"children":349},{"href":347,"rel":348},"https://datacomp.ai/",[211],[350],{"type":187,"value":351},"DataComp 基准",{"title":175,"searchDepth":353,"depth":353,"links":354},2,[355,356,357,358,359],{"id":191,"depth":353,"text":194},{"id":234,"depth":353,"text":237},{"id":264,"depth":353,"text":267},{"id":294,"depth":353,"text":297},{"id":324,"depth":353,"text":327},"markdown","content:6.maps:_ai:data-processing.md","content","6.maps/_ai/data-processing.md","6.maps/_ai/data-processing","md",[367,371],{"_path":368,"title":369,"description":370},"/maps/_ai/benchmark/simple","Simple Benchmark","日常使用的简单基准测试",{"_path":372,"title":373,"description":175},"/maps/_ai/distributed","分布式 (Distributed Training)",1771264678597]