2,"toc":362},"root",[183,191,198,204,235,241,246,273,279,284,303,309,314,333,338,343],{"type":184,"tag":185,"props":186,"children":188},"element","h1",{"id":187},"可观测性-observability",[189],{"type":190,"value":179},"text",{"type":184,"tag":192,"props":193,"children":195},"h2",{"id":194},"langsmithlangchain-生态追踪平台",[196],{"type":190,"value":197},"LangSmith：LangChain 生态追踪平台",{"type":184,"tag":199,"props":200,"children":201},"p",{},[202],{"type":190,"value":203},"LangSmith 是 LangChain 官方的可观测性平台，与 LangChain 生态深度集成。提供调用链可视化、错误定位与重放、批量测试评估、生产指标仪表盘。2025 年推出 LangSmith Fetch CLI 工具，可直接在终端和 IDE 中调试 Agent 追踪数据。适合已使用 LangChain 构建应用的团队，但部分功能需付费，不支持自托管。",{"type":184,"tag":199,"props":205,"children":206},{},[207,209,218,220,227,228],{"type":190,"value":208},"见：",{"type":184,"tag":210,"props":211,"children":215},"a",{"href":212,"rel":213},"https://smith.langchain.com/",[214],"nofollow",[216],{"type":190,"value":217},"LangSmith 官网",{"type":190,"value":219}," | ",{"type":184,"tag":210,"props":221,"children":224},{"href":222,"rel":223},"https://blog.langchain.com/introducing-langsmith-fetch/",[214],[225],{"type":190,"value":226},"LangSmith Fetch 发布",{"type":190,"value":219},{"type":184,"tag":210,"props":229,"children":232},{"href":230,"rel":231},"https://blog.langchain.com/debugging-deep-agents-with-langsmith/",[214],[233],{"type":190,"value":234},"Deep Agents 调试指南",{"type":184,"tag":192,"props":236,"children":238},{"id":237},"phoenix开源-llm-可观测性平台",[239],{"type":190,"value":240},"Phoenix：开源 LLM 可观测性平台",{"type":184,"tag":199,"props":242,"children":243},{},[244],{"type":190,"value":245},"Phoenix 由 Arize AI 开发，是完全开源的 LLM 可观测性解决方案。基于 OpenTelemetry 标准实现框架无关的追踪，提供 RAG 检索质量可视化、Embedding 向量空间探索、内置 Evals 评估库。支持自托管，与 MLflow 等 MLOps 工具集成良好，是企业级可观测性的首选开源方案。",{"type":184,"tag":199,"props":247,"children":248},{},[249,250,257,258,265,266],{"type":190,"value":208},{"type":184,"tag":210,"props":251,"children":254},{"href":252,"rel":253},"https://github.com/Arize-ai/phoenix",[214],[255],{"type":190,"value":256},"Phoenix GitHub",{"type":190,"value":219},{"type":184,"tag":210,"props":259,"children":262},{"href":260,"rel":261},"https://phoenix.arize.com/",[214],[263],{"type":190,"value":264},"Phoenix 官网",{"type":190,"value":219},{"type":184,"tag":210,"props":267,"children":270},{"href":268,"rel":269},"https://arize.com/docs/phoenix/evaluation/llm-evals",[214],[271],{"type":190,"value":272},"LLM Evals 库",{"type":184,"tag":192,"props":274,"children":276},{"id":275},"langfuse开源可观测性新选择",[277],{"type":190,"value":278},"Langfuse：开源可观测性新选择",{"type":184,"tag":199,"props":280,"children":281},{},[282],{"type":190,"value":283},"Langfuse 是 2025 年快速崛起的开源 LLM 可观测性平台，提供 Traces 追踪、Evals 评估、Prompt 管理、Metrics 指标分析。支持 OpenAI、LangChain、LlamaIndex、LiteLLM 等 10+ 集成，采用 OpenTelemetry 标准。作为完全开源的欧洲产品，是重视数据主权团队的理想选择。",{"type":184,"tag":199,"props":285,"children":286},{},[287,288,295,296],{"type":190,"value":208},{"type":184,"tag":210,"props":289,"children":292},{"href":290,"rel":291},"https://langfuse.com/",[214],[293],{"type":190,"value":294},"Langfuse 官网",{"type":190,"value":219},{"type":184,"tag":210,"props":297,"children":300},{"href":298,"rel":299},"https://langfuse.com/wrapped",[214],[301],{"type":190,"value":302},"Langfuse Wrapped 2025",{"type":184,"tag":192,"props":304,"children":306},{"id":305},"opentelemetry开放追踪标准",[307],{"type":190,"value":308},"OpenTelemetry：开放追踪标准",{"type":184,"tag":199,"props":310,"children":311},{},[312],{"type":190,"value":313},"OpenTelemetry 成为 LLM 可观测性的事实标准，提供与框架无关的 instrumentation 能力。Traceloop (OpenLLMetry) 是基于 OpenTelemetry 的 SDK，实现 LLM 应用的统一追踪和指标采集。采用开放标准可避免 vendor lock-in，实现跨平台数据兼容。",{"type":184,"tag":199,"props":315,"children":316},{},[317,318,325,326],{"type":190,"value":208},{"type":184,"tag":210,"props":319,"children":322},{"href":320,"rel":321},"https://github.com/traceloop/openllmetry",[214],[323],{"type":190,"value":324},"OpenLLMetry GitHub",{"type":190,"value":219},{"type":184,"tag":210,"props":327,"children":330},{"href":328,"rel":329},"https://opentelemetry.io/",[214],[331],{"type":190,"value":332},"OpenTelemetry 官网",{"type":184,"tag":192,"props":334,"children":336},{"id":335},"工具选型指南",[337],{"type":190,"value":335},{"type":184,"tag":199,"props":339,"children":340},{},[341],{"type":190,"value":342},"LangSmith 适合 LangChain 生态用户，功能完善但需付费；Phoenix 适合需要自托管和 RAG 分析的团队，完全开源；Langfuse 适合重视数据主权和 Prompt 管理的场景；OpenTelemetry 方案适合追求开放标准和技术自主的团队。实际部署中，开发阶段可用 LangSmith 快速上手，生产环境考虑 Phoenix 或 Langfuse 自托管以控制成本和数据安全。",{"type":184,"tag":199,"props":344,"children":345},{},[346,347,354,355],{"type":190,"value":208},{"type":184,"tag":210,"props":348,"children":351},{"href":349,"rel":350},"https://www.firecrawl.dev/blog/best-llm-observability-tools",[214],[352],{"type":190,"value":353},"2025 LLM 可观测性工具榜单",{"type":190,"value":219},{"type":184,"tag":210,"props":356,"children":359},{"href":357,"rel":358},"https://medium.com/@aunraza021/langsmith-vs-phoenix-by-arize-ai-choosing-the-right-tool-for-llm-observability-0b4c2f21c077",[214],[360],{"type":190,"value":361},"LangSmith vs Phoenix 对比",{"title":178,"searchDepth":363,"depth":363,"links":364},2,[365,366,367,368,369],{"id":194,"depth":363,"text":197},{"id":237,"depth":363,"text":240},{"id":275,"depth":363,"text":278},{"id":305,"depth":363,"text":308},{"id":335,"depth":363,"text":335},"markdown","content:6.maps:_ai:observability.md","content","6.maps/_ai/observability.md","6.maps/_ai/observability","md",[377,380],{"_path":378,"title":379,"description":178},"/maps/_ai/multimodal","多模态 (Multimodal)",{"_path":381,"title":382,"description":178},"/maps/_ai/optimization","优化 (Optimization)",1771521535392]