76,281,300,306,311,330,335,340],{"type":181,"tag":182,"props":183,"children":185},"element","h1",{"id":184},"可观测性-observability",[186],{"type":187,"value":176},"text",{"type":181,"tag":189,"props":190,"children":192},"h2",{"id":191},"langsmithlangchain-生态追踪平台",[193],{"type":187,"value":194},"LangSmith：LangChain 生态追踪平台",{"type":181,"tag":196,"props":197,"children":198},"p",{},[199],{"type":187,"value":200},"LangSmith 是 LangChain 官方的可观测性平台，与 LangChain 生态深度集成。提供调用链可视化、错误定位与重放、批量测试评估、生产指标仪表盘。2025 年推出 LangSmith Fetch CLI 工具，可直接在终端和 IDE 中调试 Agent 追踪数据。适合已使用 LangChain 构建应用的团队，但部分功能需付费，不支持自托管。",{"type":181,"tag":196,"props":202,"children":203},{},[204,206,215,217,224,225],{"type":187,"value":205},"见：",{"type":181,"tag":207,"props":208,"children":212},"a",{"href":209,"rel":210},"https://smith.langchain.com/",[211],"nofollow",[213],{"type":187,"value":214},"LangSmith 官网",{"type":187,"value":216}," | ",{"type":181,"tag":207,"props":218,"children":221},{"href":219,"rel":220},"https://blog.langchain.com/introducing-langsmith-fetch/",[211],[222],{"type":187,"value":223},"LangSmith Fetch 发布",{"type":187,"value":216},{"type":181,"tag":207,"props":226,"children":229},{"href":227,"rel":228},"https://blog.langchain.com/debugging-deep-agents-with-langsmith/",[211],[230],{"type":187,"value":231},"Deep Agents 调试指南",{"type":181,"tag":189,"props":233,"children":235},{"id":234},"phoenix开源-llm-可观测性平台",[236],{"type":187,"value":237},"Phoenix：开源 LLM 可观测性平台",{"type":181,"tag":196,"props":239,"children":240},{},[241],{"type":187,"value":242},"Phoenix 由 Arize AI 开发，是完全开源的 LLM 可观测性解决方案。基于 OpenTelemetry 标准实现框架无关的追踪，提供 RAG 检索质量可视化、Embedding 向量空间探索、内置 Evals 评估库。支持自托管，与 MLflow 等 MLOps 工具集成良好，是企业级可观测性的首选开源方案。",{"type":181,"tag":196,"props":244,"children":245},{},[246,247,254,255,262,263],{"type":187,"value":205},{"type":181,"tag":207,"props":248,"children":251},{"href":249,"rel":250},"https://github.com/Arize-ai/phoenix",[211],[252],{"type":187,"value":253},"Phoenix GitHub",{"type":187,"value":216},{"type":181,"tag":207,"props":256,"children":259},{"href":257,"rel":258},"https://phoenix.arize.com/",[211],[260],{"type":187,"value":261},"Phoenix 官网",{"type":187,"value":216},{"type":181,"tag":207,"props":264,"children":267},{"href":265,"rel":266},"https://arize.com/docs/phoenix/evaluation/llm-evals",[211],[268],{"type":187,"value":269},"LLM Evals 库",{"type":181,"tag":189,"props":271,"children":273},{"id":272},"langfuse开源可观测性新选择",[274],{"type":187,"value":275},"Langfuse：开源可观测性新选择",{"type":181,"tag":196,"props":277,"children":278},{},[279],{"type":187,"value":280},"Langfuse 是 2025 年快速崛起的开源 LLM 可观测性平台，提供 Traces 追踪、Evals 评估、Prompt 管理、Metrics 指标分析。支持 OpenAI、LangChain、LlamaIndex、LiteLLM 等 10+ 集成，采用 OpenTelemetry 标准。作为完全开源的欧洲产品，是重视数据主权团队的理想选择。",{"type":181,"tag":196,"props":282,"children":283},{},[284,285,292,293],{"type":187,"value":205},{"type":181,"tag":207,"props":286,"children":289},{"href":287,"rel":288},"https://langfuse.com/",[211],[290],{"type":187,"value":291},"Langfuse 官网",{"type":187,"value":216},{"type":181,"tag":207,"props":294,"children":297},{"href":295,"rel":296},"https://langfuse.com/wrapped",[211],[298],{"type":187,"value":299},"Langfuse Wrapped 2025",{"type":181,"tag":189,"props":301,"children":303},{"id":302},"opentelemetry开放追踪标准",[304],{"type":187,"value":305},"OpenTelemetry：开放追踪标准",{"type":181,"tag":196,"props":307,"children":308},{},[309],{"type":187,"value":310},"OpenTelemetry 成为 LLM 可观测性的事实标准，提供与框架无关的 instrumentation 能力。Traceloop (OpenLLMetry) 是基于 OpenTelemetry 的 SDK，实现 LLM 应用的统一追踪和指标采集。采用开放标准可避免 vendor lock-in，实现跨平台数据兼容。",{"type":181,"tag":196,"props":312,"children":313},{},[314,315,322,323],{"type":187,"value":205},{"type":181,"tag":207,"props":316,"children":319},{"href":317,"rel":318},"https://github.com/traceloop/openllmetry",[211],[320],{"type":187,"value":321},"OpenLLMetry GitHub",{"type":187,"value":216},{"type":181,"tag":207,"props":324,"children":327},{"href":325,"rel":326},"https://opentelemetry.io/",[211],[328],{"type":187,"value":329},"OpenTelemetry 官网",{"type":181,"tag":189,"props":331,"children":333},{"id":332},"工具选型指南",[334],{"type":187,"value":332},{"type":181,"tag":196,"props":336,"children":337},{},[338],{"type":187,"value":339},"LangSmith 适合 LangChain 生态用户，功能完善但需付费；Phoenix 适合需要自托管和 RAG 分析的团队，完全开源；Langfuse 适合重视数据主权和 Prompt 管理的场景；OpenTelemetry 方案适合追求开放标准和技术自主的团队。实际部署中，开发阶段可用 LangSmith 快速上手，生产环境考虑 Phoenix 或 Langfuse 自托管以控制成本和数据安全。",{"type":181,"tag":196,"props":341,"children":342},{},[343,344,351,352],{"type":187,"value":205},{"type":181,"tag":207,"props":345,"children":348},{"href":346,"rel":347},"https://www.firecrawl.dev/blog/best-llm-observability-tools",[211],[349],{"type":187,"value":350},"2025 LLM 可观测性工具榜单",{"type":187,"value":216},{"type":181,"tag":207,"props":353,"children":356},{"href":354,"rel":355},"https://medium.com/@aunraza021/langsmith-vs-phoenix-by-arize-ai-choosing-the-right-tool-for-llm-observability-0b4c2f21c077",[211],[357],{"type":187,"value":358},"LangSmith vs Phoenix 对比",{"title":175,"searchDepth":360,"depth":360,"links":361},2,[362,363,364,365,366],{"id":191,"depth":360,"text":194},{"id":234,"depth":360,"text":237},{"id":272,"depth":360,"text":275},{"id":302,"depth":360,"text":305},{"id":332,"depth":360,"text":332},"markdown","content:6.maps:_ai:observability.md","content","6.maps/_ai/observability.md","6.maps/_ai/observability","md",[374,377],{"_path":375,"title":376,"description":175},"/maps/_ai/multimodal","多模态 (Multimodal)",{"_path":378,"title":379,"description":175},"/maps/_ai/optimization","优化 (Optimization)",1771264683039]