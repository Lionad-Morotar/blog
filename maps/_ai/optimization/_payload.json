,292,298,303,330,336,341],{"type":181,"tag":182,"props":183,"children":185},"element","h1",{"id":184},"优化-optimization",[186],{"type":187,"value":176},"text",{"type":181,"tag":189,"props":190,"children":192},"h2",{"id":191},"flash-attention内存高效的注意力计算",[193],{"type":187,"value":194},"Flash Attention：内存高效的注意力计算",{"type":181,"tag":196,"props":197,"children":198},"p",{},[199],{"type":187,"value":200},"Flash Attention 由 Tri Dao 开发，通过分块计算（tiling）和重计算（recomputation）策略，将注意力计算从 O(N²) 内存复杂度降至 O(N)，同时保持计算精度不变。Flash Attention-3 进一步优化 Hopper GPU，利用 Tensor Core 异步执行，支持 2-4 倍更长序列，实际计算速度提升 2-4 倍。",{"type":181,"tag":196,"props":202,"children":203},{},[204,206,215,217,224,225],{"type":187,"value":205},"见：",{"type":181,"tag":207,"props":208,"children":212},"a",{"href":209,"rel":210},"https://github.com/Dao-AILab/flash-attention",[211],"nofollow",[213],{"type":187,"value":214},"Flash Attention GitHub",{"type":187,"value":216}," | ",{"type":181,"tag":207,"props":218,"children":221},{"href":219,"rel":220},"https://tridao.me/blog/2024/flash3/",[211],[222],{"type":187,"value":223},"Flash Attention-3 博客",{"type":187,"value":216},{"type":181,"tag":207,"props":226,"children":229},{"href":227,"rel":228},"https://arxiv.org/abs/2205.14135",[211],[230],{"type":187,"value":231},"Flash Attention 论文",{"type":181,"tag":189,"props":233,"children":235},{"id":234},"bitsandbytes8-bit4-bit-量化训练",[236],{"type":187,"value":237},"bitsandbytes：8-bit/4-bit 量化训练",{"type":181,"tag":196,"props":239,"children":240},{},[241],{"type":187,"value":242},"bitsandbytes 是 Hugging Face 生态的量化训练库，提供 8-bit AdamW、4-bit 量化训练等功能。与 PEFT 结合实现 QLoRA——4-bit 量化基础模型权重，冻结量化权重，训练 LoRA 适配器，训练时动态反量化，推理时保持量化。让 7B 模型能在消费级 GPU（如 RTX 3090）上微调。",{"type":181,"tag":196,"props":244,"children":245},{},[246,247,254,255],{"type":187,"value":205},{"type":181,"tag":207,"props":248,"children":251},{"href":249,"rel":250},"https://github.com/bitsandbytes-foundation/bitsandbytes",[211],[252],{"type":187,"value":253},"bitsandbytes GitHub",{"type":187,"value":216},{"type":181,"tag":207,"props":256,"children":259},{"href":257,"rel":258},"https://arxiv.org/abs/2305.14314",[211],[260],{"type":187,"value":261},"QLoRA 论文",{"type":181,"tag":189,"props":263,"children":265},{"id":264},"gptq训练后-int4-量化",[266],{"type":187,"value":267},"GPTQ：训练后 INT4 量化",{"type":181,"tag":196,"props":269,"children":270},{},[271],{"type":187,"value":272},"GPTQ 是训练后量化（PTQ）方法，通过逐层量化并补偿误差，将模型压缩至 INT4 精度。适合部署场景，无需重新训练。广泛应用于 llama.cpp、Ollama 等本地推理框架，可在单卡加载 2-3 倍大的模型。",{"type":181,"tag":196,"props":274,"children":275},{},[276,277,284,285],{"type":187,"value":205},{"type":181,"tag":207,"props":278,"children":281},{"href":279,"rel":280},"https://arxiv.org/abs/2210.17323",[211],[282],{"type":187,"value":283},"GPTQ 论文",{"type":187,"value":216},{"type":181,"tag":207,"props":286,"children":289},{"href":287,"rel":288},"https://www.newline.co/@zaoyang/gptq-vs-awq-quantization--d792476e",[211],[290],{"type":187,"value":291},"GPTQ vs AWQ 对比",{"type":181,"tag":189,"props":293,"children":295},{"id":294},"awq激活感知权重量化",[296],{"type":187,"value":297},"AWQ：激活感知权重量化",{"type":181,"tag":196,"props":299,"children":300},{},[301],{"type":187,"value":302},"AWQ（Activation-aware Weight Quantization）发现\"并非所有权重的贡献相同\"——保护对激活值影响大的权重通道，可以显著减少量化损失。相比 GPTQ，perplexity 损失更小，支持 INT4 乘加指令，吞吐提升 2-3 倍，与 TensorRT-LLM、vLLM 集成良好。",{"type":181,"tag":196,"props":304,"children":305},{},[306,307,314,315,322,323],{"type":187,"value":205},{"type":181,"tag":207,"props":308,"children":311},{"href":309,"rel":310},"https://arxiv.org/abs/2306.00978",[211],[312],{"type":187,"value":313},"AWQ 论文",{"type":187,"value":216},{"type":181,"tag":207,"props":316,"children":319},{"href":317,"rel":318},"https://github.com/mit-han-lab/llm-awq",[211],[320],{"type":187,"value":321},"AWQ GitHub",{"type":187,"value":216},{"type":181,"tag":207,"props":324,"children":327},{"href":325,"rel":326},"https://leimao.github.io/blog/AWQ-Activation-Aware-Weight-Quantization/",[211],[328],{"type":187,"value":329},"AWQ 深度解析",{"type":181,"tag":189,"props":331,"children":333},{"id":332},"ggufllamacpp-本地推理格式",[334],{"type":187,"value":335},"GGUF：llama.cpp 本地推理格式",{"type":181,"tag":196,"props":337,"children":338},{},[339],{"type":187,"value":340},"GGUF（GPT-Generated Unified Format）是 llama.cpp 项目的模型格式，专为本地 CPU/GPU 推理优化。支持多种量化方案：Q4_0（极致压缩）、Q4_K_M（平衡选择）、Q5_K_M（质量优先）、Q8_0（接近无损）。是 Ollama、LM Studio 等本地 LLM 工具的标准格式。",{"type":181,"tag":196,"props":342,"children":343},{},[344,345,352,353,360,361],{"type":187,"value":205},{"type":181,"tag":207,"props":346,"children":349},{"href":347,"rel":348},"https://github.com/ggerganov/ggml/blob/master/docs/gguf.md",[211],[350],{"type":187,"value":351},"GGUF 格式规范",{"type":187,"value":216},{"type":181,"tag":207,"props":354,"children":357},{"href":355,"rel":356},"https://kaitchup.substack.com/p/choosing-a-gguf-model-k-quants-i",[211],[358],{"type":187,"value":359},"GGUF 量化选择指南",{"type":187,"value":216},{"type":181,"tag":207,"props":362,"children":365},{"href":363,"rel":364},"https://arxiv.org/pdf/2601.14277",[211],[366],{"type":187,"value":367},"llama.cpp 量化论文",{"title":175,"searchDepth":369,"depth":369,"links":370},2,[371,372,373,374,375],{"id":191,"depth":369,"text":194},{"id":234,"depth":369,"text":237},{"id":264,"depth":369,"text":267},{"id":294,"depth":369,"text":297},{"id":332,"depth":369,"text":335},"markdown","content:6.maps:_ai:optimization.md","content","6.maps/_ai/optimization.md","6.maps/_ai/optimization","md",[383,386],{"_path":384,"title":385,"description":175},"/maps/_ai/observability","可观测性 (Observability)",{"_path":387,"title":388,"description":175},"/maps/_ai/paper-writing","ML 论文写作 (ML Paper Writing)",1771264682701]