":371},"root",[183,191,198,204,235,241,246,265,271,276,295,301,306,333,339,344],{"type":184,"tag":185,"props":186,"children":188},"element","h1",{"id":187},"优化-optimization",[189],{"type":190,"value":179},"text",{"type":184,"tag":192,"props":193,"children":195},"h2",{"id":194},"flash-attention内存高效的注意力计算",[196],{"type":190,"value":197},"Flash Attention：内存高效的注意力计算",{"type":184,"tag":199,"props":200,"children":201},"p",{},[202],{"type":190,"value":203},"Flash Attention 由 Tri Dao 开发，通过分块计算（tiling）和重计算（recomputation）策略，将注意力计算从 O(N²) 内存复杂度降至 O(N)，同时保持计算精度不变。Flash Attention-3 进一步优化 Hopper GPU，利用 Tensor Core 异步执行，支持 2-4 倍更长序列，实际计算速度提升 2-4 倍。",{"type":184,"tag":199,"props":205,"children":206},{},[207,209,218,220,227,228],{"type":190,"value":208},"见：",{"type":184,"tag":210,"props":211,"children":215},"a",{"href":212,"rel":213},"https://github.com/Dao-AILab/flash-attention",[214],"nofollow",[216],{"type":190,"value":217},"Flash Attention GitHub",{"type":190,"value":219}," | ",{"type":184,"tag":210,"props":221,"children":224},{"href":222,"rel":223},"https://tridao.me/blog/2024/flash3/",[214],[225],{"type":190,"value":226},"Flash Attention-3 博客",{"type":190,"value":219},{"type":184,"tag":210,"props":229,"children":232},{"href":230,"rel":231},"https://arxiv.org/abs/2205.14135",[214],[233],{"type":190,"value":234},"Flash Attention 论文",{"type":184,"tag":192,"props":236,"children":238},{"id":237},"bitsandbytes8-bit4-bit-量化训练",[239],{"type":190,"value":240},"bitsandbytes：8-bit/4-bit 量化训练",{"type":184,"tag":199,"props":242,"children":243},{},[244],{"type":190,"value":245},"bitsandbytes 是 Hugging Face 生态的量化训练库，提供 8-bit AdamW、4-bit 量化训练等功能。与 PEFT 结合实现 QLoRA——4-bit 量化基础模型权重，冻结量化权重，训练 LoRA 适配器，训练时动态反量化，推理时保持量化。让 7B 模型能在消费级 GPU（如 RTX 3090）上微调。",{"type":184,"tag":199,"props":247,"children":248},{},[249,250,257,258],{"type":190,"value":208},{"type":184,"tag":210,"props":251,"children":254},{"href":252,"rel":253},"https://github.com/bitsandbytes-foundation/bitsandbytes",[214],[255],{"type":190,"value":256},"bitsandbytes GitHub",{"type":190,"value":219},{"type":184,"tag":210,"props":259,"children":262},{"href":260,"rel":261},"https://arxiv.org/abs/2305.14314",[214],[263],{"type":190,"value":264},"QLoRA 论文",{"type":184,"tag":192,"props":266,"children":268},{"id":267},"gptq训练后-int4-量化",[269],{"type":190,"value":270},"GPTQ：训练后 INT4 量化",{"type":184,"tag":199,"props":272,"children":273},{},[274],{"type":190,"value":275},"GPTQ 是训练后量化（PTQ）方法，通过逐层量化并补偿误差，将模型压缩至 INT4 精度。适合部署场景，无需重新训练。广泛应用于 llama.cpp、Ollama 等本地推理框架，可在单卡加载 2-3 倍大的模型。",{"type":184,"tag":199,"props":277,"children":278},{},[279,280,287,288],{"type":190,"value":208},{"type":184,"tag":210,"props":281,"children":284},{"href":282,"rel":283},"https://arxiv.org/abs/2210.17323",[214],[285],{"type":190,"value":286},"GPTQ 论文",{"type":190,"value":219},{"type":184,"tag":210,"props":289,"children":292},{"href":290,"rel":291},"https://www.newline.co/@zaoyang/gptq-vs-awq-quantization--d792476e",[214],[293],{"type":190,"value":294},"GPTQ vs AWQ 对比",{"type":184,"tag":192,"props":296,"children":298},{"id":297},"awq激活感知权重量化",[299],{"type":190,"value":300},"AWQ：激活感知权重量化",{"type":184,"tag":199,"props":302,"children":303},{},[304],{"type":190,"value":305},"AWQ（Activation-aware Weight Quantization）发现\"并非所有权重的贡献相同\"——保护对激活值影响大的权重通道，可以显著减少量化损失。相比 GPTQ，perplexity 损失更小，支持 INT4 乘加指令，吞吐提升 2-3 倍，与 TensorRT-LLM、vLLM 集成良好。",{"type":184,"tag":199,"props":307,"children":308},{},[309,310,317,318,325,326],{"type":190,"value":208},{"type":184,"tag":210,"props":311,"children":314},{"href":312,"rel":313},"https://arxiv.org/abs/2306.00978",[214],[315],{"type":190,"value":316},"AWQ 论文",{"type":190,"value":219},{"type":184,"tag":210,"props":319,"children":322},{"href":320,"rel":321},"https://github.com/mit-han-lab/llm-awq",[214],[323],{"type":190,"value":324},"AWQ GitHub",{"type":190,"value":219},{"type":184,"tag":210,"props":327,"children":330},{"href":328,"rel":329},"https://leimao.github.io/blog/AWQ-Activation-Aware-Weight-Quantization/",[214],[331],{"type":190,"value":332},"AWQ 深度解析",{"type":184,"tag":192,"props":334,"children":336},{"id":335},"ggufllamacpp-本地推理格式",[337],{"type":190,"value":338},"GGUF：llama.cpp 本地推理格式",{"type":184,"tag":199,"props":340,"children":341},{},[342],{"type":190,"value":343},"GGUF（GPT-Generated Unified Format）是 llama.cpp 项目的模型格式，专为本地 CPU/GPU 推理优化。支持多种量化方案：Q4_0（极致压缩）、Q4_K_M（平衡选择）、Q5_K_M（质量优先）、Q8_0（接近无损）。是 Ollama、LM Studio 等本地 LLM 工具的标准格式。",{"type":184,"tag":199,"props":345,"children":346},{},[347,348,355,356,363,364],{"type":190,"value":208},{"type":184,"tag":210,"props":349,"children":352},{"href":350,"rel":351},"https://github.com/ggerganov/ggml/blob/master/docs/gguf.md",[214],[353],{"type":190,"value":354},"GGUF 格式规范",{"type":190,"value":219},{"type":184,"tag":210,"props":357,"children":360},{"href":358,"rel":359},"https://kaitchup.substack.com/p/choosing-a-gguf-model-k-quants-i",[214],[361],{"type":190,"value":362},"GGUF 量化选择指南",{"type":190,"value":219},{"type":184,"tag":210,"props":365,"children":368},{"href":366,"rel":367},"https://arxiv.org/pdf/2601.14277",[214],[369],{"type":190,"value":370},"llama.cpp 量化论文",{"title":178,"searchDepth":372,"depth":372,"links":373},2,[374,375,376,377,378],{"id":194,"depth":372,"text":197},{"id":237,"depth":372,"text":240},{"id":267,"depth":372,"text":270},{"id":297,"depth":372,"text":300},{"id":335,"depth":372,"text":338},"markdown","content:6.maps:_ai:optimization.md","content","6.maps/_ai/optimization.md","6.maps/_ai/optimization","md",[386,389],{"_path":387,"title":388,"description":178},"/maps/_ai/observability","可观测性 (Observability)",{"_path":390,"title":391,"description":178},"/maps/_ai/paper-writing","ML 论文写作 (ML Paper Writing)",1771696755742]