01,232,238,243,262,268,273,284,290,295,314,319,324],{"type":181,"tag":182,"props":183,"children":185},"element","h1",{"id":184},"提示工程-prompt-engineering",[186],{"type":187,"value":176},"text",{"type":181,"tag":189,"props":190,"children":192},"h2",{"id":191},"dspy声明式提示编程框架",[193],{"type":187,"value":194},"DSPy：声明式提示编程框架",{"type":181,"tag":196,"props":197,"children":198},"p",{},[199],{"type":187,"value":200},"DSPy 是斯坦福 NLP 团队开源的框架，将提示工程从\"手工调优\"转变为\"编程优化\"。核心抽象包括 Signature（声明输入输出语义）、Module（可组合的计算单元）、Optimizer（自动优化提示和权重）、Teleprompter（少样本示例编译器）。开发者只需描述任务逻辑，DSPy 自动优化提示词、选择示例、微调小模型，在多跳问答等任务上超越手工提示。",{"type":181,"tag":196,"props":202,"children":203},{},[204,206,215,217,224,225],{"type":187,"value":205},"见：",{"type":181,"tag":207,"props":208,"children":212},"a",{"href":209,"rel":210},"https://github.com/stanfordnlp/dspy",[211],"nofollow",[213],{"type":187,"value":214},"DSPy GitHub",{"type":187,"value":216}," | ",{"type":181,"tag":207,"props":218,"children":221},{"href":219,"rel":220},"https://dspy.ai/",[211],[222],{"type":187,"value":223},"DSPy 文档",{"type":187,"value":216},{"type":181,"tag":207,"props":226,"children":229},{"href":227,"rel":228},"https://arxiv.org/abs/2310.03714",[211],[230],{"type":187,"value":231},"DSPy 论文",{"type":181,"tag":189,"props":233,"children":235},{"id":234},"instructor结构化输出解析库",[236],{"type":187,"value":237},"Instructor：结构化输出解析库",{"type":181,"tag":196,"props":239,"children":240},{},[241],{"type":187,"value":242},"Instructor 基于 Pydantic 构建，解决 LLM 输出结构化的问题。通过定义数据模型类，自动将 LLM 的文本响应解析为强类型对象，内置重试、验证、流式处理。支持 OpenAI、Anthropic、Gemini 等主流模型，是生产环境中类型安全调用 LLM 的首选方案。",{"type":181,"tag":196,"props":244,"children":245},{},[246,247,254,255],{"type":187,"value":205},{"type":181,"tag":207,"props":248,"children":251},{"href":249,"rel":250},"https://github.com/jxnl/instructor",[211],[252],{"type":187,"value":253},"Instructor GitHub",{"type":187,"value":216},{"type":181,"tag":207,"props":256,"children":259},{"href":257,"rel":258},"https://python.useinstructor.com/",[211],[260],{"type":187,"value":261},"Instructor 文档",{"type":181,"tag":189,"props":263,"children":265},{"id":264},"guidance约束生成控制模板",[266],{"type":187,"value":267},"Guidance：约束生成控制模板",{"type":181,"tag":196,"props":269,"children":270},{},[271],{"type":187,"value":272},"Guidance 提供模板语法控制 LLM 的生成过程，支持在生成中强制特定格式（JSON、正则匹配）、动态选择分支、变量插值。通过控制流与生成交错，大幅减少无效输出和后续解析失败，适合需要严格输出格式的场景。",{"type":181,"tag":196,"props":274,"children":275},{},[276,277],{"type":187,"value":205},{"type":181,"tag":207,"props":278,"children":281},{"href":279,"rel":280},"https://github.com/guidance-ai/guidance",[211],[282],{"type":187,"value":283},"Guidance GitHub",{"type":181,"tag":189,"props":285,"children":287},{"id":286},"outlines可靠的文本结构化生成",[288],{"type":187,"value":289},"Outlines：可靠的文本结构化生成",{"type":181,"tag":196,"props":291,"children":292},{},[293],{"type":187,"value":294},"Outlines 通过预编译正则表达式或 JSON Schema 到高效索引结构，实现完全符合格式的生成。与 Guidance 相比更轻量、性能更高，支持批量生成和多种模型后端，是结构化生成的现代替代方案。",{"type":181,"tag":196,"props":296,"children":297},{},[298,299,306,307],{"type":187,"value":205},{"type":181,"tag":207,"props":300,"children":303},{"href":301,"rel":302},"https://github.com/outlines-dev/outlines",[211],[304],{"type":187,"value":305},"Outlines GitHub",{"type":187,"value":216},{"type":181,"tag":207,"props":308,"children":311},{"href":309,"rel":310},"https://dottxt-ai.github.io/outlines/",[211],[312],{"type":187,"value":313},"Outlines 文档",{"type":181,"tag":189,"props":315,"children":317},{"id":316},"工具选型指南",[318],{"type":187,"value":316},{"type":181,"tag":196,"props":320,"children":321},{},[322],{"type":187,"value":323},"选择取决于控制粒度：Instructor 适合\"解析已知格式的响应\"，Pydantic 验证确保类型安全；Guidance/Outlines 适合\"强制模型按格式生成\"，从源头约束输出结构。DSPy 则用于系统级优化，自动迭代提示策略。实际项目中常组合使用：Outlines 控制格式，Instructor 验证解析，DSPy 优化整体流程。",{"type":181,"tag":196,"props":325,"children":326},{},[327,328,335,336],{"type":187,"value":205},{"type":181,"tag":207,"props":329,"children":332},{"href":330,"rel":331},"https://www.linkedin.com/pulse/dspy-vs-instructor-pydantic-ai-which-one-right-you-answer-sancare-phdie",[211],[333],{"type":187,"value":334},"DSPy vs Instructor 对比",{"type":187,"value":216},{"type":181,"tag":207,"props":337,"children":340},{"href":338,"rel":339},"https://github.com/outlines-dev/outlines/blob/main/benchmarks/benchmark_readme.md",[211],[341],{"type":187,"value":342},"Outlines vs Guidance 性能对比",{"title":175,"searchDepth":344,"depth":344,"links":345},2,[346,347,348,349,350],{"id":191,"depth":344,"text":194},{"id":234,"depth":344,"text":237},{"id":264,"depth":344,"text":267},{"id":286,"depth":344,"text":289},{"id":316,"depth":344,"text":316},"markdown","content:6.maps:_ai:prompt-engineering.md","content","6.maps/_ai/prompt-engineering.md","6.maps/_ai/prompt-engineering","md",[358,361],{"_path":359,"title":360,"description":175},"/maps/_ai/post-training","后训练 (Post-Training)",{"_path":362,"title":363,"description":364},"/maps/_ai/prompt/context-engineering","Context Engineering","Context Engineering 是一种优化与大型语言模型（LLM）交互的技术，旨在通过提供结构化和相关的上下文信息，提高模型生成内容的准确性和相关性。",1771264674744]