,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":178,"body":180,"_type":451,"_id":452,"_source":453,"_file":454,"_stem":455,"_extension":456},"/maps/_ai/prompt-engineering","_ai",false,true,"","提示工程 (Prompt Engineering)",{"type":181,"children":182,"toc":442},"root",[183,191,198,204,235,241,246,265,271,276,287,293,298,317,322,327,346,351,357,362,367,381,390,395,400,426,431],{"type":184,"tag":185,"props":186,"children":188},"element","h1",{"id":187},"提示工程-prompt-engineering",[189],{"type":190,"value":179},"text",{"type":184,"tag":192,"props":193,"children":195},"h2",{"id":194},"dspy声明式提示编程框架",[196],{"type":190,"value":197},"DSPy：声明式提示编程框架",{"type":184,"tag":199,"props":200,"children":201},"p",{},[202],{"type":190,"value":203},"DSPy 是斯坦福 NLP 团队开源的框架，将提示工程从\"手工调优\"转变为\"编程优化\"。核心抽象包括 Signature（声明输入输出语义）、Module（可组合的计算单元）、Optimizer（自动优化提示和权重）、Teleprompter（少样本示例编译器）。开发者只需描述任务逻辑，DSPy 自动优化提示词、选择示例、微调小模型，在多跳问答等任务上超越手工提示。",{"type":184,"tag":199,"props":205,"children":206},{},[207,209,218,220,227,228],{"type":190,"value":208},"见：",{"type":184,"tag":210,"props":211,"children":215},"a",{"href":212,"rel":213},"https://github.com/stanfordnlp/dspy",[214],"nofollow",[216],{"type":190,"value":217},"DSPy GitHub",{"type":190,"value":219}," | ",{"type":184,"tag":210,"props":221,"children":224},{"href":222,"rel":223},"https://dspy.ai/",[214],[225],{"type":190,"value":226},"DSPy 文档",{"type":190,"value":219},{"type":184,"tag":210,"props":229,"children":232},{"href":230,"rel":231},"https://arxiv.org/abs/2310.03714",[214],[233],{"type":190,"value":234},"DSPy 论文",{"type":184,"tag":192,"props":236,"children":238},{"id":237},"instructor结构化输出解析库",[239],{"type":190,"value":240},"Instructor：结构化输出解析库",{"type":184,"tag":199,"props":242,"children":243},{},[244],{"type":190,"value":245},"Instructor 基于 Pydantic 构建，解决 LLM 输出结构化的问题。通过定义数据模型类，自动将 LLM 的文本响应解析为强类型对象，内置重试、验证、流式处理。支持 OpenAI、Anthropic、Gemini 等主流模型，是生产环境中类型安全调用 LLM 的首选方案。",{"type":184,"tag":199,"props":247,"children":248},{},[249,250,257,258],{"type":190,"value":208},{"type":184,"tag":210,"props":251,"children":254},{"href":252,"rel":253},"https://github.com/jxnl/instructor",[214],[255],{"type":190,"value":256},"Instructor GitHub",{"type":190,"value":219},{"type":184,"tag":210,"props":259,"children":262},{"href":260,"rel":261},"https://python.useinstructor.com/",[214],[263],{"type":190,"value":264},"Instructor 文档",{"type":184,"tag":192,"props":266,"children":268},{"id":267},"guidance约束生成控制模板",[269],{"type":190,"value":270},"Guidance：约束生成控制模板",{"type":184,"tag":199,"props":272,"children":273},{},[274],{"type":190,"value":275},"Guidance 提供模板语法控制 LLM 的生成过程，支持在生成中强制特定格式（JSON、正则匹配）、动态选择分支、变量插值。通过控制流与生成交错，大幅减少无效输出和后续解析失败，适合需要严格输出格式的场景。",{"type":184,"tag":199,"props":277,"children":278},{},[279,280],{"type":190,"value":208},{"type":184,"tag":210,"props":281,"children":284},{"href":282,"rel":283},"https://github.com/guidance-ai/guidance",[214],[285],{"type":190,"value":286},"Guidance GitHub",{"type":184,"tag":192,"props":288,"children":290},{"id":289},"outlines可靠的文本结构化生成",[291],{"type":190,"value":292},"Outlines：可靠的文本结构化生成",{"type":184,"tag":199,"props":294,"children":295},{},[296],{"type":190,"value":297},"Outlines 通过预编译正则表达式或 JSON Schema 到高效索引结构，实现完全符合格式的生成。与 Guidance 相比更轻量、性能更高，支持批量生成和多种模型后端，是结构化生成的现代替代方案。",{"type":184,"tag":199,"props":299,"children":300},{},[301,302,309,310],{"type":190,"value":208},{"type":184,"tag":210,"props":303,"children":306},{"href":304,"rel":305},"https://github.com/outlines-dev/outlines",[214],[307],{"type":190,"value":308},"Outlines GitHub",{"type":190,"value":219},{"type":184,"tag":210,"props":311,"children":314},{"href":312,"rel":313},"https://dottxt-ai.github.io/outlines/",[214],[315],{"type":190,"value":316},"Outlines 文档",{"type":184,"tag":192,"props":318,"children":320},{"id":319},"工具选型指南",[321],{"type":190,"value":319},{"type":184,"tag":199,"props":323,"children":324},{},[325],{"type":190,"value":326},"选择取决于控制粒度：Instructor 适合\"解析已知格式的响应\"，Pydantic 验证确保类型安全；Guidance/Outlines 适合\"强制模型按格式生成\"，从源头约束输出结构。DSPy 则用于系统级优化，自动迭代提示策略。实际项目中常组合使用：Outlines 控制格式，Instructor 验证解析，DSPy 优化整体流程。",{"type":184,"tag":199,"props":328,"children":329},{},[330,331,338,339],{"type":190,"value":208},{"type":184,"tag":210,"props":332,"children":335},{"href":333,"rel":334},"https://www.linkedin.com/pulse/dspy-vs-instructor-pydantic-ai-which-one-right-you-answer-sancare-phdie",[214],[336],{"type":190,"value":337},"DSPy vs Instructor 对比",{"type":190,"value":219},{"type":184,"tag":210,"props":340,"children":343},{"href":341,"rel":342},"https://github.com/outlines-dev/outlines/blob/main/benchmarks/benchmark_readme.md",[214],[344],{"type":190,"value":345},"Outlines vs Guidance 性能对比",{"type":184,"tag":192,"props":347,"children":349},{"id":348},"提示工程实践技巧",[350],{"type":190,"value":348},{"type":184,"tag":352,"props":353,"children":355},"h4",{"id":354},"利用上下文窗口优于依赖模型记忆",[356],{"type":190,"value":354},{"type":184,"tag":199,"props":358,"children":359},{},[360],{"type":190,"value":361},"当需要模型处理特定内容时，直接将其粘贴到提示中，而非依赖模型的\"知识\"。例如，与其问\"总结《傲慢与偏见》第一章\"，不如将第一章文本粘贴到提示中再要求总结。当内容在上下文窗口中时，模型拥有直接访问权，生成的质量显著高于依赖记忆召回。",{"type":184,"tag":352,"props":363,"children":365},{"id":364},"使用分隔符组织多部分输入",[366],{"type":190,"value":364},{"type":184,"tag":199,"props":368,"children":369},{},[370,372,379],{"type":190,"value":371},"当提示包含多个部分（指令、背景、参考资料）时，使用清晰的分隔符（如 ",{"type":184,"tag":373,"props":374,"children":376},"code",{"className":375},[],[377],{"type":190,"value":378},"---",{"type":190,"value":380},"、XML 标签）帮助模型区分不同区域：",{"type":184,"tag":382,"props":383,"children":385},"pre",{"code":384},"请总结以下文本：\n\n---\n[粘贴的文本内容]\n---\n",[386],{"type":184,"tag":373,"props":387,"children":388},{"__ignoreMap":178},[389],{"type":190,"value":384},{"type":184,"tag":352,"props":391,"children":393},{"id":392},"思考型模型的选择策略",[394],{"type":190,"value":392},{"type":184,"tag":199,"props":396,"children":397},{},[398],{"type":190,"value":399},"不同模型适合不同任务类型：",{"type":184,"tag":401,"props":402,"children":403},"ul",{},[404,416],{"type":184,"tag":405,"props":406,"children":407},"li",{},[408,414],{"type":184,"tag":409,"props":410,"children":411},"strong",{},[412],{"type":190,"value":413},"普通模型（GPT-4o、Claude Sonnet）",{"type":190,"value":415},"：适合创意写作、一般问答、日常对话",{"type":184,"tag":405,"props":417,"children":418},{},[419,424],{"type":184,"tag":409,"props":420,"children":421},{},[422],{"type":190,"value":423},"思考型模型（o3-mini、o1）",{"type":190,"value":425},"：适合数学、代码、逻辑推理等需要深度思考的任务",{"type":184,"tag":199,"props":427,"children":428},{},[429],{"type":190,"value":430},"思考型模型通过强化学习训练，会在回答前进行内部\"思考链\"推理。但对于创意类任务，这种思考不一定带来提升，反而可能让输出显得过于机械。",{"type":184,"tag":199,"props":432,"children":433},{},[434,435],{"type":190,"value":208},{"type":184,"tag":210,"props":436,"children":439},{"href":437,"rel":438},"https://www.youtube.com/watch?v=EWvNQjAaOHw",[214],[440],{"type":190,"value":441},"How I use LLM - Andrej Karpathy",{"title":178,"searchDepth":443,"depth":443,"links":444},2,[445,446,447,448,449,450],{"id":194,"depth":443,"text":197},{"id":237,"depth":443,"text":240},{"id":267,"depth":443,"text":270},{"id":289,"depth":443,"text":292},{"id":319,"depth":443,"text":319},{"id":348,"depth":443,"text":348},"markdown","content:6.maps:_ai:prompt-engineering.md","content","6.maps/_ai/prompt-engineering.md","6.maps/_ai/prompt-engineering","md",[458,461],{"_path":459,"title":460,"description":178},"/maps/_ai/post-training","后训练 (Post-Training)",{"_path":462,"title":463,"description":464},"/maps/_ai/prompt/context-engineering","Context Engineering","Context Engineering 是一种优化与大型语言模型（LLM）交互的技术，旨在通过提供结构化和相关的上下文信息，提高模型生成内容的准确性和相关性。",1771695824884]