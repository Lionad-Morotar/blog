:198,"props":457,"children":458},{},[459],{"type":185,"tag":202,"props":460,"children":463},{"href":461,"rel":462},"https://indienova.com/indie-game-development/ai-assisted-game-development-minimal-case-study/",[206],[464],{"type":191,"value":465},"AI辅助游戏开发极简案例：一个解谜卡牌对战小游戏",{"type":185,"tag":186,"props":467,"children":469},{"id":468},"framework",[470],{"type":191,"value":471},"Framework",{"type":185,"tag":194,"props":473,"children":474},{},[475],{"type":185,"tag":198,"props":476,"children":477},{},[478],{"type":185,"tag":202,"props":479,"children":481},{"href":480},"/maps/_ai/framework/saif",[482],{"type":191,"value":483},"SAIF",{"type":185,"tag":186,"props":485,"children":487},{"id":486},"workflow",[488],{"type":191,"value":489},"Workflow",{"type":185,"tag":194,"props":491,"children":492},{},[493],{"type":185,"tag":198,"props":494,"children":495},{},[496],{"type":185,"tag":202,"props":497,"children":499},{"href":498},"/maps/_ai/workflow/0.index",[500],{"type":191,"value":501},"开发工作流",{"type":185,"tag":186,"props":503,"children":505},{"id":504},"training",[506],{"type":191,"value":507},"Training",{"type":185,"tag":194,"props":509,"children":510},{},[511],{"type":185,"tag":198,"props":512,"children":513},{},[514],{"type":185,"tag":202,"props":515,"children":517},{"href":516},"/maps/_ai/training/training",[518],{"type":191,"value":519},"AI Training",{"type":185,"tag":186,"props":521,"children":523},{"id":522},"ai-的下半场",[524],{"type":191,"value":525},"AI 的下半场",{"type":185,"tag":248,"props":527,"children":529},{"id":528},"从训练到评估的范式转移",[530],{"type":191,"value":528},{"type":185,"tag":216,"props":532,"children":533},{},[534],{"type":191,"value":535},"AI 发展进入\"下半场\"，核心特征是从\"训练大于评估\"转向\"评估大于训练\"。上半场通过反向传播、AlexNet、DQN、Transformer、GPT-3 等方法创新不断刷分；下半场需要重新定义问题，构建能衡量真实世界效用的评估体系。OpenAI 前研究员姚顺雨（Shunyu Yao）提出这一框架，认为当前 AI 在 MMLU、Codeforces 等基准上达到博士水平，却未能显著改变 GDP——核心矛盾在于评估设定追求\"难题\"，而真实价值在于\"实用\"。",{"type":185,"tag":216,"props":537,"children":538},{},[539,540],{"type":191,"value":225},{"type":185,"tag":202,"props":541,"children":544},{"href":542,"rel":543},"https://ysymyth.github.io/The-Second-Half/",[206],[545],{"type":191,"value":546},"The Second Half - Shunyu Yao",{"type":185,"tag":248,"props":548,"children":550},{"id":549},"ai-训练的标准配方",[551],{"type":191,"value":552},"AI 训练的标准配方",{"type":185,"tag":216,"props":554,"children":555},{},[556],{"type":191,"value":557},"强化学习的通用配方由三要素构成：强大的语言先验（LLM）、支持推理的行动空间（将思考作为动作）、简单可扩展的算法。这一配方在数学推理（o1/o3）、计算机操作（Operator）等领域都被验证有效，意味着\"创造新基准比解决旧基准更有价值\"。",{"type":185,"tag":216,"props":559,"children":560},{},[561,562],{"type":191,"value":225},{"type":185,"tag":202,"props":563,"children":566},{"href":564,"rel":565},"https://arxiv.org/abs/2210.03629",[206],[567],{"type":191,"value":568},"ReAct: Synergizing Reasoning and Acting in Language Models",{"type":185,"tag":186,"props":570,"children":572},{"id":571},"行业动态",[573],{"type":191,"value":571},{"type":185,"tag":248,"props":575,"children":577},{"id":576},"科技巨头的-ai-军备竞赛规模有多大",[578],{"type":191,"value":579},"科技巨头的 AI 军备竞赛规模有多大？",{"type":185,"tag":216,"props":581,"children":582},{},[583,585,591],{"type":191,"value":584},"2026 年，亚马逊、谷歌、微软、Meta 和 Oracle 五大科技巨头的 AI 相关资本支出预计达 ",{"type":185,"tag":586,"props":587,"children":588},"strong",{},[589],{"type":191,"value":590},"7000 亿美元",{"type":191,"value":592},"，相当于美国军费的约四分之三。如此巨额投入导致电工人才短缺，部分建筑项目被迫暂停。这一数据直观展示了 AI 热潮对实体经济的资源虹吸效应——AI 竞争已从技术竞争升级为国家级基础设施竞争。",{"type":185,"tag":594,"props":595,"children":596},"blockquote",{},[597],{"type":185,"tag":216,"props":598,"children":599},{},[600,602],{"type":191,"value":601},"#周刊摘录 见：",{"type":185,"tag":202,"props":603,"children":606},{"href":604,"rel":605},"https://www.ruanyifeng.com/blog/2026/02/weekly-issue-385.html",[206],[607],{"type":191,"value":608},"科技周刊第385期",{"type":185,"tag":248,"props":610,"children":612},{"id":611},"知识产权的因果循环",[613],{"type":191,"value":611},{"type":185,"tag":216,"props":615,"children":616},{},[617],{"type":191,"value":618},"OpenAI 长期被指控未经授权使用艺术家和作家的作品训练模型，如今却反过来控诉 DeepSeek 通过「模型蒸馏」技术窃取自己的知识产权。这种「偷数据者抱怨被偷」的戏剧性反转，揭示了科技行业一个古老规律：当技术霸权者打破规则时，往往忘了规则也可能被用来对付自己。讽刺的是，OpenAI 曾游说政府要求版权豁免，如今却成为了自己最痛恨的「免费搭车者」的受害者。",{"type":185,"tag":216,"props":620,"children":621},{},[622,623,630,632],{"type":191,"value":225},{"type":185,"tag":202,"props":624,"children":627},{"href":625,"rel":626},"https://www.fdd.org/analysis/2026/02/13/openai-alleges-chinas-deepseek-stole-its-intellectual-property-to-train-its-own-models/",[206],[628],{"type":191,"value":629},"OpenAI Alleges China's DeepSeek Stole its Intellectual Property",{"type":191,"value":631},"、",{"type":185,"tag":202,"props":633,"children":636},{"href":634,"rel":635},"https://www.theguardian.com/books/2025/apr/04/us-authors-copyright-lawsuits-against-openai-and-microsoft-combined-in-new-york-with-newspaper-actions",[206],[637],{"type":191,"value":638},"US authors' copyright lawsuits against OpenAI",{"type":185,"tag":186,"props":640,"children":642},{"id":641},"推荐系统",[643],{"type":191,"value":641},{"type":185,"tag":194,"props":645,"children":646},{},[647],{"type":185,"tag":198,"props":648,"children":649},{},[650],{"type":185,"tag":202,"props":651,"children":653},{"href":652},"/maps/_ai/recommendation/recommendation-system",[654],{"type":191,"value":641},{"title":178,"searchDepth":656,"depth":656,"links":657},2,[658,659,660,661,662,663,664,665,666,667,668,669,670,671,672,673,674,675,676],{"id":188,"depth":656,"text":192},{"id":212,"depth":656,"text":212},{"id":244,"depth":656,"text":244},{"id":269,"depth":656,"text":272},{"id":286,"depth":656,"text":286},{"id":316,"depth":656,"text":319},{"id":333,"depth":656,"text":336},{"id":360,"depth":656,"text":132},{"id":377,"depth":656,"text":380},{"id":395,"depth":656,"text":398},{"id":412,"depth":656,"text":415},{"id":430,"depth":656,"text":433},{"id":450,"depth":656,"text":450},{"id":468,"depth":656,"text":471},{"id":486,"depth":656,"text":489},{"id":504,"depth":656,"text":507},{"id":522,"depth":656,"text":525},{"id":571,"depth":656,"text":571},{"id":64