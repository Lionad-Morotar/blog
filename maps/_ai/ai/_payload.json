/openai-alleges-chinas-deepseek-stole-its-intellectual-property-to-train-its-own-models/",[203],[539],{"type":188,"value":540},"OpenAI Alleges China's DeepSeek Stole its Intellectual Property",{"type":188,"value":542},"、",{"type":182,"tag":199,"props":544,"children":547},{"href":545,"rel":546},"https://www.theguardian.com/books/2025/apr/04/us-authors-copyright-lawsuits-against-openai-and-microsoft-combined-in-new-york-with-newspaper-actions",[203],[548],{"type":188,"value":549},"US authors' copyright lawsuits against OpenAI",{"type":182,"tag":183,"props":551,"children":553},{"id":552},"推荐系统",[554],{"type":188,"value":552},{"type":182,"tag":191,"props":556,"children":557},{},[558],{"type":182,"tag":195,"props":559,"children":560},{},[561],{"type":182,"tag":199,"props":562,"children":564},{"href":563},"/maps/_ai/recommendation/recommendation-system",[565],{"type":188,"value":552},{"title":175,"searchDepth":567,"depth":567,"links":568},2,[569,570,571,572,573,574,575,576,577,578,579,580,581,582,583,584],{"id":185,"depth":567,"text":189},{"id":209,"depth":567,"text":209},{"id":241,"depth":567,"text":241},{"id":266,"depth":567,"text":269},{"id":283,"depth":567,"text":283},{"id":313,"depth":567,"text":316},{"id":330,"depth":567,"text":333},{"id":357,"depth":567,"text":360},{"id":375,"depth":567,"text":378},{"id":393,"depth":567,"text":396},{"id":410,"depth":567,"text":413},{"id":428,"depth":567,"text":428},{"id":446,"depth":567,"text":449},{"id":464,"depth":567,"text":467},{"id":482,"depth":567,"text":482},{"id":552,"depth":567,"text":552},"markdown","content:6.maps:_ai:ai.md","content","6.maps/_ai/ai.md","6.maps/_ai/ai","md",[592,596],{"_path":593,"title":594,"description":595},"/maps/_ai/agents/toxic-flow-analysis","有毒数据流分析","在多代理系统中识别和缓解敏感数据泄露风险的技术",{"_path":597,"title":598,"description":599},"/maps/_ai/benchmark/benchmark","LLM Benchmark","各类大语言模型的基准测试结果",1771214193619]