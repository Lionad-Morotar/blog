en":182,"toc":804},"root",[183,191,198,204,227,233,238,257,263,268,287,293,298,317,323,328,347,353,358,377,383,388,407,411,417,424,437,448,454,459,518,524,529,572,578,583,644,650,655,678,684,689,765,771],{"type":184,"tag":185,"props":186,"children":188},"element","h1",{"id":187},"模型架构-model-architectures",[189],{"type":190,"value":179},"text",{"type":184,"tag":192,"props":193,"children":195},"h2",{"id":194},"litgptpytorch-lightning-原生的-llm-工具包",[196],{"type":190,"value":197},"LitGPT：PyTorch Lightning 原生的 LLM 工具包",{"type":184,"tag":199,"props":200,"children":201},"p",{},[202],{"type":190,"value":203},"LitGPT 让在个人数据上训练、微调和部署大模型变得简单高效。它内置 20+ 主流开源架构（Llama、Mistral、Qwen 等），并预配置 Flash Attention、FSDP 分布式训练、4-bit/8-bit 量化等生产级优化，开箱即用。核心代码采用\"单文件模型\"设计，没有过度抽象，适合快速原型验证和学习 LLM 工程实践。",{"type":184,"tag":199,"props":205,"children":206},{},[207,209,218,220],{"type":190,"value":208},"见：",{"type":184,"tag":210,"props":211,"children":215},"a",{"href":212,"rel":213},"https://github.com/Lightning-AI/litgpt",[214],"nofollow",[216],{"type":190,"value":217},"LitGPT GitHub",{"type":190,"value":219}," | ",{"type":184,"tag":210,"props":221,"children":224},{"href":222,"rel":223},"https://lightning.ai/litgpt",[214],[225],{"type":190,"value":226},"LitGPT 文档",{"type":184,"tag":192,"props":228,"children":230},{"id":229},"mamba线性复杂度的状态空间模型",[231],{"type":190,"value":232},"Mamba：线性复杂度的状态空间模型",{"type":184,"tag":199,"props":234,"children":235},{},[236],{"type":190,"value":237},"Mamba 代表了后 Transformer 时代的重要探索。传统 Transformer 的自注意力机制是二次复杂度 O(n²)，长序列时计算和内存开销爆炸。Mamba 通过选择性状态空间（Selective State Space）将复杂度降至线性 O(n)，同时保留了长程依赖建模能力。2024 年起，Mamba 与 Transformer 的混合架构成为主流——用 Mamba 处理长程上下文，用注意力机制处理局部精细交互。",{"type":184,"tag":199,"props":239,"children":240},{},[241,242,249,250],{"type":190,"value":208},{"type":184,"tag":210,"props":243,"children":246},{"href":244,"rel":245},"https://arxiv.org/abs/2312.00752",[214],[247],{"type":190,"value":248},"Mamba: Linear-Time Sequence Modeling",{"type":190,"value":219},{"type":184,"tag":210,"props":251,"children":254},{"href":252,"rel":253},"https://newsletter.maartengrootendorst.com/p/a-visual-guide-to-mamba-and-state",[214],[255],{"type":190,"value":256},"A Visual Guide to Mamba",{"type":184,"tag":192,"props":258,"children":260},{"id":259},"nanogpt极简-gpt-教学实现",[261],{"type":190,"value":262},"NanoGPT：极简 GPT 教学实现",{"type":184,"tag":199,"props":264,"children":265},{},[266],{"type":190,"value":267},"Andrej Karpathy 开发的 NanoGPT 用最简洁的代码实现了完整的 GPT 训练流程，核心代码仅约 300 行。这种\"minimal but complete\"的设计理念，让研究者能聚焦核心机制而非工程细节。配合《Let's build GPT: from scratch》视频系列，是理解 GPT 原理的最佳入门资料。",{"type":184,"tag":199,"props":269,"children":270},{},[271,272,279,280],{"type":190,"value":208},{"type":184,"tag":210,"props":273,"children":276},{"href":274,"rel":275},"https://github.com/karpathy/nanoGPT",[214],[277],{"type":190,"value":278},"nanoGPT GitHub",{"type":190,"value":219},{"type":184,"tag":210,"props":281,"children":284},{"href":282,"rel":283},"https://github.com/karpathy/build-nanogpt",[214],[285],{"type":190,"value":286},"build-nanogpt 教学仓库",{"type":184,"tag":192,"props":288,"children":290},{"id":289},"rwkvrnn-与-transformer-的混合架构",[291],{"type":190,"value":292},"RWKV：RNN 与 Transformer 的混合架构",{"type":184,"tag":199,"props":294,"children":295},{},[296],{"type":190,"value":297},"RWKV（Receptance Weighted Key Value）结合了 RNN 的 O(1) 推理内存和 Transformer 的并行训练能力。训练时像 Transformer 一样并行，推理时像 RNN 一样常数内存——这个特性让它在端侧部署和长文本生成场景有独特优势，支持 10 万+ tokens 的长文本续写。",{"type":184,"tag":199,"props":299,"children":300},{},[301,302,309,310],{"type":190,"value":208},{"type":184,"tag":210,"props":303,"children":306},{"href":304,"rel":305},"https://arxiv.org/abs/2305.13048",[214],[307],{"type":190,"value":308},"RWKV 论文",{"type":190,"value":219},{"type":184,"tag":210,"props":311,"children":314},{"href":312,"rel":313},"https://huggingface.co/blog/rwkv",[214],[315],{"type":190,"value":316},"Hugging Face RWKV 介绍",{"type":184,"tag":192,"props":318,"children":320},{"id":319},"torchtitanpytorch-原生大规模训练框架",[321],{"type":190,"value":322},"TorchTitan：PyTorch 原生大规模训练框架",{"type":184,"tag":199,"props":324,"children":325},{},[326],{"type":190,"value":327},"TorchTitan 是 PyTorch 官方出品的大规模模型训练框架，目标是成为\"PyTorch 原生的 Megatron/DeepSpeed 替代\"。它提供 4D 并行（数据并行、张量并行、流水线并行、序列并行）的统一实现，支持弹性扩缩容。各并行策略可独立开关、自由组合，无需修改模型代码即可无缝应用到大规模训练。",{"type":184,"tag":199,"props":329,"children":330},{},[331,332,339,340],{"type":190,"value":208},{"type":184,"tag":210,"props":333,"children":336},{"href":334,"rel":335},"https://github.com/pytorch/torchtitan",[214],[337],{"type":190,"value":338},"TorchTitan GitHub",{"type":190,"value":219},{"type":184,"tag":210,"props":341,"children":344},{"href":342,"rel":343},"https://arxiv.org/abs/2410.06511",[214],[345],{"type":190,"value":346},"TorchTitan 论文",{"type":184,"tag":192,"props":348,"children":350},{"id":349},"jepa非生成式自监督学习架构",[351],{"type":190,"value":352},"JEPA：非生成式自监督学习架构",{"type":184,"tag":199,"props":354,"children":355},{},[356],{"type":190,"value":357},"JEPA（Joint Embedding Predictive Architecture）是杨立昆提出的非生成式学习架构，核心创新是在抽象表示空间而非像素/token 空间进行预测。与传统生成模型重建输入不同，JEPA 学习语义表示，一次性预测而无需顺序解码。LeCun 认为这是通向 AGI 的必经之路——真正的智能需要世界模型，而非仅仅自回归生成。",{"type":184,"tag":199,"props":359,"children":360},{},[361,362,369,370],{"type":190,"value":208},{"type":184,"tag":210,"props":363,"children":366},{"href":364,"rel":365},"https://rohitbandaru.github.io/blog/JEPA-Deep-Dive/",[214],[367],{"type":190,"value":368},"JEPA 深度解析",{"type":190,"value":219},{"type":184,"tag":210,"props":371,"children":374},{"href":372,"rel":373},"https://ai.meta.com/blog/v-jepa-yann-lecun-ai-model-video-joint-embedding-predictive-architecture/",[214],[375],{"type":190,"value":376},"V-JEPA 官方发布",{"type":184,"tag":192,"props":378,"children":380},{"id":379},"空间智能理解三维世界的新一代-ai",[381],{"type":190,"value":382},"空间智能：理解三维世界的新一代 AI",{"type":184,"tag":199,"props":384,"children":385},{},[386],{"type":190,"value":387},"李飞飞创立的 World Labs 专注于\"空间智能\"——让 AI 理解三维世界的几何、物理和语义。真正的空间智能世界模型需要三种能力：生成性（创造遵守物理定律的世界）、多模态（融合视觉、语言、空间信息）、交互性（支持探索和导航的 3D 环境）。她预言未来五年，Transformer 可能被淘汰。",{"type":184,"tag":199,"props":389,"children":390},{},[391,392,399,400],{"type":190,"value":208},{"type":184,"tag":210,"props":393,"children":396},{"href":394,"rel":395},"https://www.mittrchina.com/news/detail/15468",[214],[397],{"type":190,"value":398},"李飞飞空间智能长文",{"type":190,"value":219},{"type":184,"tag":210,"props":401,"children":404},{"href":402,"rel":403},"https://zhuanlan.zhihu.com/p/1976808836682765387",[214],[405],{"type":190,"value":406},"李飞飞万字访谈",{"type":184,"tag":408,"props":409,"children":410},"hr",{},[],{"type":184,"tag":192,"props":412,"children":414},{"id":413},"transformer-基础架构",[415],{"type":190,"value":416},"Transformer 基础架构",{"type":184,"tag":418,"props":419,"children":421},"h4",{"id":420},"transformer-是什么",[422],{"type":190,"value":423},"Transformer 是什么？",{"type":184,"tag":199,"props":425,"children":426},{},[427,429,435],{"type":190,"value":428},"Transformer 是一种神经网络架构，2017 年在论文 \"Attention is All You Need\" 中首次提出。它已成为深度学习模型的主流架构，驱动着 GPT、Llama、Gemini 等文本生成模型，同时也应用于音频生成、图像识别、蛋白质结构预测等领域。文本生成类 Transformer 的核心原理是",{"type":184,"tag":430,"props":431,"children":432},"strong",{},[433],{"type":190,"value":434},"下一个 token 预测",{"type":190,"value":436},"——根据用户输入的文本提示，预测最可能的下一个词（或词片段）。其核心创新在于自注意力机制（self-attention），使模型能够处理整个序列并更有效地捕捉长距离依赖关系。",{"type":184,"tag":199,"props":438,"children":439},{},[440,441],{"type":190,"value":208},{"type":184,"tag":210,"props":442,"children":445},{"href":443,"rel":444},"https://poloclub.github.io/transformer-explainer/",[214],[446],{"type":190,"value":447},"Transformer Explainer",{"type":184,"tag":418,"props":449,"children":451},{"id":450},"transformer-架构三大组件是什么",[452],{"type":190,"value":453},"Transformer 架构三大组件是什么？",{"type":184,"tag":199,"props":455,"children":456},{},[457],{"type":190,"value":458},"每个文本生成 Transformer 包含三个关键组件：",{"type":184,"tag":460,"props":461,"children":462},"ol",{},[463,474,508],{"type":184,"tag":464,"props":465,"children":466},"li",{},[467,472],{"type":184,"tag":430,"props":468,"children":469},{},[470],{"type":190,"value":471},"Embedding（嵌入层）",{"type":190,"value":473},"：将文本输入切分为 token（词或子词），转换为捕获语义含义的数值向量",{"type":184,"tag":464,"props":475,"children":476},{},[477,482,484],{"type":184,"tag":430,"props":478,"children":479},{},[480],{"type":190,"value":481},"Transformer Block（变换器块）",{"type":190,"value":483},"：模型的核心构建模块，包含：\n",{"type":184,"tag":485,"props":486,"children":487},"ul",{},[488,498],{"type":184,"tag":464,"props":489,"children":490},{},[491,496],{"type":184,"tag":430,"props":492,"children":493},{},[494],{"type":190,"value":495},"Attention Mechanism（注意力机制）",{"type":190,"value":497},"：允许 token 之间通信，捕获上下文信息和词间关系",{"type":184,"tag":464,"props":499,"children":500},{},[501,506],{"type":184,"tag":430,"props":502,"children":503},{},[504],{"type":190,"value":505},"MLP（多层感知机）",{"type":190,"value":507},"：对每个 token 独立操作，精化每个 token 的表示",{"type":184,"tag":464,"props":509,"children":510},{},[511,516],{"type":184,"tag":430,"props":512,"children":513},{},[514],{"type":190,"value":515},"Output Probabilities（输出概率）",{"type":190,"value":517},"：最终的线性层和 softmax 层将处理后的嵌入转换为概率，预测序列中的下一个 token",{"type":184,"tag":418,"props":519,"children":521},{"id":520},"embedding-层如何将文本转换为向量表示",[522],{"type":190,"value":523},"Embedding 层如何将文本转换为向量表示？",{"type":184,"tag":199,"props":525,"children":526},{},[527],{"type":190,"value":528},"Embedding 层将输入提示转换为模型可理解的数值表示，包含四个步骤：",{"type":184,"tag":460,"props":530,"children":531},{},[532,542,552,562],{"type":184,"tag":464,"props":533,"children":534},{},[535,540],{"type":184,"tag":430,"props":536,"children":537},{},[538],{"type":190,"value":539},"Tokenization（分词）",{"type":190,"value":541},"：将输入文本切分为 token（词或子词）。GPT-2 的词表有 50,257 个唯一 token",{"type":184,"tag":464,"props":543,"children":544},{},[545,550],{"type":184,"tag":430,"props":546,"children":547},{},[548],{"type":190,"value":549},"Token Embedding（词嵌入）",{"type":190,"value":551},"：每个 token 被表示为 768 维向量（维度因模型而异）。相似含义的 token 在高维空间中距离更近",{"type":184,"tag":464,"props":553,"children":554},{},[555,560],{"type":184,"tag":430,"props":556,"children":557},{},[558],{"type":190,"value":559},"Positional Encoding（位置编码）",{"type":190,"value":561},"：编码每个 token 在输入序列中的位置信息。GPT-2 从零开始训练自己的位置编码矩阵",{"type":184,"tag":464,"props":563,"children":564},{},[565,570],{"type":184,"tag":430,"props":566,"children":567},{},[568],{"type":190,"value":569},"Final Embedding（最终嵌入）",{"type":190,"value":571},"：将 token 编码和位置编码相加，得到最终的嵌入表示",{"type":184,"tag":418,"props":573,"children":575},{"id":574},"多头自注意力机制如何工作",[576],{"type":190,"value":577},"多头自注意力机制如何工作？",{"type":184,"tag":199,"props":579,"children":580},{},[581],{"type":190,"value":582},"自注意力机制使模型能够捕获序列中 token 之间的关系：",{"type":184,"tag":460,"props":584,"children":585},{},[586,596,606,634],{"type":184,"tag":464,"props":587,"children":588},{},[589,594],{"type":184,"tag":430,"props":590,"children":591},{},[592],{"type":190,"value":593},"Q/K/V 矩阵计算",{"type":190,"value":595},"：每个 token 的嵌入向量被转换为三个向量——Query（查询）、Key（键）、Value（值）。可用搜索类比理解：Q 是搜索框输入，K 是网页标题，V 是网页内容",{"type":184,"tag":464,"props":597,"children":598},{},[599,604],{"type":184,"tag":430,"props":600,"children":601},{},[602],{"type":190,"value":603},"多头分割",{"type":190,"value":605},"：Q/K/V 向量被分割成多个头（GPT-2 small 有 12 个头），每个头独立处理嵌入的不同段，捕获不同的句法和语义关系",{"type":184,"tag":464,"props":607,"children":608},{},[609,614,616],{"type":184,"tag":430,"props":610,"children":611},{},[612],{"type":190,"value":613},"Masked Self-Attention（掩码自注意力）",{"type":190,"value":615},"：\n",{"type":184,"tag":485,"props":617,"children":618},{},[619,624,629],{"type":184,"tag":464,"props":620,"children":621},{},[622],{"type":190,"value":623},"计算 Q 和 K 的点积得到注意力分数",{"type":184,"tag":464,"props":625,"children":626},{},[627],{"type":190,"value":628},"对注意力矩阵的上三角应用 mask，防止模型访问未来 token（不能\"偷看\"未来）",{"type":184,"tag":464,"props":630,"children":631},{},[632],{"type":190,"value":633},"经过 softmax 转换为概率，每行总和为 1",{"type":184,"tag":464,"props":635,"children":636},{},[637,642],{"type":184,"tag":430,"props":638,"children":639},{},[640],{"type":190,"value":641},"输出和拼接",{"type":190,"value":643},"：将注意力分数与 V 矩阵相乘，12 个头的输出拼接后通过线性投影",{"type":184,"tag":418,"props":645,"children":647},{"id":646},"mlp-层的作用是什么",[648],{"type":190,"value":649},"MLP 层的作用是什么？",{"type":184,"tag":199,"props":651,"children":652},{},[653],{"type":190,"value":654},"MLP（多层感知机）在自注意力之后增强模型的表示能力：",{"type":184,"tag":485,"props":656,"children":657},{},[658,663,668,673],{"type":184,"tag":464,"props":659,"children":660},{},[661],{"type":190,"value":662},"包含两个线性变换，中间使用 GELU 激活函数",{"type":184,"tag":464,"props":664,"children":665},{},[666],{"type":190,"value":667},"第一次线性变换将维度从 768 扩展到 3072（4 倍），允许模型在高维空间捕获更复杂的模式",{"type":184,"tag":464,"props":669,"children":670},{},[671],{"type":190,"value":672},"第二次线性变换将维度压缩回 768，保留有用的非线性变换",{"type":184,"tag":464,"props":674,"children":675},{},[676],{"type":190,"value":677},"与自注意力不同，MLP 独立处理每个 token，仅将每个 token 的表示从一个空间映射到另一个空间",{"type":184,"tag":418,"props":679,"children":681},{"id":680},"输出概率如何生成下一个-token",[682],{"type":190,"value":683},"输出概率如何生成下一个 token？",{"type":184,"tag":199,"props":685,"children":686},{},[687],{"type":190,"value":688},"经过所有 Transformer Block 处理后：",{"type":184,"tag":460,"props":690,"children":691},{},[692,697,702],{"type":184,"tag":464,"props":693,"children":694},{},[695],{"type":190,"value":696},"最终线性层将表示投影到 50,257 维空间（词表大小），每个 token 对应一个 logit 值",{"type":184,"tag":464,"props":698,"children":699},{},[700],{"type":190,"value":701},"Softmax 将 logits 转换为概率分布（总和为 1）",{"type":184,"tag":464,"props":703,"children":704},{},[705,707],{"type":190,"value":706},"通过采样生成下一个 token，关键超参数：\n",{"type":184,"tag":485,"props":708,"children":709},{},[710,745,755],{"type":184,"tag":464,"props":711,"children":712},{},[713,718,720],{"type":184,"tag":430,"props":714,"children":715},{},[716],{"type":190,"value":717},"Temperature",{"type":190,"value":719},"：控制随机性\n",{"type":184,"tag":485,"props":721,"children":722},{},[723,728,733],{"type":184,"tag":464,"props":724,"children":725},{},[726],{"type":190,"value":727},"=1：无影响",{"type":184,"tag":464,"props":729,"children":730},{},[731],{"type":190,"value":732},"\u003C1：更确定、更尖锐的分布",{"type":184,"tag":464,"props":734,"children":735},{},[736],{"type":184,"tag":737,"props":738,"children":739},"blockquote",{},[740],{"type":184,"tag":199,"props":741,"children":742},{},[743],{"type":190,"value":744},"1：更柔和、更\"有创意\"的分布",{"type":184,"tag":464,"props":746,"children":747},{},[748,753],{"type":184,"tag":430,"props":749,"children":750},{},[751],{"type":190,"value":752},"Top-k 采样",{"type":190,"value":754},"：仅考虑概率最高的 k 个 token",{"type":184,"tag":464,"props":756,"children":757},{},[758,763],{"type":184,"tag":430,"props":759,"children":760},{},[761],{"type":190,"value":762},"Top-p 采样",{"type":190,"value":764},"：考虑累积概率超过阈值 p 的最小 token 集合",{"type":184,"tag":418,"props":766,"children":768},{"id":767},"辅助架构特性有哪些",[769],{"type":190,"value":770},"辅助架构特性有哪些？",{"type":184,"tag":485,"props":772,"children":773},{},[774,784,794],{"type":184,"tag":464,"props":775,"children":776},{},[777,782],{"type":184,"tag":430,"props":778,"children":779},{},[780],{"type":190,"value":781},"Layer Normalization（层归一化）",{"type":190,"value":783},"：稳定训练、加速收敛，在每个 Transformer Block 中应用两次（注意力前和 MLP 前）",{"type":184,"tag":464,"props":785,"children":786},{},[787,792],{"type":184,"tag":430,"props":788,"children":789},{},[790],{"type":190,"value":791},"Dropout（随机失活）",{"type":190,"value":793},"：训练时随机将部分权重设为零，防止过拟合；推理时关闭",{"type":184,"tag":464,"props":795,"children":796},{},[797,802],{"type":184,"tag":430,"props":798,"children":799},{},[800],{"type":190,"value":801},"Residual Connections（残差连接）",{"type":190,"value":803},"：绕过一层或多层的快捷连接，缓解梯度消失问题，使深层网络训练成为可能。GPT-2 在每个 Transformer Block 中使用两次",{"title":178,"searchDepth":805,"depth":805,"links":806},2,[807,808,809,810,811,812,813,814],{"id":194,"depth":805,"text":197},{"id":229,"depth":805,"text":232},{"id":259,"depth":805,"text":262},{"id":289,"depth":805,"text":292},{"id":319,"depth":805,"text":322},{"id":349,"depth":805,"text":352},{"id":379,"depth":805,"text":382},{"id":413,"depth":805,"text":416},"markdown","content:6.maps:_ai:architectures.md","content","6.maps/_ai/architectures.md","6.maps/_ai/architectures","md",[822,826],{"_path":823,"title":824,"description":825},"/maps/_ai/ai","Machine Learning","machine learning related",{"_path":827,"title":828,"description":829},"/maps/_ai/benchmark/benchmark","LLM Benchmark","各类大语言模型的基准测试结果",1771696729228]