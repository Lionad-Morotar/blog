[{"data":1,"prerenderedAt":827},["ShallowReactive",2],{"navigation":3,"/maps/_ai/architectures":170,"/maps/_ai/architectures-surround":818},[4,35,92,98,125,131,155,161],{"title":5,"_path":6,"children":7},"心流思绪 / Heart Flows","/flows",[8,11,14,17,20,23,26,29,32],{"title":9,"_path":10},"📕 狮子的书单推荐","/flows/books",{"title":12,"_path":13},"🚝 四十二篇系列","/flows/forty-two",{"title":15,"_path":16},"🌃 长夜梦","/flows/long-night-dream",{"title":18,"_path":19},"🌌 万物联结与幸福感","/flows/everything",{"title":21,"_path":22},"⌛ 偷取时间","/flows/stealing-time-from-god",{"title":24,"_path":25},"🌆 表达和孤独","/flows/expression-and-loneliness",{"title":27,"_path":28},"🌧️ 我的腼腆","/flows/shy",{"title":30,"_path":31},"🥛 新工作，喝新饮料","/flows/drinking-while-thinking",{"title":33,"_path":34},"📝 心流归档","/flows/archive",{"title":36,"_path":37,"children":38},"技术博客 / Coder","/articles",[39,41,44,47,50,53,56,59,62,65,68,71,74,77,80,83,86,89],{"title":40,"_path":37},"🦁 欢迎",{"title":42,"_path":43},"📦 一个简单有效的端口命名策略：","/articles/simple-naming-method",{"title":45,"_path":46},"🌪️ Tailwind v4 如何兼容预处理器","/articles/tailwind4-with-sass",{"title":48,"_path":49},"🥞 在 tailwind 中使用现代化 CSS Layers","/articles/tailwind-sass-and-css-layer",{"title":51,"_path":52},"💻 本地部署 Qwen 翻译网页","/articles/local-translator",{"title":54,"_path":55},"🧊 模板解析器轻考古","/articles/micro-templating",{"title":57,"_path":58},"Ⓜ️ Mini CSS Parser","/articles/mini-css-parser",{"title":60,"_path":61},"🚩 向AI咨询前端问题","/articles/use-gpt-learn-complex-frontend",{"title":63,"_path":64},"⛸️ 怎样定制复杂组件的自定义滚动条？","/articles/use-scrollbars",{"title":66,"_path":67},"⚖️ 统一多组件库的层叠顺序","/articles/zindex-manager",{"title":69,"_path":70},"🕷️ 滑动验证码破解思路","/articles/crack-the-slider",{"title":72,"_path":73},"🌟 探秘 CSS 光影效果","/articles/css-light-travel",{"title":75,"_path":76},"🍲 设计模式与 JS 魔法锅","/articles/design-patterns-and-js-magic-pot",{"title":78,"_path":79},"🌐 Anysort：灵活、优雅的多属性排序","/articles/anysort-2th",{"title":81,"_path":82},"💫 CSS 幻术 | 抗锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133,"children":134},"造物 / Make","/tools",[135,137,140,143,146,149,152],{"title":136,"_path":133},"🧰 工具收集",{"title":138,"_path":139},"📕 博客","/tools/blog",{"title":141,"_path":142},"🥥 Coconut","/tools/coconut",{"title":144,"_path":145},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":147,"_path":148},"🌐 AnySort","/tools/anysort",{"title":150,"_path":151},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":153,"_path":154},"👓 Crapto","/tools/crypto-inline",{"title":156,"_path":157,"children":158},"我 / About","/hire",[159],{"title":160,"_path":157},"📬 技术简历",{"title":162,"_path":163,"children":164},"En","/en",[165],{"title":166,"_path":167,"children":168},"🦁 Welcome","/en/articles",[169],{"title":166,"_path":167},{"_path":171,"_dir":172,"_draft":173,"_partial":174,"_locale":175,"title":176,"description":175,"body":177,"_type":812,"_id":813,"_source":814,"_file":815,"_stem":816,"_extension":817},"/maps/_ai/architectures","_ai",false,true,"","模型架构 (Model Architectures)",{"type":178,"children":179,"toc":801},"root",[180,188,195,201,224,230,235,254,260,265,284,290,295,314,320,325,344,350,355,374,380,385,404,408,414,421,434,445,451,456,515,521,526,569,575,580,641,647,652,675,681,686,762,768],{"type":181,"tag":182,"props":183,"children":185},"element","h1",{"id":184},"模型架构-model-architectures",[186],{"type":187,"value":176},"text",{"type":181,"tag":189,"props":190,"children":192},"h2",{"id":191},"litgptpytorch-lightning-原生的-llm-工具包",[193],{"type":187,"value":194},"LitGPT：PyTorch Lightning 原生的 LLM 工具包",{"type":181,"tag":196,"props":197,"children":198},"p",{},[199],{"type":187,"value":200},"LitGPT 让在个人数据上训练、微调和部署大模型变得简单高效。它内置 20+ 主流开源架构（Llama、Mistral、Qwen 等），并预配置 Flash Attention、FSDP 分布式训练、4-bit/8-bit 量化等生产级优化，开箱即用。核心代码采用\"单文件模型\"设计，没有过度抽象，适合快速原型验证和学习 LLM 工程实践。",{"type":181,"tag":196,"props":202,"children":203},{},[204,206,215,217],{"type":187,"value":205},"见：",{"type":181,"tag":207,"props":208,"children":212},"a",{"href":209,"rel":210},"https://github.com/Lightning-AI/litgpt",[211],"nofollow",[213],{"type":187,"value":214},"LitGPT GitHub",{"type":187,"value":216}," | ",{"type":181,"tag":207,"props":218,"children":221},{"href":219,"rel":220},"https://lightning.ai/litgpt",[211],[222],{"type":187,"value":223},"LitGPT 文档",{"type":181,"tag":189,"props":225,"children":227},{"id":226},"mamba线性复杂度的状态空间模型",[228],{"type":187,"value":229},"Mamba：线性复杂度的状态空间模型",{"type":181,"tag":196,"props":231,"children":232},{},[233],{"type":187,"value":234},"Mamba 代表了后 Transformer 时代的重要探索。传统 Transformer 的自注意力机制是二次复杂度 O(n²)，长序列时计算和内存开销爆炸。Mamba 通过选择性状态空间（Selective State Space）将复杂度降至线性 O(n)，同时保留了长程依赖建模能力。2024 年起，Mamba 与 Transformer 的混合架构成为主流——用 Mamba 处理长程上下文，用注意力机制处理局部精细交互。",{"type":181,"tag":196,"props":236,"children":237},{},[238,239,246,247],{"type":187,"value":205},{"type":181,"tag":207,"props":240,"children":243},{"href":241,"rel":242},"https://arxiv.org/abs/2312.00752",[211],[244],{"type":187,"value":245},"Mamba: Linear-Time Sequence Modeling",{"type":187,"value":216},{"type":181,"tag":207,"props":248,"children":251},{"href":249,"rel":250},"https://newsletter.maartengrootendorst.com/p/a-visual-guide-to-mamba-and-state",[211],[252],{"type":187,"value":253},"A Visual Guide to Mamba",{"type":181,"tag":189,"props":255,"children":257},{"id":256},"nanogpt极简-gpt-教学实现",[258],{"type":187,"value":259},"NanoGPT：极简 GPT 教学实现",{"type":181,"tag":196,"props":261,"children":262},{},[263],{"type":187,"value":264},"Andrej Karpathy 开发的 NanoGPT 用最简洁的代码实现了完整的 GPT 训练流程，核心代码仅约 300 行。这种\"minimal but complete\"的设计理念，让研究者能聚焦核心机制而非工程细节。配合《Let's build GPT: from scratch》视频系列，是理解 GPT 原理的最佳入门资料。",{"type":181,"tag":196,"props":266,"children":267},{},[268,269,276,277],{"type":187,"value":205},{"type":181,"tag":207,"props":270,"children":273},{"href":271,"rel":272},"https://github.com/karpathy/nanoGPT",[211],[274],{"type":187,"value":275},"nanoGPT GitHub",{"type":187,"value":216},{"type":181,"tag":207,"props":278,"children":281},{"href":279,"rel":280},"https://github.com/karpathy/build-nanogpt",[211],[282],{"type":187,"value":283},"build-nanogpt 教学仓库",{"type":181,"tag":189,"props":285,"children":287},{"id":286},"rwkvrnn-与-transformer-的混合架构",[288],{"type":187,"value":289},"RWKV：RNN 与 Transformer 的混合架构",{"type":181,"tag":196,"props":291,"children":292},{},[293],{"type":187,"value":294},"RWKV（Receptance Weighted Key Value）结合了 RNN 的 O(1) 推理内存和 Transformer 的并行训练能力。训练时像 Transformer 一样并行，推理时像 RNN 一样常数内存——这个特性让它在端侧部署和长文本生成场景有独特优势，支持 10 万+ tokens 的长文本续写。",{"type":181,"tag":196,"props":296,"children":297},{},[298,299,306,307],{"type":187,"value":205},{"type":181,"tag":207,"props":300,"children":303},{"href":301,"rel":302},"https://arxiv.org/abs/2305.13048",[211],[304],{"type":187,"value":305},"RWKV 论文",{"type":187,"value":216},{"type":181,"tag":207,"props":308,"children":311},{"href":309,"rel":310},"https://huggingface.co/blog/rwkv",[211],[312],{"type":187,"value":313},"Hugging Face RWKV 介绍",{"type":181,"tag":189,"props":315,"children":317},{"id":316},"torchtitanpytorch-原生大规模训练框架",[318],{"type":187,"value":319},"TorchTitan：PyTorch 原生大规模训练框架",{"type":181,"tag":196,"props":321,"children":322},{},[323],{"type":187,"value":324},"TorchTitan 是 PyTorch 官方出品的大规模模型训练框架，目标是成为\"PyTorch 原生的 Megatron/DeepSpeed 替代\"。它提供 4D 并行（数据并行、张量并行、流水线并行、序列并行）的统一实现，支持弹性扩缩容。各并行策略可独立开关、自由组合，无需修改模型代码即可无缝应用到大规模训练。",{"type":181,"tag":196,"props":326,"children":327},{},[328,329,336,337],{"type":187,"value":205},{"type":181,"tag":207,"props":330,"children":333},{"href":331,"rel":332},"https://github.com/pytorch/torchtitan",[211],[334],{"type":187,"value":335},"TorchTitan GitHub",{"type":187,"value":216},{"type":181,"tag":207,"props":338,"children":341},{"href":339,"rel":340},"https://arxiv.org/abs/2410.06511",[211],[342],{"type":187,"value":343},"TorchTitan 论文",{"type":181,"tag":189,"props":345,"children":347},{"id":346},"jepa非生成式自监督学习架构",[348],{"type":187,"value":349},"JEPA：非生成式自监督学习架构",{"type":181,"tag":196,"props":351,"children":352},{},[353],{"type":187,"value":354},"JEPA（Joint Embedding Predictive Architecture）是杨立昆提出的非生成式学习架构，核心创新是在抽象表示空间而非像素/token 空间进行预测。与传统生成模型重建输入不同，JEPA 学习语义表示，一次性预测而无需顺序解码。LeCun 认为这是通向 AGI 的必经之路——真正的智能需要世界模型，而非仅仅自回归生成。",{"type":181,"tag":196,"props":356,"children":357},{},[358,359,366,367],{"type":187,"value":205},{"type":181,"tag":207,"props":360,"children":363},{"href":361,"rel":362},"https://rohitbandaru.github.io/blog/JEPA-Deep-Dive/",[211],[364],{"type":187,"value":365},"JEPA 深度解析",{"type":187,"value":216},{"type":181,"tag":207,"props":368,"children":371},{"href":369,"rel":370},"https://ai.meta.com/blog/v-jepa-yann-lecun-ai-model-video-joint-embedding-predictive-architecture/",[211],[372],{"type":187,"value":373},"V-JEPA 官方发布",{"type":181,"tag":189,"props":375,"children":377},{"id":376},"空间智能理解三维世界的新一代-ai",[378],{"type":187,"value":379},"空间智能：理解三维世界的新一代 AI",{"type":181,"tag":196,"props":381,"children":382},{},[383],{"type":187,"value":384},"李飞飞创立的 World Labs 专注于\"空间智能\"——让 AI 理解三维世界的几何、物理和语义。真正的空间智能世界模型需要三种能力：生成性（创造遵守物理定律的世界）、多模态（融合视觉、语言、空间信息）、交互性（支持探索和导航的 3D 环境）。她预言未来五年，Transformer 可能被淘汰。",{"type":181,"tag":196,"props":386,"children":387},{},[388,389,396,397],{"type":187,"value":205},{"type":181,"tag":207,"props":390,"children":393},{"href":391,"rel":392},"https://www.mittrchina.com/news/detail/15468",[211],[394],{"type":187,"value":395},"李飞飞空间智能长文",{"type":187,"value":216},{"type":181,"tag":207,"props":398,"children":401},{"href":399,"rel":400},"https://zhuanlan.zhihu.com/p/1976808836682765387",[211],[402],{"type":187,"value":403},"李飞飞万字访谈",{"type":181,"tag":405,"props":406,"children":407},"hr",{},[],{"type":181,"tag":189,"props":409,"children":411},{"id":410},"transformer-基础架构",[412],{"type":187,"value":413},"Transformer 基础架构",{"type":181,"tag":415,"props":416,"children":418},"h4",{"id":417},"transformer-是什么",[419],{"type":187,"value":420},"Transformer 是什么？",{"type":181,"tag":196,"props":422,"children":423},{},[424,426,432],{"type":187,"value":425},"Transformer 是一种神经网络架构，2017 年在论文 \"Attention is All You Need\" 中首次提出。它已成为深度学习模型的主流架构，驱动着 GPT、Llama、Gemini 等文本生成模型，同时也应用于音频生成、图像识别、蛋白质结构预测等领域。文本生成类 Transformer 的核心原理是",{"type":181,"tag":427,"props":428,"children":429},"strong",{},[430],{"type":187,"value":431},"下一个 token 预测",{"type":187,"value":433},"——根据用户输入的文本提示，预测最可能的下一个词（或词片段）。其核心创新在于自注意力机制（self-attention），使模型能够处理整个序列并更有效地捕捉长距离依赖关系。",{"type":181,"tag":196,"props":435,"children":436},{},[437,438],{"type":187,"value":205},{"type":181,"tag":207,"props":439,"children":442},{"href":440,"rel":441},"https://poloclub.github.io/transformer-explainer/",[211],[443],{"type":187,"value":444},"Transformer Explainer",{"type":181,"tag":415,"props":446,"children":448},{"id":447},"transformer-架构三大组件是什么",[449],{"type":187,"value":450},"Transformer 架构三大组件是什么？",{"type":181,"tag":196,"props":452,"children":453},{},[454],{"type":187,"value":455},"每个文本生成 Transformer 包含三个关键组件：",{"type":181,"tag":457,"props":458,"children":459},"ol",{},[460,471,505],{"type":181,"tag":461,"props":462,"children":463},"li",{},[464,469],{"type":181,"tag":427,"props":465,"children":466},{},[467],{"type":187,"value":468},"Embedding（嵌入层）",{"type":187,"value":470},"：将文本输入切分为 token（词或子词），转换为捕获语义含义的数值向量",{"type":181,"tag":461,"props":472,"children":473},{},[474,479,481],{"type":181,"tag":427,"props":475,"children":476},{},[477],{"type":187,"value":478},"Transformer Block（变换器块）",{"type":187,"value":480},"：模型的核心构建模块，包含：\n",{"type":181,"tag":482,"props":483,"children":484},"ul",{},[485,495],{"type":181,"tag":461,"props":486,"children":487},{},[488,493],{"type":181,"tag":427,"props":489,"children":490},{},[491],{"type":187,"value":492},"Attention Mechanism（注意力机制）",{"type":187,"value":494},"：允许 token 之间通信，捕获上下文信息和词间关系",{"type":181,"tag":461,"props":496,"children":497},{},[498,503],{"type":181,"tag":427,"props":499,"children":500},{},[501],{"type":187,"value":502},"MLP（多层感知机）",{"type":187,"value":504},"：对每个 token 独立操作，精化每个 token 的表示",{"type":181,"tag":461,"props":506,"children":507},{},[508,513],{"type":181,"tag":427,"props":509,"children":510},{},[511],{"type":187,"value":512},"Output Probabilities（输出概率）",{"type":187,"value":514},"：最终的线性层和 softmax 层将处理后的嵌入转换为概率，预测序列中的下一个 token",{"type":181,"tag":415,"props":516,"children":518},{"id":517},"embedding-层如何将文本转换为向量表示",[519],{"type":187,"value":520},"Embedding 层如何将文本转换为向量表示？",{"type":181,"tag":196,"props":522,"children":523},{},[524],{"type":187,"value":525},"Embedding 层将输入提示转换为模型可理解的数值表示，包含四个步骤：",{"type":181,"tag":457,"props":527,"children":528},{},[529,539,549,559],{"type":181,"tag":461,"props":530,"children":531},{},[532,537],{"type":181,"tag":427,"props":533,"children":534},{},[535],{"type":187,"value":536},"Tokenization（分词）",{"type":187,"value":538},"：将输入文本切分为 token（词或子词）。GPT-2 的词表有 50,257 个唯一 token",{"type":181,"tag":461,"props":540,"children":541},{},[542,547],{"type":181,"tag":427,"props":543,"children":544},{},[545],{"type":187,"value":546},"Token Embedding（词嵌入）",{"type":187,"value":548},"：每个 token 被表示为 768 维向量（维度因模型而异）。相似含义的 token 在高维空间中距离更近",{"type":181,"tag":461,"props":550,"children":551},{},[552,557],{"type":181,"tag":427,"props":553,"children":554},{},[555],{"type":187,"value":556},"Positional Encoding（位置编码）",{"type":187,"value":558},"：编码每个 token 在输入序列中的位置信息。GPT-2 从零开始训练自己的位置编码矩阵",{"type":181,"tag":461,"props":560,"children":561},{},[562,567],{"type":181,"tag":427,"props":563,"children":564},{},[565],{"type":187,"value":566},"Final Embedding（最终嵌入）",{"type":187,"value":568},"：将 token 编码和位置编码相加，得到最终的嵌入表示",{"type":181,"tag":415,"props":570,"children":572},{"id":571},"多头自注意力机制如何工作",[573],{"type":187,"value":574},"多头自注意力机制如何工作？",{"type":181,"tag":196,"props":576,"children":577},{},[578],{"type":187,"value":579},"自注意力机制使模型能够捕获序列中 token 之间的关系：",{"type":181,"tag":457,"props":581,"children":582},{},[583,593,603,631],{"type":181,"tag":461,"props":584,"children":585},{},[586,591],{"type":181,"tag":427,"props":587,"children":588},{},[589],{"type":187,"value":590},"Q/K/V 矩阵计算",{"type":187,"value":592},"：每个 token 的嵌入向量被转换为三个向量——Query（查询）、Key（键）、Value（值）。可用搜索类比理解：Q 是搜索框输入，K 是网页标题，V 是网页内容",{"type":181,"tag":461,"props":594,"children":595},{},[596,601],{"type":181,"tag":427,"props":597,"children":598},{},[599],{"type":187,"value":600},"多头分割",{"type":187,"value":602},"：Q/K/V 向量被分割成多个头（GPT-2 small 有 12 个头），每个头独立处理嵌入的不同段，捕获不同的句法和语义关系",{"type":181,"tag":461,"props":604,"children":605},{},[606,611,613],{"type":181,"tag":427,"props":607,"children":608},{},[609],{"type":187,"value":610},"Masked Self-Attention（掩码自注意力）",{"type":187,"value":612},"：\n",{"type":181,"tag":482,"props":614,"children":615},{},[616,621,626],{"type":181,"tag":461,"props":617,"children":618},{},[619],{"type":187,"value":620},"计算 Q 和 K 的点积得到注意力分数",{"type":181,"tag":461,"props":622,"children":623},{},[624],{"type":187,"value":625},"对注意力矩阵的上三角应用 mask，防止模型访问未来 token（不能\"偷看\"未来）",{"type":181,"tag":461,"props":627,"children":628},{},[629],{"type":187,"value":630},"经过 softmax 转换为概率，每行总和为 1",{"type":181,"tag":461,"props":632,"children":633},{},[634,639],{"type":181,"tag":427,"props":635,"children":636},{},[637],{"type":187,"value":638},"输出和拼接",{"type":187,"value":640},"：将注意力分数与 V 矩阵相乘，12 个头的输出拼接后通过线性投影",{"type":181,"tag":415,"props":642,"children":644},{"id":643},"mlp-层的作用是什么",[645],{"type":187,"value":646},"MLP 层的作用是什么？",{"type":181,"tag":196,"props":648,"children":649},{},[650],{"type":187,"value":651},"MLP（多层感知机）在自注意力之后增强模型的表示能力：",{"type":181,"tag":482,"props":653,"children":654},{},[655,660,665,670],{"type":181,"tag":461,"props":656,"children":657},{},[658],{"type":187,"value":659},"包含两个线性变换，中间使用 GELU 激活函数",{"type":181,"tag":461,"props":661,"children":662},{},[663],{"type":187,"value":664},"第一次线性变换将维度从 768 扩展到 3072（4 倍），允许模型在高维空间捕获更复杂的模式",{"type":181,"tag":461,"props":666,"children":667},{},[668],{"type":187,"value":669},"第二次线性变换将维度压缩回 768，保留有用的非线性变换",{"type":181,"tag":461,"props":671,"children":672},{},[673],{"type":187,"value":674},"与自注意力不同，MLP 独立处理每个 token，仅将每个 token 的表示从一个空间映射到另一个空间",{"type":181,"tag":415,"props":676,"children":678},{"id":677},"输出概率如何生成下一个-token",[679],{"type":187,"value":680},"输出概率如何生成下一个 token？",{"type":181,"tag":196,"props":682,"children":683},{},[684],{"type":187,"value":685},"经过所有 Transformer Block 处理后：",{"type":181,"tag":457,"props":687,"children":688},{},[689,694,699],{"type":181,"tag":461,"props":690,"children":691},{},[692],{"type":187,"value":693},"最终线性层将表示投影到 50,257 维空间（词表大小），每个 token 对应一个 logit 值",{"type":181,"tag":461,"props":695,"children":696},{},[697],{"type":187,"value":698},"Softmax 将 logits 转换为概率分布（总和为 1）",{"type":181,"tag":461,"props":700,"children":701},{},[702,704],{"type":187,"value":703},"通过采样生成下一个 token，关键超参数：\n",{"type":181,"tag":482,"props":705,"children":706},{},[707,742,752],{"type":181,"tag":461,"props":708,"children":709},{},[710,715,717],{"type":181,"tag":427,"props":711,"children":712},{},[713],{"type":187,"value":714},"Temperature",{"type":187,"value":716},"：控制随机性\n",{"type":181,"tag":482,"props":718,"children":719},{},[720,725,730],{"type":181,"tag":461,"props":721,"children":722},{},[723],{"type":187,"value":724},"=1：无影响",{"type":181,"tag":461,"props":726,"children":727},{},[728],{"type":187,"value":729},"\u003C1：更确定、更尖锐的分布",{"type":181,"tag":461,"props":731,"children":732},{},[733],{"type":181,"tag":734,"props":735,"children":736},"blockquote",{},[737],{"type":181,"tag":196,"props":738,"children":739},{},[740],{"type":187,"value":741},"1：更柔和、更\"有创意\"的分布",{"type":181,"tag":461,"props":743,"children":744},{},[745,750],{"type":181,"tag":427,"props":746,"children":747},{},[748],{"type":187,"value":749},"Top-k 采样",{"type":187,"value":751},"：仅考虑概率最高的 k 个 token",{"type":181,"tag":461,"props":753,"children":754},{},[755,760],{"type":181,"tag":427,"props":756,"children":757},{},[758],{"type":187,"value":759},"Top-p 采样",{"type":187,"value":761},"：考虑累积概率超过阈值 p 的最小 token 集合",{"type":181,"tag":415,"props":763,"children":765},{"id":764},"辅助架构特性有哪些",[766],{"type":187,"value":767},"辅助架构特性有哪些？",{"type":181,"tag":482,"props":769,"children":770},{},[771,781,791],{"type":181,"tag":461,"props":772,"children":773},{},[774,779],{"type":181,"tag":427,"props":775,"children":776},{},[777],{"type":187,"value":778},"Layer Normalization（层归一化）",{"type":187,"value":780},"：稳定训练、加速收敛，在每个 Transformer Block 中应用两次（注意力前和 MLP 前）",{"type":181,"tag":461,"props":782,"children":783},{},[784,789],{"type":181,"tag":427,"props":785,"children":786},{},[787],{"type":187,"value":788},"Dropout（随机失活）",{"type":187,"value":790},"：训练时随机将部分权重设为零，防止过拟合；推理时关闭",{"type":181,"tag":461,"props":792,"children":793},{},[794,799],{"type":181,"tag":427,"props":795,"children":796},{},[797],{"type":187,"value":798},"Residual Connections（残差连接）",{"type":187,"value":800},"：绕过一层或多层的快捷连接，缓解梯度消失问题，使深层网络训练成为可能。GPT-2 在每个 Transformer Block 中使用两次",{"title":175,"searchDepth":802,"depth":802,"links":803},2,[804,805,806,807,808,809,810,811],{"id":191,"depth":802,"text":194},{"id":226,"depth":802,"text":229},{"id":256,"depth":802,"text":259},{"id":286,"depth":802,"text":289},{"id":316,"depth":802,"text":319},{"id":346,"depth":802,"text":349},{"id":376,"depth":802,"text":379},{"id":410,"depth":802,"text":413},"markdown","content:6.maps:_ai:architectures.md","content","6.maps/_ai/architectures.md","6.maps/_ai/architectures","md",[819,823],{"_path":820,"title":821,"description":822},"/maps/_ai/ai","Machine Learning","machine learning related",{"_path":824,"title":825,"description":826},"/maps/_ai/benchmark/benchmark","LLM Benchmark","各类大语言模型的基准测试结果",1771264657249]