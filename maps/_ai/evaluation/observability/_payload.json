lse,true,"","Observability","LLM 可观测性平台与工具，包括 LangSmith、Phoenix、Langfuse 等追踪、评估和监控方案。","_ai/observability.md",{"type":183,"children":184,"toc":365},"root",[185,194,201,207,238,244,249,276,282,287,306,312,317,336,341,346],{"type":186,"tag":187,"props":188,"children":190},"element","h1",{"id":189},"可观测性-observability",[191],{"type":192,"value":193},"text","可观测性 (Observability)",{"type":186,"tag":195,"props":196,"children":198},"h2",{"id":197},"langsmithlangchain-生态追踪平台",[199],{"type":192,"value":200},"LangSmith：LangChain 生态追踪平台",{"type":186,"tag":202,"props":203,"children":204},"p",{},[205],{"type":192,"value":206},"LangSmith 是 LangChain 官方的可观测性平台，与 LangChain 生态深度集成。提供调用链可视化、错误定位与重放、批量测试评估、生产指标仪表盘。2025 年推出 LangSmith Fetch CLI 工具，可直接在终端和 IDE 中调试 Agent 追踪数据。适合已使用 LangChain 构建应用的团队，但部分功能需付费，不支持自托管。",{"type":186,"tag":202,"props":208,"children":209},{},[210,212,221,223,230,231],{"type":192,"value":211},"见：",{"type":186,"tag":213,"props":214,"children":218},"a",{"href":215,"rel":216},"https://smith.langchain.com/",[217],"nofollow",[219],{"type":192,"value":220},"LangSmith 官网",{"type":192,"value":222}," | ",{"type":186,"tag":213,"props":224,"children":227},{"href":225,"rel":226},"https://blog.langchain.com/introducing-langsmith-fetch/",[217],[228],{"type":192,"value":229},"LangSmith Fetch 发布",{"type":192,"value":222},{"type":186,"tag":213,"props":232,"children":235},{"href":233,"rel":234},"https://blog.langchain.com/debugging-deep-agents-with-langsmith/",[217],[236],{"type":192,"value":237},"Deep Agents 调试指南",{"type":186,"tag":195,"props":239,"children":241},{"id":240},"phoenix开源-llm-可观测性平台",[242],{"type":192,"value":243},"Phoenix：开源 LLM 可观测性平台",{"type":186,"tag":202,"props":245,"children":246},{},[247],{"type":192,"value":248},"Phoenix 由 Arize AI 开发，是完全开源的 LLM 可观测性解决方案。基于 OpenTelemetry 标准实现框架无关的追踪，提供 RAG 检索质量可视化、Embedding 向量空间探索、内置 Evals 评估库。支持自托管，与 MLflow 等 MLOps 工具集成良好，是企业级可观测性的首选开源方案。",{"type":186,"tag":202,"props":250,"children":251},{},[252,253,260,261,268,269],{"type":192,"value":211},{"type":186,"tag":213,"props":254,"children":257},{"href":255,"rel":256},"https://github.com/Arize-ai/phoenix",[217],[258],{"type":192,"value":259},"Phoenix GitHub",{"type":192,"value":222},{"type":186,"tag":213,"props":262,"children":265},{"href":263,"rel":264},"https://phoenix.arize.com/",[217],[266],{"type":192,"value":267},"Phoenix 官网",{"type":192,"value":222},{"type":186,"tag":213,"props":270,"children":273},{"href":271,"rel":272},"https://arize.com/docs/phoenix/evaluation/llm-evals",[217],[274],{"type":192,"value":275},"LLM Evals 库",{"type":186,"tag":195,"props":277,"children":279},{"id":278},"langfuse开源可观测性新选择",[280],{"type":192,"value":281},"Langfuse：开源可观测性新选择",{"type":186,"tag":202,"props":283,"children":284},{},[285],{"type":192,"value":286},"Langfuse 是 2025 年快速崛起的开源 LLM 可观测性平台，提供 Traces 追踪、Evals 评估、Prompt 管理、Metrics 指标分析。支持 OpenAI、LangChain、LlamaIndex、LiteLLM 等 10+ 集成，采用 OpenTelemetry 标准。作为完全开源的欧洲产品，是重视数据主权团队的理想选择。",{"type":186,"tag":202,"props":288,"children":289},{},[290,291,298,299],{"type":192,"value":211},{"type":186,"tag":213,"props":292,"children":295},{"href":293,"rel":294},"https://langfuse.com/",[217],[296],{"type":192,"value":297},"Langfuse 官网",{"type":192,"value":222},{"type":186,"tag":213,"props":300,"children":303},{"href":301,"rel":302},"https://langfuse.com/wrapped",[217],[304],{"type":192,"value":305},"Langfuse Wrapped 2025",{"type":186,"tag":195,"props":307,"children":309},{"id":308},"opentelemetry开放追踪标准",[310],{"type":192,"value":311},"OpenTelemetry：开放追踪标准",{"type":186,"tag":202,"props":313,"children":314},{},[315],{"type":192,"value":316},"OpenTelemetry 成为 LLM 可观测性的事实标准，提供与框架无关的 instrumentation 能力。Traceloop (OpenLLMetry) 是基于 OpenTelemetry 的 SDK，实现 LLM 应用的统一追踪和指标采集。采用开放标准可避免 vendor lock-in，实现跨平台数据兼容。",{"type":186,"tag":202,"props":318,"children":319},{},[320,321,328,329],{"type":192,"value":211},{"type":186,"tag":213,"props":322,"children":325},{"href":323,"rel":324},"https://github.com/traceloop/openllmetry",[217],[326],{"type":192,"value":327},"OpenLLMetry GitHub",{"type":192,"value":222},{"type":186,"tag":213,"props":330,"children":333},{"href":331,"rel":332},"https://opentelemetry.io/",[217],[334],{"type":192,"value":335},"OpenTelemetry 官网",{"type":186,"tag":195,"props":337,"children":339},{"id":338},"工具选型指南",[340],{"type":192,"value":338},{"type":186,"tag":202,"props":342,"children":343},{},[344],{"type":192,"value":345},"LangSmith 适合 LangChain 生态用户，功能完善但需付费；Phoenix 适合需要自托管和 RAG 分析的团队，完全开源；Langfuse 适合重视数据主权和 Prompt 管理的场景；OpenTelemetry 方案适合追求开放标准和技术自主的团队。实际部署中，开发阶段可用 LangSmith 快速上手，生产环境考虑 Phoenix 或 Langfuse 自托管以控制成本和数据安全。",{"type":186,"tag":202,"props":347,"children":348},{},[349,350,357,358],{"type":192,"value":211},{"type":186,"tag":213,"props":351,"children":354},{"href":352,"rel":353},"https://www.firecrawl.dev/blog/best-llm-observability-tools",[217],[355],{"type":192,"value":356},"2025 LLM 可观测性工具榜单",{"type":192,"value":222},{"type":186,"tag":213,"props":359,"children":362},{"href":360,"rel":361},"https://medium.com/@aunraza021/langsmith-vs-phoenix-by-arize-ai-choosing-the-right-tool-for-llm-observability-0b4c2f21c077",[217],[363],{"type":192,"value":364},"LangSmith vs Phoenix 对比",{"title":178,"searchDepth":366,"depth":366,"links":367},2,[368,369,370,371,372],{"id":197,"depth":366,"text":200},{"id":240,"depth":366,"text":243},{"id":278,"depth":366,"text":281},{"id":308,"depth":366,"text":311},{"id":338,"depth":366,"text":338},"markdown","content:6.maps:_ai:evaluation:observability.md","content","6.maps/_ai/evaluation/observability.md","6.maps/_ai/evaluation/observability","md",[380,384],{"_path":381,"title":382,"description":383},"/maps/_ai/evaluation/evaluation-framework","Evaluation Framework","大语言模型评估框架与基准测试，包括 lm-evaluation-harness、BigCode 等统一评估工具。",{"_path":385,"title":386,"description":387},"/maps/_ai/evaluation/reproducibility","Reproducibility","机器学习可重复性（Reproducibility）的核心价值与实践方法，包括随机种子固定、数据版本控制等关键实践。",1772504961477]