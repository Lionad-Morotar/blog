,294],{"type":181,"tag":182,"props":183,"children":185},"element","h1",{"id":184},"评估-evaluation",[186],{"type":187,"value":176},"text",{"type":181,"tag":189,"props":190,"children":192},"h2",{"id":191},"lm-evaluation-harness统一评估框架",[193],{"type":187,"value":194},"lm-evaluation-harness：统一评估框架",{"type":181,"tag":196,"props":197,"children":198},"p",{},[199],{"type":187,"value":200},"lm-evaluation-harness 由 EleutherAI 开发，提供统一的接口测试生成式语言模型在 60+ 学术基准上的表现，解决了各基准实现不一致、结果不可比的问题。支持 MMLU（多学科知识，15,908 题）、GSM8K（数学推理，1,319 题）、HellaSwag（常识推理）、HumanEval（代码生成）、BBH（复杂推理）、TruthfulQA（事实性）等核心基准。",{"type":181,"tag":196,"props":202,"children":203},{},[204,206,215,217],{"type":187,"value":205},"见：",{"type":181,"tag":207,"props":208,"children":212},"a",{"href":209,"rel":210},"https://github.com/EleutherAI/lm-evaluation-harness",[211],"nofollow",[213],{"type":187,"value":214},"lm-evaluation-harness GitHub",{"type":187,"value":216}," | ",{"type":181,"tag":207,"props":218,"children":221},{"href":219,"rel":220},"https://blog.csdn.net/M00Rue_/article/details/148063263",[211],[222],{"type":187,"value":223},"lm-eval 使用指南",{"type":181,"tag":189,"props":225,"children":227},{"id":226},"bigcode代码能力评估",[228],{"type":187,"value":229},"BigCode：代码能力评估",{"type":181,"tag":196,"props":231,"children":232},{},[233],{"type":187,"value":234},"BigCode 项目专注于代码大模型的评估，提供 HumanEval（手写函数补全，164 题）、MBPP（Python 编程问题，约 1000 题）、DS-1000（数据科学场景代码）、BigCodeBench（更复杂的实际编程任务，需调用多个工具）等基准。HumanEval Pro 和 MBPP Pro 是新一代基准，支持自调用代码生成评估。",{"type":181,"tag":196,"props":236,"children":237},{},[238,239,246,247,254,255],{"type":187,"value":205},{"type":181,"tag":207,"props":240,"children":243},{"href":241,"rel":242},"https://bigcode-project.org/",[211],[244],{"type":187,"value":245},"BigCode 项目",{"type":187,"value":216},{"type":181,"tag":207,"props":248,"children":251},{"href":249,"rel":250},"https://huggingface.co/blog/leaderboard-bigcodebench",[211],[252],{"type":187,"value":253},"BigCodeBench",{"type":187,"value":216},{"type":181,"tag":207,"props":256,"children":259},{"href":257,"rel":258},"https://evalplus.github.io/leaderboard.html",[211],[260],{"type":187,"value":261},"EvalPlus Leaderboard",{"type":181,"tag":189,"props":263,"children":265},{"id":264},"评估维度知识推理代码安全",[266],{"type":187,"value":267},"评估维度：知识、推理、代码、安全",{"type":181,"tag":196,"props":269,"children":270},{},[271],{"type":187,"value":272},"基础能力包括知识问答（MMLU、ARC）、阅读理解（RACE、SQuAD）、推理能力（GSM8K、BBH）；专业能力涵盖代码（HumanEval、MBPP）、科学（GPQA、TheoremQA）、多语言（XNLI、MGSM）；安全性评估包括有害内容检测、越狱测试（AdvBench、HarmBench）、指令遵循（IFEval）。",{"type":181,"tag":196,"props":274,"children":275},{},[276,277],{"type":187,"value":205},{"type":181,"tag":207,"props":278,"children":281},{"href":279,"rel":280},"https://huggingface.co/spaces/open-llm-leaderboard/open_llm_leaderboard",[211],[282],{"type":187,"value":283},"Hugging Face Open LLM Leaderboard",{"type":181,"tag":189,"props":285,"children":287},{"id":286},"评估最佳实践",[288],{"type":187,"value":286},{"type":181,"tag":196,"props":290,"children":291},{},[292],{"type":187,"value":293},"避免数据污染：使用训练集 cut-off 日期后的基准，检查训练语料是否包含测试数据，对敏感任务使用动态评估（hold-out）。统计显著性：多次运行取平均，报告标准差，使用配对 t-test 比较模型差异。",{"type":181,"tag":196,"props":295,"children":296},{},[297,298],{"type":187,"value":205},{"type":181,"tag":207,"props":299,"children":302},{"href":300,"rel":301},"https://blog.csdn.net/gitblog_00326/article/details/151852170",[211],[303],{"type":187,"value":304},"自定义评估基准构建",{"title":175,"searchDepth":306,"depth":306,"links":307},2,[308,309,310,311],{"id":191,"depth":306,"text":194},{"id":226,"depth":306,"text":229},{"id":264,"depth":306,"text":267},{"id":286,"depth":306,"text":286},"markdown","content:6.maps:_ai:evaluation.md","content","6.maps/_ai/evaluation.md","6.maps/_ai/evaluation","md",[319,322],{"_path":320,"title":321,"description":175},"/maps/_ai/emerging","新兴技术 (Emerging Technologies)",{"_path":323,"title":324,"description":175},"/maps/_ai/fine-tuning","微调 (Fine-tuning)",1771264679539]