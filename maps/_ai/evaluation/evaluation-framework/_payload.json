work","evaluation",false,true,"","Evaluation Framework","大语言模型评估框架与基准测试，包括 lm-evaluation-harness、BigCode 等统一评估工具。","_ai/evaluation.md",{"type":183,"children":184,"toc":360},"root",[185,194,201,207,230,236,241,268,274,279,290,295,300,311,317,324,329,334,339,344,349],{"type":186,"tag":187,"props":188,"children":190},"element","h1",{"id":189},"评估-evaluation",[191],{"type":192,"value":193},"text","评估 (Evaluation)",{"type":186,"tag":195,"props":196,"children":198},"h2",{"id":197},"lm-evaluation-harness统一评估框架",[199],{"type":192,"value":200},"lm-evaluation-harness：统一评估框架",{"type":186,"tag":202,"props":203,"children":204},"p",{},[205],{"type":192,"value":206},"lm-evaluation-harness 由 EleutherAI 开发，提供统一的接口测试生成式语言模型在 60+ 学术基准上的表现，解决了各基准实现不一致、结果不可比的问题。支持 MMLU（多学科知识，15,908 题）、GSM8K（数学推理，1,319 题）、HellaSwag（常识推理）、HumanEval（代码生成）、BBH（复杂推理）、TruthfulQA（事实性）等核心基准。",{"type":186,"tag":202,"props":208,"children":209},{},[210,212,221,223],{"type":192,"value":211},"见：",{"type":186,"tag":213,"props":214,"children":218},"a",{"href":215,"rel":216},"https://github.com/EleutherAI/lm-evaluation-harness",[217],"nofollow",[219],{"type":192,"value":220},"lm-evaluation-harness GitHub",{"type":192,"value":222}," | ",{"type":186,"tag":213,"props":224,"children":227},{"href":225,"rel":226},"https://blog.csdn.net/M00Rue_/article/details/148063263",[217],[228],{"type":192,"value":229},"lm-eval 使用指南",{"type":186,"tag":195,"props":231,"children":233},{"id":232},"bigcode代码能力评估",[234],{"type":192,"value":235},"BigCode：代码能力评估",{"type":186,"tag":202,"props":237,"children":238},{},[239],{"type":192,"value":240},"BigCode 项目专注于代码大模型的评估，提供 HumanEval（手写函数补全，164 题）、MBPP（Python 编程问题，约 1000 题）、DS-1000（数据科学场景代码）、BigCodeBench（更复杂的实际编程任务，需调用多个工具）等基准。HumanEval Pro 和 MBPP Pro 是新一代基准，支持自调用代码生成评估。",{"type":186,"tag":202,"props":242,"children":243},{},[244,245,252,253,260,261],{"type":192,"value":211},{"type":186,"tag":213,"props":246,"children":249},{"href":247,"rel":248},"https://bigcode-project.org/",[217],[250],{"type":192,"value":251},"BigCode 项目",{"type":192,"value":222},{"type":186,"tag":213,"props":254,"children":257},{"href":255,"rel":256},"https://huggingface.co/blog/leaderboard-bigcodebench",[217],[258],{"type":192,"value":259},"BigCodeBench",{"type":192,"value":222},{"type":186,"tag":213,"props":262,"children":265},{"href":263,"rel":264},"https://evalplus.github.io/leaderboard.html",[217],[266],{"type":192,"value":267},"EvalPlus Leaderboard",{"type":186,"tag":195,"props":269,"children":271},{"id":270},"评估维度知识推理代码安全",[272],{"type":192,"value":273},"评估维度：知识、推理、代码、安全",{"type":186,"tag":202,"props":275,"children":276},{},[277],{"type":192,"value":278},"基础能力包括知识问答（MMLU、ARC）、阅读理解（RACE、SQuAD）、推理能力（GSM8K、BBH）；专业能力涵盖代码（HumanEval、MBPP）、科学（GPQA、TheoremQA）、多语言（XNLI、MGSM）；安全性评估包括有害内容检测、越狱测试（AdvBench、HarmBench）、指令遵循（IFEval）。",{"type":186,"tag":202,"props":280,"children":281},{},[282,283],{"type":192,"value":211},{"type":186,"tag":213,"props":284,"children":287},{"href":285,"rel":286},"https://huggingface.co/spaces/open-llm-leaderboard/open_llm_leaderboard",[217],[288],{"type":192,"value":289},"Hugging Face Open LLM Leaderboard",{"type":186,"tag":195,"props":291,"children":293},{"id":292},"评估最佳实践",[294],{"type":192,"value":292},{"type":186,"tag":202,"props":296,"children":297},{},[298],{"type":192,"value":299},"避免数据污染：使用训练集 cut-off 日期后的基准，检查训练语料是否包含测试数据，对敏感任务使用动态评估（hold-out）。统计显著性：多次运行取平均，报告标准差，使用配对 t-test 比较模型差异。",{"type":186,"tag":202,"props":301,"children":302},{},[303,304],{"type":192,"value":211},{"type":186,"tag":213,"props":305,"children":308},{"href":306,"rel":307},"https://blog.csdn.net/gitblog_00326/article/details/151852170",[217],[309],{"type":192,"value":310},"自定义评估基准构建",{"type":186,"tag":195,"props":312,"children":314},{"id":313},"效用问题utility-problem",[315],{"type":192,"value":316},"效用问题（Utility Problem）",{"type":186,"tag":318,"props":319,"children":321},"h4",{"id":320},"为什么-ai-如此聪明却不实用",[322],{"type":192,"value":323},"为什么 AI 如此聪明却不实用",{"type":186,"tag":202,"props":325,"children":326},{},[327],{"type":192,"value":328},"当前 AI 在 MMLU、HumanEval、Codeforces 等基准上达到博士水平，能完成人类难以企及的任务，但并未显著改变 GDP（估计仅影响了 1%）。这种\"聪明但不实用\"的矛盾被称为\"效用问题\"，核心原因在于评估设定追求\"难题\"，而真实价值在于\"实用\"。",{"type":186,"tag":318,"props":330,"children":332},{"id":331},"学术界评估与现实任务的错位",[333],{"type":192,"value":331},{"type":186,"tag":202,"props":335,"children":336},{},[337],{"type":192,"value":338},"当前 AI 评估基于 i.i.d（独立同分布）假设：500 个任务并行执行后取平均。但真实场景是持续学习——软件工程师每解决一个问题就积累代码库知识，下次解决更快。学术界缺乏评估\"学习能力\"而非\"现有能力\"的基准。入职第一天的表现不重要，入职半年后的表现才重要。",{"type":186,"tag":318,"props":340,"children":342},{"id":341},"下一代评估需要打破的隐含假设",[343],{"type":192,"value":341},{"type":186,"tag":202,"props":345,"children":346},{},[347],{"type":192,"value":348},"现有评估隐含多个惯性假设：任务必须 i.i.d、人类偏好是静态的、任务边界清晰。这些假设源于学术传统，但与现实严重脱节。当通用配方可以攻克任何既定基准时，创造\"打破通用配方\"的新设定比制造更难的题目更有价值。",{"type":186,"tag":202,"props":350,"children":351},{},[352,353],{"type":192,"value":211},{"type":186,"tag":213,"props":354,"children":357},{"href":355,"rel":356},"https://ysymyth.github.io/The-Second-Half/",[217],[358],{"type":192,"value":359},"The Second Half - AI 评估的未来",{"title":178,"searchDepth":361,"depth":361,"links":362},2,[363,364,365,366,367],{"id":197,"depth":361,"text":200},{"id":232,"depth":361,"text":235},{"id":270,"depth":361,"text":273},{"id":292,"depth":361,"text":292},{"id":313,"depth":361,"text":316},"markdown","content:6.maps:_ai:evaluation:evaluation-framework.md","content","6.maps/_ai/evaluation/evaluation-framework.md","6.maps/_ai/evaluation/evaluation-framework","md",[375,379],{"_path":376,"title":377,"description":378},"/maps/_ai/evaluation/evaluation","Evaluation","AI 系统评估与测试方法论，涵盖模型评估框架、可观测性平台和可重复性实践。",{"_path":380,"title":381,"description":382},"/maps/_ai/evaluation/observability","Observability","LLM 可观测性平台与工具，包括 LangSmith、Phoenix、Langfuse 等追踪、评估和监控方案。",1772504961461]