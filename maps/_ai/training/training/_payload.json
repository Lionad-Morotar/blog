80,"toc":354},"root",[181,190,200,225,233,251,259,282,290,308,316,334,340],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"brief",[187],{"type":188,"value":189},"text","Brief",{"type":182,"tag":191,"props":192,"children":193},"p",{},[194],{"type":182,"tag":195,"props":196,"children":197},"strong",{},[198],{"type":188,"value":199},"数据准备",{"type":182,"tag":201,"props":202,"children":203},"ol",{},[204,210,215,220],{"type":182,"tag":205,"props":206,"children":207},"li",{},[208],{"type":188,"value":209},"数据收集：收集与任务相关的高质量数据，确保数据多样性和代表性。",{"type":182,"tag":205,"props":211,"children":212},{},[213],{"type":188,"value":214},"数据清洗：处理缺失值、重复数据和异常值，确保数据的准确性。",{"type":182,"tag":205,"props":216,"children":217},{},[218],{"type":188,"value":219},"数据标注：为监督学习任务准备标注数据，确保标注的一致性和准确性。",{"type":182,"tag":205,"props":221,"children":222},{},[223],{"type":188,"value":224},"数据增强：通过数据增强技术（如旋转、缩放、裁剪等）增加训练数据的多样性。",{"type":182,"tag":191,"props":226,"children":227},{},[228],{"type":182,"tag":195,"props":229,"children":230},{},[231],{"type":188,"value":232},"模型选择",{"type":182,"tag":201,"props":234,"children":235},{},[236,241,246],{"type":182,"tag":205,"props":237,"children":238},{},[239],{"type":188,"value":240},"选择适合任务的模型架构（如卷积神经网络、循环神经网络、变换器等）。",{"type":182,"tag":205,"props":242,"children":243},{},[244],{"type":188,"value":245},"考虑模型的复杂度与计算资源的平衡，避免过拟合或欠拟合。",{"type":182,"tag":205,"props":247,"children":248},{},[249],{"type":188,"value":250},"利用预训练模型进行迁移学习，以加速训练过程和提升性能。",{"type":182,"tag":191,"props":252,"children":253},{},[254],{"type":182,"tag":195,"props":255,"children":256},{},[257],{"type":188,"value":258},"训练过程",{"type":182,"tag":201,"props":260,"children":261},{},[262,267,272,277],{"type":182,"tag":205,"props":263,"children":264},{},[265],{"type":188,"value":266},"超参数调优：调整学习率、批量大小、正则化参数等超参数以优化模型性能。",{"type":182,"tag":205,"props":268,"children":269},{},[270],{"type":188,"value":271},"损失函数选择：根据任务类型选择合适的损失函数（如交叉熵损失、均方误差等）。",{"type":182,"tag":205,"props":273,"children":274},{},[275],{"type":188,"value":276},"优化算法：选择适当的优化算法（如SGD、Adam等）以加速收敛。",{"type":182,"tag":205,"props":278,"children":279},{},[280],{"type":188,"value":281},"监控训练过程：使用验证集监控模型性能，防止过拟合。",{"type":182,"tag":191,"props":283,"children":284},{},[285],{"type":182,"tag":195,"props":286,"children":287},{},[288],{"type":188,"value":289},"评估与测试",{"type":182,"tag":201,"props":291,"children":292},{},[293,298,303],{"type":182,"tag":205,"props":294,"children":295},{},[296],{"type":188,"value":297},"使用独立的测试集评估模型性能，确保模型的泛化能力。",{"type":182,"tag":205,"props":299,"children":300},{},[301],{"type":188,"value":302},"计算关键指标（如准确率、精确率、召回率、F1分数等）以全面评估模型表现。",{"type":182,"tag":205,"props":304,"children":305},{},[306],{"type":188,"value":307},"进行误差分析，识别模型的弱点和改进方向。",{"type":182,"tag":191,"props":309,"children":310},{},[311],{"type":182,"tag":195,"props":312,"children":313},{},[314],{"type":188,"value":315},"部署与维护",{"type":182,"tag":201,"props":317,"children":318},{},[319,324,329],{"type":182,"tag":205,"props":320,"children":321},{},[322],{"type":188,"value":323},"将训练好的模型部署到生产环境，确保其稳定性和响应速度。",{"type":182,"tag":205,"props":325,"children":326},{},[327],{"type":188,"value":328},"持续监控模型性能，及时更新和重新训练模型以适应新的数据和需求。",{"type":182,"tag":205,"props":330,"children":331},{},[332],{"type":188,"value":333},"收集用户反馈，进一步优化模型和提升用户体验。",{"type":182,"tag":183,"props":335,"children":337},{"id":336},"domain",[338],{"type":188,"value":339},"Domain",{"type":182,"tag":341,"props":342,"children":343},"ul",{},[344],{"type":182,"tag":205,"props":345,"children":346},{},[347],{"type":182,"tag":348,"props":349,"children":351},"a",{"href":350},"/maps/_ai/training/topology-aware-scheduling",[352],{"type":188,"value":353},"拓扑感知调度",{"title":175,"searchDepth":355,"depth":355,"links":356},2,[357,358],{"id":185,"depth":355,"text":189},{"id":336,"depth":355,"text":339},"markdown","content:6.maps:_ai:training:training.md","content","6.maps/_ai/training/training.md","6.maps/_ai/training/training","md",[366,368],{"_path":350,"title":353,"description":367},"拓扑感知调度是一种在分布式计算环境中，根据硬件拓扑结构和网络性能来优化任务调度和资源分配的方法，以提高整体系统的效率和性能。",{"_path":369,"title":370,"description":371},"/maps/_ai/vibe/agents-md","agents.md","AGENTS.md 是一种用于向 AI 编码代理提供说明的常用格式",1771214957719]