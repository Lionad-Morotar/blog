[{"data":1,"prerenderedAt":1012},["ShallowReactive",2],{"navigation":3,"/maps/_ai/training/topology-aware-scheduling":170,"/maps/_ai/training/topology-aware-scheduling-surround":1003},[4,35,92,98,125,131,155,161],{"title":5,"_path":6,"children":7},"心流思绪 / Heart Flows","/flows",[8,11,14,17,20,23,26,29,32],{"title":9,"_path":10},"📕 狮子的书单推荐","/flows/books",{"title":12,"_path":13},"🚝 四十二篇系列","/flows/forty-two",{"title":15,"_path":16},"🌃 长夜梦","/flows/long-night-dream",{"title":18,"_path":19},"🌌 万物联结与幸福感","/flows/everything",{"title":21,"_path":22},"⌛ 偷取时间","/flows/stealing-time-from-god",{"title":24,"_path":25},"🌆 表达和孤独","/flows/expression-and-loneliness",{"title":27,"_path":28},"🌧️ 我的腼腆","/flows/shy",{"title":30,"_path":31},"🥛 新工作，喝新饮料","/flows/drinking-while-thinking",{"title":33,"_path":34},"📝 心流归档","/flows/archive",{"title":36,"_path":37,"children":38},"技术博客 / Coder","/articles",[39,41,44,47,50,53,56,59,62,65,68,71,74,77,80,83,86,89],{"title":40,"_path":37},"🦁 欢迎",{"title":42,"_path":43},"📦 一个简单有效的端口命名策略：","/articles/simple-naming-method",{"title":45,"_path":46},"🌪️ Tailwind v4 如何兼容预处理器","/articles/tailwind4-with-sass",{"title":48,"_path":49},"🥞 在 tailwind 中使用现代化 CSS Layers","/articles/tailwind-sass-and-css-layer",{"title":51,"_path":52},"💻 本地部署 Qwen 翻译网页","/articles/local-translator",{"title":54,"_path":55},"🧊 模板解析器轻考古","/articles/micro-templating",{"title":57,"_path":58},"Ⓜ️ Mini CSS Parser","/articles/mini-css-parser",{"title":60,"_path":61},"🚩 向AI咨询前端问题","/articles/use-gpt-learn-complex-frontend",{"title":63,"_path":64},"⛸️ 怎样定制复杂组件的自定义滚动条？","/articles/use-scrollbars",{"title":66,"_path":67},"⚖️ 统一多组件库的层叠顺序","/articles/zindex-manager",{"title":69,"_path":70},"🕷️ 滑动验证码破解思路","/articles/crack-the-slider",{"title":72,"_path":73},"🌟 探秘 CSS 光影效果","/articles/css-light-travel",{"title":75,"_path":76},"🍲 设计模式与 JS 魔法锅","/articles/design-patterns-and-js-magic-pot",{"title":78,"_path":79},"🌐 Anysort：灵活、优雅的多属性排序","/articles/anysort-2th",{"title":81,"_path":82},"💫 CSS 幻术 | 抗锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133,"children":134},"造物 / Make","/tools",[135,137,140,143,146,149,152],{"title":136,"_path":133},"🧰 工具收集",{"title":138,"_path":139},"📕 博客","/tools/blog",{"title":141,"_path":142},"🥥 Coconut","/tools/coconut",{"title":144,"_path":145},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":147,"_path":148},"🌐 AnySort","/tools/anysort",{"title":150,"_path":151},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":153,"_path":154},"👓 Crapto","/tools/crypto-inline",{"title":156,"_path":157,"children":158},"我 / About","/hire",[159],{"title":160,"_path":157},"📬 技术简历",{"title":162,"_path":163,"children":164},"En","/en",[165],{"title":166,"_path":167,"children":168},"🦁 Welcome","/en/articles",[169],{"title":166,"_path":167},{"_path":171,"_dir":172,"_draft":173,"_partial":174,"_locale":175,"title":176,"description":177,"body":178,"_type":997,"_id":998,"_source":999,"_file":1000,"_stem":1001,"_extension":1002},"/maps/_ai/training/topology-aware-scheduling","training",false,true,"","拓扑感知调度","拓扑感知调度是一种在分布式计算环境中，根据硬件拓扑结构和网络性能来优化任务调度和资源分配的方法，以提高整体系统的效率和性能。",{"type":179,"children":180,"toc":986},"root",[181,190,196,201,206,211,217,224,231,236,256,261,266,271,289,295,301,306,319,324,342,347,365,370,375,393,399,405,410,467,472,477,492,510,524,542,548,554,559,572,577,595,601,606,624,629,635,640,683,688,727,733,738,743,761,766,784,789,794,805,818,829,850,862,875,887,900,905,981],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"brief",[187],{"type":188,"value":189},"text","Brief",{"type":182,"tag":191,"props":192,"children":193},"p",{},[194],{"type":188,"value":195},"GPU 和 LPU 不再是彼此独立的设备，而是构成紧密耦合的加速器网络，其整体性能高度依赖于作业放置位置和底层拓扑结构。在类似 NVIDIA NVL72 这样的机架级系统中，72 张 GPU 共享超过 13 TB 显存，对上层表现为一个单一加速器——直到工作负载跨越交换机“岛屿”，把原本高效的集体通信操作变成瓶颈。类似地，Groq 采用编译期、软件调度的架构，预设了确定性的数据流动；随机调度会打破这些假设和可预测性。即使在同一个数据中心内部，不同 GPU 之间的性能也可能存在显著差异，这推动了一类新的需求：在调度作业时，调度器必须感知硬件拓扑和性能波动，做出拓扑感知的放置决策。",{"type":182,"tag":191,"props":197,"children":198},{},[199],{"type":188,"value":200},"那些忽略 NVLink、PCIe 或 NIC（网卡）拓扑的朴素调度器，往往会把多 GPU 工作负载任意打散，从而导致训练 step time 变长、整体效率下降。训练工作负载通常是同步、带宽受限的，更偏好部署在同一 NVLink“岛屿”的连续 GPU 上，并要求在 all-reduce 和流水线阶段维持统一的高带宽通信路径。这类作业的调度应基于网络织物带宽进行协同分配，避免跨交换机跳数，并将链路、交换机和节点边界视作故障域来处理。与之相对，推理工作负载则更受延迟和 SLO 约束，通常需要在跨故障域的多副本高可用与分片之间取得平衡，以在最短路径上保持 MoE（Mixture of Experts）和 KV-cache 的局部性。进一步针对 prefill 与 decode 阶段分别优化算力放置策略，配合微批处理和租户隔离，可以继续提升整体效率。",{"type":182,"tag":191,"props":202,"children":203},{},[204],{"type":188,"value":205},"随着加速器性能越来越依赖网络和数据中心拓扑，我们认为拓扑感知调度将演变为必需能力。团队已经在评估 Kueue 及相关项目，以提升作业放置精度、性能表现，并在大规模扩展场景中保持可预测的伸缩能力，为客户提供更可靠的算力服务。",{"type":182,"tag":191,"props":207,"children":208},{},[209],{"type":188,"value":210},"来源：技术雷达",{"type":182,"tag":183,"props":212,"children":214},{"id":213},"details",[215],{"type":188,"value":216},"Details",{"type":182,"tag":218,"props":219,"children":221},"h3",{"id":220},"背景与现状为什么需要拓扑感知调度",[222],{"type":188,"value":223},"背景与现状：为什么需要拓扑感知调度",{"type":182,"tag":225,"props":226,"children":228},"h4",{"id":227},"从单卡性能到机架级加速器性能",[229],{"type":188,"value":230},"从“单卡性能”到“机架级加速器性能”",{"type":182,"tag":191,"props":232,"children":233},{},[234],{"type":188,"value":235},"在大模型训练和高并发推理场景下，性能瓶颈正从单卡 FLOPS 转移到集群内通信与数据路径。典型变化包括：",{"type":182,"tag":237,"props":238,"children":239},"ul",{},[240,246,251],{"type":182,"tag":241,"props":242,"children":243},"li",{},[244],{"type":188,"value":245},"机架级系统（如 NVL72 类形态）把几十张 GPU 绑定为一个大加速器，统一暴露显存和算力。",{"type":182,"tag":241,"props":247,"children":248},{},[249],{"type":188,"value":250},"专用推理加速器（如采用编译期调度架构的设备）假设数据流是高度确定的，依赖稳定的网络和放置。",{"type":182,"tag":241,"props":252,"children":253},{},[254],{"type":188,"value":255},"同一数据中心内，不同机柜、不同交换域之间带宽与延迟差异显著，对同步训练尤为敏感。",{"type":182,"tag":191,"props":257,"children":258},{},[259],{"type":188,"value":260},"在这种背景下，调度器如果仍然只把 GPU 当作“同质资源池中的 N 个 slot”，就会系统性浪费硬件能力。",{"type":182,"tag":225,"props":262,"children":264},{"id":263},"典型适用场景",[265],{"type":188,"value":263},{"type":182,"tag":191,"props":267,"children":268},{},[269],{"type":188,"value":270},"拓扑感知调度主要针对以下场景产生价值：",{"type":182,"tag":237,"props":272,"children":273},{},[274,279,284],{"type":182,"tag":241,"props":275,"children":276},{},[277],{"type":188,"value":278},"大规模分布式训练：多机多卡、需要频繁 all-reduce / all-to-all 通信。",{"type":182,"tag":241,"props":280,"children":281},{},[282],{"type":188,"value":283},"大模型推理服务：同时承载高并发在线请求与大 batch 批处理，使用 MoE、KV cache 等结构。",{"type":182,"tag":241,"props":285,"children":286},{},[287],{"type":188,"value":288},"共享 GPU 平台：多团队、多租户共享集群，希望在不干预应用的前提下提升整体利用率和稳定性。",{"type":182,"tag":218,"props":290,"children":292},{"id":291},"问题与风险朴素调度的结构性矛盾",[293],{"type":188,"value":294},"问题与风险：朴素调度的结构性矛盾",{"type":182,"tag":225,"props":296,"children":298},{"id":297},"朴素调度忽略了物理世界",[299],{"type":188,"value":300},"朴素调度忽略了“物理世界”",{"type":182,"tag":191,"props":302,"children":303},{},[304],{"type":188,"value":305},"传统集群调度器往往只看到以下维度：",{"type":182,"tag":237,"props":307,"children":308},{},[309,314],{"type":182,"tag":241,"props":310,"children":311},{},[312],{"type":188,"value":313},"$$\\text{GPU_count}$$、$$\\text{GPU_memory}$$、节点 CPU / 内存；",{"type":182,"tag":241,"props":315,"children":316},{},[317],{"type":188,"value":318},"简单的 label（例如 “has-gpu=true”）。",{"type":182,"tag":191,"props":320,"children":321},{},[322],{"type":188,"value":323},"在这种模型下，多 GPU 任务有较大概率被“打散”到：",{"type":182,"tag":237,"props":325,"children":326},{},[327,332,337],{"type":182,"tag":241,"props":328,"children":329},{},[330],{"type":188,"value":331},"不同 NVLink 岛之间；",{"type":182,"tag":241,"props":333,"children":334},{},[335],{"type":188,"value":336},"需跨多级交换机才能互联的节点上；",{"type":182,"tag":241,"props":338,"children":339},{},[340],{"type":188,"value":341},"带宽抖动明显或共享严重拥塞上行链路的机柜中。",{"type":182,"tag":191,"props":343,"children":344},{},[345],{"type":188,"value":346},"结果是：",{"type":182,"tag":237,"props":348,"children":349},{},[350,355,360],{"type":182,"tag":241,"props":351,"children":352},{},[353],{"type":188,"value":354},"训练任务的 step time 明显变长，吞吐量下降；",{"type":182,"tag":241,"props":356,"children":357},{},[358],{"type":188,"value":359},"同一模型不同 run 之间的性能不稳定，难以容量规划；",{"type":182,"tag":241,"props":361,"children":362},{},[363],{"type":188,"value":364},"对于依赖确定性调度的推理硬件，可能直接破坏延迟 SLO。",{"type":182,"tag":225,"props":366,"children":368},{"id":367},"性能与可靠性的隐性风险",[369],{"type":188,"value":367},{"type":182,"tag":191,"props":371,"children":372},{},[373],{"type":188,"value":374},"在多租户场景中，缺乏拓扑感知还可能带来：",{"type":182,"tag":237,"props":376,"children":377},{},[378,383,388],{"type":182,"tag":241,"props":379,"children":380},{},[381],{"type":188,"value":382},"噪声邻居效应：一个高带宽训练任务影响同 fabric 上所有推理服务的 P99 延迟。",{"type":182,"tag":241,"props":384,"children":385},{},[386],{"type":188,"value":387},"故障域耦合：将高可用副本集集中在同一交换机或机柜，一旦网络故障即整体失效。",{"type":182,"tag":241,"props":389,"children":390},{},[391],{"type":188,"value":392},"性能回归难以归因：即便应用容器镜像、模型版本都未改变，仅调度放置位置不同就会引起 20%+ 性能波动。",{"type":182,"tag":218,"props":394,"children":396},{"id":395},"模式与原理拓扑感知调度在做什么",[397],{"type":188,"value":398},"模式与原理：拓扑感知调度在做什么",{"type":182,"tag":225,"props":400,"children":402},{"id":401},"核心思路把拓扑引入调度决策",[403],{"type":188,"value":404},"核心思路：把“拓扑”引入调度决策",{"type":182,"tag":191,"props":406,"children":407},{},[408],{"type":188,"value":409},"拓扑感知调度的本质，是在调度决策中显式引入以下信息：",{"type":182,"tag":237,"props":411,"children":412},{},[413,436,454],{"type":182,"tag":241,"props":414,"children":415},{},[416,418],{"type":188,"value":417},"物理与逻辑拓扑：\n",{"type":182,"tag":237,"props":419,"children":420},{},[421,426,431],{"type":182,"tag":241,"props":422,"children":423},{},[424],{"type":188,"value":425},"NVLink 拓扑（岛内 vs 岛间）。",{"type":182,"tag":241,"props":427,"children":428},{},[429],{"type":188,"value":430},"PCIe 关系（同根复杂度、跨 CPU socket）。",{"type":182,"tag":241,"props":432,"children":433},{},[434],{"type":188,"value":435},"网络拓扑（机箱内 / 机柜内 / 机柜间、交换层级）。",{"type":182,"tag":241,"props":437,"children":438},{},[439,441],{"type":188,"value":440},"链路特性与健康状况：\n",{"type":182,"tag":237,"props":442,"children":443},{},[444,449],{"type":182,"tag":241,"props":445,"children":446},{},[447],{"type":188,"value":448},"有效带宽、延迟、抖动。",{"type":182,"tag":241,"props":450,"children":451},{},[452],{"type":188,"value":453},"当前利用率和历史拥塞情况。",{"type":182,"tag":241,"props":455,"children":456},{},[457,459],{"type":188,"value":458},"故障域边界：\n",{"type":182,"tag":237,"props":460,"children":461},{},[462],{"type":182,"tag":241,"props":463,"children":464},{},[465],{"type":188,"value":466},"链路、交换机、机柜、供电和机房区域。",{"type":182,"tag":191,"props":468,"children":469},{},[470],{"type":188,"value":471},"调度器基于这些信息，为不同类型的工作负载应用不同策略，而不是一刀切地按“能跑就行”来分配资源。",{"type":182,"tag":225,"props":473,"children":475},{"id":474},"针对训练与推理的不同策略",[476],{"type":188,"value":474},{"type":182,"tag":478,"props":479,"children":480},"ol",{},[481],{"type":182,"tag":241,"props":482,"children":483},{},[484,490],{"type":182,"tag":485,"props":486,"children":487},"strong",{},[488],{"type":188,"value":489},"训练任务（同步、带宽受限）",{"type":188,"value":491},"\n目标：最大化通信效率、稳定 step time。\n典型策略：",{"type":182,"tag":237,"props":493,"children":494},{},[495,500,505],{"type":182,"tag":241,"props":496,"children":497},{},[498],{"type":188,"value":499},"优先将同一作业中的 GPU 放在同一 NVLink 岛内，保证 all-reduce 的高带宽路径。",{"type":182,"tag":241,"props":501,"children":502},{},[503],{"type":188,"value":504},"尽可能减少跨交换机跳数，避免跨机柜长路径。",{"type":182,"tag":241,"props":506,"children":507},{},[508],{"type":188,"value":509},"将链路、交换机、节点视为不同层级的故障域：同一数据并行组尽量不跨“小概率共故障”的边界。",{"type":182,"tag":478,"props":511,"children":513},{"start":512},2,[514],{"type":182,"tag":241,"props":515,"children":516},{},[517,522],{"type":182,"tag":485,"props":518,"children":519},{},[520],{"type":188,"value":521},"推理任务（延迟 & SLO 约束）",{"type":188,"value":523},"\n目标：在高可用与局部性之间平衡。\n典型策略：",{"type":182,"tag":237,"props":525,"children":526},{},[527,532,537],{"type":182,"tag":241,"props":528,"children":529},{},[530],{"type":188,"value":531},"通过副本跨故障域分布，提升高可用能力。",{"type":182,"tag":241,"props":533,"children":534},{},[535],{"type":188,"value":536},"对 MoE、KV-cache 这种强调局部性的结构，尽量把相关 shard 放在最短网络路径上。",{"type":182,"tag":241,"props":538,"children":539},{},[540],{"type":188,"value":541},"区分 prefill 与 decode 阶段：prefill 可适度批处理、追求吞吐；decode 更敏感于尾延迟，调度策略应不同。",{"type":182,"tag":218,"props":543,"children":545},{"id":544},"对比与演进从资源视角到拓扑视角",[546],{"type":188,"value":547},"对比与演进：从“资源视角”到“拓扑视角”",{"type":182,"tag":225,"props":549,"children":551},{"id":550},"旧模式资源是可互换的",[552],{"type":188,"value":553},"旧模式：资源是“可互换的”",{"type":182,"tag":191,"props":555,"children":556},{},[557],{"type":188,"value":558},"传统 GPU 调度的假设：",{"type":182,"tag":237,"props":560,"children":561},{},[562,567],{"type":182,"tag":241,"props":563,"children":564},{},[565],{"type":188,"value":566},"只要满足 $$\\text{N_GPU}$$、显存、简单 label，就认为机器是等价的。",{"type":182,"tag":241,"props":568,"children":569},{},[570],{"type":188,"value":571},"性能回归多被归咎于模型或代码变化，较少怀疑“放置”。",{"type":182,"tag":191,"props":573,"children":574},{},[575],{"type":188,"value":576},"这种模式在以下情况下还能凑合：",{"type":182,"tag":237,"props":578,"children":579},{},[580,585,590],{"type":182,"tag":241,"props":581,"children":582},{},[583],{"type":188,"value":584},"小规模训练（单机或少量节点）。",{"type":182,"tag":241,"props":586,"children":587},{},[588],{"type":188,"value":589},"模型规模较小，对跨节点带宽不敏感。",{"type":182,"tag":241,"props":591,"children":592},{},[593],{"type":188,"value":594},"推理 QPS 较低，对尾延迟要求宽松。",{"type":182,"tag":225,"props":596,"children":598},{"id":597},"新模式资源有位置和关系",[599],{"type":188,"value":600},"新模式：资源有“位置”和“关系”",{"type":182,"tag":191,"props":602,"children":603},{},[604],{"type":188,"value":605},"拓扑感知调度的变化包括：",{"type":182,"tag":237,"props":607,"children":608},{},[609,614,619],{"type":182,"tag":241,"props":610,"children":611},{},[612],{"type":188,"value":613},"作业描述不再只有“要 8 张卡”，而是附带“需要单一 NVLink 岛”“允许最多 1 次跨交换跳”等约束。",{"type":182,"tag":241,"props":615,"children":616},{},[617],{"type":188,"value":618},"调度决策不再是单步贪心，而是需要全局考虑同一 fabric 上多个作业的带宽竞争。",{"type":182,"tag":241,"props":620,"children":621},{},[622],{"type":188,"value":623},"调度策略与底层硬件演进更加耦合：新架构（如 NVL、定制加速器）推出时，需要更新对应的拓扑模型和约束策略。",{"type":182,"tag":191,"props":625,"children":626},{},[627],{"type":188,"value":628},"这意味着调度系统从“通用资源分配器”演进为“面向加速器的性能协调器”。",{"type":182,"tag":218,"props":630,"children":632},{"id":631},"系统性影响对平台与工程实践的改变",[633],{"type":188,"value":634},"系统性影响：对平台与工程实践的改变",{"type":182,"tag":225,"props":636,"children":638},{"id":637},"对整体架构与平台的影响",[639],{"type":188,"value":637},{"type":182,"tag":237,"props":641,"children":642},{},[643,653,658,663,673,678],{"type":182,"tag":241,"props":644,"children":645},{},[646,651],{"type":182,"tag":485,"props":647,"children":648},{},[649],{"type":188,"value":650},"控制面复杂度上升",{"type":188,"value":652},"\n调度器需要：",{"type":182,"tag":241,"props":654,"children":655},{},[656],{"type":188,"value":657},"与底层网络与 GPU 管理系统集成，获取实时或准实时拓扑信息。",{"type":182,"tag":241,"props":659,"children":660},{},[661],{"type":188,"value":662},"保持拓扑模型与实际布线和变更同步（机柜搬迁、链路增减等）。",{"type":182,"tag":241,"props":664,"children":665},{},[666,671],{"type":182,"tag":485,"props":667,"children":668},{},[669],{"type":188,"value":670},"观测与调优需求增强",{"type":188,"value":672},"\n平台通常需要：",{"type":182,"tag":241,"props":674,"children":675},{},[676],{"type":188,"value":677},"对 step time、集体通信耗时、网络利用率做统一观测。",{"type":182,"tag":241,"props":679,"children":680},{},[681],{"type":188,"value":682},"建立“放置变化 → 性能变化”的可追踪性，方便调优与回溯。",{"type":182,"tag":225,"props":684,"children":686},{"id":685},"对工程效率与协作方式的影响",[687],{"type":188,"value":685},{"type":182,"tag":237,"props":689,"children":690},{},[691,709],{"type":182,"tag":241,"props":692,"children":693},{},[694,696],{"type":188,"value":695},"开发与平台之间需要明确“需求表达接口”：\n",{"type":182,"tag":237,"props":697,"children":698},{},[699,704],{"type":182,"tag":241,"props":700,"children":701},{},[702],{"type":188,"value":703},"例如通过作业 spec 中声明训练并行策略、容忍的网络拓扑级别。",{"type":182,"tag":241,"props":705,"children":706},{},[707],{"type":188,"value":708},"推理服务可能需在部署配置中指定对延迟和高可用的优先级取舍。",{"type":182,"tag":241,"props":710,"children":711},{},[712,714],{"type":188,"value":713},"模型工程与 MLOps 团队需要理解：\n",{"type":182,"tag":237,"props":715,"children":716},{},[717,722],{"type":182,"tag":241,"props":718,"children":719},{},[720],{"type":188,"value":721},"为什么同一个模型在不同集群拓扑下表现不同。",{"type":182,"tag":241,"props":723,"children":724},{},[725],{"type":188,"value":726},"何时应该通过调整并行策略、batch 策略而非简单加卡。",{"type":182,"tag":218,"props":728,"children":730},{"id":729},"落地建议如何在团队中实践拓扑感知调度",[731],{"type":188,"value":732},"落地建议：如何在团队中实践拓扑感知调度",{"type":182,"tag":225,"props":734,"children":736},{"id":735},"适用边界与前置条件",[737],{"type":188,"value":735},{"type":182,"tag":191,"props":739,"children":740},{},[741],{"type":188,"value":742},"更适合考虑拓扑感知调度的场景：",{"type":182,"tag":237,"props":744,"children":745},{},[746,751,756],{"type":182,"tag":241,"props":747,"children":748},{},[749],{"type":188,"value":750},"单次训练需使用多机多卡，训练时间以天计，任一步长的提升都能带来可观收益。",{"type":182,"tag":241,"props":752,"children":753},{},[754],{"type":188,"value":755},"集群内存在明显的网络分层结构（机架级 NVLink、分层交换网络），且已经观察到不同节点组合的性能差异。",{"type":182,"tag":241,"props":757,"children":758},{},[759],{"type":188,"value":760},"多租户 GPU 平台中，训练与推理混部，经常出现性能互相干扰。",{"type":182,"tag":191,"props":762,"children":763},{},[764],{"type":188,"value":765},"不建议优先投入的情况：",{"type":182,"tag":237,"props":767,"children":768},{},[769,774,779],{"type":182,"tag":241,"props":770,"children":771},{},[772],{"type":188,"value":773},"主要是小规模单机训练或轻量推理，对尾延迟不敏感。",{"type":182,"tag":241,"props":775,"children":776},{},[777],{"type":188,"value":778},"GPU 资源规模较小、网络拓扑比较“扁平”，实际收益有限。",{"type":182,"tag":241,"props":780,"children":781},{},[782],{"type":188,"value":783},"缺乏基本的观测能力（不能方便地看到网络带宽、step time、P99 延迟等）。",{"type":182,"tag":225,"props":785,"children":787},{"id":786},"渐进式引入路径",[788],{"type":188,"value":786},{"type":182,"tag":191,"props":790,"children":791},{},[792],{"type":188,"value":793},"一个相对稳妥的推进路径可以是：",{"type":182,"tag":478,"props":795,"children":796},{},[797],{"type":182,"tag":241,"props":798,"children":799},{},[800],{"type":182,"tag":485,"props":801,"children":802},{},[803],{"type":188,"value":804},"观测先行",{"type":182,"tag":237,"props":806,"children":807},{},[808,813],{"type":182,"tag":241,"props":809,"children":810},{},[811],{"type":188,"value":812},"给现有训练与推理任务补全：step time、all-reduce 耗时、网络利用率、延迟分布的观测。",{"type":182,"tag":241,"props":814,"children":815},{},[816],{"type":188,"value":817},"对比“不同节点组合”的性能差异，用数据证明拓扑确实是问题来源之一。",{"type":182,"tag":478,"props":819,"children":820},{"start":512},[821],{"type":182,"tag":241,"props":822,"children":823},{},[824],{"type":182,"tag":485,"props":825,"children":826},{},[827],{"type":188,"value":828},"离线分析与手工约束",{"type":182,"tag":237,"props":830,"children":831},{},[832,845],{"type":182,"tag":241,"props":833,"children":834},{},[835,837],{"type":188,"value":836},"在现有调度器上先引入简单的 soft constraint：\n",{"type":182,"tag":237,"props":838,"children":839},{},[840],{"type":182,"tag":241,"props":841,"children":842},{},[843],{"type":188,"value":844},"如“同一训练作业的 GPU 优先同机柜”“同一 DP group 保持在同一 NVLink 岛”。",{"type":182,"tag":241,"props":846,"children":847},{},[848],{"type":188,"value":849},"对比应用约束前后的性能变化和资源碎片率。",{"type":182,"tag":478,"props":851,"children":853},{"start":852},3,[854],{"type":182,"tag":241,"props":855,"children":856},{},[857],{"type":182,"tag":485,"props":858,"children":859},{},[860],{"type":188,"value":861},"集成拓扑信息与调度策略",{"type":182,"tag":237,"props":863,"children":864},{},[865,870],{"type":182,"tag":241,"props":866,"children":867},{},[868],{"type":188,"value":869},"引入支持队列与拓扑感知调度的组件（如正在被评估的 Kueue 等），将拓扑、带宽和故障域纳入调度决策。",{"type":182,"tag":241,"props":871,"children":872},{},[873],{"type":188,"value":874},"根据训练 / 推理不同类型，定义并实现差异化调度策略（如不同优先级队列或 profile）。",{"type":182,"tag":478,"props":876,"children":878},{"start":877},4,[879],{"type":182,"tag":241,"props":880,"children":881},{},[882],{"type":182,"tag":485,"props":883,"children":884},{},[885],{"type":188,"value":886},"规模化与治理",{"type":182,"tag":237,"props":888,"children":889},{},[890,895],{"type":182,"tag":241,"props":891,"children":892},{},[893],{"type":188,"value":894},"当策略稳定后，将拓扑感知调度作为平台“默认能力”，并通过文档和模板向应用团队暴露少量可调参数，而非让每个团队自己写复杂约束。",{"type":182,"tag":241,"props":896,"children":897},{},[898],{"type":188,"value":899},"建立变更流程：新增机架、扩容网络时，同步更新拓扑模型和调度策略。",{"type":182,"tag":225,"props":901,"children":903},{"id":902},"典型风险与防范思路",[904],{"type":188,"value":902},{"type":182,"tag":237,"props":906,"children":907},{},[908,924,953],{"type":182,"tag":241,"props":909,"children":910},{},[911,916],{"type":182,"tag":485,"props":912,"children":913},{},[914],{"type":188,"value":915},"风险：资源碎片化和队列等待时间上升",{"type":182,"tag":237,"props":917,"children":918},{},[919],{"type":182,"tag":241,"props":920,"children":921},{},[922],{"type":188,"value":923},"防范：策略上区分“强约束作业”（大模型训练）与“弹性作业”（小规模训练或离线推理），对后者放宽拓扑要求，平衡整体利用率。",{"type":182,"tag":241,"props":925,"children":926},{},[927,932],{"type":182,"tag":485,"props":928,"children":929},{},[930],{"type":188,"value":931},"风险：调度逻辑过度复杂，难以维护",{"type":182,"tag":237,"props":933,"children":934},{},[935],{"type":182,"tag":241,"props":936,"children":937},{},[938,940],{"type":188,"value":939},"防范：\n",{"type":182,"tag":237,"props":941,"children":942},{},[943,948],{"type":182,"tag":241,"props":944,"children":945},{},[946],{"type":188,"value":947},"将拓扑模型与策略模块化，避免把所有规则硬编码在核心调度器中。",{"type":182,"tag":241,"props":949,"children":950},{},[951],{"type":188,"value":952},"保持清晰的可视化与调试工具，能直观看到一次调度决策为何如此产生。",{"type":182,"tag":241,"props":954,"children":955},{},[956,961],{"type":182,"tag":485,"props":957,"children":958},{},[959],{"type":188,"value":960},"风险：对平台与网络团队的协作要求陡增",{"type":182,"tag":237,"props":962,"children":963},{},[964],{"type":182,"tag":241,"props":965,"children":966},{},[967,968],{"type":188,"value":939},{"type":182,"tag":237,"props":969,"children":970},{},[971,976],{"type":182,"tag":241,"props":972,"children":973},{},[974],{"type":188,"value":975},"从少量关键集群、关键模型开始试点，沉淀跨团队的协作模式与责任边界。",{"type":182,"tag":241,"props":977,"children":978},{},[979],{"type":188,"value":980},"把“拓扑变更影响评估”纳入变更流程，避免网络调整后调度行为失控。",{"type":182,"tag":191,"props":982,"children":983},{},[984],{"type":188,"value":985},"整体而言，拓扑感知调度不是单一功能点，而是一条演进路径：随着训练规模增大、推理延迟要求收紧、硬件拓扑更加复杂，它逐渐从“高级优化”变成“基础能力”。对承担大模型训练和推理基础设施的团队而言，尽早在观测、建模和调度策略上预留演进空间，会减少未来被迫重构的成本。",{"title":175,"searchDepth":512,"depth":512,"links":987},[988,989],{"id":185,"depth":512,"text":189},{"id":213,"depth":512,"text":216,"children":990},[991,992,993,994,995,996],{"id":220,"depth":852,"text":223},{"id":291,"depth":852,"text":294},{"id":395,"depth":852,"text":398},{"id":544,"depth":852,"text":547},{"id":631,"depth":852,"text":634},{"id":729,"depth":852,"text":732},"markdown","content:6.maps:_ai:training:topology-aware-scheduling.md","content","6.maps/_ai/training/topology-aware-scheduling.md","6.maps/_ai/training/topology-aware-scheduling","md",[1004,1008],{"_path":1005,"title":1006,"description":1007},"/maps/_ai/tools/copilot","Copilot","Copilot 是一种新型人机协作工具。",{"_path":1009,"title":1010,"description":1011},"/maps/_ai/training/training","AI Training","AI 训练是指通过提供大量数据和调整模型参数，使人工智能系统能够学习和改进其性能的过程。",1771071684057]