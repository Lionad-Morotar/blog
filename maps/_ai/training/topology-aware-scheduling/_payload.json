[{"data":1,"prerenderedAt":1015},["ShallowReactive",2],{"navigation":3,"/maps/_ai/training/topology-aware-scheduling":173,"/maps/_ai/training/topology-aware-scheduling-surround":1006},[4,35,92,98,125,134,158,164],{"title":5,"_path":6,"children":7},"心流思绪 / Heart Flows","/flows",[8,11,14,17,20,23,26,29,32],{"title":9,"_path":10},"📕 狮子的书单推荐","/flows/books",{"title":12,"_path":13},"🚝 四十二篇系列","/flows/forty-two",{"title":15,"_path":16},"🌃 长夜梦","/flows/long-night-dream",{"title":18,"_path":19},"🌌 万物联结与幸福感","/flows/everything",{"title":21,"_path":22},"⌛ 偷取时间","/flows/stealing-time-from-god",{"title":24,"_path":25},"🌆 表达和孤独","/flows/expression-and-loneliness",{"title":27,"_path":28},"🌧️ 我的腼腆","/flows/shy",{"title":30,"_path":31},"🥛 新工作，喝新饮料","/flows/drinking-while-thinking",{"title":33,"_path":34},"📝 心流归档","/flows/archive",{"title":36,"_path":37,"children":38},"技术博客 / Coder","/articles",[39,41,44,47,50,53,56,59,62,65,68,71,74,77,80,83,86,89],{"title":40,"_path":37},"🦁 欢迎",{"title":42,"_path":43},"📦 一个简单有效的端口命名策略：","/articles/simple-naming-method",{"title":45,"_path":46},"🌪️ Tailwind v4 如何兼容预处理器","/articles/tailwind4-with-sass",{"title":48,"_path":49},"🥞 在 tailwind 中使用现代化 CSS Layers","/articles/tailwind-sass-and-css-layer",{"title":51,"_path":52},"💻 本地部署 Qwen 翻译网页","/articles/local-translator",{"title":54,"_path":55},"🧊 模板解析器轻考古","/articles/micro-templating",{"title":57,"_path":58},"Ⓜ️ Mini CSS Parser","/articles/mini-css-parser",{"title":60,"_path":61},"🚩 向AI咨询前端问题","/articles/use-gpt-learn-complex-frontend",{"title":63,"_path":64},"⛸️ 怎样定制复杂组件的自定义滚动条？","/articles/use-scrollbars",{"title":66,"_path":67},"⚖️ 统一多组件库的层叠顺序","/articles/zindex-manager",{"title":69,"_path":70},"🕷️ 滑动验证码破解思路","/articles/crack-the-slider",{"title":72,"_path":73},"🌟 探秘 CSS 光影效果","/articles/css-light-travel",{"title":75,"_path":76},"🍲 设计模式与 JS 魔法锅","/articles/design-patterns-and-js-magic-pot",{"title":78,"_path":79},"🌐 Anysort：灵活、优雅的多属性排序","/articles/anysort-2th",{"title":81,"_path":82},"💫 CSS 幻术 | 抗锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"body":181,"_type":1000,"_id":1001,"_source":1002,"_file":1003,"_stem":1004,"_extension":1005},"/maps/_ai/training/topology-aware-scheduling","training",false,true,"","拓扑感知调度","拓扑感知调度是一种在分布式计算环境中，根据硬件拓扑结构和网络性能来优化任务调度和资源分配的方法，以提高整体系统的效率和性能。",{"type":182,"children":183,"toc":989},"root",[184,193,199,204,209,214,220,227,234,239,259,264,269,274,292,298,304,309,322,327,345,350,368,373,378,396,402,408,413,470,475,480,495,513,527,545,551,557,562,575,580,598,604,609,627,632,638,643,686,691,730,736,741,746,764,769,787,792,797,808,821,832,853,865,878,890,903,908,984],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"brief",[190],{"type":191,"value":192},"text","Brief",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"GPU 和 LPU 不再是彼此独立的设备，而是构成紧密耦合的加速器网络，其整体性能高度依赖于作业放置位置和底层拓扑结构。在类似 NVIDIA NVL72 这样的机架级系统中，72 张 GPU 共享超过 13 TB 显存，对上层表现为一个单一加速器——直到工作负载跨越交换机“岛屿”，把原本高效的集体通信操作变成瓶颈。类似地，Groq 采用编译期、软件调度的架构，预设了确定性的数据流动；随机调度会打破这些假设和可预测性。即使在同一个数据中心内部，不同 GPU 之间的性能也可能存在显著差异，这推动了一类新的需求：在调度作业时，调度器必须感知硬件拓扑和性能波动，做出拓扑感知的放置决策。",{"type":185,"tag":194,"props":200,"children":201},{},[202],{"type":191,"value":203},"那些忽略 NVLink、PCIe 或 NIC（网卡）拓扑的朴素调度器，往往会把多 GPU 工作负载任意打散，从而导致训练 step time 变长、整体效率下降。训练工作负载通常是同步、带宽受限的，更偏好部署在同一 NVLink“岛屿”的连续 GPU 上，并要求在 all-reduce 和流水线阶段维持统一的高带宽通信路径。这类作业的调度应基于网络织物带宽进行协同分配，避免跨交换机跳数，并将链路、交换机和节点边界视作故障域来处理。与之相对，推理工作负载则更受延迟和 SLO 约束，通常需要在跨故障域的多副本高可用与分片之间取得平衡，以在最短路径上保持 MoE（Mixture of Experts）和 KV-cache 的局部性。进一步针对 prefill 与 decode 阶段分别优化算力放置策略，配合微批处理和租户隔离，可以继续提升整体效率。",{"type":185,"tag":194,"props":205,"children":206},{},[207],{"type":191,"value":208},"随着加速器性能越来越依赖网络和数据中心拓扑，我们认为拓扑感知调度将演变为必需能力。团队已经在评估 Kueue 及相关项目，以提升作业放置精度、性能表现，并在大规模扩展场景中保持可预测的伸缩能力，为客户提供更可靠的算力服务。",{"type":185,"tag":194,"props":210,"children":211},{},[212],{"type":191,"value":213},"来源：技术雷达",{"type":185,"tag":186,"props":215,"children":217},{"id":216},"details",[218],{"type":191,"value":219},"Details",{"type":185,"tag":221,"props":222,"children":224},"h3",{"id":223},"背景与现状为什么需要拓扑感知调度",[225],{"type":191,"value":226},"背景与现状：为什么需要拓扑感知调度",{"type":185,"tag":228,"props":229,"children":231},"h4",{"id":230},"从单卡性能到机架级加速器性能",[232],{"type":191,"value":233},"从“单卡性能”到“机架级加速器性能”",{"type":185,"tag":194,"props":235,"children":236},{},[237],{"type":191,"value":238},"在大模型训练和高并发推理场景下，性能瓶颈正从单卡 FLOPS 转移到集群内通信与数据路径。典型变化包括：",{"type":185,"tag":240,"props":241,"children":242},"ul",{},[243,249,254],{"type":185,"tag":244,"props":245,"children":246},"li",{},[247],{"type":191,"value":248},"机架级系统（如 NVL72 类形态）把几十张 GPU 绑定为一个大加速器，统一暴露显存和算力。",{"type":185,"tag":244,"props":250,"children":251},{},[252],{"type":191,"value":253},"专用推理加速器（如采用编译期调度架构的设备）假设数据流是高度确定的，依赖稳定的网络和放置。",{"type":185,"tag":244,"props":255,"children":256},{},[257],{"type":191,"value":258},"同一数据中心内，不同机柜、不同交换域之间带宽与延迟差异显著，对同步训练尤为敏感。",{"type":185,"tag":194,"props":260,"children":261},{},[262],{"type":191,"value":263},"在这种背景下，调度器如果仍然只把 GPU 当作“同质资源池中的 N 个 slot”，就会系统性浪费硬件能力。",{"type":185,"tag":228,"props":265,"children":267},{"id":266},"典型适用场景",[268],{"type":191,"value":266},{"type":185,"tag":194,"props":270,"children":271},{},[272],{"type":191,"value":273},"拓扑感知调度主要针对以下场景产生价值：",{"type":185,"tag":240,"props":275,"children":276},{},[277,282,287],{"type":185,"tag":244,"props":278,"children":279},{},[280],{"type":191,"value":281},"大规模分布式训练：多机多卡、需要频繁 all-reduce / all-to-all 通信。",{"type":185,"tag":244,"props":283,"children":284},{},[285],{"type":191,"value":286},"大模型推理服务：同时承载高并发在线请求与大 batch 批处理，使用 MoE、KV cache 等结构。",{"type":185,"tag":244,"props":288,"children":289},{},[290],{"type":191,"value":291},"共享 GPU 平台：多团队、多租户共享集群，希望在不干预应用的前提下提升整体利用率和稳定性。",{"type":185,"tag":221,"props":293,"children":295},{"id":294},"问题与风险朴素调度的结构性矛盾",[296],{"type":191,"value":297},"问题与风险：朴素调度的结构性矛盾",{"type":185,"tag":228,"props":299,"children":301},{"id":300},"朴素调度忽略了物理世界",[302],{"type":191,"value":303},"朴素调度忽略了“物理世界”",{"type":185,"tag":194,"props":305,"children":306},{},[307],{"type":191,"value":308},"传统集群调度器往往只看到以下维度：",{"type":185,"tag":240,"props":310,"children":311},{},[312,317],{"type":185,"tag":244,"props":313,"children":314},{},[315],{"type":191,"value":316},"$$\\text{GPU_count}$$、$$\\text{GPU_memory}$$、节点 CPU / 内存；",{"type":185,"tag":244,"props":318,"children":319},{},[320],{"type":191,"value":321},"简单的 label（例如 “has-gpu=true”）。",{"type":185,"tag":194,"props":323,"children":324},{},[325],{"type":191,"value":326},"在这种模型下，多 GPU 任务有较大概率被“打散”到：",{"type":185,"tag":240,"props":328,"children":329},{},[330,335,340],{"type":185,"tag":244,"props":331,"children":332},{},[333],{"type":191,"value":334},"不同 NVLink 岛之间；",{"type":185,"tag":244,"props":336,"children":337},{},[338],{"type":191,"value":339},"需跨多级交换机才能互联的节点上；",{"type":185,"tag":244,"props":341,"children":342},{},[343],{"type":191,"value":344},"带宽抖动明显或共享严重拥塞上行链路的机柜中。",{"type":185,"tag":194,"props":346,"children":347},{},[348],{"type":191,"value":349},"结果是：",{"type":185,"tag":240,"props":351,"children":352},{},[353,358,363],{"type":185,"tag":244,"props":354,"children":355},{},[356],{"type":191,"value":357},"训练任务的 step time 明显变长，吞吐量下降；",{"type":185,"tag":244,"props":359,"children":360},{},[361],{"type":191,"value":362},"同一模型不同 run 之间的性能不稳定，难以容量规划；",{"type":185,"tag":244,"props":364,"children":365},{},[366],{"type":191,"value":367},"对于依赖确定性调度的推理硬件，可能直接破坏延迟 SLO。",{"type":185,"tag":228,"props":369,"children":371},{"id":370},"性能与可靠性的隐性风险",[372],{"type":191,"value":370},{"type":185,"tag":194,"props":374,"children":375},{},[376],{"type":191,"value":377},"在多租户场景中，缺乏拓扑感知还可能带来：",{"type":185,"tag":240,"props":379,"children":380},{},[381,386,391],{"type":185,"tag":244,"props":382,"children":383},{},[384],{"type":191,"value":385},"噪声邻居效应：一个高带宽训练任务影响同 fabric 上所有推理服务的 P99 延迟。",{"type":185,"tag":244,"props":387,"children":388},{},[389],{"type":191,"value":390},"故障域耦合：将高可用副本集集中在同一交换机或机柜，一旦网络故障即整体失效。",{"type":185,"tag":244,"props":392,"children":393},{},[394],{"type":191,"value":395},"性能回归难以归因：即便应用容器镜像、模型版本都未改变，仅调度放置位置不同就会引起 20%+ 性能波动。",{"type":185,"tag":221,"props":397,"children":399},{"id":398},"模式与原理拓扑感知调度在做什么",[400],{"type":191,"value":401},"模式与原理：拓扑感知调度在做什么",{"type":185,"tag":228,"props":403,"children":405},{"id":404},"核心思路把拓扑引入调度决策",[406],{"type":191,"value":407},"核心思路：把“拓扑”引入调度决策",{"type":185,"tag":194,"props":409,"children":410},{},[411],{"type":191,"value":412},"拓扑感知调度的本质，是在调度决策中显式引入以下信息：",{"type":185,"tag":240,"props":414,"children":415},{},[416,439,457],{"type":185,"tag":244,"props":417,"children":418},{},[419,421],{"type":191,"value":420},"物理与逻辑拓扑：\n",{"type":185,"tag":240,"props":422,"children":423},{},[424,429,434],{"type":185,"tag":244,"props":425,"children":426},{},[427],{"type":191,"value":428},"NVLink 拓扑（岛内 vs 岛间）。",{"type":185,"tag":244,"props":430,"children":431},{},[432],{"type":191,"value":433},"PCIe 关系（同根复杂度、跨 CPU socket）。",{"type":185,"tag":244,"props":435,"children":436},{},[437],{"type":191,"value":438},"网络拓扑（机箱内 / 机柜内 / 机柜间、交换层级）。",{"type":185,"tag":244,"props":440,"children":441},{},[442,444],{"type":191,"value":443},"链路特性与健康状况：\n",{"type":185,"tag":240,"props":445,"children":446},{},[447,452],{"type":185,"tag":244,"props":448,"children":449},{},[450],{"type":191,"value":451},"有效带宽、延迟、抖动。",{"type":185,"tag":244,"props":453,"children":454},{},[455],{"type":191,"value":456},"当前利用率和历史拥塞情况。",{"type":185,"tag":244,"props":458,"children":459},{},[460,462],{"type":191,"value":461},"故障域边界：\n",{"type":185,"tag":240,"props":463,"children":464},{},[465],{"type":185,"tag":244,"props":466,"children":467},{},[468],{"type":191,"value":469},"链路、交换机、机柜、供电和机房区域。",{"type":185,"tag":194,"props":471,"children":472},{},[473],{"type":191,"value":474},"调度器基于这些信息，为不同类型的工作负载应用不同策略，而不是一刀切地按“能跑就行”来分配资源。",{"type":185,"tag":228,"props":476,"children":478},{"id":477},"针对训练与推理的不同策略",[479],{"type":191,"value":477},{"type":185,"tag":481,"props":482,"children":483},"ol",{},[484],{"type":185,"tag":244,"props":485,"children":486},{},[487,493],{"type":185,"tag":488,"props":489,"children":490},"strong",{},[491],{"type":191,"value":492},"训练任务（同步、带宽受限）",{"type":191,"value":494},"\n目标：最大化通信效率、稳定 step time。\n典型策略：",{"type":185,"tag":240,"props":496,"children":497},{},[498,503,508],{"type":185,"tag":244,"props":499,"children":500},{},[501],{"type":191,"value":502},"优先将同一作业中的 GPU 放在同一 NVLink 岛内，保证 all-reduce 的高带宽路径。",{"type":185,"tag":244,"props":504,"children":505},{},[506],{"type":191,"value":507},"尽可能减少跨交换机跳数，避免跨机柜长路径。",{"type":185,"tag":244,"props":509,"children":510},{},[511],{"type":191,"value":512},"将链路、交换机、节点视为不同层级的故障域：同一数据并行组尽量不跨“小概率共故障”的边界。",{"type":185,"tag":481,"props":514,"children":516},{"start":515},2,[517],{"type":185,"tag":244,"props":518,"children":519},{},[520,525],{"type":185,"tag":488,"props":521,"children":522},{},[523],{"type":191,"value":524},"推理任务（延迟 & SLO 约束）",{"type":191,"value":526},"\n目标：在高可用与局部性之间平衡。\n典型策略：",{"type":185,"tag":240,"props":528,"children":529},{},[530,535,540],{"type":185,"tag":244,"props":531,"children":532},{},[533],{"type":191,"value":534},"通过副本跨故障域分布，提升高可用能力。",{"type":185,"tag":244,"props":536,"children":537},{},[538],{"type":191,"value":539},"对 MoE、KV-cache 这种强调局部性的结构，尽量把相关 shard 放在最短网络路径上。",{"type":185,"tag":244,"props":541,"children":542},{},[543],{"type":191,"value":544},"区分 prefill 与 decode 阶段：prefill 可适度批处理、追求吞吐；decode 更敏感于尾延迟，调度策略应不同。",{"type":185,"tag":221,"props":546,"children":548},{"id":547},"对比与演进从资源视角到拓扑视角",[549],{"type":191,"value":550},"对比与演进：从“资源视角”到“拓扑视角”",{"type":185,"tag":228,"props":552,"children":554},{"id":553},"旧模式资源是可互换的",[555],{"type":191,"value":556},"旧模式：资源是“可互换的”",{"type":185,"tag":194,"props":558,"children":559},{},[560],{"type":191,"value":561},"传统 GPU 调度的假设：",{"type":185,"tag":240,"props":563,"children":564},{},[565,570],{"type":185,"tag":244,"props":566,"children":567},{},[568],{"type":191,"value":569},"只要满足 $$\\text{N_GPU}$$、显存、简单 label，就认为机器是等价的。",{"type":185,"tag":244,"props":571,"children":572},{},[573],{"type":191,"value":574},"性能回归多被归咎于模型或代码变化，较少怀疑“放置”。",{"type":185,"tag":194,"props":576,"children":577},{},[578],{"type":191,"value":579},"这种模式在以下情况下还能凑合：",{"type":185,"tag":240,"props":581,"children":582},{},[583,588,593],{"type":185,"tag":244,"props":584,"children":585},{},[586],{"type":191,"value":587},"小规模训练（单机或少量节点）。",{"type":185,"tag":244,"props":589,"children":590},{},[591],{"type":191,"value":592},"模型规模较小，对跨节点带宽不敏感。",{"type":185,"tag":244,"props":594,"children":595},{},[596],{"type":191,"value":597},"推理 QPS 较低，对尾延迟要求宽松。",{"type":185,"tag":228,"props":599,"children":601},{"id":600},"新模式资源有位置和关系",[602],{"type":191,"value":603},"新模式：资源有“位置”和“关系”",{"type":185,"tag":194,"props":605,"children":606},{},[607],{"type":191,"value":608},"拓扑感知调度的变化包括：",{"type":185,"tag":240,"props":610,"children":611},{},[612,617,622],{"type":185,"tag":244,"props":613,"children":614},{},[615],{"type":191,"value":616},"作业描述不再只有“要 8 张卡”，而是附带“需要单一 NVLink 岛”“允许最多 1 次跨交换跳”等约束。",{"type":185,"tag":244,"props":618,"children":619},{},[620],{"type":191,"value":621},"调度决策不再是单步贪心，而是需要全局考虑同一 fabric 上多个作业的带宽竞争。",{"type":185,"tag":244,"props":623,"children":624},{},[625],{"type":191,"value":626},"调度策略与底层硬件演进更加耦合：新架构（如 NVL、定制加速器）推出时，需要更新对应的拓扑模型和约束策略。",{"type":185,"tag":194,"props":628,"children":629},{},[630],{"type":191,"value":631},"这意味着调度系统从“通用资源分配器”演进为“面向加速器的性能协调器”。",{"type":185,"tag":221,"props":633,"children":635},{"id":634},"系统性影响对平台与工程实践的改变",[636],{"type":191,"value":637},"系统性影响：对平台与工程实践的改变",{"type":185,"tag":228,"props":639,"children":641},{"id":640},"对整体架构与平台的影响",[642],{"type":191,"value":640},{"type":185,"tag":240,"props":644,"children":645},{},[646,656,661,666,676,681],{"type":185,"tag":244,"props":647,"children":648},{},[649,654],{"type":185,"tag":488,"props":650,"children":651},{},[652],{"type":191,"value":653},"控制面复杂度上升",{"type":191,"value":655},"\n调度器需要：",{"type":185,"tag":244,"props":657,"children":658},{},[659],{"type":191,"value":660},"与底层网络与 GPU 管理系统集成，获取实时或准实时拓扑信息。",{"type":185,"tag":244,"props":662,"children":663},{},[664],{"type":191,"value":665},"保持拓扑模型与实际布线和变更同步（机柜搬迁、链路增减等）。",{"type":185,"tag":244,"props":667,"children":668},{},[669,674],{"type":185,"tag":488,"props":670,"children":671},{},[672],{"type":191,"value":673},"观测与调优需求增强",{"type":191,"value":675},"\n平台通常需要：",{"type":185,"tag":244,"props":677,"children":678},{},[679],{"type":191,"value":680},"对 step time、集体通信耗时、网络利用率做统一观测。",{"type":185,"tag":244,"props":682,"children":683},{},[684],{"type":191,"value":685},"建立“放置变化 → 性能变化”的可追踪性，方便调优与回溯。",{"type":185,"tag":228,"props":687,"children":689},{"id":688},"对工程效率与协作方式的影响",[690],{"type":191,"value":688},{"type":185,"tag":240,"props":692,"children":693},{},[694,712],{"type":185,"tag":244,"props":695,"children":696},{},[697,699],{"type":191,"value":698},"开发与平台之间需要明确“需求表达接口”：\n",{"type":185,"tag":240,"props":700,"children":701},{},[702,707],{"type":185,"tag":244,"props":703,"children":704},{},[705],{"type":191,"value":706},"例如通过作业 spec 中声明训练并行策略、容忍的网络拓扑级别。",{"type":185,"tag":244,"props":708,"children":709},{},[710],{"type":191,"value":711},"推理服务可能需在部署配置中指定对延迟和高可用的优先级取舍。",{"type":185,"tag":244,"props":713,"children":714},{},[715,717],{"type":191,"value":716},"模型工程与 MLOps 团队需要理解：\n",{"type":185,"tag":240,"props":718,"children":719},{},[720,725],{"type":185,"tag":244,"props":721,"children":722},{},[723],{"type":191,"value":724},"为什么同一个模型在不同集群拓扑下表现不同。",{"type":185,"tag":244,"props":726,"children":727},{},[728],{"type":191,"value":729},"何时应该通过调整并行策略、batch 策略而非简单加卡。",{"type":185,"tag":221,"props":731,"children":733},{"id":732},"落地建议如何在团队中实践拓扑感知调度",[734],{"type":191,"value":735},"落地建议：如何在团队中实践拓扑感知调度",{"type":185,"tag":228,"props":737,"children":739},{"id":738},"适用边界与前置条件",[740],{"type":191,"value":738},{"type":185,"tag":194,"props":742,"children":743},{},[744],{"type":191,"value":745},"更适合考虑拓扑感知调度的场景：",{"type":185,"tag":240,"props":747,"children":748},{},[749,754,759],{"type":185,"tag":244,"props":750,"children":751},{},[752],{"type":191,"value":753},"单次训练需使用多机多卡，训练时间以天计，任一步长的提升都能带来可观收益。",{"type":185,"tag":244,"props":755,"children":756},{},[757],{"type":191,"value":758},"集群内存在明显的网络分层结构（机架级 NVLink、分层交换网络），且已经观察到不同节点组合的性能差异。",{"type":185,"tag":244,"props":760,"children":761},{},[762],{"type":191,"value":763},"多租户 GPU 平台中，训练与推理混部，经常出现性能互相干扰。",{"type":185,"tag":194,"props":765,"children":766},{},[767],{"type":191,"value":768},"不建议优先投入的情况：",{"type":185,"tag":240,"props":770,"children":771},{},[772,777,782],{"type":185,"tag":244,"props":773,"children":774},{},[775],{"type":191,"value":776},"主要是小规模单机训练或轻量推理，对尾延迟不敏感。",{"type":185,"tag":244,"props":778,"children":779},{},[780],{"type":191,"value":781},"GPU 资源规模较小、网络拓扑比较“扁平”，实际收益有限。",{"type":185,"tag":244,"props":783,"children":784},{},[785],{"type":191,"value":786},"缺乏基本的观测能力（不能方便地看到网络带宽、step time、P99 延迟等）。",{"type":185,"tag":228,"props":788,"children":790},{"id":789},"渐进式引入路径",[791],{"type":191,"value":789},{"type":185,"tag":194,"props":793,"children":794},{},[795],{"type":191,"value":796},"一个相对稳妥的推进路径可以是：",{"type":185,"tag":481,"props":798,"children":799},{},[800],{"type":185,"tag":244,"props":801,"children":802},{},[803],{"type":185,"tag":488,"props":804,"children":805},{},[806],{"type":191,"value":807},"观测先行",{"type":185,"tag":240,"props":809,"children":810},{},[811,816],{"type":185,"tag":244,"props":812,"children":813},{},[814],{"type":191,"value":815},"给现有训练与推理任务补全：step time、all-reduce 耗时、网络利用率、延迟分布的观测。",{"type":185,"tag":244,"props":817,"children":818},{},[819],{"type":191,"value":820},"对比“不同节点组合”的性能差异，用数据证明拓扑确实是问题来源之一。",{"type":185,"tag":481,"props":822,"children":823},{"start":515},[824],{"type":185,"tag":244,"props":825,"children":826},{},[827],{"type":185,"tag":488,"props":828,"children":829},{},[830],{"type":191,"value":831},"离线分析与手工约束",{"type":185,"tag":240,"props":833,"children":834},{},[835,848],{"type":185,"tag":244,"props":836,"children":837},{},[838,840],{"type":191,"value":839},"在现有调度器上先引入简单的 soft constraint：\n",{"type":185,"tag":240,"props":841,"children":842},{},[843],{"type":185,"tag":244,"props":844,"children":845},{},[846],{"type":191,"value":847},"如“同一训练作业的 GPU 优先同机柜”“同一 DP group 保持在同一 NVLink 岛”。",{"type":185,"tag":244,"props":849,"children":850},{},[851],{"type":191,"value":852},"对比应用约束前后的性能变化和资源碎片率。",{"type":185,"tag":481,"props":854,"children":856},{"start":855},3,[857],{"type":185,"tag":244,"props":858,"children":859},{},[860],{"type":185,"tag":488,"props":861,"children":862},{},[863],{"type":191,"value":864},"集成拓扑信息与调度策略",{"type":185,"tag":240,"props":866,"children":867},{},[868,873],{"type":185,"tag":244,"props":869,"children":870},{},[871],{"type":191,"value":872},"引入支持队列与拓扑感知调度的组件（如正在被评估的 Kueue 等），将拓扑、带宽和故障域纳入调度决策。",{"type":185,"tag":244,"props":874,"children":875},{},[876],{"type":191,"value":877},"根据训练 / 推理不同类型，定义并实现差异化调度策略（如不同优先级队列或 profile）。",{"type":185,"tag":481,"props":879,"children":881},{"start":880},4,[882],{"type":185,"tag":244,"props":883,"children":884},{},[885],{"type":185,"tag":488,"props":886,"children":887},{},[888],{"type":191,"value":889},"规模化与治理",{"type":185,"tag":240,"props":891,"children":892},{},[893,898],{"type":185,"tag":244,"props":894,"children":895},{},[896],{"type":191,"value":897},"当策略稳定后，将拓扑感知调度作为平台“默认能力”，并通过文档和模板向应用团队暴露少量可调参数，而非让每个团队自己写复杂约束。",{"type":185,"tag":244,"props":899,"children":900},{},[901],{"type":191,"value":902},"建立变更流程：新增机架、扩容网络时，同步更新拓扑模型和调度策略。",{"type":185,"tag":228,"props":904,"children":906},{"id":905},"典型风险与防范思路",[907],{"type":191,"value":905},{"type":185,"tag":240,"props":909,"children":910},{},[911,927,956],{"type":185,"tag":244,"props":912,"children":913},{},[914,919],{"type":185,"tag":488,"props":915,"children":916},{},[917],{"type":191,"value":918},"风险：资源碎片化和队列等待时间上升",{"type":185,"tag":240,"props":920,"children":921},{},[922],{"type":185,"tag":244,"props":923,"children":924},{},[925],{"type":191,"value":926},"防范：策略上区分“强约束作业”（大模型训练）与“弹性作业”（小规模训练或离线推理），对后者放宽拓扑要求，平衡整体利用率。",{"type":185,"tag":244,"props":928,"children":929},{},[930,935],{"type":185,"tag":488,"props":931,"children":932},{},[933],{"type":191,"value":934},"风险：调度逻辑过度复杂，难以维护",{"type":185,"tag":240,"props":936,"children":937},{},[938],{"type":185,"tag":244,"props":939,"children":940},{},[941,943],{"type":191,"value":942},"防范：\n",{"type":185,"tag":240,"props":944,"children":945},{},[946,951],{"type":185,"tag":244,"props":947,"children":948},{},[949],{"type":191,"value":950},"将拓扑模型与策略模块化，避免把所有规则硬编码在核心调度器中。",{"type":185,"tag":244,"props":952,"children":953},{},[954],{"type":191,"value":955},"保持清晰的可视化与调试工具，能直观看到一次调度决策为何如此产生。",{"type":185,"tag":244,"props":957,"children":958},{},[959,964],{"type":185,"tag":488,"props":960,"children":961},{},[962],{"type":191,"value":963},"风险：对平台与网络团队的协作要求陡增",{"type":185,"tag":240,"props":965,"children":966},{},[967],{"type":185,"tag":244,"props":968,"children":969},{},[970,971],{"type":191,"value":942},{"type":185,"tag":240,"props":972,"children":973},{},[974,979],{"type":185,"tag":244,"props":975,"children":976},{},[977],{"type":191,"value":978},"从少量关键集群、关键模型开始试点，沉淀跨团队的协作模式与责任边界。",{"type":185,"tag":244,"props":980,"children":981},{},[982],{"type":191,"value":983},"把“拓扑变更影响评估”纳入变更流程，避免网络调整后调度行为失控。",{"type":185,"tag":194,"props":985,"children":986},{},[987],{"type":191,"value":988},"整体而言，拓扑感知调度不是单一功能点，而是一条演进路径：随着训练规模增大、推理延迟要求收紧、硬件拓扑更加复杂，它逐渐从“高级优化”变成“基础能力”。对承担大模型训练和推理基础设施的团队而言，尽早在观测、建模和调度策略上预留演进空间，会减少未来被迫重构的成本。",{"title":178,"searchDepth":515,"depth":515,"links":990},[991,992],{"id":188,"depth":515,"text":192},{"id":216,"depth":515,"text":219,"children":993},[994,995,996,997,998,999],{"id":223,"depth":855,"text":226},{"id":294,"depth":855,"text":297},{"id":398,"depth":855,"text":401},{"id":547,"depth":855,"text":550},{"id":634,"depth":855,"text":637},{"id":732,"depth":855,"text":735},"markdown","content:6.maps:_ai:training:topology-aware-scheduling.md","content","6.maps/_ai/training/topology-aware-scheduling.md","6.maps/_ai/training/topology-aware-scheduling","md",[1007,1011],{"_path":1008,"title":1009,"description":1010},"/maps/_ai/tools/copilot","Copilot","Copilot 是一种新型人机协作工具。",{"_path":1012,"title":1013,"description":1014},"/maps/_ai/training/training","AI Training","AI 训练是指通过提供大量数据和调整模型参数，使人工智能系统能够学习和改进其性能的过程。",1771304542767]