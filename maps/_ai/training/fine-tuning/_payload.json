ine-tuning","Model fine-tuning techniques and best practices","_ai/fine-tuning.md",{"type":183,"children":184,"toc":380},"root",[185,194,201,207,230,236,241,260,266,271,290,296,301,320,326,331,350,356,361],{"type":186,"tag":187,"props":188,"children":190},"element","h1",{"id":189},"微调-fine-tuning",[191],{"type":192,"value":193},"text","微调 (Fine-tuning)",{"type":186,"tag":195,"props":196,"children":198},"h2",{"id":197},"axolotlyaml-配置驱动的微调框架",[199],{"type":192,"value":200},"Axolotl：YAML 配置驱动的微调框架",{"type":186,"tag":202,"props":203,"children":204},"p",{},[205],{"type":192,"value":206},"Axolotl 的核心理念是\"用 YAML 定义整个训练流程\"——从数据预处理、模型加载、训练配置到导出部署，全部收敛在一个配置文件中。这种声明式接口降低了微调门槛，支持 LoRA/QLoRA、全参数微调、多模态微调和持续预训练。2025 年 2 月新增 LoRA 优化，在单 GPU 和多 GPU 训练中进一步降低内存占用并提升训练速度。",{"type":186,"tag":202,"props":208,"children":209},{},[210,212,221,223],{"type":192,"value":211},"见：",{"type":186,"tag":213,"props":214,"children":218},"a",{"href":215,"rel":216},"https://github.com/axolotl-ai-cloud/axolotl",[217],"nofollow",[219],{"type":192,"value":220},"Axolotl GitHub",{"type":192,"value":222}," | ",{"type":186,"tag":213,"props":224,"children":227},{"href":225,"rel":226},"https://docs.axolotl.ai/",[217],[228],{"type":192,"value":229},"Axolotl 官方文档",{"type":186,"tag":195,"props":231,"children":233},{"id":232},"llama-factory一站式-llm-训练与部署平台",[234],{"type":192,"value":235},"LLaMA-Factory：一站式 LLM 训练与部署平台",{"type":186,"tag":202,"props":237,"children":238},{},[239],{"type":192,"value":240},"LLaMA-Factory 是目前最全面的开源微调框架，支持 100+ 模型架构，提供 Web UI 界面让非技术人员也能轻松操作。其特色是集成了模型量化、合并、导出等全流程工具，微调完成后可直接生成 GGUF、vLLM 等部署格式。通过可扩展的模块统一了多种高效微调方法，让大模型微调真正普及。",{"type":186,"tag":202,"props":242,"children":243},{},[244,245,252,253],{"type":192,"value":211},{"type":186,"tag":213,"props":246,"children":249},{"href":247,"rel":248},"https://github.com/hiyouga/LLaMA-Factory",[217],[250],{"type":192,"value":251},"LLaMA-Factory GitHub",{"type":192,"value":222},{"type":186,"tag":213,"props":254,"children":257},{"href":255,"rel":256},"https://zhuanlan.zhihu.com/p/694047673",[217],[258],{"type":192,"value":259},"LLaMA-Factory 使用指南",{"type":186,"tag":195,"props":261,"children":263},{"id":262},"lora低秩适配的参数高效微调",[264],{"type":192,"value":265},"LoRA：低秩适配的参数高效微调",{"type":186,"tag":202,"props":267,"children":268},{},[269],{"type":192,"value":270},"LoRA（Low-Rank Adaptation）冻结预训练模型权重，注入可训练的秩分解矩阵到每一层：W = W_0 + BA，其中 W_0 冻结，B 和 A 可训练且秩远小于 W。这种方法将训练参数量减少 10000 倍，同时保持与全参数微调相当的性能，是在消费级 GPU 上微调大模型的标准选择。",{"type":186,"tag":202,"props":272,"children":273},{},[274,275,282,283],{"type":192,"value":211},{"type":186,"tag":213,"props":276,"children":279},{"href":277,"rel":278},"https://arxiv.org/abs/2106.09685",[217],[280],{"type":192,"value":281},"LoRA 论文",{"type":192,"value":222},{"type":186,"tag":213,"props":284,"children":287},{"href":285,"rel":286},"https://huggingface.co/learn/llm-course/en/chapter11/4",[217],[288],{"type":192,"value":289},"Hugging Face LoRA 教程",{"type":186,"tag":195,"props":291,"children":293},{"id":292},"qlora量化-lora-的极致内存优化",[294],{"type":192,"value":295},"QLoRA：量化 + LoRA 的极致内存优化",{"type":186,"tag":202,"props":297,"children":298},{},[299],{"type":192,"value":300},"QLoRA 将 4-bit 量化与 LoRA 结合，实现最大内存效率。全参数微调 70 亿参数模型需要 100-120GB 显存，而 QLoRA 仅需约 10GB，让消费级 GPU 也能微调大模型。量化后的模型权重以低精度存储，计算时动态反量化，配合 LoRA 的可训练适配器，在效率和效果之间取得完美平衡。",{"type":186,"tag":202,"props":302,"children":303},{},[304,305,312,313],{"type":192,"value":211},{"type":186,"tag":213,"props":306,"children":309},{"href":307,"rel":308},"https://www.redhat.com/en/topics/ai/lora-vs-qlora",[217],[310],{"type":192,"value":311},"LoRA vs QLoRA - RedHat",{"type":192,"value":222},{"type":186,"tag":213,"props":314,"children":317},{"href":315,"rel":316},"https://www.ibm.com/docs/en/watsonx/w-and-w/2.1.0?topic=tuning-qlora-fine",[217],[318],{"type":192,"value":319},"IBM QLoRA 文档",{"type":186,"tag":195,"props":321,"children":323},{"id":322},"pefthugging-face-参数高效微调库",[324],{"type":192,"value":325},"PEFT：Hugging Face 参数高效微调库",{"type":186,"tag":202,"props":327,"children":328},{},[329],{"type":192,"value":330},"PEFT（Parameter-Efficient Fine-Tuning）是 Hugging Face 开源的参数高效微调库，集成了 LoRA、Prefix Tuning、Prompt Tuning、IA³、Adapter 等多种方法。它让研究者可以用统一接口尝试不同微调策略，无需修改模型代码即可切换方法，极大简化了实验流程。",{"type":186,"tag":202,"props":332,"children":333},{},[334,335,342,343],{"type":192,"value":211},{"type":186,"tag":213,"props":336,"children":339},{"href":337,"rel":338},"https://github.com/huggingface/peft",[217],[340],{"type":192,"value":341},"PEFT GitHub",{"type":192,"value":222},{"type":186,"tag":213,"props":344,"children":347},{"href":345,"rel":346},"https://huggingface.co/docs/peft/en/conceptual_guides/adapter",[217],[348],{"type":192,"value":349},"PEFT 方法概览",{"type":186,"tag":195,"props":351,"children":353},{"id":352},"unsloth手写-cuda-内核的极速微调",[354],{"type":192,"value":355},"Unsloth：手写 CUDA 内核的极速微调",{"type":186,"tag":202,"props":357,"children":358},{},[359],{"type":192,"value":360},"Unsloth 通过手写 CUDA 内核和算法优化，在保持精度的前提下将微调速度提升 2-5 倍，显存占用降低 50%+。它针对 LLM 训练中的热点操作（RoPE、LayerNorm、Cross-Entropy）定制 CUDA 实现，支持与 PEFT 完全兼容，只需修改几行导入语句即可加速现有 LoRA/QLoRA 训练代码。",{"type":186,"tag":202,"props":362,"children":363},{},[364,365,372,373],{"type":192,"value":211},{"type":186,"tag":213,"props":366,"children":369},{"href":367,"rel":368},"https://unsloth.ai/",[217],[370],{"type":192,"value":371},"Unsloth 官网",{"type":192,"value":222},{"type":186,"tag":213,"props":374,"children":377},{"href":375,"rel":376},"https://unsloth.ai/blog",[217],[378],{"type":192,"value":379},"Unsloth 博客",{"title":178,"searchDepth":381,"depth":381,"links":382},2,[383,384,385,386,387,388],{"id":197,"depth":381,"text":200},{"id":232,"depth":381,"text":235},{"id":262,"depth":381,"text":265},{"id":292,"depth":381,"text":295},{"id":322,"depth":381,"text":325},{"id":352,"depth":381,"text":355},"markdown","content:6.maps:_ai:training:fine-tuning.md","content","6.maps/_ai/training/fine-tuning.md","6.maps/_ai/training/fine-tuning","md",[396,400],{"_path":397,"title":398,"description":399},"/maps/_ai/tools/tools","Tools","AI 开发工具与平台，包括 Claude Code、浏览器自动化、GitHub Copilot 等编码助手。",{"_path":401,"title":402,"description":403},"/maps/_ai/training/post-training","Post-training","Post-training optimization and model alignment",1772504960793]