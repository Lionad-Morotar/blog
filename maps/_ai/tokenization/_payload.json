,"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133,"children":134},"造物 / Make","/tools",[135,137,140,143,146,149,152],{"title":136,"_path":133},"🧰 工具收集",{"title":138,"_path":139},"📕 博客","/tools/blog",{"title":141,"_path":142},"🥥 Coconut","/tools/coconut",{"title":144,"_path":145},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":147,"_path":148},"🌐 AnySort","/tools/anysort",{"title":150,"_path":151},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":153,"_path":154},"👓 Crapto","/tools/crypto-inline",{"title":156,"_path":157,"children":158},"我 / About","/hire",[159],{"title":160,"_path":157},"📬 技术简历",{"title":162,"_path":163,"children":164},"En","/en",[165],{"title":166,"_path":167,"children":168},"🦁 Welcome","/en/articles",[169],{"title":166,"_path":167},{"_path":171,"_dir":172,"_draft":173,"_partial":174,"_locale":175,"title":176,"description":175,"body":177,"_type":351,"_id":352,"_source":353,"_file":354,"_stem":355,"_extension":356},"/maps/_ai/tokenization","_ai",false,true,"","分词 (Tokenization)",{"type":178,"children":179,"toc":342},"root",[180,188,195,201,224,230,235,254,260,265,276,282,287,298,304,309,320,326,331],{"type":181,"tag":182,"props":183,"children":185},"element","h1",{"id":184},"分词-tokenization",[186],{"type":187,"value":176},"text",{"type":181,"tag":189,"props":190,"children":192},"h2",{"id":191},"huggingface-tokenizersrust-实现的高性能分词",[193],{"type":187,"value":194},"HuggingFace Tokenizers：Rust 实现的高性能分词",{"type":181,"tag":196,"props":197,"children":198},"p",{},[199],{"type":187,"value":200},"HuggingFace Tokenizers 基于 Rust 实现，提供 Python 绑定，在训练和推理速度上都显著优于纯 Python 实现。在 GB 级语料上训练 tokenizer，它比纯 Python 实现快 10-100 倍，内存占用更低。支持 BPE、Byte-Level BPE、WordPiece、Unigram 等主流算法，与 transformers 生态无缝集成。",{"type":181,"tag":196,"props":202,"children":203},{},[204,206,215,217],{"type":187,"value":205},"见：",{"type":181,"tag":207,"props":208,"children":212},"a",{"href":209,"rel":210},"https://github.com/huggingface/tokenizers",[211],"nofollow",[213],{"type":187,"value":214},"HuggingFace Tokenizers GitHub",{"type":187,"value":216}," | ",{"type":181,"tag":207,"props":218,"children":221},{"href":219,"rel":220},"https://huggingface.co/docs/tokenizers/index",[211],[222],{"type":187,"value":223},"Tokenizers 文档",{"type":181,"tag":189,"props":225,"children":227},{"id":226},"sentencepiece语言无关的无监督分词器",[228],{"type":187,"value":229},"SentencePiece：语言无关的无监督分词器",{"type":181,"tag":196,"props":231,"children":232},{},[233],{"type":187,"value":234},"SentencePiece 由 Google 开发，采用\"语言无关\"的设计理念——不依赖预定义的单词边界（如空格），直接从原始文本学习子词单元。这让它在处理中文、日文等没有空格分隔的语言时特别有效，无需预先分词。支持 BPE、Unigram、Char、Word 四种模式。",{"type":181,"tag":196,"props":236,"children":237},{},[238,239,246,247],{"type":187,"value":205},{"type":181,"tag":207,"props":240,"children":243},{"href":241,"rel":242},"https://github.com/google/sentencepiece",[211],[244],{"type":187,"value":245},"SentencePiece GitHub",{"type":187,"value":216},{"type":181,"tag":207,"props":248,"children":251},{"href":249,"rel":250},"https://aclanthology.org/D18-2012.pdf",[211],[252],{"type":187,"value":253},"SentencePiece 论文",{"type":181,"tag":189,"props":255,"children":257},{"id":256},"bpe从小到大的子词合并算法",[258],{"type":187,"value":259},"BPE：从小到大的子词合并算法",{"type":181,"tag":196,"props":261,"children":262},{},[263],{"type":187,"value":264},"BPE（Byte-Pair Encoding）是 GPT 系列使用的分词算法，从字符开始逐步合并高频子串。训练方向是\"从小到大\"，每次选择频率最高的字符对合并，直到达到目标词表大小。优点是简单高效，能很好地平衡词表大小和序列长度。",{"type":181,"tag":196,"props":266,"children":267},{},[268,269],{"type":187,"value":205},{"type":181,"tag":207,"props":270,"children":273},{"href":271,"rel":272},"https://zhuanlan.zhihu.com/p/716655053",[211],[274],{"type":187,"value":275},"BPE 分词算法详解",{"type":181,"tag":189,"props":277,"children":279},{"id":278},"wordpiece基于似然增益的分词策略",[280],{"type":187,"value":281},"WordPiece：基于似然增益的分词策略",{"type":181,"tag":196,"props":283,"children":284},{},[285],{"type":187,"value":286},"WordPiece 是 BERT 使用的分词算法，与 BPE 类似也是从小到大合并，但选择策略不同——不是选频率最高的对，而是选似然增益最大的对。训练目标是最大化训练数据的似然概率，在数学上更加严谨。",{"type":181,"tag":196,"props":288,"children":289},{},[290,291],{"type":187,"value":205},{"type":181,"tag":207,"props":292,"children":295},{"href":293,"rel":294},"https://huggingface.co/learn/llm-course/en/chapter6/6",[211],[296],{"type":187,"value":297},"WordPiece tokenization - Hugging Face",{"type":181,"tag":189,"props":299,"children":301},{"id":300},"byte-level-bpe从根本上消除-oov",[302],{"type":187,"value":303},"Byte-level BPE：从根本上消除 OOV",{"type":181,"tag":196,"props":305,"children":306},{},[307],{"type":187,"value":308},"GPT-2 引入的 Byte-level BPE 将词表基础单元从字符降为字节，任何 Unicode 字符都可表示为 1-4 个字节序列，从根本上消除了 OOV（未登录词）问题。代价是序列长度略有增加，但对于现代 Transformer 的长上下文能力而言，这是可接受的权衡。",{"type":181,"tag":196,"props":310,"children":311},{},[312,313],{"type":187,"value":205},{"type":181,"tag":207,"props":314,"children":317},{"href":315,"rel":316},"https://blog.csdn.net/u013172930/article/details/147045833",[211],[318],{"type":187,"value":319},"字节级 BPE 详解",{"type":181,"tag":189,"props":321,"children":323},{"id":322},"中文分词词表扩充是关键",[324],{"type":187,"value":325},"中文分词：词表扩充是关键",{"type":181,"tag":196,"props":327,"children":328},{},[329],{"type":187,"value":330},"LLaMA 原生 tokenizer 仅包含少量中文字符，导致一个汉字被切分成 2-3 个 token，显著降低编码效率。使用 SentencePiece 训练中文扩展词表是中文 LLM 开发的必要步骤。推荐词表大小：32K-50K 用于通用英语，100K+ 用于多语言，200K+ 用于文本+代码混合。",{"type":181,"tag":196,"props":332,"children":333},{},[334,335],{"type":187,"value":205},{"type":181,"tag":207,"props":336,"children":339},{"href":337,"rel":338},"https://zhuanlan.zhihu.com/p/630696264",[211],[340],{"type":187,"value":341},"大模型词表扩充必备工具",{"title":175,"searchDepth":343,"depth":343,"links":344},2,[345,346,347,348,349,350],{"id":191,"depth":343,"text":194},{"id":226,"depth":343,"text":229},{"id":256,"depth":343,"text":259},{"id":278,"depth":343,"text":281},{"id":300,"depth":343,"text":303},{"id":322,"depth":343,"text":325},"markdown","content:6.maps:_ai:tokenization.md","content","6.maps/_ai/tokenization.md","6.maps/_ai/tokenization","md",[358,362],{"_path":359,"title":360,"description":361},"/maps/_ai/skills/skills","Agent Skills","Skill 是一种能力，作为 Agent 和工具之间的胶水层，帮助 Agent 理解工具以及有控制上下文等优点。",{"_path":363,"title":364,"description":365},"/maps/_ai/tools/claude-code","Claude Code","Anthropic 官方的 AI 编码助手，支持从描述构建功能、调试问题、导航代码库和自动化繁琐任务。",1771264673506]