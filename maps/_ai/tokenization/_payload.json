,"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":178,"body":180,"_type":354,"_id":355,"_source":356,"_file":357,"_stem":358,"_extension":359},"/maps/_ai/tokenization","_ai",false,true,"","分词 (Tokenization)",{"type":181,"children":182,"toc":345},"root",[183,191,198,204,227,233,238,257,263,268,279,285,290,301,307,312,323,329,334],{"type":184,"tag":185,"props":186,"children":188},"element","h1",{"id":187},"分词-tokenization",[189],{"type":190,"value":179},"text",{"type":184,"tag":192,"props":193,"children":195},"h2",{"id":194},"huggingface-tokenizersrust-实现的高性能分词",[196],{"type":190,"value":197},"HuggingFace Tokenizers：Rust 实现的高性能分词",{"type":184,"tag":199,"props":200,"children":201},"p",{},[202],{"type":190,"value":203},"HuggingFace Tokenizers 基于 Rust 实现，提供 Python 绑定，在训练和推理速度上都显著优于纯 Python 实现。在 GB 级语料上训练 tokenizer，它比纯 Python 实现快 10-100 倍，内存占用更低。支持 BPE、Byte-Level BPE、WordPiece、Unigram 等主流算法，与 transformers 生态无缝集成。",{"type":184,"tag":199,"props":205,"children":206},{},[207,209,218,220],{"type":190,"value":208},"见：",{"type":184,"tag":210,"props":211,"children":215},"a",{"href":212,"rel":213},"https://github.com/huggingface/tokenizers",[214],"nofollow",[216],{"type":190,"value":217},"HuggingFace Tokenizers GitHub",{"type":190,"value":219}," | ",{"type":184,"tag":210,"props":221,"children":224},{"href":222,"rel":223},"https://huggingface.co/docs/tokenizers/index",[214],[225],{"type":190,"value":226},"Tokenizers 文档",{"type":184,"tag":192,"props":228,"children":230},{"id":229},"sentencepiece语言无关的无监督分词器",[231],{"type":190,"value":232},"SentencePiece：语言无关的无监督分词器",{"type":184,"tag":199,"props":234,"children":235},{},[236],{"type":190,"value":237},"SentencePiece 由 Google 开发，采用\"语言无关\"的设计理念——不依赖预定义的单词边界（如空格），直接从原始文本学习子词单元。这让它在处理中文、日文等没有空格分隔的语言时特别有效，无需预先分词。支持 BPE、Unigram、Char、Word 四种模式。",{"type":184,"tag":199,"props":239,"children":240},{},[241,242,249,250],{"type":190,"value":208},{"type":184,"tag":210,"props":243,"children":246},{"href":244,"rel":245},"https://github.com/google/sentencepiece",[214],[247],{"type":190,"value":248},"SentencePiece GitHub",{"type":190,"value":219},{"type":184,"tag":210,"props":251,"children":254},{"href":252,"rel":253},"https://aclanthology.org/D18-2012.pdf",[214],[255],{"type":190,"value":256},"SentencePiece 论文",{"type":184,"tag":192,"props":258,"children":260},{"id":259},"bpe从小到大的子词合并算法",[261],{"type":190,"value":262},"BPE：从小到大的子词合并算法",{"type":184,"tag":199,"props":264,"children":265},{},[266],{"type":190,"value":267},"BPE（Byte-Pair Encoding）是 GPT 系列使用的分词算法，从字符开始逐步合并高频子串。训练方向是\"从小到大\"，每次选择频率最高的字符对合并，直到达到目标词表大小。优点是简单高效，能很好地平衡词表大小和序列长度。",{"type":184,"tag":199,"props":269,"children":270},{},[271,272],{"type":190,"value":208},{"type":184,"tag":210,"props":273,"children":276},{"href":274,"rel":275},"https://zhuanlan.zhihu.com/p/716655053",[214],[277],{"type":190,"value":278},"BPE 分词算法详解",{"type":184,"tag":192,"props":280,"children":282},{"id":281},"wordpiece基于似然增益的分词策略",[283],{"type":190,"value":284},"WordPiece：基于似然增益的分词策略",{"type":184,"tag":199,"props":286,"children":287},{},[288],{"type":190,"value":289},"WordPiece 是 BERT 使用的分词算法，与 BPE 类似也是从小到大合并，但选择策略不同——不是选频率最高的对，而是选似然增益最大的对。训练目标是最大化训练数据的似然概率，在数学上更加严谨。",{"type":184,"tag":199,"props":291,"children":292},{},[293,294],{"type":190,"value":208},{"type":184,"tag":210,"props":295,"children":298},{"href":296,"rel":297},"https://huggingface.co/learn/llm-course/en/chapter6/6",[214],[299],{"type":190,"value":300},"WordPiece tokenization - Hugging Face",{"type":184,"tag":192,"props":302,"children":304},{"id":303},"byte-level-bpe从根本上消除-oov",[305],{"type":190,"value":306},"Byte-level BPE：从根本上消除 OOV",{"type":184,"tag":199,"props":308,"children":309},{},[310],{"type":190,"value":311},"GPT-2 引入的 Byte-level BPE 将词表基础单元从字符降为字节，任何 Unicode 字符都可表示为 1-4 个字节序列，从根本上消除了 OOV（未登录词）问题。代价是序列长度略有增加，但对于现代 Transformer 的长上下文能力而言，这是可接受的权衡。",{"type":184,"tag":199,"props":313,"children":314},{},[315,316],{"type":190,"value":208},{"type":184,"tag":210,"props":317,"children":320},{"href":318,"rel":319},"https://blog.csdn.net/u013172930/article/details/147045833",[214],[321],{"type":190,"value":322},"字节级 BPE 详解",{"type":184,"tag":192,"props":324,"children":326},{"id":325},"中文分词词表扩充是关键",[327],{"type":190,"value":328},"中文分词：词表扩充是关键",{"type":184,"tag":199,"props":330,"children":331},{},[332],{"type":190,"value":333},"LLaMA 原生 tokenizer 仅包含少量中文字符，导致一个汉字被切分成 2-3 个 token，显著降低编码效率。使用 SentencePiece 训练中文扩展词表是中文 LLM 开发的必要步骤。推荐词表大小：32K-50K 用于通用英语，100K+ 用于多语言，200K+ 用于文本+代码混合。",{"type":184,"tag":199,"props":335,"children":336},{},[337,338],{"type":190,"value":208},{"type":184,"tag":210,"props":339,"children":342},{"href":340,"rel":341},"https://zhuanlan.zhihu.com/p/630696264",[214],[343],{"type":190,"value":344},"大模型词表扩充必备工具",{"title":178,"searchDepth":346,"depth":346,"links":347},2,[348,349,350,351,352,353],{"id":194,"depth":346,"text":197},{"id":229,"depth":346,"text":232},{"id":259,"depth":346,"text":262},{"id":281,"depth":346,"text":284},{"id":303,"depth":346,"text":306},{"id":325,"depth":346,"text":328},"markdown","content:6.maps:_ai:tokenization.md","content","6.maps/_ai/tokenization.md","6.maps/_ai/tokenization","md",[361,365],{"_path":362,"title":363,"description":364},"/maps/_ai/skills/skills","Agent Skills","Skill 是一种能力，作为 Agent 和工具之间的胶水层，帮助 Agent 理解工具以及有控制上下文等优点。",{"_path":366,"title":367,"description":368},"/maps/_ai/tools/browser-automation","Browser AI Automation","AI 驱动的浏览器自动化工具对比",1771693442366]