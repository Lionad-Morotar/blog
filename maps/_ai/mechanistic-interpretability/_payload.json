dren":179,"toc":368},"root",[180,188,195,201,232,238,243,270,276,281,308,314,319,338,344,349],{"type":181,"tag":182,"props":183,"children":185},"element","h1",{"id":184},"机制可解释性-mechanistic-interpretability",[186],{"type":187,"value":176},"text",{"type":181,"tag":189,"props":190,"children":192},"h2",{"id":191},"transformerlens逆向工程-gpt-风格模型的标准工具",[193],{"type":187,"value":194},"TransformerLens：逆向工程 GPT 风格模型的标准工具",{"type":181,"tag":196,"props":197,"children":198},"p",{},[199],{"type":187,"value":200},"TransformerLens 由 Neel Nanda 开发，是机制可解释性领域的事实标准工具。它提供对 GPT 风格语言模型内部的深度访问能力，包括激活缓存、注意力模式分析、因果追踪和激活修补（Activation Patching）。使用它可以重现经典研究：归纳头（Induction Heads）负责 few-shot 学习的注意力回路、间接对象识别（IOI）解析代词指代消解的电路、以及定位执行简单数学运算的子网络。",{"type":181,"tag":196,"props":202,"children":203},{},[204,206,215,217,224,225],{"type":187,"value":205},"见：",{"type":181,"tag":207,"props":208,"children":212},"a",{"href":209,"rel":210},"https://github.com/TransformerLensOrg/TransformerLens",[211],"nofollow",[213],{"type":187,"value":214},"TransformerLens GitHub",{"type":187,"value":216}," | ",{"type":181,"tag":207,"props":218,"children":221},{"href":219,"rel":220},"https://neelnanda-io.github.io/TransformerLens/",[211],[222],{"type":187,"value":223},"TransformerLens 教程",{"type":187,"value":216},{"type":181,"tag":207,"props":226,"children":229},{"href":227,"rel":228},"https://arxiv.org/html/2404.15255v1",[211],[230],{"type":187,"value":231},"Activation Patching 论文",{"type":181,"tag":189,"props":233,"children":235},{"id":234},"稀疏自动编码器将神经元分解为可解释特征",[236],{"type":187,"value":237},"稀疏自动编码器：将神经元分解为可解释特征",{"type":181,"tag":196,"props":239,"children":240},{},[241],{"type":187,"value":242},"稀疏自动编码器（SAE）是当前可解释性研究的热点方向。它将高维激活向量分解为稀疏的、可解释的\"特征\"基向量，这些特征往往对应人类可理解的概念：数字、颜色、语法结构、甚至抽象的情感概念。Anthropic 在 Claude 3 Sonnet 上的研究发现，约 70% 的 SAE 特征可被人类解释，实现了从\"多义神经元\"到\"单语义特征\"的突破。",{"type":181,"tag":196,"props":244,"children":245},{},[246,247,254,255,262,263],{"type":187,"value":205},{"type":181,"tag":207,"props":248,"children":251},{"href":249,"rel":250},"https://transformer-circuits.pub/2024/scaling-monosemanticity/",[211],[252],{"type":187,"value":253},"Anthropic SAE 研究",{"type":187,"value":216},{"type":181,"tag":207,"props":256,"children":259},{"href":257,"rel":258},"https://nickjiang.substack.com/p/a-primer-on-sparse-autoencoders",[211],[260],{"type":187,"value":261},"SAE 入门指南",{"type":187,"value":216},{"type":181,"tag":207,"props":264,"children":267},{"href":265,"rel":266},"https://github.com/jbloomAus/SAELens",[211],[268],{"type":187,"value":269},"SAELens GitHub",{"type":181,"tag":189,"props":271,"children":273},{"id":272},"nnsight-与-ndif远程可解释性实验基础设施",[274],{"type":187,"value":275},"nnsight 与 NDIF：远程可解释性实验基础设施",{"type":181,"tag":196,"props":277,"children":278},{},[279],{"type":187,"value":280},"传统可解释性工具受限于单机 GPU 显存，难以分析 70B+ 参数模型。nnsight 通过远程执行架构解决了这个问题——本地编写干预逻辑，远程在大型 GPU 集群执行，只返回分析结果。National Deep Inference Facility (NDIF) 为研究者提供免费的远程可解释性计算资源，让任何研究者都能分析 Llama-2-70B 级别的模型。",{"type":181,"tag":196,"props":282,"children":283},{},[284,285,292,293,300,301],{"type":187,"value":205},{"type":181,"tag":207,"props":286,"children":289},{"href":287,"rel":288},"https://nnsight.net/",[211],[290],{"type":187,"value":291},"nnsight 文档",{"type":187,"value":216},{"type":181,"tag":207,"props":294,"children":297},{"href":295,"rel":296},"https://github.com/ndif-team/nnsight",[211],[298],{"type":187,"value":299},"nnsight GitHub",{"type":187,"value":216},{"type":181,"tag":207,"props":302,"children":305},{"href":303,"rel":304},"https://ndif.us/",[211],[306],{"type":187,"value":307},"NDIF 官网",{"type":181,"tag":189,"props":309,"children":311},{"id":310},"归纳头few-shot-学习的注意力回路",[312],{"type":187,"value":313},"归纳头：Few-shot 学习的注意力回路",{"type":181,"tag":196,"props":315,"children":316},{},[317],{"type":187,"value":318},"归纳头是 Transformer 中一种特殊的注意力头模式，负责识别序列中的重复模式并进行 few-shot 学习。当一个 token 在序列中重复出现时，归纳头能够\"复制\"之前出现的模式，这是大模型上下文学习能力的重要机制。通过 TransformerLens 的激活修补技术，可以精确定位这些回路并研究其工作机制。",{"type":181,"tag":196,"props":320,"children":321},{},[322,323,330,331],{"type":187,"value":205},{"type":181,"tag":207,"props":324,"children":327},{"href":325,"rel":326},"https://aclanthology.org/2025.acl-long.442.pdf",[211],[328],{"type":187,"value":329},"Circuit Stability 论文",{"type":187,"value":216},{"type":181,"tag":207,"props":332,"children":335},{"href":333,"rel":334},"https://www.alignmentforum.org/posts/jP9KDyMkchuv6tHwm/how-to-become-a-mechanistic-interpretability-researcher",[211],[336],{"type":187,"value":337},"如何成为可解释性研究员",{"type":181,"tag":189,"props":339,"children":341},{"id":340},"表征工程主动修改模型内部行为",[342],{"type":187,"value":343},"表征工程：主动修改模型内部行为",{"type":181,"tag":196,"props":345,"children":346},{},[347],{"type":187,"value":348},"表征工程（Representation Engineering）是通过定位和修改模型内部表征来实现特定行为的技术。包括增强诚实性（检测并抑制模型幻觉）、提升有用性（增强指令遵循能力）、以及改善安全性（抑制有害输出）。这为 AI 对齐提供了一条不同于 RLHF 的技术路径——直接操作模型的内部表征而非仅仅调整输出分布。",{"type":181,"tag":196,"props":350,"children":351},{},[352,353,360,361],{"type":187,"value":205},{"type":181,"tag":207,"props":354,"children":357},{"href":355,"rel":356},"https://www.anthropic.com/research/transformer-circuits",[211],[358],{"type":187,"value":359},"Anthropic 可解释性研究",{"type":187,"value":216},{"type":181,"tag":207,"props":362,"children":365},{"href":363,"rel":364},"https://arena-chapter1-transformer-interp.streamlit.app/",[211],[366],{"type":187,"value":367},"ARENA 可解释性教程",{"title":175,"searchDepth":369,"depth":369,"links":370},2,[371,372,373,374,375],{"id":191,"depth":369,"text":194},{"id":234,"depth":369,"text":237},{"id":272,"depth":369,"text":275},{"id":310,"depth":369,"text":313},{"id":340,"depth":369,"text":343},"markdown","content:6.maps:_ai:mechanistic-interpretability.md","content","6.maps/_ai/mechanistic-interpretability.md","6.maps/_ai/mechanistic-interpretability","md",[383,387],{"_path":384,"title":385,"description":386},"/maps/_ai/mcp/native-api-to-mcp","反对「直接把内部 API 暴露成 MCP」的天真做法","原文反对将现有内部 API 直接转换为 MCP，建议为代理场景专门设计安全的 MCP 服务层。",{"_path":388,"title":389,"description":175},"/maps/_ai/mlops","MLOps",1771264679116]