":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"body":181,"_type":692,"_id":693,"_source":694,"_file":695,"_stem":696,"_extension":697},"/maps/_cpp/google-cpp-standard","_cpp",false,true,"","Google C++ Standard","Google C++ 编程规范",{"type":182,"children":183,"toc":689},"root",[184,198,204,247,252,280,285,338,343,376,381,389,395,492,497,550,555,578,583,666,671],{"type":185,"tag":186,"props":187,"children":188},"element","p",{},[189],{"type":185,"tag":190,"props":191,"children":195},"a",{"href":192,"rel":193},"https://zh-google-styleguide.readthedocs.io/en/latest/google-cpp-styleguide/headers/",[194],"nofollow",[196],{"type":197,"value":192},"text",{"type":185,"tag":199,"props":200,"children":202},"h4",{"id":201},"头文件",[203],{"type":197,"value":201},{"type":185,"tag":205,"props":206,"children":207},"ul",{},[208,214,232,237,242],{"type":185,"tag":209,"props":210,"children":211},"li",{},[212],{"type":197,"value":213},"头文件应该能够自给自足（self-contained, 也就是可以作为第一个头文件被引入），以 .h 结尾。至于用来插入文本的文件，说到底它们并不是头文件，所以应以 .inc 结尾。不允许分离出 -inl.h 头文件的做法。",{"type":185,"tag":209,"props":215,"children":216},{},[217,219,225,227],{"type":197,"value":218},"所有头文件都应该有 #define 保护来防止头文件被多重包含，命名格式当是：\u003CPROJECT>",{"type":185,"tag":220,"props":221,"children":222},"em",{},[223],{"type":197,"value":224},"\u003CPATH>",{"type":197,"value":226},"\u003CFILE>",{"type":185,"tag":220,"props":228,"children":229},{},[230],{"type":197,"value":231},"H",{"type":185,"tag":209,"props":233,"children":234},{},[235],{"type":197,"value":236},"尽可能地避免使用前置声明。使用 #include 包含需要的头文件即可。",{"type":185,"tag":209,"props":238,"children":239},{},[240],{"type":197,"value":241},"只有当函数只有 10 行甚至更少时才将其定义为内联函数。",{"type":185,"tag":209,"props":243,"children":244},{},[245],{"type":197,"value":246},"使用标准的头文件包含顺序：相关头文件、C 库、C++ 库、其他库的头文件、本项目内的头文件。",{"type":185,"tag":199,"props":248,"children":250},{"id":249},"作用域",[251],{"type":197,"value":249},{"type":185,"tag":205,"props":253,"children":254},{},[255,260,265,270,275],{"type":185,"tag":209,"props":256,"children":257},{},[258],{"type":197,"value":259},"鼓励在 .cc 文件内使用匿名命名空间或 static 声明。使用具名的命名空间时，其名称可基于项目名或相对路径。禁止使用 using 指示（using-directive）。禁止使用内联命名空间（inline namespace）。",{"type":185,"tag":209,"props":261,"children":262},{},[263],{"type":197,"value":264},"在 .cc 文件中定义一个不需要被外部引用的变量时，可以将它们放在匿名命名空间或声明为 static。但是不要在 .h 文件中这么做。",{"type":185,"tag":209,"props":266,"children":267},{},[268],{"type":197,"value":269},"使用静态成员函数或命名空间内的非成员函数，尽量不要用裸的全局函数。将一系列函数直接置于命名空间中，不要用类的静态方法模拟出命名空间的效果，类的静态方法应当和类的实例或静态数据紧密相关。",{"type":185,"tag":209,"props":271,"children":272},{},[273],{"type":197,"value":274},"将函数变量尽可能置于最小作用域内，并在变量声明时进行初始化。",{"type":185,"tag":209,"props":276,"children":277},{},[278],{"type":197,"value":279},"禁止定义静态储存周期非 POD 变量，禁止使用含有副作用的函数初始化 POD 全局变量，因为多编译单元中的静态变量执行时的构造和析构顺序是未明确的，这将导致代码的不可移植。",{"type":185,"tag":199,"props":281,"children":283},{"id":282},"类",[284],{"type":197,"value":282},{"type":185,"tag":205,"props":286,"children":287},{},[288,293,298,303,308,313,318,323,328,333],{"type":185,"tag":209,"props":289,"children":290},{},[291],{"type":197,"value":292},"不要在构造函数中调用虚函数，也不要在无法报出错误时进行可能失败的初始化。",{"type":185,"tag":209,"props":294,"children":295},{},[296],{"type":197,"value":297},"不要定义隐式类型转换。对于转换运算符和单参数构造函数，请使用 explicit 关键字。",{"type":185,"tag":209,"props":299,"children":300},{},[301],{"type":197,"value":302},"如果你的类型需要，就让它们支持拷贝 / 移动。否则，就把隐式产生的拷贝和移动函数禁用。",{"type":185,"tag":209,"props":304,"children":305},{},[306],{"type":197,"value":307},"仅当只有数据成员时使用 struct，其它一概使用 class。",{"type":185,"tag":209,"props":309,"children":310},{},[311],{"type":197,"value":312},"使用组合常常比使用继承更合理。如果使用继承的话，定义为 public 继承。",{"type":185,"tag":209,"props":314,"children":315},{},[316],{"type":197,"value":317},"真正需要用到多重实现继承的情况少之又少。只在以下情况我们才允许多重继承：最多只有一个基类是非抽象类；其它基类都是以 Interface 为后缀的 纯接口类。",{"type":185,"tag":209,"props":319,"children":320},{},[321],{"type":197,"value":322},"接口是指只有纯虚函数和静态函数、没有非静态成员和非 protected 的构造函数的类，这些类以 Interface 为后缀 （不强制）。",{"type":185,"tag":209,"props":324,"children":325},{},[326],{"type":197,"value":327},"除少数特定环境外，不要重载运算符。也不要创建用户定义字面量。",{"type":185,"tag":209,"props":329,"children":330},{},[331],{"type":197,"value":332},"将所有数据成员声明为 private，除非是 static const 类型成员 （遵循 常量命名规则）。",{"type":185,"tag":209,"props":334,"children":335},{},[336],{"type":197,"value":337},"将相似的声明放在一起，将 public 部分放在最前。",{"type":185,"tag":199,"props":339,"children":341},{"id":340},"函数",[342],{"type":197,"value":340},{"type":185,"tag":205,"props":344,"children":345},{},[346,351,356,361,366,371],{"type":185,"tag":209,"props":347,"children":348},{},[349],{"type":197,"value":350},"我们倾向于按值返回， 否则按引用返回。 避免返回指针， 除非它可以为空。",{"type":185,"tag":209,"props":352,"children":353},{},[354],{"type":197,"value":355},"倾向于编写简短，凝练的函数。",{"type":185,"tag":209,"props":357,"children":358},{},[359],{"type":197,"value":360},"所有按引用传递的参数必须加上 const。",{"type":185,"tag":209,"props":362,"children":363},{},[364],{"type":197,"value":365},"若要使用函数重载，则必须能让读者一看调用点就胸有成竹，而不用花心思猜测调用的重载函数到底是哪一种。这一规则也适用于构造函数。",{"type":185,"tag":209,"props":367,"children":368},{},[369],{"type":197,"value":370},"只允许在非虚函数中使用缺省参数，且必须保证缺省参数的值始终一致。缺省参数与 函数重载 遵循同样的规则。一般情况下建议使用函数重载。",{"type":185,"tag":209,"props":372,"children":373},{},[374],{"type":197,"value":375},"只有在常规写法 （返回类型前置） 不便于书写或不便于阅读时使用返回类型后置语法。",{"type":185,"tag":199,"props":377,"children":379},{"id":378},"指针",[380],{"type":197,"value":378},{"type":185,"tag":205,"props":382,"children":383},{},[384],{"type":185,"tag":209,"props":385,"children":386},{},[387],{"type":197,"value":388},"动态分配出的对象最好有单一且固定的所有主，并通过智能指针传递所有权。",{"type":185,"tag":199,"props":390,"children":392},{"id":391},"其他-c-特性",[393],{"type":197,"value":394},"其他 C++ 特性",{"type":185,"tag":205,"props":396,"children":397},{},[398,402,407,412,417,422,427,432,437,442,447,452,457,462,467,472,477,482,487],{"type":185,"tag":209,"props":399,"children":400},{},[401],{"type":197,"value":360},{"type":185,"tag":209,"props":403,"children":404},{},[405],{"type":197,"value":406},"只在定义移动构造函数与移动赋值操作时使用右值引用。不要使用 std::forward。",{"type":185,"tag":209,"props":408,"children":409},{},[410],{"type":197,"value":411},"不允许使用变长数组和 alloca()。",{"type":185,"tag":209,"props":413,"children":414},{},[415],{"type":197,"value":416},"通常友元应该定义在同一文件内。",{"type":185,"tag":209,"props":418,"children":419},{},[420],{"type":197,"value":421},"不使用 C++ 异常。",{"type":185,"tag":209,"props":423,"children":424},{},[425],{"type":197,"value":426},"禁止使用 RTTI。",{"type":185,"tag":209,"props":428,"children":429},{},[430],{"type":197,"value":431},"使用 C++ 的类型转换，如 static_cast\u003C>()。不要使用 int y = (int)x 或 int y = int(x) 等转换方式；",{"type":185,"tag":209,"props":433,"children":434},{},[435],{"type":197,"value":436},"只在记录日志时使用流。",{"type":185,"tag":209,"props":438,"children":439},{},[440],{"type":197,"value":441},"对于迭代器和其他模板对象使用前缀形式 (++i) 的自增，自减运算符。",{"type":185,"tag":209,"props":443,"children":444},{},[445],{"type":197,"value":446},"我们强烈建议你在任何可能的情况下都要使用 const。此外有时改用 C++11 推出的 constexpr 更好。",{"type":185,"tag":209,"props":448,"children":449},{},[450],{"type":197,"value":451},"在 C++11 里，用 constexpr 来定义真正的常量，或实现常量初始化。",{"type":185,"tag":209,"props":453,"children":454},{},[455],{"type":197,"value":456},"C++ 内建整型中，仅使用 int。如果程序中需要不同大小的变量，可以使用 \u003Cstdint.h> 中长度精确的整型，如 int16_t。",{"type":185,"tag":209,"props":458,"children":459},{},[460],{"type":197,"value":461},"使用宏时要非常谨慎，尽量以内联函数，引用，枚举和常量代替之。",{"type":185,"tag":209,"props":463,"children":464},{},[465],{"type":197,"value":466},"整数用 0，实数用 0.0，指针用 nullptr 或 NULL，字符 （串） 用 '\\0'。",{"type":185,"tag":209,"props":468,"children":469},{},[470],{"type":197,"value":471},"尽可能用 sizeof(varname) 代替 sizeof(type)。",{"type":185,"tag":209,"props":473,"children":474},{},[475],{"type":197,"value":476},"用 auto 绕过烦琐的类型名，只要可读性好就继续用，别用在局部变量之外的地方。",{"type":185,"tag":209,"props":478,"children":479},{},[480],{"type":197,"value":481},"适当使用 lambda 表达式。别用默认 lambda 捕获，所有捕获都要显式写出来。",{"type":185,"tag":209,"props":483,"children":484},{},[485],{"type":197,"value":486},"不要使用复杂的模板编程",{"type":185,"tag":209,"props":488,"children":489},{},[490],{"type":197,"value":491},"只使用 Boost 中被认可的库，包括：Call Traits、Compressed Pair、BGL、Property Map、Iterator、Polygon、Bitmap、Statistic Distribution and Functions、Multi-index、Heap、Container。",{"type":185,"tag":199,"props":493,"children":495},{"id":494},"命名约定",[496],{"type":197,"value":494},{"type":185,"tag":205,"props":498,"children":499},{},[500,505,510,515,520,525,530,535,540,545],{"type":185,"tag":209,"props":501,"children":502},{},[503],{"type":197,"value":504},"函数命名，变量命名，文件命名要有描述性；少用缩写。",{"type":185,"tag":209,"props":506,"children":507},{},[508],{"type":197,"value":509},"文件名要全部小写，可以包含下划线或连字符，依照项目的约定。如果没有约定，那么下划线更好。",{"type":185,"tag":209,"props":511,"children":512},{},[513],{"type":197,"value":514},"类型名称的每个单词首字母均大写，不包含下划线。",{"type":185,"tag":209,"props":516,"children":517},{},[518],{"type":197,"value":519},"变量 （包括函数参数） 和数据成员名一律小写，单词之间用下划线连接。类的成员变量以下划线结尾，但结构体的不用。",{"type":185,"tag":209,"props":521,"children":522},{},[523],{"type":197,"value":524},"声明为 constexpr 或 const 的变量，或在程序运行期间其值始终保持不变的，命名时以 “k” 开头，大小写混合。",{"type":185,"tag":209,"props":526,"children":527},{},[528],{"type":197,"value":529},"常规函数使用大小写混合。",{"type":185,"tag":209,"props":531,"children":532},{},[533],{"type":197,"value":534},"取值和设值函数则要求与变量名匹配。",{"type":185,"tag":209,"props":536,"children":537},{},[538],{"type":197,"value":539},"命名空间以小写字母命名。最高级命名空间的名字取决于项目名称。",{"type":185,"tag":209,"props":541,"children":542},{},[543],{"type":197,"value":544},"枚举的命名应当和 常量 一致。",{"type":185,"tag":209,"props":546,"children":547},{},[548],{"type":197,"value":549},"宏命名应使用全部大写加下划线分割单词。",{"type":185,"tag":199,"props":551,"children":553},{"id":552},"注释",[554],{"type":197,"value":552},{"type":185,"tag":205,"props":556,"children":557},{},[558,563,568,573],{"type":185,"tag":209,"props":559,"children":560},{},[561],{"type":197,"value":562},"在每一个文件开头加入版权公告。",{"type":185,"tag":209,"props":564,"children":565},{},[566],{"type":197,"value":567},"函数声明处的注释描述函数功能；定义处的注释描述函数实现。",{"type":185,"tag":209,"props":569,"children":570},{},[571],{"type":197,"value":572},"对于代码中巧妙的，晦涩的，有趣的，重要的地方加以注释。",{"type":185,"tag":209,"props":574,"children":575},{},[576],{"type":197,"value":577},"对那些临时的，短期的解决方案，或已经够好但仍不完美的代码使用 TODO 注释；通过弃用注释（DEPRECATED comments）以标记某接口点已弃用；",{"type":185,"tag":199,"props":579,"children":581},{"id":580},"格式化",[582],{"type":197,"value":580},{"type":185,"tag":205,"props":584,"children":585},{},[586,591,596,601,606,611,616,621,626,631,636,641,646,651,656,661],{"type":185,"tag":209,"props":587,"children":588},{},[589],{"type":197,"value":590},"每一行代码字符数不超过 80。",{"type":185,"tag":209,"props":592,"children":593},{},[594],{"type":197,"value":595},"尽量不使用非 ASCII 字符，使用时必须使用 UTF-8 编码。",{"type":185,"tag":209,"props":597,"children":598},{},[599],{"type":197,"value":600},"只使用空格，每次缩进 2 个空格。",{"type":185,"tag":209,"props":602,"children":603},{},[604],{"type":197,"value":605},"返回类型和函数名在同一行，参数也尽量放在同一行，如果放不下就对形参分行，分行方式与 函数调用 一致。",{"type":185,"tag":209,"props":607,"children":608},{},[609],{"type":197,"value":610},"要么一行写完函数调用，要么在圆括号里对参数分行，要么参数另起一行且缩进四格。如果没有其它顾虑的话，尽可能精简行数，比如把多个参数适当地放在同一行里。",{"type":185,"tag":209,"props":612,"children":613},{},[614],{"type":197,"value":615},"怎么格式化函数调用，就怎么格式化 列表初始化。",{"type":185,"tag":209,"props":617,"children":618},{},[619],{"type":197,"value":620},"倾向于不在圆括号内使用空格。关键字 if 和 else 另起一行。",{"type":185,"tag":209,"props":622,"children":623},{},[624],{"type":197,"value":625},"switch 语句可以使用大括号分段，以表明 cases 之间不是连在一起的。在单语句循环里，括号可用可不用。空循环体应使用 {} 或 continue。",{"type":185,"tag":209,"props":627,"children":628},{},[629],{"type":197,"value":630},"句点或箭头前后不要有空格。指针/地址操作符 (*，&) 之后不能有空格。",{"type":185,"tag":209,"props":632,"children":633},{},[634],{"type":197,"value":635},"布尔运算符如逻辑与总位于行尾：",{"type":185,"tag":209,"props":637,"children":638},{},[639],{"type":197,"value":640},"预处理指令不要缩进，从行首开始。",{"type":185,"tag":209,"props":642,"children":643},{},[644],{"type":197,"value":645},"访问控制块的声明依次序是 public:，protected:，private:，每个都缩进 1 个空格。",{"type":185,"tag":209,"props":647,"children":648},{},[649],{"type":197,"value":650},"构造函数初始化列表放在同一行或按四格缩进并排多行。",{"type":185,"tag":209,"props":652,"children":653},{},[654],{"type":197,"value":655},"命名空间内容不缩进。",{"type":185,"tag":209,"props":657,"children":658},{},[659],{"type":197,"value":660},"水平留白的使用根据在代码中的位置决定。永远不要在行尾添加没意义的留白。",{"type":185,"tag":209,"props":662,"children":663},{},[664],{"type":197,"value":665},"垂直留白越少越好。",{"type":185,"tag":199,"props":667,"children":669},{"id":668},"规则特例",[670],{"type":197,"value":668},{"type":185,"tag":205,"props":672,"children":673},{},[674,679,684],{"type":185,"tag":209,"props":675,"children":676},{},[677],{"type":197,"value":678},"对于现有不符合既定编程风格的代码可以网开一面。",{"type":185,"tag":209,"props":680,"children":681},{},[682],{"type":197,"value":683},"Windows 程序员有自己的编程习惯，主要源于 Windows 头文件和其它 Microsoft 代码。",{"type":185,"tag":209,"props":685,"children":686},{},[687],{"type":197,"value":688},"运用常识和判断力，并且 保持一致。",{"title":178,"searchDepth":690,"depth":690,"links":691},2,[],"markdown","content:6.maps:_cpp:google-cpp-standard.md","content","6.maps/_cpp/google-cpp-standard.md","6.maps/_cpp/google-cpp-standard","md",[699,703],{"_path":700,"title":701,"description":702},"/maps/_cpp/cpp","C++","C++ 是一种静态类型、编译式、通用、多范式编程语言，支持过程化编程、面向对象编程和泛型编程。",{"_path":704,"title":705,"description":706},"/maps/_cpp/king-db","King Database","A simple key-value store database",1771693719011]