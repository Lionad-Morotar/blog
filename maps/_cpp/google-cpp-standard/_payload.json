":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"original_path":181,"body":182,"_type":693,"_id":694,"_source":695,"_file":696,"_stem":697,"_extension":698},"/maps/_cpp/google-cpp-standard","_cpp",false,true,"","Google C++ Standard","Google C++ 编程规范","content/6.maps/_cpp/google-cpp-standard.md",{"type":183,"children":184,"toc":690},"root",[185,199,205,248,253,281,286,339,344,377,382,390,396,493,498,551,556,579,584,667,672],{"type":186,"tag":187,"props":188,"children":189},"element","p",{},[190],{"type":186,"tag":191,"props":192,"children":196},"a",{"href":193,"rel":194},"https://zh-google-styleguide.readthedocs.io/en/latest/google-cpp-styleguide/headers/",[195],"nofollow",[197],{"type":198,"value":193},"text",{"type":186,"tag":200,"props":201,"children":203},"h4",{"id":202},"头文件",[204],{"type":198,"value":202},{"type":186,"tag":206,"props":207,"children":208},"ul",{},[209,215,233,238,243],{"type":186,"tag":210,"props":211,"children":212},"li",{},[213],{"type":198,"value":214},"头文件应该能够自给自足（self-contained, 也就是可以作为第一个头文件被引入），以 .h 结尾。至于用来插入文本的文件，说到底它们并不是头文件，所以应以 .inc 结尾。不允许分离出 -inl.h 头文件的做法。",{"type":186,"tag":210,"props":216,"children":217},{},[218,220,226,228],{"type":198,"value":219},"所有头文件都应该有 #define 保护来防止头文件被多重包含，命名格式当是：\u003CPROJECT>",{"type":186,"tag":221,"props":222,"children":223},"em",{},[224],{"type":198,"value":225},"\u003CPATH>",{"type":198,"value":227},"\u003CFILE>",{"type":186,"tag":221,"props":229,"children":230},{},[231],{"type":198,"value":232},"H",{"type":186,"tag":210,"props":234,"children":235},{},[236],{"type":198,"value":237},"尽可能地避免使用前置声明。使用 #include 包含需要的头文件即可。",{"type":186,"tag":210,"props":239,"children":240},{},[241],{"type":198,"value":242},"只有当函数只有 10 行甚至更少时才将其定义为内联函数。",{"type":186,"tag":210,"props":244,"children":245},{},[246],{"type":198,"value":247},"使用标准的头文件包含顺序：相关头文件、C 库、C++ 库、其他库的头文件、本项目内的头文件。",{"type":186,"tag":200,"props":249,"children":251},{"id":250},"作用域",[252],{"type":198,"value":250},{"type":186,"tag":206,"props":254,"children":255},{},[256,261,266,271,276],{"type":186,"tag":210,"props":257,"children":258},{},[259],{"type":198,"value":260},"鼓励在 .cc 文件内使用匿名命名空间或 static 声明。使用具名的命名空间时，其名称可基于项目名或相对路径。禁止使用 using 指示（using-directive）。禁止使用内联命名空间（inline namespace）。",{"type":186,"tag":210,"props":262,"children":263},{},[264],{"type":198,"value":265},"在 .cc 文件中定义一个不需要被外部引用的变量时，可以将它们放在匿名命名空间或声明为 static。但是不要在 .h 文件中这么做。",{"type":186,"tag":210,"props":267,"children":268},{},[269],{"type":198,"value":270},"使用静态成员函数或命名空间内的非成员函数，尽量不要用裸的全局函数。将一系列函数直接置于命名空间中，不要用类的静态方法模拟出命名空间的效果，类的静态方法应当和类的实例或静态数据紧密相关。",{"type":186,"tag":210,"props":272,"children":273},{},[274],{"type":198,"value":275},"将函数变量尽可能置于最小作用域内，并在变量声明时进行初始化。",{"type":186,"tag":210,"props":277,"children":278},{},[279],{"type":198,"value":280},"禁止定义静态储存周期非 POD 变量，禁止使用含有副作用的函数初始化 POD 全局变量，因为多编译单元中的静态变量执行时的构造和析构顺序是未明确的，这将导致代码的不可移植。",{"type":186,"tag":200,"props":282,"children":284},{"id":283},"类",[285],{"type":198,"value":283},{"type":186,"tag":206,"props":287,"children":288},{},[289,294,299,304,309,314,319,324,329,334],{"type":186,"tag":210,"props":290,"children":291},{},[292],{"type":198,"value":293},"不要在构造函数中调用虚函数，也不要在无法报出错误时进行可能失败的初始化。",{"type":186,"tag":210,"props":295,"children":296},{},[297],{"type":198,"value":298},"不要定义隐式类型转换。对于转换运算符和单参数构造函数，请使用 explicit 关键字。",{"type":186,"tag":210,"props":300,"children":301},{},[302],{"type":198,"value":303},"如果你的类型需要，就让它们支持拷贝 / 移动。否则，就把隐式产生的拷贝和移动函数禁用。",{"type":186,"tag":210,"props":305,"children":306},{},[307],{"type":198,"value":308},"仅当只有数据成员时使用 struct，其它一概使用 class。",{"type":186,"tag":210,"props":310,"children":311},{},[312],{"type":198,"value":313},"使用组合常常比使用继承更合理。如果使用继承的话，定义为 public 继承。",{"type":186,"tag":210,"props":315,"children":316},{},[317],{"type":198,"value":318},"真正需要用到多重实现继承的情况少之又少。只在以下情况我们才允许多重继承：最多只有一个基类是非抽象类；其它基类都是以 Interface 为后缀的 纯接口类。",{"type":186,"tag":210,"props":320,"children":321},{},[322],{"type":198,"value":323},"接口是指只有纯虚函数和静态函数、没有非静态成员和非 protected 的构造函数的类，这些类以 Interface 为后缀 （不强制）。",{"type":186,"tag":210,"props":325,"children":326},{},[327],{"type":198,"value":328},"除少数特定环境外，不要重载运算符。也不要创建用户定义字面量。",{"type":186,"tag":210,"props":330,"children":331},{},[332],{"type":198,"value":333},"将所有数据成员声明为 private，除非是 static const 类型成员 （遵循 常量命名规则）。",{"type":186,"tag":210,"props":335,"children":336},{},[337],{"type":198,"value":338},"将相似的声明放在一起，将 public 部分放在最前。",{"type":186,"tag":200,"props":340,"children":342},{"id":341},"函数",[343],{"type":198,"value":341},{"type":186,"tag":206,"props":345,"children":346},{},[347,352,357,362,367,372],{"type":186,"tag":210,"props":348,"children":349},{},[350],{"type":198,"value":351},"我们倾向于按值返回， 否则按引用返回。 避免返回指针， 除非它可以为空。",{"type":186,"tag":210,"props":353,"children":354},{},[355],{"type":198,"value":356},"倾向于编写简短，凝练的函数。",{"type":186,"tag":210,"props":358,"children":359},{},[360],{"type":198,"value":361},"所有按引用传递的参数必须加上 const。",{"type":186,"tag":210,"props":363,"children":364},{},[365],{"type":198,"value":366},"若要使用函数重载，则必须能让读者一看调用点就胸有成竹，而不用花心思猜测调用的重载函数到底是哪一种。这一规则也适用于构造函数。",{"type":186,"tag":210,"props":368,"children":369},{},[370],{"type":198,"value":371},"只允许在非虚函数中使用缺省参数，且必须保证缺省参数的值始终一致。缺省参数与 函数重载 遵循同样的规则。一般情况下建议使用函数重载。",{"type":186,"tag":210,"props":373,"children":374},{},[375],{"type":198,"value":376},"只有在常规写法 （返回类型前置） 不便于书写或不便于阅读时使用返回类型后置语法。",{"type":186,"tag":200,"props":378,"children":380},{"id":379},"指针",[381],{"type":198,"value":379},{"type":186,"tag":206,"props":383,"children":384},{},[385],{"type":186,"tag":210,"props":386,"children":387},{},[388],{"type":198,"value":389},"动态分配出的对象最好有单一且固定的所有主，并通过智能指针传递所有权。",{"type":186,"tag":200,"props":391,"children":393},{"id":392},"其他-c-特性",[394],{"type":198,"value":395},"其他 C++ 特性",{"type":186,"tag":206,"props":397,"children":398},{},[399,403,408,413,418,423,428,433,438,443,448,453,458,463,468,473,478,483,488],{"type":186,"tag":210,"props":400,"children":401},{},[402],{"type":198,"value":361},{"type":186,"tag":210,"props":404,"children":405},{},[406],{"type":198,"value":407},"只在定义移动构造函数与移动赋值操作时使用右值引用。不要使用 std::forward。",{"type":186,"tag":210,"props":409,"children":410},{},[411],{"type":198,"value":412},"不允许使用变长数组和 alloca()。",{"type":186,"tag":210,"props":414,"children":415},{},[416],{"type":198,"value":417},"通常友元应该定义在同一文件内。",{"type":186,"tag":210,"props":419,"children":420},{},[421],{"type":198,"value":422},"不使用 C++ 异常。",{"type":186,"tag":210,"props":424,"children":425},{},[426],{"type":198,"value":427},"禁止使用 RTTI。",{"type":186,"tag":210,"props":429,"children":430},{},[431],{"type":198,"value":432},"使用 C++ 的类型转换，如 static_cast\u003C>()。不要使用 int y = (int)x 或 int y = int(x) 等转换方式；",{"type":186,"tag":210,"props":434,"children":435},{},[436],{"type":198,"value":437},"只在记录日志时使用流。",{"type":186,"tag":210,"props":439,"children":440},{},[441],{"type":198,"value":442},"对于迭代器和其他模板对象使用前缀形式 (++i) 的自增，自减运算符。",{"type":186,"tag":210,"props":444,"children":445},{},[446],{"type":198,"value":447},"我们强烈建议你在任何可能的情况下都要使用 const。此外有时改用 C++11 推出的 constexpr 更好。",{"type":186,"tag":210,"props":449,"children":450},{},[451],{"type":198,"value":452},"在 C++11 里，用 constexpr 来定义真正的常量，或实现常量初始化。",{"type":186,"tag":210,"props":454,"children":455},{},[456],{"type":198,"value":457},"C++ 内建整型中，仅使用 int。如果程序中需要不同大小的变量，可以使用 \u003Cstdint.h> 中长度精确的整型，如 int16_t。",{"type":186,"tag":210,"props":459,"children":460},{},[461],{"type":198,"value":462},"使用宏时要非常谨慎，尽量以内联函数，引用，枚举和常量代替之。",{"type":186,"tag":210,"props":464,"children":465},{},[466],{"type":198,"value":467},"整数用 0，实数用 0.0，指针用 nullptr 或 NULL，字符 （串） 用 '\\0'。",{"type":186,"tag":210,"props":469,"children":470},{},[471],{"type":198,"value":472},"尽可能用 sizeof(varname) 代替 sizeof(type)。",{"type":186,"tag":210,"props":474,"children":475},{},[476],{"type":198,"value":477},"用 auto 绕过烦琐的类型名，只要可读性好就继续用，别用在局部变量之外的地方。",{"type":186,"tag":210,"props":479,"children":480},{},[481],{"type":198,"value":482},"适当使用 lambda 表达式。别用默认 lambda 捕获，所有捕获都要显式写出来。",{"type":186,"tag":210,"props":484,"children":485},{},[486],{"type":198,"value":487},"不要使用复杂的模板编程",{"type":186,"tag":210,"props":489,"children":490},{},[491],{"type":198,"value":492},"只使用 Boost 中被认可的库，包括：Call Traits、Compressed Pair、BGL、Property Map、Iterator、Polygon、Bitmap、Statistic Distribution and Functions、Multi-index、Heap、Container。",{"type":186,"tag":200,"props":494,"children":496},{"id":495},"命名约定",[497],{"type":198,"value":495},{"type":186,"tag":206,"props":499,"children":500},{},[501,506,511,516,521,526,531,536,541,546],{"type":186,"tag":210,"props":502,"children":503},{},[504],{"type":198,"value":505},"函数命名，变量命名，文件命名要有描述性；少用缩写。",{"type":186,"tag":210,"props":507,"children":508},{},[509],{"type":198,"value":510},"文件名要全部小写，可以包含下划线或连字符，依照项目的约定。如果没有约定，那么下划线更好。",{"type":186,"tag":210,"props":512,"children":513},{},[514],{"type":198,"value":515},"类型名称的每个单词首字母均大写，不包含下划线。",{"type":186,"tag":210,"props":517,"children":518},{},[519],{"type":198,"value":520},"变量 （包括函数参数） 和数据成员名一律小写，单词之间用下划线连接。类的成员变量以下划线结尾，但结构体的不用。",{"type":186,"tag":210,"props":522,"children":523},{},[524],{"type":198,"value":525},"声明为 constexpr 或 const 的变量，或在程序运行期间其值始终保持不变的，命名时以 “k” 开头，大小写混合。",{"type":186,"tag":210,"props":527,"children":528},{},[529],{"type":198,"value":530},"常规函数使用大小写混合。",{"type":186,"tag":210,"props":532,"children":533},{},[534],{"type":198,"value":535},"取值和设值函数则要求与变量名匹配。",{"type":186,"tag":210,"props":537,"children":538},{},[539],{"type":198,"value":540},"命名空间以小写字母命名。最高级命名空间的名字取决于项目名称。",{"type":186,"tag":210,"props":542,"children":543},{},[544],{"type":198,"value":545},"枚举的命名应当和 常量 一致。",{"type":186,"tag":210,"props":547,"children":548},{},[549],{"type":198,"value":550},"宏命名应使用全部大写加下划线分割单词。",{"type":186,"tag":200,"props":552,"children":554},{"id":553},"注释",[555],{"type":198,"value":553},{"type":186,"tag":206,"props":557,"children":558},{},[559,564,569,574],{"type":186,"tag":210,"props":560,"children":561},{},[562],{"type":198,"value":563},"在每一个文件开头加入版权公告。",{"type":186,"tag":210,"props":565,"children":566},{},[567],{"type":198,"value":568},"函数声明处的注释描述函数功能；定义处的注释描述函数实现。",{"type":186,"tag":210,"props":570,"children":571},{},[572],{"type":198,"value":573},"对于代码中巧妙的，晦涩的，有趣的，重要的地方加以注释。",{"type":186,"tag":210,"props":575,"children":576},{},[577],{"type":198,"value":578},"对那些临时的，短期的解决方案，或已经够好但仍不完美的代码使用 TODO 注释；通过弃用注释（DEPRECATED comments）以标记某接口点已弃用；",{"type":186,"tag":200,"props":580,"children":582},{"id":581},"格式化",[583],{"type":198,"value":581},{"type":186,"tag":206,"props":585,"children":586},{},[587,592,597,602,607,612,617,622,627,632,637,642,647,652,657,662],{"type":186,"tag":210,"props":588,"children":589},{},[590],{"type":198,"value":591},"每一行代码字符数不超过 80。",{"type":186,"tag":210,"props":593,"children":594},{},[595],{"type":198,"value":596},"尽量不使用非 ASCII 字符，使用时必须使用 UTF-8 编码。",{"type":186,"tag":210,"props":598,"children":599},{},[600],{"type":198,"value":601},"只使用空格，每次缩进 2 个空格。",{"type":186,"tag":210,"props":603,"children":604},{},[605],{"type":198,"value":606},"返回类型和函数名在同一行，参数也尽量放在同一行，如果放不下就对形参分行，分行方式与 函数调用 一致。",{"type":186,"tag":210,"props":608,"children":609},{},[610],{"type":198,"value":611},"要么一行写完函数调用，要么在圆括号里对参数分行，要么参数另起一行且缩进四格。如果没有其它顾虑的话，尽可能精简行数，比如把多个参数适当地放在同一行里。",{"type":186,"tag":210,"props":613,"children":614},{},[615],{"type":198,"value":616},"怎么格式化函数调用，就怎么格式化 列表初始化。",{"type":186,"tag":210,"props":618,"children":619},{},[620],{"type":198,"value":621},"倾向于不在圆括号内使用空格。关键字 if 和 else 另起一行。",{"type":186,"tag":210,"props":623,"children":624},{},[625],{"type":198,"value":626},"switch 语句可以使用大括号分段，以表明 cases 之间不是连在一起的。在单语句循环里，括号可用可不用。空循环体应使用 {} 或 continue。",{"type":186,"tag":210,"props":628,"children":629},{},[630],{"type":198,"value":631},"句点或箭头前后不要有空格。指针/地址操作符 (*，&) 之后不能有空格。",{"type":186,"tag":210,"props":633,"children":634},{},[635],{"type":198,"value":636},"布尔运算符如逻辑与总位于行尾：",{"type":186,"tag":210,"props":638,"children":639},{},[640],{"type":198,"value":641},"预处理指令不要缩进，从行首开始。",{"type":186,"tag":210,"props":643,"children":644},{},[645],{"type":198,"value":646},"访问控制块的声明依次序是 public:，protected:，private:，每个都缩进 1 个空格。",{"type":186,"tag":210,"props":648,"children":649},{},[650],{"type":198,"value":651},"构造函数初始化列表放在同一行或按四格缩进并排多行。",{"type":186,"tag":210,"props":653,"children":654},{},[655],{"type":198,"value":656},"命名空间内容不缩进。",{"type":186,"tag":210,"props":658,"children":659},{},[660],{"type":198,"value":661},"水平留白的使用根据在代码中的位置决定。永远不要在行尾添加没意义的留白。",{"type":186,"tag":210,"props":663,"children":664},{},[665],{"type":198,"value":666},"垂直留白越少越好。",{"type":186,"tag":200,"props":668,"children":670},{"id":669},"规则特例",[671],{"type":198,"value":669},{"type":186,"tag":206,"props":673,"children":674},{},[675,680,685],{"type":186,"tag":210,"props":676,"children":677},{},[678],{"type":198,"value":679},"对于现有不符合既定编程风格的代码可以网开一面。",{"type":186,"tag":210,"props":681,"children":682},{},[683],{"type":198,"value":684},"Windows 程序员有自己的编程习惯，主要源于 Windows 头文件和其它 Microsoft 代码。",{"type":186,"tag":210,"props":686,"children":687},{},[688],{"type":198,"value":689},"运用常识和判断力，并且 保持一致。",{"title":178,"searchDepth":691,"depth":691,"links":692},2,[],"markdown","content:6.maps:_cpp:google-cpp-standard.md","content","6.maps/_cpp/google-cpp-standard.md","6.maps/_cpp/google-cpp-standard","md",[700,704],{"_path":701,"title":702,"description":703},"/maps/_cpp/cpp","C++","C++ 是一种静态类型、编译式、通用、多范式编程语言",{"_path":705,"title":706,"description":707},"/maps/_cpp/king-db","King Database","A simple key-value store database",1772185479654]