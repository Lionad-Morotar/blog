":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133,"children":134},"造物 / Make","/tools",[135,137,140,143,146,149,152],{"title":136,"_path":133},"🧰 工具收集",{"title":138,"_path":139},"📕 博客","/tools/blog",{"title":141,"_path":142},"🥥 Coconut","/tools/coconut",{"title":144,"_path":145},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":147,"_path":148},"🌐 AnySort","/tools/anysort",{"title":150,"_path":151},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":153,"_path":154},"👓 Crapto","/tools/crypto-inline",{"title":156,"_path":157,"children":158},"我 / About","/hire",[159],{"title":160,"_path":157},"📬 技术简历",{"title":162,"_path":163,"children":164},"En","/en",[165],{"title":166,"_path":167,"children":168},"🦁 Welcome","/en/articles",[169],{"title":166,"_path":167},{"_path":171,"_dir":172,"_draft":173,"_partial":174,"_locale":175,"title":176,"description":177,"body":178,"_type":689,"_id":690,"_source":691,"_file":692,"_stem":693,"_extension":694},"/maps/_cpp/google-cpp-standard","_cpp",false,true,"","Google C++ Standard","Google C++ 编程规范",{"type":179,"children":180,"toc":686},"root",[181,195,201,244,249,277,282,335,340,373,378,386,392,489,494,547,552,575,580,663,668],{"type":182,"tag":183,"props":184,"children":185},"element","p",{},[186],{"type":182,"tag":187,"props":188,"children":192},"a",{"href":189,"rel":190},"https://zh-google-styleguide.readthedocs.io/en/latest/google-cpp-styleguide/headers/",[191],"nofollow",[193],{"type":194,"value":189},"text",{"type":182,"tag":196,"props":197,"children":199},"h4",{"id":198},"头文件",[200],{"type":194,"value":198},{"type":182,"tag":202,"props":203,"children":204},"ul",{},[205,211,229,234,239],{"type":182,"tag":206,"props":207,"children":208},"li",{},[209],{"type":194,"value":210},"头文件应该能够自给自足（self-contained, 也就是可以作为第一个头文件被引入），以 .h 结尾。至于用来插入文本的文件，说到底它们并不是头文件，所以应以 .inc 结尾。不允许分离出 -inl.h 头文件的做法。",{"type":182,"tag":206,"props":212,"children":213},{},[214,216,222,224],{"type":194,"value":215},"所有头文件都应该有 #define 保护来防止头文件被多重包含，命名格式当是：\u003CPROJECT>",{"type":182,"tag":217,"props":218,"children":219},"em",{},[220],{"type":194,"value":221},"\u003CPATH>",{"type":194,"value":223},"\u003CFILE>",{"type":182,"tag":217,"props":225,"children":226},{},[227],{"type":194,"value":228},"H",{"type":182,"tag":206,"props":230,"children":231},{},[232],{"type":194,"value":233},"尽可能地避免使用前置声明。使用 #include 包含需要的头文件即可。",{"type":182,"tag":206,"props":235,"children":236},{},[237],{"type":194,"value":238},"只有当函数只有 10 行甚至更少时才将其定义为内联函数。",{"type":182,"tag":206,"props":240,"children":241},{},[242],{"type":194,"value":243},"使用标准的头文件包含顺序：相关头文件、C 库、C++ 库、其他库的头文件、本项目内的头文件。",{"type":182,"tag":196,"props":245,"children":247},{"id":246},"作用域",[248],{"type":194,"value":246},{"type":182,"tag":202,"props":250,"children":251},{},[252,257,262,267,272],{"type":182,"tag":206,"props":253,"children":254},{},[255],{"type":194,"value":256},"鼓励在 .cc 文件内使用匿名命名空间或 static 声明。使用具名的命名空间时，其名称可基于项目名或相对路径。禁止使用 using 指示（using-directive）。禁止使用内联命名空间（inline namespace）。",{"type":182,"tag":206,"props":258,"children":259},{},[260],{"type":194,"value":261},"在 .cc 文件中定义一个不需要被外部引用的变量时，可以将它们放在匿名命名空间或声明为 static。但是不要在 .h 文件中这么做。",{"type":182,"tag":206,"props":263,"children":264},{},[265],{"type":194,"value":266},"使用静态成员函数或命名空间内的非成员函数，尽量不要用裸的全局函数。将一系列函数直接置于命名空间中，不要用类的静态方法模拟出命名空间的效果，类的静态方法应当和类的实例或静态数据紧密相关。",{"type":182,"tag":206,"props":268,"children":269},{},[270],{"type":194,"value":271},"将函数变量尽可能置于最小作用域内，并在变量声明时进行初始化。",{"type":182,"tag":206,"props":273,"children":274},{},[275],{"type":194,"value":276},"禁止定义静态储存周期非 POD 变量，禁止使用含有副作用的函数初始化 POD 全局变量，因为多编译单元中的静态变量执行时的构造和析构顺序是未明确的，这将导致代码的不可移植。",{"type":182,"tag":196,"props":278,"children":280},{"id":279},"类",[281],{"type":194,"value":279},{"type":182,"tag":202,"props":283,"children":284},{},[285,290,295,300,305,310,315,320,325,330],{"type":182,"tag":206,"props":286,"children":287},{},[288],{"type":194,"value":289},"不要在构造函数中调用虚函数，也不要在无法报出错误时进行可能失败的初始化。",{"type":182,"tag":206,"props":291,"children":292},{},[293],{"type":194,"value":294},"不要定义隐式类型转换。对于转换运算符和单参数构造函数，请使用 explicit 关键字。",{"type":182,"tag":206,"props":296,"children":297},{},[298],{"type":194,"value":299},"如果你的类型需要，就让它们支持拷贝 / 移动。否则，就把隐式产生的拷贝和移动函数禁用。",{"type":182,"tag":206,"props":301,"children":302},{},[303],{"type":194,"value":304},"仅当只有数据成员时使用 struct，其它一概使用 class。",{"type":182,"tag":206,"props":306,"children":307},{},[308],{"type":194,"value":309},"使用组合常常比使用继承更合理。如果使用继承的话，定义为 public 继承。",{"type":182,"tag":206,"props":311,"children":312},{},[313],{"type":194,"value":314},"真正需要用到多重实现继承的情况少之又少。只在以下情况我们才允许多重继承：最多只有一个基类是非抽象类；其它基类都是以 Interface 为后缀的 纯接口类。",{"type":182,"tag":206,"props":316,"children":317},{},[318],{"type":194,"value":319},"接口是指只有纯虚函数和静态函数、没有非静态成员和非 protected 的构造函数的类，这些类以 Interface 为后缀 （不强制）。",{"type":182,"tag":206,"props":321,"children":322},{},[323],{"type":194,"value":324},"除少数特定环境外，不要重载运算符。也不要创建用户定义字面量。",{"type":182,"tag":206,"props":326,"children":327},{},[328],{"type":194,"value":329},"将所有数据成员声明为 private，除非是 static const 类型成员 （遵循 常量命名规则）。",{"type":182,"tag":206,"props":331,"children":332},{},[333],{"type":194,"value":334},"将相似的声明放在一起，将 public 部分放在最前。",{"type":182,"tag":196,"props":336,"children":338},{"id":337},"函数",[339],{"type":194,"value":337},{"type":182,"tag":202,"props":341,"children":342},{},[343,348,353,358,363,368],{"type":182,"tag":206,"props":344,"children":345},{},[346],{"type":194,"value":347},"我们倾向于按值返回， 否则按引用返回。 避免返回指针， 除非它可以为空。",{"type":182,"tag":206,"props":349,"children":350},{},[351],{"type":194,"value":352},"倾向于编写简短，凝练的函数。",{"type":182,"tag":206,"props":354,"children":355},{},[356],{"type":194,"value":357},"所有按引用传递的参数必须加上 const。",{"type":182,"tag":206,"props":359,"children":360},{},[361],{"type":194,"value":362},"若要使用函数重载，则必须能让读者一看调用点就胸有成竹，而不用花心思猜测调用的重载函数到底是哪一种。这一规则也适用于构造函数。",{"type":182,"tag":206,"props":364,"children":365},{},[366],{"type":194,"value":367},"只允许在非虚函数中使用缺省参数，且必须保证缺省参数的值始终一致。缺省参数与 函数重载 遵循同样的规则。一般情况下建议使用函数重载。",{"type":182,"tag":206,"props":369,"children":370},{},[371],{"type":194,"value":372},"只有在常规写法 （返回类型前置） 不便于书写或不便于阅读时使用返回类型后置语法。",{"type":182,"tag":196,"props":374,"children":376},{"id":375},"指针",[377],{"type":194,"value":375},{"type":182,"tag":202,"props":379,"children":380},{},[381],{"type":182,"tag":206,"props":382,"children":383},{},[384],{"type":194,"value":385},"动态分配出的对象最好有单一且固定的所有主，并通过智能指针传递所有权。",{"type":182,"tag":196,"props":387,"children":389},{"id":388},"其他-c-特性",[390],{"type":194,"value":391},"其他 C++ 特性",{"type":182,"tag":202,"props":393,"children":394},{},[395,399,404,409,414,419,424,429,434,439,444,449,454,459,464,469,474,479,484],{"type":182,"tag":206,"props":396,"children":397},{},[398],{"type":194,"value":357},{"type":182,"tag":206,"props":400,"children":401},{},[402],{"type":194,"value":403},"只在定义移动构造函数与移动赋值操作时使用右值引用。不要使用 std::forward。",{"type":182,"tag":206,"props":405,"children":406},{},[407],{"type":194,"value":408},"不允许使用变长数组和 alloca()。",{"type":182,"tag":206,"props":410,"children":411},{},[412],{"type":194,"value":413},"通常友元应该定义在同一文件内。",{"type":182,"tag":206,"props":415,"children":416},{},[417],{"type":194,"value":418},"不使用 C++ 异常。",{"type":182,"tag":206,"props":420,"children":421},{},[422],{"type":194,"value":423},"禁止使用 RTTI。",{"type":182,"tag":206,"props":425,"children":426},{},[427],{"type":194,"value":428},"使用 C++ 的类型转换，如 static_cast\u003C>()。不要使用 int y = (int)x 或 int y = int(x) 等转换方式；",{"type":182,"tag":206,"props":430,"children":431},{},[432],{"type":194,"value":433},"只在记录日志时使用流。",{"type":182,"tag":206,"props":435,"children":436},{},[437],{"type":194,"value":438},"对于迭代器和其他模板对象使用前缀形式 (++i) 的自增，自减运算符。",{"type":182,"tag":206,"props":440,"children":441},{},[442],{"type":194,"value":443},"我们强烈建议你在任何可能的情况下都要使用 const。此外有时改用 C++11 推出的 constexpr 更好。",{"type":182,"tag":206,"props":445,"children":446},{},[447],{"type":194,"value":448},"在 C++11 里，用 constexpr 来定义真正的常量，或实现常量初始化。",{"type":182,"tag":206,"props":450,"children":451},{},[452],{"type":194,"value":453},"C++ 内建整型中，仅使用 int。如果程序中需要不同大小的变量，可以使用 \u003Cstdint.h> 中长度精确的整型，如 int16_t。",{"type":182,"tag":206,"props":455,"children":456},{},[457],{"type":194,"value":458},"使用宏时要非常谨慎，尽量以内联函数，引用，枚举和常量代替之。",{"type":182,"tag":206,"props":460,"children":461},{},[462],{"type":194,"value":463},"整数用 0，实数用 0.0，指针用 nullptr 或 NULL，字符 （串） 用 '\\0'。",{"type":182,"tag":206,"props":465,"children":466},{},[467],{"type":194,"value":468},"尽可能用 sizeof(varname) 代替 sizeof(type)。",{"type":182,"tag":206,"props":470,"children":471},{},[472],{"type":194,"value":473},"用 auto 绕过烦琐的类型名，只要可读性好就继续用，别用在局部变量之外的地方。",{"type":182,"tag":206,"props":475,"children":476},{},[477],{"type":194,"value":478},"适当使用 lambda 表达式。别用默认 lambda 捕获，所有捕获都要显式写出来。",{"type":182,"tag":206,"props":480,"children":481},{},[482],{"type":194,"value":483},"不要使用复杂的模板编程",{"type":182,"tag":206,"props":485,"children":486},{},[487],{"type":194,"value":488},"只使用 Boost 中被认可的库，包括：Call Traits、Compressed Pair、BGL、Property Map、Iterator、Polygon、Bitmap、Statistic Distribution and Functions、Multi-index、Heap、Container。",{"type":182,"tag":196,"props":490,"children":492},{"id":491},"命名约定",[493],{"type":194,"value":491},{"type":182,"tag":202,"props":495,"children":496},{},[497,502,507,512,517,522,527,532,537,542],{"type":182,"tag":206,"props":498,"children":499},{},[500],{"type":194,"value":501},"函数命名，变量命名，文件命名要有描述性；少用缩写。",{"type":182,"tag":206,"props":503,"children":504},{},[505],{"type":194,"value":506},"文件名要全部小写，可以包含下划线或连字符，依照项目的约定。如果没有约定，那么下划线更好。",{"type":182,"tag":206,"props":508,"children":509},{},[510],{"type":194,"value":511},"类型名称的每个单词首字母均大写，不包含下划线。",{"type":182,"tag":206,"props":513,"children":514},{},[515],{"type":194,"value":516},"变量 （包括函数参数） 和数据成员名一律小写，单词之间用下划线连接。类的成员变量以下划线结尾，但结构体的不用。",{"type":182,"tag":206,"props":518,"children":519},{},[520],{"type":194,"value":521},"声明为 constexpr 或 const 的变量，或在程序运行期间其值始终保持不变的，命名时以 “k” 开头，大小写混合。",{"type":182,"tag":206,"props":523,"children":524},{},[525],{"type":194,"value":526},"常规函数使用大小写混合。",{"type":182,"tag":206,"props":528,"children":529},{},[530],{"type":194,"value":531},"取值和设值函数则要求与变量名匹配。",{"type":182,"tag":206,"props":533,"children":534},{},[535],{"type":194,"value":536},"命名空间以小写字母命名。最高级命名空间的名字取决于项目名称。",{"type":182,"tag":206,"props":538,"children":539},{},[540],{"type":194,"value":541},"枚举的命名应当和 常量 一致。",{"type":182,"tag":206,"props":543,"children":544},{},[545],{"type":194,"value":546},"宏命名应使用全部大写加下划线分割单词。",{"type":182,"tag":196,"props":548,"children":550},{"id":549},"注释",[551],{"type":194,"value":549},{"type":182,"tag":202,"props":553,"children":554},{},[555,560,565,570],{"type":182,"tag":206,"props":556,"children":557},{},[558],{"type":194,"value":559},"在每一个文件开头加入版权公告。",{"type":182,"tag":206,"props":561,"children":562},{},[563],{"type":194,"value":564},"函数声明处的注释描述函数功能；定义处的注释描述函数实现。",{"type":182,"tag":206,"props":566,"children":567},{},[568],{"type":194,"value":569},"对于代码中巧妙的，晦涩的，有趣的，重要的地方加以注释。",{"type":182,"tag":206,"props":571,"children":572},{},[573],{"type":194,"value":574},"对那些临时的，短期的解决方案，或已经够好但仍不完美的代码使用 TODO 注释；通过弃用注释（DEPRECATED comments）以标记某接口点已弃用；",{"type":182,"tag":196,"props":576,"children":578},{"id":577},"格式化",[579],{"type":194,"value":577},{"type":182,"tag":202,"props":581,"children":582},{},[583,588,593,598,603,608,613,618,623,628,633,638,643,648,653,658],{"type":182,"tag":206,"props":584,"children":585},{},[586],{"type":194,"value":587},"每一行代码字符数不超过 80。",{"type":182,"tag":206,"props":589,"children":590},{},[591],{"type":194,"value":592},"尽量不使用非 ASCII 字符，使用时必须使用 UTF-8 编码。",{"type":182,"tag":206,"props":594,"children":595},{},[596],{"type":194,"value":597},"只使用空格，每次缩进 2 个空格。",{"type":182,"tag":206,"props":599,"children":600},{},[601],{"type":194,"value":602},"返回类型和函数名在同一行，参数也尽量放在同一行，如果放不下就对形参分行，分行方式与 函数调用 一致。",{"type":182,"tag":206,"props":604,"children":605},{},[606],{"type":194,"value":607},"要么一行写完函数调用，要么在圆括号里对参数分行，要么参数另起一行且缩进四格。如果没有其它顾虑的话，尽可能精简行数，比如把多个参数适当地放在同一行里。",{"type":182,"tag":206,"props":609,"children":610},{},[611],{"type":194,"value":612},"怎么格式化函数调用，就怎么格式化 列表初始化。",{"type":182,"tag":206,"props":614,"children":615},{},[616],{"type":194,"value":617},"倾向于不在圆括号内使用空格。关键字 if 和 else 另起一行。",{"type":182,"tag":206,"props":619,"children":620},{},[621],{"type":194,"value":622},"switch 语句可以使用大括号分段，以表明 cases 之间不是连在一起的。在单语句循环里，括号可用可不用。空循环体应使用 {} 或 continue。",{"type":182,"tag":206,"props":624,"children":625},{},[626],{"type":194,"value":627},"句点或箭头前后不要有空格。指针/地址操作符 (*，&) 之后不能有空格。",{"type":182,"tag":206,"props":629,"children":630},{},[631],{"type":194,"value":632},"布尔运算符如逻辑与总位于行尾：",{"type":182,"tag":206,"props":634,"children":635},{},[636],{"type":194,"value":637},"预处理指令不要缩进，从行首开始。",{"type":182,"tag":206,"props":639,"children":640},{},[641],{"type":194,"value":642},"访问控制块的声明依次序是 public:，protected:，private:，每个都缩进 1 个空格。",{"type":182,"tag":206,"props":644,"children":645},{},[646],{"type":194,"value":647},"构造函数初始化列表放在同一行或按四格缩进并排多行。",{"type":182,"tag":206,"props":649,"children":650},{},[651],{"type":194,"value":652},"命名空间内容不缩进。",{"type":182,"tag":206,"props":654,"children":655},{},[656],{"type":194,"value":657},"水平留白的使用根据在代码中的位置决定。永远不要在行尾添加没意义的留白。",{"type":182,"tag":206,"props":659,"children":660},{},[661],{"type":194,"value":662},"垂直留白越少越好。",{"type":182,"tag":196,"props":664,"children":666},{"id":665},"规则特例",[667],{"type":194,"value":665},{"type":182,"tag":202,"props":669,"children":670},{},[671,676,681],{"type":182,"tag":206,"props":672,"children":673},{},[674],{"type":194,"value":675},"对于现有不符合既定编程风格的代码可以网开一面。",{"type":182,"tag":206,"props":677,"children":678},{},[679],{"type":194,"value":680},"Windows 程序员有自己的编程习惯，主要源于 Windows 头文件和其它 Microsoft 代码。",{"type":182,"tag":206,"props":682,"children":683},{},[684],{"type":194,"value":685},"运用常识和判断力，并且 保持一致。",{"title":175,"searchDepth":687,"depth":687,"links":688},2,[],"markdown","content:6.maps:_cpp:google-cpp-standard.md","content","6.maps/_cpp/google-cpp-standard.md","6.maps/_cpp/google-cpp-standard","md",[696,700],{"_path":697,"title":698,"description":699},"/maps/_cpp/cpp","C++","C++ 是一种静态类型、编译式、通用、多范式编程语言，支持过程化编程、面向对象编程和泛型编程。",{"_path":701,"title":702,"description":703},"/maps/_cpp/king-db","King Database","A simple key-value store database",1771214953501]