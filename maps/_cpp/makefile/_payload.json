/6.maps/_cpp/makefile.md",{"type":183,"children":184,"toc":590},"root",[185,193,199,204,209,253,258,263,268,273,335,340,361,366,371,376,530,542,547,584],{"type":186,"tag":187,"props":188,"children":189},"element","p",{},[190],{"type":191,"value":192},"text","之前看 ElementUI 的时候有了解一点 Makefile 的语法，现在正在看 C++，恰好是更细致学习一下的好机会。",{"type":186,"tag":194,"props":195,"children":197},"h2",{"id":196},"概述",[198],{"type":191,"value":196},{"type":186,"tag":187,"props":200,"children":201},{},[202],{"type":191,"value":203},"Make（GNU Make）是一个自动化工具，它的特色在于有基本逻辑能力，可以跟踪特定文件。这样一来，诸如按需编译这种任务就可以高效完成。",{"type":186,"tag":187,"props":205,"children":206},{},[207],{"type":191,"value":208},"它最主要的语法结构如下代码所示。",{"type":186,"tag":210,"props":211,"children":215},"pre",{"className":212,"code":213,"language":214,"meta":178,"style":178},"language-makefile shiki shiki-themes material-theme-lighter github-light github-dark monokai","target: dependencies\n        commands\n","makefile",[216],{"type":186,"tag":217,"props":218,"children":219},"code",{"__ignoreMap":178},[220,244],{"type":186,"tag":221,"props":222,"children":225},"span",{"class":223,"line":224},"line",1,[226,232,238],{"type":186,"tag":221,"props":227,"children":229},{"style":228},"--shiki-light:#6182B8;--shiki-default:#6F42C1;--shiki-dark:#B392F0;--shiki-sepia:#A6E22E",[230],{"type":191,"value":231},"target",{"type":186,"tag":221,"props":233,"children":235},{"style":234},"--shiki-light:#39ADB5;--shiki-default:#24292E;--shiki-dark:#E1E4E8;--shiki-sepia:#F8F8F2",[236],{"type":191,"value":237},":",{"type":186,"tag":221,"props":239,"children":241},{"style":240},"--shiki-light:#90A4AE;--shiki-default:#24292E;--shiki-dark:#E1E4E8;--shiki-sepia:#F8F8F2",[242],{"type":191,"value":243}," dependencies\n",{"type":186,"tag":221,"props":245,"children":247},{"class":223,"line":246},2,[248],{"type":186,"tag":221,"props":249,"children":250},{"style":240},[251],{"type":191,"value":252},"        commands\n",{"type":186,"tag":187,"props":254,"children":255},{},[256],{"type":191,"value":257},"这意味着：构建目标（target） = 依赖（dependencies） + 执行命令（commands）。",{"type":186,"tag":187,"props":259,"children":260},{},[261],{"type":191,"value":262},"就语法来说，依赖可以不存在，这就表示某个目标意味着直接执行对应的指令。这有点像是定义了一个命令名，或者是一个快捷入口之类的。比如，你可以定义一个 help 目标，以便执行 make help 时，在控制台输出一串帮助文本。",{"type":186,"tag":187,"props":264,"children":265},{},[266],{"type":191,"value":267},"执行时，直接使用 make \u003Ctarget> 就可以了。如果构建目标的修改日期比依赖更新的话，显而易见就不需要再执行对应的指令；如果依赖不存在，那么会自动回溯执行依赖作为目标时的指令，如此一层一层递归下去，直到所有的 target 及 dependencies 的关系被确认。",{"type":186,"tag":187,"props":269,"children":270},{},[271],{"type":191,"value":272},"由于 Make 不会像解析编程语言一样去细致解析 Makefile，所以其语法能力还是稍弱。不会鉴于其隐含的终极目标只是说明各个文件的依赖关系时顺带执行指令，所以也就可以理解为什么 Makefile 中变量只是类似 C 语言中宏一样的字符串替换了。",{"type":186,"tag":210,"props":274,"children":276},{"className":212,"code":275,"language":214,"meta":178,"style":178},"# define my variable\nvar = strings\ntarget: $(var)\n",[277],{"type":186,"tag":217,"props":278,"children":279},{"__ignoreMap":178},[280,289,307],{"type":186,"tag":221,"props":281,"children":282},{"class":223,"line":224},[283],{"type":186,"tag":221,"props":284,"children":286},{"style":285},"--shiki-light:#90A4AE;--shiki-light-font-style:italic;--shiki-default:#6A737D;--shiki-default-font-style:inherit;--shiki-dark:#6A737D;--shiki-dark-font-style:inherit;--shiki-sepia:#88846F;--shiki-sepia-font-style:inherit",[287],{"type":191,"value":288},"# define my variable\n",{"type":186,"tag":221,"props":290,"children":291},{"class":223,"line":246},[292,297,302],{"type":186,"tag":221,"props":293,"children":294},{"style":240},[295],{"type":191,"value":296},"var ",{"type":186,"tag":221,"props":298,"children":299},{"style":234},[300],{"type":191,"value":301},"=",{"type":186,"tag":221,"props":303,"children":304},{"style":240},[305],{"type":191,"value":306}," strings\n",{"type":186,"tag":221,"props":308,"children":310},{"class":223,"line":309},3,[311,315,319,325,330],{"type":186,"tag":221,"props":312,"children":313},{"style":228},[314],{"type":191,"value":231},{"type":186,"tag":221,"props":316,"children":317},{"style":234},[318],{"type":191,"value":237},{"type":186,"tag":221,"props":320,"children":322},{"style":321},"--shiki-light:#39ADB5;--shiki-default:#032F62;--shiki-dark:#9ECBFF;--shiki-sepia:#E6DB74",[323],{"type":191,"value":324}," $(",{"type":186,"tag":221,"props":326,"children":327},{"style":240},[328],{"type":191,"value":329},"var",{"type":186,"tag":221,"props":331,"children":332},{"style":321},[333],{"type":191,"value":334},")\n",{"type":186,"tag":187,"props":336,"children":337},{},[338],{"type":191,"value":339},"Make 和 C/C++ 确实是一对儿。Make 在识别 .o 文件时，能自动把 .c 添加为依赖关系。这功能叫做自动推导（或隐私推导）。除了隐私推导，他还支持类似 C 的 Include，把别的 Makefile 整个包含进来。",{"type":186,"tag":210,"props":341,"children":343},{"className":212,"code":342,"language":214,"meta":178,"style":178},"include foo.make a.mk b.mk\n",[344],{"type":186,"tag":217,"props":345,"children":346},{"__ignoreMap":178},[347],{"type":186,"tag":221,"props":348,"children":349},{"class":223,"line":224},[350,356],{"type":186,"tag":221,"props":351,"children":353},{"style":352},"--shiki-light:#39ADB5;--shiki-light-font-style:italic;--shiki-default:#D73A49;--shiki-default-font-style:inherit;--shiki-dark:#F97583;--shiki-dark-font-style:inherit;--shiki-sepia:#F92672;--shiki-sepia-font-style:inherit",[354],{"type":191,"value":355},"include",{"type":186,"tag":221,"props":357,"children":358},{"style":240},[359],{"type":191,"value":360}," foo.make a.mk b.mk\n",{"type":186,"tag":187,"props":362,"children":363},{},[364],{"type":191,"value":365},"可以发现，Make 和字符串要打非常多交道，所以它支持各种通配符也就不令人意外了。如同 SHELL 中的通配符，* 和 ⁓ 分别代表任意长度字符串和用户主目录。不知道你用过正则没有，通配符就用作匹配及确认，再返回 true 或 false。这时候有人要问了，既然 Makefile 和字符串打交道，通配符返回布尔有啥用啊，它没办法表示列表哇！",{"type":186,"tag":187,"props":367,"children":368},{},[369],{"type":191,"value":370},"这就要说到 Makefile 的关键字了，wildcard，它是扩展关键字，可以把通配符匹配到的所有东西“扩展”为“列表”。列表当然是想象中的列表，其实际产物还是字符串的啦。不过为了更方便操作列表，还有辅助用的其它关键字，比如 patsubst，它是类似正则中的 replaceAll 那种效果。",{"type":186,"tag":187,"props":372,"children":373},{},[374],{"type":191,"value":375},"下面用一个例子来说明吧，把目录下所有 C 文件找出来，替换为 .o 后缀，这样一来，就可以用 gcc 全部编译了。",{"type":186,"tag":210,"props":377,"children":379},{"className":212,"code":378,"language":214,"meta":178,"style":178},"cfiles := $(wildcard *.c)\nofiles := $(patsubst %.c, %.o, %(cfiles))\ncompile: $(ofiles)\n         gcc -o $(ofiles)\n",[380],{"type":186,"tag":217,"props":381,"children":382},{"__ignoreMap":178},[383,422,483,508],{"type":186,"tag":221,"props":384,"children":385},{"class":223,"line":224},[386,391,396,400,406,412,418],{"type":186,"tag":221,"props":387,"children":388},{"style":240},[389],{"type":191,"value":390},"cfiles ",{"type":186,"tag":221,"props":392,"children":393},{"style":234},[394],{"type":191,"value":395},":=",{"type":186,"tag":221,"props":397,"children":398},{"style":321},[399],{"type":191,"value":324},{"type":186,"tag":221,"props":401,"children":403},{"style":402},"--shiki-light:#6182B8;--shiki-default:#005CC5;--shiki-dark:#79B8FF;--shiki-sepia:#66D9EF",[404],{"type":191,"value":405},"wildcard",{"type":186,"tag":221,"props":407,"children":409},{"style":408},"--shiki-light:#E53935;--shiki-default:#005CC5;--shiki-dark:#79B8FF;--shiki-sepia:#AE81FF",[410],{"type":191,"value":411}," *",{"type":186,"tag":221,"props":413,"children":415},{"style":414},"--shiki-light:#91B859;--shiki-default:#032F62;--shiki-dark:#9ECBFF;--shiki-sepia:#E6DB74",[416],{"type":191,"value":417},".c",{"type":186,"tag":221,"props":419,"children":420},{"style":321},[421],{"type":191,"value":334},{"type":186,"tag":221,"props":423,"children":424},{"class":223,"line":246},[425,430,434,438,443,448,452,457,461,466,470,474,479],{"type":186,"tag":221,"props":426,"children":427},{"style":240},[428],{"type":191,"value":429},"ofiles ",{"type":186,"tag":221,"props":431,"children":432},{"style":234},[433],{"type":191,"value":395},{"type":186,"tag":221,"props":435,"children":436},{"style":321},[437],{"type":191,"value":324},{"type":186,"tag":221,"props":439,"children":440},{"style":402},[441],{"type":191,"value":442},"patsubst",{"type":186,"tag":221,"props":444,"children":445},{"style":408},[446],{"type":191,"value":447}," %",{"type":186,"tag":221,"props":449,"children":450},{"style":414},[451],{"type":191,"value":417},{"type":186,"tag":221,"props":453,"children":454},{"style":321},[455],{"type":191,"value":456},",",{"type":186,"tag":221,"props":458,"children":459},{"style":408},[460],{"type":191,"value":447},{"type":186,"tag":221,"props":462,"children":463},{"style":414},[464],{"type":191,"value":465},".o",{"type":186,"tag":221,"props":467,"children":468},{"style":321},[469],{"type":191,"value":456},{"type":186,"tag":221,"props":471,"children":472},{"style":408},[473],{"type":191,"value":447},{"type":186,"tag":221,"props":475,"children":476},{"style":414},[477],{"type":191,"value":478},"(cfiles)",{"type":186,"tag":221,"props":480,"children":481},{"style":321},[482],{"type":191,"value":334},{"type":186,"tag":221,"props":484,"children":485},{"class":223,"line":309},[486,491,495,499,504],{"type":186,"tag":221,"props":487,"children":488},{"style":228},[489],{"type":191,"value":490},"compile",{"type":186,"tag":221,"props":492,"children":493},{"style":234},[494],{"type":191,"value":237},{"type":186,"tag":221,"props":496,"children":497},{"style":321},[498],{"type":191,"value":324},{"type":186,"tag":221,"props":500,"children":501},{"style":240},[502],{"type":191,"value":503},"ofiles",{"type":186,"tag":221,"props":505,"children":506},{"style":321},[507],{"type":191,"value":334},{"type":186,"tag":221,"props":509,"children":511},{"class":223,"line":510},4,[512,517,522,526],{"type":186,"tag":221,"props":513,"children":514},{"style":240},[515],{"type":191,"value":516},"         gcc -o ",{"type":186,"tag":221,"props":518,"children":519},{"style":321},[520],{"type":191,"value":521},"$(",{"type":186,"tag":221,"props":523,"children":524},{"style":240},[525],{"type":191,"value":503},{"type":186,"tag":221,"props":527,"children":528},{"style":321},[529],{"type":191,"value":334},