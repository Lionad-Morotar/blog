,269,331,336,357,362,367,372,526,538,543,580],{"type":182,"tag":183,"props":184,"children":185},"element","p",{},[186],{"type":187,"value":188},"text","之前看 ElementUI 的时候有了解一点 Makefile 的语法，现在正在看 C++，恰好是更细致学习一下的好机会。",{"type":182,"tag":190,"props":191,"children":193},"h2",{"id":192},"概述",[194],{"type":187,"value":192},{"type":182,"tag":183,"props":196,"children":197},{},[198],{"type":187,"value":199},"Make（GNU Make）是一个自动化工具，它的特色在于有基本逻辑能力，可以跟踪特定文件。这样一来，诸如按需编译这种任务就可以高效完成。",{"type":182,"tag":183,"props":201,"children":202},{},[203],{"type":187,"value":204},"它最主要的语法结构如下代码所示。",{"type":182,"tag":206,"props":207,"children":211},"pre",{"className":208,"code":209,"language":210,"meta":175,"style":175},"language-makefile shiki shiki-themes material-theme-lighter github-light github-dark monokai","target: dependencies\n        commands\n","makefile",[212],{"type":182,"tag":213,"props":214,"children":215},"code",{"__ignoreMap":175},[216,240],{"type":182,"tag":217,"props":218,"children":221},"span",{"class":219,"line":220},"line",1,[222,228,234],{"type":182,"tag":217,"props":223,"children":225},{"style":224},"--shiki-light:#6182B8;--shiki-default:#6F42C1;--shiki-dark:#B392F0;--shiki-sepia:#A6E22E",[226],{"type":187,"value":227},"target",{"type":182,"tag":217,"props":229,"children":231},{"style":230},"--shiki-light:#39ADB5;--shiki-default:#24292E;--shiki-dark:#E1E4E8;--shiki-sepia:#F8F8F2",[232],{"type":187,"value":233},":",{"type":182,"tag":217,"props":235,"children":237},{"style":236},"--shiki-light:#90A4AE;--shiki-default:#24292E;--shiki-dark:#E1E4E8;--shiki-sepia:#F8F8F2",[238],{"type":187,"value":239}," dependencies\n",{"type":182,"tag":217,"props":241,"children":243},{"class":219,"line":242},2,[244],{"type":182,"tag":217,"props":245,"children":246},{"style":236},[247],{"type":187,"value":248},"        commands\n",{"type":182,"tag":183,"props":250,"children":251},{},[252],{"type":187,"value":253},"这意味着：构建目标（target） = 依赖（dependencies） + 执行命令（commands）。",{"type":182,"tag":183,"props":255,"children":256},{},[257],{"type":187,"value":258},"就语法来说，依赖可以不存在，这就表示某个目标意味着直接执行对应的指令。这有点像是定义了一个命令名，或者是一个快捷入口之类的。比如，你可以定义一个 help 目标，以便执行 make help 时，在控制台输出一串帮助文本。",{"type":182,"tag":183,"props":260,"children":261},{},[262],{"type":187,"value":263},"执行时，直接使用 make \u003Ctarget> 就可以了。如果构建目标的修改日期比依赖更新的话，显而易见就不需要再执行对应的指令；如果依赖不存在，那么会自动回溯执行依赖作为目标时的指令，如此一层一层递归下去，直到所有的 target 及 dependencies 的关系被确认。",{"type":182,"tag":183,"props":265,"children":266},{},[267],{"type":187,"value":268},"由于 Make 不会像解析编程语言一样去细致解析 Makefile，所以其语法能力还是稍弱。不会鉴于其隐含的终极目标只是说明各个文件的依赖关系时顺带执行指令，所以也就可以理解为什么 Makefile 中变量只是类似 C 语言中宏一样的字符串替换了。",{"type":182,"tag":206,"props":270,"children":272},{"className":208,"code":271,"language":210,"meta":175,"style":175},"# define my variable\nvar = strings\ntarget: $(var)\n",[273],{"type":182,"tag":213,"props":274,"children":275},{"__ignoreMap":175},[276,285,303],{"type":182,"tag":217,"props":277,"children":278},{"class":219,"line":220},[279],{"type":182,"tag":217,"props":280,"children":282},{"style":281},"--shiki-light:#90A4AE;--shiki-light-font-style:italic;--shiki-default:#6A737D;--shiki-default-font-style:inherit;--shiki-dark:#6A737D;--shiki-dark-font-style:inherit;--shiki-sepia:#88846F;--shiki-sepia-font-style:inherit",[283],{"type":187,"value":284},"# define my variable\n",{"type":182,"tag":217,"props":286,"children":287},{"class":219,"line":242},[288,293,298],{"type":182,"tag":217,"props":289,"children":290},{"style":236},[291],{"type":187,"value":292},"var ",{"type":182,"tag":217,"props":294,"children":295},{"style":230},[296],{"type":187,"value":297},"=",{"type":182,"tag":217,"props":299,"children":300},{"style":236},[301],{"type":187,"value":302}," strings\n",{"type":182,"tag":217,"props":304,"children":306},{"class":219,"line":305},3,[307,311,315,321,326],{"type":182,"tag":217,"props":308,"children":309},{"style":224},[310],{"type":187,"value":227},{"type":182,"tag":217,"props":312,"children":313},{"style":230},[314],{"type":187,"value":233},{"type":182,"tag":217,"props":316,"children":318},{"style":317},"--shiki-light:#39ADB5;--shiki-default:#032F62;--shiki-dark:#9ECBFF;--shiki-sepia:#E6DB74",[319],{"type":187,"value":320}," $(",{"type":182,"tag":217,"props":322,"children":323},{"style":236},[324],{"type":187,"value":325},"var",{"type":182,"tag":217,"props":327,"children":328},{"style":317},[329],{"type":187,"value":330},")\n",{"type":182,"tag":183,"props":332,"children":333},{},[334],{"type":187,"value":335},"Make 和 C/C++ 确实是一对儿。Make 在识别 .o 文件时，能自动把 .c 添加为依赖关系。这功能叫做自动推导（或隐私推导）。除了隐私推导，他还支持类似 C 的 Include，把别的 Makefile 整个包含进来。",{"type":182,"tag":206,"props":337,"children":339},{"className":208,"code":338,"language":210,"meta":175,"style":175},"include foo.make a.mk b.mk\n",[340],{"type":182,"tag":213,"props":341,"children":342},{"__ignoreMap":175},[343],{"type":182,"tag":217,"props":344,"children":345},{"class":219,"line":220},[346,352],{"type":182,"tag":217,"props":347,"children":349},{"style":348},"--shiki-light:#39ADB5;--shiki-light-font-style:italic;--shiki-default:#D73A49;--shiki-default-font-style:inherit;--shiki-dark:#F97583;--shiki-dark-font-style:inherit;--shiki-sepia:#F92672;--shiki-sepia-font-style:inherit",[350],{"type":187,"value":351},"include",{"type":182,"tag":217,"props":353,"children":354},{"style":236},[355],{"type":187,"value":356}," foo.make a.mk b.mk\n",{"type":182,"tag":183,"props":358,"children":359},{},[360],{"type":187,"value":361},"可以发现，Make 和字符串要打非常多交道，所以它支持各种通配符也就不令人意外了。如同 SHELL 中的通配符，* 和 ⁓ 分别代表任意长度字符串和用户主目录。不知道你用过正则没有，通配符就用作匹配及确认，再返回 true 或 false。这时候有人要问了，既然 Makefile 和字符串打交道，通配符返回布尔有啥用啊，它没办法表示列表哇！",{"type":182,"tag":183,"props":363,"children":364},{},[365],{"type":187,"value":366},"这就要说到 Makefile 的关键字了，wildcard，它是扩展关键字，可以把通配符匹配到的所有东西“扩展”为“列表”。列表当然是想象中的列表，其实际产物还是字符串的啦。不过为了更方便操作列表，还有辅助用的其它关键字，比如 patsubst，它是类似正则中的 replaceAll 那种效果。",{"type":182,"tag":183,"props":368,"children":369},{},[370],{"type":187,"value":371},"下面用一个例子来说明吧，把目录下所有 C 文件找出来，替换为 .o 后缀，这样一来，就可以用 gcc 全部编译了。",{"type":182,"tag":206,"props":373,"children":375},{"className":208,"code":374,"language":210,"meta":175,"style":175},"cfiles := $(wildcard *.c)\nofiles := $(patsubst %.c, %.o, %(cfiles))\ncompile: $(ofiles)\n         gcc -o $(ofiles)\n",[376],{"type":182,"tag":213,"props":377,"children":378},{"__ignoreMap":175},[379,418,479,504],{"type":182,"tag":217,"props":380,"children":381},{"class":219,"line":220},[382,387,392,396,402,408,414],{"type":182,"tag":217,"props":383,"children":384},{"style":236},[385],{"type":187,"value":386},"cfiles ",{"type":182,"tag":217,"props":388,"children":389},{"style":230},[390],{"type":187,"value":391},":=",{"type":182,"tag":217,"props":393,"children":394},{"style":317},[395],{"type":187,"value":320},{"type":182,"tag":217,"props":397,"children":399},{"style":398},"--shiki-light:#6182B8;--shiki-default:#005CC5;--shiki-dark:#79B8FF;--shiki-sepia:#66D9EF",[400],{"type":187,"value":401},"wildcard",{"type":182,"tag":217,"props":403,"children":405},{"style":404},"--shiki-light:#E53935;--shiki-default:#005CC5;--shiki-dark:#79B8FF;--shiki-sepia:#AE81FF",[406],{"type":187,"value":407}," *",{"type":182,"tag":217,"props":409,"children":411},{"style":410},"--shiki-light:#91B859;--shiki-default:#032F62;--shiki-dark:#9ECBFF;--shiki-sepia:#E6DB74",[412],{"type":187,"value":413},".c",{"type":182,"tag":217,"props":415,"children":416},{"style":317},[417],{"type":187,"value":330},{"type":182,"tag":217,"props":419,"children":420},{"class":219,"line":242},[421,426,430,434,439,444,448,453,457,462,466,470,475],{"type":182,"tag":217,"props":422,"children":423},{"style":236},[424],{"type":187,"value":425},"ofiles ",{"type":182,"tag":217,"props":427,"children":428},{"style":230},[429],{"type":187,"value":391},{"type":182,"tag":217,"props":431,"children":432},{"style":317},[433],{"type":187,"value":320},{"type":182,"tag":217,"props":435,"children":436},{"style":398},[437],{"type":187,"value":438},"patsubst",{"type":182,"tag":217,"props":440,"children":441},{"style":404},[442],{"type"