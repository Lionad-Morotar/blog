"toc":589},"root",[184,192,198,203,208,252,257,262,267,272,334,339,360,365,370,375,529,541,546,583],{"type":185,"tag":186,"props":187,"children":188},"element","p",{},[189],{"type":190,"value":191},"text","之前看 ElementUI 的时候有了解一点 Makefile 的语法，现在正在看 C++，恰好是更细致学习一下的好机会。",{"type":185,"tag":193,"props":194,"children":196},"h2",{"id":195},"概述",[197],{"type":190,"value":195},{"type":185,"tag":186,"props":199,"children":200},{},[201],{"type":190,"value":202},"Make（GNU Make）是一个自动化工具，它的特色在于有基本逻辑能力，可以跟踪特定文件。这样一来，诸如按需编译这种任务就可以高效完成。",{"type":185,"tag":186,"props":204,"children":205},{},[206],{"type":190,"value":207},"它最主要的语法结构如下代码所示。",{"type":185,"tag":209,"props":210,"children":214},"pre",{"className":211,"code":212,"language":213,"meta":178,"style":178},"language-makefile shiki shiki-themes material-theme-lighter github-light github-dark monokai","target: dependencies\n        commands\n","makefile",[215],{"type":185,"tag":216,"props":217,"children":218},"code",{"__ignoreMap":178},[219,243],{"type":185,"tag":220,"props":221,"children":224},"span",{"class":222,"line":223},"line",1,[225,231,237],{"type":185,"tag":220,"props":226,"children":228},{"style":227},"--shiki-light:#6182B8;--shiki-default:#6F42C1;--shiki-dark:#B392F0;--shiki-sepia:#A6E22E",[229],{"type":190,"value":230},"target",{"type":185,"tag":220,"props":232,"children":234},{"style":233},"--shiki-light:#39ADB5;--shiki-default:#24292E;--shiki-dark:#E1E4E8;--shiki-sepia:#F8F8F2",[235],{"type":190,"value":236},":",{"type":185,"tag":220,"props":238,"children":240},{"style":239},"--shiki-light:#90A4AE;--shiki-default:#24292E;--shiki-dark:#E1E4E8;--shiki-sepia:#F8F8F2",[241],{"type":190,"value":242}," dependencies\n",{"type":185,"tag":220,"props":244,"children":246},{"class":222,"line":245},2,[247],{"type":185,"tag":220,"props":248,"children":249},{"style":239},[250],{"type":190,"value":251},"        commands\n",{"type":185,"tag":186,"props":253,"children":254},{},[255],{"type":190,"value":256},"这意味着：构建目标（target） = 依赖（dependencies） + 执行命令（commands）。",{"type":185,"tag":186,"props":258,"children":259},{},[260],{"type":190,"value":261},"就语法来说，依赖可以不存在，这就表示某个目标意味着直接执行对应的指令。这有点像是定义了一个命令名，或者是一个快捷入口之类的。比如，你可以定义一个 help 目标，以便执行 make help 时，在控制台输出一串帮助文本。",{"type":185,"tag":186,"props":263,"children":264},{},[265],{"type":190,"value":266},"执行时，直接使用 make \u003Ctarget> 就可以了。如果构建目标的修改日期比依赖更新的话，显而易见就不需要再执行对应的指令；如果依赖不存在，那么会自动回溯执行依赖作为目标时的指令，如此一层一层递归下去，直到所有的 target 及 dependencies 的关系被确认。",{"type":185,"tag":186,"props":268,"children":269},{},[270],{"type":190,"value":271},"由于 Make 不会像解析编程语言一样去细致解析 Makefile，所以其语法能力还是稍弱。不会鉴于其隐含的终极目标只是说明各个文件的依赖关系时顺带执行指令，所以也就可以理解为什么 Makefile 中变量只是类似 C 语言中宏一样的字符串替换了。",{"type":185,"tag":209,"props":273,"children":275},{"className":211,"code":274,"language":213,"meta":178,"style":178},"# define my variable\nvar = strings\ntarget: $(var)\n",[276],{"type":185,"tag":216,"props":277,"children":278},{"__ignoreMap":178},[279,288,306],{"type":185,"tag":220,"props":280,"children":281},{"class":222,"line":223},[282],{"type":185,"tag":220,"props":283,"children":285},{"style":284},"--shiki-light:#90A4AE;--shiki-light-font-style:italic;--shiki-default:#6A737D;--shiki-default-font-style:inherit;--shiki-dark:#6A737D;--shiki-dark-font-style:inherit;--shiki-sepia:#88846F;--shiki-sepia-font-style:inherit",[286],{"type":190,"value":287},"# define my variable\n",{"type":185,"tag":220,"props":289,"children":290},{"class":222,"line":245},[291,296,301],{"type":185,"tag":220,"props":292,"children":293},{"style":239},[294],{"type":190,"value":295},"var ",{"type":185,"tag":220,"props":297,"children":298},{"style":233},[299],{"type":190,"value":300},"=",{"type":185,"tag":220,"props":302,"children":303},{"style":239},[304],{"type":190,"value":305}," strings\n",{"type":185,"tag":220,"props":307,"children":309},{"class":222,"line":308},3,[310,314,318,324,329],{"type":185,"tag":220,"props":311,"children":312},{"style":227},[313],{"type":190,"value":230},{"type":185,"tag":220,"props":315,"children":316},{"style":233},[317],{"type":190,"value":236},{"type":185,"tag":220,"props":319,"children":321},{"style":320},"--shiki-light:#39ADB5;--shiki-default:#032F62;--shiki-dark:#9ECBFF;--shiki-sepia:#E6DB74",[322],{"type":190,"value":323}," $(",{"type":185,"tag":220,"props":325,"children":326},{"style":239},[327],{"type":190,"value":328},"var",{"type":185,"tag":220,"props":330,"children":331},{"style":320},[332],{"type":190,"value":333},")\n",{"type":185,"tag":186,"props":335,"children":336},{},[337],{"type":190,"value":338},"Make 和 C/C++ 确实是一对儿。Make 在识别 .o 文件时，能自动把 .c 添加为依赖关系。这功能叫做自动推导（或隐私推导）。除了隐私推导，他还支持类似 C 的 Include，把别的 Makefile 整个包含进来。",{"type":185,"tag":209,"props":340,"children":342},{"className":211,"code":341,"language":213,"meta":178,"style":178},"include foo.make a.mk b.mk\n",[343],{"type":185,"tag":216,"props":344,"children":345},{"__ignoreMap":178},[346],{"type":185,"tag":220,"props":347,"children":348},{"class":222,"line":223},[349,355],{"type":185,"tag":220,"props":350,"children":352},{"style":351},"--shiki-light:#39ADB5;--shiki-light-font-style:italic;--shiki-default:#D73A49;--shiki-default-font-style:inherit;--shiki-dark:#F97583;--shiki-dark-font-style:inherit;--shiki-sepia:#F92672;--shiki-sepia-font-style:inherit",[353],{"type":190,"value":354},"include",{"type":185,"tag":220,"props":356,"children":357},{"style":239},[358],{"type":190,"value":359}," foo.make a.mk b.mk\n",{"type":185,"tag":186,"props":361,"children":362},{},[363],{"type":190,"value":364},"可以发现，Make 和字符串要打非常多交道，所以它支持各种通配符也就不令人意外了。如同 SHELL 中的通配符，* 和 ⁓ 分别代表任意长度字符串和用户主目录。不知道你用过正则没有，通配符就用作匹配及确认，再返回 true 或 false。这时候有人要问了，既然 Makefile 和字符串打交道，通配符返回布尔有啥用啊，它没办法表示列表哇！",{"type":185,"tag":186,"props":366,"children":367},{},[368],{"type":190,"value":369},"这就要说到 Makefile 的关键字了，wildcard，它是扩展关键字，可以把通配符匹配到的所有东西“扩展”为“列表”。列表当然是想象中的列表，其实际产物还是字符串的啦。不过为了更方便操作列表，还有辅助用的其它关键字，比如 patsubst，它是类似正则中的 replaceAll 那种效果。",{"type":185,"tag":186,"props":371,"children":372},{},[373],{"type":190,"value":374},"下面用一个例子来说明吧，把目录下所有 C 文件找出来，替换为 .o 后缀，这样一来，就可以用 gcc 全部编译了。",{"type":185,"tag":209,"props":376,"children":378},{"className":211,"code":377,"language":213,"meta":178,"style":178},"cfiles := $(wildcard *.c)\nofiles := $(patsubst %.c, %.o, %(cfiles))\ncompile: $(ofiles)\n         gcc -o $(ofiles)\n",[379],{"type":185,"tag":216,"props":380,"children":381},{"__ignoreMap":178},[382,421,482,507],{"type":185,"tag":220,"props":383,"children":384},{"class":222,"line":223},[385,390,395,399,405,411,417],{"type":185,"tag":220,"props":386,"children":387},{"style":239},[388],{"type":190,"value":389},"cfiles ",{"type":185,"tag":220,"props":391,"children":392},{"style":233},[393],{"type":190,"value":394},":=",{"type":185,"tag":220,"props":396,"children":397},{"style":320},[398],{"type":190,"value":323},{"type":185,"tag":220,"props":400,"children":402},{"style":401},"--shiki-light:#6182B8;--shiki-default:#005CC5;--shiki-dark:#79B8FF;--shiki-sepia:#66D9EF",[403],{"type":190,"value":404},"wildcard",{"type":185,"tag":220,"props":406,"children":408},{"style":407},"--shiki-light:#E53935;--shiki-default:#005CC5;--shiki-dark:#79B8FF;--shiki-sepia:#AE81FF",[409],{"type":190,"value":410}," *",{"type":185,"tag":220,"props":412,"children":414},{"style":413},"--shiki-light:#91B859;--shiki-default:#032F62;--shiki-dark:#9ECBFF;--shiki-sepia:#E6DB74",[415],{"type":190,"value":416},".c",{"type":185,"tag":220,"props":418,"children":419},{"style":320},[420],{"type":190,"value":333},{"type":185,"tag":220,"props":422,"children":423},{"class":222,"line":245},[424,429,433,437,442,447,451,456,460,465,469,473,478],{"type":185,"tag":220,"props":425,"children":426},{"style":239},[427],{"type":190,"value":428},"ofiles ",{"type":185,"tag":220,"props":430,"children":431},{"style":233},[432],{"type":190,"value":394},{"type":185,"tag":220,"props":434,"children":435},{"style":320},[436],{"type":190,"value":323},{"type":185,"tag":220,"props":438,"children":439},{"style":401},[440],{"type":190,"value":441},"patsubst",{"type":185,"tag":220,"