行业研究、分析、报告等","content/6.maps/_industry/analytics.md",{"type":183,"children":184,"toc":1231},"root",[185,204,210,216,228,234,239,244,262,267,278,283,288,298,308,318,329,335,340,345,355,366,372,377,387,397,420,431,436,441,449,467,477,487,497,508,514,526,534,567,577,587,598,604,612,645,653,693,701,724,735,740,745,753,846,856,864,1086,1097,1103,1108,1116,1169,1179,1187,1210,1220],{"type":186,"tag":187,"props":188,"children":189},"element","ul",{},[190],{"type":186,"tag":191,"props":192,"children":193},"li",{},[194],{"type":186,"tag":195,"props":196,"children":200},"a",{"href":197,"rel":198},"https://www.idc.com/resource-center",[199],"nofollow",[201],{"type":202,"value":203},"text","IDC Analyst Insights",{"type":186,"tag":205,"props":206,"children":208},"h4",{"id":207},"美国人对外星人和神秘生物的信仰调查",[209],{"type":202,"value":207},{"type":186,"tag":211,"props":212,"children":213},"p",{},[214],{"type":202,"value":215},"YouGov 对 1,114 名美国成年人的调查显示，相信超自然存在的人数可能超出预期。\n超过半数美国人（56%）相信外星人存在，其中 18% 绝对相信、38% 可能相信。\n相比之下，神秘生物的信仰率较低：大脚怪（28%）、雪人（23%）、尼斯湖水怪（22%）、卓柏卡布拉（16%）。",{"type":186,"tag":211,"props":217,"children":218},{},[219,221],{"type":202,"value":220},"见：",{"type":186,"tag":195,"props":222,"children":225},{"href":223,"rel":224},"https://www.visualcapitalist.com/cp/who-believes-in-aliens-bigfoot-and-the-chupacabra/",[199],[226],{"type":202,"value":227},"Who Believes in Aliens, Bigfoot, and the Chupacabra?",{"type":186,"tag":205,"props":229,"children":231},{"id":230},"美国食品安全food-insecurity州级分布调查",[232],{"type":202,"value":233},"美国食品安全（Food Insecurity）州级分布调查",{"type":186,"tag":211,"props":235,"children":236},{},[237],{"type":202,"value":238},"USDA 对 32,719 户家庭的调查显示（2022-2024 年数据），美国各州食品不安全率存在显著地区差异。\n全国平均为 13.3%，但南部多州远高于此水平。",{"type":186,"tag":211,"props":240,"children":241},{},[242],{"type":202,"value":243},"食品不安全（Food Insecurity）是指由于经济资源有限，无法持续获得足够营养食物的状态。",{"type":186,"tag":211,"props":245,"children":246},{},[247,253,255,260],{"type":186,"tag":248,"props":249,"children":250},"strong",{},[251],{"type":202,"value":252},"最高：",{"type":202,"value":254}," 阿肯色州（19.4%）、肯塔基州（18.8%）、路易斯安那州（17.7%）\n",{"type":186,"tag":248,"props":256,"children":257},{},[258],{"type":202,"value":259},"最低：",{"type":202,"value":261}," 北达科他州（9.0%）、新罕布什尔州（9.1%）、佛蒙特州（9.4%）",{"type":186,"tag":211,"props":263,"children":264},{},[265],{"type":202,"value":266},"值得注意的是，德州和加州虽然比率不同（17.6% vs 12.5%），但因人口庞大，影响的家庭数量均超过千万户。\n食品不安全与低收入、高贫困率、农村人口多、依赖公共援助等结构性经济因素密切相关。",{"type":186,"tag":211,"props":268,"children":269},{},[270,271],{"type":202,"value":220},{"type":186,"tag":195,"props":272,"children":275},{"href":273,"rel":274},"https://www.visualcapitalist.com/food-security-is-highest-state-by-state/",[199],[276],{"type":202,"value":277},"Where Food Insecurity Is Highest, State by State",{"type":186,"tag":205,"props":279,"children":281},{"id":280},"各国麦当劳人均拥有量地图",[282],{"type":202,"value":280},{"type":186,"tag":211,"props":284,"children":285},{},[286],{"type":202,"value":287},"麦当劳在全球近 100 个市场拥有超过 40,000 家门店。\n按人均计算，澳门（56.8 家/百万人）和圣马丁（43.2 家/百万人）领先，美国以 38.6 家/百万人位居大型国家之首。",{"type":186,"tag":211,"props":289,"children":290},{},[291,296],{"type":186,"tag":248,"props":292,"children":293},{},[294],{"type":202,"value":295},"亚洲差异显著：",{"type":202,"value":297}," 尽管中印人口都超过 14 亿，但中国人均拥有量（约 5 家/百万人）是印度（0.5 家）的 10 倍；日本（24.1 家）与巴基斯坦（0.3 家，全球最低）差距更大。",{"type":186,"tag":211,"props":299,"children":300},{},[301,306],{"type":186,"tag":248,"props":302,"children":303},{},[304],{"type":202,"value":305},"市场潜力：",{"type":202,"value":307}," 非洲仅有埃及、摩洛哥、南非三个国家设有麦当劳门店；中东地区卡塔尔（27.6 家）和以色列（23.1 家）密度较高。",{"type":186,"tag":211,"props":309,"children":310},{},[311,316],{"type":186,"tag":248,"props":312,"children":313},{},[314],{"type":202,"value":315},"退出市场：",{"type":202,"value":317}," 2022 年麦当劳全面退出俄罗斯（850 家门店），2024 年出售斯里兰卡全部 12 家门店。",{"type":186,"tag":211,"props":319,"children":320},{},[321,322],{"type":202,"value":220},{"type":186,"tag":195,"props":323,"children":326},{"href":324,"rel":325},"https://www.visualcapitalist.com/mapped-how-many-mcdonalds-each-country-has-per-person/",[199],[327],{"type":202,"value":328},"Mapped: The Countries With the Most McDonald's Per Person",{"type":186,"tag":205,"props":330,"children":332},{"id":331},"北极冰层流失可视化1980-2025",[333],{"type":202,"value":334},"北极冰层流失可视化（1980-2025）",{"type":186,"tag":211,"props":336,"children":337},{},[338],{"type":202,"value":339},"NASA 数据显示，自 1980 年以来北极夏季海冰以每十年 12.2% 的速度缩小。\n1980 年至 2025 年间，北极最小冰范围减少了 110 万平方英里（约 280 万平方公里），相当于阿根廷的国土面积。",{"type":186,"tag":211,"props":341,"children":342},{},[343],{"type":202,"value":344},"按当前趋势，北极可能在 2050 年夏季出现\"几乎无冰\"状态。\n这一变化正在打开新的全球航运路线——北方海路可比苏伊士运河缩短近 20 天航程（约 40%）。",{"type":186,"tag":211,"props":346,"children":347},{},[348,353],{"type":186,"tag":248,"props":349,"children":350},{},[351],{"type":202,"value":352},"地缘政治影响：",{"type":202,"value":354}," 北极估计拥有 4120 亿桶未发现石油和大量稀土资源（格陵兰储量全球第八）。中国、俄罗斯、美国、欧盟均已制定北极国家战略，该地区正成为新的地缘政治竞争焦点。",{"type":186,"tag":211,"props":356,"children":357},{},[358,359],{"type":202,"value":220},{"type":186,"tag":195,"props":360,"children":363},{"href":361,"rel":362},"https://www.visualcapitalist.com/arctic-ice-loss-compared-to-the-size-of-countries/",[199],[364],{"type":202,"value":365},"Visualizing Arctic Ice Loss Since 1980, Compared to Countries",{"type":186,"tag":205,"props":367,"children":369},{"id":368},"海洋未来探索蓝色经济投资机遇",[370],{"type":202,"value":371},"海洋未来探索：蓝色经济投资机遇",{"type":186,"tag":211,"props":373,"children":374},{},[375],{"type":202,"value":376},"与迪拜未来论坛合作的研究显示，海洋正成为新的投资前沿。\n尽管海洋覆盖地球 70% 以上，但仅 27% 的海底被现代标准测绘，剩余 73% 的未测绘面积比所有陆地面积还大。",{"type":186,"tag":211,"props":378,"children":379},{},[380,385],{"type":186,"tag":248,"props":381,"children":382},{},[383],{"type":202,"value":384},"生物多样性潜力巨大：",{"type":202,"value":386}," 估计 91% 的海洋生物尚未被发现，目前已知约 34.7 万种。每年科学家都能发现和编目数千个新物种，这些发现可能为医药和技术突破提供线索。",{"type":186,"tag":211,"props":388,"children":389},{},[390,395],{"type":186,"tag":248,"props":391,"children":392},{},[393],{"type":202,"value":394},"蓝色经济投资：",{"type":202,"value":396