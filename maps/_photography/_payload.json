ype":182,"tag":183,"props":184,"children":186},"element","h4",{"id":185},"怎么衡量一张照片的好坏",[187],{"type":188,"value":189},"text","怎么衡量一张照片的好坏？",{"type":182,"tag":191,"props":192,"children":193},"p",{},[194],{"type":188,"value":195},"摄影是摄影师想法及内容的表达，所以照片好坏关乎其主题是否明确，内容是否有趣，及想法的传达是否到位。",{"type":182,"tag":191,"props":197,"children":198},{},[199],{"type":188,"value":200},"技术是围绕想法服务的，所以摄影需要有摄影师的思考构思，而不单纯是一种记录。",{"type":182,"tag":183,"props":202,"children":204},{"id":203},"光圈和景深的关系",[205],{"type":188,"value":206},"光圈和景深的关系？",{"type":182,"tag":191,"props":208,"children":209},{},[210],{"type":188,"value":211},"光圈大，景深小，虚化强",{"type":182,"tag":183,"props":213,"children":215},{"id":214},"光圈快门iso-cheat-sheet",[216],{"type":188,"value":217},"光圈、快门、ISO Cheat Sheet",{"type":182,"tag":191,"props":219,"children":220},{},[221],{"type":182,"tag":222,"props":223,"children":226},"img",{"alt":224,"src":225},"光圈","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202411090118055.png",[],{"type":182,"tag":191,"props":228,"children":229},{},[230],{"type":182,"tag":222,"props":231,"children":234},{"alt":232,"src":233},"快门","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202411090127871.png",[],{"type":182,"tag":191,"props":236,"children":237},{},[238],{"type":182,"tag":222,"props":239,"children":242},{"alt":240,"src":241},"ISO","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202411090128878.png",[],{"type":182,"tag":183,"props":244,"children":246},{"id":245},"不同自动快门模式适合什么场景",[247],{"type":188,"value":248},"不同自动快门模式适合什么场景？",{"type":182,"tag":191,"props":250,"children":251},{},[252],{"type":188,"value":253},"一般有 M 档，Av 档，Tv 档。Av 档光圈优先适合人像、风景、微距等固定光圈以达特定虚化效果的场景。Tv 档快门优先适合运动、动态场景，如体育摄影、街拍等。M 档手动模式适合特殊场景，如夜景、星空、棚内摄影等。",{"title":175,"searchDepth":255,"depth":255,"links":256},2,[],"markdown","content:6.maps:_photography:0.index.md","content","6.maps/_photography/0.index.md","6.maps/_photography/0.index","md",[264,268],{"_path":265,"title":266,"description":267},"/map