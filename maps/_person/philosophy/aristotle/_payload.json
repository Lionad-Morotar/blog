lse,true,"","亚里士多德（BC384~BC322）","古希腊哲学家，亚历山大大帝的老师，西方哲学的集大成者。","content/6.maps/_person/aristotle.md",{"type":183,"children":184,"toc":271},"root",[185,194,200,215,228,234,247,254],{"type":186,"tag":187,"props":188,"children":190},"element","h4",{"id":189},"亚里士多德的生平",[191],{"type":192,"value":193},"text","亚里士多德的生平?",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198],{"type":192,"value":199},"亚里士多德是柏拉图的学生，亚历山大的老师。他是一位百科全书式的科学家，堪称希腊哲学的集大成者。其写作涉及伦理学、形而上学、心理学、经济学、神学、政治学、修辞学、自然科学、教育学、诗歌、风俗，以及雅典法律。他的著作构建了西方哲学的第一个广泛系统，包含道德、美学、逻辑和科学、政治和玄学。",{"type":186,"tag":201,"props":202,"children":203},"blockquote",{},[204],{"type":186,"tag":195,"props":205,"children":206},{},[207,209],{"type":192,"value":208},"古希腊哲学家中最博学的人物。\n",{"type":186,"tag":210,"props":211,"children":212},"name",{},[213],{"type":192,"value":214},"马克思",{"type":186,"tag":201,"props":216,"children":217},{},[218],{"type":186,"tag":195,"props":219,"children":220},{},[221,223],{"type":192,"value":222},"古代的黑格尔。\n",{"type":186,"tag":210,"props":224,"children":225},{},[226],{"type":192,"value":227},"恩格斯",{"type":186,"tag":187,"props":229,"children":231},{"id":230},"亚里士多德关于精神大脑和心的认识",[232],{"type":192,"value":233},"亚里士多德关于精神、大脑和心的认识？",{"type":186,"tag":195,"props":235,"children":236},{},[237,239,245],{"type":192,"value":238},"与希波克拉底相反，亚里士多德认为",{"type":186,"tag":240,"props":241,"children":242},"u",{},[243],{"type":192,"value":244},"神智在心",{"type":192,"value":246},"。亚里士多德（及多位大思想家）认为，大脑是不太重要的器官，灵魂位于心脏。",{"type":186,"tag":248,"props":249,"children":251},"h2",{"id":250},"references",[252],{"type":192,"value":253},"References",{"type":186,"tag":255,"props":256,"children":257},"ul",{},[258],{"type":186,"tag":259,"props":260,"children":261},"li",{},[262],{"type":186,"tag":263,"props":264,"children":268},"a",{"href":265,"rel":266},"https://baike.baidu.com/item/%E4%BA%9A%E9%87%8C%E5%A3%AB%E5%A4%9A%E5%BE%B7/26769",[267],"nofollow",[269],{"type":192,"value":270},"亚里士多德",{"title":178,"searchDepth":272,"depth":272,"links":273},