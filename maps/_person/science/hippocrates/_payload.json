"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"original_path":181,"body":182,"_type":257,"_id":258,"_source":259,"_file":260,"_stem":261,"_extension":262},"/maps/_person/science/hippocrates","science",false,true,"","希波克拉底（BC460~BC370）","古希腊伯利克时期御用医师，西方医学之父。","content/6.maps/_person/hippocrates.md",{"type":183,"children":184,"toc":254},"root",[185,194,208,214,219,225,230,235],{"type":186,"tag":187,"props":188,"children":190},"element","h4",{"id":189},"希波克拉底的四元素说是什么",[191],{"type":192,"value":193},"text","希波克拉底的四元素说是什么？",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198,200,206],{"type":192,"value":199},"希波克拉底认为，人类正如宇宙中的其他部分一样，是由四种元素——",{"type":186,"tag":201,"props":202,"children":203},"u",{},[204],{"type":192,"value":205},"土、气、水、火",{"type":192,"value":207},"组成的，这四种元素和人体中的四种液体（黑胆汁、黄胆汁、血液和粘液）相对应。这四种液体处于平衡时，人就是健康的；失衡时，人就会得病。尽管在现在看来这种医学理论是错误的，他其影响几乎一直延续到 19 世纪，时至今日我们对人的气质的描述还在沿用他提出的部分名词。",{"type":186,"tag":187,"props":209,"children":211},{"id":210},"希波克拉底如何看待大脑",[212],{"type":192,"value":213},"希波克拉底如何看待大脑？",{"type":186,"tag":195,"props":215,"children":216},{},[217],{"type":192,"value":218},"古希腊医学之父希波克拉底是第一位正式描述脑的作用的人，他在专门讨论脑部疾病的《论神奇的疾病》一文中写道：\"人们应该认识到所有的快乐、愉悦、欢笑、运动，还有悲伤、忧愁、沮丧和哀伤都来自大脑，而不是来自其它的东西。脑一起某种特殊的方式使我们有了智慧和知识，能看会听，并且懂得什么是邪恶，什么是公平......也是因为有了脑，我们才会发疯和精神错乱，害怕和恐惧才会折磨我们。当脑不健康的时候，我们就会因此受累，根据上面所讲的一切，我认为脑对人有最大的影响。\"",{"type":186,"tag":187,"props":220,"children":222},{"id":221},"希波克拉底誓言是什么",[223],{"type":192,"value":224},"希波克拉底誓言是什么？",{"type":186,"tag":195,"props":226,"children":227},{},[228],{"type":192,"value":229},"医神阿波罗，阿斯克勒庇俄斯及天地诸神为证，鄙人敬谨宣誓，愿以自身能判断力所及，遵守此约。凡授我艺者敬之如父母，作为终身同世伴侣，彼有急需我接济之。视彼儿女，犹我弟兄，如欲受业，当免费并无条件传授之。凡我所知无论口授书传俱传之吾子，吾师之子及发誓遵守此约之生徒，此外不传与他人。",{"type":186,"tag":195,"props":231,"children":232},{},[233],{"type":192,"value":234},"我愿尽余之能力与判断力所及，遵守为病家谋利益之信条，并检束一切堕落及害人行为，我不得将危害药品给与他人，并不作此项之指导，虽然人请求亦必不与之。尤不为妇人施堕胎手术。我愿以此纯洁与神圣之精神终身执行我职务。凡患结石者，我不施手术，此则有待于专家为之。",{"type":186,"tag":195,"props":236,"children":237},{},[238,240,252],{"type":192,"value":239},"无论至于何处，遇男或女，贵人及奴婢，我之唯一目的，为病家谋幸福，并检点吾身，不做各种害人及恶劣行为，尤不做诱奸之事。凡我所见所闻，无论有无业务关系，我认为应守秘密者，我愿保守秘密。倘使我严守上述誓言时，请求神祇让我生命与医术能得无上光荣，我苟违誓，天地鬼神共",{"type":186,"tag":241,"props":242,"children":243},"ruby",{},[244,246],{"type":192,"value":245},"殛",{"type":186,"tag":247,"props":248,"children":249},"rt",{},[250],{"type":192,"value":251},"jí",{"type":192,"value":253},"之。",{"title":178,"searchDepth":255,"depth":255,"links":256},2,[],"markdown","content:6.maps:_person:science:hippocrates.md","content","6.maps/_person/science/hippocrates.md","6.maps/_person/science/hippocrates","md",[264,268],{"_path":265,"title":266,"description":267},"/maps/_person/science/henry-molaison","亨利·莫莱森","医学史上最著名的健忘症患者",{"_path":269,"title":270,"description":271},"/maps/_person/science/john-michell","约翰·米歇尔","有史以来最伟大的无名科学家之一，是已知的第一个提出黑洞存在的人，也是第一个提出地震以波传播的人。",1772185500750]