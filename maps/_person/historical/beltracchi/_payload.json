,false,true,"","贝特拉基","贝特拉基是一个德国画家，曾以伪造画作闻名。","content/6.maps/_person/beltracchi.md",{"type":183,"children":184,"toc":284},"root",[185,194,200,205,226,239],{"type":186,"tag":187,"props":188,"children":190},"element","h4",{"id":189},"现代假画之王贝特拉基的故事",[191],{"type":192,"value":193},"text","现代假画之王贝特拉基的故事？",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198],{"type":192,"value":199},"贝特拉基 1951 年出生于德国人，原名叫费舍尔，但后来二婚后改妻姓才叫 Beltracchi。Beltracchi 是个意大利的姓氏，所以应该翻译为“贝特拉基”而不是英译“贝特莱奇”。",{"type":186,"tag":195,"props":201,"children":202},{},[203],{"type":192,"value":204},"青年时的贝特拉基有相当高的绘画天赋，曾在 1978 年在慕尼黑一个相当有名的绘画展展出过，并以一万五千马克的价格售出过一副作品。曾有画廊邀约他为签约画家，但他不想丢下“性、毒品与摇滚”的自由自在的嬉皮士生活拒绝了该邀请。除了画自己的作品，他还做起了假画生意，主要思路是仿制一些史料模糊的中档作者的绘画。一开始他完全单枪匹马做造假，知道后来碰上了画商舒尔特·克林豪斯和海伦，于是三人分工，分别画假画、销售以及编造故事。据不完全统计，直到 2010 年东窗事发，贝特拉基在 30 余年画假画的生涯中，共假冒在绘画史上知名度不一的 50 余位画家的 300 余幅绘画作品，至少获得了 3500 万欧元的不义之财。",{"type":186,"tag":195,"props":206,"children":207},{},[208,210,224],{"type":192,"value":209},"贝特拉基被捕后，在监狱度过了六年时光。从监狱获释后，贝特拉基和他的妻子继续以艺术家的身份工作，出版了自传和电影（《伪造的艺术》，2014年），并从画作中赚了数百万美元收入",{"type":186,"tag":211,"props":212,"children":213},"sup",{},[214],{"type":186,"tag":215,"props":216,"children":221},"a",{"href":217,"ariaDescribedBy":218,"dataFootnoteRef":178,"id":220},"#user-content-fn-income",[219],"footnote-label","user-content-fnref-income",[222],{"type":192,"value":223},"1",{"type":192,"value":225},"。",{"type":186,"tag":195,"props":227,"children":228},{},[229,231],{"type":192,"value":230},"见：",{"type":186,"tag":215,"props":232,"children":236},{"href":233,"rel":234},"https://www.zhihu.com/xen/market/pdf-view/paid_magazine/1395369078886834176",[235],"nofollow",[237],{"type":192,"value":238},"《现代假画之王贝特拉基》",{"type":186,"tag":240,"props":241,"children":244},"section",{"className":242,"dataFootnotes":178},[243],"footnotes",[245,253],{"type":186,"tag":246,"props":247,"children":250},"h2",{"className":248,"id":219},[249],"sr-only",[251],{"type":192,"value":252},"Footnotes",{"type":186,"tag":254,"props":255,"children":256},"ol",{},[257],{"type":186,"tag":258,"props":259,"children":261},"li",{"id":260},"user-content-fn-income",[262,273,275],{"type":186,"tag":215,"props":263,"children":266},{"href":264,"rel":265},"https://www.we-wealth.com/news/pleasure-assets/opere-darte/beltracchi-due-falsari-bonny-clyde-xxi-secolo",[235],[267],{"type":186,"tag":268,"props":269,"children":270},"i",{},[271],{"type":192,"value":272},"Beltracchi, i due falsari d'arte alla 'Bonnie e Clyde' del XXI secolo",{"type":192,"value":274}," ",{"type":186,"tag":215,"props":276,"children":281},{"href":277,"ariaLabel":278,"className":279,"dataFootnoteBackref":178},"#user-content-fnref-income","Back to reference 1",[280],"data-footnote-backref",[282],{"type":192,"value":283},"↩",{"title":178,"searchDepth":285,"depth":285,"links":286},2,[287],{"id":219,"depth":285,"text":252},"markdown","content:6.maps:_person:historical:beltracchi.md","content","6.maps/_person/historical/beltracchi.md","6.maps/_person/historical/beltracchi","md",[295,299],{"_path":296,"title":297,"description":298},"/maps/_person/historical/armstrong","阿姆斯特朗","阿姆斯特朗关于工程的演讲",{"_path":300,"title":301,"description":302},"/maps/_person/historical/historical","历史人物","各领域具有历史重要意义的人物",1772504955550]