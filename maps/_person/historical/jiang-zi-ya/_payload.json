al",false,true,"","姜子牙","周朝的开国功臣，周武王谋士，太公望，武圣","content/6.maps/_person/jiang-zi-ya.md",{"type":183,"children":184,"toc":262},"root",[185,194,200,214,219,231,237,242],{"type":186,"tag":187,"props":188,"children":190},"element","h4",{"id":189},"枯骨死草何知凶吉",[191],{"type":192,"value":193},"text","枯骨死草，何知凶吉？",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198],{"type":192,"value":199},"居二年，纣杀王子比干，囚箕子。武王将伐纣，卜，龟兆不吉，风雨暴至。群公尽惧，唯太公彊之劝武王，武王於是遂行。",{"type":186,"tag":195,"props":201,"children":202},{},[203,205],{"type":192,"value":204},"见：",{"type":186,"tag":206,"props":207,"children":211},"a",{"href":208,"rel":209},"https://so.gushiwen.cn/guwen/bookv_46653FD803893E4F0D6BAC27C4B75E01.aspx",[210],"nofollow",[212],{"type":192,"value":213},"《史记·三十世家·齐太公世家》",{"type":186,"tag":195,"props":215,"children":216},{},[217],{"type":192,"value":218},"周武王伐纣，师至汜水牛头山，风甚雷疾，鼓旗毁折，王之骖乘惶震而死。太公曰：“用兵者，顺天之道未必吉，逆之不必凶，若失人事，则三军败亡。且天道鬼神，视之不见，听之不闻，智将不法，而愚将拘之。若乃好贤而能用，举事而得时，此则不看时日而事利，不假卜筮而事吉，不待祷祀而福从。”遂命驱之前进。周公曰：“今时逆太岁，龟灼告凶，卜筮不吉，星变为灾，请还师。”太公怒曰：“今纣刳比干，囚箕子，以飞廉为政，伐之有何不可？枯草朽骨，安可知乎！”乃焚龟折蓍，援枹而鼓，率众先涉河，武王从之，遂灭纣。",{"type":186,"tag":195,"props":220,"children":221},{},[222,224],{"type":192,"value":223},"见： ",{"type":186,"tag":206,"props":225,"children":228},{"href":226,"rel":227},"https://so.gushiwen.cn/guwen/bookv_46653FD803893E4F4829913B35E634BF.aspx",[210],[229],{"type":192,"value":230},"《通典》推人事破灾异",{"type":186,"tag":187,"props":232,"children":234},{"id":233},"关羽和姜子牙的武圣之争",[235],{"type":192,"value":236},"关羽和姜子牙的武圣之争？",{"type":186,"tag":195,"props":238,"children":239},{},[240],{"type":192,"value":241},"在相当长的一段时间里，姜子牙的历史地位都很高，作为官方祭祀的“武神”。其地位直到被朱元璋贬黜。《孟子》在百家诸子中对武王评价颇高，而朱元璋对《孟子》的憎恨恨屋及乌地迁怒到周武王与姜子牙身上，以及《三国演义》在民间的流行，后改立关羽为武神，关羽庙基本取代了太公庙。",{"type":186,"tag":195,"props":243,"children":244},{},[245,246,253,255],{"type":192,"value":204},{"type":186,"tag":206,"props":247,"children":250},{"href":248,"rel":249},"https://xueshu.baidu.com/usercenter/paper/show?paperid=1c6e0eu04s2b0c50cp0v0rf0gs087476",[210],[251],{"type":192,"value":252},"《历史·政治·文学——姜子牙形象的演变与文化内涵》",{"type":192,"value":254},"，",{"type":186,"tag":206,"props":256,"children":259},{"href":257,"rel":258},"https://xueshu.baidu.com/usercenter/paper/show?paperid=11180jr09y6b0x40v06e0c70vw699859",[210],[260],{"type":192,"value":261},"《姜太公形象演变探析》",{"title":178,"searchDepth":263,"depth":263,"links":264},2,[],"markdown","content:6.maps:_person:historical:jiang-zi-ya.md","content","6.maps/_person/historical/jiang-zi-ya.md","6.maps/_person/historical/jiang-zi-ya","md",[272,276],{"_path":273,"title":274,"description":275},"/maps/_person/historical/historical","历史人物","各领域具有历史重要意义的人物",{"_path":277,"title":278,"description":279},"/maps/_person/historical/jim-jones","吉姆·琼斯","人民圣殿教创始人",1772504955719]