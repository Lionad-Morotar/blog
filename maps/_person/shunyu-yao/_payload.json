方向核心探索者，现任腾讯首席 AI 科学家",{"type":182,"children":183,"toc":321},"root",[184,193,199,205,214,219,227,232,240,245,253,258,264,300],{"type":185,"tag":186,"props":187,"children":189},"element","h4",{"id":188},"简介",[190],{"type":191,"value":192},"text","简介？",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"姚顺雨（1998 年出生），本科毕业于清华大学交叉信息研究院\"姚班\"，普林斯顿大学计算机科学博士，师从 NLP 领域知名学者 Karthik Narasimhan。博士期间在 Google Brain 和 OpenAI 实习，2023 年加入 OpenAI 任研究员，2025 年入选《麻省理工科技评论》\"35 岁以下科技创新 35 人\"中国区名单。2025 年底加入腾讯，任 CEO/总裁办公室首席 AI 科学家，兼任 AI Infra 部及大语言模型部负责人。",{"type":185,"tag":186,"props":200,"children":202},{"id":201},"主要贡献观点",[203],{"type":191,"value":204},"主要贡献/观点？",{"type":185,"tag":194,"props":206,"children":207},{},[208],{"type":185,"tag":209,"props":210,"children":211},"strong",{},[212],{"type":191,"value":213},"AI 的\"下半场\"理论",{"type":185,"tag":194,"props":215,"children":216},{},[217],{"type":191,"value":218},"提出 AI 发展已进入\"中场休息\"阶段，核心特征是从\"训练大于评估\"转向\"评估大于训练\"。上半场通过算法创新（反向传播、Transformer、GPT-3 等）不断刷分；下半场需要重新定义问题，构建能衡量真实世界效用的评估体系。",{"type":185,"tag":194,"props":220,"children":221},{},[222],{"type":185,"tag":209,"props":223,"children":224},{},[225],{"type":191,"value":226},"Language Agent 的倡导者",{"type":185,"tag":194,"props":228,"children":229},{},[230],{"type":191,"value":231},"指出 Agent 的本质是通过语言实现推理，通过推理实现泛化，是通往 AGI 的必经形态。提出 ReAct（Reasoning + Acting）框架，将思考作为行动空间的一部分，显著提升了 Agent 的泛化能力。",{"type":185,"tag":194,"props":233,"children":234},{},[235],{"type":185,"tag":209,"props":236,"children":237},{},[238],{"type":191,"value":239},"效用问题（Utility Problem）",{"type":185,"tag":194,"props":241,"children":242},{},[243],{"type":191,"value":244},"指出当前 AI 的核心矛盾：模型在 MMLU、Codeforces 等基准上达到博士水平，却未能显著改变 GDP。原因在于评估设定追求\"难题\"而非\"实用\"，学术界缺乏评估\"学习能力\"而非\"现有能力\"的基准。",{"type":185,"tag":194,"props":246,"children":247},{},[248],{"type":185,"tag":209,"props":249,"children":250},{},[251],{"type":191,"value":252},"Agent 记忆的重要性",{"type":185,"tag":194,"props":254,"children":255},{},[256],{"type":191,"value":257},"强调 AI 系统的记忆层次缺陷：仅有上下文（短期记忆）和模型权重（长期记忆），缺乏人类式的灵活记忆巩固机制。认为这是限制 Agent 持续学习和个性化的关键瓶颈。",{"type":185,"tag":186,"props":259,"children":261},{"id":260},"代表作品",[262],{"type":191,"value":263},"代表作品？",{"type":185,"tag":265,"props":266,"children":267},"ul",{},[268,274,288],{"type":185,"tag":269,"props":270,"children":271},"li",{},[272],{"type":191,"value":273},"《The Second Half》(2025) - 阐述 AI 下半场理论的代表性博文",{"type":185,"tag":269,"props":275,"children":276},{},[277,286],{"type":185,"tag":278,"props":279,"children":283},"a",{"href":280,"rel":281},"https://arxiv.org/abs/2210.03629",[282],"nofollow",[284],{"type":191,"value":285},"ReAct: Synergizing Reasoning and Acting in Language Models",{"type":191,"value":287}," (2022) - 将推理与行动结合的 Agent 框架",{"type":185,"tag":269,"props":289,"children":290},{},[291,298],{"type":185,"tag":278,"props":292,"children":295},{"href":293,"rel":294},"https://arxiv.org/abs/2205.11916",[282],[296],{"type":191,"value":297},"Language Models are Few-Shot Reasoners",{"type":191,"value":299}," (2022) - 上下文学习研究",{"type":185,"tag":194,"props":301,"children":302},{},[303,305,312,314],{"type":191,"value":304},"见：",{"type":185,"tag":278,"props":306,"children":309},{"href":307,"rel":308},"https://ysymyth.github.io/",[282],[310],{"type":191,"value":311},"个人主页",{"type":191,"value":313},"、",{"type":185,"tag":278,"props":315,"children":318},{"href":316,"rel":317},"https://ysymyth.github.io/The-Second-Half/",[282],[319],{"type":191,"value":320},"The Second Half 原文",{"title":178,"searchDepth":322,"depth":322,"links":323},2,[],"markdown","content:6.maps:_person:shunyu-yao.md","content","6.maps/_person/shunyu-yao.md","6.maps/_person/shunyu-yao","md",[331,335],{"_path":332,"title":333,"description":334},"/maps/_person/richard-stallman","Richard Stallman","计算机程序员、软件自由运动的创始人",{"_path":336,"title":337,"description":338},"/maps/_photography","摄影","技术传达情感，摄影记录生活。",1771521512921]