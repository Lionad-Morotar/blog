"type":182,"tag":183,"props":184,"children":185},"element","p",{},[186],{"type":187,"value":188},"text","埃拉托色尼收到了良好的教育，成了一位博学的哲学家、天文学家和地理学家。他受埃及国王邀请，任皇家教师，并被任命为亚历山大里亚图书馆研究员。于 BC234 接任图书馆馆长直至离世。著有《地球大小的修正》和《地理学概论》，但已遗失。",{"type":182,"tag":190,"props":191,"children":193},"h4",{"id":192},"两千年前的埃拉托色尼如何求解地球周长",[194],{"type":187,"value":195},"两千年前的埃拉托色尼如何求解地球周长？",{"type":182,"tag":183,"props":197,"children":198},{},[199],{"type":187,"value":200},"塞伊尼是一个著名的景点，位于被回归线上，其中有一口井会在太阳的照射下不产生阴影。埃拉托色尼选取了和塞伊尼同经线的亚历山大的一座尖塔，并根据同一天正午的尖塔高度及其阴影长度，计算出了太阳在亚历山大的高度角。再加上他打听到的塞伊尼与亚历山大的直线距离，算出了地球的周长，约为四万公里，很接近现代测量结果。",{"type":182,"tag":183,"props":202,"children":203},{},[204],{"type":182,"tag":205,"props":206,"children":209},"img",{"alt":207,"src":208},"求解示意","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220117233422.png",[],{"type":182,"tag":211,"props":212,"children":214},"h2",{"id":213},"references",[215],{"type":187,"value":216},"References",{"type":182,"tag":218,"props":219,"children":220},"ul",{},[221,234],{"type":182,"tag":222,"props":223,"children":224},"li",{},[225],{"type":182,"tag":226,"props":227,"children":231},"a",{"href":228,"rel":229},"https://www.bilibili.com/video/BV1Ma4y1e7rx",[230],"nofollow",[232],{"type":187,"value":233},"古埃及人是怎么早在2200多年前就测量出地球周长的？",{"type":182,"tag":222,"props":235,"children":236},{},[237],{"type":182,"tag":226,"props":238,"children":241},{"href":239,"rel":240},"https://www.bilibili.com/video/BV1GJ41197eB",[230],[242],{"type":187,"value":243},"伪史批判：造假的古希腊天文和地理学",{"title":175,"searchDepth":245,"depth":245,"links":246},2,[247],{"id":213,"depth":245,"text":216},"markdown","content:6.maps:_person:eratosthenes.md","content","6.maps/_person/eratosthenes.md","6.maps/_person/eratosthenes","md",[255,259],{"_path":256,"title":257,"description":258},"/maps/_person/claudius-ptolemaeus","克罗狄斯·托勒密","地心说",{"_path":260,"title":261,"description":262},"/maps/_person/henry-molaison","亨利·莫莱森","医学史上最著名的健忘症患者",1771071685681]