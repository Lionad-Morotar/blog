注人工智能发展",{"type":182,"children":183,"toc":352},"root",[184,193,199,205,214,234,242,260,268,281,287,305,311,329],{"type":185,"tag":186,"props":187,"children":189},"element","h4",{"id":188},"简介",[190],{"type":191,"value":192},"text","简介？",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"Gary Marcus 是认知科学家、AI 研究者、企业家和作家。他是纽约大学心理学与神经科学荣誉教授，曾创立机器学习公司 Geometric Intelligence（后被 Uber 收购），并创立了机器人公司 Robust.AI。他以对当前 AI 技术路径的批判性观点而闻名，主张结合深度学习与符号推理的混合方法。",{"type":185,"tag":186,"props":200,"children":202},{"id":201},"主要观点",[203],{"type":191,"value":204},"主要观点？",{"type":185,"tag":194,"props":206,"children":207},{},[208],{"type":185,"tag":209,"props":210,"children":211},"strong",{},[212],{"type":191,"value":213},"对深度学习局限性的批判",{"type":185,"tag":215,"props":216,"children":217},"ul",{},[218,224,229],{"type":185,"tag":219,"props":220,"children":221},"li",{},[222],{"type":191,"value":223},"认为当前大语言模型本质上是「高级自动补全」，缺乏真正的理解和推理能力",{"type":185,"tag":219,"props":225,"children":226},{},[227],{"type":191,"value":228},"指出深度学习在数据效率、泛化能力和可解释性方面存在根本性缺陷",{"type":185,"tag":219,"props":230,"children":231},{},[232],{"type":191,"value":233},"主张「深度学习撞墙了」(Deep Learning is Hitting a Wall)",{"type":185,"tag":194,"props":235,"children":236},{},[237],{"type":185,"tag":209,"props":238,"children":239},{},[240],{"type":191,"value":241},"对 AI 安全的关注",{"type":185,"tag":215,"props":243,"children":244},{},[245,250,255],{"type":185,"tag":219,"props":246,"children":247},{},[248],{"type":191,"value":249},"关注 AI 竞赛中的安全风险，特别是当商业利益凌驾于安全考量之上时",{"type":185,"tag":219,"props":251,"children":252},{},[253],{"type":191,"value":254},"提出 p(doom) 评估会因企业鲁莽行为而上升",{"type":185,"tag":219,"props":256,"children":257},{},[258],{"type":191,"value":259},"批评 OpenAI、xAI 等公司在安全措施上的倒退",{"type":185,"tag":194,"props":261,"children":262},{},[263],{"type":185,"tag":209,"props":264,"children":265},{},[266],{"type":191,"value":267},"混合 AI 架构倡导者",{"type":185,"tag":215,"props":269,"children":270},{},[271,276],{"type":185,"tag":219,"props":272,"children":273},{},[274],{"type":191,"value":275},"主张将神经网络的感知能力与符号系统的推理能力结合",{"type":185,"tag":219,"props":277,"children":278},{},[279],{"type":191,"value":280},"认为通往 AGI 需要更结构化的知识表示和因果推理能力",{"type":185,"tag":186,"props":282,"children":284},{"id":283},"代表作品",[285],{"type":191,"value":286},"代表作品？",{"type":185,"tag":215,"props":288,"children":289},{},[290,295,300],{"type":185,"tag":219,"props":291,"children":292},{},[293],{"type":191,"value":294},"《重启 AI》（Rebooting AI，2019）- 与 Ernest Davis 合著，探讨构建可信 AI 的路径",{"type":185,"tag":219,"props":296,"children":297},{},[298],{"type":191,"value":299},"《代数思维》（The Algebraic Mind，2001）- 关于认知科学的早期著作",{"type":185,"tag":219,"props":301,"children":302},{},[303],{"type":191,"value":304},"《未来的面孔》（Guitar Zero，2012）- 关于音乐学习的科普作品",{"type":185,"tag":186,"props":306,"children":308},{"id":307},"媒体活动",[309],{"type":191,"value":310},"媒体活动？",{"type":185,"tag":215,"props":312,"children":313},{},[314,319,324],{"type":185,"tag":219,"props":315,"children":316},{},[317],{"type":191,"value":318},"活跃于 Substack（Marcus on AI）和 X/Twitter，定期评论 AI 行业动态",{"type":185,"tag":219,"props":320,"children":321},{},[322],{"type":191,"value":323},"曾与 Yann LeCun 等深度学习先驱公开辩论 AI 发展路径",{"type":185,"tag":219,"props":325,"children":326},{},[327],{"type":191,"value":328},"参与美国国会关于 AI 监管的听证会",{"type":185,"tag":194,"props":330,"children":331},{},[332,334,343,345],{"type":191,"value":333},"见：",{"type":185,"tag":335,"props":336,"children":340},"a",{"href":337,"rel":338},"https://garymarcus.substack.com/",[339],"nofollow",[341],{"type":191,"value":342},"Gary Marcus Substack",{"type":191,"value":344},"、",{"type":185,"tag":335,"props":346,"children":349},{"href":347,"rel":348},"https://en.wikipedia.org/wiki/Gary_Marcus",[339],[350],{"type":191,"value":351},"Wikipedia - Gary Marcus",{"title":178,"searchDepth":353,"depth":353,"links":354},2,[],"markdown","content:6.maps:_person:gary-marcus.md","content","6.maps/_person/gary-marcus.md","6.maps/_person/gary-ma