[181,190,196,202,211,231,239,257,265,278,284,302,308,326],{"type":182,"tag":183,"props":184,"children":186},"element","h4",{"id":185},"简介",[187],{"type":188,"value":189},"text","简介？",{"type":182,"tag":191,"props":192,"children":193},"p",{},[194],{"type":188,"value":195},"Gary Marcus 是认知科学家、AI 研究者、企业家和作家。他是纽约大学心理学与神经科学荣誉教授，曾创立机器学习公司 Geometric Intelligence（后被 Uber 收购），并创立了机器人公司 Robust.AI。他以对当前 AI 技术路径的批判性观点而闻名，主张结合深度学习与符号推理的混合方法。",{"type":182,"tag":183,"props":197,"children":199},{"id":198},"主要观点",[200],{"type":188,"value":201},"主要观点？",{"type":182,"tag":191,"props":203,"children":204},{},[205],{"type":182,"tag":206,"props":207,"children":208},"strong",{},[209],{"type":188,"value":210},"对深度学习局限性的批判",{"type":182,"tag":212,"props":213,"children":214},"ul",{},[215,221,226],{"type":182,"tag":216,"props":217,"children":218},"li",{},[219],{"type":188,"value":220},"认为当前大语言模型本质上是「高级自动补全」，缺乏真正的理解和推理能力",{"type":182,"tag":216,"props":222,"children":223},{},[224],{"type":188,"value":225},"指出深度学习在数据效率、泛化能力和可解释性方面存在根本性缺陷",{"type":182,"tag":216,"props":227,"children":228},{},[229],{"type":188,"value":230},"主张「深度学习撞墙了」(Deep Learning is Hitting a Wall)",{"type":182,"tag":191,"props":232,"children":233},{},[234],{"type":182,"tag":206,"props":235,"children":236},{},[237],{"type":188,"value":238},"对 AI 安全的关注",{"type":182,"tag":212,"props":240,"children":241},{},[242,247,252],{"type":182,"tag":216,"props":243,"children":244},{},[245],{"type":188,"value":246},"关注 AI 竞赛中的安全风险，特别是当商业利益凌驾于安全考量之上时",{"type":182,"tag":216,"props":248,"children":249},{},[250],{"type":188,"value":251},"提出 p(doom) 评估会因企业鲁莽行为而上升",{"type":182,"tag":216,"props":253,"children":254},{},[255],{"type":188,"value":256},"批评 OpenAI、xAI 等公司在安全措施上的倒退",{"type":182,"tag":191,"props":258,"children":259},{},[260],{"type":182,"tag":206,"props":261,"children":262},{},[263],{"type":188,"value":264},"混合 AI 架构倡导者",{"type":182,"tag":212,"props":266,"children":267},{},[268,273],{"type":182,"tag":216,"props":269,"children":270},{},[271],{"type":188,"value":272},"主张将神经网络的感知能力与符号系统的推理能力结合",{"type":182,"tag":216,"props":274,"children":275},{},[276],{"type":188,"value":277},"认为通往 AGI 需要更结构化的知识表示和因果推理能力",{"type":182,"tag":183,"props":279,"children":281},{"id":280},"代表作品",[282],{"type":188,"value":283},"代表作品？",{"type":182,"tag":212,"props":285,"children":286},{},[287,292,297],{"type":182,"tag":216,"props":288,"children":289},{},[290],{"type":188,"value":291},"《重启 AI》（Rebooting AI，2019）- 与 Ernest Davis 合著，探讨构建可信 AI 的路径",{"type":182,"tag":216,"props":293,"children":294},{},[295],{"type":188,"value":296},"《代数思维》（The Algebraic Mind，2001）- 关于认知科学的早期著作",{"type":182,"tag":216,"props":298,"children":299},{},[300],{"type":188,"value":301},"《未来的面孔》（Guitar Zero，2012）- 关于音乐学习的科普作品",{"type":182,"tag":183,"props":303,"children":305},{"id":304},"媒体活动",[306],{"type":188,"value":307},"媒体活动？",{"type":182,"tag":212,"props":309,"children":310},{},[311,316,321],{"type":182,"tag":216,"props":312,"children":313},{},[314],{"type":188,"value":315},"活跃于 Substack（Marcus on AI）和 X/Twitter，定期评论 AI 行业动态",{"type":182,"tag":216,"props":317,"children":318},{},[319],{"type":188,"value":320},"曾与 Yann LeCun 等深度学习先驱公开辩论 AI 发展路径",{"type":182,"tag":216,"props":322,"children":323},{},[324],{"type":188,"value":325},"参与美国国会关于 AI 监管的听证会",{"type":182,"tag":191,"props":327,"children":328},{},[329,331,340,342],{"type":188,"value":330},"见：",{"type":182,"tag":332,"props":333,"children":337},"a",{"href":334,"rel":335},"https://garymarcus.substack.com/",[336],"nofollow",[338],{"type":188,"value":339},"Gary Marcus Substack",{"type":188,"value":341},"、",{"type":182,"tag":332,"props":343,"children":346},{"href":344,"rel":345},"https://en.wikipedia.org/wiki/Gary_Marcus",[336],[347],{"type":188,"value":348},"Wikipedia - Gary Marcus",{"title":175,"searchDepth":350,"depth":350,"links":351},2,[],"markdown","content:6.maps:_person:gary-marcus.md","content","6.maps/_person/gary-marcus.md","6.maps/_person/gary-marcus","md",[359,363],{"_path":360,"title":361,"descrip