oaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"original_path":181,"body":182,"_type":354,"_id":355,"_source":356,"_file":357,"_stem":358,"_extension":359},"/maps/_person/technology/evan-martin","technology",false,true,"","Evan Martin","Chrome 早期开发者（2007-2012），Linux Chrome 负责人，版本控制发烧友","content/6.maps/_person/evan-martin.md",{"type":183,"children":184,"toc":351},"root",[185,194,200,206,215,220,228,233,241,246,254,259,267,272,280,285,293,298,306,311,319,324,332,337],{"type":186,"tag":187,"props":188,"children":190},"element","h4",{"id":189},"简介",[191],{"type":192,"value":193},"text","简介？",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198],{"type":192,"value":199},"Evan Martin 是 Chrome 早期核心开发者，2007 至 2012 年间在 Google 工作，负责 Linux 版 Chrome 的开发。他最初以自由软件社区成员的身份加入 Chrome 项目，希望解决 Linux 上缺乏优秀浏览器的问题。十年后他回顾这段经历，写下了《Chrome, 10 years later》一文，记录了那些年的故事与反思。",{"type":186,"tag":187,"props":201,"children":203},{"id":202},"主要贡献观点",[204],{"type":192,"value":205},"主要贡献/观点？",{"type":186,"tag":195,"props":207,"children":208},{},[209],{"type":186,"tag":210,"props":211,"children":212},"strong",{},[213],{"type":192,"value":214},"Chrome 时期的工作",{"type":186,"tag":195,"props":216,"children":217},{},[218],{"type":192,"value":219},"他最初的目标是让 Linux Chrome 成为现实，为此先在 Windows-only Chrome 上工作多年，最终领导 Linux 团队。他参与了构建系统的设计，写了书签\"星号\"按钮点亮的代码，也是最早推动 Git 工具链集成的人之一。",{"type":186,"tag":195,"props":221,"children":222},{},[223],{"type":186,"tag":210,"props":224,"children":225},{},[226],{"type":192,"value":227},"团队成功的关键：Alignment（对齐）",{"type":186,"tag":195,"props":229,"children":230},{},[231],{"type":192,"value":232},"他认为 Chrome 成功的核心因素是\"对齐\"——产品有一个清晰的目标，每个人都理解并朝同一个方向前进。他回忆曾质疑某个设计细节，设计师 Glen 详细解释了他平衡的各种因素，从那以后他对 Glen 的判断充满信心。好的领导力不一定有秘密配方，但团队对齐至关重要。",{"type":186,"tag":195,"props":234,"children":235},{},[236],{"type":186,"tag":210,"props":237,"children":238},{},[239],{"type":192,"value":240},"Polish timing（打磨时机）",{"type":186,"tag":195,"props":242,"children":243},{},[244],{"type":192,"value":245},"Chrome 首次发布前夕，某个外部危机导致发布推迟一个月。这一个月不能加新功能，只能修 bug 和打磨细节。回顾起来，这段意外的打磨时间让首版比原计划更惊艳。打磨对某些产品至关重要，但在日常工作中却很难被优先安排。",{"type":186,"tag":195,"props":247,"children":248},{},[249],{"type":186,"tag":210,"props":250,"children":251},{},[252],{"type":192,"value":253},"Reward paradox（奖励悖论）",{"type":186,"tag":195,"props":255,"children":256},{},[257],{"type":192,"value":258},"Google 有一个项目，会给特别成功的团队发放额外股票奖励。Chrome 团队获奖后，一位资深成员很快宣布离职。作者问他为什么，对方说：\"一旦我知道留下的最高收益是多少，我就能更好地评估其他选项。\" 这是一个关于奖励可能适得其反的教训——告诉人们\"最高可能收益\"反而加速他们的离职决策。",{"type":186,"tag":195,"props":260,"children":261},{},[262],{"type":186,"tag":210,"props":263,"children":264},{},[265],{"type":192,"value":266},"平台权力动态",{"type":186,"tag":195,"props":268,"children":269},{},[270],{"type":192,"value":271},"浏览器世界的权力关系会随规模变化：小时你兼容别人的 bug，大了网站兼容你的 bug，巨大了你就定义网站能做什么。Chrome 从小到大，经历了这种权力转移。他对此感到不安——没有结构性原因保证这些决定是正确的。",{"type":186,"tag":195,"props":273,"children":274},{},[275],{"type":186,"tag":210,"props":276,"children":277},{},[278],{"type":192,"value":279},"Web vs Native 的演变",{"type":186,"tag":195,"props":281,"children":282},{},[283],{"type":192,"value":284},"发布 Chrome 时，连浏览器开发者都认为 HTML 太烂不适合做浏览器 UI。他记得为搜索结果标签页写了原生 UI 代码来实现文本布局和可点击链接——尽管那个 UI 本来就应该像网页一样。后来他推动用 HTML 实现浏览器 UI，现在 Electron 大行其道，桌面应用不用 HTML 反而少见。",{"type":186,"tag":195,"props":286,"children":287},{},[288],{"type":186,"tag":210,"props":289,"children":290},{},[291],{"type":192,"value":292},"版本控制债务",{"type":186,"tag":195,"props":294,"children":295},{},[296],{"type":192,"value":297},"他是版本控制发烧友，用过 monotone、darcs、tla 等冷门工具，很早就知道 Git 会成为主流。他为 Chrome 写了 Git 工具链来对接 SVN 代码审查流程，但没能推动团队尽早迁移。多年后 Chrome 终于切换到 Git，花了数年时间才完成。他反思这是领导力的失败——为你认为显而易见的事发声，本可以省掉很多人力。",{"type":186,"tag":195,"props":299,"children":300},{},[301],{"type":186,"tag":210,"props":302,"children":303},{},[304],{"type":192,"value":305},"与 Apple 的合作",{"type":186,"tag":195,"props":307,"children":308},{},[309],{"type":192,"value":310},"Chrome 约一半代码是 WebKit fork，发布后需要向 Apple 上游提交 patch。他享受这个经历：来自完全不同工程文化（没有单元测试、没有注释）的 Apple 工程师的 code review 是极好的学习机会，同时也防止 Chrome 随意往 Web 平台塞私货。但他也提到 Steve Jobs 曾因 Google 挖角 WebKit 团队成员而暴怒，这后来被揭露是全行业非法串通的一部分——他最终收到了一张约 1.2 万美元的集体诉讼赔偿支票。",{"type":186,"tag":195,"props":312,"children":313},{},[314],{"type":186,"tag":210,"props":315,"children":316},{},[317],{"type":192,"value":318},"对 Web 未来的悲观",{"type":186,"tag":195,"props":320,"children":321},{},[322],{"type":192,"value":323},"离开 Chrome 后，他花了三年做一个试图\"拯救报纸\"的产品，最终失败。他认为广告驱动的 Web 正在螺旋下降——用 Web 技术可以做出 Figma 这样的好东西，但更容易做出用户敌对的垃圾。人们认为浏览器应该屏蔽广告，但他的观点是：如果商家想把生意做得令人厌恶，唯一合理的回应就是不再光顾。",{"type":186,"tag":195,"props":325,"children":326},{},[327],{"type":186,"tag":210,"props":328,"children":329},{},[330],{"type":192,"value":331},"对 Chrome 现状的复杂情感",{"type":186,"tag":195,"props":333,"children":334},{},[335],{"type":192,"value":336},"他开玩笑说\"Chrome 12 是最好的 Chrome\"——因为他想要的是一个快速精简的浏览器，而之后的版本都在变慢变大。他投入了大量心血，但产品是活的，走向了他不会选择的方向。他对 Google 日益随意的隐私态度感到失望——\"Old Google was a lot more respectful than what you see today.\"",{"type":186,"tag":195,"props":338,"children":339},{},[340,342],{"type":192,"value":341},"见：",{"type":186,"tag":343,"props":344,"children":348},"a",{"href":345,"rel":346},"https://neugierig.org/software/blog/2022/12/chrome.html",[347],"nofollow",[349],{"type":192,"value":350},"Chrome, 10 years later",{"title":178,"searchDepth":352,"depth":352,"links":353},2,[],"markdown","content:6.maps:_person:technology:evan-martin.md","content","6.maps/_person/technology/evan-martin.md","6.maps/_person/technology/evan-martin","md",[361,365],{"_path":362,"title":363,"description":364},"/maps/_person/technology/andrej-karpathy","Andrej Karpathy","AI 研究员、教育家，OpenAI 创始成员，前 Tesla AI 高级总监",{"_path":366,"title":367,"description":368},"/maps/_person/technology/evan-schwartz","Evan Schwartz","Rust / TypeScript 工程师，信息策展人",1772185500706]