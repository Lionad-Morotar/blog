gy",false,true,"","Gary Marcus","认知科学家、AI 研究者、作家，以批判性视角关注人工智能发展","content/6.maps/_person/gary-marcus.md",{"type":183,"children":184,"toc":372},"root",[185,194,200,206,215,235,243,261,269,282,288,306,312,330,336,341],{"type":186,"tag":187,"props":188,"children":190},"element","h4",{"id":189},"简介",[191],{"type":192,"value":193},"text","简介？",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198],{"type":192,"value":199},"Gary Marcus 是认知科学家、AI 研究者、企业家和作家。他是纽约大学心理学与神经科学荣誉教授，曾创立机器学习公司 Geometric Intelligence（后被 Uber 收购），并创立了机器人公司 Robust.AI。他以对当前 AI 技术路径的批判性观点而闻名，主张结合深度学习与符号推理的混合方法。",{"type":186,"tag":187,"props":201,"children":203},{"id":202},"主要观点",[204],{"type":192,"value":205},"主要观点？",{"type":186,"tag":195,"props":207,"children":208},{},[209],{"type":186,"tag":210,"props":211,"children":212},"strong",{},[213],{"type":192,"value":214},"对深度学习局限性的批判",{"type":186,"tag":216,"props":217,"children":218},"ul",{},[219,225,230],{"type":186,"tag":220,"props":221,"children":222},"li",{},[223],{"type":192,"value":224},"认为当前大语言模型本质上是「高级自动补全」，缺乏真正的理解和推理能力",{"type":186,"tag":220,"props":226,"children":227},{},[228],{"type":192,"value":229},"指出深度学习在数据效率、泛化能力和可解释性方面存在根本性缺陷",{"type":186,"tag":220,"props":231,"children":232},{},[233],{"type":192,"value":234},"主张「深度学习撞墙了」(Deep Learning is Hitting a Wall)",{"type":186,"tag":195,"props":236,"children":237},{},[238],{"type":186,"tag":210,"props":239,"children":240},{},[241],{"type":192,"value":242},"对 AI 安全的关注",{"type":186,"tag":216,"props":244,"children":245},{},[246,251,256],{"type":186,"tag":220,"props":247,"children":248},{},[249],{"type":192,"value":250},"关注 AI 竞赛中的安全风险，特别是当商业利益凌驾于安全考量之上时",{"type":186,"tag":220,"props":252,"children":253},{},[254],{"type":192,"value":255},"提出 p(doom) 评估会因企业鲁莽行为而上升",{"type":186,"tag":220,"props":257,"children":258},{},[259],{"type":192,"value":260},"批评 OpenAI、xAI 等公司在安全措施上的倒退",{"type":186,"tag":195,"props":262,"children":263},{},[264],{"type":186,"tag":210,"props":265,"children":266},{},[267],{"type":192,"value":268},"混合 AI 架构倡导者",{"type":186,"tag":216,"props":270,"children":271},{},[272,277],{"type":186,"tag":220,"props":273,"children":274},{},[275],{"type":192,"value":276},"主张将神经网络的感知能力与符号系统的推理能力结合",{"type":186,"tag":220,"props":278,"children":279},{},[280],{"type":192,"value":281},"认为通往 AGI 需要更结构化的知识表示和因果推理能力",{"type":186,"tag":187,"props":283,"children":285},{"id":284},"代表作品",[286],{"type":192,"value":287},"代表作品？",{"type":186,"tag":216,"props":289,"children":290},{},[291,296,301],{"type":186,"tag":220,"props":292,"children":293},{},[294],{"type":192,"value":295},"《重启 AI》（Rebooting AI，2019）- 与 Ernest Davis 合著，探讨构建可信 AI 的路径",{"type":186,"tag":220,"props":297,"children":298},{},[299],{"type":192,"value":300},"《代数思维》（The Algebraic Mind，2001）- 关于认知科学的早期著作",{"type":186,"tag":220,"props":302,"children":303},{},[304],{"type":192,"value":305},"《未来的面孔》（Guitar Zero，2012）- 关于音乐学习的科普作品",{"type":186,"tag":187,"props":307,"children":309},{"id":308},"媒体活动",[310],{"type":192,"value":311},"媒体活动？",{"type":186,"tag":216,"props":313,"children":314},{},[315,320,325],{"type":186,"tag":220,"props":316,"children":317},{},[318],{"type":192,"value":319},"活跃于 Substack（Marcus on AI）和 X/Twitter，定期评论 AI 行业动态",{"type":186,"tag":220,"props":321,"children":322},{},[323],{"type":192,"value":324},"曾与 Yann LeCun 等深度学习先驱公开辩论 AI 发展路径",{"type":186,"tag":220,"props":326,"children":327},{},[328],{"type":192,"value":329},"参与美国国会关于 AI 监管的听证会",{"type":186,"tag":187,"props":331,"children":333},{"id":332},"个人与影响",[334],{"type":192,"value":335},"个人与影响？",{"type":186,"tag":195,"props":337,"children":338},{},[339],{"type":192,"value":340},"2026 年 2 月，Gary Marcus 在母亲 Marilyn (Molly) Marcus 突然离世后，写下了一篇感人至深的悼念文章。\n他回顾了母亲作为治疗师和社会工作者的一生，以及从她身上学到的人生准则：\n人皆有共通之处、关注整个世界、每个生命都重要、金钱不是唯一变量、为自己而写作、默默支持所爱之人。\n这些人文价值观深刻影响了 Gary 对 AI 发展路径的思考，特别是他对 AI 安全和社会责任的关切。",{"type":186,"tag":195,"props":342,"children":343},{},[344,346,355,357,364,365],{"type":192,"value":345},"见：",{"type":186,"tag":347,"props":348,"children":352},"a",{"href":349,"rel":350},"https://garymarcus.substack.com/",[351],"nofollow",[353],{"type":192,"value":354},"Gary Marcus Substack",{"type":192,"value":356},"、",{"type":186,"tag":347,"props":358,"children":361},{"href":359,"rel":360},"https://en.wikipedia.org/wiki/Gary_Marcus",[351],[362],{"type":192,"value":363},"Wikipedia - Gary Marcus",{"type":192,"value":356},{"type":186,"tag":347,"props":366,"children":369},{"href":367,"rel":368},"https://garymarcus.substack.com/p/marilyn-molly-marcus-1942-2026",[351],[370],{"type":192,"value":371},"悼念母亲 Marilyn (Molly) Marcus",{"title":178,"searchDepth":373,"depth":373,"links":374},2,[],"markdown","content:6.maps:_person:technology:gary-marcus.md","content","6.maps/_person/technology/gary-marcus.md","6.maps/_person/technology/gary-marcus","md",[382,386],{"_path":383,"title":384,"description":385},"/maps/_person/technology/evan-schwartz","Evan Schwartz","Rust / TypeScript 工程师，信息策展人",{"_path":387,"title":388,"description":389},"/maps/_person/technology/peter-steinberger","Peter Steinberger","PSPDFKit 创始人、Claudebot 创建者，Agentic Engineering 倡导者",1772185500737]