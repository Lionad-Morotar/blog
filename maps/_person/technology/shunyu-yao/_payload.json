,false,true,"","姚顺雨 (Shunyu Yao)","OpenAI 前研究员、AI Agent 方向核心探索者，现任腾讯首席 AI 科学家","content/6.maps/_person/shunyu-yao.md",{"type":183,"children":184,"toc":322},"root",[185,194,200,206,215,220,228,233,241,246,254,259,265,301],{"type":186,"tag":187,"props":188,"children":190},"element","h4",{"id":189},"简介",[191],{"type":192,"value":193},"text","简介？",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198],{"type":192,"value":199},"姚顺雨（1998 年出生），本科毕业于清华大学交叉信息研究院\"姚班\"，普林斯顿大学计算机科学博士，师从 NLP 领域知名学者 Karthik Narasimhan。博士期间在 Google Brain 和 OpenAI 实习，2023 年加入 OpenAI 任研究员，2025 年入选《麻省理工科技评论》\"35 岁以下科技创新 35 人\"中国区名单。2025 年底加入腾讯，任 CEO/总裁办公室首席 AI 科学家，兼任 AI Infra 部及大语言模型部负责人。",{"type":186,"tag":187,"props":201,"children":203},{"id":202},"主要贡献观点",[204],{"type":192,"value":205},"主要贡献/观点？",{"type":186,"tag":195,"props":207,"children":208},{},[209],{"type":186,"tag":210,"props":211,"children":212},"strong",{},[213],{"type":192,"value":214},"AI 的\"下半场\"理论",{"type":186,"tag":195,"props":216,"children":217},{},[218],{"type":192,"value":219},"提出 AI 发展已进入\"中场休息\"阶段，核心特征是从\"训练大于评估\"转向\"评估大于训练\"。上半场通过算法创新（反向传播、Transformer、GPT-3 等）不断刷分；下半场需要重新定义问题，构建能衡量真实世界效用的评估体系。",{"type":186,"tag":195,"props":221,"children":222},{},[223],{"type":186,"tag":210,"props":224,"children":225},{},[226],{"type":192,"value":227},"Language Agent 的倡导者",{"type":186,"tag":195,"props":229,"children":230},{},[231],{"type":192,"value":232},"指出 Agent 的本质是通过语言实现推理，通过推理实现泛化，是通往 AGI 的必经形态。提出 ReAct（Reasoning + Acting）框架，将思考作为行动空间的一部分，显著提升了 Agent 的泛化能力。",{"type":186,"tag":195,"props":234,"children":235},{},[236],{"type":186,"tag":210,"props":237,"children":238},{},[239],{"type":192,"value":240},"效用问题（Utility Problem）",{"type":186,"tag":195,"props":242,"children":243},{},[244],{"type":192,"value":245},"指出当前 AI 的核心矛盾：模型在 MMLU、Codeforces 等基准上达到博士水平，却未能显著改变 GDP。原因在于评估设定追求\"难题\"而非\"实用\"，学术界缺乏评估\"学习能力\"而非\"现有能力\"的基准。",{"type":186,"tag":195,"props":247,"children":248},{},[249],{"type":186,"tag":210,"props":250,"children":251},{},[252],{"type":192,"value":253},"Agent 记忆的重要性",{"type":186,"tag":195,"props":255,"children":256},{},[257],{"type":192,"value":258},"强调 AI 系统的记忆层次缺陷：仅有上下文（短期记忆）和模型权重（长期记忆），缺乏人类式的灵活记忆巩固机制。认为这是限制 Agent 持续学习和个性化的关键瓶颈。",{"type":186,"tag":187,"props":260,"children":262},{"id":261},"代表作品",[263],{"type":192,"value":264},"代表作品？",{"type":186,"tag":266,"props":267,"children":268},"ul",{},[269,275,289],{"type":186,"tag":270,"props":271,"children":272},"li",{},[273],{"type":192,"value":274},"《The Second Half》(2025) - 阐述 AI 下半场理论的代表性博文",{"type":186,"tag":270,"props":276,"children":277},{},[278,287],{"type":186,"tag":279,"props":280,"children":284},"a",{"href":281,"rel":282},"https://arxiv.org/abs/2210.03629",[283],"nofollow",[285],{"type":192,"value":286},"ReAct: Synergizing Reasoning and Acting in Language Models",{"type":192,"value":288}," (2022) - 将推理与行动结合的 Agent 框架",{"type":186,"tag":270,"props":290,"children":291},{},[292,299],{"type":186,"tag":279,"props":293,"children":296},{"href":294,"rel":295},"https://arxiv.org/abs/2205.11916",[283],[297],{"type":192,"value":298},"Language Models are Few-Shot Reasoners",{"type":192,"value":300}," (2022) - 上下文学习研究",{"type":186,"tag":195,"props":302,"children":303},{},[304,306,313,315],{"type":192,"value":305},"见：",{"type":186,"tag":279,"props":307,"children":310},{"href":308,"rel":309},"https://ysymyth.github.io/",[283],[311],{"type":192,"value":312},"个人主页",{"type":192,"value":314},"、",{"type":186,"tag":279,"props":316,"children":319},{"href":317,"rel":318},"https://ysymyth.github.io/The-Second-Half/",[283],[320],{"type":192,"value":321},"The Second Half 原文",{"title":178,"searchDepth":323,"depth":323,"links":324},2,[],"markdown","content:6.maps:_person:technology:shunyu-yao.md","content","6.maps/_person/technology/shunyu-yao.md","6.maps/_person/technology/shunyu-yao","md",[332,336],{"_path":333,"title":334,"description":335},"/maps/_person/technology/richard-stallman","Richard Stallman","计算机程序员、软件自由运动的创始人",{"_path":337,"title":338,"description":339},"/maps/_person/technology/steve-blank","Steve Blank","硅谷创业教父、精益创业运动发起人，《四步创业法》作者",1772504955886]