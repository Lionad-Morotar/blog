lman","technology",false,true,"","Richard Stallman","计算机程序员、软件自由运动的创始人","content/6.maps/_person/richard-stallman.md",{"type":183,"children":184,"toc":452},"root",[185,194,200,209,284,290,298,350,358,409,423,429],{"type":186,"tag":187,"props":188,"children":190},"element","h4",{"id":189},"简介",[191],{"type":192,"value":193},"text","简介？",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198],{"type":192,"value":199},"Richard Stallman（理查德·斯托曼，常缩写为 RMS）是自由软件运动的发起人和核心人物之一，美国程序员与软件自由倡导者。",{"type":186,"tag":195,"props":201,"children":202},{},[203],{"type":186,"tag":204,"props":205,"children":206},"strong",{},[207],{"type":192,"value":208},"主要背景与贡献：",{"type":186,"tag":210,"props":211,"children":212},"ul",{},[213,224,240,257,274],{"type":186,"tag":214,"props":215,"children":216},"li",{},[217,222],{"type":186,"tag":204,"props":218,"children":219},{},[220],{"type":192,"value":221},"出生与背景",{"type":192,"value":223},"：1953 年出生于美国纽约。",{"type":186,"tag":214,"props":225,"children":226},{},[227,232,234,238],{"type":186,"tag":204,"props":228,"children":229},{},[230],{"type":192,"value":231},"GNU 项目",{"type":192,"value":233},"：1983 年，他发起 ",{"type":186,"tag":204,"props":235,"children":236},{},[237],{"type":192,"value":231},{"type":192,"value":239},"，目标是创建一个完全自由（不是免费，而是自由授权）的类 Unix 操作系统。",{"type":186,"tag":214,"props":241,"children":242},{},[243,248,250,255],{"type":186,"tag":204,"props":244,"children":245},{},[246],{"type":192,"value":247},"自由软件基金会（FSF）",{"type":192,"value":249},"：1985 年创立 ",{"type":186,"tag":204,"props":251,"children":252},{},[253],{"type":192,"value":254},"Free Software Foundation",{"type":192,"value":256},"，致力于推广和维护自由软件理念。",{"type":186,"tag":214,"props":258,"children":259},{},[260,265,267,272],{"type":186,"tag":204,"props":261,"children":262},{},[263],{"type":192,"value":264},"GPL 许可证",{"type":192,"value":266},"：他主导制定了 ",{"type":186,"tag":204,"props":268,"children":269},{},[270],{"type":192,"value":271},"GNU 通用公共许可证（GPL）",{"type":192,"value":273},"，这是世界上最有影响力的开源软件许可证之一，保证用户有权使用、复制、修改和分发软件。",{"type":186,"tag":214,"props":275,"children":276},{},[277,282],{"type":186,"tag":204,"props":278,"children":279},{},[280],{"type":192,"value":281},"软件自由理念",{"type":192,"value":283},"：他提出软件应赋予用户\"四个自由\"——运行、学习、修改和分享的自由，并强调\"free\"是\"freedom\"而非\"free of charge\"。",{"type":186,"tag":187,"props":285,"children":287},{"id":286},"影响与争议",[288],{"type":192,"value":289},"影响与争议？",{"type":186,"tag":195,"props":291,"children":292},{},[293],{"type":186,"tag":204,"props":294,"children":295},{},[296],{"type":192,"value":297},"🔹 支持者的观点",{"type":186,"tag":299,"props":300,"children":301},"ol",{},[302,318,334],{"type":186,"tag":214,"props":303,"children":304},{},[305,310],{"type":186,"tag":204,"props":306,"children":307},{},[308],{"type":192,"value":309},"自由与用户权利的捍卫者",{"type":186,"tag":210,"props":311,"children":312},{},[313],{"type":186,"tag":214,"props":314,"children":315},{},[316],{"type":192,"value":317},"他们认为 Stallman 是唯一始终坚持\"软件自由\"原则的大旗手，不妥协、不被商业利益左右。",{"type":186,"tag":214,"props":319,"children":320},{},[321,326],{"type":186,"tag":204,"props":322,"children":323},{},[324],{"type":192,"value":325},"开源与自由软件发展的奠基人",{"type":186,"tag":210,"props":327,"children":328},{},[329],{"type":186,"tag":214,"props":330,"children":331},{},[332],{"type":192,"value":333},"没有他的 GNU 项目和 GPL 许可协议，Linux 和大量开源软件可能无法迅速发展到今天的规模。",{"type":186,"tag":214,"props":335,"children":336},{},[337,342],{"type":186,"tag":204,"props":338,"children":339},{},[340],{"type":192,"value":341},"道德与哲学启发",{"type":186,"tag":210,"props":343,"children":344},{},[345],{"type":186,"tag":214,"props":346,"children":347},{},[348],{"type":192,"value":349},"他强调软件自由是社会公义问题，而不仅仅是技术问题，这对许多开发者和活动家都有深刻影响。",{"type":186,"tag":195,"props":351,"children":352},{},[353],{"type":186,"tag":204,"props":354,"children":355},{},[356],{"type":192,"value":357},"🔹 批评者的观点",{"type":186,"tag":299,"props":359,"children":360},{},[361,377,393],{"type":186,"tag":214,"props":362,"children":363},{},[364,369],{"type":186,"tag":204,"props":365,"children":366},{},[367],{"type":192,"value":368},"过于理想化",{"type":186,"tag":210,"props":370,"children":371},{},[372],{"type":186,"tag":214,"props":373,"children":374},{},[375],{"type":192,"value":376},"批评者认为他的理念在商业现实中难以完全落实，对企业合作有时显得不切实际。",{"type":186,"tag":214,"props":378,"children":379},{},[380,385],{"type":186,"tag":204,"props":381,"children":382},{},[383],{"type":192,"value":384},"反对\"开源\"称呼的分化",{"type":186,"tag":210,"props":386,"children":387},{},[388],{"type":186,"tag":214,"props":389,"children":390},{},[391],{"type":192,"value":392},"他坚持\"自由软件\"一词，不愿与\"开源软件\"混为一谈，导致部分人觉得理念过于狭隘。",{"type":186,"tag":214,"props":394,"children":395},{},[396,401],{"type":186,"tag":204,"props":397,"children":398},{},[399],{"type":192,"value":400},"争议性言论与行为",{"type":186,"tag":210,"props":402,"children":403},{},[404],{"type":186,"tag":214,"props":405,"children":406},{},[407],{"type":192,"value":408},"他在邮件列表、演讲以及一些公共事件中的直言甚至偏激的表达方式，引发过多次舆论争议，造成部分组织与他保持距离。",{"type":186,"tag":195,"props":410,"children":411},{},[412,414],{"type":192,"value":413},"见：",{"type":186,"tag":415,"props":416,"children":420},"a",{"href":417,"rel":418},"https://www.gnu.org/philosophy/open-source-misses-the-point.html",[419],"nofollow",[421],{"type":192,"value":422},"为什么开源错失了自由软件的重点",{"type":186,"tag":187,"props":424,"children":426},{"id":425},"自由软件与开源软件在价值观上有何本质区别",[427],{"type":192,"value":428},"自由软件与开源软件在价值观上有何本质区别？",{"type":186,"tag":210,"props":430,"children":431},{},[432,442],{"type":186,"tag":214,"props":433,"children":434},{},[435,440],{"type":186,"tag":204,"props":436,"children":437},{},[438],{"type":192,"value":439},"价值观区别",{"type":192,"value":441},"：自由软件运动强调的是用户的自由权利，包括自由运行、学习、修改和重新发布软件的自由，其核心是道德和伦理，关注的是用户的基本自由。而开源软件则更注重实用优势，如软件的强大、稳定和高效，其出发点是实用主义，关注的是软件的开发方式和质量。",{"type":186,"tag":214,"props":443,"children":444},{},[445,450],{"type":186,"tag":204,"props":446,"children":447},{},[448],{"type":192,"value":449},"对待非自由软件的态度",{"type":192,"value":451},"：自由软件运动认为非自由软件是一个社会问题，主张停止使用非自由软件，以维护用户的自由权利。开源软件则认为非自由软件不好是因为其开发方式劣等，但并不从道德和伦理角度批判非自由软件，甚至在某些情况下可能会接受非自由软件的某些特性，只要这些特性在技术上被认为是\"更好\"的。",{"title":178,"searchDepth":453,"depth":453,"links":454},2,[],"markdown","content:6.maps:_person:technology:richard-stallman.md","content","6.maps/_person/technology/richard-stallman.md","6.maps/_person/technology/richard-stallman","md",[462,466],{"_path":463,"title":464,"description":465},"/maps/_person/technology/peter-steinberger","Peter Steinberger","PSPDFKit 创始人、Claudebot 创建者，Agentic Engineering 倡导者",{"_path":467,"title":468,"description":469},"/maps/_person/technology/shunyu-yao","姚顺雨 (Shunyu Yao)","OpenAI 前研究员、AI Agent 方向核心探索者，现任腾讯首席 AI 科学家",1772504955793]