teve Blank","硅谷创业教父、精益创业运动发起人，《四步创业法》作者",{"type":182,"children":183,"toc":276},"root",[184,193,199,205,214,234,240,248,253],{"type":185,"tag":186,"props":187,"children":189},"element","h4",{"id":188},"简介",[190],{"type":191,"value":192},"text","简介？",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"Steve Blank 是硅谷最具影响力的创业思想家之一，精益创业（Lean Startup）运动的发起人。\n他曾是八家科技公司的创始人，后转向教学，在斯坦福大学、加州大学伯克利分校等高校讲授创业课程。\n其著作《四步创业法》（The Four Steps to the Epiphany）被视为硅谷创业圣经，影响了 Eric Ries 等人。",{"type":185,"tag":186,"props":200,"children":202},{"id":201},"核心思想",[203],{"type":191,"value":204},"核心思想？",{"type":185,"tag":194,"props":206,"children":207},{},[208],{"type":185,"tag":209,"props":210,"children":211},"strong",{},[212],{"type":191,"value":213},"精益创业方法论",{"type":185,"tag":215,"props":216,"children":217},"ul",{},[218,224,229],{"type":185,"tag":219,"props":220,"children":221},"li",{},[222],{"type":191,"value":223},"提出\"客户开发\"（Customer Development）流程，强调在开发产品前先验证客户需求",{"type":185,"tag":219,"props":225,"children":226},{},[227],{"type":191,"value":228},"主张创业是\"可管理的、可重复的过程\"，而非依赖天才的随机行为",{"type":185,"tag":219,"props":230,"children":231},{},[232],{"type":191,"value":233},"推动\"最小可行产品\"（MVP）和快速迭代理念在创业界的普及",{"type":185,"tag":186,"props":235,"children":237},{"id":236},"洞见与思考",[238],{"type":191,"value":239},"洞见与思考？",{"type":185,"tag":194,"props":241,"children":242},{},[243],{"type":185,"tag":209,"props":244,"children":245},{},[246],{"type":191,"value":247},"关系结束是一种\"人生转向\"",{"type":185,"tag":194,"props":249,"children":250},{},[251],{"type":191,"value":252},"Steve Blank 认为，关系的结束不应被视为失败，而是一种正常的\"人生转向\"（life pivot）。\n他通过亲身经历说明：长期关系往往会进入\"自动运行\"状态，直到某个\"警醒时刻\"（wake-up call）迫使你重新评估。\n人、机构、目标都会随时间变化，关系的结束通常意味着成长发生，而非失败。\n他提出七种关系结束的信号：关系为\"过去的你/对方\"而建、共同使命到期、隐性契约改变、长期不一致、留下的成本上升等。\n这种思维框架不仅适用于人际关系，也适用于创业伙伴关系、组织支持决策等场景。",{"type":185,"tag":194,"props":254,"children":255},{},[256,258,267,269],{"type":191,"value":257},"见：",{"type":185,"tag":259,"props":260,"children":264},"a",{"href":261,"rel":262},"https://steveblank.com/",[263],"nofollow",[265],{"type":191,"value":266},"Steve Blank 官网",{"type":191,"value":268},"、",{"type":185,"tag":259,"props":270,"children":273},{"href":271,"rel":272},"https://steveblank.com/2026/02/24/time-to-move-on-the-reason-relationships-end/",[263],[274],{"type":191,"value":275},"Time to Move On – The Reason Relationships End",{"title":178,"searchDepth":277,"depth":277,"links":278},2,[],"markdown","content:6.maps:_person:technology:steve-blank.md","content","6.maps/_person/technology/steve-blank.md","6.maps/_person/technology/steve-blank","md",[286,290],{"_path":287,"title":288,"description":289},"/maps/_person/technology/shunyu-yao","姚顺雨 (Shunyu Yao)","OpenAI 前研究员、AI Agent 方向核心探索者，现任腾讯首席 AI 科学家",{"_path":291,"title":292,"description":293},"/maps/_person/technology/technology","技术人物","软件工程师、AI研究员、开源活动家等当代科技领域重要人物",1772185500930]