y","technology",false,true,"","Andrej Karpathy","AI 研究员、教育家，OpenAI 创始成员，前 Tesla AI 高级总监","content/6.maps/_person/andrej-karpathy.md",{"type":183,"children":184,"toc":378},"root",[185,194,200,206,215,220,235,243,268,276,281,289,294,300,349],{"type":186,"tag":187,"props":188,"children":190},"element","h4",{"id":189},"简介",[191],{"type":192,"value":193},"text","简介？",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198],{"type":192,"value":199},"Andrej Karpathy 是斯洛伐克裔加拿大计算机科学家，1986 年出生于捷克斯洛伐克。他是斯坦福大学李飞飞教授的学生，博士期间专注于深度学习与计算机视觉。Karpathy 是 OpenAI 的创始成员和研究科学家，后担任 Tesla AI 高级总监，领导自动驾驶的计算机视觉团队。2023 年离开 Tesla 后回归 OpenAI，2024 年离职专注于 AI 教育。他被网友称为\"赛博活佛\"，因其将复杂的 AI 概念讲解得深入浅出。",{"type":186,"tag":187,"props":201,"children":203},{"id":202},"主要贡献观点",[204],{"type":192,"value":205},"主要贡献/观点？",{"type":186,"tag":195,"props":207,"children":208},{},[209],{"type":186,"tag":210,"props":211,"children":212},"strong",{},[213],{"type":192,"value":214},"LLM 科普教育",{"type":186,"tag":195,"props":216,"children":217},{},[218],{"type":192,"value":219},"制作了多个面向普通观众的高质量 LLM 科普视频，包括：",{"type":186,"tag":221,"props":222,"children":223},"ul",{},[224,230],{"type":186,"tag":225,"props":226,"children":227},"li",{},[228],{"type":192,"value":229},"《State of GPT》- 详解大模型训练流程（预训练、SFT、RLHF）",{"type":186,"tag":225,"props":231,"children":232},{},[233],{"type":192,"value":234},"《How I use LLM》- 实用的大模型使用指南，涵盖提示技巧、工具选择、生态系统",{"type":186,"tag":195,"props":236,"children":237},{},[238],{"type":186,"tag":210,"props":239,"children":240},{},[241],{"type":192,"value":242},"神经网络教育框架",{"type":186,"tag":195,"props":244,"children":245},{},[246,248,257,259,266],{"type":192,"value":247},"开发了 ",{"type":186,"tag":249,"props":250,"children":254},"a",{"href":251,"rel":252},"https://github.com/karpathy/micrograd",[253],"nofollow",[255],{"type":192,"value":256},"micrograd",{"type":192,"value":258}," 和 ",{"type":186,"tag":249,"props":260,"children":263},{"href":261,"rel":262},"https://github.com/karpathy/llm.c",[253],[264],{"type":192,"value":265},"llm.c",{"type":192,"value":267}," 等教学项目，用最精简的代码展示核心原理。llm.c 仅需约 1000 行 C 代码即可训练 GPT-2 级别的语言模型。",{"type":186,"tag":195,"props":269,"children":270},{},[271],{"type":186,"tag":210,"props":272,"children":273},{},[274],{"type":192,"value":275},"对 LLM 本质的理解",{"type":186,"tag":195,"props":277,"children":278},{},[279],{"type":192,"value":280},"提出 LLM 是\"数据标注员的神经网络模拟\"的观点——监督微调阶段的模型本质上是学习了人类标注员的回复风格。同时强调 LLM 的\"瑞士奶酪\"能力特征：在某些任务上表现惊艳，却在简单任务上有出人意料的盲点。",{"type":186,"tag":195,"props":282,"children":283},{},[284],{"type":186,"tag":210,"props":285,"children":286},{},[287],{"type":192,"value":288},"强化学习的潜力",{"type":186,"tag":195,"props":290,"children":291},{},[292],{"type":192,"value":293},"认为思考型模型（如 o1、o3-mini）通过强化学习在可验证领域（数学、代码）发现的思考策略，可能代表 AI 超越人类水平的新范式，类似 AlphaGo 的\"第37手\"。",{"type":186,"tag":187,"props":295,"children":297},{"id":296},"代表作品",[298],{"type":192,"value":299},"代表作品？",{"type":186,"tag":221,"props":301,"children":302},{},[303,315,327,337],{"type":186,"tag":225,"props":304,"children":305},{},[306,313],{"type":186,"tag":249,"props":307,"children":310},{"href":308,"rel":309},"https://www.youtube.com/watch?v=bZQun8Y4L2A",[253],[311],{"type":192,"value":312},"State of GPT",{"type":192,"value":314}," (2023) - 微软 Build 大会演讲，详解大模型训练",{"type":186,"tag":225,"props":316,"children":317},{},[318,325],{"type":186,"tag":249,"props":319,"children":322},{"href":320,"rel":321},"https://www.youtube.com/watch?v=EWvNQjAaOHw",[253],[323],{"type":192,"value":324},"How I use LLM",{"type":192,"value":326}," (2025) - 实用的大模型使用指南",{"type":186,"tag":225,"props":328,"children":329},{},[330,335],{"type":186,"tag":249,"props":331,"children":333},{"href":261,"rel":332},[253],[334],{"type":192,"value":265},{"type":192,"value":336}," - 纯 C 语言实现的大模型训练",{"type":186,"tag":225,"props":338,"children":339},{},[340,347],{"type":186,"tag":249,"props":341,"children":344},{"href":342,"rel":343},"https://github.com/karpathy/nanoGPT",[253],[345],{"type":192,"value":346},"nanoGPT",{"type":192,"valu