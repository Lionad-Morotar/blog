nberger","technology",false,true,"","Peter Steinberger","PSPDFKit 创始人、Claudebot 创建者，Agentic Engineering 倡导者","content/6.maps/_person/peter-steinberger.md",{"type":183,"children":184,"toc":324},"root",[185,194,200,206,215,220,240,248,253,261,266,274,288,296,301],{"type":186,"tag":187,"props":188,"children":190},"element","h4",{"id":189},"简介",[191],{"type":192,"value":193},"text","简介？",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198],{"type":192,"value":199},"Peter Steinberger 是奥地利资深开发者，PSPDFKit（PDF 框架，用于超 10 亿设备）的创始人。2024 年离开 PSPDFKit 后，创建了 Claudebot——一个开源的个人 AI 助手项目，短期内迅速获得社区关注（GitHub 3k+ stars）。",{"type":186,"tag":187,"props":201,"children":203},{"id":202},"主要贡献观点",[204],{"type":192,"value":205},"主要贡献/观点？",{"type":186,"tag":195,"props":207,"children":208},{},[209],{"type":186,"tag":210,"props":211,"children":212},"strong",{},[213],{"type":192,"value":214},"Agentic Engineering 方法论",{"type":186,"tag":195,"props":216,"children":217},{},[218],{"type":192,"value":219},"区分于随意的 \"vibe coding\"，提出有意识、架构驱动的 AI 协作方式：",{"type":186,"tag":221,"props":222,"children":223},"ul",{},[224,230,235],{"type":186,"tag":225,"props":226,"children":227},"li",{},[228],{"type":192,"value":229},"单日可合并 600+ commits，秘诀是并行运行 5-10 个 agents",{"type":186,"tag":225,"props":231,"children":232},{},[233],{"type":192,"value":234},"与 AI \"讨论\"而非直接下指令，让它探索多种方案后再决定",{"type":186,"tag":225,"props":236,"children":237},{},[238],{"type":192,"value":239},"自己不写代码，但深度把控架构方向",{"type":186,"tag":195,"props":241,"children":242},{},[243],{"type":186,"tag":210,"props":244,"children":245},{},[246],{"type":192,"value":247},"Closing the Loop 原则",{"type":186,"tag":195,"props":249,"children":250},{},[251],{"type":192,"value":252},"AI 擅长编码的核心原因是代码可被验证。设计\"可验证的架构\"让 AI 能自我测试、自我调试，本地测试比 CI 更快。",{"type":186,"tag":195,"props":254,"children":255},{},[256],{"type":186,"tag":210,"props":257,"children":258},{},[259],{"type":192,"value":260},"从 PR 到 Prompt Request",{"type":186,"tag":195,"props":262,"children":263},{},[264],{"type":192,"value":265},"将 GitHub PR 重新定义为 \"Prompt Request\"——重要的不是代码是什么，而是如何得到这段代码的思考过程。",{"type":186,"tag":195,"props":267,"children":268},{},[269],{"type":186,"tag":210,"props":270,"children":271},{},[272],{"type":192,"value":273},"对 MCP 的批判",{"type":186,"tag":195,"props":275,"children":276},{},[277,279,286],{"type":192,"value":278},"认为 MCP 是\"临时拐杖\"，CLI 更灵活：可以用 ",{"type":186,"tag":280,"props":281,"children":283},"code",{"className":282},[],[284],{"type":192,"value":285},"jq",{"type":192,"value":287}," 精确过滤、管道组合、按需调用，而非预加载所有函数定义污染上下文。",{"type":186,"tag":195,"props":289,"children":290},{},[291],{"type":186,"tag":210,"props":292,"children":293},{},[294],{"type":192,"value":295},"企业 AI 采用障碍",{"type":186,"tag":195,"props":297,"children":298},{},[299],{"type":192,"value":300},"现有公司很难高效采用 AI，因为需要重构整个组织和代码库，优化代码库是为了让 agent 易于理解，而非人类工程师的偏好。",{"type":186,"tag":195,"props":302,"children":303},{},[304,306,315,317],{"type":192,"value":305},"见：",{"type":186,"tag":307,"props":308,"children":312},"a",{"href":309,"rel":310},"https://podcasts.apple.com/us/podcast/the-pragmatic-engineer/id1457313865",[311],"nofollow",[313],{"type":192,"value":314},"The Pragmatic Engineer Podcast 访谈",{"type":192,"value":316}," | ",{"type":186,"tag":307,"props":318,"children":321},{"href":319,"rel":320},"https://github.com/steipete/claudebot",[311],[322],{"type":192,"value":323},"Claudebot GitHub",{"title":178,"searchDepth":325,"depth":325,"links":326},2,[],"markdown","content:6.maps:_person:technology:peter-steinberger.md","content","6.maps/_person/technology/peter-steinberger.md","6.maps/_person/technology/peter-steinberger","md",[334,338],{"_path":335,"title":336,"description":337},"/maps/_person/technology/gary-marcus","Gary Marcus","认知科学家、AI 研究者、作家，以批判性视角关注人工智能发展",{"_path":339,"title":340,"description":341},"/maps/_person/technology/richard-stallman","Richard Stallman","计算机程序员、软件自由运动的创始人",1772504955971]