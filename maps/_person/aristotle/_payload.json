集大成者。",{"type":182,"children":183,"toc":270},"root",[184,193,199,214,227,233,246,253],{"type":185,"tag":186,"props":187,"children":189},"element","h4",{"id":188},"亚里士多德的生平",[190],{"type":191,"value":192},"text","亚里士多德的生平?",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"亚里士多德是柏拉图的学生，亚历山大的老师。他是一位百科全书式的科学家，堪称希腊哲学的集大成者。其写作涉及伦理学、形而上学、心理学、经济学、神学、政治学、修辞学、自然科学、教育学、诗歌、风俗，以及雅典法律。他的著作构建了西方哲学的第一个广泛系统，包含道德、美学、逻辑和科学、政治和玄学。",{"type":185,"tag":200,"props":201,"children":202},"blockquote",{},[203],{"type":185,"tag":194,"props":204,"children":205},{},[206,208],{"type":191,"value":207},"古希腊哲学家中最博学的人物。\n",{"type":185,"tag":209,"props":210,"children":211},"name",{},[212],{"type":191,"value":213},"马克思",{"type":185,"tag":200,"props":215,"children":216},{},[217],{"type":185,"tag":194,"props":218,"children":219},{},[220,222],{"type":191,"value":221},"古代的黑格尔。\n",{"type":185,"tag":209,"props":223,"children":224},{},[225],{"type":191,"value":226},"恩格斯",{"type":185,"tag":186,"props":228,"children":230},{"id":229},"亚里士多德关于精神大脑和心的认识",[231],{"type":191,"value":232},"亚里士多德关于精神、大脑和心的认识？",{"type":185,"tag":194,"props":234,"children":235},{},[236,238,244],{"type":191,"value":237},"与希波克拉底相反，亚里士多德认为",{"type":185,"tag":239,"props":240,"children":241},"u",{},[242],{"type":191,"value":243},"神智在心",{"type":191,"value":245},"。亚里士多德（及多位大思想家）认为，大脑是不太重要的器官，灵魂位于心脏。",{"type":185,"tag":247,"props":248,"children":250},"h2",{"id":249},"references",[251],{"type":191,"value":252},"References",{"type":185,"tag":254,"props":255,"children":256},"ul",{},[257],{"type":185,"tag":258,"props":259,"children":260},"li",{},[261],{"type":185,"tag":262,"props":263,"children":267},"a",{"href":264,"rel":265},"https://baike.baidu.com/item/%E4%BA%9A%E9%87%8C%E5%A3%AB%E5%A4%9A%E5%BE%B7/26769",[266],"nofollow",[268],{"type":191,"value":269},"亚里士多德",{"title":178,"searchDepth":271,"depth":271,"links":272},2,[273],{"id":249,"depth":271,"text":252},"markdown","content:6.maps:_person:aristotle.md","co