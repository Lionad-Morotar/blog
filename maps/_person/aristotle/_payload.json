81,190,196,211,224,230,243,250],{"type":182,"tag":183,"props":184,"children":186},"element","h4",{"id":185},"亚里士多德的生平",[187],{"type":188,"value":189},"text","亚里士多德的生平?",{"type":182,"tag":191,"props":192,"children":193},"p",{},[194],{"type":188,"value":195},"亚里士多德是柏拉图的学生，亚历山大的老师。他是一位百科全书式的科学家，堪称希腊哲学的集大成者。其写作涉及伦理学、形而上学、心理学、经济学、神学、政治学、修辞学、自然科学、教育学、诗歌、风俗，以及雅典法律。他的著作构建了西方哲学的第一个广泛系统，包含道德、美学、逻辑和科学、政治和玄学。",{"type":182,"tag":197,"props":198,"children":199},"blockquote",{},[200],{"type":182,"tag":191,"props":201,"children":202},{},[203,205],{"type":188,"value":204},"古希腊哲学家中最博学的人物。\n",{"type":182,"tag":206,"props":207,"children":208},"name",{},[209],{"type":188,"value":210},"马克思",{"type":182,"tag":197,"props":212,"children":213},{},[214],{"type":182,"tag":191,"props":215,"children":216},{},[217,219],{"type":188,"value":218},"古代的黑格尔。\n",{"type":182,"tag":206,"props":220,"children":221},{},[222],{"type":188,"value":223},"恩格斯",{"type":182,"tag":183,"props":225,"children":227},{"id":226},"亚里士多德关于精神大脑和心的认识",[228],{"type":188,"value":229},"亚里士多德关于精神、大脑和心的认识？",{"type":182,"tag":191,"props":231,"children":232},{},[233,235,241],{"type":188,"value":234},"与希波克拉底相反，亚里士多德认为",{"type":182,"tag":236,"props":237,"children":238},"u",{},[239],{"type":188,"value":240},"神智在心",{"type":188,"value":242},"。亚里士多德（及多位大思想家）认为，大脑是不太重要的器官，灵魂位于心脏。",{"type":182,"tag":244,"props":245,"children":247},"h2",{"id":246},"references",[248],{"type":188,"value":249},"References",{"type":182,"tag":251,"props":252,"children":253},"ul",{},[254],{"type":182,"tag":255,"props":256,"children":257},"li",{},[258],{"type":182,"tag":259,"props":260,"children":264},"a",{"href":261,"rel":262},"https://baike.baidu.com/item/%E4%BA%9A%E9%87%8C%E5%A3%AB%E5%A4%9A%E5%BE%B7/26769",[263],"nofollow",[265],{"type":188,"value":266},"亚里士多德",{"title":175,"searchDepth":268,"depth":268,"links":269},2,[270],{"id":246,"depth":268,"text":249},"markdown","content:6.maps:_person:aristotle.md","content","6.maps/_person/aristotle.md","6.maps/_person/a