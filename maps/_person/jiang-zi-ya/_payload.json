15,227,233,238],{"type":182,"tag":183,"props":184,"children":186},"element","h4",{"id":185},"枯骨死草何知凶吉",[187],{"type":188,"value":189},"text","枯骨死草，何知凶吉？",{"type":182,"tag":191,"props":192,"children":193},"p",{},[194],{"type":188,"value":195},"居二年，纣杀王子比干，囚箕子。武王将伐纣，卜，龟兆不吉，风雨暴至。群公尽惧，唯太公彊之劝武王，武王於是遂行。",{"type":182,"tag":191,"props":197,"children":198},{},[199,201],{"type":188,"value":200},"见：",{"type":182,"tag":202,"props":203,"children":207},"a",{"href":204,"rel":205},"https://so.gushiwen.cn/guwen/bookv_46653FD803893E4F0D6BAC27C4B75E01.aspx",[206],"nofollow",[208],{"type":188,"value":209},"《史记·三十世家·齐太公世家》",{"type":182,"tag":191,"props":211,"children":212},{},[213],{"type":188,"value":214},"周武王伐纣，师至汜水牛头山，风甚雷疾，鼓旗毁折，王之骖乘惶震而死。太公曰：“用兵者，顺天之道未必吉，逆之不必凶，若失人事，则三军败亡。且天道鬼神，视之不见，听之不闻，智将不法，而愚将拘之。若乃好贤而能用，举事而得时，此则不看时日而事利，不假卜筮而事吉，不待祷祀而福从。”遂命驱之前进。周公曰：“今时逆太岁，龟灼告凶，卜筮不吉，星变为灾，请还师。”太公怒曰：“今纣刳比干，囚箕子，以飞廉为政，伐之有何不可？枯草朽骨，安可知乎！”乃焚龟折蓍，援枹而鼓，率众先涉河，武王从之，遂灭纣。",{"type":182,"tag":191,"props":216,"children":217},{},[218,220],{"type":188,"value":219},"见： ",{"type":182,"tag":202,"props":221,"children":224},{"href":222,"rel":223},"https://so.gushiwen.cn/guwen/bookv_46653FD803893E4F4829913B35E634BF.aspx",[206],[225],{"type":188,"value":226},"《通典》推人事破灾异",{"type":182,"tag":183,"props":228,"children":230},{"id":229},"关羽和姜子牙的武圣之争",[231],{"type":188,"value":232},"关羽和姜子牙的武圣之争？",{"type":182,"tag":191,"props":234,"children":235},{},[236],{"type":188,"value":237},"在相当长的一段时间里，姜子牙的历史地位都很高，作为官方祭祀的“武神”。其地位直到被朱元璋贬黜。《孟子》在百家诸子中对武王评价颇高，而朱元璋对《孟子》的憎恨恨屋及乌地迁怒到周武王与姜子牙身上，以及《三国演义》在民间的流行，后改立关羽为武神，关羽庙基本取代了太公庙。",{"type":182,"tag":191,"props":239,"children":240},{},[241,242,249,251],{"type":188,"value":200},{"type":182,"tag":202,"props":243,"children":246},{"href":244,"rel":245},"https://xueshu.baidu.com/usercenter/paper/show?paperid=1c6e0eu04s2b0c50cp0v0rf0gs087476",[206],[247],{"type":188,"value":248},"《历史·政治·文学——姜子牙形象的演变与文化内涵》",{"type":188,"value":250},"，",{"type":182,"tag":202,"props":252,"children":255},{"href":253,"rel":254},"https://xueshu.baidu.com/usercenter/paper/show?paperid=11180jr09y6b0x40v06e0c70vw699859",[206],[256],{"type":188,"value":257},"《姜太公形象演变探析》",{"title":175,"searchDepth":259,"depth":259,"links":260},2,[],"markdown","content:6.maps:_person:jiang-zi-ya.md","content","6.maps/_person/jiang-zi-ya.md","6.maps/_person/jiang-zi-ya","md",[268,272],{"_path":269,"title":270,"description":271},"/maps/_person/hippocrates","希波克拉底（BC460~BC370）","古希腊伯利克时期御用医师，西方医学之父。",{"_path":273,"title":274,"description":275},"/maps/_person/jim-jones","吉姆·琼斯","人民圣殿教创始人",1771071685738]