82,"children":183,"toc":261},"root",[184,193,199,213,218,230,236,241],{"type":185,"tag":186,"props":187,"children":189},"element","h4",{"id":188},"枯骨死草何知凶吉",[190],{"type":191,"value":192},"text","枯骨死草，何知凶吉？",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"居二年，纣杀王子比干，囚箕子。武王将伐纣，卜，龟兆不吉，风雨暴至。群公尽惧，唯太公彊之劝武王，武王於是遂行。",{"type":185,"tag":194,"props":200,"children":201},{},[202,204],{"type":191,"value":203},"见：",{"type":185,"tag":205,"props":206,"children":210},"a",{"href":207,"rel":208},"https://so.gushiwen.cn/guwen/bookv_46653FD803893E4F0D6BAC27C4B75E01.aspx",[209],"nofollow",[211],{"type":191,"value":212},"《史记·三十世家·齐太公世家》",{"type":185,"tag":194,"props":214,"children":215},{},[216],{"type":191,"value":217},"周武王伐纣，师至汜水牛头山，风甚雷疾，鼓旗毁折，王之骖乘惶震而死。太公曰：“用兵者，顺天之道未必吉，逆之不必凶，若失人事，则三军败亡。且天道鬼神，视之不见，听之不闻，智将不法，而愚将拘之。若乃好贤而能用，举事而得时，此则不看时日而事利，不假卜筮而事吉，不待祷祀而福从。”遂命驱之前进。周公曰：“今时逆太岁，龟灼告凶，卜筮不吉，星变为灾，请还师。”太公怒曰：“今纣刳比干，囚箕子，以飞廉为政，伐之有何不可？枯草朽骨，安可知乎！”乃焚龟折蓍，援枹而鼓，率众先涉河，武王从之，遂灭纣。",{"type":185,"tag":194,"props":219,"children":220},{},[221,223],{"type":191,"value":222},"见： ",{"type":185,"tag":205,"props":224,"children":227},{"href":225,"rel":226},"https://so.gushiwen.cn/guwen/bookv_46653FD803893E4F4829913B35E634BF.aspx",[209],[228],{"type":191,"value":229},"《通典》推人事破灾异",{"type":185,"tag":186,"props":231,"children":233},{"id":232},"关羽和姜子牙的武圣之争",[234],{"type":191,"value":235},"关羽和姜子牙的武圣之争？",{"type":185,"tag":194,"props":237,"children":238},{},[239],{"type":191,"value":240},"在相当长的一段时间里，姜子牙的历史地位都很高，作为官方祭祀的“武神”。其地位直到被朱元璋贬黜。《孟子》在百家诸子中对武王评价颇高，而朱元璋对《孟子》的憎恨恨屋及乌地迁怒到周武王与姜子牙身上，以及《三国演义》在民间的流行，后改立关羽为武神，关羽庙基本取代了太公庙。",{"type":185,"tag":194,"props":242,"children":243},{},[244,245,252,254],{"type":191,"value":203},{"type":185,"tag":205,"props":246,"children":249},{"href":247,"rel":248},"https://xueshu.baidu.com/usercenter/paper/show?paperid=1c6e0eu04s2b0c50cp0v0rf0gs087476",[209],[250],{"type":191,"value":251},"《历史·政治·文学——姜子牙形象的演变与文化内涵》",{"type":191,"value":253},"，",{"type":185,"tag":205,"props":255,"children":258},{"href":256,"rel":257},"https://xueshu.baidu.com/usercenter/paper/show?paperid=11180jr09y6b0x40v06e0c70vw699859",[209],[259],{"type":191,"value":260},"《姜太公形象演变探析》",{"title":178,"searchDepth":262,"depth":262,"links":263},2,[],"markdown","content:6.maps:_person:jiang-zi-ya.md","content","6.maps/_person/jiang-zi-ya.md","6.maps/_person/jiang-zi-ya","md",[271,275],{"_path":272,"title":273,"description":274},"/maps/_person/hippocrates","希波克拉底（BC460~BC370）","古希腊伯利克时期御用医师，西方医学之父。",{"_path":276,"title":277,"description":278},"/maps/_person/jim-jones","吉姆·琼斯","人民圣殿教创始人",1771696731853]