程序员、软件自由运动的创始人",{"type":182,"children":183,"toc":451},"root",[184,193,199,208,283,289,297,349,357,408,422,428],{"type":185,"tag":186,"props":187,"children":189},"element","h4",{"id":188},"简介",[190],{"type":191,"value":192},"text","简介？",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"Richard Stallman（理查德·斯托曼，常缩写为 RMS）是自由软件运动的发起人和核心人物之一，美国程序员与软件自由倡导者。",{"type":185,"tag":194,"props":200,"children":201},{},[202],{"type":185,"tag":203,"props":204,"children":205},"strong",{},[206],{"type":191,"value":207},"主要背景与贡献：",{"type":185,"tag":209,"props":210,"children":211},"ul",{},[212,223,239,256,273],{"type":185,"tag":213,"props":214,"children":215},"li",{},[216,221],{"type":185,"tag":203,"props":217,"children":218},{},[219],{"type":191,"value":220},"出生与背景",{"type":191,"value":222},"：1953 年出生于美国纽约。",{"type":185,"tag":213,"props":224,"children":225},{},[226,231,233,237],{"type":185,"tag":203,"props":227,"children":228},{},[229],{"type":191,"value":230},"GNU 项目",{"type":191,"value":232},"：1983 年，他发起 ",{"type":185,"tag":203,"props":234,"children":235},{},[236],{"type":191,"value":230},{"type":191,"value":238},"，目标是创建一个完全自由（不是免费，而是自由授权）的类 Unix 操作系统。",{"type":185,"tag":213,"props":240,"children":241},{},[242,247,249,254],{"type":185,"tag":203,"props":243,"children":244},{},[245],{"type":191,"value":246},"自由软件基金会（FSF）",{"type":191,"value":248},"：1985 年创立 ",{"type":185,"tag":203,"props":250,"children":251},{},[252],{"type":191,"value":253},"Free Software Foundation",{"type":191,"value":255},"，致力于推广和维护自由软件理念。",{"type":185,"tag":213,"props":257,"children":258},{},[259,264,266,271],{"type":185,"tag":203,"props":260,"children":261},{},[262],{"type":191,"value":263},"GPL 许可证",{"type":191,"value":265},"：他主导制定了 ",{"type":185,"tag":203,"props":267,"children":268},{},[269],{"type":191,"value":270},"GNU 通用公共许可证（GPL）",{"type":191,"value":272},"，这是世界上最有影响力的开源软件许可证之一，保证用户有权使用、复制、修改和分发软件。",{"type":185,"tag":213,"props":274,"children":275},{},[276,281],{"type":185,"tag":203,"props":277,"children":278},{},[279],{"type":191,"value":280},"软件自由理念",{"type":191,"value":282},"：他提出软件应赋予用户“四个自由”——运行、学习、修改和分享的自由，并强调“free”是“freedom”而非“free of charge”。",{"type":185,"tag":186,"props":284,"children":286},{"id":285},"影响与争议",[287],{"type":191,"value":288},"影响与争议？",{"type":185,"tag":194,"props":290,"children":291},{},[292],{"type":185,"tag":203,"props":293,"children":294},{},[295],{"type":191,"value":296},"🔹 支持者的观点",{"type":185,"tag":298,"props":299,"children":300},"ol",{},[301,317,333],{"type":185,"tag":213,"props":302,"children":303},{},[304,309],{"type":185,"tag":203,"props":305,"children":306},{},[307],{"type":191,"value":308},"自由与用户权利的捍卫者",{"type":185,"tag":209,"props":310,"children":311},{},[312],{"type":185,"tag":213,"props":313,"children":314},{},[315],{"type":191,"value":316},"他们认为 Stallman 是唯一始终坚持“软件自由”原则的大旗手，不妥协、不被商业利益左右。",{"type":185,"tag":213,"props":318,"children":319},{},[320,325],{"type":185,"tag":203,"props":321,"children":322},{},[323],{"type":191,"value":324},"开源与自由软件发展的奠基人",{"type":185,"tag":209,"props":326,"children":327},{},[328],{"type":185,"tag":213,"props":329,"children":330},{},[331],{"type":191,"value":332},"没有他的 GNU 项目和 GPL 许可协议，Linux 和大量开源软件可能无法迅速发展到今天的规模。",{"type":185,"tag":213,"props":334,"children":335},{},[336,341],{"type":185,"tag":203,"props":337,"children":338},{},[339],{"type":191,"value":340},"道德与哲学启发",{"type":185,"tag":209,"props":342,"children":343},{},[344],{"type":185,"tag":213,"props":345,"children":346},{},[347],{"type":191,"value":348},"他强调软件自由是社会公义问题，而不仅仅是技术问题，这对许多开发者和活动家都有深刻影响。",{"type":185,"tag":194,"props":350,"children":351},{},[352],{"type":185,"tag":203,"props":353,"children":354},{},[355],{"type":191,"value":356},"🔹 批评者的观点",{"type":185,"tag":298,"props":358,"children":359},{},[360,376,392],{"type":185,"tag":213,"props":361,"children":362},{},[363,368],{"type":185,"tag":203,"props":364,"children":365},{},[366],{"type":191,"value":367},"过于理想化",{"type":185,"tag":209,"props":369,"children":370},{},[371],{"type":185,"tag":213,"props":372,"children":373},{},[374],{"type":191,"value":375},"批评者认为他的理念在商业现实中难以完全落实，对企业合作有时显得不切实际。",{"type":185,"tag":213,"props":377,"children":378},{},[379,384],{"type":185,"tag":203,"props":380,"children":381},{},[382],{"type":191,"value":383},"反对“开源”称呼的分化",{"type":185,"tag":209,"props":385,"children":386},{},[387],{"type":185,"tag":213,"props":388,"children":389},{},[390],{"type":191,"value":391},"他坚持“自由软件”一词，不愿与“开源软件”混为一谈，导致部分人觉得理念过于狭隘。",{"type":185,"tag":213,"props":393,"children":394},{},[395,400],{"type":185,"tag":203,"props":396,"children":397},{},[398],{"type":191,"value":399},"争议性言论与行为",{"type":185,"tag":209,"props":401,"children":402},{},[403],{"type":185,"tag":213,"props":404,"children":405},{},[406],{"type":191,"value":407},"他在邮件列表、演讲以及一些公共事件中的直言甚至偏激的表达方式，引发过多次舆论争议，造成部分组织与他保持距离。",{"type":185,"tag":194,"props":409,"children":410},{},[411,413],{"type":191,"value":412},"见：",{"type":185,"tag":414,"props":415,"children":419},"a",{"href":416,"rel":417},"https://www.gnu.org/philosophy/open-source-misses-the-point.html",[418],"nofollow",[420],{"type":191,"value":421},"为什么开源错失了自由软件的重点",{"type":185,"tag":186,"props":423,"children":425},{"id":424},"自由软件与开源软件在价值观上有何本质区别",[426],{"type":191,"value":427},"自由软件与开源软件在价值观上有何本质区别？",{"type":185,"tag":209,"props":429,"children":430},{},[431,441],{"type":185,"tag":213,"props":432,"children":433},{},[434,439],{"type":185,"tag":203,"props":435,"children":436},{},[437],{"type":191,"value":438},"价值观区别",{"type":191,"value":440},"：自由软件运动强调的是用户的自由权利，包括自由运行、学习、修改和重新发布软件的自由，其核心是道德和伦理，关注的是用户的基本自由。而开源软件则更注重实用优势，如软件的强大、稳定和高效，其出发点是实用主义，关注的是软件的开发方式和质量。",{"type":185,"tag":213,"props":442,"children":443},{},[444,449],{"type":185,"tag":203,"props":445,"children":446},{},[447],{"type":191,"value":448},"对待非自由软件的态度",{"type":191,"value":450},"：自由软件运动认为非自由软件是一个社会问题，主张停止使用非自由软件，以维护用户的自由权利。开源软件则认为非自由软件不好是因为其开发方式劣等，但并不从道德和伦理角度批判非自由软件，甚至在某些情况下可能会接受非自由软件的某些特性，只要这些特性在技术上被认为是“更好”的。",{"title":178,"searchDepth":452,"depth":452,"links":453},2,[],"markdown","content:6.maps:_person:richard-stallman.md","content","6.maps/_person/richard-stallman.md","6.maps/_person/richard-stallman","md",[461,465],{"_path":462,"title":463,"description":464},"/maps/_person/mikolaj-kopernik","尼古拉·哥白尼","波兰天文学家、数学家、教会法博士、神父",{"_path":466,"title":467,"description":468},"/maps/_person/shunyu-yao","姚顺雨 (Shunyu Yao)","OpenAI 前研究员、AI Agent 方向核心探索者，现任腾讯首席 AI 科学家",1771693427418]