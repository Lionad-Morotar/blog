"root",[181,190,196,205,280,286,294,346,354,405,419,425],{"type":182,"tag":183,"props":184,"children":186},"element","h4",{"id":185},"简介",[187],{"type":188,"value":189},"text","简介？",{"type":182,"tag":191,"props":192,"children":193},"p",{},[194],{"type":188,"value":195},"Richard Stallman（理查德·斯托曼，常缩写为 RMS）是自由软件运动的发起人和核心人物之一，美国程序员与软件自由倡导者。",{"type":182,"tag":191,"props":197,"children":198},{},[199],{"type":182,"tag":200,"props":201,"children":202},"strong",{},[203],{"type":188,"value":204},"主要背景与贡献：",{"type":182,"tag":206,"props":207,"children":208},"ul",{},[209,220,236,253,270],{"type":182,"tag":210,"props":211,"children":212},"li",{},[213,218],{"type":182,"tag":200,"props":214,"children":215},{},[216],{"type":188,"value":217},"出生与背景",{"type":188,"value":219},"：1953 年出生于美国纽约。",{"type":182,"tag":210,"props":221,"children":222},{},[223,228,230,234],{"type":182,"tag":200,"props":224,"children":225},{},[226],{"type":188,"value":227},"GNU 项目",{"type":188,"value":229},"：1983 年，他发起 ",{"type":182,"tag":200,"props":231,"children":232},{},[233],{"type":188,"value":227},{"type":188,"value":235},"，目标是创建一个完全自由（不是免费，而是自由授权）的类 Unix 操作系统。",{"type":182,"tag":210,"props":237,"children":238},{},[239,244,246,251],{"type":182,"tag":200,"props":240,"children":241},{},[242],{"type":188,"value":243},"自由软件基金会（FSF）",{"type":188,"value":245},"：1985 年创立 ",{"type":182,"tag":200,"props":247,"children":248},{},[249],{"type":188,"value":250},"Free Software Foundation",{"type":188,"value":252},"，致力于推广和维护自由软件理念。",{"type":182,"tag":210,"props":254,"children":255},{},[256,261,263,268],{"type":182,"tag":200,"props":257,"children":258},{},[259],{"type":188,"value":260},"GPL 许可证",{"type":188,"value":262},"：他主导制定了 ",{"type":182,"tag":200,"props":264,"children":265},{},[266],{"type":188,"value":267},"GNU 通用公共许可证（GPL）",{"type":188,"value":269},"，这是世界上最有影响力的开源软件许可证之一，保证用户有权使用、复制、修改和分发软件。",{"type":182,"tag":210,"props":271,"children":272},{},[273,278],{"type":182,"tag":200,"props":274,"children":275},{},[276],{"type":188,"value":277},"软件自由理念",{"type":188,"value":279},"：他提出软件应赋予用户“四个自由”——运行、学习、修改和分享的自由，并强调“free”是“freedom”而非“free of charge”。",{"type":182,"tag":183,"props":281,"children":283},{"id":282},"影响与争议",[284],{"type":188,"value":285},"影响与争议？",{"type":182,"tag":191,"props":287,"children":288},{},[289],{"type":182,"tag":200,"props":290,"children":291},{},[292],{"type":188,"value":293},"🔹 支持者的观点",{"type":182,"tag":295,"props":296,"children":297},"ol",{},[298,314,330],{"type":182,"tag":210,"props":299,"children":300},{},[301,306],{"type":182,"tag":200,"props":302,"children":303},{},[304],{"type":188,"value":305},"自由与用户权利的捍卫者",{"type":182,"tag":206,"props":307,"children":308},{},[309],{"type":182,"tag":210,"props":310,"children":311},{},[312],{"type":188,"value":313},"他们认为 Stallman 是唯一始终坚持“软件自由”原则的大旗手，不妥协、不被商业利益左右。",{"type":182,"tag":210,"props":315,"children":316},{},[317,322],{"type":182,"tag":200,"props":318,"children":319},{},[320],{"type":188,"value":321},"开源与自由软件发展的奠基人",{"type":182,"tag":206,"props":323,"children":324},{},[325],{"type":182,"tag":210,"props":326,"children":327},{},[328],{"type":188,"value":329},"没有他的 GNU 项目和 GPL 许可协议，Linux 和大量开源软件可能无法迅速发展到今天的规模。",{"type":182,"tag":210,"props":331,"children":332},{},[333,338],{"type":182,"tag":200,"props":334,"children":335},{},[336],{"type":188,"value":337},"道德与哲学启发",{"type":182,"tag":206,"props":339,"children":340},{},[341],{"type":182,"tag":210,"props":342,"children":343},{},[344],{"type":188,"value":345},"他强调软件自由是社会公义问题，而不仅仅是技术问题，这对许多开发者和活动家都有深刻影响。",{"type":182,"tag":191,"props":347,"children":348},{},[349],{"type":182,"tag":200,"props":350,"children":351},{},[352],{"type":188,"value":353},"🔹 批评者的观点",{"type":182,"tag":295,"props":355,"children":356},{},[357,373,389],{"type":182,"tag":210,"props":358,"children":359},{},[360,365],{"type":182,"tag":200,"props":361,"children":362},{},[363],{"type":188,"value":364},"过于理想化",{"type":182,"tag":206,"props":366,"children":367},{},[368],{"type":182,"tag":210,"props":369,"children":370},{},[371],{"type":188,"value":372},"批评者认为他的理念在商业现实中难以完全落实，对企业合作有时显得不切实际。",{"type":182,"tag":210,"props":374,"children":375},{},[376,381],{"type":182,"tag":200,"props":377,"children":378},{},[379],{"type":188,"value":380},"反对“开源”称呼的分化",{"type":182,"tag":206,"props":382,"children":383},{},[384],{"type":182,"tag":210,"props":385,"children":386},{},[387],{"type":188,"value":388},"他坚持“自由软件”一词，不愿与“开源软件”混为一谈，导致部分人觉得理念过于狭隘。",{"type":182,"tag":210,"props":390,"children":391},{},[392,397],{"type":182,"tag":200,"props":393,"children":394},{},[395],{"type":188,"value":396},"争议性言论与行为",{"type":182,"tag":206,"props":398,"children":399},{},[400],{"type":182,"tag":210,"props":401,"children":402},{},[403],{"type":188,"value":404},"他在邮件列表、演讲以及一些公共事件中的直言甚至偏激的表达方式，引发过多次舆论争议，造成部分组织与他保持距离。",{"type":182,"tag":191,"props":406,"children":407},{},[408,410],{"type":188,"value":409},"见：",{"type":182,"tag":411,"props":412,"children":416},"a",{"href":413,"rel":414},"https://www.gnu.org/philosophy/open-source-misses-the-point.html",[415],"nofollow",[417],{"type":188,"value":418},"为什么开源错失了自由软件的重点",{"type":182,"tag":183,"props":420,"children":422},{"id":421},"自由软件与开源软件在价值观上有何本质区别",[423],{"type":188,"value":424},"自由软件与开源软件在价值观上有何本质区别？",{"type":182,"tag":206,"props":426,"children":427},{},[428,438],{"type":182,"tag":210,"props":429,"children":430},{},[431,436],{"type":182,"tag":200,"props":432,"children":433},{},[434],{"type":188,"value":435},"价值观区别",{"type":188,"value":437},"：自由软件运动强调的是用户的自由权利，包括自由运行、学习、修改和重新发布软件的自由，其核心是道德和伦理，关注的是用户的基本自由。而开源软件则更注重实用优势，如软件的强大、稳定和高效，其出发点是实用主义，关注的是软件的开发方式和质量。",{"type":182,"tag":210,"props":439,"children":440},{},[441,446],{"type":182,"tag":200,"props":442,"children":443},{},[444],{"type":188,"value":445},"对待非自由软件的态度",{"type":188,"value":447},"：自由软件运动认为非自由软件是一个社会问题，主张停止使用非自由软件，以维护用户的自由权利。开源软件则认为非自由软件不好是因为其开发方式劣等，但并不从道德和伦理角度批判非自由软件，甚至在某些情况下可能会接受非自由软件的某些特性，只要这些特性在技术上被认为是“更好”的。",{"title":175,"searchDepth":449,"depth":449,"links":450},2,[],"markdown","content:6.maps:_person:richard-stallman.md","content","6.maps/_person/richard-stallman.md","6.maps/_person/richard-stallman","md",[458,462],{"_path":459,"title":460,"description":461},"/maps/_person/mikolaj-kopernik","尼古拉·哥白尼","波兰天文学家、数学家、教会法博士、神父",{"_path":463,"title":464,"description":465},"/maps/_photography","摄影","技术传达情感，摄影记录生活。",1771214960198]