教育家，OpenAI 创始成员，前 Tesla AI 高级总监",{"type":182,"children":183,"toc":377},"root",[184,193,199,205,214,219,234,242,267,275,280,288,293,299,348],{"type":185,"tag":186,"props":187,"children":189},"element","h4",{"id":188},"简介",[190],{"type":191,"value":192},"text","简介？",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"Andrej Karpathy 是斯洛伐克裔加拿大计算机科学家，1986 年出生于捷克斯洛伐克。他是斯坦福大学李飞飞教授的学生，博士期间专注于深度学习与计算机视觉。Karpathy 是 OpenAI 的创始成员和研究科学家，后担任 Tesla AI 高级总监，领导自动驾驶的计算机视觉团队。2023 年离开 Tesla 后回归 OpenAI，2024 年离职专注于 AI 教育。他被网友称为\"赛博活佛\"，因其将复杂的 AI 概念讲解得深入浅出。",{"type":185,"tag":186,"props":200,"children":202},{"id":201},"主要贡献观点",[203],{"type":191,"value":204},"主要贡献/观点？",{"type":185,"tag":194,"props":206,"children":207},{},[208],{"type":185,"tag":209,"props":210,"children":211},"strong",{},[212],{"type":191,"value":213},"LLM 科普教育",{"type":185,"tag":194,"props":215,"children":216},{},[217],{"type":191,"value":218},"制作了多个面向普通观众的高质量 LLM 科普视频，包括：",{"type":185,"tag":220,"props":221,"children":222},"ul",{},[223,229],{"type":185,"tag":224,"props":225,"children":226},"li",{},[227],{"type":191,"value":228},"《State of GPT》- 详解大模型训练流程（预训练、SFT、RLHF）",{"type":185,"tag":224,"props":230,"children":231},{},[232],{"type":191,"value":233},"《How I use LLM》- 实用的大模型使用指南，涵盖提示技巧、工具选择、生态系统",{"type":185,"tag":194,"props":235,"children":236},{},[237],{"type":185,"tag":209,"props":238,"children":239},{},[240],{"type":191,"value":241},"神经网络教育框架",{"type":185,"tag":194,"props":243,"children":244},{},[245,247,256,258,265],{"type":191,"value":246},"开发了 ",{"type":185,"tag":248,"props":249,"children":253},"a",{"href":250,"rel":251},"https://github.com/karpathy/micrograd",[252],"nofollow",[254],{"type":191,"value":255},"micrograd",{"type":191,"value":257}," 和 ",{"type":185,"tag":248,"props":259,"children":262},{"href":260,"rel":261},"https://github.com/karpathy/llm.c",[252],[263],{"type":191,"value":264},"llm.c",{"type":191,"value":266}," 等教学项目，用最精简的代码展示核心原理。llm.c 仅需约 1000 行 C 代码即可训练 GPT-2 级别的语言模型。",{"type":185,"tag":194,"props":268,"children":269},{},[270],{"type":185,"tag":209,"props":271,"children":272},{},[273],{"type":191,"value":274},"对 LLM 本质的理解",{"type":185,"tag":194,"props":276,"children":277},{},[278],{"type":191,"value":279},"提出 LLM 是\"数据标注员的神经网络模拟\"的观点——监督微调阶段的模型本质上是学习了人类标注员的回复风格。同时强调 LLM 的\"瑞士奶酪\"能力特征：在某些任务上表现惊艳，却在简单任务上有出人意料的盲点。",{"type":185,"tag":194,"props":281,"children":282},{},[283],{"type":185,"tag":209,"props":284,"children":285},{},[286],{"type":191,"value":287},"强化学习的潜力",{"type":185,"tag":194,"props":289,"children":290},{},[291],{"type":191,"value":292},"认为思考型模型（如 o1、o3-mini）通过强化学习在可验证领域（数学、代码）发现的思考策略，可能代表 AI 超越人类水平的新范式，类似 AlphaGo 的\"第37手\"。",{"type":185,"tag":186,"props":294,"children":296},{"id":295},"代表作品",[297],{"type":191,"value":298},"代表作品？",{"type":185,"tag":220,"props":300,"children":301},{},[302,314,326,336],{"type":185,"tag":224,"props":303,"children":304},{},[305,312],{"type":185,"tag":248,"props":306,"children":309},{"href":307,"rel":308},"https://www.youtube.com/watch?v=bZQun8Y4L2A",[252],[310],{"type":191,"value":311},"State of GPT",{"type":191,"value":313}," (2023) - 微软 Build 大会演讲，详解大模型训练",{"type":185,"tag":224,"props":315,"children":316},{},[317,324],{"type":185,"tag":248,"props":318,"children":321},{"href":319,"rel":320},"https://www.youtube.com/watch?v=EWvNQjAaOHw",[252],[322],{"type":191,"value":323},"How I use LLM",{"type":191,"value":325}," (2025) - 实用的大模型使用指南",{"type":185,"tag":224,"props":327,"children":328},{},[329,334],{"type":185,"tag":248,"props":330,"children":332},{"href":260,"rel":331},[252],[333],{"type":191,"value":264},{"type":191,"value":335}," - 纯 C 语言实现的大模型训练",{"type":185,"tag":224,"props":337,"children":338},{},[339,346],{"type":185,"tag":248,"props":340,"children":343},{"href":341,"rel":342},"https://github.com/karpathy/nanoGPT",[252],[344],{"type":191,"value":345},"nanoGPT",{"type":191,"value":347}," - 最简洁的 GPT 训练实现",{"type":185,"tag":194,"props":349,"children":350},{},[351,353,360,362,369