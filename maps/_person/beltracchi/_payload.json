2,"children":183,"toc":283},"root",[184,193,199,204,225,238],{"type":185,"tag":186,"props":187,"children":189},"element","h4",{"id":188},"现代假画之王贝特拉基的故事",[190],{"type":191,"value":192},"text","现代假画之王贝特拉基的故事？",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"贝特拉基 1951 年出生于德国人，原名叫费舍尔，但后来二婚后改妻姓才叫 Beltracchi。Beltracchi 是个意大利的姓氏，所以应该翻译为“贝特拉基”而不是英译“贝特莱奇”。",{"type":185,"tag":194,"props":200,"children":201},{},[202],{"type":191,"value":203},"青年时的贝特拉基有相当高的绘画天赋，曾在 1978 年在慕尼黑一个相当有名的绘画展展出过，并以一万五千马克的价格售出过一副作品。曾有画廊邀约他为签约画家，但他不想丢下“性、毒品与摇滚”的自由自在的嬉皮士生活拒绝了该邀请。除了画自己的作品，他还做起了假画生意，主要思路是仿制一些史料模糊的中档作者的绘画。一开始他完全单枪匹马做造假，知道后来碰上了画商舒尔特·克林豪斯和海伦，于是三人分工，分别画假画、销售以及编造故事。据不完全统计，直到 2010 年东窗事发，贝特拉基在 30 余年画假画的生涯中，共假冒在绘画史上知名度不一的 50 余位画家的 300 余幅绘画作品，至少获得了 3500 万欧元的不义之财。",{"type":185,"tag":194,"props":205,"children":206},{},[207,209,223],{"type":191,"value":208},"贝特拉基被捕后，在监狱度过了六年时光。从监狱获释后，贝特拉基和他的妻子继续以艺术家的身份工作，出版了自传和电影（《伪造的艺术》，2014年），并从画作中赚了数百万美元收入",{"type":185,"tag":210,"props":211,"children":212},"sup",{},[213],{"type":185,"tag":214,"props":215,"children":220},"a",{"href":216,"ariaDescribedBy":217,"dataFootnoteRef":178,"id":219},"#user-content-fn-income",[218],"footnote-label","user-content-fnref-income",[221],{"type":191,"value":222},"1",{"type":191,"value":224},"。",{"type":185,"tag":194,"props":226,"children":227},{},[228,230],{"type":191,"value":229},"见：",{"type":185,"tag":214,"props":231,"children":235},{"href":232,"rel":233},"https://www.zhihu.com/xen/market/pdf-view/paid_magazine/1395369078886834176",[234],"nofollow",[236],{"type":191,"value":237},"《现代假画之王贝特拉基》",{"type":185,"tag":239,"props":240,"children":243},"section",{"className":241,"dataFootnotes":178},[242],"footnotes",[244,252],{"type":185,"tag":245,"props":246,"children":249},"h2",{"className":247,"id":218},[248],"sr-only",[250],{"type":191,"value":251},"Footnotes",{"type":185,"tag":253,"props":254,"children":255},"ol",{},[256],{"type":185,"tag":257,"props":258,"children":260},"li",{"id":259},"user-content-fn-income",[261,272,274],{"type":185,"tag":214,"props":262,"children":265},{"href":263,"rel":264},"https://www.we-wealth.com/news/pleasure-assets/opere-darte/beltracchi-due-falsari-bonny-clyde-xxi-secolo",[234],[266],{"type":185,"tag":267,"props":268,"children":269},"i",{},[270],{"type":191,"value":271},"Beltracchi, i due falsari d'arte alla 'Bonnie e Clyde' del XXI secolo",{"type":191,"value":273}," ",{"type":185,"tag":214,"props":275,"children":280},{"href":276,"ariaLabel":277,"className":278,"dataFootnoteBackref":178},"#user-content-fnref-income","Back to reference 1",[279],"data-footnote-backref",[281],{"type":191,"value":282},"↩",{"title":178,"searchDepth":284,"depth":284,"links":285},2,[286],{"id":218,"depth":284,"text":251},"markdown","content:6.maps:_person:beltracchi.md","content","6.maps/_person/beltracchi.md","6.maps/_person/beltracchi","md",[294,298],{"_path":295,"title":296,"description":297},"/maps/_person/armstrong","阿姆斯特朗","阿姆斯特朗关于工程的演讲",{"_path":299,"title":300,"description":301},"/maps/_person/claudius-ptolemaeus","克罗狄斯·托勒密","地心说",1771693725554]