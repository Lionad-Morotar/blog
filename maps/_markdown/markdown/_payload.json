hildren":180,"toc":279},"root",[181,190,196,201,228,233,238,251,256,274],{"type":182,"tag":183,"props":184,"children":186},"element","h4",{"id":185},"markdown-inline-style",[187],{"type":188,"value":189},"text","Markdown Inline Style",{"type":182,"tag":191,"props":192,"children":193},"p",{},[194],{"type":188,"value":195},"通过 VuePress 可以在 Markdown 文件中嵌套 HTML 和 VueJS 代码，然而贴到掘金之后需要我手动贴图，太麻烦了。",{"type":182,"tag":191,"props":197,"children":198},{},[199],{"type":188,"value":200},"于是我测试了几种 Inline CSS 的方案：",{"type":182,"tag":202,"props":203,"children":204},"ul",{},[205,218],{"type":182,"tag":206,"props":207,"children":208},"li",{},[209],{"type":182,"tag":210,"props":211,"children":215},"a",{"href":212,"rel":213},"https://mdnice.com/",[214],"nofollow",[216],{"type":188,"value":217},"MarkdownNice",{"type":182,"tag":206,"props":219,"children":220},{},[221],{"type":182,"tag":210,"props":222,"children":225},{"href":223,"rel":224},"https://github.com/jonkemp/inline-css",[214],[226],{"type":188,"value":227},"InlineCSS",{"type":182,"tag":191,"props":229,"children":230},{},[231],{"type":188,"value":232},"不过结果都不理想，MarkdownNice 的主题，一点儿也不好康。.. InlineCSS 有很多很多很多问题。..",{"type":182,"tag":191,"props":234,"children":235},{},[236],{"type":188,"value":237},"这两种工具我都放弃了，然后我尝试了组合工具的可能性。",{"type":182,"tag":202,"props":239,"children":240},{},[241,246],{"type":182,"tag":206,"props":242,"children":243},{},[244],{"type":188,"value":245},"先通过 SingleFile 将网页保存为一个整体的 HTML 文件",{"type":182,"tag":206,"props":247,"children":248},{},[249],{"type":188,"value":250},"再使用 InlineCSS + Cheerio 手写代码并规避 InlineCSS 的一些配置问题",{"type":182,"tag":191,"props":252,"children":253},{},[254],{"type":188,"value":255},"虽然期间有很多坑，但从最后尝试的结果来说，总的方向可行。",{"type":182,"tag":202,"props":257,"children":258},{},[259,264,269],{"type":182,"tag":206,"props":260,"children":261},{},[262],{"type":188,"value":263},"SingleFile 会自动内联图片和字体文件，这个好解决，处理之前直接打开控制台修改对应元素避免内联即可，比如将图片的 SRC 属性名改为 SRCBACKUP",{"type":182,"tag":206,"props":265,"children":266},{},[267],{"type":188,"value":268},"InlineCSS 合并时 Margin、MarginBottom 这些重复的属性不会被合并，所以出现了部分样式问题",{"type":182,"tag":206,"props":270,"children":271},{},[272],{"type":188,"value":273},"InlineCSS 解析 CSS 不能解析 CSS 变量",{"type":182,"tag":191,"props":275,"children":276},{},[277],{"type":188,"value":278},"因为相关问题很多，虽然方向可行，但还是弃坑了。最近需要贴文章时还是直接贴 Markdown，懒得再做转换了。以后重新再捡起来的时候，也许会写个直接在浏览器中跑的脚本，毕竟直接调用 DOM API 获取样式的稳定性感觉要比用 InlineCSS 好。",{"title":175,"searchDepth":280,"depth":280,"links":281},2,[],"markdown","content:6.maps:_markdown:markdown.md","content","6.maps/_markdown/markdown.md","6.maps/_markdown/markdown","md",[289,293],{"_path":290,"title":291,"description":292},"/maps/_management/slice/standalone-data-engineering-team","Standalone Data Engineering Teams（独立数据工程团队）","为什么将数据工程从业务领域团队中剥离出来是一种组织反模式，以及应该如何用平台 + 领域团队协作来取代它。",{"_path":294,"title":295,"description":296},"/maps/_medicine/medicine","医疗","常见医疗知识、疾病、药物等。",1771214191327]