微信小程序开发指南，包含双线程模型、Exparser 组件框架、分包异步化等技术原理和最佳实践。","content/6.maps/_web/miniapp.md",{"type":183,"children":184,"toc":1090},"root",[185,193,230,237,243,249,254,260,265,270,276,290,302,308,313,339,345,350,361,366,376,381,394,399,408,413,421,435,1054,1063,1071,1076,1084],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"技术",[191],{"type":192,"value":189},"text",{"type":186,"tag":194,"props":195,"children":196},"ul",{},[197,210,220],{"type":186,"tag":198,"props":199,"children":200},"li",{},[201],{"type":186,"tag":202,"props":203,"children":207},"a",{"href":204,"rel":205},"https://github.com/phodal/articles/issues/32",[206],"nofollow",[208],{"type":192,"value":209},"这【五篇】文章将带你深入了解「微信小程序」",{"type":186,"tag":198,"props":211,"children":212},{},[213],{"type":186,"tag":202,"props":214,"children":217},{"href":215,"rel":216},"https://developers.weixin.qq.com/ebook?action=get_post_info&volumn=1&lang=zh_CN&book=miniprogram&docid=0000e82f924ca0bb00869a5de5ec0a",[206],[218],{"type":192,"value":219},"小程序底层框架",{"type":186,"tag":198,"props":221,"children":222},{},[223],{"type":186,"tag":202,"props":224,"children":227},{"href":225,"rel":226},"https://zhaomenghuan.js.org/blog/wechat-miniprogram-principle-analysis.html",[206],[228],{"type":192,"value":229},"微信小程序技术原理分析",{"type":186,"tag":231,"props":232,"children":234},"h4",{"id":233},"小程序双线程模型是怎样的",[235],{"type":192,"value":236},"小程序双线程模型是怎样的？",{"type":186,"tag":238,"props":239,"children":240},"p",{},[241],{"type":192,"value":242},"小程序的渲染层和逻辑层使用两个不同的线程管理。渲染层使用 Webviews 渲染页面，逻辑层使用 JSCore 解析执行 JS，而两个线程间的通讯以及 JS 发起的 HTTP、WS 等请求交由 Native 处理。",{"type":186,"tag":231,"props":244,"children":246},{"id":245},"小程序对比网页的优势与限制",[247],{"type":192,"value":248},"小程序对比网页的优势与限制？",{"type":186,"tag":238,"props":250,"children":251},{},[252],{"type":192,"value":253},"相比 PWA 的手动缓存，小程序框架提供了包的自动更新机制。但是出于安全和管控的考虑，小程序阻止页面跳转、动态脚本以及 DOM 操作等能力。",{"type":186,"tag":231,"props":255,"children":257},{"id":256},"小程序的-exparser-是什么",[258],{"type":192,"value":259},"小程序的 Exparser 是什么？",{"type":186,"tag":238,"props":261,"children":262},{},[263],{"type":192,"value":264},"Exparser 是一套小程序的组件框架，它提供了一套类似 Shadow DOM 标准的实现，以维护页面节点树信息，同时它提供了一套内置的基础组件库，用于满足小程序日常开发需求。",{"type":186,"tag":187,"props":266,"children":268},{"id":267},"常见问题",[269],{"type":192,"value":267},{"type":186,"tag":231,"props":271,"children":273},{"id":272},"分包异步化是什么",[274],{"type":192,"value":275},"分包异步化是什么？",{"type":186,"tag":238,"props":277,"children":278},{},[279,281,288],{"type":192,"value":280},"指通过 ",{"type":186,"tag":282,"props":283,"children":285},"code",{"className":284},[],[286],{"type":192,"value":287},"require.async('sub/xxx')",{"type":192,"value":289}," 引用分包中的代码，达到减小主包体积的目的。同理，还有分包插件异步化这种方法。",{"type":186,"tag":238,"props":291,"children":292},{},[293,295],{"type":192,"value":294},"见：",{"type":186,"tag":202,"props":296,"children":299},{"href":297,"rel":298},"https://juejin.cn/post/7205092873326723109",[206],[300],{"type":192,"value":301},"分包异步化在货拉拉微信小程序中的实践",{"type":186,"tag":231,"props":303,"children":305},{"id":304},"微信内的小程序在什么时候会更新版本",[306],{"type":192,"value":307},"微信内的小程序在什么时候会更新版本？",{"type":186,"tag":238,"props":309,"children":310},{},[311],{"type":192,"value":312},"小程序更新分为同步和异步更新：",{"type":186,"tag":194,"props":314,"children":315},{},[316,321,326],{"type":186,"tag":198,"props":317,"children":318},{},[319],{"type":192,"value":320},"打开小程序时异步检查并下载最新版小程序，在下次小程序冷启动时使用新版",{"type":186,"tag":198,"props":322,"children":323},{},[324],{"type":192,"value":325},"微信定期检查小程序版本或小程序长时间未启动再打开时使用同步更新，同步更新会阻塞使用流程",{"type":186,"tag":198,"props":327,"children":328},{},[329,331,337],{"type":192,"value":330},"开发者使用 ",{"type":186,"tag":282,"props":332,"children":334},{"className":333},[],[335],{"type":192,"value":336},"getUpdateManager.onUpdateReady",{"type":192,"value":338}," 接口提醒用户同步更新最新版本",{"type":186,"tag":231,"props":340,"children":342},{"id":341},"小程序对-grid-布局的支持能力如何",[343],{"type":192,"value":344},"小程序对 Grid 布局的支持能力如何？",{"type":186,"tag":238,"props":346,"children":347},{},[348],{"type":192,"value":349},"有许多手机不支持 Grid 布局，如果需要写响应式的栅格布局，要安装插件。",{"type":186,"tag":238,"props":351,"children":352},{},[353,354],{"type":192,"value":294},{"type":186,"tag":202,"props":355,"children":358},{"href":356,"rel":357},"https://developers.weixin.qq.com/community/develop/doc/000004337c41c074412c471d356000?jumpto=comment&commentid=000e664b2e8f28c4432c782675b0",[206],[359],{"type":192,"value":360},"小程序对 grid 布局支持的如何？",{"type":186,"tag":187,"props":362,"children":364},{"id":363},"框架对比",[365],{"type":192,"value":363},{"type":186,"tag":231,"props":367,"children":369},{"id":368},"小程序多端框架全面测评",[370],{"type":186,"tag":202,"props":371,"children":374},{"href":372,"rel":373},"https://developers.weixin.qq.com/community/develop/article/doc/000eaadb944de06374485c3ed51813",[206],[375],{"type":192,"value":368},{"type":186,"tag":238,"props":377,"children":378},{},[379],{"type":192,"value":380},"讨论多端小程序时，我们其实是在讨论其架构的技术差异以及这些技术差异对业务的影响。",{"type":186,"tag":238,"props":382,"children":383},{},[384,386,392],{"type":192,"value":385},"作者认为分为三种多端 UI 框架（这个词不太合适，原文是小程序多端框架）：全包型的 ",{"type":186,"tag":202,"props":387,"children":389},{"href":388},"/maps/_cross-platform/flutter",[390],{"type":192,"value":391},"Flutter",{"type":192,"value":393},"，JS 作为 DSL 的 Web 技术类型如 React Native，和 JS 编译到 native 代码的编译型如 Taro。",{"type":186,"tag":238,"props":395,"children":396},{},[397],{"type":192,"value":398},"查过 React Native 架构技术文档页面，写得是稀烂，一行都看不懂。",{"type":186,"tag":238,"props":400,"children":401},{},[402],{"type":186,"tag":403,"props":404,"children":405},"q",{},[406],{"type":192,"value":407},"交互复杂时难以写出高性能的代码，这类框架的设计就必然导致 JS 和 Native 之间需要通信，类似于手势操作这样频繁地触发通信就很可能使得 UI 无法在 16ms 内及时绘制。React Native 有一些声明式的组件可以避免这个问题，但声明式的写法很难满足复杂交互的需求。",{"type":186,"tag":238,"props":409,"children":410},{},[411],{"type":192,"value":412},"Flutter 的高保真是通过 Skia（以及 Web 端的 WASM Skia 实现的），如果没有 Skia，那么也很难说高保真（比如在 Web 端用 HTML 渲染）。",{"type":186,"tag":238,"props":414,"children":415},{},[416],{"type":186,"tag":403,"props":417,"children":418},{},[419],{"type":192,"value":420},"由于没有渲染引擎，使用各端的原生组件渲染，相同代码渲染的一致性没有第一种高。",{"type":186,"tag":238,"props":422,"children":423},{},[424,426,433],{"type":192,"value":425},"简单的项目 if/else 就够用了，再复杂我觉得 Taro 的条件编译也够用。Chameleon 的 ",{"type":186,"tag":202,"props":427,"children":430},{"href":428,"rel":429},"https://cml.js.org/docs/poly.html#%E5%88%9D%E5%A7%8B%E5%8C%96%E5%A4%9A%E6%80%81%E6%8E%A5%E5%8F%A3",[206],[431],{"type":192,"value":432},"多态协议",{"type":192,"value":434}," 这个东西太复杂了，它包含多态接口、多态组件和多态模板，在编写 CML 业务层代码（CML 是 Chameleon 的 DSL）时，可以根据多态协议通过定义好的 .interface 来检查输入输出（编译时和运行时）、完成多端原生组件的调用。代价就是要编写额外的代码，且 Chamelon 本身变得复杂起来，比如需要一个强大的 Linter。",{"type":186,"tag":436,"props":437,"children":441},"pre",{"className":438,"code":439,"language":440,"meta":178,"style":178},"language-html shiki shiki-themes material-theme-lighter github-light github-dark monokai","\u003C!-- 多态接口定义示例 -->\n\u003Cscript cml-type=\"interface\">\ntype Callback = (state: string) => undefined;\ninterface UtilsInterface {\n  setStorage(key: string, value: string, cb: Callback): undefined;\n}\n\u003C/script>\n\n\u003C!-- 多态接口百度小程序端实现示例 -->\n\u003Cscript cml-type=\"baidu\">\nclass Method implements UtilsInterface {\n  setStorage(key, value, cb) {\n    try {\n      swan.setStorageSync(key, value);\n      cb('success');\n    }\n    catch(e) {\n      cb('fail');\n    }\n  }\n}\nexport default new Method();\n\u003C/script>\n","html",[442],{"type":186,"tag":282,"props":443,"children":444},{"__ignoreMap":178},[445,457,505,569,587,666,675,692,701,710,747,776,816,830,876,911,920,948,981,989,998,1006,1038],{"type":186,"tag":446,"props":447,"children":450},"span",{"class":448,"line":449},"line",1,[451],{"type":186,"tag":446,"props":452,"children":454},{"style":453},"--shiki-light:#90A4AE;--shiki-light-font-style:italic;--shiki-default:#6A737D;--shiki-default-font-style:inherit;--shiki-dark:#6A737D;--shiki-dark-font-style:inherit;--shiki-sepia:#88846F;--shiki-sepia-font-style:inherit",[455],{"type":19