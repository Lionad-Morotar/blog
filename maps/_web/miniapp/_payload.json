。",{"type":182,"children":183,"toc":1089},"root",[184,192,229,236,242,248,253,259,264,269,275,289,301,307,312,338,344,349,360,365,375,380,393,398,407,412,420,434,1053,1062,1070,1075,1083],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"技术",[190],{"type":191,"value":188},"text",{"type":185,"tag":193,"props":194,"children":195},"ul",{},[196,209,219],{"type":185,"tag":197,"props":198,"children":199},"li",{},[200],{"type":185,"tag":201,"props":202,"children":206},"a",{"href":203,"rel":204},"https://github.com/phodal/articles/issues/32",[205],"nofollow",[207],{"type":191,"value":208},"这【五篇】文章将带你深入了解「微信小程序」",{"type":185,"tag":197,"props":210,"children":211},{},[212],{"type":185,"tag":201,"props":213,"children":216},{"href":214,"rel":215},"https://developers.weixin.qq.com/ebook?action=get_post_info&volumn=1&lang=zh_CN&book=miniprogram&docid=0000e82f924ca0bb00869a5de5ec0a",[205],[217],{"type":191,"value":218},"小程序底层框架",{"type":185,"tag":197,"props":220,"children":221},{},[222],{"type":185,"tag":201,"props":223,"children":226},{"href":224,"rel":225},"https://zhaomenghuan.js.org/blog/wechat-miniprogram-principle-analysis.html",[205],[227],{"type":191,"value":228},"微信小程序技术原理分析",{"type":185,"tag":230,"props":231,"children":233},"h4",{"id":232},"小程序双线程模型是怎样的",[234],{"type":191,"value":235},"小程序双线程模型是怎样的？",{"type":185,"tag":237,"props":238,"children":239},"p",{},[240],{"type":191,"value":241},"小程序的渲染层和逻辑层使用两个不同的线程管理。渲染层使用 Webviews 渲染页面，逻辑层使用 JSCore 解析执行 JS，而两个线程间的通讯以及 JS 发起的 HTTP、WS 等请求交由 Native 处理。",{"type":185,"tag":230,"props":243,"children":245},{"id":244},"小程序对比网页的优势与限制",[246],{"type":191,"value":247},"小程序对比网页的优势与限制？",{"type":185,"tag":237,"props":249,"children":250},{},[251],{"type":191,"value":252},"相比 PWA 的手动缓存，小程序框架提供了包的自动更新机制。但是出于安全和管控的考虑，小程序阻止页面跳转、动态脚本以及 DOM 操作等能力。",{"type":185,"tag":230,"props":254,"children":256},{"id":255},"小程序的-exparser-是什么",[257],{"type":191,"value":258},"小程序的 Exparser 是什么？",{"type":185,"tag":237,"props":260,"children":261},{},[262],{"type":191,"value":263},"Exparser 是一套小程序的组件框架，它提供了一套类似 Shadow DOM 标准的实现，以维护页面节点树信息，同时它提供了一套内置的基础组件库，用于满足小程序日常开发需求。",{"type":185,"tag":186,"props":265,"children":267},{"id":266},"常见问题",[268],{"type":191,"value":266},{"type":185,"tag":230,"props":270,"children":272},{"id":271},"分包异步化是什么",[273],{"type":191,"value":274},"分包异步化是什么？",{"type":185,"tag":237,"props":276,"children":277},{},[278,280,287],{"type":191,"value":279},"指通过 ",{"type":185,"tag":281,"props":282,"children":284},"code",{"className":283},[],[285],{"type":191,"value":286},"require.async('sub/xxx')",{"type":191,"value":288}," 引用分包中的代码，达到减小主包体积的目的。同理，还有分包插件异步化这种方法。",{"type":185,"tag":237,"props":290,"children":291},{},[292,294],{"type":191,"value":293},"见：",{"type":185,"tag":201,"props":295,"children":298},{"href":296,"rel":297},"https://juejin.cn/post/7205092873326723109",[205],[299],{"type":191,"value":300},"分包异步化在货拉拉微信小程序中的实践",{"type":185,"tag":230,"props":302,"children":304},{"id":303},"微信内的小程序在什么时候会更新版本",[305],{"type":191,"value":306},"微信内的小程序在什么时候会更新版本？",{"type":185,"tag":237,"props":308,"children":309},{},[310],{"type":191,"value":311},"小程序更新分为同步和异步更新：",{"type":185,"tag":193,"props":313,"children":314},{},[315,320,325],{"type":185,"tag":197,"props":316,"children":317},{},[318],{"type":191,"value":319},"打开小程序时异步检查并下载最新版小程序，在下次小程序冷启动时使用新版",{"type":185,"tag":197,"props":321,"children":322},{},[323],{"type":191,"value":324},"微信定期检查小程序版本或小程序长时间未启动再打开时使用同步更新，同步更新会阻塞使用流程",{"type":185,"tag":197,"props":326,"children":327},{},[328,330,336],{"type":191,"value":329},"开发者使用 ",{"type":185,"tag":281,"props":331,"children":333},{"className":332},[],[334],{"type":191,"value":335},"getUpdateManager.onUpdateReady",{"type":191,"value":337}," 接口提醒用户同步更新最新版本",{"type":185,"tag":230,"props":339,"children":341},{"id":340},"小程序对-grid-布局的支持能力如何",[342],{"type":191,"value":343},"小程序对 Grid 布局的支持能力如何？",{"type":185,"tag":237,"props":345,"children":346},{},[347],{"type":191,"value":348},"有许多手机不支持 Grid 布局，如果需要写响应式的栅格布局，要安装插件。",{"type":185,"tag":237,"props":350,"children":351},{},[352,353],{"type":191,"value":293},{"type":185,"tag":201,"props":354,"children":357},{"href":355,"rel":356},"https://developers.weixin.qq.com/community/develop/doc/000004337c41c074412c471d356000?jumpto=comment&commentid=000e664b2e8f28c4432c782675b0",[205],[358],{"type":191,"value":359},"小程序对 grid 布局支持的如何？",{"type":185,"tag":186,"props":361,"children":363},{"id":362},"框架对比",[364],{"type":191,"value":362},{"type":185,"tag":230,"props":366,"children":368},{"id":367},"小程序多端框架全面测评",[369],{"type":185,"tag":201,"props":370,"children":373},{"href":371,"rel":372},"https://developers.weixin.qq.com/community/develop/article/doc/000eaadb944de06374485c3ed51813",[205],[374],{"type":191,"value":367},{"type":185,"tag":237,"props":376,"children":377},{},[378],{"type":191,"value":379},"讨论多端小程序时，我们其实是在讨论其架构的技术差异以及这些技术差异对业务的影响。",{"type":185,"tag":237,"props":381,"children":382},{},[383,385,391],{"type":191,"value":384},"作者认为分为三种多端 UI 框架（这个词不太合适，原文是小程序多端框架）：全包型的 ",{"type":185,"tag":201,"props":386,"children":388},{"href":387},"/maps/_cross-platform/flutter",[389],{"type":191,"value":390},"Flutter",{"type":191,"value":392},"，JS 作为 DSL 的 Web 技术类型如 React Native，和 JS 编译到 native 代码的编译型如 Taro。",{"type":185,"tag":237,"props":394,"children":395},{},[396],{"type":191,"value":397},"查过 React Native 架构技术文档页面，写得是稀烂，一行都看不懂。",{"type":185,"tag":237,"props":399,"children":400},{},[401],{"type":185,"tag":402,"props":403,"children":404},"q",{},[405],{"type":191,"value":406},"交互复杂时难以写出高性能的代码，这类框架的设计就必然导致 JS 和 Native 之间需要通信，类似于手势操作这样频繁地触发通信就很可能使得 UI 无法在 16ms 内及时绘制。React Native 有一些声明式的组件可以避免这个问题，但声明式的写法很难满足复杂交互的需求。",{"type":185,"tag":237,"props":408,"children":409},{},[410],{"type":191,"value":411},"Flutter 的高保真是通过 Skia（以及 Web 端的 WASM Skia 实现的），如果没有 Skia，那么也很难说高保真（比如在 Web 端用 HTML 渲染）。",{"type":185,"tag":237,"props":413,"children":414},{},[415],{"type":185,"tag":402,"props":416,"children":417},{},[418],{"type":191,"value":419},"由于没有渲染引擎，使用各端的原生组件渲染，相同代码渲染的一致性没有第一种高。",{"type":185,"tag":237,"props":421,"children":422},{},[423,425,432],{"type":191,"value":424},"简单的项目 if/else 就够用了，再复杂我觉得 Taro 的条件编译也够用。Chameleon 的 ",{"type":185,"tag":201,"props":426,"children":429},{"href":427,"rel":428},"https://cml.js.org/docs/poly.html#%E5%88%9D%E5%A7%8B%E5%8C%96%E5%A4%9A%E6%80%81%E6%8E%A5%E5%8F%A3",[205],[430],{"type":191,"value":431},"多态协议",{"type":191,"value":433}," 这个东西太复杂了，它包含多态接口、多态组件和多态模板，在编写 CML 业务层代码（CML 是 Chameleon 的 DSL）时，可以根据多态协议通过定义好的 .interface 来检查输入输出（编译时和运行时）、完成多端原生组件的调用。代价就是要编写额外的代码，且 Chamelon 本身变得复杂起来，比如需要一个强大的 Linter。",{"type":185,"tag":435,"props":436,"children":440},"pre",{"className":437,"code":438,"language":439,"meta":178,"style":178},"language-html shiki shiki-themes material-theme-lighter github-light github-dark monokai","\u003C!-- 多态接口定义示例 -->\n\u003Cscript cml-type=\"interface\">\ntype Callback = (state: string) => undefined;\ninterface UtilsInterface {\n  setStorage(key: string, value: string, cb: Callback): undefined;\n}\n\u003C/script>\n\n\u003C!-- 多态接口百度小程序端实现示例 -->\n\u003Cscript cml-type=\"baidu\">\nclass Method implements UtilsInterface {\n  setStorage(key, value, cb) {\n    try {\n      swan.setStorageSync(key, value);\n      cb('success');\n    }\n    catch(e) {\n      cb('fail');\n    }\n  }\n}\nexport default new Method();\n\u003C/script>\n","html",[441],{"type":185,"tag":281,"props":442,"children":443},{"__ignoreMap":178},[444,456,504,568,586,665,674,691,700,709,746,775,815,829,875,910,919,947,980,988,997,1005,1037],{"type":185,"tag":445,"props":446,"children":449},"span",{"class":447,"line":448},"line",1,[450],{"type":185,"tag":445,"props":451,"children":453},{"style":452},"--shiki-light:#90A4AE;--shiki-light-font-style:italic;--shiki-default:#6A737D;--shiki-default-font-style:inherit;--shiki-dark:#6A737D;--shiki-dark-font-style:inherit;--shiki-sepia:#88846F;--shiki-sepia-font-style:inherit",[454],{"type":191,"value":455},"\u003C!-- 多态接口定义示例 -->\n",{"type":185,"tag":445,"props":457,"chi