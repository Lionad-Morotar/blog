189,226,233,239,245,250,256,261,266,272,286,298,304,309,335,341,346,357,362,372,377,390,395,404,409,417,431,1050,1059,1067,1072,1080],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"技术",[187],{"type":188,"value":185},"text",{"type":182,"tag":190,"props":191,"children":192},"ul",{},[193,206,216],{"type":182,"tag":194,"props":195,"children":196},"li",{},[197],{"type":182,"tag":198,"props":199,"children":203},"a",{"href":200,"rel":201},"https://github.com/phodal/articles/issues/32",[202],"nofollow",[204],{"type":188,"value":205},"这【五篇】文章将带你深入了解「微信小程序」",{"type":182,"tag":194,"props":207,"children":208},{},[209],{"type":182,"tag":198,"props":210,"children":213},{"href":211,"rel":212},"https://developers.weixin.qq.com/ebook?action=get_post_info&volumn=1&lang=zh_CN&book=miniprogram&docid=0000e82f924ca0bb00869a5de5ec0a",[202],[214],{"type":188,"value":215},"小程序底层框架",{"type":182,"tag":194,"props":217,"children":218},{},[219],{"type":182,"tag":198,"props":220,"children":223},{"href":221,"rel":222},"https://zhaomenghuan.js.org/blog/wechat-miniprogram-principle-analysis.html",[202],[224],{"type":188,"value":225},"微信小程序技术原理分析",{"type":182,"tag":227,"props":228,"children":230},"h4",{"id":229},"小程序双线程模型是怎样的",[231],{"type":188,"value":232},"小程序双线程模型是怎样的？",{"type":182,"tag":234,"props":235,"children":236},"p",{},[237],{"type":188,"value":238},"小程序的渲染层和逻辑层使用两个不同的线程管理。渲染层使用 Webviews 渲染页面，逻辑层使用 JSCore 解析执行 JS，而两个线程间的通讯以及 JS 发起的 HTTP、WS 等请求交由 Native 处理。",{"type":182,"tag":227,"props":240,"children":242},{"id":241},"小程序对比网页的优势与限制",[243],{"type":188,"value":244},"小程序对比网页的优势与限制？",{"type":182,"tag":234,"props":246,"children":247},{},[248],{"type":188,"value":249},"相比 PWA 的手动缓存，小程序框架提供了包的自动更新机制。但是出于安全和管控的考虑，小程序阻止页面跳转、动态脚本以及 DOM 操作等能力。",{"type":182,"tag":227,"props":251,"children":253},{"id":252},"小程序的-exparser-是什么",[254],{"type":188,"value":255},"小程序的 Exparser 是什么？",{"type":182,"tag":234,"props":257,"children":258},{},[259],{"type":188,"value":260},"Exparser 是一套小程序的组件框架，它提供了一套类似 Shadow DOM 标准的实现，以维护页面节点树信息，同时它提供了一套内置的基础组件库，用于满足小程序日常开发需求。",{"type":182,"tag":183,"props":262,"children":264},{"id":263},"常见问题",[265],{"type":188,"value":263},{"type":182,"tag":227,"props":267,"children":269},{"id":268},"分包异步化是什么",[270],{"type":188,"value":271},"分包异步化是什么？",{"type":182,"tag":234,"props":273,"children":274},{},[275,277,284],{"type":188,"value":276},"指通过 ",{"type":182,"tag":278,"props":279,"children":281},"code",{"className":280},[],[282],{"type":188,"value":283},"require.async('sub/xxx')",{"type":188,"value":285}," 引用分包中的代码，达到减小主包体积的目的。同理，还有分包插件异步化这种方法。",{"type":182,"tag":234,"props":287,"children":288},{},[289,291],{"type":188,"value":290},"见：",{"type":182,"tag":198,"props":292,"children":295},{"href":293,"rel":294},"https://juejin.cn/post/7205092873326723109",[202],[296],{"type":188,"value":297},"分包异步化在货拉拉微信小程序中的实践",{"type":182,"tag":227,"props":299,"children":301},{"id":300},"微信内的小程序在什么时候会更新版本",[302],{"type":188,"value":303},"微信内的小程序在什么时候会更新版本？",{"type":182,"tag":234,"props":305,"children":306},{},[307],{"type":188,"value":308},"小程序更新分为同步和异步更新：",{"type":182,"tag":190,"props":310,"children":311},{},[312,317,322],{"type":182,"tag":194,"props":313,"children":314},{},[315],{"type":188,"value":316},"打开小程序时异步检查并下载最新版小程序，在下次小程序冷启动时使用新版",{"type":182,"tag":194,"props":318,"children":319},{},[320],{"type":188,"value":321},"微信定期检查小程序版本或小程序长时间未启动再打开时使用同步更新，同步更新会阻塞使用流程",{"type":182,"tag":194,"props":323,"children":324},{},[325,327,333],{"type":188,"value":326},"开发者使用 ",{"type":182,"tag":278,"props":328,"children":330},{"className":329},[],[331],{"type":188,"value":332},"getUpdateManager.onUpdateReady",{"type":188,"value":334}," 接口提醒用户同步更新最新版本",{"type":182,"tag":227,"props":336,"children":338},{"id":337},"小程序对-grid-布局的支持能力如何",[339],{"type":188,"value":340},"小程序对 Grid 布局的支持能力如何？",{"type":182,"tag":234,"props":342,"children":343},{},[344],{"type":188,"value":345},"有许多手机不支持 Grid 布局，如果需要写响应式的栅格布局，要安装插件。",{"type":182,"tag":234,"props":347,"children":348},{},[349,350],{"type":188,"value":290},{"type":182,"tag":198,"props":351,"children":354},{"href":352,"rel":353},"https://developers.weixin.qq.com/community/develop/doc/000004337c41c074412c471d356000?jumpto=comment&commentid=000e664b2e8f28c4432c782675b0",[202],[355],{"type":188,"value":356},"小程序对 grid 布局支持的如何？",{"type":182,"tag":183,"props":358,"children":360},{"id":359},"框架对比",[361],{"type":188,"value":359},{"type":182,"tag":227,"props":363,"children":365},{"id":364},"小程序多端框架全面测评",[366],{"type":182,"tag":198,"props":367,"children":370},{"href":368,"rel":369},"https://developers.weixin.qq.com/community/develop/article/doc/000eaadb944de06374485c3ed51813",[202],[371],{"type":188,"value":364},{"type":182,"tag":234,"props":373,"children":374},{},[375],{"type":188,"value":376},"讨论多端小程序时，我们其实是在讨论其架构的技术差异以及这些技术差异对业务的影响。",{"type":182,"tag":234,"props":378,"children":379},{},[380,382,388],{"type":188,"value":381},"作者认为分为三种多端 UI 框架（这个词不太合适，原文是小程序多端框架）：全包型的 ",{"type":182,"tag":198,"props":383,"children":385},{"href":384},"/maps/_cross-platform/flutter",[386],{"type":188,"value":387},"Flutter",{"type":188,"value":389},"，JS 作为 DSL 的 Web 技术类型如 React Native，和 JS 编译到 native 代码的编译型如 Taro。",{"type":182,"tag":234,"props":391,"children":392},{},[393],{"type":188,"value":394},"查过 React Native 架构技术文档页面，写得是稀烂，一行都看不懂。",{"type":182,"tag":234,"props":396,"children":397},{},[398],{"type":182,"tag":399,"props":400,"children":401},"q",{},[402],{"type":188,"value":403},"交互复杂时难以写出高性能的代码，这类框架的设计就必然导致 JS 和 Native 之间需要通信，类似于手势操作这样频繁地触发通信就很可能使得 UI 无法在 16ms 内及时绘制。React Native 有一些声明式的组件可以避免这个问题，但声明式的写法很难满足复杂交互的需求。",{"type":182,"tag":234,"props":405,"children":406},{},[407],{"type":188,"value":408},"Flutter 的高保真是通过 Skia（以及 Web 端的 WASM Skia 实现的），如果没有 Skia，那么也很难说高保真（比如在 Web 端用 HTML 渲染）。",{"type":182,"tag":234,"props":410,"children":411},{},[412],{"type":182,"tag":399,"props":413,"children":414},{},[415],{"type":188,"value":416},"由于没有渲染引擎，使用各端的原生组件渲染，相同代码渲染的一致性没有第一种高。",{"type":182,"tag":234,"props":418,"children":419},{},[420,422,429],{"type":188,"value":421},"简单的项目 if/else 就够用了，再复杂我觉得 Taro 的条件编译也够用。Chameleon 的 ",{"type":182,"tag":198,"props":423,"children":426},{"href":424,"rel":425},"https://cml.js.org/docs/poly.html#%E5%88%9D%E5%A7%8B%E5%8C%96%E5%A4%9A%E6%80%81%E6%8E%A5%E5%8F%A3",[202],[427],{"type":188,"value":428},"多态协议",{"type":188,"value":430}," 这个东西太复杂了，它包含多态接口、多态组件和多态模板，在编写 CML 业务层代码（CML 是 Chameleon 的 DSL）时，可以根据多态协议通过定义好的 .interface 来检查输入输出（编译时和运行时）、完成多端原生组件的调用。代价就是要编写额外的代码，且 Chamelon 本身变得复杂起来，比如需要一个强大的 Linter。",{"type":182,"tag":432,"props":433,"children":437},"pre",{"className":434,"code":435,"language":436,"meta":175,"style":175},"language-html shiki shiki-themes material-theme-lighter github-light github-dark monokai","\u003C!-- 多态接口定义示例 -->\n\u003Cscript cml-type=\"interface\">\ntype Callback = (state: string) => undefined;\ninterface UtilsInterface {\n  setStorage(key: string, value: string, cb: Callback): undefined;\n}\n\u003C/script>\n\n\u003C!-- 多态接口百度小程序端实现示例 -->\n\u003Cscript cml-type=\"baidu\">\nclass Method implements UtilsInterface {\n  setStorage(key, value, cb) {\n    try {\n      swan.setStorageSync(key, value);\n      cb('success');\n    }\n    catch(e) {\n      cb('fail');\n    }\n  }\n}\nexport default new Method();\n\u003C/script>\n","html",[438],{"type":182,"tag":278,"props":439,"children":440},{"__ignoreMap":175},[441,453,501,565,583,662,671,688,697,706,743,772,812,826,872,907,916,944,977,985,994,1002,1034],{"type":182,"tag":442,"props":443,"children":446},"span",{"class":444,"line":445},"line",1,[447],{"type":182,"tag":442,"props":448,"children":450},{"style":449},"--shiki-light:#90A4AE;--shiki-light-font-style:italic;--shiki-default:#6A737D;--shiki-default-font-style:inherit;--shiki-dark:#6A737D;--shiki-dark-font-style:inherit;--shiki-sepia:#88846F;--shiki-sepia-font-style:inherit",[451],{"type":188,"value":452},"\u003C!-- 多态接口定义示例 -->\n",{"type":182,"tag":442,"props":454,"children":456},{"class":444,"line":455},2,[457,463,469,47