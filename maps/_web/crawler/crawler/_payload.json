术指南，包含常见反爬虫策略分析、多线程爬虫设计、增量爬取实现以及性能优化等实践经验。","content/6.maps/_web/crawler.md",{"type":183,"children":184,"toc":329},"root",[185,193,200,206,211,217,222,228,233,239,244,250,255,269,275,280,286,291,296,313,319],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"技术问题",[191],{"type":192,"value":189},"text",{"type":186,"tag":194,"props":195,"children":197},"h4",{"id":196},"有哪些常见的反爬虫策略",[198],{"type":192,"value":199},"有哪些常见的反爬虫策略？",{"type":186,"tag":201,"props":202,"children":203},"p",{},[204],{"type":192,"value":205},"前端主要从 HTML、CSS、JS 的角度去考虑。HTML 和 CSS 的策略较简单，比如 iframe 延迟加载、隐形内容、background 偏移、字体重映射等。JS 加密一般会用于价值较高的项目。服务器端可以分主动防御和被动防御两项，指纹、蜜罐、无头浏览器校验、UA、IP、robots.txt 等等。",{"type":186,"tag":201,"props":207,"children":208},{},[209],{"type":192,"value":210},"通过对规则进行组合可以设计出更严格的的反爬策略，如：先访问某图片才能访问某 URL，否则被计分。",{"type":186,"tag":194,"props":212,"children":214},{"id":213},"js-加密如何破解",[215],{"type":192,"value":216},"JS 加密如何破解？",{"type":186,"tag":201,"props":218,"children":219},{},[220],{"type":192,"value":221},"主要依靠调试，找到加解密的关键 JS 函数。",{"type":186,"tag":194,"props":223,"children":225},{"id":224},"多进程协程多线程如何选择",[226],{"type":192,"value":227},"多进程、协程、多线程如何选择？",{"type":186,"tag":201,"props":229,"children":230},{},[231],{"type":192,"value":232},"爬虫在抓取阶段时是网络密集的，解析数据阶段是 CPU 密集的，写入数据阶段是 IO 密集的。由于大部分开销都花费在了抓取阶段，所以宜选择多线程或协程的方式写爬虫程序。更好的方式可能是非阻塞 IO（异步 IO）。",{"type":186,"tag":194,"props":234,"children":236},{"id":235},"增量爬取是怎么设计的",[237],{"type":192,"value":238},"增量爬取是怎么设计的？",{"type":186,"tag":201,"props":240,"children":241},{},[242],{"type":192,"value":243},"通过网址管理器管理每个 URL 的状态。它维护了如 URL 是否被下载完、下载失败次数、子页面等数据，并能根据需求返回仍未被抓取的页面 URL。",{"type":186,"tag":194,"props":245,"children":247},{"id":246},"如何判断页面的相似性",[248],{"type":192,"value":249},"如何判断页面的相似性？",{"type":186,"tag":201,"props":251,"children":252},{},[253],{"type":192,"value":254},"使用 Google 的 SmithHash 算法。",{"type":186,"tag":201,"props":256,"children":257},{},[258,260],{"type":192,"value":259},"见：",{"type":186,"tag":261,"props":262,"children":266},"a",{"href":263,"rel":264},"https://www.likecs.com/show-204424165.html",[265],"nofollow",[267],{"type":192,"value":268},"SimHash 算法原理",{"type":186,"tag":194,"props":270,"children":272},{"id":271},"架构技巧",[273],{"type":192,"value":274},"架构技巧？",{"type":186,"tag":201,"props":276,"children":277},{},[278],{"type":192,"value":279},"爬虫分为抓取、解析和写入三个阶段，所以可以拆分为抓取写入以及读取解析两个程序，分别部署，提高应用以及维护的效率。",{"type":186,"tag":194,"props":281,"children":283},{"id":282},"如何测试网站的抓取极限",[284],{"type":192,"value":285},"如何测试网站的抓取极限？",{"type":186,"tag":201,"props":287,"children":288},{},[289],{"type":192,"value":290},"如果测试每分钟抓 100 次被封了，那么很可能在 80 次就上了监控，所以可以把频次控制在 40 次左右，防止别人的爬虫触发了目标站的反爬虫限制（如 80 次上监控进化为 60 次）。",{"type":186,"tag":187,"props":292,"children":294},{"id":293},"调试工具",[295],{"type":192,"value":293},{"type":186,"tag":297,"props":298,"children":299},"ul",{},[300],{"type":186,"tag":301,"props":302,"children":303},"li",{},[304,311],{"type":186,"tag":261,"props":305,"children":308},{"href":306,"rel":307},"https://github.com/adriancooney/puppeteer-heap-snapshot",[265],[309],{"type":192,"value":310},"puppeteer-heap-snapshot",{"type":192,"value":312},"，根据属性的名字遍历堆内存，查找有这些属性的对象。",{"type":186,"tag":187,"props":314,"children":316},{"id":315},"links",[317],{"type":192,"value":318},"Links",{"type":186,"tag":201,"props":320,"children":321},{},[322],{"type":186,"tag":261,"props":323,"children":326},{"href":324,"rel":325},"https://www.yuanrenxue.com/crawler/why-write-python-crawler.html",[265],[327],{"type":192,"value":328},"TODO，猿人学爬虫教程",{"title":178,"searchDepth":330,"depth":330,"links":331},2,[332,333,334],{"id":189,"depth":330,"text":189},{"id":293,"depth":330,"text":293},{"id":315,"depth":330,"text":318},"markdown","content:6.maps:_web:crawler:crawler.md","content","6.maps/_web/crawler/crawler.md","6.maps/_web/crawler/crawler","md",[342,346],{"_path":343,"title":344,"description":345},"/maps/_web/browser/router","路由技术","Web 前端路由技术详解，包含 Hash 路由、History 路由的实现原理与最佳实践。",{"_pat