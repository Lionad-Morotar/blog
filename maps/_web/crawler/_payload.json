ype":182,"children":183,"toc":328},"root",[184,192,199,205,210,216,221,227,232,238,243,249,254,268,274,279,285,290,295,312,318],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"技术问题",[190],{"type":191,"value":188},"text",{"type":185,"tag":193,"props":194,"children":196},"h4",{"id":195},"有哪些常见的反爬虫策略",[197],{"type":191,"value":198},"有哪些常见的反爬虫策略？",{"type":185,"tag":200,"props":201,"children":202},"p",{},[203],{"type":191,"value":204},"前端主要从 HTML、CSS、JS 的角度去考虑。HTML 和 CSS 的策略较简单，比如 iframe 延迟加载、隐形内容、background 偏移、字体重映射等。JS 加密一般会用于价值较高的项目。服务器端可以分主动防御和被动防御两项，指纹、蜜罐、无头浏览器校验、UA、IP、robots.txt 等等。",{"type":185,"tag":200,"props":206,"children":207},{},[208],{"type":191,"value":209},"通过对规则进行组合可以设计出更严格的的反爬策略，如：先访问某图片才能访问某 URL，否则被计分。",{"type":185,"tag":193,"props":211,"children":213},{"id":212},"js-加密如何破解",[214],{"type":191,"value":215},"JS 加密如何破解？",{"type":185,"tag":200,"props":217,"children":218},{},[219],{"type":191,"value":220},"主要依靠调试，找到加解密的关键 JS 函数。",{"type":185,"tag":193,"props":222,"children":224},{"id":223},"多进程协程多线程如何选择",[225],{"type":191,"value":226},"多进程、协程、多线程如何选择？",{"type":185,"tag":200,"props":228,"children":229},{},[230],{"type":191,"value":231},"爬虫在抓取阶段时是网络密集的，解析数据阶段是 CPU 密集的，写入数据阶段是 IO 密集的。由于大部分开销都花费在了抓取阶段，所以宜选择多线程或协程的方式写爬虫程序。更好的方式可能是非阻塞 IO（异步 IO）。",{"type":185,"tag":193,"props":233,"children":235},{"id":234},"增量爬取是怎么设计的",[236],{"type":191,"value":237},"增量爬取是怎么设计的？",{"type":185,"tag":200,"props":239,"children":240},{},[241],{"type":191,"value":242},"通过网址管理器管理每个 URL 的状态。它维护了如 URL 是否被下载完、下载失败次数、子页面等数据，并能根据需求返回仍未被抓取的页面 URL。",{"type":185,"tag":193,"props":244,"children":246},{"id":245},"如何判断页面的相似性",[247],{"type":191,"value":248},"如何判断页面的相似性？",{"type":185,"tag":200,"props":250,"children":251},{},[252],{"type":191,"value":253},"使用 Google 的 SmithHash 算法。",{"type":185,"tag":200,"props":255,"children":256},{},[257,259],{"type":191,"value":258},"见：",{"type":185,"tag":260,"props":261,"children":265},"a",{"href":262,"rel":263},"https://www.likecs.com/show-204424165.html",[264],"nofollow",[266],{"type":191,"value":267},"SimHash 算法原理",{"type":185,"tag":193,"props":269,"children":271},{"id":270},"架构技巧",[272],{"type":191,"value":273},"架构技巧？",{"type":185,"tag":200,"props":275,"children":276},{},[277],{"type":191,"value":278},"爬虫分为抓取、解析和写入三个阶段，所以可以拆分为抓取写入以及读取解析两个程序，分别部署，提高应用以及维护的效率。",{"type":185,"tag":193,"props":280,"children":282},{"id":281},"如何测试网站的抓取极限",[283],{"type":191,"value":284},"如何测试网站的抓取极限？",{"type":185,"tag":200,"props":286,"children":287},{},[288],{"type":191,"value":289},"如果测试每分钟抓 100 次被封了，那么很可能在 80 次就上了监控，所以可以把频次控制在 40 次左右，防止别人的爬虫触发了目标站的反爬虫限制（如 80 次上监控进化为 60 次）。",{"type":185,"tag":186,"props":291,"children":293},{"id":292},"调试工具",[294],{"type":191,"value":292},{"type":185,"tag":296,"props":297,"children":298},"ul",{},[299],{"type":185,"tag":300,"props":301,"children":302},"li",{},[303,310],{"type":185,"tag":260,"props":304,"children":307},{"href":305,"rel":306},"https://github.com/adriancooney/puppeteer-heap-snapshot",[264],[308],{"type":191,"value":309},"puppeteer-heap-snapshot",{"type":191,"value":311},"，根据属性的名字遍历堆内存，查找有这些属性的对象。",{"type":185,"tag":186,"props":313,"children":315},{"id":314},"links",[316],{"type":191,"value":317},"Links",{"type":185,"tag":200,"props":319,"children":320},{},[321],{"type":185,"tag":260,"props":322,"children":325},{"href":323,"rel":324},"https://www.yuanrenxue.com/crawler/why-write-python-crawler.html",[264],[326],{"type":191,"value":327},"TODO，猿人学爬虫教程",{"title":178,"searchDepth":329,"depth":329,"links":330},2,[331,332,333],{"id":188,"depth":329,"text":188},{"id":292,"depth":329,"text":292},{"id":314,"depth":329,"text":317},"markdown","content:6.maps:_web:crawler.md","content","6.maps/_web/crawler.md","6.maps/_web/crawler","md",[341,345],{"_path":342,"title":343,"description":344},"/maps/_web/browser/router","路由技术","Web 前端路由技术详解，包含 Hash 路由、History 路由的实现原理与最佳实践。",{"_path":346,"title":347,"description":348},"/maps/_web/miniapp","小程序","微信小程序开发指南，包含双线程模型、Exparser 组件框架、分包异步化等