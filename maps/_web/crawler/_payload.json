,202,207,213,218,224,229,235,240,246,251,265,271,276,282,287,292,309,315],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"技术问题",[187],{"type":188,"value":185},"text",{"type":182,"tag":190,"props":191,"children":193},"h4",{"id":192},"有哪些常见的反爬虫策略",[194],{"type":188,"value":195},"有哪些常见的反爬虫策略？",{"type":182,"tag":197,"props":198,"children":199},"p",{},[200],{"type":188,"value":201},"前端主要从 HTML、CSS、JS 的角度去考虑。HTML 和 CSS 的策略较简单，比如 iframe 延迟加载、隐形内容、background 偏移、字体重映射等。JS 加密一般会用于价值较高的项目。服务器端可以分主动防御和被动防御两项，指纹、蜜罐、无头浏览器校验、UA、IP、robots.txt 等等。",{"type":182,"tag":197,"props":203,"children":204},{},[205],{"type":188,"value":206},"通过对规则进行组合可以设计出更严格的的反爬策略，如：先访问某图片才能访问某 URL，否则被计分。",{"type":182,"tag":190,"props":208,"children":210},{"id":209},"js-加密如何破解",[211],{"type":188,"value":212},"JS 加密如何破解？",{"type":182,"tag":197,"props":214,"children":215},{},[216],{"type":188,"value":217},"主要依靠调试，找到加解密的关键 JS 函数。",{"type":182,"tag":190,"props":219,"children":221},{"id":220},"多进程协程多线程如何选择",[222],{"type":188,"value":223},"多进程、协程、多线程如何选择？",{"type":182,"tag":197,"props":225,"children":226},{},[227],{"type":188,"value":228},"爬虫在抓取阶段时是网络密集的，解析数据阶段是 CPU 密集的，写入数据阶段是 IO 密集的。由于大部分开销都花费在了抓取阶段，所以宜选择多线程或协程的方式写爬虫程序。更好的方式可能是非阻塞 IO（异步 IO）。",{"type":182,"tag":190,"props":230,"children":232},{"id":231},"增量爬取是怎么设计的",[233],{"type":188,"value":234},"增量爬取是怎么设计的？",{"type":182,"tag":197,"props":236,"children":237},{},[238],{"type":188,"value":239},"通过网址管理器管理每个 URL 的状态。它维护了如 URL 是否被下载完、下载失败次数、子页面等数据，并能根据需求返回仍未被抓取的页面 URL。",{"type":182,"tag":190,"props":241,"children":243},{"id":242},"如何判断页面的相似性",[244],{"type":188,"value":245},"如何判断页面的相似性？",{"type":182,"tag":197,"props":247,"children":248},{},[249],{"type":188,"value":250},"使用 Google 的 SmithHash 算法。",{"type":182,"tag":197,"props":252,"children":253},{},[254,256],{"type":188,"value":255},"见：",{"type":182,"tag":257,"props":258,"children":262},"a",{"href":259,"rel":260},"https://www.likecs.com/show-204424165.html",[261],"nofollow",[263],{"type":188,"value":264},"SimHash 算法原理",{"type":182,"tag":190,"props":266,"children":268},{"id":267},"架构技巧",[269],{"type":188,"value":270},"架构技巧？",{"type":182,"tag":197,"props":272,"children":273},{},[274],{"type":188,"value":275},"爬虫分为抓取、解析和写入三个阶段，所以可以拆分为抓取写入以及读取解析两个程序，分别部署，提高应用以及维护的效率。",{"type":182,"tag":190,"props":277,"children":279},{"id":278},"如何测试网站的抓取极限",[280],{"type":188,"value":281},"如何测试网站的抓取极限？",{"type":182,"tag":197,"props":283,"children":284},{},[285],{"type":188,"value":286},"如果测试每分钟抓 100 次被封了，那么很可能在 80 次就上了监控，所以可以把频次控制在 40 次左右，防止别人的爬虫触发了目标站的反爬虫限制（如 80 次上监控进化为 60 次）。",{"type":182,"tag":183,"props":288,"children":290},{"id":289},"调试工具",[291],{"type":188,"value":289},{"type":182,"tag":293,"props":294,"children":295},"ul",{},[296],{"type":182,"tag":297,"props":298,"children":299},"li",{},[300,307],{"type":182,"tag":257,"props":301,"children":304},{"href":302,"rel":303},"https://github.com/adriancooney/puppeteer-heap-snapshot",[261],[305],{"type":188,"value":306},"puppeteer-heap-snapshot",{"type":188,"value":308},"，根据属性的名字遍历堆内存，查找有这些属性的对象。",{"type":182,"tag":183,"props":310,"children":312},{"id":311},"links",[313],{"type":188,"value":314},"Links",{"type":182,"tag":197,"props":316,"children":317},{},[318],{"type":182,"tag":257,"props":319,"children":322},{"href":320,"rel":321},"https://www.yuanrenxue.com/crawler/why-write-python-crawler.html",[261],[323],{"type":188,"value":324},"TODO，猿人学爬虫教程",{"title":175,"searchDepth":326,"depth":326,"links":327},2,[328,329,330],{"id":185,"depth":326,"text":185},{"id":289,"depth":326,"text":289},{"id":311,"depth":326,"text":314},"markdown","content:6.maps:_web:crawler.md","content","6.maps/_web/crawler.md","6.maps/_web/crawler","md",[338,342],{"_path":339,"title":340,"description":341},"/maps/_web/browser/router","路由技术","Web 前端路由技术详解，包含 Hash 路由、History 路由的实现原理与最佳实践。",{"_path":343,"title":344,"description":345},"/maps/_web/miniapp","小程序","微信小程序开发指南，包含双线程模型、Exparser 组件框架、分包异步化等技术原理和最佳实践。",1771214188476]