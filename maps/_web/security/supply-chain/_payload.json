态中的传递性信任问题与供应链攻击防范",{"type":182,"children":183,"toc":268},"root",[184,192,198,203,208,244,249,254],{"type":185,"tag":186,"props":187,"children":189},"element","h4",{"id":188},"传递性信任问题",[190],{"type":191,"value":188},"text",{"type":185,"tag":193,"props":194,"children":195},"p",{},[196],{"type":191,"value":197},"开源生态建立在维护者之间的传递性信任之上：一个 800 个传递依赖的包之所以能工作，\n是因为链上每个维护者都合理选择和维护了自己的依赖。\n但现有工具（npm audit、Dependabot）只能扫描已知漏洞，无法验证维护者的安全实践。",{"type":185,"tag":193,"props":199,"children":200},{},[201],{"type":191,"value":202},"你信任你的维护者，你的维护者信任他们的维护者，但他们是否信任他们维护者的维护者？",{"type":185,"tag":186,"props":204,"children":206},{"id":205},"供应链攻击案例",[207],{"type":191,"value":205},{"type":185,"tag":209,"props":210,"children":211},"ul",{},[212,224,234],{"type":185,"tag":213,"props":214,"children":215},"li",{},[216,222],{"type":185,"tag":217,"props":218,"children":219},"strong",{},[220],{"type":191,"value":221},"event-stream 事件",{"type":191,"value":223},"：原维护者将项目交给新人，后者添加恶意依赖",{"type":185,"tag":213,"props":225,"children":226},{},[227,232],{"type":185,"tag":217,"props":228,"children":229},{},[230],{"type":191,"value":231},"xz backdoor",{"type":191,"value":233},"：共同维护者潜伏两年后在构建系统中植入混淆代码",{"type":185,"tag":213,"props":235,"children":236},{},[237,242],{"type":185,"tag":217,"props":238,"children":239},{},[240],{"type":191,"value":241},"codecov bash uploader",{"type":191,"value":243},"：CI 工具被攻击，数千项目受影响",{"type":185,"tag":186,"props":245,"children":247},{"id":246},"信任边界的局限",[248],{"type":191,"value":246},{"type":185,"tag":193,"props":250,"children":251},{},[252],{"type":191,"value":253},"Trusted Publishing 和 vendoring 都只是移动了信任边界，而非消除信任需求。\n大公司的受控构建仍然依赖编译器、操作系统和硬件——\n在某处你总会停止验证，开始信任。",{"type":185,"tag":193,"props":255,"children":256},{},[257,259],{"type":191,"value":258},"见：",{"type":185,"tag":260,"props":261,"children":265},"a",{"href":262,"rel":263},"https://nesbitt.io/2026/03/02/transitive-trust.html",[264],"nofollow",[266],{"type":191,"value":267},"Transitive Trust | Andrew Nesbitt",{"title":178,"se