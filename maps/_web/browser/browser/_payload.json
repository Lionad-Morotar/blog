},"core browser include mobile versions","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20231227012228.png",[],{"type":186,"tag":187,"props":357,"children":359},{"id":358},"浏览器插件",[360],{"type":192,"value":358},{"type":186,"tag":194,"props":362,"children":363},{},[364],{"type":186,"tag":198,"props":365,"children":366},{},[367],{"type":186,"tag":202,"props":368,"children":371},{"href":369,"rel":370},"https://developer.chrome.com/docs/extensions/reference/api?hl=zh-cn",[258],[372],{"type":192,"value":373},"Chrome Extensions API",{"type":186,"tag":187,"props":375,"children":377},{"id":376},"浏览器开发",[378],{"type":192,"value":376},{"type":186,"tag":304,"props":380,"children":382},{"id":381},"事件捕获机制",[383],{"type":192,"value":384},"事件捕获机制？",{"type":186,"tag":279,"props":386,"children":387},{},[388],{"type":192,"value":389},"浏览器的事件传播分为三个阶段：Capturing、Targeting、Bubbling，顺序上来说是先从根元素一直向目标元素传播，然后再由目标元素向根元素传播。事件捕获默认发生在冒泡阶段，但可以在事件监听时使用 useCapture 参数使回调在 Capture 阶段触发。",{"type":186,"tag":279,"props":391,"children":392},{},[393],{"type":186,"tag":351,"props":394,"children":397},{"alt":395,"src":396},"event processing in browser","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/event-capture.svg?w=60",[],{"type":186,"tag":304,"props":399,"children":401},{"id":400},"为什么-passive-true-能改善滚动性能",[402],{"type":192,"value":403},"为什么 passive true 能改善滚动性能？",{"type":186,"tag":279,"props":405,"children":406},{},[407],{"type":192,"value":408},"绑定了事件的 DOM 相关区域会在合成器线程中被标记为 Non-fast Scrollable Region，滚动时，需要等待可能的 JS 执行（比如说 e.preventDefault），将渲染树复合分割为磁贴后，交由栅格线程渲染，最后由 GPU 绘制到界面上。当一个事件标记了 passive: true 之后，合成器线程知悉 JS 执行不会改变滚动事件，所以可以直接走复合、栅格化、渲染的流程。",{"type":186,"tag":279,"props":410,"children":411},{},[412],{"type":192,"value":413},"passive 在 document 绑定 touchmove 或 touchstart 时默认是开启的，但是如果内部使用了 preventDefault，则会使优化失效，在控制台也会报警告。",{"type":186,"tag":304,"props":415,"children":417},{"id":416},"bfcache-是如何运作的",[418],{"type":192,"value":419},"BFCache 是如何运作的？",{"type":186,"tag":279,"props":421,"children":422},{},[423,430],{"type":186,"tag":202,"props":424,"children":427},{"href":425,"rel":426},"https://www.youtube.com/watch?v=cuPsdRckkF0",[258],[428],{"type":192,"value":429},"BFCache（Back/Forward Cache）",{"type":192,"value":431}," 是一种缓存策略。浏览器会把当前页面的快照（包括 JS Heap 快照）缓存到内存中，以便用户从当前页面导航到其它页面短暂浏览后又返回原先页面时，迅速地展现页面。",{"type":186,"tag":279,"props":433,"children":434},{},[435],{"type":192,"value":436},"为了使 BFCache 生效，不能使用 unload、beforeunload 事件，不能指明 window.open，此外，在离开前面前需要连接是关闭状态的（WS、fetch 等）。",{"type":186,"tag":279,"props":438,"children":439},{},[440,442],{"type":192,"value":441},"见：",{"type":186,"tag":202,"props":443,"children":446},{"href":444,"rel":445},"https://web.dev/bfcache",[258],[447],{"type":192,"value":448},"BFCache",{"type":186,"tag":304,"props":450,"children":452},{"id":451},"浏览器怎么跨页面通信",[453],{"type":192,"value":454},"浏览器怎么跨页面通信？",{"type":186,"tag":279,"props":456,"children":457},{},[458],{"type":192,"value":459},"考虑兼容性的话需要使用服务器中转，否则使用 Broadcast Channel 非常合适。Broadcast Channel 可以在 Workers 中使用，它能实现同源 URL 下多窗口、多标签或 iFrames 中的通信。",{"type":186,"tag":279,"props":461,"children":462},{},[463,464],{"type":192,"value":441},{"type":186,"tag":202,"props":465,"children":468},{"href":466,"rel":467},"https://developer.mozilla.org/en-US/docs/Web/API/Broadcast_Channel_API",[258],[469],{"type":192,"value":470},"Broadcast Channel",{"type":186,"tag":304,"props":472,"children":474},{"id":473},"compression-streams",[475],{"type":192,"value":476},"Compression Streams",{"type":186,"tag":194,"props":478,"children":479},{},[480],{"type":186,"tag":198,"props":481,"children":482},{},[483,485],{"type":192,"value":484},"Compression Streams：",{"type":186,"tag":202,"props":486,"children":489},{"href":487,"rel":488},"https://web.dev/blog/compressionstreams?hl=en",[258],[490],{"type":192,"value":491},"Compression Streams are now supported on all browsers",{"type":186,"tag":304,"props":493,"children":495},{"id":494},"eventsource",[496],{"type":192,"value":497},"EventSourc