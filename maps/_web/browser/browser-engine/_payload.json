ue,"","浏览器引擎","Web 浏览器引擎相关知识，包括主流引擎和新兴引擎项目","content/6.maps/_web/browser/browser-engine.md",{"type":183,"children":184,"toc":339},"root",[185,194,200,214,220,233,238,249,255,265,275,285,294,300,310,320,330],{"type":186,"tag":187,"props":188,"children":190},"element","h4",{"id":189},"chrome-早期团队回忆录",[191],{"type":192,"value":193},"text","Chrome 早期团队回忆录",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198],{"type":192,"value":199},"Evan Martin（Ninja 构建系统作者）回忆 2007-2012 年在 Chrome 团队的经历：\nGoogle 做 Chrome 的动机是\"让 Web 成功\"，早期成功源于罕见的 alignment 和人才密度。\nOld Google 比今天的 Google 更尊重员工。",{"type":186,"tag":195,"props":201,"children":202},{},[203,205],{"type":192,"value":204},"见：",{"type":186,"tag":206,"props":207,"children":211},"a",{"href":208,"rel":209},"https://neugierig.org/software/blog/2022/12/chrome.html",[210],"nofollow",[212],{"type":192,"value":213},"Chrome, 10 years later",{"type":186,"tag":187,"props":215,"children":217},{"id":216},"ladybird-是什么",[218],{"type":192,"value":219},"Ladybird 是什么？",{"type":186,"tag":195,"props":221,"children":222},{},[223,225,231],{"type":192,"value":224},"Ladybird 是一个从零构建的全新浏览器引擎，",{"type":186,"tag":226,"props":227,"children":228},"strong",{},[229],{"type":192,"value":230},"非任何现有浏览器的分支",{"type":192,"value":232},"（Not a fork）。",{"type":186,"tag":195,"props":234,"children":235},{},[236],{"type":192,"value":237},"项目由 501(c)(3) 非营利组织支持，致力于解决\"整个网络仅由少数几家有自身议程的公司控制的浏览器引擎驱动\"的问题。目前网络主要由 Blink（Chrome）、WebKit（Safari）和 Gecko（Firefox）三大引擎主导。",{"type":186,"tag":195,"props":239,"children":240},{},[241,242],{"type":192,"value":204},{"type":186,"tag":206,"props":243,"children":246},{"href":244,"rel":245},"https://ladybird.org/",[210],[247],{"type":192,"value":248},"Ladybird 官网",{"type":186,"tag":187,"props":250,"children":252},{"id":251},"ladybird-的技术特点",[253],{"type":192,"value":254},"Ladybird 的技术特点",{"type":186,"tag":195,"props":256,"children":257},{},[258,263],{"type":186,"tag":226,"props":259,"children":260},{},[261],{"type":192,"value":262},"完全独立",{"type":192,"value":264},"：不使用 Blink、WebKit、Gecko 等现有引擎的任何代码，基于 Web 标准全新构建。",{"type":186,"tag":195,"props":266,"children":267},{},[268,273],{"type":186,"tag":226,"props":269,"children":270},{},[271],{"type":192,"value":272},"语言演进",{"type":192,"value":274},"：原基于 C++，2026 年 2 月宣布采用 Rust 作为 C++ 的继任语言，并使用 AI 代理加速迁移。",{"type":186,"tag":195,"props":276,"children":277},{},[278,283],{"type":186,"tag":226,"props":279,"children":280},{},[281],{"type":192,"value":282},"单一专注",{"type":192,"value":284},"：专注于一件事——构建 Web 浏览器，拒绝功能蔓延。",{"type":186,"tag":195,"props":286,"children":287},{},[288,289],{"type":192,"value":204},{"type":186,"tag":206,"props":290,"children":292},{"href":244,"rel":291},[210],[293],{"type":192,"value":248},{"type":186,"tag":187,"props":295,"children":297},{"id":296},"ladybird-的运营模式",[298],{"type":192,"value":299},"Ladybird 的运营模式",{"type":186,"tag":195,"props":301,"children":302},{},[303,308],{"type":186,"tag":226,"props":304,"children":305},{},[306],{"type":192,"value":307},"无用户变现",{"type":192,"value":309},"：拒绝默认搜索协议、加密代币等模式，完全依赖捐赠和赞助。主要赞助商包括 FUTO、Shopify、Cloudflare 等。",{"type":186,"tag":195,"props":311,"children":312},{},[313,318],{"type":186,"tag":226,"props":314,"children":315},{},[316],{"type":192,"value":317},"团队组织",{"type":192,"value":319},"：8 名全职付费工程师 + 大量社区志愿者，保持 18 个月资金储备。",{"type":186,"tag":195,"props":321,"children":322},{},[323,328],{"type":186,"tag":226,"props":324,"children":325},{},[326],{"type":192,"value":327},"路线图",{"type":192,"value":329},"：2026 年发布 Linux/macOS Alpha 版（面向开发者和早期用户）；Windows 和移动端非当前优先。",{"type":186,"tag":195,"props":331,"children":332},{},[333,334],{"type":192,"value":204},{"type":186,"tag":206,"props":335,"children":337},{"href":244,"rel":336},[210],[338],{"type":192,"value":248},{"title":178,"searchDepth":340,"depth":340,"links":341},2,[],"markdown","content:6.maps:_web:browser:browser-engine.md","content","6.maps/_web/browser/browser-engine.md","6.maps/_web/browser/browser-engine","md",[349,353],{"_path":350,"title"