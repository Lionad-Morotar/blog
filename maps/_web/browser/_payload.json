:271,"children":274},{"href":272,"rel":273},"https://web.dev/blog/baseline-definition-update?hl=en",[202],[275],{"type":187,"value":276},"A definition update for Baseline",{"type":181,"tag":241,"props":278,"children":279},{},[280],{"type":187,"value":281},"新更新的 Baseline 包含两个关键时间点：",{"type":181,"tag":190,"props":283,"children":284},{},[285,290],{"type":181,"tag":194,"props":286,"children":287},{},[288],{"type":187,"value":289},"Newly available：所有主流浏览器开始支持某个特性",{"type":181,"tag":194,"props":291,"children":292},{},[293],{"type":187,"value":294},"Widely available：Newly available 过后的 30 个月（通常已经覆盖到 95% 的用户）",{"type":181,"tag":241,"props":296,"children":297},{},[298],{"type":181,"tag":299,"props":300,"children":301},"q",{},[302],{"type":187,"value":303},"We have also expanded the core browser set to explicitly include mobile versions of those browsers.",{"type":181,"tag":241,"props":305,"children":306},{},[307],{"type":187,"value":308},"在这个列表里，Edge 的移动端不算主流浏览器，em...",{"type":181,"tag":241,"props":310,"children":311},{},[312],{"type":181,"tag":313,"props":314,"children":317},"img",{"alt":315,"src":316},"core browser include mobile versions","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20231227012228.png",[],{"type":181,"tag":182,"props":319,"children":321},{"id":320},"浏览器插件",[322],{"type":187,"value":320},{"type":181,"tag":190,"props":324,"children":325},{},[326],{"type":181,"tag":194,"props":327,"children":328},{},[329],{"type":181,"tag":198,"props":330,"children":333},{"href":331,"rel":332},"https://developer.chrome.com/docs/extensions/reference/api?hl=zh-cn",[202],[334],{"type":187,"value":335},"Chrome Extensions API",{"type":181,"tag":182,"props":337,"children":339},{"id":338},"架构",[340],{"type":187,"value":338},{"type":181,"tag":190,"props":342,"children":343},{},[344,353],{"type":181,"tag":194,"props":345,"children":346},{},[347],{"type":181,"tag":198,"props":348,"children":350},{"href":349},"/maps/_web/browser/principle",[351],{"type":187,"value":352},"浏览器原理",{"type":181,"tag":194,"props":354,"children":355},{},[356],{"type":181,"tag":198,"props":357,"children":359},{"href":358},"/maps/_web/browser/router",[360],{"type":187,"value":361},"路由技术",{"type":181,"tag":182,"props":363,"children":365},{"id":364},"开发",[366],{"type":187,"value":364},{"type":181,"tag":266,"props":368,"children":370},{"id":369},"事件捕获机制",[371],{"type":187,"value":372},"事件捕获机制？",{"type":181,"tag":241,"props":374,"children":375},{},[376],{"type":187,"value":377},"浏览器的事件传播分为三个阶段：Capturing、Targeting、Bubbling，顺序上来说是先从根元素一直向目标元素传播，然后再由目标元素向根元素传播。事件捕获默认发生在冒泡阶段，但可以在事件监听时使用 useCapture 参数使回调在 Capture 阶段触发。",{"type":181,"tag":241,"props":379,"children":380},{},[381],{"type":181,"tag":313,"props":382,"children":385},{"alt":383,"src":384},"event processing in browser","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/event-capture.svg?w=60",[],{"type":181,"tag":266,"props":387,"children":389},{"id":388},"为什么-passive-true-能改善滚动性能",[390],{"type":187,"value":391},"为什么 passive true 能改善滚动性能？",{"type":181,"tag":241,"props":393,"children":394},{},[395],{"type":187,"value":396},"绑定了事件的 DOM 相关区域会在合成器线程中被标记为 Non-fast Scrollable Region，滚动时，需要等待可能的 JS 执行（比如说 e.preventDefault），将渲染树复合分割为磁贴后，交由栅格线程渲染，最后由 GPU 绘制到界面上。当一个事件标记了 passive: true 之后，合成器线程知悉 JS 执行不会改变滚动事件，所以可以直接走复合、栅格化、渲染的流程。",{"type":181,"tag":241,"props":398,"children":399},{},[400],{"type":187,"value":401},"passive 在 document 绑定 touchmove 或 touchstart 时默认是开启的，但是如果内部使用了 preventDefault，则会使优化失效，在控制台也会报警告。",{"type":181,"tag":266,"props":403,"children":405},{"id":404},"bfcache-是如何运作的",[406],{"type":187,"value":407},"BFCache 是如何运作的？",{"type":181,"tag":241,"props":409,"children":410},{},[411,418],{"type":181,"tag":198,"props":412,"children":415},{"href":413,"rel":414},"https://www.youtube.com/watch?v=cuPsdRckkF0",[202],[416],{"type":187,"value":417},"BFCache（Back/Forward Cache）",{"type":187,"value":419}," 是一种缓存策略。浏览器会把当前页面的快照（包括 JS Heap 快照）缓存到内存中，以便用户从当前页面导航到其它页面短暂浏览后又返回原先页面时，迅速地展现页面。",{"type":181,"tag":241,"props":421,"children":422},{},[423],{"type":187,"value":424},"为了使 BFCache 生效，不能使用 unload、beforeunload 事件，不能指明 window.open，此外，在离开前面前需要连接是关闭状态的（WS、fetch 等）。",{"type":181,"tag":241,"props":426,"children":427},{},[428,430],{"type":187,"value":429},"见：",{"type":181,"tag":198,"props":431,"children":434},{"href":432,"rel":433},"https://web.dev/bfcache",[202],[435],{"type":187,"value":436},"BFCache",{"type":181,"tag":266,"props":438,"children":440},{"id":439},"浏览器怎么跨页面通信",[441],{"type":187,"value":442},"浏览器怎么跨页面通信？",{"type":181,"tag":241,"props":444,"children":445},{},[446],{"type":187,"value":447},"考虑兼容性的话需要使用服务器中转，否则使用 Broadcast Channel 非常合适。Broadcast Channel 可以在 Workers 中使用，它能实现同源 URL 下多窗口、多标签或 iFrames 中的通信。",{"type":181,"tag":241,"props":449,"children":450},{},[451,452],{"type":187,"value":429},{"type":181,"tag":198,"props":453,"children":456},{"href":454,"rel":455},"https://developer.mozilla.org/en-US/docs/Web/API/Broadcast_Channel_API",[202],[457],{"type":187,"value":458},"Broadcast Channel",{"type":181,"tag":266,"props":460,"children":462},{"id":461},"compression-streams",[463],{"type":187,"value":464},"Compression Streams",{"type":181,"tag":190,"props":466,"children":467},{},[468],{"type":181,"tag":194,"props":469,"children":470},{},[471,473],{"type":187,"value":472},"Compression Streams：",{"type":181,"tag":198,"props":474,"children":477},{"href":475,"rel":476},"https://web.dev/blog/compressionstreams?hl=en",[202],[478],{"type":187,"value":479},"Compression Streams are now supported on all browsers",{"type":181,"tag":266,"props":481,"children":483},{"id":482},"eventsource",[484],{"type":187,"value":485},"EventSource",{"type":181,"tag":241,"props":487,"children":488},{},[489],{"type":187,"value":490},"EventSource 是一个基于 HTTP 协议，能在浏览器端自动重连的服务端推送协议。常用于股票、天气等服务端需要实时向客户端推送消息的场景。",{"type":181,"tag":241,"props":492,"children":493},{},[494,495],{"type":187,"value":429},{"type":181,"tag":198,"props":496,"children":499},{"href":497,"rel":498},"https://github.com/Lionad-Morotar/read-source-code/blob/6e866c893fc1edb3fa2da1979af0c1b252f81da5/api/event-source/index.html",[202],[500],{"type":187,"value":501},"Event Source API Test",{"type":181,"tag":182,"props":503,"children":505},{"id":504},"调试",[506],{"type":187,"value":504},{"type":181,"tag":266,"props":508,"children":510},{"id":509},"代码覆盖率怎么看",[511],{"type":187,"value":512},"代码覆盖率怎么看？",{"type":181,"tag":241,"props":514,"children":515},{},[516],{"type":187,"value":517},"通过代码覆盖率选项查看某个页面或某流程中，执行到的 JS 和 CSS 代码的百分比。可以用来优化首屏等场景。",{"type":181,"tag":241,"props":519,"children":520},{},[521],{"type":181,"tag":313,"props":522,"children":525},{"alt":523,"src":524},"Code Coverage","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220704211729.png",[],{"title":175,"searchDepth":527,"depth":527,"links":528},2,[529,530,531,532,533,534,535],{"id":184,"depth":527,"text":188},{"id":208,"depth":527,"text":211},{"id":236,"depth":527,"text":239},{"id":320,"depth":527,"text":320},{"id":338,"depth":527,"text":338},{"id":364,"depth":527,"text":364},{"id":504,"depth":527,"text":504},"markdown","content:6.maps:_web:browser:index.md","content","6.maps/_web/browser/index.md","6.maps/_web/browser/index","md",[543,547],{"_path":544,"title":545,"description":546},"/maps/_web/browser-api/crypto","Web Crypto API","Web Crypto API 是一个 JavaScript 接口，用于在浏览器中执行加密操作。",{"_path":220,"title":548,"description":549},"浏览器新特性","Web.dev 月刊精选，追踪和总结主流浏览器的最新特性更新与时动态。",1771214187752]