date-for-baseline",[273],{"type":184,"tag":201,"props":274,"children":277},{"href":275,"rel":276},"https://web.dev/blog/baseline-definition-update?hl=en",[205],[278],{"type":190,"value":279},"A definition update for Baseline",{"type":184,"tag":244,"props":281,"children":282},{},[283],{"type":190,"value":284},"新更新的 Baseline 包含两个关键时间点：",{"type":184,"tag":193,"props":286,"children":287},{},[288,293],{"type":184,"tag":197,"props":289,"children":290},{},[291],{"type":190,"value":292},"Newly available：所有主流浏览器开始支持某个特性",{"type":184,"tag":197,"props":294,"children":295},{},[296],{"type":190,"value":297},"Widely available：Newly available 过后的 30 个月（通常已经覆盖到 95% 的用户）",{"type":184,"tag":244,"props":299,"children":300},{},[301],{"type":184,"tag":302,"props":303,"children":304},"q",{},[305],{"type":190,"value":306},"We have also expanded the core browser set to explicitly include mobile versions of those browsers.",{"type":184,"tag":244,"props":308,"children":309},{},[310],{"type":190,"value":311},"在这个列表里，Edge 的移动端不算主流浏览器，em...",{"type":184,"tag":244,"props":313,"children":314},{},[315],{"type":184,"tag":316,"props":317,"children":320},"img",{"alt":318,"src":319},"core browser include mobile versions","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20231227012228.png",[],{"type":184,"tag":185,"props":322,"children":324},{"id":323},"浏览器插件",[325],{"type":190,"value":323},{"type":184,"tag":193,"props":327,"children":328},{},[329],{"type":184,"tag":197,"props":330,"children":331},{},[332],{"type":184,"tag":201,"props":333,"children":336},{"href":334,"rel":335},"https://developer.chrome.com/docs/extensions/reference/api?hl=zh-cn",[205],[337],{"type":190,"value":338},"Chrome Extensions API",{"type":184,"tag":185,"props":340,"children":342},{"id":341},"架构",[343],{"type":190,"value":341},{"type":184,"tag":193,"props":345,"children":346},{},[347,356],{"type":184,"tag":197,"props":348,"children":349},{},[350],{"type":184,"tag":201,"props":351,"children":353},{"href":352},"/maps/_web/browser/principle",[354],{"type":190,"value":355},"浏览器原理",{"type":184,"tag":197,"props":357,"children":358},{},[359],{"type":184,"tag":201,"props":360,"children":362},{"href":361},"/maps/_web/browser/router",[363],{"type":190,"value":364},"路由技术",{"type":184,"tag":185,"props":366,"children":368},{"id":367},"开发",[369],{"type":190,"value":367},{"type":184,"tag":269,"props":371,"children":373},{"id":372},"事件捕获机制",[374],{"type":190,"value":375},"事件捕获机制？",{"type":184,"tag":244,"props":377,"children":378},{},[379],{"type":190,"value":380},"浏览器的事件传播分为三个阶段：Capturing、Targeting、Bubbling，顺序上来说是先从根元素一直向目标元素传播，然后再由目标元素向根元素传播。事件捕获默认发生在冒泡阶段，但可以在事件监听时使用 useCapture 参数使回调在 Capture 阶段触发。",{"type":184,"tag":244,"props":382,"children":383},{},[384],{"type":184,"tag":316,"props":385,"children":388},{"alt":386,"src":387},"event processing in browser","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/event-capture.svg?w=60",[],{"type":184,"tag":269,"props":390,"children":392},{"id":391},"为什么-passive-true-能改善滚动性能",[393],{"type":190,"value":394},"为什么 passive true 能改善滚动性能？",{"type":184,"tag":244,"props":396,"children":397},{},[398],{"type":190,"value":399},"绑定了事件的 DOM 相关区域会在合成器线程中被标记为 Non-fast Scrollable Region，滚动时，需要等待可能的 JS 执行（比如说 e.preventDefault），将渲染树复合分割为磁贴后，交由栅格线程渲染，最后由 GPU 绘制到界面上。当一个事件标记了 passive: true 之后，合成器线程知悉 JS 执行不会改变滚动事件，所以可以直接走复合、栅格化、渲染的流程。",{"type":184,"tag":244,"props":401,"children":402},{},[403],{"type":190,"value":404},"passive 在 document 绑定 touchmove 或 touchstart 时默认是开启的，但是如果内部使用了 preventDefault，则会使优化失效，在控制台也会报警告。",{"type":184,"tag":269,"props":406,"children":408},{"id":407},"bfcache-是如何运作的",[409],{"type":190,"value":410},"BFCache 是如何运作的？",{"type":184,"tag":244,"props":412,"children":413},{},[414,421],{"type":184,"tag":201,"props":415,"children":418},{"href":416,"rel":417},"https://www.youtube.com/watch?v=cuPsdRckkF0",[205],[419],{"type":190,"value":420},"BFCache（Back/Forward Cache）",{"type":190,"value":422}," 是一种缓存策略。浏览器会把当前页面的快照（包括 JS Heap 快照）缓存到内存中，以便用户从当前页面导航到其它页面短暂浏览后又返回原先页面时，迅速地展现页面。",{"type":184,"tag":244,"props":424,"children":425},{},[426],{"type":190,"value":427},"为了使 BFCache 生效，不能使用 unload、beforeunload 事件，不能指明 window.open，此外，在离开前面前需要连接是关闭状态的（WS、fetch 等）。",{"type":184,"tag":244,"props":429,"children":430},{},[431,433],{"type":190,"value":432},"见：",{"type":184,"tag":201,"props":434,"children":437},{"href":435,"rel":436},"https://web.dev/bfcache",[205],[438],{"type":190,"value":439},"BFCache",{"type":184,"tag":269,"props":441,"children":443},{"id":442},"浏览器怎么跨页面通信",[444],{"type":190,"value":445},"浏览器怎么跨页面通信？",{"type":184,"tag":244,"props":447,"children":448},{},[449],{"type":190,"value":450},"考虑兼容性的话需要使用服务器中转，否则使用 Broadcast Channel 非常合适。Broadcast Channel 可以在 Workers 中使用，它能实现同源 URL 下多窗口、多标签或 iFrames 中的通信。",{"type":184,"tag":244,"props":452,"children":453},{},[454,455],{"type":190,"value":432},{"type":184,"tag":201,"props":456,"children":459},{"href":457,"rel":458},"https://developer.mozilla.org/en-US/docs/Web/API/Broadcast_Channel_API",[205],[460],{"type":190,"value":461},"Broadcast Channel",{"type":184,"tag":269,"props":463,"children":465},{"id":464},"compression-streams",[466],{"type":190,"value":467},"Compression Streams",{"type":184,"tag":193,"props":469,"children":470},{},[471],{"type":184,"tag":197,"props":472,"children":473},{},[474,476],{"type":190,"value":475},"Compression Streams：",{"type":184,"tag":201,"props":477,"children":480},{"href":478,"rel":479},"https://web.dev/blog/compressionstreams?hl=en",[205],[481],{"type":190,"value":482},"Compression Streams are now supported on all browsers",{"type":184,"tag":269,"props":484,"children":486},{"id":485},"eventsource",[487],{"type":190,"value":488},"EventSource",{"type":184,"tag":244,"props":490,"children":491},{},[492],{"type":190,"value":493},"EventSource 是一个基于 HTTP 协议，能在浏览器端自动重连的服务端推送协议。常用于股票、天气等服务端需要实时向客户端推送消息的场景。",{"type":184,"tag":244,"props":495,"children":496},{},[497,498],{"type":190,"value":432},{"type":184,"tag":201,"props":499,"children":502},{"href":500,"rel":501},"https://github.com/Lionad-Morotar/read-source-code/blob/6e866c893fc1edb3fa2da1979af0c1b252f81da5/api/event-source/index.html",[205],[503],{"type":190,"value":504},"Event Source API Test",{"type":184,"tag":185,"props":506,"children":508},{"id":507},"调试",[509],{"type":190,"value":507},{"type":184,"tag":269,"props":511,"children":513},{"id":512},"代码覆盖率怎么看",[514],{"type":190,"value":515},"代码覆盖率怎么看？",{"type":184,"tag":244,"props":517,"children":518},{},[519],{"type":190,"value":520},"通过代码覆盖率选项查看某个页面或某流程中，执行到的 JS 和 CSS 代码的百分比。可以用来优化首屏等场景。",{"type":184,"tag":244,"props":522,"children":523},{},[524],{"type":184,"tag":316,"props":525,"children":528},{"alt":526,"src":527},"Code Coverage","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220704211729.png",[],{"title":178,"searchDepth":530,"depth":530,"links":531},2,[532,533,534,535,536,537,538],{"id":187,"depth":530,"text":191},{"id":211,"depth":530,"text":214},{"id":239,"depth":530,"text":242},{"id":323,"depth":530,"text":323},{"id":341,"depth":530,"text":341},{"id":367,"depth":530,"text":367},{"id":507,"depth":530,"text":507},"markdown","content:6.maps:_web:browser:index.md","content","6.maps/_web/browser/index.md","6.maps/_web/browser/index","md",[546,550],{"_path":547,"title":548,"description":549},"/maps/_web/browser-api/crypto","Web Crypto API","Web Crypto API 是一个 JavaScript 接口，用于在浏览器中执行加密操作。",{"_path":223,"title":551,"description":552},"浏览器新特性","Web.dev 月刊精选，追踪和总结主流浏览器的最新特性更新与时动态。",1771304509221]