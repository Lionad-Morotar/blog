,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"original_path":181,"body":182,"_type":762,"_id":763,"_source":764,"_file":765,"_stem":766,"_extension":767},"/maps/_web/browser/principle","browser",false,true,"","浏览器相关","浏览器相关问题","content/6.maps/_web/browser/principle.md",{"type":183,"children":184,"toc":753},"root",[185,193,200,263,268,274,284,290,295,301,306,312,317,323,328,334,339,345,350,355,360,388,393,399,404,409,414,419,424,429,435,440,446,451,457,482,487,510,516,521,526,539,546,551,557,562,567,573,578,584,589,597,603,608,614,619,631,636],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"经典问题",[191],{"type":192,"value":189},"text",{"type":186,"tag":194,"props":195,"children":197},"h4",{"id":196},"从输入-url-到页面显示的过程",[198],{"type":192,"value":199},"从输入 URL 到页面显示的过程？",{"type":186,"tag":201,"props":202,"children":203},"ol",{},[204,210,215,220,232,237,242,247,258],{"type":186,"tag":205,"props":206,"children":207},"li",{},[208],{"type":192,"value":209},"浏览器进程响应键鼠操作，将 URL 传递给网络线程准备进行请求。",{"type":186,"tag":205,"props":211,"children":212},{},[213],{"type":192,"value":214},"根据 Expired、Cache-Control 查看缓存是否过期。如果已过期，则携带 If-Modified-Since、If-Match 字段准备发起请求。",{"type":186,"tag":205,"props":216,"children":217},{},[218],{"type":192,"value":219},"解析域名，DNS 查址。涉及浏览器、操作系统、HOSTS、路由器、各级 DNS 服务器缓存。",{"type":186,"tag":205,"props":221,"children":222},{},[223,225],{"type":192,"value":224},"如果是请求 CDN 中的资源，见：",{"type":186,"tag":226,"props":227,"children":229},"a",{"href":228},"#%E8%AF%B7%E6%B1%82-cdn-%E4%B8%AD%E7%9A%84%E8%B5%84%E6%BA%90%E7%9A%84%E6%B5%81%E7%A8%8B%E6%98%AF%E6%80%8E%E6%A0%B7%E7%9A%84",[230],{"type":192,"value":231},"请求 CDN 中的资源的流程是怎样的？",{"type":186,"tag":205,"props":233,"children":234},{},[235],{"type":192,"value":236},"建立 TCP 链接。如果是 HTTPS，涉及 HTTPS 握手过程和 CA 认证过程。",{"type":186,"tag":205,"props":238,"children":239},{},[240],{"type":192,"value":241},"服务器收到请求，根据 Nginx 重新向到具体文件后，检查 If-Modified-Since、If-Match 字段。缓存新鲜则返回 304，否则计算并设置 Etag 返回最新资源。",{"type":186,"tag":205,"props":243,"children":244},{},[245],{"type":192,"value":246},"浏览器根据响应，缓存资源。",{"type":186,"tag":205,"props":248,"children":249},{},[250,252],{"type":192,"value":251},"渲染进程开始渲染，见：",{"type":186,"tag":226,"props":253,"children":255},{"href":254},"#%E6%B8%B2%E6%9F%93%E8%BF%9B%E7%A8%8B%E7%9A%84%E5%A4%A7%E8%87%B4%E5%B7%A5%E4%BD%9C%E6%B5%81%E7%A8%8B%E6%98%AF%E6%80%8E%E6%A0%B7%E7%9A%84",[256],{"type":192,"value":257},"渲染进程的大致工作流程是怎样的？",{"type":186,"tag":205,"props":259,"children":260},{},[261],{"type":192,"value":262},"渲染结束，所以资源加载完毕，触发 onload 事件。",{"type":186,"tag":187,"props":264,"children":266},{"id":265},"组成原理",[267],{"type":192,"value":265},{"type":186,"tag":194,"props":269,"children":271},{"id":270},"浏览器有哪些组件-浏览器架构",[272],{"type":192,"value":273},"浏览器有哪些组件 / 浏览器架构？",{"type":186,"tag":275,"props":276,"children":277},"p",{},[278],{"type":186,"tag":279,"props":280,"children":283},"img",{"alt":281,"src":282},"浏览器的主要组件","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200811234200.png",[],{"type":186,"tag":194,"props":285,"children":287},{"id":286},"进程和线程的区别是什么",[288],{"type":192,"value":289},"进程和线程的区别是什么？",{"type":186,"tag":275,"props":291,"children":292},{},[293],{"type":192,"value":294},"进程是系统分配资源的最小单位，线程是 CPU 调度的最小单位。线程间资源独立，但是启动、切换和通讯代价较大。线程间资源共享，但一个卡死全员卡死。",{"type":186,"tag":194,"props":296,"children":298},{"id":297},"浏览器的进程线程结构是怎么样的",[299],{"type":192,"value":300},"浏览器的进程线程结构是怎么样的？",{"type":186,"tag":275,"props":302,"children":303},{},[304],{"type":192,"value":305},"一般浏览器由主进程（浏览器进程）、渲染进程（浏览器内核）、插件进程和 GPU 进程组成。和页面渲染相关的是渲染进程，一般由网络请求线程、脚本引擎线程、GUI 渲染线程、合成器线程、光栅线程、事件触发线程、定时器线程和 Worker 线程组成。",{"type":186,"tag":194,"props":307,"children":309},{"id":308},"每个页面都有一个对应的渲染进程吗",[310],{"type":192,"value":311},"每个页面都有一个对应的渲染进程吗？",{"type":186,"tag":275,"props":313,"children":314},{},[315],{"type":192,"value":316},"一般来说是的，给页面一个独立的渲染进程，可以保证该页面崩溃的时候不会影响其它页面。如果页面内有跨站 iFrame，那么会由新的渲染进程接管，这样更安全。此外，由于创建和维持页面的渲染进程需要消耗大量内存，所以浏览器的实践是在进程数达到一定限制后，新页面会共享老页面的渲染进程。",{"type":186,"tag":194,"props":318,"children":320},{"id":319},"service-worker-是如何工作的",[321],{"type":192,"value":322},"Service Worker 是如何工作的？",{"type":186,"tag":275,"props":324,"children":325},{},[326],{"type":192,"value":327},"注册 Service Worker 时，浏览器会保存其作用域。每当请求一个新的资源时，浏览器通过比对资源 URL 是否在某个 Service Worker 的职责中。如果是，会在渲染进程中执行 Service Worker 代码，它可能中缓存中加载数据（同时中止网络请求），也可能从网上请求新的资源。",{"type":186,"tag":194,"props":329,"children":331},{"id":330},"为什么渲染和脚本执行不可以同时进行",[332],{"type":192,"value":333},"为什么渲染和脚本执行不可以同时进行？",{"type":186,"tag":275,"props":335,"children":336},{},[337],{"type":192,"value":338},"由于 JS 执行过程中可能操作 DOM，所以为了防止渲染时同时执行脚本导致前后结果的不一致，脚本线程和 GUI 线程被设计为互斥的：JS 执行时 GUI 会被挂起，等到 JS 线程空闲 GUI 才会更新。",{"type":186,"tag":194,"props":340,"children":342},{"id":341},"webworker-和-sharedworker-的资源是谁来管理的",[343],{"type":192,"value":344},"WebWorker 和 SharedWorker 的资源是谁来管理的？",{"type":186,"tag":275,"props":346,"children":347},{},[348],{"type":192,"value":349},"WebWorker 由当前页面进程管理，它是一个新的线程；SharedWorker 由浏览器的 SharedWorker 进程管理。",{"type":186,"tag":187,"props":351,"children":353},{"id":352},"网络请求",[354],{"type":192,"value":352},{"type":186,"tag":194,"props":356,"children":358},{"id":357},"请求-cdn-中的资源的流程是怎样的",[359],{"type":192,"value":231},{"type":186,"tag":201,"props":361,"children":362},{},[363,368,373,378,383],{"type":186,"tag":205,"props":364,"children":365},{},[366],{"type":192,"value":367},"发请求，本地 DNS 服务器根据记录将请求重定向到 CDN 专用的 DNS 服务器",{"type":186,"tag":205,"props":369,"children":370},{},[371],{"type":192,"value":372},"CDN 专用 DNS 服务器将全局负载均衡服务器的 IP 地址返回给用户",{"type":186,"tag":205,"props":374,"children":375},{},[376],{"type":192,"value":377},"发请求，负载均衡根据用户 IP 将区域负载均衡设备 IP 地址返回给用户",{"type":186,"tag":205,"props":379,"children":380},{},[381],{"type":192,"value":382},"发请求，区域负载均衡设备将缓存服务器 IP 地址返回给用户",{"type":186,"tag":205,"props":384,"children":385},{},[386],{"type":192,"value":387},"发请求，根据各级缓存服务器查找对应资源",{"type":186,"tag":187,"props":389,"children":391},{"id":390},"解析",[392],{"type":192,"value":390},{"type":186,"tag":194,"props":394,"children":396},{"id":395},"浏览器怎么根据请求的文件类型来进一步处理",[397],{"type":192,"value":398},"浏览器怎么根据请求的文件类型来进一步处理？",{"type":186,"tag":275,"props":400,"children":401},{},[402],{"type":192,"value":403},"可以根据 HTTP Header 中携带的 Content-Type 或是 MIME 嗅探技术来判断文件类型。如果是 HTML 之类的文档则交由渲染进程，如果是其他文件，则转交给下载管理器。",{"type":186,"tag":194,"props":405,"children":407},{"id":406},"渲染进程的大致工作流程是怎样的",[408],{"type":192,"value":257},{"type":186,"tag":275,"props":410,"children":411},{},[412],{"type":192,"value":413},"具体工作流程因浏览器而异，但总体而言都是要解析文档与资源并将其渲染至屏幕。总的来说分为解析、构建、布局和渲染四个步骤。",{"type":186,"tag":275,"props":415,"children":416},{},[417],{"type":192,"value":418},"渲染引擎会从网络线程中逐缓存区地取出文档（8KB）进行解析。",{"type":186,"tag":275,"props":420,"children":421},{},[422],{"type":192,"value":423},"解析分 HTML、CSS 和 JS。解析 HTML 时是一个从字符流到标记（Tokenizing），再到带属性对象（Lexing），最后组成 DOM Tree 的过程。解析 CSS 类似，最后会组成 CSSOM Tree。如果是普通脚本，解析时会阻塞 DOM Tree 和 CSSOM Tree 的构建。",{"type":186,"tag":275,"props":425,"children":426},{},[427],{"type":192,"value":428},"当 DOM Tree 和 CSSOM Tree 准备好后，依据 CSS 规范构建渲染树。渲染树将会被带入布局处理，计算节点在屏幕上的精确坐标，随后在图层合层过程中分割为磁贴，并交由栅格线程栅格化并储存在显存中。最后，由浏览器主进程通知渲染 GPU 进程渲染页面。",{"type":186,"tag":194,"props":430,"children":432},{"id":431},"为什么解析-html-无法使用自上而下或自下而上的解析器",[433],{"type":192,"value":434},"为什么解析 HTML 无法使用自上而下或自下而上的解析器？",{"type":186,"tag":275,"props":436,"children":437},{},[438],{"type":192,"value":439},"TODO。主要是因为其语言规范宽松，并且内容在解析时可能发生改变。",{"type":186,"tag":194,"props":441,"children":443},{"id":442},"碰到错误的标签会怎么处理",[444],{"type":192,"value":445},"碰到错误的标签会怎么处理？",{"type":186,"tag":275,"props":447,"children":448},{},[449],{"type":192,"value":450},"看具体的浏览器。一般来说，碰到错误的内容，解析器和 DOM Tree 的构建过程都会想方设法去揣摩正确的代码。浏览器是很包容的。",{"type":186,"tag":194,"props":452,"children":454},{"id":453},"css-解析和-html-的有什么不同",[455],{"type":192,"value":456},"CSS 解析和 HTML 的有什么不同？",{"type":186,"tag":275,"props":458,"children":459},{},[460,462,468,470,474,476,480],{"type":192,"value":461},"因为 CSS 的语法上下文无关，所以可以使用传统的解析器进行解析，比如 WebKit 使用 Bison 解析 CSS。CSS 的词法及语法都由 CSS 规范定义好了。词法用正则描述，比如 num: ",{"type":186,"tag":463,"props":464,"children":465},"span",{},[466],{"type":192,"value":467},"0-9",{"type":192,"value":469},"+|",{"type":186,"tag":463,"props":471,"children":472},{},[473],{"type":192,"value":467},{"type":192,"value":475},"*.",{"type":186,"tag":463,"props":477,"children":478},{},[479],{"type":192,"value":467},{"type":192,"value":481},"+，语法则用 BNF（巴科斯范式）描述。",{"type":186,"tag":275,"props":483,"children":484},{},[485],{"type":192,"value":486},"TODO:",{"type":186,"tag":488,"props":489,"children":490},"ul",{},[491,501],{"type":186,"tag":205,"props":492,"children":493},{},[494],{"type":186,"tag":226,"props":495,"children":499},{"href":496,"rel":497},"https://zhuanlan.zhihu.com/p/31311515",[498],"nofollow",[500],{"type":192,"value":496},{"type":186,"tag":205,"props":502,"children":503},{},[504],{"type":186,"tag":226,"props":505,"children":508},{"href":506,"rel":507},"https://zhuanlan.zhihu.com/p/358518402",[498],[509],{"type":192,"value":506},{"type":186,"tag":194,"props":511,"children":513},{"id":512},"构建渲染树时用了什么优化策略",[514],{"type":192,"value":515},"构建渲染树时用了什么优化策略？",{"type":186,"tag":275,"props":517,"children":518},{},[519],{"type":192,"value":520},"样式计算是一个复杂操作，因为 DOM Tree 和 CSSOM Tree 都是树状结构。DOM 元素都携带了样式属性，这会消耗了大量的内存，并且，样式的嵌套和层叠会引发计算性能问题。",{"type":186,"tag":275,"props":522,"children":523},{},[524],{"type":192,"value":525},"WebKit 使用共享渲染样式对象来优化，但要求元素类名相同、属性及值相同，且不能由 Inline，且不能使用 ID 选择器、属性选择器、同级选择器。",{"type":186,"tag":275,"props":527,"children":528},{},[529,531,537],{"type":192,"value":530},"Firefox 使用了",{"type":186,"tag":532,"props":533,"children":534},"strong",{},[535],{"type":192,"value":536},"规则树",{"type":192,"value":538},"这一方案。TODO",{"type":186,"tag":275,"props":540,"children":541},{},[542],{"type":186,"tag":279,"props":543,"children":545},{"alt":536,"src":544},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200813142147.png",[],{"type":186,"tag":187,"props":547,"children":549},{"id":548},"渲染",[550],{"type":192,"value":548},{"type":186,"tag":194,"props":552,"children":554},{"id":553},"如何避免重绘与回流",[555],{"type":192,"value":556},"如何避免重绘与回流？",{"type":186,"tag":275,"props":558,"children":559},{},[560],{"type":192,"value":561},"渲染树将会被带入布局处理，计算节点在屏幕上的精确坐标，随后在图层合层过程中分割为磁贴，并交由栅格线程栅格化并储存在显存中。如果更改了节点宽高等属性，可能需要从新计算渲染树，然后从布局开始执行逻辑，这叫做回流。如果只是改动节点的文字颜色等属性，只要从重新绘制单个节点开始，这叫做重绘。所以避免回流和重绘，需要减少更改样式的频率，或者换方式实现。",{"type":186,"tag":275,"props":563,"children":564},{},[565],{"type":192,"value":566},"浏览器会用一个队列缓存频繁的重绘和回流相关操作，但是如果用了 getComputedStyle、getBoundingRect 接口，会立即清空队列，所以频繁使用此类接口是有害性能的。",{"type":186,"tag":194,"props":568,"children":570},{"id":569},"domcontentloaded-和-onload-事件先后顺序是",[571],{"type":192,"value":572},"DOMContentLoaded 和 onload 事件先后顺序是？",{"type":186,"tag":275,"props":574,"children":575},{},[576],{"type":192,"value":577},"所有同步脚本执行完，DOM Tree 构建好之后，触发 DOMContentLoaded。所有样式、图片都加载完了才会触发 window.onload。",{"type":186,"tag":194,"props":579,"children":581},{"id":580},"复合composite是什么",[582],{"type":192,"value":583},"复合（Composite）是什么？",{"type":186,"tag":275,"props":585,"children":586},{},[587],{"type":192,"value":588},"复合是将页面分割为不同的图层，分别栅格化，然后组合为帧的流程。",{"type":186,"tag":275,"props":590,"children":591},{},[592],{"type":186,"tag":279,"props":593,"children":596},{"alt":594,"src":595},"Composite Thread","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220627000101.png",[],{"type":186,"tag":194,"props":598,"children":600},{"id":599},"图层是什么",[601],{"type":192,"value":602},"图层是什么？",{"type":186,"tag":275,"props":604,"children":605},{},[606],{"type":192,"value":607},"图层是用来管理渲染树的一种结构。在一个图层中的渲染树的所有节点都会经过布局再交给 GPU 绘制，若 DOM 元素发生改变，可能会引起相应图层中的回流与重绘。可以通过通过 translate3D、will-change 等方式创建新图层（复合图层），这样一来相关元素会被单独绘制，不会影响默认图层。",{"type":186,"tag":194,"props":609,"children":611},{"id":610},"浏览器硬件加速是指什么",[612],{"type":192,"value":613},"浏览器硬件加速是指什么？",{"type":186,"tag":275,"props":615,"children":616},{},[617],{"type":192,"value":618},"硬件加速是通过指定 transform、opacity、filter 等 CSS 属性，使浏览器使用很大并行计算能力的 GPU 替 CPU 分担这些元素的渲染工作，降低 CPU 负载，达到渲染更加流畅的效果。使用硬件加速的图层都会使用新图层绘制，所以为了提前告知浏览器，将元素直接渲染至新图层，而不是从默认图层中拷贝过去，可以使用 will-change 属性明示。",{"type":186,"tag":275,"props":620,"children":621},{},[622,624],{"type":192,"value":623},"见：",{"type":186,"tag":226,"props":625,"children":628},{"href":626,"rel":627},"https://zhuanlan.zhihu.com/p/404656386",[498],[629],{"type":192,"value":630},"搞懂 GPU 和 CSS 硬件加速",{"type":186,"tag":187,"props":632,"children":634},{"id":633},"阅读更多",[635],{"type":192,"value":633},{"type":186,"tag":488,"props":637,"children":638},{},[639,649,659,669,679,691,703,713,723,733,743],{"type":186,"tag":205,"props":640,"children":641},{},[642],{"type":186,"tag":226,"props":643,"children":646},{"href":644,"rel":645},"https://www.html5rocks.com/zh/tutorials/internals/howbrowserswork/",[498],[647],{"type":192,"value":648},"浏览器的工作原理：新式网络浏览器幕后揭秘",{"type":186,"tag":205,"props":650,"children":651},{},[652],{"type":186,"tag":226,"props":653,"children":656},{"href":654,"rel":655},"https://html.spec.whatwg.org/multipage/parsing.html#parsing",[498],[657],{"type":192,"value":658},"HTML SPEC",{"type":186,"tag":205,"props":660,"children":661},{},[662],{"type":186,"tag":226,"props":663,"children":666},{"href":664,"rel":665},"https://www.w3.org/TR/selectors-3/#grammar",[498],[667],{"type":192,"value":668},"CSS Selectors Level 3",{"type":186,"tag":205,"props":670,"children":671},{},[672],{"type":186,"tag":226,"props":673,"children":676},{"href":674,"rel":675},"https://developer.chrome.com/blog/inside-browser-part1/",[498],[677],{"type":192,"value":678},"Inside look at modern web browser (part 1)",{"type":186,"tag":205,"props":680,"children":681},{},[682,689],{"type":186,"tag":226,"props":683,"children":686},{"href":684,"rel":685},"https://zhuanlan.zhihu.com/p/47407398",[498],[687],{"type":192,"value":688},"图解浏览器的基本工作原理",{"type":192,"value":690},"，现代浏览器内部原理系列的中文翻译其一。",{"type":186,"tag":205,"props":692,"children":693},{},[694,701],{"type":186,"tag":226,"props":695,"children":698},{"href":696,"rel":697},"https://www.starryskystar.space/detail/612beeddf1daf402f34f4fa5",[498],[699],{"type":192,"value":700},"浏览器地址栏中输入 URL 到页面显示，浏览器到底发生了什么？",{"type":192,"value":702},"，综合笔记。",{"type":186,"tag":205,"props":704,"children":705},{},[706],{"type":186,"tag":226,"props":707,"children":710},{"href":708,"rel":709},"https://juejin.im/post/59e85eebf265da430d571f89",[498],[711],{"type":192,"value":712},"这一次，彻底弄懂 JavaScript 执行机制",{"type":186,"tag":205,"props":714,"children":715},{},[716],{"type":186,"tag":226,"props":717,"children":720},{"href":718,"rel":719},"https://javascript.ruanyifeng.com/oop/basic.html",[498],[721],{"type":192,"value":722},"构造函数与 new 命令",{"type":186,"tag":205,"props":724,"children":725},{},[726],{"type":186,"tag":226,"props":727,"children":730},{"href":728,"rel":729},"http://newhtml.net/v8-garbage-collection/",[498],[731],{"type":192,"value":732},"V8 之旅：垃圾回收器",{"type":186,"tag":205,"props":734,"children":735},{},[736],{"type":186,"tag":226,"props":737,"children":740},{"href":738,"rel":739},"https://v8.dev/blog/concurrent-marking",[498],[741],{"type":192,"value":742},"Concurrent marking in V8",{"type":186,"tag":205,"props":744,"children":745},{},[746],{"type":186,"tag":226,"props":747,"children":750},{"href":748,"rel":749},"https://juejin.im/post/59fbdb46f265da4321536565",[498],[751],{"type":192,"value":752},"内存分析与内存泄漏定位",{"title":178,"searchDepth":754,"depth":754,"links":755},2,[756,757,758,759,760,761],{"id":189,"depth":754,"text":189},{"id":265,"depth":754,"text":265},{"id":352,"depth":754,"text":352},{"id":390,"depth":754,"text":390},{"id":548,"depth":754,"text":548},{"id":633,"depth":754,"text":633},"markdown","content:6.maps:_web:browser:principle.md","content","6.maps/_web/browser/principle.md","6.maps/_web/browser/principle","md",[769,773],{"_path":770,"title":771,"description":772},"/maps/_web/browser/new","浏览器新特性","Web.dev 月刊精选，追踪和总结主流浏览器的最新特性更新与时动态。",{"_path":774,"title":775,"description":776},"/maps/_web/browser/router","路由技术","Web 前端路由技术详解，包含 Hash 路由、History 路由的实现原理与最佳实践。",1772504926922]