,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"body":181,"_type":761,"_id":762,"_source":763,"_file":764,"_stem":765,"_extension":766},"/maps/_web/browser/principle","browser",false,true,"","浏览器相关","浏览器相关问题",{"type":182,"children":183,"toc":752},"root",[184,192,199,262,267,273,283,289,294,300,305,311,316,322,327,333,338,344,349,354,359,387,392,398,403,408,413,418,423,428,434,439,445,450,456,481,486,509,515,520,525,538,545,550,556,561,566,572,577,583,588,596,602,607,613,618,630,635],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"经典问题",[190],{"type":191,"value":188},"text",{"type":185,"tag":193,"props":194,"children":196},"h4",{"id":195},"从输入-url-到页面显示的过程",[197],{"type":191,"value":198},"从输入 URL 到页面显示的过程？",{"type":185,"tag":200,"props":201,"children":202},"ol",{},[203,209,214,219,231,236,241,246,257],{"type":185,"tag":204,"props":205,"children":206},"li",{},[207],{"type":191,"value":208},"浏览器进程响应键鼠操作，将 URL 传递给网络线程准备进行请求。",{"type":185,"tag":204,"props":210,"children":211},{},[212],{"type":191,"value":213},"根据 Expired、Cache-Control 查看缓存是否过期。如果已过期，则携带 If-Modified-Since、If-Match 字段准备发起请求。",{"type":185,"tag":204,"props":215,"children":216},{},[217],{"type":191,"value":218},"解析域名，DNS 查址。涉及浏览器、操作系统、HOSTS、路由器、各级 DNS 服务器缓存。",{"type":185,"tag":204,"props":220,"children":221},{},[222,224],{"type":191,"value":223},"如果是请求 CDN 中的资源，见：",{"type":185,"tag":225,"props":226,"children":228},"a",{"href":227},"#%E8%AF%B7%E6%B1%82-cdn-%E4%B8%AD%E7%9A%84%E8%B5%84%E6%BA%90%E7%9A%84%E6%B5%81%E7%A8%8B%E6%98%AF%E6%80%8E%E6%A0%B7%E7%9A%84",[229],{"type":191,"value":230},"请求 CDN 中的资源的流程是怎样的？",{"type":185,"tag":204,"props":232,"children":233},{},[234],{"type":191,"value":235},"建立 TCP 链接。如果是 HTTPS，涉及 HTTPS 握手过程和 CA 认证过程。",{"type":185,"tag":204,"props":237,"children":238},{},[239],{"type":191,"value":240},"服务器收到请求，根据 Nginx 重新向到具体文件后，检查 If-Modified-Since、If-Match 字段。缓存新鲜则返回 304，否则计算并设置 Etag 返回最新资源。",{"type":185,"tag":204,"props":242,"children":243},{},[244],{"type":191,"value":245},"浏览器根据响应，缓存资源。",{"type":185,"tag":204,"props":247,"children":248},{},[249,251],{"type":191,"value":250},"渲染进程开始渲染，见：",{"type":185,"tag":225,"props":252,"children":254},{"href":253},"#%E6%B8%B2%E6%9F%93%E8%BF%9B%E7%A8%8B%E7%9A%84%E5%A4%A7%E8%87%B4%E5%B7%A5%E4%BD%9C%E6%B5%81%E7%A8%8B%E6%98%AF%E6%80%8E%E6%A0%B7%E7%9A%84",[255],{"type":191,"value":256},"渲染进程的大致工作流程是怎样的？",{"type":185,"tag":204,"props":258,"children":259},{},[260],{"type":191,"value":261},"渲染结束，所以资源加载完毕，触发 onload 事件。",{"type":185,"tag":186,"props":263,"children":265},{"id":264},"组成原理",[266],{"type":191,"value":264},{"type":185,"tag":193,"props":268,"children":270},{"id":269},"浏览器有哪些组件-浏览器架构",[271],{"type":191,"value":272},"浏览器有哪些组件 / 浏览器架构？",{"type":185,"tag":274,"props":275,"children":276},"p",{},[277],{"type":185,"tag":278,"props":279,"children":282},"img",{"alt":280,"src":281},"浏览器的主要组件","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200811234200.png",[],{"type":185,"tag":193,"props":284,"children":286},{"id":285},"进程和线程的区别是什么",[287],{"type":191,"value":288},"进程和线程的区别是什么？",{"type":185,"tag":274,"props":290,"children":291},{},[292],{"type":191,"value":293},"进程是系统分配资源的最小单位，线程是 CPU 调度的最小单位。线程间资源独立，但是启动、切换和通讯代价较大。线程间资源共享，但一个卡死全员卡死。",{"type":185,"tag":193,"props":295,"children":297},{"id":296},"浏览器的进程线程结构是怎么样的",[298],{"type":191,"value":299},"浏览器的进程线程结构是怎么样的？",{"type":185,"tag":274,"props":301,"children":302},{},[303],{"type":191,"value":304},"一般浏览器由主进程（浏览器进程）、渲染进程（浏览器内核）、插件进程和 GPU 进程组成。和页面渲染相关的是渲染进程，一般由网络请求线程、脚本引擎线程、GUI 渲染线程、合成器线程、光栅线程、事件触发线程、定时器线程和 Worker 线程组成。",{"type":185,"tag":193,"props":306,"children":308},{"id":307},"每个页面都有一个对应的渲染进程吗",[309],{"type":191,"value":310},"每个页面都有一个对应的渲染进程吗？",{"type":185,"tag":274,"props":312,"children":313},{},[314],{"type":191,"value":315},"一般来说是的，给页面一个独立的渲染进程，可以保证该页面崩溃的时候不会影响其它页面。如果页面内有跨站 iFrame，那么会由新的渲染进程接管，这样更安全。此外，由于创建和维持页面的渲染进程需要消耗大量内存，所以浏览器的实践是在进程数达到一定限制后，新页面会共享老页面的渲染进程。",{"type":185,"tag":193,"props":317,"children":319},{"id":318},"service-worker-是如何工作的",[320],{"type":191,"value":321},"Service Worker 是如何工作的？",{"type":185,"tag":274,"props":323,"children":324},{},[325],{"type":191,"value":326},"注册 Service Worker 时，浏览器会保存其作用域。每当请求一个新的资源时，浏览器通过比对资源 URL 是否在某个 Service Worker 的职责中。如果是，会在渲染进程中执行 Service Worker 代码，它可能中缓存中加载数据（同时中止网络请求），也可能从网上请求新的资源。",{"type":185,"tag":193,"props":328,"children":330},{"id":329},"为什么渲染和脚本执行不可以同时进行",[331],{"type":191,"value":332},"为什么渲染和脚本执行不可以同时进行？",{"type":185,"tag":274,"props":334,"children":335},{},[336],{"type":191,"value":337},"由于 JS 执行过程中可能操作 DOM，所以为了防止渲染时同时执行脚本导致前后结果的不一致，脚本线程和 GUI 线程被设计为互斥的：JS 执行时 GUI 会被挂起，等到 JS 线程空闲 GUI 才会更新。",{"type":185,"tag":193,"props":339,"children":341},{"id":340},"webworker-和-sharedworker-的资源是谁来管理的",[342],{"type":191,"value":343},"WebWorker 和 SharedWorker 的资源是谁来管理的？",{"type":185,"tag":274,"props":345,"children":346},{},[347],{"type":191,"value":348},"WebWorker 由当前页面进程管理，它是一个新的线程；SharedWorker 由浏览器的 SharedWorker 进程管理。",{"type":185,"tag":186,"props":350,"children":352},{"id":351},"网络请求",[353],{"type":191,"value":351},{"type":185,"tag":193,"props":355,"children":357},{"id":356},"请求-cdn-中的资源的流程是怎样的",[358],{"type":191,"value":230},{"type":185,"tag":200,"props":360,"children":361},{},[362,367,372,377,382],{"type":185,"tag":204,"props":363,"children":364},{},[365],{"type":191,"value":366},"发请求，本地 DNS 服务器根据记录将请求重定向到 CDN 专用的 DNS 服务器",{"type":185,"tag":204,"props":368,"children":369},{},[370],{"type":191,"value":371},"CDN 专用 DNS 服务器将全局负载均衡服务器的 IP 地址返回给用户",{"type":185,"tag":204,"props":373,"children":374},{},[375],{"type":191,"value":376},"发请求，负载均衡根据用户 IP 将区域负载均衡设备 IP 地址返回给用户",{"type":185,"tag":204,"props":378,"children":379},{},[380],{"type":191,"value":381},"发请求，区域负载均衡设备将缓存服务器 IP 地址返回给用户",{"type":185,"tag":204,"props":383,"children":384},{},[385],{"type":191,"value":386},"发请求，根据各级缓存服务器查找对应资源",{"type":185,"tag":186,"props":388,"children":390},{"id":389},"解析",[391],{"type":191,"value":389},{"type":185,"tag":193,"props":393,"children":395},{"id":394},"浏览器怎么根据请求的文件类型来进一步处理",[396],{"type":191,"value":397},"浏览器怎么根据请求的文件类型来进一步处理？",{"type":185,"tag":274,"props":399,"children":400},{},[401],{"type":191,"value":402},"可以根据 HTTP Header 中携带的 Content-Type 或是 MIME 嗅探技术来判断文件类型。如果是 HTML 之类的文档则交由渲染进程，如果是其他文件，则转交给下载管理器。",{"type":185,"tag":193,"props":404,"children":406},{"id":405},"渲染进程的大致工作流程是怎样的",[407],{"type":191,"value":256},{"type":185,"tag":274,"props":409,"children":410},{},[411],{"type":191,"value":412},"具体工作流程因浏览器而异，但总体而言都是要解析文档与资源并将其渲染至屏幕。总的来说分为解析、构建、布局和渲染四个步骤。",{"type":185,"tag":274,"props":414,"children":415},{},[416],{"type":191,"value":417},"渲染引擎会从网络线程中逐缓存区地取出文档（8KB）进行解析。",{"type":185,"tag":274,"props":419,"children":420},{},[421],{"type":191,"value":422},"解析分 HTML、CSS 和 JS。解析 HTML 时是一个从字符流到标记（Tokenizing），再到带属性对象（Lexing），最后组成 DOM Tree 的过程。解析 CSS 类似，最后会组成 CSSOM Tree。如果是普通脚本，解析时会阻塞 DOM Tree 和 CSSOM Tree 的构建。",{"type":185,"tag":274,"props":424,"children":425},{},[426],{"type":191,"value":427},"当 DOM Tree 和 CSSOM Tree 准备好后，依据 CSS 规范构建渲染树。渲染树将会被带入布局处理，计算节点在屏幕上的精确坐标，随后在图层合层过程中分割为磁贴，并交由栅格线程栅格化并储存在显存中。最后，由浏览器主进程通知渲染 GPU 进程渲染页面。",{"type":185,"tag":193,"props":429,"children":431},{"id":430},"为什么解析-html-无法使用自上而下或自下而上的解析器",[432],{"type":191,"value":433},"为什么解析 HTML 无法使用自上而下或自下而上的解析器？",{"type":185,"tag":274,"props":435,"children":436},{},[437],{"type":191,"value":438},"TODO。主要是因为其语言规范宽松，并且内容在解析时可能发生改变。",{"type":185,"tag":193,"props":440,"children":442},{"id":441},"碰到错误的标签会怎么处理",[443],{"type":191,"value":444},"碰到错误的标签会怎么处理？",{"type":185,"tag":274,"props":446,"children":447},{},[448],{"type":191,"value":449},"看具体的浏览器。一般来说，碰到错误的内容，解析器和 DOM Tree 的构建过程都会想方设法去揣摩正确的代码。浏览器是很包容的。",{"type":185,"tag":193,"props":451,"children":453},{"id":452},"css-解析和-html-的有什么不同",[454],{"type":191,"value":455},"CSS 解析和 HTML 的有什么不同？",{"type":185,"tag":274,"props":457,"children":458},{},[459,461,467,469,473,475,479],{"type":191,"value":460},"因为 CSS 的语法上下文无关，所以可以使用传统的解析器进行解析，比如 WebKit 使用 Bison 解析 CSS。CSS 的词法及语法都由 CSS 规范定义好了。词法用正则描述，比如 num: ",{"type":185,"tag":462,"props":463,"children":464},"span",{},[465],{"type":191,"value":466},"0-9",{"type":191,"value":468},"+|",{"type":185,"tag":462,"props":470,"children":471},{},[472],{"type":191,"value":466},{"type":191,"value":474},"*.",{"type":185,"tag":462,"props":476,"children":477},{},[478],{"type":191,"value":466},{"type":191,"value":480},"+，语法则用 BNF（巴科斯范式）描述。",{"type":185,"tag":274,"props":482,"children":483},{},[484],{"type":191,"value":485},"TODO:",{"type":185,"tag":487,"props":488,"children":489},"ul",{},[490,500],{"type":185,"tag":204,"props":491,"children":492},{},[493],{"type":185,"tag":225,"props":494,"children":498},{"href":495,"rel":496},"https://zhuanlan.zhihu.com/p/31311515",[497],"nofollow",[499],{"type":191,"value":495},{"type":185,"tag":204,"props":501,"children":502},{},[503],{"type":185,"tag":225,"props":504,"children":507},{"href":505,"rel":506},"https://zhuanlan.zhihu.com/p/358518402",[497],[508],{"type":191,"value":505},{"type":185,"tag":193,"props":510,"children":512},{"id":511},"构建渲染树时用了什么优化策略",[513],{"type":191,"value":514},"构建渲染树时用了什么优化策略？",{"type":185,"tag":274,"props":516,"children":517},{},[518],{"type":191,"value":519},"样式计算是一个复杂操作，因为 DOM Tree 和 CSSOM Tree 都是树状结构。DOM 元素都携带了样式属性，这会消耗了大量的内存，并且，样式的嵌套和层叠会引发计算性能问题。",{"type":185,"tag":274,"props":521,"children":522},{},[523],{"type":191,"value":524},"WebKit 使用共享渲染样式对象来优化，但要求元素类名相同、属性及值相同，且不能由 Inline，且不能使用 ID 选择器、属性选择器、同级选择器。",{"type":185,"tag":274,"props":526,"children":527},{},[528,530,536],{"type":191,"value":529},"Firefox 使用了",{"type":185,"tag":531,"props":532,"children":533},"strong",{},[534],{"type":191,"value":535},"规则树",{"type":191,"value":537},"这一方案。TODO",{"type":185,"tag":274,"props":539,"children":540},{},[541],{"type":185,"tag":278,"props":542,"children":544},{"alt":535,"src":543},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200813142147.png",[],{"type":185,"tag":186,"props":546,"children":548},{"id":547},"渲染",[549],{"type":191,"value":547},{"type":185,"tag":193,"props":551,"children":553},{"id":552},"如何避免重绘与回流",[554],{"type":191,"value":555},"如何避免重绘与回流？",{"type":185,"tag":274,"props":557,"children":558},{},[559],{"type":191,"value":560},"渲染树将会被带入布局处理，计算节点在屏幕上的精确坐标，随后在图层合层过程中分割为磁贴，并交由栅格线程栅格化并储存在显存中。如果更改了节点宽高等属性，可能需要从新计算渲染树，然后从布局开始执行逻辑，这叫做回流。如果只是改动节点的文字颜色等属性，只要从重新绘制单个节点开始，这叫做重绘。所以避免回流和重绘，需要减少更改样式的频率，或者换方式实现。",{"type":185,"tag":274,"props":562,"children":563},{},[564],{"type":191,"value":565},"浏览器会用一个队列缓存频繁的重绘和回流相关操作，但是如果用了 getComputedStyle、getBoundingRect 接口，会立即清空队列，所以频繁使用此类接口是有害性能的。",{"type":185,"tag":193,"props":567,"children":569},{"id":568},"domcontentloaded-和-onload-事件先后顺序是",[570],{"type":191,"value":571},"DOMContentLoaded 和 onload 事件先后顺序是？",{"type":185,"tag":274,"props":573,"children":574},{},[575],{"type":191,"value":576},"所有同步脚本执行完，DOM Tree 构建好之后，触发 DOMContentLoaded。所有样式、图片都加载完了才会触发 window.onload。",{"type":185,"tag":193,"props":578,"children":580},{"id":579},"复合composite是什么",[581],{"type":191,"value":582},"复合（Composite）是什么？",{"type":185,"tag":274,"props":584,"children":585},{},[586],{"type":191,"value":587},"复合是将页面分割为不同的图层，分别栅格化，然后组合为帧的流程。",{"type":185,"tag":274,"props":589,"children":590},{},[591],{"type":185,"tag":278,"props":592,"children":595},{"alt":593,"src":594},"Composite Thread","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220627000101.png",[],{"type":185,"tag":193,"props":597,"children":599},{"id":598},"图层是什么",[600],{"type":191,"value":601},"图层是什么？",{"type":185,"tag":274,"props":603,"children":604},{},[605],{"type":191,"value":606},"图层是用来管理渲染树的一种结构。在一个图层中的渲染树的所有节点都会经过布局再交给 GPU 绘制，若 DOM 元素发生改变，可能会引起相应图层中的回流与重绘。可以通过通过 translate3D、will-change 等方式创建新图层（复合图层），这样一来相关元素会被单独绘制，不会影响默认图层。",{"type":185,"tag":193,"props":608,"children":610},{"id":609},"浏览器硬件加速是指什么",[611],{"type":191,"value":612},"浏览器硬件加速是指什么？",{"type":185,"tag":274,"props":614,"children":615},{},[616],{"type":191,"value":617},"硬件加速是通过指定 transform、opacity、filter 等 CSS 属性，使浏览器使用很大并行计算能力的 GPU 替 CPU 分担这些元素的渲染工作，降低 CPU 负载，达到渲染更加流畅的效果。使用硬件加速的图层都会使用新图层绘制，所以为了提前告知浏览器，将元素直接渲染至新图层，而不是从默认图层中拷贝过去，可以使用 will-change 属性明示。",{"type":185,"tag":274,"props":619,"children":620},{},[621,623],{"type":191,"value":622},"见：",{"type":185,"tag":225,"props":624,"children":627},{"href":625,"rel":626},"https://zhuanlan.zhihu.com/p/404656386",[497],[628],{"type":191,"value":629},"搞懂 GPU 和 CSS 硬件加速",{"type":185,"tag":186,"props":631,"children":633},{"id":632},"阅读更多",[634],{"type":191,"value":632},{"type":185,"tag":487,"props":636,"children":637},{},[638,648,658,668,678,690,702,712,722,732,742],{"type":185,"tag":204,"props":639,"children":640},{},[641],{"type":185,"tag":225,"props":642,"children":645},{"href":643,"rel":644},"https://www.html5rocks.com/zh/tutorials/internals/howbrowserswork/",[497],[646],{"type":191,"value":647},"浏览器的工作原理：新式网络浏览器幕后揭秘",{"type":185,"tag":204,"props":649,"children":650},{},[651],{"type":185,"tag":225,"props":652,"children":655},{"href":653,"rel":654},"https://html.spec.whatwg.org/multipage/parsing.html#parsing",[497],[656],{"type":191,"value":657},"HTML SPEC",{"type":185,"tag":204,"props":659,"children":660},{},[661],{"type":185,"tag":225,"props":662,"children":665},{"href":663,"rel":664},"https://www.w3.org/TR/selectors-3/#grammar",[497],[666],{"type":191,"value":667},"CSS Selectors Level 3",{"type":185,"tag":204,"props":669,"children":670},{},[671],{"type":185,"tag":225,"props":672,"children":675},{"href":673,"rel":674},"https://developer.chrome.com/blog/inside-browser-part1/",[497],[676],{"type":191,"value":677},"Inside look at modern web browser (part 1)",{"type":185,"tag":204,"props":679,"children":680},{},[681,688],{"type":185,"tag":225,"props":682,"children":685},{"href":683,"rel":684},"https://zhuanlan.zhihu.com/p/47407398",[497],[686],{"type":191,"value":687},"图解浏览器的基本工作原理",{"type":191,"value":689},"，现代浏览器内部原理系列的中文翻译其一。",{"type":185,"tag":204,"props":691,"children":692},{},[693,700],{"type":185,"tag":225,"props":694,"children":697},{"href":695,"rel":696},"https://www.starryskystar.space/detail/612beeddf1daf402f34f4fa5",[497],[698],{"type":191,"value":699},"浏览器地址栏中输入 URL 到页面显示，浏览器到底发生了什么？",{"type":191,"value":701},"，综合笔记。",{"type":185,"tag":204,"props":703,"children":704},{},[705],{"type":185,"tag":225,"props":706,"children":709},{"href":707,"rel":708},"https://juejin.im/post/59e85eebf265da430d571f89",[497],[710],{"type":191,"value":711},"这一次，彻底弄懂 JavaScript 执行机制",{"type":185,"tag":204,"props":713,"children":714},{},[715],{"type":185,"tag":225,"props":716,"children":719},{"href":717,"rel":718},"https://javascript.ruanyifeng.com/oop/basic.html",[497],[720],{"type":191,"value":721},"构造函数与 new 命令",{"type":185,"tag":204,"props":723,"children":724},{},[725],{"type":185,"tag":225,"props":726,"children":729},{"href":727,"rel":728},"http://newhtml.net/v8-garbage-collection/",[497],[730],{"type":191,"value":731},"V8 之旅：垃圾回收器",{"type":185,"tag":204,"props":733,"children":734},{},[735],{"type":185,"tag":225,"props":736,"children":739},{"href":737,"rel":738},"https://v8.dev/blog/concurrent-marking",[497],[740],{"type":191,"value":741},"Concurrent marking in V8",{"type":185,"tag":204,"props":743,"children":744},{},[745],{"type":185,"tag":225,"props":746,"children":749},{"href":747,"rel":748},"https://juejin.im/post/59fbdb46f265da4321536565",[497],[750],{"type":191,"value":751},"内存分析与内存泄漏定位",{"title":178,"searchDepth":753,"depth":753,"links":754},2,[755,756,757,758,759,760],{"id":188,"depth":753,"text":188},{"id":264,"depth":753,"text":264},{"id":351,"depth":753,"text":351},{"id":389,"depth":753,"text":389},{"id":547,"depth":753,"text":547},{"id":632,"depth":753,"text":632},"markdown","content:6.maps:_web:browser:principle.md","content","6.maps/_web/browser/principle.md","6.maps/_web/browser/principle","md",[768,772],{"_path":769,"title":770,"description":771},"/maps/_web/browser/new","浏览器新特性","Web.dev 月刊精选，追踪和总结主流浏览器的最新特性更新与时动态。",{"_path":773,"title":774,"description":775},"/maps/_web/browser/router","路由技术","Web 前端路由技术详解，包含 Hash 路由、History 路由的实现原理与最佳实践。",1771693714784]