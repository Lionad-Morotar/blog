79,"children":180,"toc":389},"root",[181,189,194,199,204,209,214,219,224,229,234,239,244,249,254,259,264,269,274,279,284,289,294,299,304,309,314,319,324,329,334,339,344,349,354,359,364,369,374,379,384],{"type":182,"tag":183,"props":184,"children":185},"element","p",{},[186],{"type":187,"value":188},"text","TODO",{"type":182,"tag":183,"props":190,"children":191},{},[192],{"type":187,"value":193},"对称加密与非对称加密",{"type":182,"tag":183,"props":195,"children":196},{},[197],{"type":187,"value":198},"了解对称加密（如 AES）与非对称加密（如 RSA, ECDSA）的区别和应用场景。\n实践：使用对称加密快速加密数据，用非对称加密实现密钥交换或敏感数据加密。",{"type":182,"tag":183,"props":200,"children":201},{},[202],{"type":187,"value":203},"密钥管理",{"type":182,"tag":183,"props":205,"children":206},{},[207],{"type":187,"value":208},"学习密钥的生成、存储（如 IndexedDB）、共享和销毁。\n实践：使用 Web Crypto API 生成随机密钥并安全存储。",{"type":182,"tag":183,"props":210,"children":211},{},[212],{"type":187,"value":213},"哈希算法",{"type":182,"tag":183,"props":215,"children":216},{},[217],{"type":187,"value":218},"学习哈希算法（如 SHA-256）在数据完整性验证中的作用。\n实践：生成数据的哈希值以实现校验或数字签名。",{"type":182,"tag":183,"props":220,"children":221},{},[222],{"type":187,"value":223},"随机数生成",{"type":182,"tag":183,"props":225,"children":226},{},[227],{"type":187,"value":228},"理解安全随机数生成器（CSPRNG）在加密中的重要性。\n实践：用 Web Crypto API 生成随机初始向量（IV）或密钥。",{"type":182,"tag":183,"props":230,"children":231},{},[232],{"type":187,"value":233},"安全通信与 HTTPS",{"type":182,"tag":183,"props":235,"children":236},{},[237],{"type":187,"value":238},"学习 HTTPS 的基础原理，理解 TLS 和证书机制。\n实践：配置 HTTPS，确保安全使用 Web Crypto API。",{"type":182,"tag":183,"props":240,"children":241},{},[242],{"type":187,"value":243},"用户数据加密",{"type":182,"tag":183,"props":245,"children":246},{},[247],{"type":187,"value":248},"加密用户敏感数据（如密码）再传输，提升传输安全性。\n实践：将用户密码在前端加密传输到后端解密。",{"type":182,"tag":183,"props":250,"children":251},{},[252],{"type":187,"value":253},"数据完整性验证",{"type":182,"tag":183,"props":255,"children":256},{},[257],{"type":187,"value":258},"学习 HMAC 等校验算法，保障数据在传输中不被篡改。\n实践：使用 Web Crypto API 生成 HMAC 校验消息完整性。",{"type":182,"tag":183,"props":260,"children":261},{},[262],{"type":187,"value":263},"数字签名与身份验证",{"type":182,"tag":183,"props":265,"children":266},{},[267],{"type":187,"value":268},"学习 RSA/ECDSA 签名与验证，用于身份认证和消息认证。\n实践：在前端生成私钥签名并用公钥验证完整性。",{"type":182,"tag":183,"props":270,"children":271},{},[272],{"type":187,"value":273},"密码学协议",{"type":182,"tag":183,"props":275,"children":276},{},[277],{"type":187,"value":278},"学习 Diffie-Hellman 等密钥交换协议原理。\n实践：实现一次性生成对称密钥并安全传输。",{"type":182,"tag":183,"props":280,"children":281},{},[282],{"type":187,"value":283},"加密文件存储",{"type":182,"tag":183,"props":285,"children":286},{},[287],{"type":187,"value":288},"实现前端文件加密后存储到云端，保障数据离线安全性。\n实践：用 AES 加密文件并解密还原。",{"type":182,"tag":183,"props":290,"children":291},{},[292],{"type":187,"value":293},"Token 生成与验证",{"type":182,"tag":183,"props":295,"children":296},{},[297],{"type":187,"value":298},"学习结合对称或非对称加密生成安全认证 Token。\n实践：生成加密 JWT 并在后端进行验证。",{"type":182,"tag":183,"props":300,"children":301},{},[302],{"type":187,"value":303},"权限管理与授权",{"type":182,"tag":183,"props":305,"children":306},{},[307],{"type":187,"value":308},"使用加密机制实现 Role-based Access Control (RBAC)。\n实践：基于用户角色生成带权限标识的加密数据。",{"type":182,"tag":183,"props":310,"children":311},{},[312],{"type":187,"value":313},"隐私保护",{"type":182,"tag":183,"props":315,"children":316},{},[317],{"type":187,"value":318},"学习 GDPR 等法规要求如何保护用户隐私数据。\n实践：为用户数据加密存储并提供隐私合规性支持。",{"type":182,"tag":183,"props":320,"children":321},{},[322],{"type":187,"value":323},"数据脱敏（加密处理）",{"type":182,"tag":183,"props":325,"children":326},{},[327],{"type":187,"value":328},"开发敏感信息（如账号、身份证）加密保存方案。\n实践：对数据库中敏感字段进行加密存储与解密读取。",{"type":182,"tag":183,"props":330,"children":331},{},[332],{"type":187,"value":333},"数字签名在区块链中的应用",{"type":182,"tag":183,"props":335,"children":336},{},[337],{"type":187,"value":338},"了解如何用 ECDSA 实现用户签名交易。\n实践：用 Web Crypto API 模拟为交易数据生成签名。",{"type":182,"tag":183,"props":340,"children":341},{},[342],{"type":187,"value":343},"密钥管理在钱包中的实现",{"type":182,"tag":183,"props":345,"children":346},{},[347],{"type":187,"value":348},"学习如何生成、存储区块链钱包密钥的机制。\n实践：基于 Web Crypto 实现区块链私钥管理功能。",{"type":182,"tag":183,"props":350,"children":351},{},[352],{"type":187,"value":353},"批量数据加密的优化",{"type":182,"tag":183,"props":355,"children":356},{},[357],{"type":187,"value":358},"学习如何用 API 实现更高性能的加密操作。\n实践：加密/解密大文件时使用流式处理。",{"type":182,"tag":183,"props":360,"children":361},{},[362],{"type":187,"value":363},"流式加密实现",{"type":182,"tag":183,"props":365,"children":366},{},[367],{"type":187,"value":368},"学习 AES-GCM 等支持流模式的加密，处理大块数据或文件传输。\n实践：用流式加密处理视频/音频文件。",{"type":182,"tag":183,"props":370,"children":371},{},[372],{"type":187,"value":373},"常见安全漏洞与防护",{"type":182,"tag":183,"props":375,"children":376},{},[377],{"type":187,"value":378},"学习如何防护中间人攻击、重放攻击等。\n实践：在加密与传输过程中加入时间戳或随机数防攻击。",{"type":182,"tag":183,"props":380,"children":381},{},[382],{"type":187,"value":383},"填充攻击及其防护",{"type":182,"tag":183,"props":385,"children":386},{},[387],{"type":187,"value":388},"学习填充攻击（Padding Oracle Attack）及对策。\n实践：使用 Web Crypto API 提供的配置避免漏洞。",{"title":175,"searchDepth":390,"depth":390,"links":391},2,[],"markdown","content:6.maps:_web:browser-api:crypto.md","content","6.maps/_web/browser-api/crypto.md","6.maps/_web/browser-api/crypto","md",[399,403],{"_path":400,"title":401,"description":402},"/maps/_web-pages/web-pages","网站推荐","收藏一些好用的网站。不使用书签是因为书签难以管理且不易分享。",{"_path":404,"title":405,"description":175},"/maps/_web/browser","浏览器",1771214207482]