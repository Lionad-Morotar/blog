e/data-structure","data-structure",false,true,"","Data Structure","数据结构基础知识，包含二叉树遍历、B 树和 B+树原理等核心概念的详细解析。","content/6.maps/_software/data-structure.md",{"type":183,"children":184,"toc":304},"root",[185,193,220,226,232,243,248,253,271,276],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"树",[191],{"type":192,"value":189},"text",{"type":186,"tag":194,"props":195,"children":196},"ul",{},[197,210],{"type":186,"tag":198,"props":199,"children":200},"li",{},[201],{"type":186,"tag":202,"props":203,"children":207},"a",{"href":204,"rel":205},"https://zhuanlan.zhihu.com/p/101321696",[206],"nofollow",[208],{"type":192,"value":209},"神级遍历——morris",{"type":186,"tag":198,"props":211,"children":212},{},[213],{"type":186,"tag":202,"props":214,"children":217},{"href":215,"rel":216},"https://www.cnblogs.com/anniekim/archive/2013/06/15/morristraversal.html",[206],[218],{"type":192,"value":219},"Morris Traversal 方法遍历二叉树（非递归，不用栈，O(1) 空间） ",{"type":186,"tag":221,"props":222,"children":224},"h4",{"id":223},"二叉树的删除",[225],{"type":192,"value":223},{"type":186,"tag":227,"props":228,"children":229},"p",{},[230],{"type":192,"value":231},"如果是排序树，节点的删除分为三种情况：如果被删除的是叶子节点，那么直接删除；如果被删除的节点只有左子树或右子树，那么用子树替换该节点；不然，使用左值树最大值节点或右子树最小值节点替换该节点。",{"type":186,"tag":221,"props":233,"children":235},{"id":234},"彻底理解-b-树和-b树为何它们常用在数据库中",[236],{"type":186,"tag":202,"props":237,"children":240},{"href":238,"rel":239},"https://www.bilibili.com/video/BV1UC4y1p7zm",[206],[241],{"type":192,"value":242},"彻底理解 B 树和 B+树！为何它们常用在数据库中？",{"type":186,"tag":227,"props":244,"children":245},{},[246],{"type":192,"value":247},"B-tree 是 M-way-Tree 的约束版本。在创建 M-way 的 B-tree 时，需要持续往一个目标节点塞入 M-1 个元素。如果目标节点塞不下，则分裂出一个新节点存放新元素，并将目标节点中部分元素取出，另新建一个低层节点置于目标节点和新节点的上层，并连接。每次分裂出节点时，所有改变了元素的节点都需要重新调整其子节点的指向。",{"type":186,"tag":227,"props":249,"children":250},{},[251],{"type":192,"value":252},"B+-tree 相比 B-tree 有几点改变：",{"type":186,"tag":194,"props":254,"children":255},{},[256,261,266],{"type":186,"tag":198,"props":257,"children":258},{},[259],{"type":192,"value":260},"B+-tree 允许重复索引值的元素，底层节点的所有元素都能在高层节点找到一份拷贝，这也意味着 B+-tree 的叶子是全索引。",{"type":186,"tag":198,"props":262,"children":263},{},[264],{"type":192,"value":265},"B-tree 每一个元素都携带了指针指向索引物理位置，而 B+-tree 的指针位于叶子节点。",{"type":186,"tag":198,"props":267,"children":268},{},[269],{"type":192,"value":270},"B+-tree 的叶子节点作为链表相连。",{"type":186,"tag":227,"props":272,"children":273},{},[274],{"type":192,"value":275},"原始的 B-tree 是面向磁盘设计的：",{"type":186,"tag":194,"props":277,"children":278},{},[279,284,289,294,299],{"type":186,"tag":198,"props":280,"children":281},{},[282],{"type":192,"value":283},"有序、平衡的多级储存结构",{"type":186,"tag":198,"props":285,"children":286},{},[287],{"type":192,"value":288},"面向磁盘设计，每一个节点都是磁盘块",{"type":186,"tag":198,"props":290,"children":291},{},[292],{"type":192,"value":293},"查找性能好，适合读密集负载",{"type":186,"tag":198,"props":295,"children":296},{},[297],{"type":192,"value":298},"就地更新（In-Place Update）",{"type":186,"tag":198,"props":300,"children":301},{},[302],{"type":192,"value":303},"写入性能差，分裂、合并等操作都是随机写",{"title":178,"searchDepth":305,"depth":305,"links":306},2,[307],{"id":189,"depth":305,"text":189},"markdown","content:6.maps:_software:data-structure:data-structure.md","content","6.maps/_software/data-structure/data-structure.md","6.maps/_software/data-structure/data-structure","md",[315,319],{"_path":316,"title":317,"description":318},"/maps/_software/algorithm/algorithm","算法","经典算法原理与实现，包含快速排序等常用算法的详细解析和代码示例。",{"_path":320,"title":321,"description":322},"/maps/_software/design-patterns/design-patterns","设计模式","设计模式是一套被反复使用、多数人知晓的、经过分类的、代码设计经验的总结。",1772185452834]