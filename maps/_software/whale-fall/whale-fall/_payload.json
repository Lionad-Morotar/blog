-fall",false,true,"","Whale Fall","大型开源项目死亡后的生态演替，类比海洋中的鲸落现象","content/6.maps/_software/whale-fall.md",{"type":183,"children":184,"toc":456},"root",[185,193,199,210,230,240,253,263,281,295,300,305,315,325,330,335,353,358,368,374,379,384,417,422,427,437,447],{"type":186,"tag":187,"props":188,"children":190},"element","h4",{"id":189},"开源项目的鲸落三阶段",[191],{"type":192,"value":189},"text",{"type":186,"tag":194,"props":195,"children":196},"p",{},[197],{"type":192,"value":198},"当大型开源项目停止维护时，会像鲸尸一样经历三个生态阶段：",{"type":186,"tag":194,"props":200,"children":201},{},[202,208],{"type":186,"tag":203,"props":204,"children":205},"strong",{},[206],{"type":192,"value":207},"1. 移动食腐者",{"type":192,"value":209},"：直接 fork 并接管项目",{"type":186,"tag":211,"props":212,"children":213},"ul",{},[214,220,225],{"type":186,"tag":215,"props":216,"children":217},"li",{},[218],{"type":192,"value":219},"OpenOffice → LibreOffice",{"type":186,"tag":215,"props":221,"children":222},{},[223],{"type":192,"value":224},"MySQL → MariaDB",{"type":186,"tag":215,"props":226,"children":227},{},[228],{"type":192,"value":229},"Hudson → Jenkins",{"type":186,"tag":194,"props":231,"children":232},{},[233,238],{"type":186,"tag":203,"props":234,"children":235},{},[236],{"type":192,"value":237},"2. 富集机会主义者",{"type":192,"value":239},"：针对死项目的数据格式开发替代工具",{"type":186,"tag":211,"props":241,"children":242},{},[243,248],{"type":186,"tag":215,"props":244,"children":245},{},[246],{"type":192,"value":247},"Google Reader 关闭后：Feedly、Miniflux、FreshRSS、Tiny Tiny RSS 等涌现，实现 Google Reader API 兼容",{"type":186,"tag":215,"props":249,"children":250},{},[251],{"type":192,"value":252},"许可证无关紧要，接口公开且其他软件依赖它就足够",{"type":186,"tag":194,"props":254,"children":255},{},[256,261],{"type":186,"tag":203,"props":257,"children":258},{},[259],{"type":192,"value":260},"3. 化能自养细菌",{"type":192,"value":262},"：协议、文件格式、API 契约等结构骨架持续支持社区",{"type":186,"tag":211,"props":264,"children":265},{},[266,271,276],{"type":186,"tag":215,"props":267,"children":268},{},[269],{"type":192,"value":270},"OpenDocument Format 超越了创建它的 OpenOffice",{"type":186,"tag":215,"props":272,"children":273},{},[274],{"type":192,"value":275},"Docker 将容器运行时捐给 OCI，Docker 自身衰落但规范永存",{"type":186,"tag":215,"props":277,"children":278},{},[279],{"type":192,"value":280},"Tree-sitter 为 Atom 而建，Atom 归档后成为 Zed、Neovim、Helix 的语法引擎",{"type":186,"tag":194,"props":282,"children":283},{},[284,286],{"type":192,"value":285},"见：",{"type":186,"tag":287,"props":288,"children":292},"a",{"href":289,"rel":290},"https://nesbitt.io/2026/02/21/whale-fall.html",[291],"nofollow",[293],{"type":192,"value":294},"Whale Fall - Andrew Nesbitt",{"type":186,"tag":187,"props":296,"children":298},{"id":297},"连续再殖民化",[299],{"type":192,"value":297},{"type":186,"tag":194,"props":301,"children":302},{},[303],{"type":192,"value":304},"开源项目死亡后的典型模式：项目沉寂 → 有人 fork → 其他项目依赖该 fork → fork 维护者燃尽 → 循环重复，但规模逐代缩小，直到概念迁移而非代码继承。",{"type":186,"tag":194,"props":306,"children":307},{},[308,313],{"type":186,"tag":203,"props":309,"children":310},{},[311],{"type":192,"value":312},"Sass 的迁移路径",{"type":192,"value":314},"：Ruby gem → LibSass (C++) → Dart Sass。每代重写都受益于前代的 bug 报告和设计争论，但实现被抛弃。大多数写 Sass 的人不知道它始于 Ruby gem。",{"type":186,"tag":194,"props":316,"children":317},{},[318,323],{"type":186,"tag":203,"props":319,"children":320},{},[321],{"type":192,"value":322},"失败模式",{"type":192,"value":324},"：Edera 在 Rust tar-rs 库发现解析漏洞，影响所有下游 fork（async-tar、tokio-tar、Astral 内部 fork）。代码通过连续 fork 复制，但没人重新审计继承自原版的 PAX 头解析逻辑。安全漏洞就这样藏在骨架中，协调披露需要联系约二十个实体，其中多个库无人维护。",{"type":186,"tag":187,"props":326,"children":328},{"id":327},"许可证变更触发食腐",[329],{"type":192,"value":327},{"type":186,"tag":194,"props":331,"children":332},{},[333],{"type":192,"value":334},"项目从开源转向源码可用许可证时，食腐阶段几乎立即触发：",{"type":186,"tag":211,"props":336,"children":337},{},[338,343,348],{"type":186,"tag":215,"props":339,"children":340},{},[341],{"type":192,"value":342},"Redis → Valkey",{"type":186,"tag":215,"props":344,"children":345},{},[346],{"type":192,"value":347},"Elasticsearch → OpenSearch",{"type":186,"tag":215,"props":349,"children":350},{},[351],{"type":192,"value":352},"Terraform → OpenTofu",{"type":186,"tag":194,"props":354,"children":355},{},[356],{"type":192,"value":357},"社区已形成固定流程： rush fork 最后一个开放提交 → 短暂竞争 → 整合到一两个幸存者。从开源生态视角看，代码主体已停止接受外部贡献。",{"type":186,"tag":194,"props":359,"children":360},{},[361,366],{"type":186,"tag":203,"props":362,"children":363},{},[364],{"type":192,"value":365},"持久的抽象层",{"type":192,"value":367},"：集成项目面临选择——跟随专有版本或转向 fork，许多人选择构建兼容垫片。这些垫片往往在许可证争议冷却多年后，仍在依赖原版 API 的骨架生存。",{"type":186,"tag":187,"props":369,"children":371},{"id":370},"sun-microsystems-的鲸群死亡",[372],{"type":192,"value":373},"Sun Microsystems 的鲸群死亡",{"type":186,"tag":194,"props":375,"children":376},{},[377],{"type":192,"value":378},"Oracle 2010 年收购 Sun 不是单一鲸落，而是整群鲸鱼同时死亡：Java、Solaris、ZFS、DTrace、VirtualBox、NetBeans、GlassFish、Hudson、MySQL。",{"type":186,"tag":194,"props":380,"children":381},{},[382],{"type":192,"value":383},"每个都沉到各自的海底，产生不同的继承：",{"type":186,"tag":211,"props":385,"children":386},{},[387,397,407],{"type":186,"tag":215,"props":388,"children":389},{},[390,395],{"type":186,"tag":203,"props":391,"children":392},{},[393],{"type":192,"value":394},"单一主导 fork",{"type":192,"value":396},"：Hudson→Jenkins、ZFS→OpenZFS",{"type":186,"tag":215,"props":398,"children":399},{},[400,405],{"type":186,"tag":203,"props":401,"children":402},{},[403],{"type":192,"value":404},"多线竞争",{"type":192,"value":406},"：MySQL 喂养出 MariaDB、Percona、Drizzle（后者本身又成为小鲸落）",{"type":186,"tag":215,"props":408,"children":409},{},[410,415],{"type":186,"tag":203,"props":411,"children":412},{},[413],{"type":192,"value":414},"基金会辗转",{"type":192,"value":416},"：NetBeans→Apache、GlassFish→Payara 和 Jakarta EE",{"type":186,"tag":194,"props":418,"children":419},{},[420],{"type":192,"value":421},"结构骨架（JVM 字节码格式、ZFS 磁盘格式、MySQL 协议）至今仍是负载-bearing，而许多开发者从未听说过 Sun。",{"type":186,"tag":187,"props":423,"children":425},{"id":424},"浅水区与云厂商整合",[426],{"type":192,"value":424},{"type":186,"tag":194,"props":428,"children":429},{},[430,435],{"type":186,"tag":203,"props":431,"children":432},{},[433],{"type":192,"value":434},"浅水区死亡",{"type":192,"value":436},"：收购式招聘（acqui-hires）——公司被吸收，代码闭源或归档，知识随人员 disperses 而非积累为公共资源。",{"type":186,"tag":194,"props":438,"children":439},{},[440,445],{"type":186,"tag":203,"props":441,"children":442},{},[443],{"type":192,"value":444},"云厂商整合趋势",{"type":192,"value":446},"：当前大型开源项目被平台公司拥有的趋势正在减少鲸落率。这可能产生二阶效应——生态系统多样性受损，但无人追踪。",{"type":186,"tag":448,"props":449,"children":450},"blockquote",{},[451],{"type":186,"tag":194,"props":452,"children":453},{},[454],{"type":192,"value":455},"健康生态需要稳定的鲸落供应——尽管这意味着希望大型项目死亡，因为深海海底没有其他食物来源。",{"title":178,"searchDepth":457,"depth":457,"links":458},2,[],"markdown","content:6.maps:_software:whale-fall:whale-fall.md","content","6.maps/_software/whale-fall/whale-fall.md","6.maps/_software/whale-fall/whale-fall","md",[466,470],{"_path":467,"title":468,"description":469},"/maps/_software/software-engineering/software-engineering","软件工程","软件工程（Software Engineering）是指应用工程化的方法和原则来设计、开发、测试和维护软件系统的学科和实践。",{"_path":471,"title":472,"description":178},"/maps/_source-code/javascript/evil","Evil.js",1772504905163]