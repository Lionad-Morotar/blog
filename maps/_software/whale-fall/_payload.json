中的鲸落现象",{"type":182,"children":183,"toc":455},"root",[184,192,198,209,229,239,252,262,280,294,299,304,314,324,329,334,352,357,367,373,378,383,416,421,426,436,446],{"type":185,"tag":186,"props":187,"children":189},"element","h4",{"id":188},"开源项目的鲸落三阶段",[190],{"type":191,"value":188},"text",{"type":185,"tag":193,"props":194,"children":195},"p",{},[196],{"type":191,"value":197},"当大型开源项目停止维护时，会像鲸尸一样经历三个生态阶段：",{"type":185,"tag":193,"props":199,"children":200},{},[201,207],{"type":185,"tag":202,"props":203,"children":204},"strong",{},[205],{"type":191,"value":206},"1. 移动食腐者",{"type":191,"value":208},"：直接 fork 并接管项目",{"type":185,"tag":210,"props":211,"children":212},"ul",{},[213,219,224],{"type":185,"tag":214,"props":215,"children":216},"li",{},[217],{"type":191,"value":218},"OpenOffice → LibreOffice",{"type":185,"tag":214,"props":220,"children":221},{},[222],{"type":191,"value":223},"MySQL → MariaDB",{"type":185,"tag":214,"props":225,"children":226},{},[227],{"type":191,"value":228},"Hudson → Jenkins",{"type":185,"tag":193,"props":230,"children":231},{},[232,237],{"type":185,"tag":202,"props":233,"children":234},{},[235],{"type":191,"value":236},"2. 富集机会主义者",{"type":191,"value":238},"：针对死项目的数据格式开发替代工具",{"type":185,"tag":210,"props":240,"children":241},{},[242,247],{"type":185,"tag":214,"props":243,"children":244},{},[245],{"type":191,"value":246},"Google Reader 关闭后：Feedly、Miniflux、FreshRSS、Tiny Tiny RSS 等涌现，实现 Google Reader API 兼容",{"type":185,"tag":214,"props":248,"children":249},{},[250],{"type":191,"value":251},"许可证无关紧要，接口公开且其他软件依赖它就足够",{"type":185,"tag":193,"props":253,"children":254},{},[255,260],{"type":185,"tag":202,"props":256,"children":257},{},[258],{"type":191,"value":259},"3. 化能自养细菌",{"type":191,"value":261},"：协议、文件格式、API 契约等结构骨架持续支持社区",{"type":185,"tag":210,"props":263,"children":264},{},[265,270,275],{"type":185,"tag":214,"props":266,"children":267},{},[268],{"type":191,"value":269},"OpenDocument Format 超越了创建它的 OpenOffice",{"type":185,"tag":214,"props":271,"children":272},{},[273],{"type":191,"value":274},"Docker 将容器运行时捐给 OCI，Docker 自身衰落但规范永存",{"type":185,"tag":214,"props":276,"children":277},{},[278],{"type":191,"value":279},"Tree-sitter 为 Atom 而建，Atom 归档后成为 Zed、Neovim、Helix 的语法引擎",{"type":185,"tag":193,"props":281,"children":282},{},[283,285],{"type":191,"value":284},"见：",{"type":185,"tag":286,"props":287,"children":291},"a",{"href":288,"rel":289},"https://nesbitt.io/2026/02/21/whale-fall.html",[290],"nofollow",[292],{"type":191,"value":293},"Whale Fall - Andrew Nesbitt",{"type":185,"tag":186,"props":295,"children":297},{"id":296},"连续再殖民化",[298],{"type":191,"value":296},{"type":185,"tag":193,"props":300,"children":301},{},[302],{"type":191,"value":303},"开源项目死亡后的典型模式：项目沉寂 → 有人 fork → 其他项目依赖该 fork → fork 维护者燃尽 → 循环重复，但规模逐代缩小，直到概念迁移而非代码继承。",{"type":185,"tag":193,"props":305,"children":306},{},[307,312],{"type":185,"tag":202,"props":308,"children":309},{},[310],{"type":191,"value":311},"Sass 的迁移路径",{"type":191,"value":313},"：Ruby gem → LibSass (C++) → Dart Sass。每代重写都受益于前代的 bug 报告和设计争论，但实现被抛弃。大多数写 Sass 的人不知道它始于 Ruby gem。",{"type":185,"tag":193,"props":315,"children":316},{},[317,322],{"type":185,"tag":202,"props":318,"children":319},{},[320],{"type":191,"value":321},"失败模式",{"type":191,"value":323},"：Edera 在 Rust tar-rs 库发现解析漏洞，影响所有下游 fork（async-tar、tokio-tar、Astral 内部 fork）。代码通过连续 fork 复制，但没人重新审计继承自原版的 PAX 头解析逻辑。安全漏洞就这样藏在骨架中，协调披露需要联系约二十个实体，其中多个库无人维护。",{"type":185,"tag":186,"props":325,"children":327},{"id":326},"许可证变更触发食腐",[328],{"type":191,"value":326},{"type":185,"tag":193,"props":330,"children":331},{},[332],{"type":191,"value":333},"项目从开源转向源码可用许可证时，食腐阶段几乎立即触发：",{"type":185,"tag":210,"props":335,"children":336},{},[337,342,347],{"type":185,"tag":214,"props":338,"children":339},{},[340],{"type":191,"value":341},"Redis → Valkey",{"type":185,"tag":214,"props":343,"children":344},{},[345],{"type":191,"value":346},"Elasticsearch → OpenSearch",{"type":185,"tag":214,"props":348,"children":349},{},[350],{"type":191,"value":351},"Terraform → OpenTofu",{"type":185,"tag":193,"props":353,"children":354},{},[355],{"type":191,"value":356},"社区已形成固定流程： rush fork 最后一个开放提交 → 短暂竞争 → 整合到一两个幸存者。从开源生态视角看，代码主体已停止接受外部贡献。",{"type":185,"tag":193,"props":358,"children":359},{},[360,365],{"type":185,"tag":202,"props":361,"children":362},{},[363],{"type":191,"value":364},"持久的抽象层",{"type":191,"value":366},"：集成项目面临选择——跟随专有版本或转向 fork，许多人选择构建兼容垫片。这些垫片往往在许可证争议冷却多年后，仍在依赖原版 API 的骨架生存。",{"type":185,"tag":186,"props":368,"children":370},{"id":369},"sun-microsystems-的鲸群死亡",[371],{"type":191,"value":372},"Sun Microsystems 的鲸群死亡",{"type":185,"tag":193,"props":374,"children":375},{},[376],{"type":191,"value":377},"Oracle 2010 年收购 Sun 不是单一鲸落，而是整群鲸鱼同时死亡：Java、Solaris、ZFS、DTrace、VirtualBox、NetBeans、GlassFish、Hudson、MySQL。",{"type":185,"tag":193,"props":379,"children":380},{},[381],{"type":191,"value":382},"每个都沉到各自的海底，产生不同的继承：",{"type":185,"tag":210,"props":384,"children":385},{},[386,396,406],{"type":185,"tag":214,"props":387,"children":388},{},[389,394],{"type":185,"tag":202,"props":390,"children":391},{},[392],{"type":191,"value":393},"单一主导 fork",{"type":191,"value":395},"：Hudson→Jenkins、ZFS→OpenZFS",{"type":185,"tag":214,"props":397,"children":398},{},[399,404],{"type":185,"tag":202,"props":400,"children":401},{},[402],{"type":191,"value":403},"多线竞争",{"type":191,"value":405},"：MySQL 喂养出 MariaDB、Percona、Drizzle（后者本身又成为小鲸落）",{"type":185,"tag":214,"props":407,"children":408},{},[409,414],{"type":185,"tag":202,"props":410,"children":411},{},[412],{"type":191,"value":413},"基金会辗转",{"type":191,"value":415},"：NetBeans→Apache、GlassFish→Payara 和 Jakarta EE",{"type":185,"tag":193,"props":417,"children":418},{},[419],{"type":191,"value":420},"结构骨架（JVM 字节码格式、ZFS 磁盘格式、MySQL 协议）至今仍是负载-bearing，而许多开发者从未听说过 Sun。",{"type":185,"tag":186,"props":422,"children":424},{"id":423},"浅水区与云厂商整合",[425],{"type":191,"value":423},{"type":185,"tag":193,"props":427,"children":428},{},[429,434],{"type":185,"tag":202,"props":430,"children":431},{},[432],{"type":191,"value":433},"浅水区死亡",{"type":191,"value":435},"：收购式招聘（acqui-hires）——公司被吸收，代码闭源或归档，知识随人员 disperses 而非积累为公共资源。",{"type":185,"tag":193,"props":437,"children":438},{},[439,444],{"type":185,"tag":202,"props":440,"children":441},{},[442],{"type":191,"value":443},"云厂商整合趋势",{"type":191,"value":445},"：当前大型开源项目被平台公司拥有的趋势正在减少鲸落率。这可能产生二阶效应——生态系统多样性受损，但无人追踪。",{"type":185,"tag":447,"props":448,"children":449},"blockquote",{},[450],{"type":185,"tag":193,"props":451,"children":452},{},[453],{"type":191,"value":454},"健康生态需要稳定的鲸落供应——尽管这意味着希望大型项目死亡，因为深海海底没有其他食物来源。",{"title":178,"searchDepth":456,"depth":456,"links":457},2,[],"markdown","content:6.maps:_software:whale-fall.md","content","6.maps/_software/whale-fall.md","6.maps/_software/whale-fall","md",[465,469],{"_path":466,"title":467,"description":468},"/maps/_software/software-engineering","软件工程","软件工程（Software Engineering）是指应用工程化的方法和原则来设计、开发、测试和维护软件系统的学科和实践。",{"_path":470,"title":471,"description":178},"/maps/_source-code/javascript/evil","Evil.js",1771690594138]