ath":82},"💫 CSS 幻术 | 抗锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"original_path":181,"body":182,"_type":364,"_id":365,"_source":366,"_file":367,"_stem":368,"_extension":369},"/maps/_software/software-engineering/software-engineering","software-engineering",false,true,"","软件工程","软件工程（Software Engineering）是指应用工程化的方法和原则来设计、开发、测试和维护软件系统的学科和实践。","content/6.maps/_software/software-engineering.md",{"type":183,"children":184,"toc":360},"root",[185,194,201,207,218,228,238,243,248,262,268,287,296,304,312,320,328,336,344,352],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"gists",[191],{"type":192,"value":193},"text","Gists",{"type":186,"tag":195,"props":196,"children":198},"h4",{"id":197},"渐进演进的战略智慧为何丑陋的代码比干净的重写更有价值",[199],{"type":192,"value":200},"渐进演进的战略智慧：为何\"丑陋\"的代码比\"干净\"的重写更有价值",{"type":186,"tag":202,"props":203,"children":204},"p",{},[205],{"type":192,"value":206},"程序员本能地想要推倒重来，因为他们认为旧代码是\"混乱的\"。\n但这种直觉恰恰揭示了软件工程中最深刻的悖论：",{"type":186,"tag":202,"props":208,"children":209},{},[210,216],{"type":186,"tag":211,"props":212,"children":213},"strong",{},[214],{"type":192,"value":215},"读代码比写代码更难",{"type":192,"value":217},"——这是程序员总想重写的根本原因，而非旧代码本身有问题。\n那些看似\"丑陋\"的长函数、奇怪的API调用和晦涩的hack，实际上是无数bug修复和业务智慧结晶的化石记录。\n每一行\"毛发\"都代表着一个在真实世界中发现的边界情况、一个用户报告的问题、数周的调试和一行关键的修复。",{"type":186,"tag":202,"props":219,"children":220},{},[221,226],{"type":186,"tag":211,"props":222,"children":223},{},[224],{"type":192,"value":225},"重写是对知识资产的毁灭性清算",{"type":192,"value":227},"。当选择从零开始时，你不仅放弃了代码，更放弃了 years of accumulated bug fixes、真实场景的测试验证、\n以及团队对系统行为的集体理解。Netscape为此付出了3年时间和市场主导地位的代价——在软件行业，这等同于商业自杀。",{"type":186,"tag":202,"props":229,"children":230},{},[231,236],{"type":186,"tag":211,"props":232,"children":233},{},[234],{"type":192,"value":235},"渐进式重构是更深刻的工程能力",{"type":192,"value":237},"。架构问题可以通过 careful moving code 解决；性能问题可以通过针对性优化解决；\n代码风格问题可以通过工具批量解决。这些方法都在保留知识资产的前提下演进系统。\n而重写不仅无法保证做得更好（你没有\"更多经验\"，你甚至可能换了团队），还会让公司在数年内无法响应市场需求。",{"type":186,"tag":202,"props":239,"children":240},{},[241],{"type":192,"value":242},"这是关于软件演化的深层认知：代码的价值不在于其当下的优雅，而在于它所承载的历史智慧和验证过的正确性。",{"type":186,"tag":202,"props":244,"children":245},{},[246],{"type":192,"value":247},"不过，在 Coding Agent 已经强大的 2026 年来看，这些过往的软件工程经验正在急速演变。",{"type":186,"tag":202,"props":249,"children":250},{},[251,253],{"type":192,"value":252},"见：",{"type":186,"tag":254,"props":255,"children":259},"a",{"href":256,"rel":257},"https://www.joelonsoftware.com/2000/04/06/things-you-should-never-do-part-i/",[258],"nofollow",[260],{"type":192,"value":261},"Things You Should Never Do, Part I",{"type":186,"tag":195,"props":263,"children":265},{"id":264},"martin-fowler深度访谈软件工程正迎来-40-年来最猛烈的一次地震",[266],{"type":192,"value":267},"Martin Fowler深度访谈：软件工程正迎来 40 年来最猛烈的一次地震",{"type":186,"tag":202,"props":269,"children":270},{},[271,273,278,280,285],{"type":192,"value":272},"这轮技术变革的本质，是从确定性世界走向非确定性世界，AI 最适合用来",{"type":186,"tag":211,"props":274,"children":275},{},[276],{"type":192,"value":277},"理解复杂系统、生成输入与方案",{"type":192,"value":279},"，再交给",{"type":186,"tag":211,"props":281,"children":282},{},[283],{"type":192,"value":284},"确定性的传统工具去执行和落地",{"type":192,"value":286},"，在这一过程中，软件开发过程的管理————软件工程的概念只会演变，但不会过时。",{"type":186,"tag":202,"props":288,"children":289},{},[290],{"type":186,"tag":291,"props":292,"children":293},"q",{},[294],{"type":192,"value":295},"这次变革最大的特点，不是抽象层又提高了，而是我们从确定性的世界进入了非确定性的世界。",{"type":186,"tag":202,"props":297,"children":298},{},[299],{"type":186,"tag":291,"props":300,"children":301},{},[302],{"type":192,"value":303},"Fowler说Thoughtworks已经把用AI理解遗留代码放进了他们技术雷达的采纳环。这是最高级别的推荐，意味着他们强烈建议在这个场景下使用AI。",{"type":186,"tag":202,"props":305,"children":306},{},[307],{"type":186,"tag":291,"props":308,"children":309},{},[310],{"type":192,"value":311},"Fowler说他的同事James Lewis用Cursor尝试重命名一个类，结果花了一个半小时，用掉了10%的月度token配额。这个任务如果用传统IDE的重构功能，也就几秒钟的事。",{"type":186,"tag":202,"props":313,"children":314},{},[315],{"type":186,"tag":291,"props":316,"children":317},{},[318],{"type":192,"value":319},"不要让AI直接生成最终代码，而是让AI生成输入，然后用确定性的工具来执行。",{"type":186,"tag":202,"props":321,"children":322},{},[323],{"type":186,"tag":291,"props":324,"children":325},{},[326],{"type":192,"value":327},"软件开发的核心技能不会过时。什么是核心技能？理解用户需求，与人沟通，把模糊的想法变成清晰的方案，在约束条件下做权衡。",{"type":186,"tag":202,"props":329,"children":330},{},[331],{"type":186,"tag":291,"props":332,"children":333},{},[334],{"type":192,"value":335},"Fowler今年应该快70岁了。他说自己当年进入这个行业纯属偶然，因为自己手笨，干不了需要体力的工程活，写代码刚好不需要力气。谁能想到，这个偶然的选择让他见证了人类历史上发展最快的行业的几乎全部历程。",{"type":186,"tag":202,"props":337,"children":338},{},[339],{"type":186,"tag":291,"props":340,"children":341},{},[342],{"type":192,"value":343},"当我们所有人都在谈论千亿美元投资、万卡集群的时候，这位 AI 领域最神秘的大脑之一 Ilya Sutskever 却说了一句让人意外的话：我们正在从规模时代重回研究时代。",{"type":186,"tag":202,"props":345,"children":346},{},[347],{"type":186,"tag":291,"props":348,"children":349},{},[350],{"type":192,"value":351},"这就是 Andrej Karpathy 想强调的核心差异： 动物智能是被自然进化\"碾\"出来的，全能、通用、压力巨大； AI 的智能是被商业训练\"筛\"出来的，用来完成任务、讨好用户、服务人类。 两个力场完全不同，方向也完全不同。",{"type":186,"tag":202,"props":353,"children":354},{},[355],{"type":186,"tag":291,"props":356,"children":357},{},[358],{"type":192,"value":359},"所以真正的超级智能应该是什么样的？Ilya 给出了一个新的定义：它不是一个什么都知道的全能大脑，而是一个能够快速学习任何技能的智能体。就像一个 15 岁的超级学生，基础很扎实，学习能力极强，但还需要去具体的领域深入学习。",{"title":178,"searchDepth":361,"depth":361,"links":362},2,[363],{"id":189,"depth":361,"text":193},"markdown","content:6.maps:_software:software-engineering:software-engineering.md","content","6.maps/_software/software-engineering/software-engineering.md","6.maps/_software/software-engineering/software-engineering","md",[371,375],{"_path":372,"title":373,"description":374},"/maps/_software/software","软件","软件工程、数据结构、算法与设计模式",{"_path":376,"title":377,"description":378},"/maps/_software/whale-fall/whale-fall","Whale Fall","大型开源项目死亡后的生态演替，类比海洋中的鲸落现象",1772185452669]