，易于上手，同时也便于与第三方库或既有项目整合。",{"type":182,"children":183,"toc":807},"root",[184,193,220,225,232,250,256,262,267,272,278,283,289,312,318,336,342,347,352,357,369,374,380,385,390,396,407,412,418,427,433,439,444,450,461,472,483,494,499,505,510,516,521,527,532,538,544,549,555,559,569,575,586,591,596,601,606,620,633,638,651,656,669,674,733,778,783,789,801],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"todo",[190],{"type":191,"value":192},"text","TODO",{"type":185,"tag":194,"props":195,"children":196},"ul",{},[197,210],{"type":185,"tag":198,"props":199,"children":200},"li",{},[201],{"type":185,"tag":202,"props":203,"children":207},"a",{"href":204,"rel":205},"https://www.zhihu.com/question/390956688/answer/1184696066",[206],"nofollow",[208],{"type":191,"value":209},"Vue.js 技术揭秘",{"type":185,"tag":198,"props":211,"children":212},{},[213],{"type":185,"tag":202,"props":214,"children":217},{"href":215,"rel":216},"https://github.com/HcySunYang/vue-design/blob/elegant/docs/art/1start-learn",[206],[218],{"type":191,"value":219},"vue-design",{"type":185,"tag":186,"props":221,"children":223},{"id":222},"简介",[224],{"type":191,"value":222},{"type":185,"tag":226,"props":227,"children":229},"h4",{"id":228},"前端框架发展历史关键点",[230],{"type":191,"value":231},"前端框架发展历史关键点？",{"type":185,"tag":194,"props":233,"children":234},{},[235,240,245],{"type":185,"tag":198,"props":236,"children":237},{},[238],{"type":191,"value":239},"2004 年，Google Gmail 使用的 Ajax 技术使前端脱离模板的束缚。",{"type":185,"tag":198,"props":241,"children":242},{},[243],{"type":191,"value":244},"jQuery 解决了不同浏览器的兼容性问题。",{"type":185,"tag":198,"props":246,"children":247},{},[248],{"type":191,"value":249},"2009 年，AngularJS 引领了 MVVM 的潮流，NodeJS 加速了前端工程化的诞生。",{"type":185,"tag":226,"props":251,"children":253},{"id":252},"vue-和-react-的计算性能瓶颈是什么",[254],{"type":191,"value":255},"Vue 和 React 的计算性能瓶颈是什么？",{"type":185,"tag":257,"props":258,"children":259},"p",{},[260],{"type":191,"value":261},"Vue1 的每一个响应式数据都有一个 Watcher，极大的消耗内存，React 的问题发生在当页面 JS 执行 Diff 算法超过帧时间时带来的卡顿问题。",{"type":185,"tag":257,"props":263,"children":264},{},[265],{"type":191,"value":266},"Vue2 引入虚拟 DOM，采用组件级别的响应式数据颗粒度，在避免了 Diff 算法超时问题的同时，降低内存消耗。同时，虚拟 DOM 还带来跨端能力。",{"type":185,"tag":257,"props":268,"children":269},{},[270],{"type":191,"value":271},"React 引入 Fiber 架构，将 DOM Tree 变成链表，使得有能力随时启动或停止 Diff 算法（树的遍历使用递归所以相比链表更难记录状态），可以利用浏览器的空闲时间计算 Diff，避免了卡顿。",{"type":185,"tag":226,"props":273,"children":275},{"id":274},"mvvmmvc-的区别",[276],{"type":191,"value":277},"MVVM、MVC 的区别？",{"type":185,"tag":257,"props":279,"children":280},{},[281],{"type":191,"value":282},"都是软件架构模式，主要区别是关注点不一样，Controller 用来承接交互操作并触发 Model 的修改，而 ViewModel 和 Model 层是双向绑定的，所以写 VueJS 时的思想不在如何操作 DOM 元素，而主要是数据应该怎么变化。",{"type":185,"tag":226,"props":284,"children":286},{"id":285},"vue2-较明显的设计缺陷",[287],{"type":191,"value":288},"Vue2 较明显的设计缺陷？",{"type":185,"tag":194,"props":290,"children":291},{},[292,297,302,307],{"type":185,"tag":198,"props":293,"children":294},{},[295],{"type":191,"value":296},"使用 Flow.js 来做类型校验，而不是社区所向的 TypeScript",{"type":185,"tag":198,"props":298,"children":299},{},[300],{"type":191,"value":301},"Vue2 内嵌了诸如 DOM API 之类的代码，使得跨端等二次开发变得困难，代码耦合也使得摇树优化变得困难",{"type":185,"tag":198,"props":303,"children":304},{},[305],{"type":191,"value":306},"Vue2 使用的 defineProperty 有缺陷，不支持 delete 等操作符",{"type":185,"tag":198,"props":308,"children":309},{},[310],{"type":191,"value":311},"Option API 在组件代码较多时不易维护",{"type":185,"tag":226,"props":313,"children":315},{"id":314},"option-api-的一些缺陷",[316],{"type":191,"value":317},"Option API 的一些缺陷？",{"type":185,"tag":194,"props":319,"children":320},{},[321,326,331],{"type":185,"tag":198,"props":322,"children":323},{},[324],{"type":191,"value":325},"数据挂载在 this 对象上，对类型系统以及摇树优化不友好",{"type":185,"tag":198,"props":327,"children":328},{},[329],{"type":191,"value":330},"代码增多时，维护变得困难",{"type":185,"tag":198,"props":332,"children":333},{},[334],{"type":191,"value":335},"不方便抽离通用逻辑",{"type":185,"tag":226,"props":337,"children":339},{"id":338},