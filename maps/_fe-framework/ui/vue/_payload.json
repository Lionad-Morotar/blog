07},{},[508],{"type":191,"value":509},"keep-alive 是一个内置抽象组件，会根据内部组件的 key，使用 LRU 策略来缓存组件实例。",{"type":185,"tag":226,"props":511,"children":513},{"id":512},"vue-的生命周期",[514],{"type":191,"value":515},"Vue 的生命周期",{"type":185,"tag":257,"props":517,"children":518},{},[519],{"type":191,"value":520},"keep-alive 独有 activated 和 deactivated 两个生命周期。",{"type":185,"tag":226,"props":522,"children":524},{"id":523},"vue-子组件和父组件执行顺序",[525],{"type":191,"value":526},"Vue 子组件和父组件执行顺序",{"type":185,"tag":257,"props":528,"children":529},{},[530],{"type":191,"value":531},"父组件 mount 前，初始化子组件，所以父组件 beforeMount 后直到子组件 mounted 完成，再挂载。update 和 destroy 两个阶段类似，都是子组件先行。",{"type":185,"tag":186,"props":533,"children":535},{"id":534},"vue-router",[536],{"type":191,"value":537},"Vue Router",{"type":185,"tag":226,"props":539,"children":541},{"id":540},"route-vs-router",[542],{"type":191,"value":543},"$route VS $router",{"type":185,"tag":257,"props":545,"children":546},{},[547],{"type":191,"value":548},"$route 是路由信息对象，包含 path、params、hash、query 等，$router 是 vue-router 实例，包含路由跳转方法和钩子函数等。",{"type":185,"tag":186,"props":550,"children":552},{"id":551},"ssr",[553],{"type":191,"value":554},"SSR",{"type":185,"tag":257,"props":556,"children":557},{},[558],{"type":191,"value":192},{"type":185,"tag":257,"props":560,"children":561},{},[562],{"type":185,"tag":202,"props":563,"children":566},{"href":564,"rel":565},"https://vuejs.org/guide/scaling-up/ssr.html",[206],[567],{"type":191,"value":568},"Vue SSR",{"type":185,"tag":186,"props":570,"children":572},{"id":571},"with-typescript",[573],{"type":191,"value":574},"with TypeScript",{"type":185,"tag":226,"props":576,"children":578},{"id":577},"using-vue-with-typescript",[579],{"type":185,"tag":202,"props":580,"children":583},{"href":581,"rel":582},"https://vuejs.org/guide/typescript/overview.html",[206],[584],{"type":191,"value":585},"Using Vue with TypeScript",{"type":185,"tag":257,"props":587,"children":588},{},[589],{"type":191,"value":590},"\"With a Vite-based setup, the dev server and the bundler are transpilation-only and do not perform any type-checking.\"",{"type":185,"tag":257,"props":592,"children":593},{},[594],{"type":191,"value":595},"Vite-based 的项目不会在开发服务器启用类型检查。Vue 推荐开发者依赖 IDE 进行类型检查，或使用 vue-tsc watch mode、使用 vite-plugin-checker 另起线程插件。Vue 认为类型检查降低开发环境的速度是不值得的。",{"type":185,"tag":257,"props":597,"children":598},{},[599],{"type":191,"value":600},"两个 tsconfig.json 编译选项必须开启：isolatedModule 以便允许 esbuild 解析模块、noImplicitThis 以便启用 this 的类型。",{"type":185,"tag":257,"props":602,"children":603},{},[604],{"type":191,"value":605},"“but for each project we are running two TS language service instances: one from Volar, one from VSCode's built-in service”",{"type":185,"tag":257,"props":607,"children":608},{},[609,611,618],{"type":191,"value":610},"禁用 ",{"type":185,"tag":612,"props":613,"children":615},"code",{"className":614},[],[616],{"type":191,"value":617},"@builtin",{"type":191,"value":619}," TS 插件或打开 Volar 的 Takeover Mode，重启后便能使 Takeover Mode 生效。",{"type":185,"tag":257,"props":621,"children":622},{},[623,625,631],{"type":191,"value":624},"“... with ",{"type":185,"tag":612,"props":626,"children":628},{"className":627},[],[629],{"type":191,"value":630},"ts-loader",{"type":191,"value":632},". This, however, isn't a clean solution because the type system needs knowledge of the entire module graph to perform type checks”",{"type":185,"tag":257,"props":634,"children":635},{},[636],{"type":191,"value":637},"使用 loader 用来类型检查的两个缺陷：检测缓慢阻塞编译、只能解析预解析后的文件所以报错不能直接跳转回源码。",{"type":185,"tag":257,"props":639,"children":640},{},[641,643,649],{"type":191,"value":642},"“In version 3.2 and below, the generic type parameter for ",{"type":185,"tag":612,"props":644,"children":646},{"className":645},[],[647],{"type":191,"value":648},"defineProps()",{"type":191,"value":650}," were limited to a type literal or a reference to a local interface. This limitation has been resolved in 3.3.”",{"type":185,"tag":257,"props":652,"children":653},{},[654],{"type":191,