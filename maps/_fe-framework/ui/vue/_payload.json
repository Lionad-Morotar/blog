置抽象组件，会根据内部组件的 key，使用 LRU 策略来缓存组件实例。",{"type":182,"tag":223,"props":508,"children":510},{"id":509},"vue-的生命周期",[511],{"type":188,"value":512},"Vue 的生命周期",{"type":182,"tag":254,"props":514,"children":515},{},[516],{"type":188,"value":517},"keep-alive 独有 activated 和 deactivated 两个生命周期。",{"type":182,"tag":223,"props":519,"children":521},{"id":520},"vue-子组件和父组件执行顺序",[522],{"type":188,"value":523},"Vue 子组件和父组件执行顺序",{"type":182,"tag":254,"props":525,"children":526},{},[527],{"type":188,"value":528},"父组件 mount 前，初始化子组件，所以父组件 beforeMount 后直到子组件 mounted 完成，再挂载。update 和 destroy 两个阶段类似，都是子组件先行。",{"type":182,"tag":183,"props":530,"children":532},{"id":531},"vue-router",[533],{"type":188,"value":534},"Vue Router",{"type":182,"tag":223,"props":536,"children":538},{"id":537},"route-vs-router",[539],{"type":188,"value":540},"$route VS $router",{"type":182,"tag":254,"props":542,"children":543},{},[544],{"type":188,"value":545},"$route 是路由信息对象，包含 path、params、hash、query 等，$router 是 vue-router 实例，包含路由跳转方法和钩子函数等。",{"type":182,"tag":183,"props":547,"children":549},{"id":548},"ssr",[550],{"type":188,"value":551},"SSR",{"type":182,"tag":254,"props":553,"children":554},{},[555],{"type":188,"value":189},{"type":182,"tag":254,"props":557,"children":558},{},[559],{"type":182,"tag":199,"props":560,"children":563},{"href":561,"rel":562},"https://vuejs.org/guide/scaling-up/ssr.html",[203],[564],{"type":188,"value":565},"Vue SSR",{"type":182,"tag":183,"props":567,"children":569},{"id":568},"with-typescript",[570],{"type":188,"value":571},"with TypeScript",{"type":182,"tag":223,"props":573,"children":575},{"id":574},"using-vue-with-typescript",[576],{"type":182,"tag":199,"props":577,"children":580},{"href":578,"rel":579},"https://vuejs.org/guide/typescript/overview.html",[203],[581],{"type":188,"value":582},"Using Vue with TypeScript",{"type":182,"tag":254,"props":584,"children":585},{},[586],{"type":188,"value":587},"\"With a Vite-based setup, the dev server and the bundler are transpilation-only and do not perform any type-checking.\"",{"type":182,"tag":254,"props":589,"children":590},{},[591],{"type":188,"value":592},"Vite-based 的项目不会在开发服务器启用类型检查。Vue 推荐开发者依赖 IDE 进行类型检查，或使用 vue-tsc watch mode、使用 vite-plugin-checker 另起线程插件。Vue 认为类型检查降低开发环境的速度是不值得的。",{"type":182,"tag":254,"props":594,"children":595},{},[596],{"type":188,"value":597},"两个 tsconfig.json 编译选项必须开启：isolatedModule 以便允许 esbuild 解析模块、noImplicitThis 以便启用 this 的类型。",{"type":182,"tag":254,"props":599,"children":600},{},[601],{"type":188,"value":602},"“but for each project we are running two TS language service instances: one from Volar, one from VSCode's built-in service”",{"type":182,"tag":254,"props":604,"children":605},{},[606,608,615],{"type":188,"value":607},"禁用 ",{"type":182,"tag":609,"props":610,"children":612},"code",{"className":611},[],[613],{"type":188,"value":614},"@builtin",{"type":188,"value":616}," TS 插件或打开 Volar 的 Takeover Mode，重启后便能使 Takeover Mode 生效。",{"type":182,"tag":254,"props":618,"children":619},{},[620,622,628],{"type":188,"value":621},"“... with ",{"type":182,"tag":609,"props":623,"children":625},{"className":624},[],[626],{"type":188,"value":627},"ts-loader",{"type":188,"value":629},". This, however, isn't a clean solution because the type system needs knowledge of the entire module graph to perform type checks”",{"type":182,"tag":254,"props":631,"children":632},{},[633],{"type":188,"value":634},"使用 loader 用来类型检查的两个缺陷：检测缓慢阻塞编译、只能解析预解析后的文件所以报错不能直接跳转回源码。",{"type":182,"tag":254,"props":636,"children":637},{},[638,640,646],{"type":188,"value":639},"“In version 3.2 and below, the generic type parameter for ",{"type":182,"tag":609,"props":641,"children":643},{"className":642},[],[644],{"type":188,"value":645},"defineProps()",{"type":188,"value":647}," were limited to a type literal or a reference to a local interface. This limitation has been resolved in 3.3.”",{"type":182,"tag":254,"props":649,"children":650},{},[651],{"type":188,"value":652},"TODO。为什么 Vue 3.2 不能使用外部引入的 Props 作为 type