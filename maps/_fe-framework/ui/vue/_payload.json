toc":804},"root",[181,190,217,222,229,247,253,259,264,269,275,280,286,309,315,333,339,344,349,354,366,371,377,382,387,393,404,409,415,424,430,436,441,447,458,469,480,491,496,502,507,513,518,524,529,535,541,546,552,556,566,572,583,588,593,598,603,617,630,635,648,653,666,671,730,775,780,786,798],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"todo",[187],{"type":188,"value":189},"text","TODO",{"type":182,"tag":191,"props":192,"children":193},"ul",{},[194,207],{"type":182,"tag":195,"props":196,"children":197},"li",{},[198],{"type":182,"tag":199,"props":200,"children":204},"a",{"href":201,"rel":202},"https://www.zhihu.com/question/390956688/answer/1184696066",[203],"nofollow",[205],{"type":188,"value":206},"Vue.js 技术揭秘",{"type":182,"tag":195,"props":208,"children":209},{},[210],{"type":182,"tag":199,"props":211,"children":214},{"href":212,"rel":213},"https://github.com/HcySunYang/vue-design/blob/elegant/docs/art/1start-learn",[203],[215],{"type":188,"value":216},"vue-design",{"type":182,"tag":183,"props":218,"children":220},{"id":219},"简介",[221],{"type":188,"value":219},{"type":182,"tag":223,"props":224,"children":226},"h4",{"id":225},"前端框架发展历史关键点",[227],{"type":188,"value":228},"前端框架发展历史关键点？",{"type":182,"tag":191,"props":230,"children":231},{},[232,237,242],{"type":182,"tag":195,"props":233,"children":234},{},[235],{"type":188,"value":236},"2004 年，Google Gmail 使用的 Ajax 技术使前端脱离模板的束缚。",{"type":182,"tag":195,"props":238,"children":239},{},[240],{"type":188,"value":241},"jQuery 解决了不同浏览器的兼容性问题。",{"type":182,"tag":195,"props":243,"children":244},{},[245],{"type":188,"value":246},"2009 年，AngularJS 引领了 MVVM 的潮流，NodeJS 加速了前端工程化的诞生。",{"type":182,"tag":223,"props":248,"children":250},{"id":249},"vue-和-react-的计算性能瓶颈是什么",[251],{"type":188,"value":252},"Vue 和 React 的计算性能瓶颈是什么？",{"type":182,"tag":254,"props":255,"children":256},"p",{},[257],{"type":188,"value":258},"Vue1 的每一个响应式数据都有一个 Watcher，极大的消耗内存，React 的问题发生在当页面 JS 执行 Diff 算法超过帧时间时带来的卡顿问题。",{"type":182,"tag":254,"props":260,"children":261},{},[262],{"type":188,"value":263},"Vue2 引入虚拟 DOM，采用组件级别的响应式数据颗粒度，在避免了 Diff 算法超时问题的同时，降低内存消耗。同时，虚拟 DOM 还带来跨端能力。",{"type":182,"tag":254,"props":265,"children":266},{},[267],{"type":188,"value":268},"React 引入 Fiber 架构，将 DOM Tree 变成链表，使得有能力随时启动或停止 Diff 算法（树的遍历使用递归所以相比链表更难记录状态），可以利用浏览器的空闲时间计算 Diff，避免了卡顿。",{"type":182,"tag":223,"props":270,"children":272},{"id":271},"mvvmmvc-的区别",[273],{"type":188,"value":274},"MVVM、MVC 的区别？",{"type":182,"tag":254,"props":276,"children":277},{},[278],{"type":188,"value":279},"都是软件架构模式，主要区别是关注点不一样，Controller 用来承接交互操作并触发 Model 的修改，而 ViewModel 和 Model 层是双向绑定的，所以写 VueJS 时的思想不在如何操作 DOM 元素，而主要是数据应该怎么变化。",{"type":182,"tag":223,"props":281,"children":283},{"id":282},"vue2-较明显的设计缺陷",[284],{"type":188,"value":285},"Vue2 较明显的设计缺陷？",{"type":182,"tag":191,"props":287,"children":288},{},[289,294,299,304],{"type":182,"tag":195,"props":290,"children":291},{},[292],{"type":188,"value":293},"使用 Flow.js 来做类型校验，而不是社区所向的 TypeScript",{"type":182,"tag":195,"props":295,"children":296},{},[297],{"type":188,"value":298},"Vue2 内嵌了诸如 DOM API 之类的代码，使得跨端等二次开发变得困难，代码耦合也使得摇树优化变得困难",{"type":182,"tag":195,"props":300,"children":301},{},[302],{"type":188,"value":303},"Vue2 使用的 defineProperty 有缺陷，不支持 delete 等操作符",{"type":182,"tag":195,"props":305,"children":306},{},[307],{"type":188,"value":308},"Option API 在组件代码较多时不易维护",{"type":182,"tag":223,"props":310,"children":312},{"id":311},"option-api-的一些缺陷",[313],{"type":188,"value":314},"Option API 的一些缺陷？",{"type":182,"tag":191,"props":316,"children":317},{},[318,323,328],{"type":182,"tag":195,"props":319,"children":320},{},[321],{"type":188,"value":322},"数据挂载在 this 对象上，对类型系统以及摇树优化不友好",{"type":182,"tag":195,"props":324,"children":325},{},[326],{"type":188,"value":327},"代码增多时，维护变得困难",{"type":182,"tag":195,"props":329,"children":330},{},[331],{"type":188,"value":332},"不方便抽离通用逻辑",{"type":182,"tag":223,"props":334,"children":336},{"id":335},"为什么要重写-vue2",[337],{"type":188,"value":338},"为什么要重写 Vue2？",{"type":182,"tag":254,"props":340,"children":341},{},[342],{"type":188,"value":343},"有两个关键因素：主流浏览器逐渐兼容 Proxy，以及修复 Vue2 的设计缺陷。",{"type":182,"tag":254,"props":345,"children":346},{},[347],{"type":188,"value":348},"切换到 Proxy 可以修复过去 setter、getter 无法拦截数组修改以及修改了对象本身带来的语义变化的问题，但由于它是一个原生特性，无法 polyfill，所以对 Vue 而言是一个重大的突破性变动。",{"type":182,"tag":254,"props":350,"children":351},{},[352],{"type":188,"value":353},"过去的架构带来了模板很难正确的在 source-map 中追溯、渲染器（如 DOM 渲染器）不是渐进式的可选项的问题，再加上框架内部代码的耦合，使得摇树优化变得困难，代码也不便理解。",{"type":182,"tag":254,"props":355,"children":356},{},[357,359],{"type":188,"value":358},"见：",{"type":182,"tag":199,"props":360,"children":363},{"href":361,"rel":362},"https://zhuanlan.zhihu.com/p/147022323",[203],[364],{"type":188,"value":365},"重头来过的 Vue 3 带来了什么？",{"type":182,"tag":183,"props":367,"children":369},{"id":368},"响应式",[370],{"type":188,"value":368},{"type":182,"tag":223,"props":372,"children":374},{"id":373},"ref-的原理",[375],{"type":188,"value":376},"ref 的原理？",{"type":182,"tag":254,"props":378,"children":379},{},[380],{"type":188,"value":381},"ref 是在基础值的外面封装了一层对象，使用对象的 value setting、value getter 函数拦截并操作 value 属性，达到响应式的效果。",{"type":182,"tag":183,"props":383,"children":385},{"id":384},"模板",[386],{"type":188,"value":384},{"type":182,"tag":223,"props":388,"children":390},{"id":389},"vue3-双向绑定的原理",[391],{"type":188,"value":392},"Vue3 双向绑定的原理？",{"type":182,"tag":254,"props":394,"children":395},{},[396,397],{"type":188,"value":358},{"type":182,"tag":199,"props":398,"children":401},{"href":399,"rel":400},"https://segmentfault.com/a/1190000041716718",[203],[402],{"type":188,"value":403},"TODO，Vue.js 3.x 双向绑定原理",{"type":182,"tag":183,"props":405,"children":407},{"id":406},"编译器",[408],{"type":188,"value":406},{"type":182,"tag":223,"props":410,"children":412},{"id":411},"vue3-做的静态优化有哪些",[413],{"type":188,"value":414},"Vue3 做的静态优化有哪些？",{"type":182,"tag":254,"props":416,"children":417},{},[418],{"type":182,"tag":419,"props":420,"children":423},"img",{"alt":421,"src":422},"Vue