用，每个小型应用都可以独立开发、独立部署。",{"type":179,"children":180,"toc":336},"root",[181,210,214,221,227,236,242,247,290,296,324],{"type":182,"tag":183,"props":184,"children":185},"element","ul",{},[186,200],{"type":182,"tag":187,"props":188,"children":189},"li",{},[190],{"type":182,"tag":191,"props":192,"children":196},"a",{"href":193,"rel":194},"https://zhuanlan.zhihu.com/p/551206945",[195],"nofollow",[197],{"type":198,"value":199},"text","将微前端做到极致-无界微前端方案",{"type":182,"tag":187,"props":201,"children":202},{},[203],{"type":182,"tag":191,"props":204,"children":207},{"href":205,"rel":206},"https://juejin.cn/post/7016911648656982024",[195],[208],{"type":198,"value":209},"字节跳动是如何落地微前端的",{"type":182,"tag":211,"props":212,"children":213},"hr",{},[],{"type":182,"tag":215,"props":216,"children":218},"h4",{"id":217},"微前端解决什么问题",[219],{"type":198,"value":220},"微前端解决什么问题？",{"type":182,"tag":222,"props":223,"children":224},"p",{},[225],{"type":198,"value":226},"主要应对一个单体应用在相对长的时间跨度下，由于参与人数、团队的增多和变迁，从一个普通应用演变为了巨石应用，随之带来的难以维护的问题。",{"type":182,"tag":222,"props":228,"children":229},{},[230],{"type":182,"tag":231,"props":232,"children":235},"img",{"alt":233,"src":234},"单体应用、前后端分离和微前端","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20221023230253.png",[],{"type":182,"tag":215,"props":237,"children":239},{"id":238},"微前端技术要点",[240],{"type":198,"value":241},"微前端技术要点？",{"type":182,"tag":222,"props":243,"children":244},{},[245],{"type":198,"value":246},"做到技术栈无关的同时提供以下技术能力支持：",{"type":182,"tag":183,"props":248,"children":249},{},[250,255,260,265,270,275,280,285],{"type":182,"tag":187,"props":251,"children":252},{},[253],{"type":198,"value":254},"JS 沙箱：子应用全局变量、事件不互相影响",{"type":182,"tag":187,"props":256,"children":257},{},[258],{"type":198,"value":259},"CSS 隔离：子应用之间的样式不互相影响",{"type":182,"tag":187,"props":261,"children":262},{},[263],{"type":198,"value":264},"公共依赖加载：不同子应用都用到的资源怎么加载",{"type":182,"tag":187,"props":266,"children":267},{},[268],{"type":198,"value":269},"父子应用通讯：子应用如何调用父应用方法、父应用如何下发状态",{"type":182,"tag":187,"props":271,"children":272},{},[273],{"type":198,"value":274},"按需加载",{"type":182,"tag":187,"props":276,"children":277},{},[278],{"type":198,"value":279},"预加载",{"type":182,"tag":187,"props":281,"children":282},{},[283],{"type":198,"value":284},"子应用嵌套",{"type":182,"tag":187,"props":286,"children":287},{},[288],{"type":198,"value":289},"子应用并行",{"type":182,"tag":215,"props":291,"children":293},{"id":292},"微前端的方案选择",[294],{"type":198,"value":295},"微前端的方案选择？",{"type":182,"tag":183,"props":297,"children":298},{},[299,304,309,314,319],{"type":182,"tag":187,"props":300,"children":301},{},[302],{"type":198,"value":303},"基座方案：主应用中预先注册子应用，然后监听路由变化，加载匹配到的子应用资源。",{"type":182,"tag":187,"props":305,"children":306},{},[307],{"type":198,"value":308},"iframe：接入简单并且有完美的隔离效果，但是在共享资源如 URL、Cookie 时不好处理，再者是加载慢。",{"type":182,"tag":187,"props":310,"children":311},{},[312],{"type":198,"value":313},"Web Components：Custom Elements、Shadow DOM、HTML Templates 等规范的集合，需调查兼容性。",{"type":182,"tag":187,"props":315,"children":316},{},[317],{"type":198,"value":318},"Module Federation：没有基座，打包时使用模块联邦注册远程模块，使用时用 import 导入模块。",{"type":182,"tag":187,"props":320,"children":321},{},[322],{"type":198,"value":323},"ESM：微前端的无技术栈限制、应用单独开发，多应用整合三个特性都能很好支持，需调查兼容性，以及 ESM 语法有传染性。",{"type":182,"tag":222,"props":325,"children":326},{},[327,329],{"type":198,"value":328},"表格总结见：",{"type":182,"tag":191,"props":330,"children":333},{"href":331,"rel":332},"https://zhuanlan.zhihu.com/p/556422347",[195],[334],{"type":198,"value":335},"一文读懂 5 种微前端常用方案",{"title":175,"searchDepth":337,"depth":337,"links":338},2,[],"markdown","content:6.maps:_fe-framework:micro-fe:index.md","content","6.maps/_fe-framework/micro-fe/index.md","6.maps/_fe-framework/micro-fe/index","md",[346,350],{"_path":347,"title":348,"description":349},"/maps/_fe-framework/fe-framework","前端框架","前端框架是在前端开发不同阶段，用以简化开发的工具集合。它们提供了一种组织代码的方式，使得开发者可以专注于业务逻辑，而不是底层的技术细节。",{"_path":351,"title":352,"description":353},"/maps/_fe-framework/motion/blockies-animation","Blockies Animation","Designed for performance, ease of use, and seamless integration into any modern project.",1771214204576]