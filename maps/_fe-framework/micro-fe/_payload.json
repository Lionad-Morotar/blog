端应用拆分成更小、更独立的部分，然后将这些部分组合在一起的技术方案。微前端的目标是将单体应用拆分成多个小型应用，每个小型应用都可以独立开发、独立部署。",{"type":182,"children":183,"toc":339},"root",[184,213,217,224,230,239,245,250,293,299,327],{"type":185,"tag":186,"props":187,"children":188},"element","ul",{},[189,203],{"type":185,"tag":190,"props":191,"children":192},"li",{},[193],{"type":185,"tag":194,"props":195,"children":199},"a",{"href":196,"rel":197},"https://zhuanlan.zhihu.com/p/551206945",[198],"nofollow",[200],{"type":201,"value":202},"text","将微前端做到极致-无界微前端方案",{"type":185,"tag":190,"props":204,"children":205},{},[206],{"type":185,"tag":194,"props":207,"children":210},{"href":208,"rel":209},"https://juejin.cn/post/7016911648656982024",[198],[211],{"type":201,"value":212},"字节跳动是如何落地微前端的",{"type":185,"tag":214,"props":215,"children":216},"hr",{},[],{"type":185,"tag":218,"props":219,"children":221},"h4",{"id":220},"微前端解决什么问题",[222],{"type":201,"value":223},"微前端解决什么问题？",{"type":185,"tag":225,"props":226,"children":227},"p",{},[228],{"type":201,"value":229},"主要应对一个单体应用在相对长的时间跨度下，由于参与人数、团队的增多和变迁，从一个普通应用演变为了巨石应用，随之带来的难以维护的问题。",{"type":185,"tag":225,"props":231,"children":232},{},[233],{"type":185,"tag":234,"props":235,"children":238},"img",{"alt":236,"src":237},"单体应用、前后端分离和微前端","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20221023230253.png",[],{"type":185,"tag":218,"props":240,"children":242},{"id":241},"微前端技术要点",[243],{"type":201,"value":244},"微前端技术要点？",{"type":185,"tag":225,"props":246,"children":247},{},[248],{"type":201,"value":249},"做到技术栈无关的同时提供以下技术能力支持：",{"type":185,"tag":186,"props":251,"children":252},{},[253,258,263,268,273,278,283,288],{"type":185,"tag":190,"props":254,"children":255},{},[256],{"type":201,"value":257},"JS 沙箱：子应用全局变量、事件不互相影响",{"type":185,"tag":190,"props":259,"children":260},{},[261],{"type":201,"value":262},"CSS 隔离：子应用之间的样式不互相影响",{"type":185,"tag":190,"props":264,"children":265},{},[266],{"type":201,"value":267},"公共依赖加载：不同子应用都用到的资源怎么加载",{"type":185,"tag":190,"props":269,"children":270},{},[271],{"type":201,"value":272},"父子应用通讯：子应用如何调用父应用方法、父应用如何下发状态",{"type":185,"tag":190,"props":274,"children":275},{},[276],{"type":201,"value":277},"按需加载",{"type":185,"tag":190,"props":279,"children":280},{},[281],{"type":201,"value":282},"预加载",{"type":185,"tag":190,"props":284,"children":285},{},[286],{"type":201,"value":287},"子应用嵌套",{"type":185,"tag":190,"props":289,"children":290},{},[291],{"type":201,"value":292},"子应用并行",{"type":185,"tag":218,"props":294,"children":296},{"id":295},"微前端的方案选择",[297],{"type":201,"value":298},"微前端的方案选择？",{"type":185,"tag":186,"props":300,"children":301},{},[302,307,312,317,322],{"type":185,"tag":190,"props":303,"children":304},{},[305],{"type":201,"value":306},"基座方案：主应用中预先注册子应用，然后监听路由变化，加载匹配到的子应用资源。",{"type":185,"tag":190,"props":308,"children":309},{},[310],{"type":201,"value":311},"iframe：接入简单并且有完美的隔离效果，但是在共享资源如 URL、Cookie 时不好处理，再者是加载慢。",{"type":185,"tag":190,"props":313,"children":314},{},[315],{"type":201,"value":316},"Web Components：Custom Elements、Shadow DOM、HTML Templates 等规范的集合，需调查兼容性。",{"type":185,"tag":190,"props":318,"children":319},{},[320],{"type":201,"value":321},"Module Federation：没有基座，打包时使用模块联邦注册远程模块，使用时用 import 导入模块。",{"type":185,"tag":190,"props":323,"children":324},{},[325],{"type":201,"value":326},"ESM：微前端的无技术栈限制、应用单独开发，多应用整合三个特性都能很好支持，需调查兼容性，以及 ESM 语法有传染性。",{"type":185,"tag":225,"props":328,"children":329},{},[330,332],{"type":201,"value":331},"表格总结见：",{"type":185,"tag":194,"props":333,"children":336},{"href":334,"rel":335},"https://zhuanlan.zhihu.com/p/556422347",[198],[337],{"type":201,"value":338},"一文读懂 5 种微前端常用方案",{"title":178,"searchDepth":340,"depth":340,"links":341},2,[],"markdown","content:6.maps:_fe-framework:micro-fe:index.md","content","6.maps/_fe-framework/micro-fe/index.md","6.maps/_fe-framework/micro-fe/index","md",[349,353],{"_path":350,"title":351,"description":352},"/maps/_fe-framework/fe-framework","前端框架","前端框架是在前端开发不同阶段，用以简化开发的工具集合。它们提供了一种组织代码的方式，使得开发者可以专注于业务逻辑，而不是底层的技术细节。",{"_path":354,"title":355,"description":356},"/maps/_fe-framework/motion/blockies-animation","Blockies Animation","Designed for performance, ease of use, and seamless integration into any modern project.",1771693410062]