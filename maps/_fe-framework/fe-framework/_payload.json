发各阶段的工具集合，包括 UI 框架、元框架、组件方案、动画库等。",{"type":182,"children":183,"toc":473},"root",[184,191,197,203,210,252,257,278,283,304,309,330,335,356,361,373,378,385,390,399,404,412,417,423,428,433,446,452,457,462],{"type":185,"tag":186,"props":187,"children":188},"element","h1",{"id":179},[189],{"type":190,"value":179},"text",{"type":185,"tag":192,"props":193,"children":194},"p",{},[195],{"type":190,"value":196},"前端框架是在前端开发不同阶段，用以简化开发的工具集合。它们提供了一种组织代码的方式，使得开发者可以专注于业务逻辑，而不是底层的技术细节。",{"type":185,"tag":198,"props":199,"children":201},"h2",{"id":200},"子领域导航",[202],{"type":190,"value":200},{"type":185,"tag":204,"props":205,"children":207},"h3",{"id":206},"ui-框架",[208],{"type":190,"value":209},"UI 框架",{"type":185,"tag":211,"props":212,"children":213},"ul",{},[214,225,234,243],{"type":185,"tag":215,"props":216,"children":217},"li",{},[218],{"type":185,"tag":219,"props":220,"children":222},"a",{"href":221},"/maps/_fe-framework/ui-frameworks/vue",[223],{"type":190,"value":224},"Vue",{"type":185,"tag":215,"props":226,"children":227},{},[228],{"type":185,"tag":219,"props":229,"children":231},{"href":230},"/maps/_fe-framework/ui-frameworks/react",[232],{"type":190,"value":233},"React",{"type":185,"tag":215,"props":235,"children":236},{},[237],{"type":185,"tag":219,"props":238,"children":240},{"href":239},"/maps/_fe-framework/ui-frameworks/angular",[241],{"type":190,"value":242},"Angular",{"type":185,"tag":215,"props":244,"children":245},{},[246],{"type":185,"tag":219,"props":247,"children":249},{"href":248},"/maps/_fe-framework/ui-frameworks/vue-reactive",[250],{"type":190,"value":251},"Vue 响应式",{"type":185,"tag":204,"props":253,"children":255},{"id":254},"元框架",[256],{"type":190,"value":254},{"type":185,"tag":211,"props":258,"children":259},{},[260,269],{"type":185,"tag":215,"props":261,"children":262},{},[263],{"type":185,"tag":219,"props":264,"children":266},{"href":265},"/maps/_fe-framework/meta-frameworks/nuxt",[267],{"type":190,"value":268},"Nuxt",{"type":185,"tag":215,"props":270,"children":271},{},[272],{"type":185,"tag":219,"props":273,"children":275},{"href":274},"/maps/_fe-framework/meta-frameworks/nuxt-security",[276],{"type":190,"value":277},"Nuxt Security",{"type":185,"tag":204,"props":279,"children":281},{"id":280},"组件方案",[282],{"type":190,"value":280},{"type":185,"tag":211,"props":284,"children":285},{},[286,295],{"type":185,"tag":215,"props":287,"children":288},{},[289],{"type":185,"tag":219,"props":290,"children":292},{"href":291},"/maps/_fe-framework/component-solutions/web-components",[293],{"type":190,"value":294},"Web Components",{"type":185,"tag":215,"props":296,"children":297},{},[298],{"type":185,"tag":219,"props":299,"children":301},{"href":300},"/maps/_fe-framework/component-solutions/micro-frontend",[302],{"type":190,"value":303},"微前端",{"type":185,"tag":204,"props":305,"children":307},{"id":306},"动画与交互",[308],{"type":190,"value":306},{"type":185,"tag":211,"props":310,"children":311},{},[312,321],{"type":185,"tag":215,"props":313,"children":314},{},[315],{"type":185,"tag":219,"props":316,"children":318},{"href":317},"/maps/_fe-framework/motion/blockies-animation",[319],{"type":190,"value":320},"Blockies Animation",{"type":185,"tag":215,"props":322,"children":323},{},[324],{"type":185,"tag":219,"props":325,"children":327},{"href":326},"/maps/_fe-framework/motion/lottie",[328],{"type":190,"value":329},"Lottie",{"type":185,"tag":204,"props":331,"children":333},{"id":332},"类型系统",[334],{"type":190,"value":332},{"type":185,"tag":211,"props":336,"children":337},{},[338,347],{"type":185,"tag":215,"props":339,"children":340},{},[341],{"type":185,"tag":219,"props":342,"children":344},{"href":343},"/maps/_fe-framework/type-system/utility-types",[345],{"type":190,"value":346},"Utility Types",{"type":185,"tag":215,"props":348,"children":349},{},[350],{"type":185,"tag":219,"props":351,"children":353},{"href":352},"/maps/_fe-framework/type-system/zod",[354],{"type":190,"value":355},"Zod",{"type":185,"tag":204,"props":357,"children":359},{"id":358},"资源管理",[360],{"type":190,"value":358},{"type":185,"tag":211,"props":362,"children":363},{},[364],{"type":185,"tag":215,"props":365,"children":366},{},[367],{"type":185,"tag":219,"props":368,"children":370},{"href":369},"/maps/_fe-framework/assets/iconify",[371],{"type":190,"value":372},"Iconify",{"type":185,"tag":198,"props":374,"children":376},{"id":375},"知识点",[377],{"type":190,"value":375},{"type":185,"tag":379,"props":380,"children":382},"h4",{"id":381},"sharing-state-with-islands-architecture",[383],{"type":190,"value":384},"Sharing State with Islands Architecture",{"type":185,"tag":192,"props":386,"children":387},{},[388],{"type":190,"value":389},"MAXI FERREIRA 阐述的在岛模式组件中管理状态的思路也可以用于低代码场景。",{"type":185,"tag":391,"props":392,"children":393},"blockquote",{},[394],{"type":185,"tag":192,"props":395,"children":396},{},[397],{"type":190,"value":398},"We have several options for choosing a store. Astro recommends the nanostores library in their documentation, which is what we'll use for our example, but several UI frameworks already come with a built-in solution—Svelte has Stores, Preact has Signals (as does Solid), and Vue has the Reactivity API.",{"type":185,"tag":192,"props":400,"children":401},{},[402],{"type":190,"value":403},"第一次见到有人在公开场合说 Vue 的 Reactive API 是可以用于管理状态的。",{"type":185,"tag":192,"props":405,"children":406},{},[407],{"type":185,"tag":408,"props":409,"children":411},"img",{"alt":178,"src":410},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20231010125234.png",[],{"type":185,"tag":192,"props":413,"children":414},{},[415],{"type":190,"value":416},"新的状态管理办法结合了事件通知和统一的状态管理库。一种替代的版本是使用回调函数。",{"type":185,"tag":379,"props":418,"children":420},{"id":419},"模板语言为何终将变成糟糕的编程语言",[421],{"type":190,"value":422},"模板语言为何终将变成糟糕的编程语言？",{"type":185,"tag":192,"props":424,"children":425},{},[426],{"type":190,"value":427},"许多框架坚持使用模板语言而非将 HTML/CSS 融入 JavaScript。但模板语言的演化轨迹证明：\n它们 inevitably 会添加条件、循环、作用域、宏等特性，最终变成一门表达能力远逊于真正编程语言的\"内部平台\"。\n模板语言假设存在一个\"不怕代码但不够聪明写真正代码\"的用户群体，但实践中这个群体并不存在——\n设计师根本不想写代码，而开发者需要原生表达能力。",{"type":185,"tag":192,"props":429,"children":430},{},[431],{"type":190,"value":432},"动态语言的优势在于运行时可重新配置行为，这对构建赋予用户自由度的复杂应用至关重要。\n大多数 React 替代方案针对的是\"网站\"而非\"应用\"场景，它们铺设的是走惯的小径，\n却从未超越这些路径。",{"type":185,"tag":192,"props":434,"children":435},{},[436,438],{"type":190,"value":437},"见：",{"type":185,"tag":219,"props":439,"children":443},{"href":440,"rel":441},"https://acko.net/blog/get-in-zoomer-we-re-saving-react/",[442],"nofollow",[444],{"type":190,"value":445},"Get in Zoomer, We're Saving React",{"type":185,"tag":379,"props":447,"children":449},{"id":448},"编译型框架的崛起是否推翻了模板语言批评",[450],{"type":190,"value":451},"编译型框架的崛起是否推翻了模板语言批评？",{"type":185,"tag":192,"props":453,"children":454},{},[455],{"type":190,"value":456},"2022 年的批评认为 React 替代方案\"只适合网站\"。但 2025-2026 年的数据显示：\nSvelte 开发者满意度达 92%，SolidJS 达 90%，均超越 React 的 78%。\nSolidJS 已进入 NASA JPL 等高性能场景，SvelteKit 支撑起复杂全栈应用。",{"type":185,"tag":192,"props":458,"children":459},{},[460],{"type":190,"value":461},"编译时优化与细粒度响应式的组合证明：模板/编译方案可以在保持开发体验的同时，\n达到甚至超越虚拟 DOM 方案的灵活性。Vue 3.6 的 Vapor 模式（绕过虚拟 DOM）\n进一步模糊了\"模板 vs JSX\"的界限。",{"type":185,"tag":192,"props":463,"children":464},{},[465,471],{"type":185,"tag":466,"props":467,"children":468},"strong",{},[469],{"type":190,"value":470},"修正结论",{"type":190,"value":472},"：模板语言 vs JSX 之争未分胜负，取决于场景——\n内容型网站倾向模板（Astro、Svelte），高度交互应用倾向 JSX（React、Solid）。\n2022 年对编译型框架的悲观预测已被证伪。",{"title":178,"searchDepth":474,"depth":474,"links":475},2,[476,485],{"id":200,"depth":474,"text":200,"children":477},[478,480,481,482,483,484],{"id":206,"depth":479,"text":209},3,{"id":254,"depth":479,"text":254},{"id":280,"depth":479,"text":280},{"id":306,"depth":479,"text":306},{"id":332,"depth":479,"text":332},{"id":358,"depth":479,"text":358},{"id":375,"depth":474,"text":375},"markdown","content:6.maps:_fe-framework:fe-framework.md","content","6.maps/_fe-framework/fe-framework.md","6.maps/_fe-framework/fe-framework","md",[493,495],{"_path":291,"title":294,"description":494},"Web Components 是一种 Web 开发技术，它允许开发者创建自定义的、可重用的组件，这些组件可以在不同的 Web 应用中使用。",{"_path":496,"title":254,"description":497},"/maps/_fe-framework/meta-frameworks","基于 UI 框架的全栈开发框架，提供 SSR、SSG、路由等开箱即用功能。",1772185448037]