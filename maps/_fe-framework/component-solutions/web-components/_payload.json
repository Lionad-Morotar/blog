ps/_fe-framework/component-solutions/web-components","component-solutions",false,true,"","Web Components","Web Components 是一种 Web 开发技术，它允许开发者创建自定义的、可重用的组件，这些组件可以在不同的 Web 应用中使用。","/maps/_fe-framework/web-components.md",{"type":183,"children":184,"toc":1269},"root",[185,194,206,211,241,247,252,282,303,308,376,381,398,403,416,421,900,913,1017,1023,1028,1033,1143,1148,1153,1207,1263],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"shadow-dom",[191],{"type":192,"value":193},"text","Shadow DOM",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198,204],{"type":186,"tag":199,"props":200,"children":201},"strong",{},[202],{"type":192,"value":203},"传统网页应用中的样式具有一定程度的脆弱性，微小样式带来的影响通常会逐渐累积、放大，最终给全局带来影响。",{"type":192,"value":205}," 为了解决这种脆弱性，Shadow DOM 定义了一系列围绕 DOM 产生的新概念，如影子树规范（DOM 4.1）、UI 交互规范等。其渲染部分则与 CSS 作用域规范（CSS Scoping Specification）相关。",{"type":186,"tag":195,"props":207,"children":208},{},[209],{"type":192,"value":210},"影子树（Shadow Tree）的根节点是影子根（Shadow Root），后者并不是一个真正的元素，不过它作为影子树和 DOM 的桥梁，和一个正常的 DOM 元素，即影子宿主（Shadow Root）绑定在一起。有时，我们会按照组件的作用域范围，把影子宿主所在的树称作 Light Tree（组件外部），以区分影子树所在树 Dark Tree（组件内部）。",{"type":186,"tag":195,"props":212,"children":213},{},[214,216,230,232,239],{"type":192,"value":215},"可能会令人困惑的是：影子宿主元素中的正常元素是不会被正常渲染，而是通过规范定义的通讯组（Distribution List",{"type":186,"tag":217,"props":218,"children":219},"sup",{},[220],{"type":186,"tag":221,"props":222,"children":227},"a",{"href":223,"ariaDescribedBy":224,"dataFootnoteRef":178,"id":226},"#user-content-fn-distribution-list",[225],"footnote-label","user-content-fnref-distribution-list",[228],{"type":192,"value":229},"1",{"type":192,"value":231},"）将这些元素强制拉入影子树中渲染。通讯组不是一个实体概念，但它具有一个 Content 元素，将影子宿主中的正常元素囊括其中，而 Content 本身并不渲染（类似 ",{"type":186,"tag":233,"props":234,"children":236},"code",{"className":235},[],[237],{"type":192,"value":238},"display：content",{"type":192,"value":240},"）。",{"type":186,"tag":242,"props":243,"children":245},"h3",{"id":244},"样式",[246],{"type":192,"value":244},{"type":186,"tag":195,"props":248,"children":249},{},[250],{"type":192,"value":251},"相关 Shadow DOM 有几种新的选择器方法：",{"type":186,"tag":253,"props":254,"children":255},"ul",{},[256,262,267,272,277],{"type":186,"tag":257,"props":258,"children":259},"li",{},[260],{"type":192,"value":261},"选择影子宿主：在影子树样式中直接使用使用 $:host$、$:host()$ 伪类选择影子宿主；",{"type":186,"tag":257,"props":263,"children":264},{},[265],{"type":192,"value":266},"向上选择：使用 $:host-context()$ 伪类选择器可以选取当前元素的\"父节点\"，可能是影子宿主、Distribution List 的 Content 元素或元素的父元素；",{"type":186,"tag":257,"props":268,"children":269},{},[270],{"type":192,"value":271},"向下选择：使用 $::shadow()$ 选择当前元素对应的影子根（可以有多个）；",{"type":186,"tag":257,"props":273,"children":274},{},[275],{"type":192,"value":276},"选择通讯组：使用 $::content$ 选择当前影子树对应的宿主中通讯组对应的 Content 元素；",{"type":186,"tag":257,"props":278,"children":279},{},[280],{"type":192,"value":281},"选择插槽：使用 $::slotted()$ 选择插槽节点；（插槽在下一小节介绍）",{"type":186,"tag":195,"props":283,"children":284},{},[285,287,293,295,301],{"type":192,"value":286},"需要注意的是，对影子宿主来说，组件内部样式的优先级总是低于外部样式的，如 ",{"type":186,"tag":233,"props":288,"children":290},{"className":289},[],[291],{"type":192,"value":292},".shadow-root",{"type":192,"value":294}," 的优先级要高于影子树内部的 ",{"type":186,"tag":233,"props":296,"children":298},{"className":297},[],[299],{"type":192,"value":300},":host",{"type":192,"value":302},"。",{"type":186,"tag":195,"props":304,"children":305},{},[306],{"type":192,"value":307},"此外，CSS 作用域规范提供了深度选择器（$/deep/$），用于穿刺选择，无论嵌套多深的影子树中的元素都能被选中。不过，一些 CSS 中可继承的属性会穿透影子边界，所以建议使用如下样式重置组件内的 CSS：",{"type":186,"tag":309,"props":310,"children":314},"pre",{"className":311,"code":312,"language":313,"meta":178,"style":178},"language-css shiki shiki-themes material-theme-lighter github-light github-dark monokai",":host {\n  all: initial;\n}\n","css",[315],{"type":186,"tag":233,"props":316,"children":317},{"__ignoreMap":178},[318,342,367],{"type":186,"tag":319,"props":320,"children":323},"span",{"class":321,"line":322},"line",1,[324,330,336],{"type":186,"tag":3