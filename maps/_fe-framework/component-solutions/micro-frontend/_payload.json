ramework/component-solutions/micro-frontend","component-solutions",false,true,"","微前端","微前端是一种架构风格，是一种将前端应用拆分成更小、更独立的部分，然后将这些部分组合在一起的技术方案。微前端的目标是将单体应用拆分成多个小型应用，每个小型应用都可以独立开发、独立部署。","/maps/_fe-framework/micro-fe/index.md",{"type":183,"children":184,"toc":340},"root",[185,214,218,225,231,240,246,251,294,300,328],{"type":186,"tag":187,"props":188,"children":189},"element","ul",{},[190,204],{"type":186,"tag":191,"props":192,"children":193},"li",{},[194],{"type":186,"tag":195,"props":196,"children":200},"a",{"href":197,"rel":198},"https://zhuanlan.zhihu.com/p/551206945",[199],"nofollow",[201],{"type":202,"value":203},"text","将微前端做到极致-无界微前端方案",{"type":186,"tag":191,"props":205,"children":206},{},[207],{"type":186,"tag":195,"props":208,"children":211},{"href":209,"rel":210},"https://juejin.cn/post/7016911648656982024",[199],[212],{"type":202,"value":213},"字节跳动是如何落地微前端的",{"type":186,"tag":215,"props":216,"children":217},"hr",{},[],{"type":186,"tag":219,"props":220,"children":222},"h4",{"id":221},"微前端解决什么问题",[223],{"type":202,"value":224},"微前端解决什么问题？",{"type":186,"tag":226,"props":227,"children":228},"p",{},[229],{"type":202,"value":230},"主要应对一个单体应用在相对长的时间跨度下，由于参与人数、团队的增多和变迁，从一个普通应用演变为了巨石应用，随之带来的难以维护的问题。",{"type":186,"tag":226,"props":232,"children":233},{},[234],{"type":186,"tag":235,"props":236,"children":239},"img",{"alt":237,"src":238},"单体应用、前后端分离和微前端","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20221023230253.png",[],{"type":186,"tag":219,"props":241,"children":243},{"id":242},"微前端技术要点",[244],{"type":202,"value":245},"微前端技术要点？",{"type":186,"tag":226,"props":247,"children":248},{},[249],{"type":202,"value":250},"做到技术栈无关的同时提供以下技术能力支持：",{"type":186,"tag":187,"props":252,"children":253},{},[254,259,264,269,274,279,284,289],{"type":186,"tag":191,"props":255,"children":256},{},[257],{"type":202,"value":258},"JS 沙箱：子应用全局变量、事件不互相影响",{"type":186,"tag":191,"props":260,"children":261},{},[262],{"type":202,"value":263},"CSS 隔离：子应用之间的样式不互相影响",{"type":186,"tag":191,"props":265,"children":266},{},[267],{"type":202,"value":268},"公共依赖加载：不同子应用都用到的资源怎么加载",{"type":186,"tag":191,"props":270,"children":271},{},[272],{"type":202,"value":273},"父子应用通讯：子应用如何调用父应用方法、父应用如何下发状态",{"type":186,"tag":191,"props":275,"children":276},{},[277],{"type":202,"value":278},"按需加载",{"type":186,"tag":191,"props":280,"children":281},{},[282],{"type":202,"value":283},"预加载",{"type":186,"tag":191,"props":285,"children":286},{},[287],{"type":202,"value":288},"子应用嵌套",{"type":186,"tag":191,"props":290,"children":291},{},[292],{"type":202,"value":293},"子应用并行",{"type":186,"tag":219,"props":295,"children":297},{"id":296},"微前端的方案选择",[298],{"type":202,"value":299},"微前端的方案选择？",{"type":186,"tag":187,"props":301,"children":302},{},[303,308,313,318,323],{"type":186,"tag":191,"props":304,"children":305},{},[306],{"type":202,"value":307},"基座方案：主应用中预先注册子应用，然后监听路由变化，加载匹配到的子应用资源。",{"type":186,"tag":191,"props":309,"children":310},{},[311],{"type":202,"value":312},"iframe：接入简单并且有完美的隔离效果，但是在共享资源如 URL、Cookie 时不好处理，再者是加载慢。",{"type":186,"tag":191,"props":314,"children":315},{},[316],{"type":202,"value":317},"Web Components：Custom Elements、Shadow DOM、HTML Templates 等规范的集合，需调查兼容性。",{"type":186,"tag":191,"props":319,"children":320},{},[321],{"type":202,"value":322},"Module Federation：没有基座，打包时使用模块联邦注册远程模块，使用时用 import 导入模块。",{"type":186,"tag":191,"props":324,"children":325},{},[326],{"type":202,"value":327},"ESM：微前端的无技术栈限制、应用单独开发，多应用整合三个特性都能很好支持，需调查兼容性，以及 ESM 语法有传染性。",{"type":186,"tag":226,"props":329,"children":330},{},[331,333],{"type":202,"value":332},"表格总结见：",{"type":186,"tag":195,"props":334,"children":337},{"href":335,"rel":336},"https://zhuanlan.zhihu.com/p/556422347",[199],[338],{"type":202,"value":339},"一文读懂 5 种微前端常用方案",{"title":178,"searchDepth":341,"depth":341,"links":342},2,[],"markdown","content:6.maps:_fe-framework:component-solutions:micro-frontend.md","content","6.maps/_fe-framework/component-solutions/micro-frontend.md","6.maps/_fe-framework/component-solutions/micro-frontend","md",[350,354],{"_path":351,"title":352,"description":353},"/maps/_fe-framework/component-solutions","组件方案","前端组件化解决方案，包括 Web Components 标准和微前端架构。",{"_path":355,"title":356,"description":357},"/maps/_fe-framework/component-solutions/web-components","Web Components","Web Components 是一种 Web 开发技术，它允许开发者创建自定义的、可重用的组件，这些组件可以在不同的 Web 应用中使用。",1772504922853]