{"style":1168},[1205],{"type":187,"value":741},{"type":182,"tag":244,"props":1207,"children":1208},{"class":246,"line":315},[1209,1214,1218,1222,1227],{"type":182,"tag":244,"props":1210,"children":1211},{"style":380},[1212],{"type":187,"value":1213},"  characterSet",{"type":182,"tag":244,"props":1215,"children":1216},{"style":783},[1217],{"type":187,"value":786},{"type":182,"tag":244,"props":1219,"children":1220},{"style":403},[1221],{"type":187,"value":791},{"type":182,"tag":244,"props":1223,"children":1224},{"style":794},[1225],{"type":187,"value":1226},"!@#$%^&*()_+-=[]{}|;:,.\u003C>?",{"type":182,"tag":244,"props":1228,"children":1229},{"style":403},[1230],{"type":187,"value":1231},"\"\n",{"type":182,"tag":244,"props":1233,"children":1234},{"class":246,"line":354},[1235],{"type":182,"tag":244,"props":1236,"children":1237},{"style":263},[1238],{"type":187,"value":806},{"type":182,"tag":244,"props":1240,"children":1241},{"class":246,"line":363},[1242],{"type":182,"tag":244,"props":1243,"children":1244},{"style":257},[1245],{"type":187,"value":1246},"  Fast Special Characters Hover\n",{"type":182,"tag":244,"props":1248,"children":1249},{"class":246,"line":390},[1250,1254,1258],{"type":182,"tag":244,"props":1251,"children":1252},{"style":263},[1253],{"type":187,"value":856},{"type":182,"tag":244,"props":1255,"children":1256},{"style":772},[1257],{"type":187,"value":1148},{"type":182,"tag":244,"props":1259,"children":1260},{"style":263},[1261],{"type":187,"value":806},{"type":182,"tag":183,"props":1263,"children":1264},{},[1265],{"type":187,"value":1266},"可能让人意外的是，文字打乱的效果其实早就可以用纯 CSS 实现，比如下图展示了从“CSS”变换到“YES”的过程。",{"type":182,"tag":183,"props":1268,"children":1269},{},[1270],{"type":182,"tag":204,"props":1271,"children":1274},{"alt":1272,"src":1273},"文字变化效果","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202506121624129.gif",[],{"type":182,"tag":183,"props":1276,"children":1277},{},[1278,1280,1287],{"type":187,"value":1279},"这种实现的好处在于，可以利用 transition 动画曲线等 CSS 特性，实现主题复用，无需用 JS 传递参数。原理也很简单，就是用 counter 函数的第二个参数，将带有动画效果的数字转为字符显示。例如，下图中“1”被转化为字母“a”。详细介绍参考：",{"type":182,"tag":190,"props":1281,"children":1284},{"href":1282,"rel":1283},"https://css-tricks.com/animating-number-counters",[194],[1285],{"type":187,"value":1286},"Animating Number Counters",{"type":187,"value":1039},{"type":182,"tag":183,"props":1289,"children":1290},{},[1291],{"type":182,"tag":204,"props":1292,"children":1295},{"alt":1293,"src":1294},"counter 函数第二个参数","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202506121620640.png",[],{"type":182,"tag":899,"props":1297,"children":1299},{"id":1298},"zoom-effect放大效果",[1300],{"type":187,"value":1301},"Zoom Effect（放大效果）",{"type":182,"tag":183,"props":1303,"children":1304},{},[1305],{"type":187,"value":1306},"鼠标悬浮时放大某个部分的效果。",{"type":182,"tag":183,"props":1308,"children":1309},{},[1310],{"type":182,"tag":204,"props":1311,"children":1314},{"alt":1312,"src":1313},"放大效果","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202506121639073.png",[],{"type":182,"tag":183,"props":1316,"children":1317},{},[1318],{"type":187,"value":1319},"这种放大镜效果的实现，是采用了一个双层 DOM 结构：内层是完整复制的内容节点，外层是一个设置了 overflow: hidden 的圆形容器。通过计算鼠标在内容上的偏移量，动态设置内外层容器的位置，就能在鼠标悬浮时显示对应区域的放大效果。",{"type":182,"tag":183,"props":1321,"children":1322},{},[1323],{"type":182,"tag":204,"props":1324,"children":1327},{"alt":1325,"src":1326},"双层节点结构","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202506121646084.png",[],{"type":182,"tag":183,"props":1329,"children":1330},{},[1331,1333,1339],{"type":187,"value":1332},"距离偏移量的计算可以画个草图帮助理解。外层圆因为溢出隐藏，只允许内容在 ",{"type":182,"tag":225,"props":1334,"children":1336},{"className":1335},[],[1337],{"type":187,"value":1338},"[0 - 圆半径，待放大内容宽高 - 圆半径]",{"type":187,"value":1340}," 这个范围内移动。内层容器的偏移量，只需根据放大倍数，乘以鼠标在内容区的 x、y 比例坐标即可。比如，当鼠标移到右上角时，对应的位移如下图所示：",{"type":182,"tag":183,"props":1342,"children":1343},{},[1344],{"type":182,"tag":204,"props":1345,"children":1348},{"alt":1346,"src":1347},"内层容器位移","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202506121655370.png",[],{"type":182,"tag":1350,"props":1351,"children":1352},"style",{},[1353],{"type":187,"value":1354},"html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html .sepia .shiki span {color: var(--shiki-sepia);background: var(--shiki-sepia-bg);font-style: var(--shiki-sepia-font-style);font-weight: var(--shiki-sepia-font-weight);text-decoration: var(--shiki-sepia-text-decoration);}html.sepia .shiki span {color: var(--shiki-sepia);background: var(--shiki-sepia-bg);font-style: var(--shiki-sepia-font-style);font-weight: var(--shiki-sepia-font-weight);text-decoration: var(--shiki-sepia-text-decoration);}",{"title":175,"searchDepth":269,"depth":269,"links":1356},[1357,1358],{"id":211,"depth":269,"text":211},{"id":882,"depth":269,"text":882,"children":1359},[1360,1361,1362,1363,1364],{"id":901,"depth":289,"text":904},{"id":992,"depth":289,"text":995},{"id":1042,"depth":289,"text":1045},{"id":1113,"depth":289,"text":1116},{"id":1298,"depth":289,"text":1301},"markdown","content:6.maps:_fe-framework:motion:blockies-animation.md","content","6.maps/_fe-framework/motion/blockies-animation.md","6.maps/_fe-framework/motion/blockies-animation","md",[1372,1376],{"_path":1373,"title":1374,"description":1375},"/maps/_fe-framework/micro-fe","微前端","微前端是一种架构风格，是一种将前端应用拆分成更小、更独立的部分，然后将这些部分组合在一起的技术方案。微前端的目标是将单体应用拆分成多个小型应用，每个小型应用都可以独立开发、独立部署。",{"_path":1377,"title":1378,"description":1379},"/maps/_fe-framework/nuxt/module/nuxt-security","Nuxt Security","自动通过使用 HTTP 头和中间件配置您的应用程序遵循 OWASP 安全模式和原则",1771214943450]