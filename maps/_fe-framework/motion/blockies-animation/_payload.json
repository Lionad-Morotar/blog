.02",{"type":185,"tag":247,"props":1206,"children":1207},{"style":1171},[1208],{"type":190,"value":744},{"type":185,"tag":247,"props":1210,"children":1211},{"class":249,"line":318},[1212,1217,1221,1225,1230],{"type":185,"tag":247,"props":1213,"children":1214},{"style":383},[1215],{"type":190,"value":1216},"  characterSet",{"type":185,"tag":247,"props":1218,"children":1219},{"style":786},[1220],{"type":190,"value":789},{"type":185,"tag":247,"props":1222,"children":1223},{"style":406},[1224],{"type":190,"value":794},{"type":185,"tag":247,"props":1226,"children":1227},{"style":797},[1228],{"type":190,"value":1229},"!@#$%^&*()_+-=[]{}|;:,.\u003C>?",{"type":185,"tag":247,"props":1231,"children":1232},{"style":406},[1233],{"type":190,"value":1234},"\"\n",{"type":185,"tag":247,"props":1236,"children":1237},{"class":249,"line":357},[1238],{"type":185,"tag":247,"props":1239,"children":1240},{"style":266},[1241],{"type":190,"value":809},{"type":185,"tag":247,"props":1243,"children":1244},{"class":249,"line":366},[1245],{"type":185,"tag":247,"props":1246,"children":1247},{"style":260},[1248],{"type":190,"value":1249},"  Fast Special Characters Hover\n",{"type":185,"tag":247,"props":1251,"children":1252},{"class":249,"line":393},[1253,1257,1261],{"type":185,"tag":247,"props":1254,"children":1255},{"style":266},[1256],{"type":190,"value":859},{"type":185,"tag":247,"props":1258,"children":1259},{"style":775},[1260],{"type":190,"value":1151},{"type":185,"tag":247,"props":1262,"children":1263},{"style":266},[1264],{"type":190,"value":809},{"type":185,"tag":186,"props":1266,"children":1267},{},[1268],{"type":190,"value":1269},"可能让人意外的是，文字打乱的效果其实早就可以用纯 CSS 实现，比如下图展示了从“CSS”变换到“YES”的过程。",{"type":185,"tag":186,"props":1271,"children":1272},{},[1273],{"type":185,"tag":207,"props":1274,"children":1277},{"alt":1275,"src":1276},"文字变化效果","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202506121624129.gif",[],{"type":185,"tag":186,"props":1279,"children":1280},{},[1281,1283,1290],{"type":190,"value":1282},"这种实现的好处在于，可以利用 transition 动画曲线等 CSS 特性，实现主题复用，无需用 JS 传递参数。原理也很简单，就是用 counter 函数的第二个参数，将带有动画效果的数字转为字符显示。例如，下图中“1”被转化为字母“a”。详细介绍参考：",{"type":185,"tag":193,"props":1284,"children":1287},{"href":1285,"rel":1286},"https://css-tricks.com/animating-number-counters",[197],[1288],{"type":190,"value":1289},"Animating Number Counters",{"type":190,"value":1042},{"type":185,"tag":186,"props":1292,"children":1293},{},[1294],{"type":185,"tag":207,"props":1295,"children":1298},{"alt":1296,"src":1297},"counter 函数第二个参数","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202506121620640.png",[],{"type":185,"tag":902,"props":1300,"children":1302},{"id":1301},"zoom-effect放大效果",[1303],{"type":190,"value":1304},"Zoom Effect（放大效果）",{"type":185,"tag":186,"props":1306,"children":1307},{},[1308],{"type":190,"value":1309},"鼠标悬浮时放大某个部分的效果。",{"type":185,"tag":186,"props":1311,"children":1312},{},[1313],{"type":185,"tag":207,"props":1314,"children":1317},{"alt":1315,"src":1316},"放大效果","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202506121639073.png",[],{"type":185,"tag":186,"props":1319,"children":1320},{},[1321],{"type":190,"value":1322},"这种放大镜效果的实现，是采用了一个双层 DOM 结构：内层是完整复制的内容节点，外层是一个设置了 overflow: hidden 的圆形容器。通过计算鼠标在内容上的偏移量，动态设置内外层容器的位置，就能在鼠标悬浮时显示对应区域的放大效果。",{"type":185,"tag":186,"props":1324,"children":1325},{},[1326],{"type":185,"tag":207,"props":1327,"children":1330},{"alt":1328,"src":1329},"双层节点结构","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202506121646084.png",[],{"type":185,"tag":186,"props":1332,"children":1333},{},[1334,1336,1342],{"type":190,"value":1335},"距离偏移量的计算可以画个草图帮助理解。外层圆因为溢出隐藏，只允许内容在 ",{"type":185,"tag":228,"props":1337,"children":1339},{"className":1338},[],[1340],{"type":190,"value":1341},"[0 - 圆半径，待放大内容宽高 - 圆半径]",{"type":190,"value":1343}," 这个范围内移动。内层容器的偏移量，只需根据放大倍数，乘以鼠标在内容区的 x、y 比例坐标即可。比如，当鼠标移到右上角时，对应的位移如下图所示：",{"type":185,"tag":186,"props":1345,"children":1346},{},[1347],{"type":185,"tag":207,"props":1348,"children":1351},{"alt":1349,"src":1350},"内层容器位移","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202506121655370.png",[],{"type":185,"tag":1353,"props":1354,"children":1355},"style",{},[1356],{"type":190,"value":1357},"html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html .sepia .shiki span {color: var(--shiki-sepia);background: var(--shiki-sepia-bg);font-style: var(--shiki-sepia-font-style);font-weight: var(--shiki-sepia-font-weight);text-decoration: var(--shiki-sepia-text-decoration);}html.sepia .shiki span {color: var(--shiki-sepia);background: var(--shiki-sepia-bg);font-style: var(--shiki-sepia-font-style);font-weight: var(--shiki-sepia-font-weight);text-decoration: var