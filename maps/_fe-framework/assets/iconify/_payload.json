88,"value":327}," fill",{"type":182,"tag":217,"props":329,"children":330},{"style":224},[331],{"type":188,"value":244},{"type":182,"tag":217,"props":333,"children":334},{"style":247},[335],{"type":188,"value":250},{"type":182,"tag":217,"props":337,"children":338},{"style":253},[339],{"type":188,"value":340},"blue",{"type":182,"tag":217,"props":342,"children":343},{"style":247},[344],{"type":188,"value":250},{"type":182,"tag":217,"props":346,"children":347},{"style":236},[348],{"type":188,"value":349}," d",{"type":182,"tag":217,"props":351,"children":352},{"style":224},[353],{"type":188,"value":244},{"type":182,"tag":217,"props":355,"children":356},{"style":247},[357],{"type":188,"value":250},{"type":182,"tag":217,"props":359,"children":360},{"style":253},[361],{"type":188,"value":362},"M5 5h14v14H5z",{"type":182,"tag":217,"props":364,"children":365},{"style":247},[366],{"type":188,"value":250},{"type":182,"tag":217,"props":368,"children":369},{"style":224},[370],{"type":188,"value":371},"/>\n",{"type":182,"tag":217,"props":373,"children":375},{"class":219,"line":374},3,[376,381,385],{"type":182,"tag":217,"props":377,"children":378},{"style":224},[379],{"type":188,"value":380},"\u003C/",{"type":182,"tag":217,"props":382,"children":383},{"style":230},[384],{"type":188,"value":233},{"type":182,"tag":217,"props":386,"children":387},{"style":224},[388],{"type":188,"value":308},{"type":182,"tag":190,"props":390,"children":391},{},[392],{"type":188,"value":393},"此外还提供了统一的设计规范，使用 Material Design Icons 的网格为图标填充做指导。",{"type":182,"tag":190,"props":395,"children":396},{},[397],{"type":182,"tag":398,"props":399,"children":402},"img",{"alt":400,"src":401},"Material Design Icons","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202504010251952.png",[],{"type":182,"tag":190,"props":404,"children":405},{},[406],{"type":188,"value":407},"Iconify 的图标集就是一组带有相同设计规范和元信息的图标集合。",{"type":182,"tag":190,"props":409,"children":410},{},[411],{"type":188,"value":412},"除了开发者使用上的方便，Iconify 在数量上也有优势，其包含了超过 20w 的开源图标。",{"type":182,"tag":190,"props":414,"children":415},{},[416],{"type":188,"value":417},"那么具体如何使用呢？Iconify 提供了两种使用方式：",{"type":182,"tag":419,"props":420,"children":421},"ol",{},[422,428],{"type":182,"tag":423,"props":424,"children":425},"li",{},[426],{"type":188,"value":427},"下载 IconifyJSON 格式的图标集合库，如 @iconify/json，然后在代码中通过 API 找到并使用对应 SVG 文件",{"type":182,"tag":423,"props":429,"children":430},{},[431],{"type":188,"value":432},"使用 Iconify API，一般来说是向第三方发送图标名称，然后使用服务返回的图标文件",{"type":182,"tag":190,"props":434,"children":435},{},[436],{"type":188,"value":437},"由于 @iconify/json 包含所有图标集，其包体积很大，所以一般会使用单独的图标集如 @iconify-json/heroicons，或是通过 @iconify/collections 获取图标集列表然后按需载入对应图标集内容。",{"type":182,"tag":190,"props":439,"children":440},{},[441],{"type":188,"value":442},"独立的图标集会包含 IconifyJSON 类型的图标文件、以及 IconifyInfo、IconifyMetaData、IconifyChars 等格式的信息文件。",{"type":182,"tag":444,"props":445,"children":446},"ul",{},[447,463,474,485],{"type":182,"tag":423,"props":448,"children":449},{},[450,452,461],{"type":188,"value":451},"IconifyChars 是给部分带文本映射的图标集使用的，比如 Twemoji 图标集是对 emoji 的某种重新设计，所以其图标需要一一对应到 emoji 字符，见 ",{"type":182,"tag":453,"props":454,"children":458},"a",{"href":455,"rel":456},"https://www.npmjs.com/package/@iconify-json/twemoji?activeTab=code",[457],"nofollow",[459],{"type":188,"value":460},"Twemoji Chars",{"type":188,"value":462},"。",{"type":182,"tag":423,"props":464,"children":465},{},[466,468],{"type":188,"value":467},"IconifyMetaData 包含了图标分类、主题等信息，例如 ",{"type":182,"tag":453,"props":469,"children":471},{"href":455,"rel":470},[457],[472],{"type":188,"value":473},"Twemoji Metadata",{"type":182,"tag":423,"props":475,"children":476},{},[477,479],{"type":188,"value":478},"IconifyInfo 包含了图标集的元信息，如名称、版本、作者、协议等，例如 ",{"type":182,"tag":453,"props":480,"children":482},{"href":455,"rel":481},[457],[483],{"type":188,"value":484},"Twemoji Info",{"type":182,"tag":423,"props":486,"children":487},{},[488,490,496],{"type":188,"value":489},"IconifyJSON 是图标文件的具体聚合，见 ",{"type":182,"tag":453,"props":491,"children":493},{"href":455,"rel":492},[457],[494],{"type":188,"value":495},"Twemoji JSON",{"type":188,"value":462},{"type":182,"tag":183,"props":498,"children":500},{"id":499},"具体使用",[501],{"type":188,"value":499},{"type":182,"tag":190,"props":503,"children":504},{},[505],{"type":188,"value":506},"尽管 Iconify 做到了开箱即用，但是部分老旧项目仍然需要维持使用大量老旧图标的现状。所以 Iconify 也提供了自定义图标集工具 Iconify Tools，辅助用户将老旧图标转换为 IconifyJSON 格式的图标集，以便使用上统一的开发规范。",{"type":182,"tag":419,"props":508,"children":509},{},[510,515,520,525],{"type":182,"tag":423,"props":511,"children":512},{},[513],{"type":188,"value":514},"使用 importDirectory 等导入函数导入图标文件",{"type":182,"tag":423,"props":516,"children":517},{},[518],{"type":188,"value":519},"使用 cleanupSVG 函数清理图标文件",{"type":182,"tag":423,"props":521,"children":522},{},[523],{"type":188,"value":524},"使用 parseColors 为图标设置统一的颜色",{"type":182,"tag":423,"props":526,"children":527},{},[528],{"type":188,"value":529},"export 导出图标集为 IconifyJSON 格式文件",{"type":182,"tag":531,"props":532,"children":533},"style",{},[534],{"type":188,"value":535},"html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html .sepia .shiki span {color: var(--shiki-sepia);background: var(--shiki-sepia-bg);font-style: var(--shiki-sepia-font-style);font-weight: var(--shiki-sepia-font-weight);text-decoration: var(--shiki-sepia-text-decoration);}html.sepia .shiki span {color: var(--shiki-sepia);background: var(--shiki-sepia-bg);font-style: var(--shiki-sepia-font-style);font-weight: var(--shiki-sepia-font-weight);text-decoration: var(--shiki-sepia-text-decoration);}",{"title":175,"searchDepth":311,"depth":311,"links":537},[538,539],{"id":185,"depth":311,"text":185},{"id":499,"depth":311,"text":499},"markdown","content:6.maps:_fe-framework:assets:iconify.md","content","6.maps/_fe-framework/assets/iconify.md","6.maps/_fe-framework/assets/iconify","md",[547,550],{"_path":548,"title":549,"description":175},"/maps/_docs/tech-docs/tech-docs","技术文档",{"_path":551,"title":552,"description":553},"/maps/_fe-framework/fe-framework","前端框架","前端框架是在前端开发不同阶段，用以简化开发的工具集合。它们提供了一种组织代码的方式，使得开发者可以专注于业务逻辑，而不是底层的技术细节。",1771214204562]