ops":327,"children":328},{"style":239},[329],{"type":191,"value":330}," fill",{"type":185,"tag":220,"props":332,"children":333},{"style":227},[334],{"type":191,"value":247},{"type":185,"tag":220,"props":336,"children":337},{"style":250},[338],{"type":191,"value":253},{"type":185,"tag":220,"props":340,"children":341},{"style":256},[342],{"type":191,"value":343},"blue",{"type":185,"tag":220,"props":345,"children":346},{"style":250},[347],{"type":191,"value":253},{"type":185,"tag":220,"props":349,"children":350},{"style":239},[351],{"type":191,"value":352}," d",{"type":185,"tag":220,"props":354,"children":355},{"style":227},[356],{"type":191,"value":247},{"type":185,"tag":220,"props":358,"children":359},{"style":250},[360],{"type":191,"value":253},{"type":185,"tag":220,"props":362,"children":363},{"style":256},[364],{"type":191,"value":365},"M5 5h14v14H5z",{"type":185,"tag":220,"props":367,"children":368},{"style":250},[369],{"type":191,"value":253},{"type":185,"tag":220,"props":371,"children":372},{"style":227},[373],{"type":191,"value":374},"/>\n",{"type":185,"tag":220,"props":376,"children":378},{"class":222,"line":377},3,[379,384,388],{"type":185,"tag":220,"props":380,"children":381},{"style":227},[382],{"type":191,"value":383},"\u003C/",{"type":185,"tag":220,"props":385,"children":386},{"style":233},[387],{"type":191,"value":236},{"type":185,"tag":220,"props":389,"children":390},{"style":227},[391],{"type":191,"value":311},{"type":185,"tag":193,"props":393,"children":394},{},[395],{"type":191,"value":396},"此外还提供了统一的设计规范，使用 Material Design Icons 的网格为图标填充做指导。",{"type":185,"tag":193,"props":398,"children":399},{},[400],{"type":185,"tag":401,"props":402,"children":405},"img",{"alt":403,"src":404},"Material Design Icons","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202504010251952.png",[],{"type":185,"tag":193,"props":407,"children":408},{},[409],{"type":191,"value":410},"Iconify 的图标集就是一组带有相同设计规范和元信息的图标集合。",{"type":185,"tag":193,"props":412,"children":413},{},[414],{"type":191,"value":415},"除了开发者使用上的方便，Iconify 在数量上也有优势，其包含了超过 20w 的开源图标。",{"type":185,"tag":193,"props":417,"children":418},{},[419],{"type":191,"value":420},"那么具体如何使用呢？Iconify 提供了两种使用方式：",{"type":185,"tag":422,"props":423,"children":424},"ol",{},[425,431],{"type":185,"tag":426,"props":427,"children":428},"li",{},[429],{"type":191,"value":430},"下载 IconifyJSON 格式的图标集合库，如 @iconify/json，然后在代码中通过 API 找到并使用对应 SVG 文件",{"type":185,"tag":426,"props":432,"children":433},{},[434],{"type":191,"value":435},"使用 Iconify API，一般来说是向第三方发送图标名称，然后使用服务返回的图标文件",{"type":185,"tag":193,"props":437,"children":438},{},[439],{"type":191,"value":440},"由于 @iconify/json 包含所有图标集，其包体积很大，所以一般会使用单独的图标集如 @iconify-json/heroicons，或是通过 @iconify/collections 获取图标集列表然后按需载入对应图标集内容。",{"type":185,"tag":193,"props":442,"children":443},{},[444],{"type":191,"value":445},"独立的图标集会包含 IconifyJSON 类型的图标文件、以及 IconifyInfo、IconifyMetaData、IconifyChars 等格式的信息文件。",{"type":185,"tag":447,"props":448,"children":449},"ul",{},[450,466,477,488],{"type":185,"tag":426,"props":451,"children":452},{},[453,455,464],{"type":191,"value":454},"IconifyChars 是给部分带文本映射的图标集使用的，比如 Twemoji 图标集是对 emoji 的某种重新设计，所以其图标需要一一对应到 emoji 字符，见 ",{"type":185,"tag":456,"props":457,"children":461},"a",{"href":458,"rel":459},"https://www.npmjs.com/package/@iconify-json/twemoji?activeTab=code",[460],"nofollow",[462],{"type":191,"value":463},"Twemoji Chars",{"type":191,"value":465},"。",{"type":185,"tag":426,"props":467,"children":468},{},[469,471],{"type":191,"value":470},"IconifyMetaData 包含了图标分类、主题等信息，例如 ",{"type":185,"tag":456,"props":472,"children":474},{"href":458,"rel":473},[460],[475],{"type":191,"value":476},"Twemoji Metadata",{"type":185,"tag":426,"props":478,"children":479},{},[480,482],{"type":191,"value":481},"IconifyInfo 包含了图标集的元信息，如名称、版本、作者、协议等，例如 ",{"type":185,"tag":456,"props":483,"children":485},{"href":458,"rel":484},[460],[486],{"type":191,"value":487},"Twemoji Info",{"type":185,"tag":426,"props":489,"children":490},{},[491,493,499],{"type":191,"value":492},"IconifyJSON 是图标文件的具体聚合，见 ",{"type":185,"tag":456,"props":494,"children":496},{"href":458,"rel":495},[460],[497],{"type":191,"value":498},"Twemoji JSON",{"type":191,"value":465},{"type":185,"tag":186,"props":501,"children":503},{"id":502},"具体使用",[504],{"type":191,"value":502},{"type":185,"tag":193,"props":506,"children":507},{},[508],{"type":191,"value":509},"尽管 Iconify 做到了开箱即用，但是部分老旧项目仍然需要维持使用大量老旧图标的现状。所以 Iconify 也提供了自定义图标集工具 Iconify Tools，辅助用户将老旧图标转换为 IconifyJSON 格式的图标集，以便使用上统一的开发规范。",{"type":185,"tag":422,"props":511,"children":512},{},[513,518,523,528],{"type":185,"tag":426,"props":514,"children":515},{},[516],{"type":191,"value":517},"使用 importDirectory 等导入函数导入图标文件",{"type":185,"tag":426,"props":519,"children":520},{},[521],{"type":191,"value":522},"使用 cleanupSVG 函数清理图标文件",{"type":185,"tag":426,"props":524,"children":525},{},[526],{"type":191,"value":527},"使用 parseColors 为图标设置统一的颜色",{"type":185,"tag":426,"props":529,"children":530},{},[531],{"type":191,"value":532},"export 导出图标集为 IconifyJSON 格式文件",{"type":185,"tag":534,"props":535,"children":536},"style",{},[537],{"type":191,"value":538},"html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html .sepia .shiki span {color: var(--shiki-sepia);background: var(--shiki-sepia-bg);font-style: var(--shiki-sepia-font-style);font-weight: var(--shiki-sepia-font-weight);text-decoration: var(--shiki-sepia-text-decoration);}html.sepia .shiki span {color: var(--shiki-sepia);background: var(--shiki-sepia-bg);font-style: var(--shiki-sepia-font-style);font-weight: var(--shiki-sepia-font-weight);text-decoration: var(--shiki-sepia-text-decoration);}",{"title":178,"searchDepth":314,"depth":314,"links":540},[541,542],{"id":188,"depth":314,"text":188},{"id":502,"depth":314,"text":502},"markdown","content:6.maps:_fe-framework:assets:iconify.md","content","6.maps/_fe-framework/assets/iconify.md","6.maps/_fe-framework/assets/iconify","md",[550,553],{"_path":551,"title":552,"description":178},"/maps/_docs/tech-docs/tech-docs","技术文档",{"_path":554,"title":555,"description":556},"/maps/_fe-framework/fe-framework","前端框架","前端框架是在前端开发不同阶段，用以简化开发的工具集合。它们提供了一种组织代码的方式，使得开发者可以专注于业务逻辑，而不是底层的技术细节。",1771304529159]