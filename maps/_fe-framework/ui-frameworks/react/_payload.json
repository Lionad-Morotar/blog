},[694],{"type":186,"tag":218,"props":695,"children":696},{"style":264},[697],{"type":192,"value":366},{"type":186,"tag":218,"props":699,"children":700},{"class":220,"line":427},[701,706],{"type":186,"tag":218,"props":702,"children":703},{"style":290},[704],{"type":192,"value":705},"  return",{"type":186,"tag":218,"props":707,"children":709},{"style":708},"--shiki-light:#39ADB5;--shiki-default:#005CC5;--shiki-dark:#79B8FF;--shiki-sepia:#AE81FF",[710],{"type":192,"value":711}," null\n",{"type":186,"tag":218,"props":713,"children":714},{"class":220,"line":435},[715],{"type":186,"tag":218,"props":716,"children":717},{"style":264},[718],{"type":192,"value":441},{"type":186,"tag":194,"props":720,"children":722},{"id":721},"为什么在-componentdidmount-而不是其它生命周期中取请求数据",[723],{"type":192,"value":724},"为什么在 componentDidMount 而不是其它生命周期中取请求数据？",{"type":186,"tag":201,"props":726,"children":727},{},[728],{"type":192,"value":729},"其它生命周期可能执行多次，比如说 componentWillMount 会在服务端和客户端各执行一次。",{"type":186,"tag":194,"props":731,"children":733},{"id":732},"类组件和函数组件有什么不同",[734],{"type":192,"value":735},"类组件和函数组件有什么不同？",{"type":186,"tag":201,"props":737,"children":738},{},[739],{"type":192,"value":740},"类组件是面向对象的，函数组件是函数式的，了解前者主要需要知道继承、生命周期概念，后者则是 state、无副作用和引用透明。类组件依靠 shouldComponentUpdate 来优化性能，函数组件使用 React.memo。",{"type":186,"tag":194,"props":742,"children":744},{"id":743},"setstate-是同步的还是异步的",[745],{"type":192,"value":746},"setState 是同步的还是异步的？",{"type":186,"tag":201,"props":748,"children":749},{},[750],{"type":192,"value":751},"在大部分情况下 setState 是异步的。多次 setState 的状态会被合并，直到当前宏任务跑完才会触发重新渲染。这和 Taro 的思路是一致的。",{"type":186,"tag":194,"props":753,"children":755},{"id":754},"react-和-vue-有什么异同",[756],{"type":192,"value":757},"React 和 Vue 有什么异同？",{"type":186,"tag":201,"props":759,"children":760},{},[761],{"type":192,"value":762},"相同的地方在于他们都是渐进式的框架，都有自己的脚手架和最佳实践的模板；在框架层面，数据流都是自顶向下的，都引入了 VDom 的概念。",{"type":186,"tag":201,"props":764,"children":765},{},[766],{"type":192,"value":767},"不同的地方在于 Vue 的数据和视图是双向绑定的，React 推崇不可变数据，并且需要手动优化，所以 Vue 模板有利于静态优化。",{"type":186,"tag":194,"props":769,"children":771},{"id":770},"react-的演进历程是什么",[772],{"type":192,"value":773},"React 的演进历程是什么？",{"type":186,"tag":201,"props":775,"children":776},{},[777],{"type":192,"value":778},"React 经历了多次架构变革。早期使用 mixins 实现代码复用，ES6 类组件出现后转为 class-based，\n直到 React 16.8 引入 Hooks 才真正改变了开发范式。Hooks 将必要样板代码减少了一个数量级，\n并催生了自定义 Hook 的爆发式发展。第三方库也经历了类似轨迹：Redux 等方案兴起后被抛弃，\n因为开发者意识到样板代码的成本得不偿失。",{"type":186,"tag":201,"props":780,"children":781},{},[782,788],{"type":186,"tag":783,"props":784,"children":785},"strong",{},[786],{"type":192,"value":787},"2026 年回看",{"type":192,"value":789},"：React 18/19 的 Concurrent Mode 与 Server Components 延续了\"减少样板代码\"的承诺，\n却意外引发了社区对\"复杂性爆炸\"的广泛批评。2025 年 Redux 作者 Mark Erikson 承认 React 生态\n\"支离破碎\"，RSC 的落地困难与 Vercel 影响力争议印证了 2022 年对 React 方向的担忧。\n不过 React 仍占约 48.7% 市场份额，其成熟度在企业级场景难以被撼动。",{"type":186,"tag":201,"props":791,"children":792},{},[793,794],{"type":192,"value":471},{"type":186,"tag":473,"props":795,"children":798},{"href":796,"rel":797},"https://acko.net/blog/get-in-zoomer-we-re-saving-react/",[477],[799],{"type":192,"value":800},"Get in Zoomer, We're Saving React",{"type":186,"tag":187,"props":802,"children":804},{"id":803},"hooks",[805],{"type":192,"value":806},"Hooks",{"type":186,"tag":808,"props":809,"children":810},"ul",{},[811,822,832],{"type":186,"tag":812,"props":813,"children":814},"li",{},[815],{"type":186,"tag":473,"props":816,"children":819},{"href":817,"rel":818},"https://usehooks.com/",[477],[820],{"type":192,"value":821},"useHooks(🐠)",{"type":186,"tag":812,"props":823,"children":824},{},[825],{"type":186,"tag":473,"props":826,"children":829},{"href":827,"rel":828},"https://juejin.cn/post/6844903991730503687",[477],[830],{"type":192,"value":831},"精读《Hooks 取数 - swr 源码》",{"type":186,"tag":812,"props":833,"children":834},{},[835],{"type":186,"tag":473,"props":836,"children":839},{"href":837,"rel":838},"https://my.oschina.net/wsafight/blog/3133057",[477],[840],{"type":192,"