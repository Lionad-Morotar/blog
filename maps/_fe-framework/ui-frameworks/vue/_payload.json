","ui-frameworks",false,true,"","Vue","Vue 是一套用于构建用户界面的渐进式框架，它的核心库只关注视图层，易于上手，同时也便于与第三方库或既有项目整合。","content/6.maps/_fe-framework/ui/vue.md",{"type":183,"children":184,"toc":1173},"root",[185,194,221,226,233,251,257,263,268,273,279,284,290,313,319,337,343,348,353,358,370,375,386,392,397,403,417,426,704,712,745,764,769,775,786,791,797,806,812,818,823,829,840,851,862,873,878,884,889,895,900,906,911,917,923,928,934,938,948,954,965,970,975,980,985,998,1011,1016,1029,1034,1047,1052,1099,1144,1149,1155,1167],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"todo",[191],{"type":192,"value":193},"text","TODO",{"type":186,"tag":195,"props":196,"children":197},"ul",{},[198,211],{"type":186,"tag":199,"props":200,"children":201},"li",{},[202],{"type":186,"tag":203,"props":204,"children":208},"a",{"href":205,"rel":206},"https://www.zhihu.com/question/390956688/answer/1184696066",[207],"nofollow",[209],{"type":192,"value":210},"Vue.js 技术揭秘",{"type":186,"tag":199,"props":212,"children":213},{},[214],{"type":186,"tag":203,"props":215,"children":218},{"href":216,"rel":217},"https://github.com/HcySunYang/vue-design/blob/elegant/docs/art/1start-learn",[207],[219],{"type":192,"value":220},"vue-design",{"type":186,"tag":187,"props":222,"children":224},{"id":223},"简介",[225],{"type":192,"value":223},{"type":186,"tag":227,"props":228,"children":230},"h4",{"id":229},"前端框架发展历史关键点",[231],{"type":192,"value":232},"前端框架发展历史关键点？",{"type":186,"tag":195,"props":234,"children":235},{},[236,241,246],{"type":186,"tag":199,"props":237,"children":238},{},[239],{"type":192,"value":240},"2004 年，Google Gmail 使用的 Ajax 技术使前端脱离模板的束缚。",{"type":186,"tag":199,"props":242,"children":243},{},[244],{"type":192,"value":245},"jQuery 解决了不同浏览器的兼容性问题。",{"type":186,"tag":199,"props":247,"children":248},{},[249],{"type":192,"value":250},"2009 年，AngularJS 引领了 MVVM 的潮流，NodeJS 加速了前端工程化的诞生。",{"type":186,"tag":227,"props":252,"children":254},{"id":253},"vue-和-react-的计算性能瓶颈是什么",[255],{"type":192,"value":256},"Vue 和 React 的计算性能瓶颈是什么？",{"type":186,"tag":258,"props":259,"children":260},"p",{},[261],{"type":192,"value":262},"Vue1 的每一个响应式数据都有一个 Watcher，极大的消耗内存，React 的问题发生在当页面 JS 执行 Diff 算法超过帧时间时带来的卡顿问题。",{"type":186,"tag":258,"props":264,"children":265},{},[266],{"type":192,"value":267},"Vue2 引入虚拟 DOM，采用组件级别的响应式数据颗粒度，在避免了 Diff 算法超时问题的同时，降低内存消耗。同时，虚拟 DOM 还带来跨端能力。",{"type":186,"tag":258,"props":269,"children":270},{},[271],{"type":192,"value":272},"React 引入 Fiber 架构，将 DOM Tree 变成链表，使得有能力随时启动或停止 Diff 算法（树的遍历使用递归所以相比链表更难记录状态），可以利用浏览器的空闲时间计算 Diff，避免了卡顿。",{"type":186,"tag":227,"props":274,"children":276},{"id":275},"mvvmmvc-的区别",[277],{"type":192,"value":278},"MVVM、MVC 的区别？",{"type":186,"tag":258,"props":280,"children":281},{},[282],{"type":192,"value":283},"都是软件架构模式，主要区别是关注点不一样，Controller 用来承接交互操作并触发 Model 的修改，而 ViewModel 和 Model 层是双向绑定的，所以写 VueJS 时的思想不在如何操作 DOM 元素，而主要是数据应该怎么变化。",{"type":186,"tag":227,"props":285,"children":287},{"id":286},"vue2-较明显的设计缺陷",[288],{"type":192,"value":289},"Vue2 较明显的设计缺陷？",{"type":186,"tag":195,"props":291,"children":292},{},[293,298,303,308],{"type":186,"tag":199,"props":294,"children":295},{},[296],{"type":192,"value":297},"使用 Flow.js 来做类型校验，而不是社区所向的 TypeScript",{"type":186,"tag":199,"props":299,"children":300},{},[301],{"type":192,"value":302},"Vue2 内嵌了诸如 DOM API 之类的代码，使得跨端等二次开发变得困难，代码耦合也使得摇树优化变得困难",{"type":186,"tag":199,"props":304,"children":305},{},[306],{"type":192,"value":307},"Vue2 使用的 defineProperty 有缺陷，不支持 delete 等操作符",{"type":186,"tag":199,"props":309,"children":310},{},[311],{"type":192,"value":312},"Option API 在组件代码较多时不易维护",{"type":186,"tag":227,"props":314,"children":316},{"id":315},"option-api-的一些缺陷",[317],{"type":192,"value":318},"Option API 的一些缺陷？",{"type":186,"tag":195,"props":320,"children":321},{},[322,327,332],{"type":186,"tag":199,"props":323,"children":324},{},[325],{"type":192,"value":326},"数据挂载在 this 对象上，对类型系统以及摇树优化不友好",{"type":186,"tag":199,"props":328,"children":329},{},[330],{"type":192,"value":331},"代码增多时，维护变得困难",{"type":186,"tag":199,"props":333,"children":334},{},[335],{"type":192,"value":336},"不方便抽离通用逻辑",{"type":186,"tag":227,"props":338,"children":340},{"id":339},"为什么要重写-vue2",[341],{"type":192,"value":342},"为什么要重写 Vue2？",{"type":186,"tag":258,"props":344,"children":345},{},[346],{"type":192,"value":347},"有两个关键因素：主流浏览器逐渐兼容 Proxy，以及修复 Vue2 的设计缺陷。",{"type":186,"tag":258,"props":349,"children":350},{},[351],{"type":192,"value":352},"切换到 Proxy 可以修复过去 setter、getter 无法拦截数组修改以及修改了对象本身带来的语义变化的问题，但由于它是一个原生特性，无法 polyfill，所以对 Vue 而言是一个重大的突破性变动。",{"type":186,"tag":258,"props":354,"children":355},{},[356],{"type":192,"value":357},"过去的架构带来了模板很难正确的在 source-map 中追溯、渲染器（如 DOM 渲染器）不是渐进式的可选项的问题，再加上框架内部代码的耦合，使得摇树优化变得困难，代码也不便理解。",{"type":186,"tag":258,"props":359,"children":360},{},[361,363],{"type":192,"value":362},"见：",{"type":186,"tag":203,"props":364,"children":367},{"href":365,"rel":366},"https://zhuanlan.zhihu.com/p/147022323",[207],[368],{"type":192,"value":369},"重头来过的 Vue 3 带来了什么？",{"type":186,"tag":187,"props":371,"children":373},{"id":372},"响应式",[374],{"type":192,"value":372},{"type":186,"tag":258,"props":376,"children":377},{},[378,380],{"type":192,"value":379},"更多详细 API 见：",{"type":186,"tag":203,"props":381,"children":383},{"href":382},"./vue-reactive",[384],{"type":192,"value":385},"Vue Reactivity API",{"type":186,"tag":227,"props":387,"children":389},{"id":388},"ref-的原理",[390],{"type":192,"value":391},"ref 的原理？",{"type":186,"tag":258,"props":393,"children":394},{},[395],{"type":192,"value":396},"ref 是在基础值的外面封装了一层对象，使用对象的 value setting、value getter 函数拦截并操作 value 属性，达到响应式的效果。",{"type":186,"tag":227,"props":398,"children":400},{"id":399},"vue-3-的自动脱-ref-机制",[401],{"type":192,"value":402},"Vue 3 的自动脱 ref 机制？",{"type":186,"tag":258,"props":404,"children":405},{},[406,408,415],{"type":192,"value":407},"自动脱 ref（Auto Unwrapping）是 Vue 3 响应式系统的特性，在特定场景下 ref 会被自动解包，无需手动写 ",{"type":186,"tag":409,"props":410,"children":412},"code",{"className":411},[],[413],{"type":192,"value":414},".value"