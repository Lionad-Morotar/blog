"style":231},[249],{"type":190,"value":234},{"type":185,"tag":218,"props":251,"children":252},{"style":237},[253],{"type":190,"value":254},"/Users/username/Library/Application Support/Trae/User/globalStorage/fredjeck.fav/favorites.json",{"type":185,"tag":218,"props":256,"children":257},{"style":231},[258],{"type":190,"value":259},"\"\n",{"type":185,"tag":186,"props":261,"children":262},{"id":179},[263],{"type":190,"value":264},"VSCode",{"type":185,"tag":266,"props":267,"children":269},"h4",{"id":268},"如何使大纲视图默认只显示一级",[270],{"type":190,"value":271},"如何使大纲视图默认只显示一级？",{"type":185,"tag":193,"props":273,"children":274},{},[275],{"type":190,"value":276},"在稍微大点的文件里，由于大纲视图总是展开得非常深，所以几乎不可读。如果可以设置大纲默认的折叠层数就好了！",{"type":185,"tag":193,"props":278,"children":279},{},[280,282,288],{"type":190,"value":281},"很可惜没有这种设置，不过可以更改 ",{"type":185,"tag":199,"props":283,"children":285},{"className":284},[],[286],{"type":190,"value":287},"outline.collapseItems",{"type":190,"value":289}," 为默认折叠状态。设置完之后，大纲会默认展示第一层变量声明的内容，这样 Vue SFC Setup 里的变量、函数、生命周期之类的东西全都会展示出来。",{"type":185,"tag":193,"props":291,"children":292},{},[293,295],{"type":190,"value":294},"见：",{"type":185,"tag":296,"props":297,"children":301},"a",{"href":298,"rel":299},"https://github.com/microsoft/vscode/issues/53262",[300],"nofollow",[302],{"type":185,"tag":303,"props":304,"children":305},"i",{},[306],{"type":190,"value":307},"Outline view: collapsed by default (introduce optional setting?)",{"type":185,"tag":266,"props":309,"children":311},{"id":310},"不能聚焦到文件树视图了",[312],{"type":190,"value":313},"不能聚焦到文件树视图了？",{"type":185,"tag":193,"props":315,"children":316},{},[317,319,325],{"type":190,"value":318},"因为电脑是 OLED 屏，长时间在固定位置显示图标容易烧屏，所以今天小改了一下 VSCode 的界面结构。把文件视图挪到右边侧边栏里面后发现使用 ",{"type":185,"tag":199,"props":320,"children":322},{"className":321},[],[323],{"type":190,"value":324},"Ctrl + Shift + E",{"type":190,"value":326}," 按键不能聚焦到文件树视图了。",{"type":185,"tag":193,"props":328,"children":329},{},[330,332,338],{"type":190,"value":331},"检查发