":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"deep-mode",[187],{"type":188,"value":189},"text","Deep Mode",{"type":182,"tag":191,"props":192,"children":194},"h4",{"id":193},"smart-的协作-vs-deep-的独处",[195],{"type":188,"value":196},"Smart 的协作 vs Deep 的独处",{"type":182,"tag":198,"props":199,"children":200},"p",{},[201],{"type":188,"value":202},"Smart 模式像一位热情的结对编程伙伴——急切、互动、随时愿意动手改代码。Deep 则是那种埋头苦干的工程师——沉默地读文件、在代码库里游走，可以独处五到十五分钟不被打扰。它不是在等待指令，而是在消化问题。这种性格差异决定了你什么时候该召唤谁。",{"type":182,"tag":198,"props":204,"children":205},{},[206,208,217,219],{"type":188,"value":207},"见：",{"type":182,"tag":209,"props":210,"children":214},"a",{"href":211,"rel":212},"https://addyo.substack.com/p/the-70-problem-hard-truths-about",[213],"nofollow",[215],{"type":188,"value":216},"The 70% problem: Hard truths about AI-assisted coding",{"type":188,"value":218},", ",{"type":182,"tag":209,"props":220,"children":223},{"href":221,"rel":222},"https://zhuanlan.zhihu.com/p/2004110489978953940",[213],[224],{"type":188,"value":225},"人机结对编程已死？",{"title":175,"searchDepth":227,"depth":227,"links":228},2,[229],{"id":185,"depth":227,"text":189},"markdown","content:6.maps:_ide:amp.md","content","6.maps/_ide/amp.md","6.maps/_ide/amp","md",[237,240],{"_path":238,"title":239,"description":175},"/maps/_hire/interview/records/ttx","面试相关",{"_path":241,"title":242,"description":243},"/maps/_ide/ide","集成开发环境（IDE）","集成开发环境（IDE）是一种软件应用程序，用于提供开发人员在一个环境中编写、测试和调试代码的功能。它通常包括代码编辑器、调试器、构建工具和其他辅助功能。",1771214232052]