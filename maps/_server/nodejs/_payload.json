,207,212,218,223,229,278,292,298,312,318,323,329,334,340,345,351,369,375,381,386,397,402,411,416],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"简介",[187],{"type":188,"value":185},"text",{"type":182,"tag":190,"props":191,"children":193},"h4",{"id":192},"nodejs-是什么",[194],{"type":188,"value":195},"NodeJS 是什么？",{"type":182,"tag":197,"props":198,"children":199},"p",{},[200],{"type":188,"value":177},{"type":182,"tag":190,"props":202,"children":204},{"id":203},"非阻塞-io-是什么",[205],{"type":188,"value":206},"非阻塞 IO 是什么？",{"type":182,"tag":197,"props":208,"children":209},{},[210],{"type":188,"value":211},"非阻塞 IO 意味着在执行 IO 操作时，将耗时任务以异步的方式交给子线程处理，等完成之后再通过回调的方式继续执行后续代码。",{"type":182,"tag":190,"props":213,"children":215},{"id":214},"事件循环机制和浏览器中有什么不同",[216],{"type":188,"value":217},"事件循环机制和浏览器中有什么不同？",{"type":182,"tag":197,"props":219,"children":220},{},[221],{"type":188,"value":222},"TODO，类似但稍有区别。",{"type":182,"tag":190,"props":224,"children":226},{"id":225},"_2025-年现代-nodejs-模式",[227],{"type":188,"value":228},"《2025 年现代 Node.js 模式》",{"type":182,"tag":230,"props":231,"children":232},"ol",{},[233,248,253,258,263,268,273],{"type":182,"tag":234,"props":235,"children":236},"li",{},[237,239,246],{"type":188,"value":238},"Embrace Web Standards: Use ",{"type":182,"tag":240,"props":241,"children":243},"code",{"className":242},[],[244],{"type":188,"value":245},"node:",{"type":188,"value":247}," prefixes, fetch API, AbortController, and Web Streams for better compatibility and reduced dependencies",{"type":182,"tag":234,"props":249,"children":250},{},[251],{"type":188,"value":252},"Built-in Tools: The test runner, watch mode, and environment file support reduce external dependencies and configuration complexity",{"type":182,"tag":234,"props":254,"children":255},{},[256],{"type":188,"value":257},"Modern Async Patterns: Top-level await, structured error handling, and async iterators make code more readable and maintainable",{"type":182,"tag":234,"props":259,"children":260},{},[261],{"type":188,"value":262},"Worker Threads for CPU-intensive tasks: worker threads provide true parallelism without blocking the main thread",{"type":182,"tag":234,"props":264,"children":265},{},[266],{"type":188,"value":267},"Robust Application: Use permission models, diagnostics channels, and performance monitoring to build robust, observable applications",{"type":182,"tag":234,"props":269,"children":270},{},[271],{"type":188,"value":272},"Developer Experience: Watch mode, built-in testing, and import maps create a more pleasant development workflow",{"type":182,"tag":234,"props":274,"children":275},{},[276],{"type":188,"value":277},"Distribution: Single executable applications and modern packaging make deployment simpler",{"type":182,"tag":197,"props":279,"children":280},{},[281,283],{"type":188,"value":282},"见：",{"type":182,"tag":284,"props":285,"children":289},"a",{"href":286,"rel":287},"https://kashw1n.com/blog/nodejs-2025/",[288],"nofollow",[290],{"type":188,"value":291},"Modern Node.js Patterns for 2025",{"type":182,"tag":183,"props":293,"children":295},{"id":294},"v8",[296],{"type":188,"value":297},"V8",{"type":182,"tag":299,"props":300,"children":301},"ul",{},[302],{"type":182,"tag":234,"props":303,"children":304},{},[305],{"type":182,"tag":284,"props":306,"children":309},{"href":307,"rel":308},"https://v8.dev/docs",[288],[310],{"type":188,"value":311},"V8 Docs",{"type":182,"tag":190,"props":313,"children":315},{"id":314},"引擎的垃圾回收机制有了解吗",[316],{"type":188,"value":317},"引擎的垃圾回收机制有了解吗？",{"type":182,"tag":197,"props":319,"children":320},{},[321],{"type":188,"value":322},"V8 使用分代回收机制，将内存分为新生代和老生代空间，分别用不同的算法进行 GC。新生代空间每个周期都会触发 ScavengeGC，俗称小周期。如果两个周期内都没被清除的变量则转移到老生代内存中。老生代空间则使用标记清除算法（和标记紧缩算法）进行清理。",{"type":182,"tag":190,"props":324,"children":326},{"id":325},"新生代空间的-gc-过程是怎样的",[327],{"type":188,"value":328},"新生代空间的 GC 过程是怎样的？",{"type":182,"tag":197,"props":330,"children":331},{},[332],{"type":188,"value":333},"新生代空间通常只有 1-8 MB，被划分为两个等大的区域，出区和入区。新增变量放到入区中。一但入区满了，便把活跃对象复制到出区中，删除不活跃对象（紧缩过程）并交换出区入区，如此称为一个周期。如果活跃对象再两个周期内都没有被清除，则转移只老生代内存中。",{"type":182,"tag":190,"props":335,"children":337},{"id":336},"老生代空间的-gc-过程是怎样的",[338],{"type":188,"value":339},"老生代空间的 GC 过程是怎样的？",{"type":182,"tag":197,"props":341,"children":342},{},[343],{"type":188,"value":344},"老生代空间的 GC 分标记和清除（或紧缩）两个阶段。每次循环，标记算法会将一个对象从队列中取出，将它以及邻接对象标记。到了清除阶段，未被标记的对象都将被删除。如果清楚阶段额外执行紧缩过程，则会尝试将零散的对象移动成连续的整体，以解决内存碎片化问题。为了优化老生代空间 GC 的“全停顿”，V8 将老生代空间的标记过程拆分为了子步骤，这样就可以将标记算法穿插在其它任务过程中执行。",{"type":182,"tag":190,"props":346,"children":348},{"id":347},"常见的商业开源研究用的-js-引擎有哪些",[349],{"type":188,"value":350},"常见的商业、开源、研究用的 JS 引擎有哪些？",{"type":182,"tag":197,"props":352,"children":353},{},[354,356,367],{"type":188,"value":355},"见",{"type":182,"tag":357,"props":358,"children":359},"i",{},[360],{"type":182,"tag":284,"props":361,"children":364},{"href":362,"rel":363},"https://notes.eatonphil.com/javascript-implementations.html",[288],[365],{"type":188,"value":366},"Enumerating and analyzing 40+ non-V8 JavaScript implementations",{"type":188,"value":368},"，列举了 40 多个非 V8 的 JS 引擎实现。",{"type":182,"tag":183,"props":370,"children":372},{"id":371},"api",[373],{"type":188,"value":374},"API",{"type":182,"tag":190,"props":376,"children":378},{"id":377},"nodevm-是什么",[379],{"type":188,"value":380},"node:vm 是什么？",{"type":182,"tag":197,"props":382,"children":383},{},[384],{"type":188,"value":385},"node:vm 模块允许在 V8 虚拟机上下文中编译和运行代码，上下文中的任何属性都被视为全局变量，对全局变量任何改动也反映到上下文对象中。但是 node:vm 不是一个安全机制，不应该使用它来运行不受信任的代码。",{"type":182,"tag":197,"props":387,"children":388},{},[389,390],{"type":188,"value":282},{"type":182,"tag":284,"props":391,"children":394},{"href":392,"rel":393},"http://nodejs.cn/api/vm.html#vm_vm_executing_javascript",[288],[395],{"type":188,"value":396},"VM",{"type":182,"tag":183,"props":398,"children":400},{"id":399},"源码解析",[401],{"type":188,"value":399},{"type":182,"tag":197,"props":403,"children":404},{},[405],{"type":182,"tag":284,"props":406,"children":408},{"href":407},"/maps/_server/nodejs/source/require",[409],{"type":188,"value":410},"NodeJS | require",{"type":182,"tag":183,"props":412,"children":414},{"id":413},"调试",[415],{"type":188,"value":413},{"type":182,"tag":299,"props":417,"children":418},{},[419],{"type":182,"tag":234,"props":420,"children":421},{},[422],{"type":182,"tag":284,"props":423,"children":426},{"href":424,"rel":425},"https://juejin.cn/post/6844903904728236045",[288],[427],{"type":188,"value":428},"使用火焰图优化 NodeJS CPU 爆涨",{"title":175,"searchDepth":430,"depth":430,"links":431},2,[432,433,434,435,436],{"id":185,"depth":430,"text":185},{"id":294,"depth":430,"text":297},{"id":371,"depth":430,"text":374},{"id":399,"depth":430,"text":399},{"id":413,"depth":430,"text":413},"markdown","content:6.maps:_server:nodejs:index.md","content","6.maps/_server/nodejs/index.md","6.maps/_server/nodejs/index","md",[444,448],{"_path":445,"title":446,"description":447},"/maps/_seo/seo","搜索引擎优化","搜索引擎优化包含了对网站内容的基本元素的一系列改动，这些改动通常相互作用，提高用户体验以及增加网站在自然搜索结果中的排名。",{"_path":407,"title":449,"description":450},"NodeJS Require","NodeJS 模块导入的源码解析",1771264626001]