:182,"children":183,"toc":432},"root",[184,192,199,204,210,215,221,226,232,281,295,301,315,321,326,332,337,343,348,354,372,378,384,389,400,405,414,419],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"简介",[190],{"type":191,"value":188},"text",{"type":185,"tag":193,"props":194,"children":196},"h4",{"id":195},"nodejs-是什么",[197],{"type":191,"value":198},"NodeJS 是什么？",{"type":185,"tag":200,"props":201,"children":202},"p",{},[203],{"type":191,"value":180},{"type":185,"tag":193,"props":205,"children":207},{"id":206},"非阻塞-io-是什么",[208],{"type":191,"value":209},"非阻塞 IO 是什么？",{"type":185,"tag":200,"props":211,"children":212},{},[213],{"type":191,"value":214},"非阻塞 IO 意味着在执行 IO 操作时，将耗时任务以异步的方式交给子线程处理，等完成之后再通过回调的方式继续执行后续代码。",{"type":185,"tag":193,"props":216,"children":218},{"id":217},"事件循环机制和浏览器中有什么不同",[219],{"type":191,"value":220},"事件循环机制和浏览器中有什么不同？",{"type":185,"tag":200,"props":222,"children":223},{},[224],{"type":191,"value":225},"TODO，类似但稍有区别。",{"type":185,"tag":193,"props":227,"children":229},{"id":228},"_2025-年现代-nodejs-模式",[230],{"type":191,"value":231},"《2025 年现代 Node.js 模式》",{"type":185,"tag":233,"props":234,"children":235},"ol",{},[236,251,256,261,266,271,276],{"type":185,"tag":237,"props":238,"children":239},"li",{},[240,242,249],{"type":191,"value":241},"Embrace Web Standards: Use ",{"type":185,"tag":243,"props":244,"children":246},"code",{"className":245},[],[247],{"type":191,"value":248},"node:",{"type":191,"value":250}," prefixes, fetch API, AbortController, and Web Streams for better compatibility and reduced dependencies",{"type":185,"tag":237,"props":252,"children":253},{},[254],{"type":191,"value":255},"Built-in Tools: The test runner, watch mode, and environment file support reduce external dependencies and configuration complexity",{"type":185,"tag":237,"props":257,"children":258},{},[259],{"type":191,"value":260},"Modern Async Patterns: Top-level await, structured error handling, and async iterators make code more readable and maintainable",{"type":185,"tag":237,"props":262,"children":263},{},[264],{"type":191,"value":265},"Worker Threads for CPU-intensive tasks: worker threads provide true parallelism without blocking the main thread",{"type":185,"tag":237,"props":267,"children":268},{},[269],{"type":191,"value":270},"Robust Application: Use permission models, diagnostics channels, and performance monitoring to build robust, observable applications",{"type":185,"tag":237,"props":272,"children":273},{},[274],{"type":191,"value":275},"Developer Experience: Watch mode, built-in testing, and import maps create a more pleasant development workflow",{"type":185,"tag":237,"props":277,"children":278},{},[279],{"type":191,"value":280},"Distribution: Single executable applications and modern packaging make deployment simpler",{"type":185,"tag":200,"props":282,"children":283},{},[284,286],{"type":191,"value":285},"见：",{"type":185,"tag":287,"props":288,"children":292},"a",{"href":289,"rel":290},"https://kashw1n.com/blog/nodejs-2025/",[291],"nofollow",[293],{"type":191,"value":294},"Modern Node.js Patterns for 2025",{"type":185,"tag":186,"props":296,"children":298},{"id":297},"v8",[299],{"type":191,"value":300},"V8",{"type":185,"tag":302,"props":303,"children":304},"ul",{},[305],{"type":185,"tag":237,"props":306,"children":307},{},[308],{"type":185,"tag":287,"props":309,"children":312},{"href":310,"rel":311},"https://v8.dev/docs",[291],[313],{"type":191,"value":314},"V8 Docs",{"type":185,"tag":193,"props":316,"children":318},{"id":317},"引擎的垃圾回收机制有了解吗",[319],{"type":191,"value":320},"引擎的垃圾回收机制有了解吗？",{"type":185,"tag":200,"props":322,"children":323},{},[324],{"type":191,"value":325},"V8 使用分代回收机制，将内存分为新生代和老生代空间，分别用不同的算法进行 GC。新生代空间每个周期都会触发 ScavengeGC，俗称小周期。如果两个周期内都没被清除的变量则转移到老生代内存中。老生代空间则使用标记清除算法（和标记紧缩算法）进行清理。",{"type":185,"tag":193,"props":327,"children":329},{"id":328},"新生代空间的-gc-过程是怎样的",[330],{"type":191,"value":331},"新生代空间的 GC 过程是怎样的？",{"type":185,"tag":200,"props":333,"children":334},{},[335],{"type":191,"value":336},"新生代空间通常只有 1-8 MB，被划分为两个等大的区域，出区和入区。新增变量放到入区中。一但入区满了，便把活跃对象复制到出区中，删除不活跃对象（紧缩过程）并交换出区入区，如此称为一个周期。如果活跃对象再两个周期内都没有被清除，则转移只老生代内存中。",{"type":185,"tag":193,"props":338,"children":340},{"id":339},"老生代空间的-gc-过程是怎样的",[341],{"type":191,"value":342},"老生代空间的 GC 过程是怎样的？",{"type":185,"tag":200,"props":344,"children":345},{},[346],{"type":191,"value":347},"老生代空间的 GC 分标记和清除（或紧缩）两个阶段。每次循环，标记算法会将一个对象从队列中取出，将它以及邻接对象标记。到了清除阶段，未被标记的对象都将被删除。如果清楚阶段额外执行紧缩过程，则会尝试将零散的对象移动成连续的整体，以解决内存碎片化问题。为了优化老生代空间 GC 的“全停顿”，V8 将老生代空间的标记过程拆分为了子步骤，这样就可以将标记算法穿插在其它任务过程中执行。",{"type":185,"tag":193,"props":349,"children":351},{"id":350},"常见的商业开源研究用的-js-引擎有哪些",[352],{"type":191,"value":353},"常见的商业、开源、研究用的 JS 引擎有哪些？",{"type":185,"tag":200,"props":355,"children":356},{},[357,359,370],{"type":191,"value":358},"见",{"type":185,"tag":360,"props":361,"children":362},"i",{},[363],{"type":185,"tag":287,"props":364,"children":367},{"href":365,"rel":366},"https://notes.eatonphil.com/javascript-implementations.html",[291],[368],{"type":191,"value":369},"Enumerating and analyzing 40+ non-V8 JavaScript implementations",{"type":191,"value":371},"，列举了 40 多个非 V8 的 JS 引擎实现。",{"type":185,"tag":186,"props":373,"children":375},{"id":374},"api",[376],{"type":191,"value":377},"API",{"type":185,"tag":193,"props":379,"children":381},{"id":380},"nodevm-是什么",[382],{"type":191,"value":383},"node:vm 是什么？",{"type":185,"tag":200,"props":385,"children":386},{},[387],{"type":191,"value":388},"node:vm 模块允许在 V8 虚拟机上下文中编译和运行代码，上下文中的任何属性都被视为全局变量，对全局变量任何改动也反映到上下文对象中。但是 node:vm 不是一个安全机制，不应该使用它来运行不受信任的代码。",{"type":185,"tag":200,"props":390,"children":391},{},[392,393],{"type":191,"value":285},{"type":185,"tag":287,"props":394,"children":397},{"href":395,"rel":396},"http://nodejs.cn/api/vm.html#vm_vm_executing_javascript",[291],[398],{"type":191,"value":399},"VM",{"type":185,"tag":186,"props":401,"children":403},{"id":402},"源码解析",[404],{"type":191,"value":402},{"type":185,"tag":200,"props":406,"children":407},{},[408],{"type":185,"tag":287,"props":409,"children":411},{"href":410},"/maps/_server/nodejs/source/require",[412],{"type":191,"value":413},"NodeJS | require",{"type":185,"tag":186,"props":415,"children":417},{"id":416},"调试",[418],{"type":191,"value":416},{"type":185,"tag":302,"props":420,"children":421},{},[422],{"type":185,"tag":237,"props":423,"children":424},{},[425],{"type":185,"tag":287,"props":426,"children":429},{"href":427,"rel":428},"https://juejin.cn/post/6844903904728236045",[291],[430],{"type":191,"value":431},"使用火焰图优化 NodeJS CPU 爆涨",{"title":178,"searchDepth":433,"depth":433,"links":434},2,[435,436,437,438,439],{"id":188,"depth":433,"text":188},{"id":297,"depth":433,"text":300},{"id":374,"depth":433,"text":377},{"id":402,"depth":433,"text":402},{"id":416,"depth":433,"text":416},"markdown","content:6.maps:_server:nodejs:index.md","content","6.maps/_server/nodejs/index.md","6.maps/_server/nodejs/index","md",[447,451],{"_path":448,"title":449,"description":450},"/maps/_seo/seo","搜索引擎优化","搜索引擎优化包含了对网站内容的基本元素的一系列改动，这些改动通常相互作用，提高用户体验以及增加网站在自然搜索结果中的排名。",{"_path":410,"title":452,"description":453},"NodeJS Require","NodeJS 模块导入的源码解析",1771696695626]