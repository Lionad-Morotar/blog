eJS 是一个非阻塞 IO、事件驱动的服务端 JS 运行环境。","content/6.maps/_server/nodejs/index.md",{"type":183,"children":184,"toc":433},"root",[185,193,200,205,211,216,222,227,233,282,296,302,316,322,327,333,338,344,349,355,373,379,385,390,401,406,415,420],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"简介",[191],{"type":192,"value":189},"text",{"type":186,"tag":194,"props":195,"children":197},"h4",{"id":196},"nodejs-是什么",[198],{"type":192,"value":199},"NodeJS 是什么？",{"type":186,"tag":201,"props":202,"children":203},"p",{},[204],{"type":192,"value":180},{"type":186,"tag":194,"props":206,"children":208},{"id":207},"非阻塞-io-是什么",[209],{"type":192,"value":210},"非阻塞 IO 是什么？",{"type":186,"tag":201,"props":212,"children":213},{},[214],{"type":192,"value":215},"非阻塞 IO 意味着在执行 IO 操作时，将耗时任务以异步的方式交给子线程处理，等完成之后再通过回调的方式继续执行后续代码。",{"type":186,"tag":194,"props":217,"children":219},{"id":218},"事件循环机制和浏览器中有什么不同",[220],{"type":192,"value":221},"事件循环机制和浏览器中有什么不同？",{"type":186,"tag":201,"props":223,"children":224},{},[225],{"type":192,"value":226},"TODO，类似但稍有区别。",{"type":186,"tag":194,"props":228,"children":230},{"id":229},"_2025-年现代-nodejs-模式",[231],{"type":192,"value":232},"《2025 年现代 Node.js 模式》",{"type":186,"tag":234,"props":235,"children":236},"ol",{},[237,252,257,262,267,272,277],{"type":186,"tag":238,"props":239,"children":240},"li",{},[241,243,250],{"type":192,"value":242},"Embrace Web Standards: Use ",{"type":186,"tag":244,"props":245,"children":247},"code",{"className":246},[],[248],{"type":192,"value":249},"node:",{"type":192,"value":251}," prefixes, fetch API, AbortController, and Web Streams for better compatibility and reduced dependencies",{"type":186,"tag":238,"props":253,"children":254},{},[255],{"type":192,"value":256},"Built-in Tools: The test runner, watch mode, and environment file support reduce external dependencies and configuration complexity",{"type":186,"tag":238,"props":258,"children":259},{},[260],{"type":192,"value":261},"Modern Async Patterns: Top-level await, structured error handling, and async iterators make code more readable and maintainable",{"type":186,"tag":238,"props":263,"children":264},{},[265],{"type":192,"value":266},"Worker Threads for CPU-intensive tasks: worker threads provide true parallelism without blocking the main thread",{"type":186,"tag":238,"props":268,"children":269},{},[270],{"type":192,"value":271},"Robust Application: Use permission models, diagnostics channels, and performance monitoring to build robust, observable applications",{"type":186,"tag":238,"props":273,"children":274},{},[275],{"type":192,"value":276},"Developer Experience: Watch mode, built-in testing, and import maps create a more pleasant development workflow",{"type":186,"tag":238,"props":278,"children":279},{},[280],{"type":192,"value":281},"Distribution: Single executable applications and modern packaging make deployment simpler",{"type":186,"tag":201,"props":283,"children":284},{},[285,287],{"type":192,"value":286},"见：",{"type":186,"tag":288,"props":289,"children":293},"a",{"href":290,"rel":291},"https://kashw1n.com/blog/nodejs-2025/",[292],"nofollow",[294],{"type":192,"value":295},"Modern Node.js Patterns for 2025",{"type":186,"tag":187,"props":297,"children":299},{"id":298},"v8",[300],{"type":192,"value":301},"V8",{"type":186,"tag":303,"props":304,"children":305},"ul",{},[306],{"type":186,"tag":238,"props":307,"children":308},{},[309],{"type":186,"tag":288,"props":310,"children":313},{"href":311,"rel":312},"https://v8.dev/docs",[292],[314],{"type":192,"value":315},"V8 Docs",{"type":186,"tag":194,"props":317,"children":319},{"id":318},"引擎的垃圾回收机制有了解吗",[320],{"type":192,"value":321},"引擎的垃圾回收机制有了解吗？",{"type":186,"tag":201,"props":323,"children":324},{},[325],{"type":192,"value":326},"V8 使用分代回收机制，将内存分为新生代和老生代空间，分别用不同的算法进行 GC。新生代空间每个周期都会触发 ScavengeGC，俗称小周期。如果两个周期内都没被清除的变量则转移到老生代内存中。老生代空间则使用标记清除算法（和标记紧缩算法）进行清理。",{"type":186,"tag":194,"props":328,"children":330},{"id":329},"新生代空间的-gc-过程是怎样的",[331],{"type":192,"value":332},"新生代空间的 GC 过程是怎样的？",{"type":186,"tag":201,"props":334,"children":335},{},[336],{"type":192,"value":337},"新生代空间通常只有 1-8 MB，被划分为两个等大的区域，出区和入区。新增变量放到入区中。一但入区满了，便把活跃对象复制到出区中，删除不活跃对象（紧缩过程）并交换出区入区，如此称为一个周期。如果活跃对象再两个周期内都没有被清除，则转移只老生代内存中。",{"type":186,"tag":194,"props":339,"children":341},{"id":340},"老生代空间的-gc-过程是怎样的",[342],{"type":192,"value":343},"老生代空间的 GC 过程是怎样的？",{"type":186,"tag":201,"props":345,"children":346},{},[347],{"type":192,"value":348},"老生代空间的 GC 分标记和清除（或紧缩）两个阶段。每次循环，标记算法会将一个对象从队列中取出，将它以及邻接对象标记。到了清除阶段，未被标记的对象都将被删除。如果清楚阶段额外执行紧缩过程，则会尝试将零散的对象移动成连续的整体，以解决内存碎片化问题。为了优化老生代空间 GC 的“全停顿”，V8 将老生代空间的标记过程拆分为了子步骤，这样就可以将标记算法穿插在其它任务过程中执行。",{"type":186,"tag":194,"props":350,"children":352},{"id":351},"常见的商业开源研究用的-js-引擎有哪些",[353],{"type":192,"value":354},"常见的商业、开源、研究用的 JS 引擎有哪些？",{"type":186,"tag":201,"props":356,"children":357},{},[358,360,371],{"type":192,"value":359},"见",{"type":186,"tag":361,"props":362,"children":363},"i",{},[364],{"type":186,"tag":288,"props":365,"children":368},{"href":366,"rel":367},"https://notes.eatonphil.com/javascript-implementations.html",[292],[369],{"type":192,"value":370},"Enumerating and analyzing 40+ non-V8 JavaScript implementations",{"type":192,"value":372},"，列举了 40 多个非 V8 的 JS 引擎实现。",{"type":186,"tag":187,"props":374,"children":376},{"id":375},"api",[377],{"type":192,"value":378},"API",{"type":186,"tag":194,"props":380,"children":382},{"id":381},"nodevm-是什么",[383],{"type":192,"value":384},"node:vm 是什么？",{"type":186,"tag":201,"props":386,"children":387},{},[388],{"type":192,"value":389},"node:vm 模块允许在 V8 虚拟机上下文中编译和运行代码，上下文中的任何属性都被视为全局变量，对全局变量任何改动也反映到上下文对象中。但是 node:vm 不是一个安全机制，不应该使用它来运行不受信任的代码。",{"type":186,"tag":201,"props":391,"children":392},{},[393,394],{"type":192,"value":286},{"type":186,"tag":288,"props":395,"children":398},{"href":396,"rel":397},"http://nodejs.cn/api/vm.html#vm_vm_executing_javascript",[292],[399],{"type":192,"value":400},"VM",{"type":186,"tag":187,"props":402,"children":404},{"id":403},"源码解析",[405],{"type":192,"value":403},{"type":186,"tag":201,"props":407,"children":408},{},[409],{"type":186,"tag":288,"props":410,"children":412},{"href":411},"/maps/_server/nodejs/source/require",[413],{"type":192,"value":414},"NodeJS | require",{"type":186,"tag":187,"props":416,"children":418},{"id":417},"调试",[419],{"type":192,"value":417},{"type":186,"tag":303,"props":421,"children":422},{},[423],{"type":186,"tag":238,"props":424,"children":425},{},[426],{"type":186,"tag":288,"props":427,"children":430},{"href":428,"rel":429},"https://juejin.cn/post/6844903904728236045",[292],[431],{"type":192,"value":432},"使用火焰图优化 NodeJS CPU 爆涨",{"title":178,"searchDepth":434,"depth":434,"links":435},2,[436,437,438,439,440],{"id":189,"depth":434,"text":189},{"id":298,"depth":434,"text":301},{"id":375,"depth":434,"text":378},{"id":403,"depth":434,"text":403},{"id":417,"depth":434,"text":417},"markdown","content:6.maps:_server:nodejs:nodejs.md","content","6.maps/_server/nodejs/nodejs.md","6.maps/_server/nodejs/nodejs","md",[448,450],{"_path":449,"title":179,"description":180},"/maps/_server/nodejs",{"_path":411,"title":451,"description":452},"NodeJS Require","NodeJS 模块导入的源码解析",1772185450957]