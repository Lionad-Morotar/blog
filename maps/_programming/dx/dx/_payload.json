,"开发者体验（Developer Experience，DX）是指开发者在使用产品、工具、框架等过程中的感受和体验。它是用户体验（User Experience，UX）的一个子集，专注于开发者的需求和体验。","content/6.maps/_programming/dx.md",{"type":183,"children":184,"toc":407},"root",[185,194,218,224,245,251,265,271,305,310,393,398],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"domain",[191],{"type":192,"value":193},"text","Domain",{"type":186,"tag":195,"props":196,"children":197},"ul",{},[198,209],{"type":186,"tag":199,"props":200,"children":201},"li",{},[202],{"type":186,"tag":203,"props":204,"children":206},"a",{"href":205},"/maps/_programming/dx/genai-for-legacy-codebases",[207],{"type":192,"value":208},"GenAI for legacy codebases",{"type":186,"tag":199,"props":210,"children":211},{},[212],{"type":186,"tag":203,"props":213,"children":215},{"href":214},"/maps/_programming/dx/genai-for-forward-engineering",[216],{"type":192,"value":217},"GenAI for forward engineering",{"type":186,"tag":187,"props":219,"children":221},{"id":220},"cross-domain",[222],{"type":192,"value":223},"Cross Domain",{"type":186,"tag":195,"props":225,"children":226},{},[227,236],{"type":186,"tag":199,"props":228,"children":229},{},[230],{"type":186,"tag":203,"props":231,"children":233},{"href":232},"/maps/_ai/prompt/team-based-instructions",[234],{"type":192,"value":235},"Team based Instructions",{"type":186,"tag":199,"props":237,"children":238},{},[239],{"type":186,"tag":203,"props":240,"children":242},{"href":241},"/maps/_ai/vibe/agents-md",[243],{"type":192,"value":244},"agents.md",{"type":186,"tag":187,"props":246,"children":248},{"id":247},"gists",[249],{"type":192,"value":250},"Gists",{"type":186,"tag":252,"props":253,"children":255},"h4",{"id":254},"developer-exception-engineering",[256,263],{"type":186,"tag":257,"props":258,"children":262},"link",{"type":259,"to":260,"source":261},"h5","https://mgear-file.oss-cn-shanghai.aliyuncs.com/Developer%20Exception%20Engineering.html","https://www.swyx.io/developer-exception/",[],{"type":192,"value":264},"《Developer Exception Engineering》",{"type":186,"tag":266,"props":267,"children":268},"p",{},[269],{"type":192,"value":270},"SWYX 认为社区在过去讨论 Developer Experience 的角度稍稍狭隘了。",{"type":186,"tag":195,"props":272,"children":273},{},[274,285,295],{"type":186,"tag":199,"props":275,"children":276},{},[277,283],{"type":186,"tag":278,"props":279,"children":280},"strong",{},[281],{"type":192,"value":282},"能效提升",{"type":192,"value":284},"：提高代码效率、自动化、代码生成器、开箱即用。..",{"type":186,"tag":199,"props":286,"children":287},{},[288,293],{"type":186,"tag":278,"props":289,"children":290},{},[291],{"type":192,"value":292},"富文档",{"type":192,"value":294},"：起步文档、代码示例、可交互示例、API 清单、最佳实践、可搜索。..",{"type":186,"tag":199,"props":296,"children":297},{},[298,303],{"type":186,"tag":278,"props":299,"children":300},{},[301],{"type":192,"value":302},"开发者工具",{"type":192,"value":304},"：脚手架、编辑器插件、代码片段、代码展示、版本控制。..",{"type":186,"tag":266,"props":306,"children":307},{},[308],{"type":192,"value":309},"这些东西对开发者来说时\"友好的\"，但是也很\"简单\"。也许是时候主动跳出站在开发者的角度思考 DX 的舒适区，开始转向终端用户。也许可以尝试保证这些东西：",{"type":186,"tag":195,"props":311,"children":312},{},[313,323,333,343,353,363,373,383],{"type":186,"tag":199,"props":314,"children":315},{},[316,321],{"type":186,"tag":278,"props":317,"children":318},{},[319],{"type":192,"value":320},"服务可用",{"type":192,"value":322},"：产品数据页面和报错页面会说谎吗？...",{"type":186,"tag":199,"props":324,"children":325},{},[326,331],{"type":186,"tag":278,"props":327,"children":328},{},[329],{"type":192,"value":330},"反馈有效",{"type":192,"value":332},"：是否及时有效的解决了客户反馈？...",{"type":186,"tag":199,"props":334,"children":335},{},[336,341],{"type":186,"tag":278,"props":337,"children":338},{},[339],{"type":192,"value":340},"功能完整",{"type":192,"value":342},"：是否发布了不完整甚至需要返工的功能？...",{"type":186,"tag":199,"props":344,"children":345},{},[346,351],{"type":186,"tag":278,"props":347,"children":348},{},[349],{"type":192,"value":350},"产品路线完整",{"type":192,"value":352},"：对产品路线的规划是否清晰合理？...",{"type":186,"tag":199,"props":354,"children":355},{},[356,361],{"type":186,"tag":278,"props":357,"children":358},{},[359],{"type":192,"value":360},"计价合理",{"type":192,"value":362},"：用户会对你的报价产生疑惑么，它是否是可计算和比较的？...",{"type":186,"tag":199,"props":364,"children":365},{},[366,371],{"type":186,"tag":278,"props":367,"children":368},{},[369],{"type":192,"value":370},"兼容性",{"type":192,"value":372},"：废弃的 API 是否合理？...",{"type":186,"tag":199,"props":374,"children":375},{},[376,381],{"type":186,"tag":278,"props":377,"children":378},{},[379],{"type":192,"value":380},"报错优雅",{"type":192,"value":382},"：出错后是否可调试？...",{"type":186,"tag":199,"props":384,"children":385},{},[386,391],{"type":186,"tag":278,"props":387,"children":388},{},[389],{"type":192,"value":390},"访问控制",{"type":192,"value":392},"：客户有审计日志或访问控制的权力吗？...",{"type":186,"tag":266,"props":394,"children":395},{},[396],{"type":192,"value":397},"正如面对漏水的桶下雨解决不了问题，如果只是一直站在开发者的角度思考 DX，对解决品牌满意度下降、客户流失这些\"异常\"没有办法带来帮助。此外，根据康威定律，一个不合理的 DX 会反映出公司的组织架构的不合理之处，这值得引起注意。",{"type":186,"tag":266,"props":399,"children":400},{},[401],{"type":186,"tag":402,"props":403,"children":406},"img",{"alt":404,"src":405},"The Experience of Developer | https://www.swyx.io/developer-exception/","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20210917170405.png",[],{"title":178,"searchDepth":408,"depth":408,"links":409},2,[410,411,412],{"id":189,"depth":408,"text":193},{"id":220,"depth":408,"text":223},{"id":247,"depth":408,"text":250},"markdown","content:6.maps:_programming:dx:dx.md","content","6.maps/_programming/dx/dx.md","6.maps/_programming/dx/dx","md",[420,424],{"_path":421,"title":422,"description":423},"/maps/_programming/debugging/debugging","调试技术","系统化 Bug 修复方法与调试技术",{"_path":214,"title":425,"description":426},"GenAI for Forward Engineering","GenAI用于前向工程是一种新兴技术，通过AI生成的遗留代码库描述来实现系统现代化。它引入了一个显式步骤，专注于遗留代码的功能（其规范），同时刻意隐藏当前实现方式。这与规范驱动开发相关，但专门应用于遗留系统现代化。",1772185448750]