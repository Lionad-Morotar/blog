ing/dx/genai-for-legacy-codebases","dx",false,true,"","GenAI for Legacy Codebases","借助生成式 AI 来理解遗留系统，现在已经是一个实用的默认选择","content/6.maps/_programming/dx/genai-for-legacy-codebases.md",{"type":183,"children":184,"toc":1089},"root",[185,194,200,213,218,224,231,236,324,329,342,348,353,530,536,541,741,747,752,949,955],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"brief",[191],{"type":192,"value":193},"text","Brief",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198],{"type":192,"value":199},"最近几个月，我们已经看到清晰的证据：使用生成式 AI 来理解遗留代码库，能够显著加速对大型、复杂系统的理解。像 Cursor、Claude Code、Copilot、Windsurf、Aider、Cody、Swimm、Unblocked 以及 PocketFlow-Tutorial-Codebase-Knowledge 这样的工具，可以帮助开发人员挖掘业务规则、总结业务与技术逻辑，并识别系统依赖关系。配合开放的技术框架和直接对大模型进行提示（prompt），这些工具能大幅缩短理解遗留代码库所需的时间。",{"type":186,"tag":195,"props":201,"children":202},{},[203,205,211],{"type":192,"value":204},"我们在多个客户项目中的经验表明：借助生成式 AI 来理解遗留系统，现在已经是一个",{"type":186,"tag":206,"props":207,"children":208},"strong",{},[209],{"type":192,"value":210},"实用的默认选择",{"type":192,"value":212},"，而不再只是试验性的做法。前期的环境与数据准备工作量会有所不同，尤其是像 GraphRAG 这类高级方法，其成本通常会随着被分析代码库的规模和复杂度而增长。尽管如此，对生产力的正向影响却是持续而且显著的。生成式 AI 已经成为我们探索和理解遗留系统方式中的一个关键组成部分。",{"type":186,"tag":195,"props":214,"children":215},{},[216],{"type":192,"value":217},"来源：技术雷达",{"type":186,"tag":187,"props":219,"children":221},{"id":220},"guide",[222],{"type":192,"value":223},"Guide",{"type":186,"tag":225,"props":226,"children":228},"h3",{"id":227},"_1-诉求与意义",[229],{"type":192,"value":230},"1. 诉求与意义",{"type":186,"tag":195,"props":232,"children":233},{},[234],{"type":192,"value":235},"从架构视角看，理解遗留代码库通常有几类核心诉求：",{"type":186,"tag":237,"props":238,"children":239},"ol",{},[240,270,297],{"type":186,"tag":241,"props":242,"children":243},"li",{},[244,249,251],{"type":186,"tag":206,"props":245,"children":246},{},[247],{"type":192,"value":248},"业务能力映射",{"type":192,"value":250},"：",{"type":186,"tag":252,"props":253,"children":254},"ul",{},[255,260,265],{"type":186,"tag":241,"props":256,"children":257},{},[258],{"type":192,"value":259},"当前系统是如何实现核心业务流程的？",{"type":186,"tag":241,"props":261,"children":262},{},[263],{"type":192,"value":264},"哪些模块对应哪些领域边界（领域驱动设计中的 $$Bounded\\ Context$$）？",{"type":186,"tag":241,"props":266,"children":267},{},[268],{"type":192,"value":269},"有哪些隐性业务规则只存在于代码里而没有文档？",{"type":186,"tag":241,"props":271,"children":272},{},[273,278,279],{"type":186,"tag":206,"props":274,"children":275},{},[276],{"type":192,"value":277},"架构结构与依赖图谱",{"type":192,"value":250},{"type":186,"tag":252,"props":280,"children":281},{},[282,287,292],{"type":186,"tag":241,"props":283,"children":284},{},[285],{"type":192,"value":286},"分层（UI/服务层/领域层/基础设施层）是否清晰？",{"type":186,"tag":241,"props":288,"children":289},{},[290],{"type":192,"value":291},"系统内部、系统间有哪些高耦合依赖？",{"type":186,"tag":241,"props":293,"children":294},{},[295],{"type":192,"value":296},"哪些模块是“关键路径”或“热点服务”，是未来演进和拆分的重点？",{"type":186,"tag":241,"props":298,"children":299},{},[300,305,306],{"type":186,"tag":206,"props":301,"children":302},{},[303],{"type":192,"value":304},"质量属性与风险点",{"type":192,"value":250},{"type":186,"tag":252,"props":307,"children":308},{},[309,314,319],{"type":186,"tag":241,"props":310,"children":311},{},[312],{"type":192,"value":313},"性能瓶颈可能集中在哪些模块（如同步远程调用、复杂循环、IO 密集逻辑等）？",{"type":186,"tag":241,"props":315,"children":316},{},[317],{"type":192,"value":318},"安全、审计、合规逻辑分布位置？",{"type":186,"tag":241,"props":320,"children":321},{},[322],{"type":192,"value":323},"技术债的集中区域（上古框架、过时库、硬编码配置、临时补丁等）？",{"type":186,"tag":195,"props":325,"children":326},{},[327],{"type":192,"value":328},"生成式 AI 为以上问题提供了一个**高效率“放大镜 + 导游”**的组合：",{"type":186,"tag":252,"props":330,"children":331},{},[332,337],{"type":186,"tag":241,"props":333,"children":334},{},[335],{"type":192,"value":336},"“放大镜”：细粒度阅读与解释代码、注释、配置、脚本。",{"type":186,"tag":241,"props":338,"children":339},{},[340],{"type":192,"value":341},"“导游”：根据我们的问题视角（业务/性能/安全/架构），组织和重构信息，形成更贴合架构决策的视图。",{"type":186,"tag":225,"props":343,"children":345},{"id":344},"_2-工具在分析中的典型用法",[346],{"type":192,"value":347},"2. 工具在分析中的典型用法",{"type":186,"tag":195,"props":349,"children":350},{},[351],{"type":192,"value":352},"原文提到的工具（Cursor、Claude Code、Copilot、Windsurf、Aider、Cody、Swimm、Unblocked、PocketFlow-…）本质上都围绕几个共同能力：",{"type":186,"tag":237,"props":354,"children":355},{},[356,377,439,478],{"type":186,"tag":241,"props":357,"children":358},{},[359,364],{"type":186,"tag":206,"props":360,"children":361},{},[362],{"type":192,"value":363},"代码语义搜索与问答",{"type":186,"tag":252,"props":365,"children":366},{},[367,372],{"type":186,"tag":241,"props":368,"children":369},{},[370],{"type":192,"value":371},"按“业务概念”搜索：例如询问“订单取消流程从哪里开始？涉及哪些服务和数据库表？”",{"type":186,"tag":241,"props":373,"children":374},{},[375],{"type":192,"value":376},"按“架构关注点”搜索：“系统中所有调用外部支付网关的代码与配置有哪些？请画出依赖图。”",{"type":186,"tag":241,"props":378,"children":379},{},[380,385],{"type":186,"tag":206,"props":381,"children":382},{},[383],{"type":192,"value":384},"自动摘要与结构化输出",{"type":186,"tag":252,"props":386,"children":387},{},[388,416],{"type":186,"tag":241,"props":389,"children":390},{},[391,393],{"type":192,"value":392},"对一个模块/服务/目录，让模型生成：\n",{"type":186,"tag":252,"props":394,"children":395},{},[396,401,406,411],{"type":186,"tag":241,"props":397,"children":398},{},[399],{"type":192,"value":400},"功能摘要",{"type":186,"tag":241,"props":402,"children":403},{},[404],{"type":192,"value":405},"输入输出",{"type":186,"tag":241,"props":407,"children":408},{},[409],{"type":192,"value":410},"关键业务规则",{"type":186,"tag":241,"props":412,"children":413},{},[414],{"type":192,"value":415},"主要依赖（服务/库/外部系统）",{"type":186,"tag":241,"props":417,"children":418},{},[419,421],{"type":192,"value":420},"架构师可以据此快速构建：\n",{"type":186,"tag":252,"props":422,"children":423},{},[424,429,434],{"type":186,"tag":241,"props":425,"children":426},{},[427],{"type":192,"value":428},"业务能力清单",{"type":186,"tag":241,"props":430,"children":431},{},[432],{"type":192,"value":433},"服务拓扑图",{"type":186,"tag":241,"props":435,"children":436},{},[437],{"type":192,"value":438},"数据流图 / 依赖图",{"type":186,"tag":241,"props":440,"children":441},{},[442,447],{"type":186,"tag":206,"props":443,"children":444},{},[445],{"type":192,"value":446},"跨文件/跨服务的依赖分析",{"type":186,"tag":252,"props":448,"children":449},{},[450,455],{"type":186,"tag":241,"props":451,"children":452},{},[453],{"type":192,"value":454},"借助工具内置的“项目索引”能力或 GraphRAG，一次性回答：“从 Web 层到数据库，‘用户注册’这条调用链完整路径是什么？”",{"type":186,"tag":241,"props":456,"children":457},{},[458,460],{"type":192,"value":459},"对微服务或模块化单体，帮助识别：\n",{"type":186,"tag":252,"props":461,"children":462},{},[463,468,473],{"type":186,"tag":241,"props":464,"children":465},{},[466],{"type":192,"value":467},"循环依赖",{"type":186,"tag":241,"props":469,"children":470},{},[471],{"type":192,"value":472},"未经网关直接互调",{"type":186,"tag":241,"props":474,"children":475},{},[476],{"type":192,"value":477},"隐式共享数据库/表",{"type":186,"tag":241,"props":479,"children":480},{},[481,486],{"type":186,"tag":206,"props":482,"children":483},{},[484],{"type":192,"value":485},"业务规则“挖掘”",{"type":186,"tag":252,"props":487,"children":488},{},[489,494,512],{"type":186,"tag":241,"props":490,"children":491},{},[492],{"type":192,"value":493},"传统问题：很多老系统的业务规则只存在于代码条件判断中。",{"type":186,"tag":241,"props":495,"children":496},{},[497,499],{"type":192,"value":498},"生成式 AI 能把分散在多处的 if/else、校验、状态机逻辑聚合成：\n",{"type":186,"tag":252,"props":500,"children":501},{},[502,507],{"type":186,"tag":241,"props":503,"children":504},{},[505],{"type":192,"value":506},"“订单状态流转规则一览”",{"type":186,"tag":241,"props":508,"children":509},{},[510],{"type":192,"value":511},"“贷款审批的所有规则及其触发条件”",{"type":186,"tag":241,"props":513,"children":514},{},[515,517],{"type":192,"value":516},"架构层面可以用这些结果去：\n",{"type":186,"tag":252,"props":518,"children":519},{},[520,525],{"type":186,"tag":241,"props":521,"children":522},{},[523],{"type":192,"value":524},"反推领域模型",{"type":186,"tag":241,"props":526,"children":527},{},[528],{"type":192,"value":529},"识别跨上下文的“业务泄漏”（某个上下文不该关心的规则却出现在了这里）",{"type":186,"tag":225,"props":531,"children":533},{"id":532},"_3-与开源框架-graphrag-的结合方式",[534],{"type":192,"value":535},"3. 与开源框架 & GraphRAG 的结合方式",{"type":186,"tag":195,"props":537,"children":538},{},[539],{"type":192,"value":540},"原文提到 “open frameworks and direct LLM prompting” 和 “GraphRAG”等，更偏工程实践，但对架构也很关键：",{"type":186,"tag":237,"props":542,"children":543},{},[544,591,637,689],{"type":186,"tag":241,"props":545,"children":546},{},[547,552],{"type":186,"tag":206,"props":548,"children":549},{},[550],{"type":192,"value":551},"直接 Prompt + 编辑器/IDE 插件",{"type":186,"tag":252,"props":553,"children":554},{},[555,573],{"type":186,"tag":241,"props":556,"children":557},{},[558,560],{"type":192,"value":559},"适合：\n",{"type":186,"tag":252,"props":561,"children":562},{},[563,568],{"type":186,"tag":241,"props":564,"children":565},{},[566],{"type":192,"value":567},"较小代码库",{"type":186,"tag":241,"props":569,"children":570},{},[571],{"type":192,"value":572},"初步摸底、临时问题排查",{"type":186,"tag":241,"props":574,"children":575},{},[576,578],{"type":192,"value":577},"架构侧用途：\n",{"type":186,"tag":252,"props":579,"children":580},{},[581,586],{"type":186,"tag":241,"props":582,"children":583},{},[584],{"type":192,"value":585},"快速查看某个模块的设计意图和实现差异",{"type":186,"tag":241,"props":587,"children":588},{},[589],{"type":192,"value":590},"比对“架构蓝图”与“代码现状”的偏差",{"type":186,"tag":241,"props":592,"children":593},{},[594,599],{"type":186,"tag":206,"props":595,"children":596},{},[597],{"type":192,"value":598},"自建文档/代码知识库 + RAG（检索增强生成）",{"type":186,"tag":252,"props":600,"children":601},{},[602,615],{"type":186,"tag":241,"props":603,"children":604},{},[605,607],{"type":192,"value":606},"将代码、README、API 文档、架构图、接口说明导入向量库：\n",{"type":186,"tag":252,"props":608,"children":609},{},[610],{"type":186,"tag":241,"props":611,"children":612},{},[613],{"type":192,"value":614},"支持 “在整个系统知识库上提问”",{"type":186,"tag":241,"props":616,"children":617},{},[618,619],{"type":192,"value":577},{"type":186,"tag":252,"props":620,"children":621},{},[622,627,632],{"type":186,"tag":241,"props":623,"children":624},{},[625],{"type":192,"value":626},"做“系统级问答平台”",{"type":186,"tag":241,"props":628,"children":629},{},[630],{"type":192,"value":631},"支持新成员快速理解架构",{"type":186,"tag":241,"props":633,"children":634},{},[635],{"type":192,"value":636},"支撑架构评审、方案论证时的事实核查",{"type":186,"tag":241,"props":638,"children":639},{},[640,645],{"type":186,"tag":206,"props":641,"children":642},{},[643],{"type":192,"value":644},"GraphRAG（图结构 + RAG）在架构场景的好处",{"type":186,"tag":252,"props":646,"children":647},{},[648,666],{"type":186,"tag":241,"props":649,"children":650},{},[651,653],{"type":192,"value":652},"不只是“把文档切块”，而是显式建图：\n",{"type":186,"tag":252,"props":654,"children":655},{},[656,661],{"type":186,"tag":241,"props":657,"children":658},{},[659],{"type":192,"value":660},"节点：服务、模块、类、数据库表、API、队列等",{"type":186,"tag":241,"props":662,"children":663},{},[664],{"type":192,"value":665},"边：调用关系、依赖关系、数据流向、事件订阅",{"type":186,"tag":241,"props":667,"children":668},{},[669,671],{"type":192,"value":670},"架构层面可以用来：\n",{"type":186,"tag":252,"props":672,"children":673},{},[674,679,684],{"type":186,"tag":241,"props":675,"children":676},{},[677],{"type":192,"value":678},"自动生成或更新 C4 模型中的 C2/C3 级别图",{"type":186,"tag":241,"props":680,"children":681},{},[682],{"type":192,"value":683},"自动识别“高耦合簇”与“潜在拆分边界”",{"type":186,"tag":241,"props":685,"children":686},{},[687],{"type":192,"value":688},"支持“基于图”的提问，例如：“所有依赖用户服务的下游服务有哪些？影响面如何？”",{"type":186,"tag":241,"props":690,"children":691},{},[692,697],{"type":186,"tag":206,"props":693,"children":694},{},[695],{"type":192,"value":696},"成本与收益考量（架构视角）",{"type":186,"tag":252,"props":698,"children":699},{},[700,723],{"type":186,"tag":241,"props":701,"children":702},{},[703,705],{"type":192,"value":704},"成本随代码规模和复杂度增加：\n",{"type":186,"tag":252,"props":706,"children":707},{},[708,713,718],{"type":186,"tag":241,"props":709,"children":710},{},[711],{"type":192,"value":712},"代码索引与向量化时间",{"type":186,"tag":241,"props":714,"children":715},{},[716],{"type"