type":182,"tag":248,"props":911,"children":912},{},[913,918,923],{"type":182,"tag":237,"props":914,"children":915},{},[916],{"type":188,"value":917},"密码/秘钥处理逻辑",{"type":182,"tag":237,"props":919,"children":920},{},[921],{"type":188,"value":922},"个人数据处理与脱敏逻辑",{"type":182,"tag":237,"props":924,"children":925},{},[926],{"type":188,"value":927},"审计日志记录位置",{"type":182,"tag":237,"props":929,"children":930},{},[931,932],{"type":188,"value":784},{"type":182,"tag":248,"props":933,"children":934},{},[935,940],{"type":182,"tag":237,"props":936,"children":937},{},[938],{"type":188,"value":939},"与法规（如 GDPR、数据安全要求）对齐的“现状对照表”",{"type":182,"tag":237,"props":941,"children":942},{},[943],{"type":188,"value":944},"缺口与整改优先级",{"type":182,"tag":221,"props":946,"children":948},{"id":947},"_5-实施建议",[949],{"type":188,"value":950},"5. 实施建议",{"type":182,"tag":233,"props":952,"children":953},{},[954,983,1017,1056],{"type":182,"tag":237,"props":955,"children":956},{},[957,962],{"type":182,"tag":202,"props":958,"children":959},{},[960],{"type":188,"value":961},"把 “GenAI 辅助理解” 设为默认动作",{"type":182,"tag":248,"props":963,"children":964},{},[965,978],{"type":182,"tag":237,"props":966,"children":967},{},[968,970],{"type":188,"value":969},"新接管一个遗留系统时：\n",{"type":182,"tag":248,"props":971,"children":972},{},[973],{"type":182,"tag":237,"props":974,"children":975},{},[976],{"type":188,"value":977},"第一周就搭建基本的 AI 助手（哪怕只是 IDE 插件 + 项目索引）",{"type":182,"tag":237,"props":979,"children":980},{},[981],{"type":188,"value":982},"把“问 AI”当作与“全文搜索”“读文档”同等优先的手段。",{"type":182,"tag":237,"props":984,"children":985},{},[986,991],{"type":182,"tag":202,"props":987,"children":988},{},[989],{"type":188,"value":990},"架构师主导问题视角",{"type":182,"tag":248,"props":992,"children":993},{},[994,999],{"type":182,"tag":237,"props":995,"children":996},{},[997],{"type":188,"value":998},"避免只用来写代码或解释局部函数；",{"type":182,"tag":237,"props":1000,"children":1001},{},[1002,1004],{"type":188,"value":1003},"要刻意提出架构级问题，例如：\n",{"type":182,"tag":248,"props":1005,"children":1006},{},[1007,1012],{"type":182,"tag":237,"props":1008,"children":1009},{},[1010],{"type":188,"value":1011},"“从架构分层角度总结本项目的结构，并指出不一致之处。”",{"type":182,"tag":237,"props":1013,"children":1014},{},[1015],{"type":188,"value":1016},"“按领域边界帮我重新分组这些模块，给出分组依据。”",{"type":182,"tag":237,"props":1018,"children":1019},{},[1020,1025],{"type":182,"tag":202,"props":1021,"children":1022},{},[1023],{"type":188,"value":1024},"结合人工判断，避免“AI 版本的错觉式架构图”",{"type":182,"tag":248,"props":1026,"children":1027},{},[1028,1051],{"type":182,"tag":237,"props":1029,"children":1030},{},[1031,1033],{"type":188,"value":1032},"所有自动生成的：\n",{"type":182,"tag":248,"props":1034,"children":1035},{},[1036,1041,1046],{"type":182,"tag":237,"props":1037,"children":1038},{},[1039],{"type":188,"value":1040},"架构图",{"type":182,"tag":237,"props":1042,"children":1043},{},[1044],{"type":188,"value":1045},"依赖总结",{"type":182,"tag":237,"props":1047,"children":1048},{},[1049],{"type":188,"value":1050},"业务规则列表",{"type":182,"tag":237,"props":1052,"children":1053},{},[1054],{"type":188,"value":1055},"都要通过抽样验证和代码 spot check 来确认准确性，逐步修正。",{"type":182,"tag":237,"props":1057,"children":1058},{},[1059,1064],{"type":182,"tag":202,"props":1060,"children":1061},{},[1062],{"type":188,"value":1063},"注意安全与合规",{"type":182,"tag":248,"props":1065,"children":1066},{},[1067],{"type":182,"tag":237,"props":1068,"children":1069},{},[1070,1072],{"type":188,"value":1071},"对含敏感代码的项目：\n",{"type":182,"tag":248,"props":1073,"children":1074},{},[1075,1080],{"type":182,"tag":237,"props":1076,"children":1077},{},[1078],{"type":188,"value":1079},"优先选择本地部署或企业版 LLM 方案",{"type":182,"tag":237,"props":1081,"children":1082},{},[1083],{"type":188,"value":1084},"在组织层面明确：哪些仓库可以、哪些不可以接入外部云端 AI 工具。",{"title":175,"searchDepth":1086,"depth":1086,"links":1087},2,[1088,1089],{"id":185,"depth":1086,"text":189},{"id":216,"depth":1086,"text":219,"children":1090},[1091,1093,1094,1095,1096],{"id":223,"depth":1092,"text":226},3,{"id":340,"depth":1092,"text":343},{"id":528,"depth":1092,"text":531},{"id":739,"depth":1092,"text":742},{"id":947,"depth":1092,"text":950},"markdown","content:6.maps:_programming:dx:genai-for-legacy-codebases.md","content","6.maps/_programming/dx/genai-for-legacy-codebases.md","6.maps/_programming/dx/genai-for-legacy-codebases","md",[1104,1108],{"_path":1105,"title":1106,"description":1107},"/maps/_programming/dx/genai-for-forward-engineering","GenAI for Forward Engineering","GenAI用于前向工程是一种新兴技术，通过AI生成的遗留代码库描述来实现系统现代化。它引入了一个显式步骤，专注于遗留代码的功能（其规范），同时刻意隐藏当前实现方式。这与规范驱动开发相关，但专门应用于遗留系统现代化。",{"_path":1109,"title":1110,"description":1111},"/maps/_programming/functional","函数式","函数式编程是一种编程范式，它将计算机运算视为数学函数的计算，并且避免使用程序状态以及易变对象。",1771214948604]