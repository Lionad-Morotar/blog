debases","借助生成式 AI 来理解遗留系统，现在已经是一个实用的默认选择",{"type":179,"children":180,"toc":1085},"root",[181,190,196,209,214,220,227,232,320,325,338,344,349,526,532,537,737,743,748,945,951],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"brief",[187],{"type":188,"value":189},"text","Brief",{"type":182,"tag":191,"props":192,"children":193},"p",{},[194],{"type":188,"value":195},"最近几个月，我们已经看到清晰的证据：使用生成式 AI 来理解遗留代码库，能够显著加速对大型、复杂系统的理解。像 Cursor、Claude Code、Copilot、Windsurf、Aider、Cody、Swimm、Unblocked 以及 PocketFlow-Tutorial-Codebase-Knowledge 这样的工具，可以帮助开发人员挖掘业务规则、总结业务与技术逻辑，并识别系统依赖关系。配合开放的技术框架和直接对大模型进行提示（prompt），这些工具能大幅缩短理解遗留代码库所需的时间。",{"type":182,"tag":191,"props":197,"children":198},{},[199,201,207],{"type":188,"value":200},"我们在多个客户项目中的经验表明：借助生成式 AI 来理解遗留系统，现在已经是一个",{"type":182,"tag":202,"props":203,"children":204},"strong",{},[205],{"type":188,"value":206},"实用的默认选择",{"type":188,"value":208},"，而不再只是试验性的做法。前期的环境与数据准备工作量会有所不同，尤其是像 GraphRAG 这类高级方法，其成本通常会随着被分析代码库的规模和复杂度而增长。尽管如此，对生产力的正向影响却是持续而且显著的。生成式 AI 已经成为我们探索和理解遗留系统方式中的一个关键组成部分。",{"type":182,"tag":191,"props":210,"children":211},{},[212],{"type":188,"value":213},"来源：技术雷达",{"type":182,"tag":183,"props":215,"children":217},{"id":216},"guide",[218],{"type":188,"value":219},"Guide",{"type":182,"tag":221,"props":222,"children":224},"h3",{"id":223},"_1-诉求与意义",[225],{"type":188,"value":226},"1. 诉求与意义",{"type":182,"tag":191,"props":228,"children":229},{},[230],{"type":188,"value":231},"从架构视角看，理解遗留代码库通常有几类核心诉求：",{"type":182,"tag":233,"props":234,"children":235},"ol",{},[236,266,293],{"type":182,"tag":237,"props":238,"children":239},"li",{},[240,245,247],{"type":182,"tag":202,"props":241,"children":242},{},[243],{"type":188,"value":244},"业务能力映射",{"type":188,"value":246},"：",{"type":182,"tag":248,"props":249,"children":250},"ul",{},[251,256,261],{"type":182,"tag":237,"props":252,"children":253},{},[254],{"type":188,"value":255},"当前系统是如何实现核心业务流程的？",{"type":182,"tag":237,"props":257,"children":258},{},[259],{"type":188,"value":260},"哪些模块对应哪些领域边界（领域驱动设计中的 $$Bounded\\ Context$$）？",{"type":182,"tag":237,"props":262,"children":263},{},[264],{"type":188,"value":265},"有哪些隐性业务规则只存在于代码里而没有文档？",{"type":182,"tag":237,"props":267,"children":268},{},[269,274,275],{"type":182,"tag":202,"props":270,"children":271},{},[272],{"type":188,"value":273},"架构结构与依赖图谱",{"type":188,"value":246},{"type":182,"tag":248,"props":276,"children":277},{},[278,283,288],{"type":182,"tag":237,"props":279,"children":280},{},[281],{"type":188,"value":282},"分层（UI/服务层/领域层/基础设施层）是否清晰？",{"type":182,"tag":237,"props":284,"children":285},{},[286],{"type":188,"value":287},"系统内部、系统间有哪些高耦合依赖？",{"type":182,"tag":237,"props":289,"children":290},{},[291],{"type":188,"value":292},"哪些模块是“关键路径”或“热点服务”，是未来演进和拆分的重点？",{"type":182,"tag":237,"props":294,"children":295},{},[296,301,302],{"type":182,"tag":202,"props":297,"children":298},{},[299],{"type":188,"value":300},"质量属性与风险点",{"type":188,"value":246},{"type":182,"tag":248,"props":303,"children":304},{},[305,310,315],{"type":182,"tag":237,"props":306,"children":307},{},[308],{"type":188,"value":309},"性能瓶颈可能集中在哪些模块（如同步远程调用、复杂循环、IO 密集逻辑等）？",{"type":182,"tag":237,"props":311,"children":312},{},[313],{"type":188,"value":314},"安全、审计、合规逻辑分布位置？",{"type":182,"tag":237,"props":316,"children":317},{},[318],{"type":188,"value":319},"技术债的集中区域（上古框架、过时库、硬编码配置、临时补丁等）？",{"type":182,"tag":191,"props":321,"children":322},{},[323],{"type":188,"value":324},"生成式 AI 为以上问题提供了一个**高效率“放大镜 + 导游”**的组合：",{"type":182,"tag":248,"props":326,"children":327},{},[328,333],{"type":182,"tag":237,"props":329,"children":330},{},[331],{"type":188,"value":332},"“放大镜”：细粒度阅读与解释代码、注释、配置、脚本。",{"type":182,"tag":237,"props":334,"children":335},{},[336],{"type":188,"value":337},"“导游”：根据我们的问题视角（业务/性能/安全/架构），组织和重构信息，形成更贴合架构决策的视图。",{"type":182,"tag":221,"props":339,"children":341},{"id":340},"_2-工具在分析中的典型用法",[342],{"type":188,"value":343},"2. 工具在分析中的典型用法",{"type":182,"tag":191,"props":345,"children":346},{},[347],{"type":188,"value":348},"原文提到的工具（Cursor、Claude Code、Copilot、Windsurf、Aider、Cody、Swimm、Unblocked、PocketFlow-…）本质上都围绕几个共同能力：",{"type":182,"tag":233,"props":350,"children":351},{},[352,373,435,474],{"type":182,"tag":237,"props":353,"children":354},{},[355,360],{"type":182,"tag":202,"props":356,"children":357},{},[358],{"type":188,"value":359},"代码语义搜索与问答",{"type":182,"tag":248,"props":361,"children":362},{},[363,368],{"type":182,"tag":237,"props":364,"children":365},{},[366],{"type":188,"value":367},"按“业务概念”搜索：例如询问“订单取消流程从哪里开始？涉及哪些服务和数据库表？”",{"type":182,"tag":237,"props":369,"children":370},{},[371],{"type":188,"value":372},"按“架构关注点”搜索：“系统中所有调用外部支付网关的代码与配置有哪些？请画出依赖图。”",{"type":182,"tag":237,"props":374,"children":375},{},[376,381],{"type":182,"tag":202,"props":377,"children":378},{},[379],{"type":188,"value":380},"自动摘要与结构化输出",{"type":182,"tag":248,"props":382,"children":383},{},[384,412],{"type":182,"tag":237,"props":385,"children":386},{},[387,389],{"type":188,"value":388},"对一个模块/服务/目录，让模型生成：\n",{"type":182,"tag":248,"props":390,"children":391},{},[392,397,402,407],{"type":182,"tag":237,"props":393,"children":394},{},[395],{"type":188,"value":396},"功能摘要",{"type":182,"tag":237,"props":398,"children":399},{},[400],{"type":188,"value":401},"输入输出",{"type":182,"tag":237,"props":403,"children":404},{},[405],{"type":188,"value":406},"关键业务规则",{"type":182,"tag":237,"props":408,"children":409},{},[410],{"type":188,"value":411},"主要依赖（服务/库/外部系统）",{"type":182,"tag":237,"props":413,"children":414},{},[415,417],{"type":188,"value":416},"架构师可以据此快速构建：\n",{"type":182,"tag":248,"props":418,"children":419},{},[420,425,430],{"type":182,"tag":237,"props":421,"children":422},{},[423],{"type":188,"value":424},"业务能力清单",{"type":182,"tag":237,"props":426,"children":427},{},[428],{"type":188,"value":429},"服务拓扑图",{"type":182,"tag":237,"props":431,"children":432},{},[433],{"type":188,"value":434},"数据流图 / 依赖图",{"type":182,"tag":237,"props":436,"children":437},{},[438,443],{"type":182,"tag":202,"props":439,"children":440},{},[441],{"type":188,"value":442},"跨文件/跨服务的依赖分析",{"type":182,"tag":248,"props":444,"children":445},{},[446,451],{"type":182,"tag":237,"props":447,"children":448},{},[449],{"type":188,"value":450},"借助工具内置的“项目索引”能力或 GraphRAG，一次性回答：“从 Web 层到数据库，‘用户注册’这条调用链完整路径是什么？”",{"type":182,"tag":237,"props":452,"children":453},{},[454,456],{"type":188,"value":455},"对微服务或模块化单体，帮助识别：\n",{"type":182,"tag":248,"props":457,"children":458},{},[459,464,469],{"type":182,"tag":237,"props":460,"children":461},{},[462],{"type":188,"value":463},"循环依赖",{"type":182,"tag":237,"props":465,"children":466},{},[467],{"type":188,"value":468},"未经网关直接互调",{"type":182,"tag":237,"props":470,"children":471},{},[472],{"type":188,"value":473},"隐式共享数据库/表",{"type":182,"tag":237,"props":475,"children":476},{},[477,482],{"type":182,"tag":202,"props":478,"children":479},{},[480],{"type":188,"value":481},"业务规则“挖掘”",{"type":182,"tag":248,"props":483,"children":484},{},[485,490,508],{"type":182,"tag":237,"props":486,"children":487},{},[488],{"type":188,"value":489},"传统问题：很多老系统的业务规则只存在于代码条件判断中。",{"type":182,"tag":237,"props":491,"children":492},{},[493,495],{"type":188,"value":494},"生成式 AI 能把分散在多处的 if/else、校验、状态机逻辑聚合成：\n",{"type":182,"tag":248,"props":496,"children":497},{},[498,503],{"type":182,"tag":237,"props":499,"children":500},{},[501],{"type":188,"value":502},"“订单状态流转规则一览”",{"type":182,"tag":237,"props":504,"children":505},{},[506],{"type":188,"value":507},"“贷款审批的所有规则及其触发条件”",{"type":182,"tag":237,"props":509,"children":510},{},[511,513],{"type":188,"value":512},"架构层面可以用这些结果去：\n",{"type":182,"tag":248,"props":514,"children":515},{},[516,521],{"type":182,"tag":237,"props":517,"children":518},{},[519],{"type":188,"value":520},"反推领域模型",{"type":182,"tag":237,"props":522,"children":523},{},[524],{"type":188,"value":525},"识别跨上下文的“业务泄漏”（某个上下文不该关心的规则却出现在了这里）",{"type":182,"tag":221,"props":527,"children":529},{"id":528},"_3-与开源框架-graphrag-的结合方式",[530],{"type":188,"value":531},"3. 与开源框架 & GraphRAG 的结合方式",{"type":182,"tag":191,"props":533,"children":534},{},[535],{"type":188,"value":536},"原文提到 “open frameworks and direct LLM prompting” 和 “GraphRAG”等，更偏工程实践，但对架构也很关键：",{"type":182,"tag":233,"props":538,"children":539},{},[540,587,633,685],{"type":182,"tag":237,"props":541,"children":542},{},[543,548],{"type":182,"tag":202,"props":544,"children":545},{},[546],{"type":188,"value":547},"直接 Prompt + 编辑器/IDE 插件",{"type":182,"tag":248,"props":549,"children":550},{},[551,569],{"type":182,"tag":237,"props":552,"children":553},{},[554,556],{"type":188,"value":555},"适合：\n",{"type":182,"tag":248,"props":557,"children":558},{},[559,564],{"type":182,"tag":237,"props":560,"children":561},{},[562],{"type":188,"value":563},"较小代码库",{"type":182,"tag":237,"props":565,"children":566},{},[567],{"type":188,"value":568},"初步摸底、临时问题排查",{"type":182,"tag":237,"props":570,"children":571},{},[572,574],{"type":188,"value":573},"架构侧用途：\n",{"type":182,"tag":248,"props":575,"children":576},{},[577,582],{"type":182,"tag":237,"props":578,"children":579},{},[580],{"type":188,"value":581},"快速查看某个模块的设计意图和实现差异",{"type":182,"tag":237,"props":583,"children":584},{},[585],{"type":188,"value":586},"比对“架构蓝图”与“代码现状”的偏差",{"type":182,"tag":237,"props":588,"children":589},{},[590,595],{"type":182,"tag":202,"props":591,"children":592},{},[593],{"type":188,"value":594},"自建文档/代码知识库 + RAG（检索增强生成）",{"type":182,"tag":248,"props":596,"children":597},{},[598,611],{"type":182,"tag":237,"props":599,"children":600},{},[601,603],{"type":188,"value":602},"将代码、README、API 文档、架构图、接口说明导入向量库：\n",{"type":182,"tag":248,"props":604,"children":605},{},[606],{"type":182,"tag":237,"props":607,"children":608},{},[609],{"type":188,"value":610},"支持 “在整个系统知识库上提问”",{"type":182,"tag":237,"props":612,"children":613},{},[614,615],{"type":188,"value":573},{"type":182,"tag":248,"props":616,"children":617},{},[618,623,628],{"type":182,"tag":237,"props":619,"children":620},{},[621],{"type":188,"value":622},"做“系统级问答平台”",{"type":182,"tag":237,"props":624,"children":625},{},[626],{"type":188,"value":627},"支持新成员快速理解架构",{"type":182,"tag":237,"props":629,"children":630},{},[631],{"type":188,"value":632},"支撑架构评审、方案论证时的事实核查",{"type":182,"tag":237,"props":634,"children":635},{},[636,641],{"type":182,"tag":202,"props":637,"children":638},{},[639],{"type":188,"value":640},"GraphRAG（图结构 + RAG）在架构场景的好处",{"type":182,"tag":248,"props":642,"children":643},{},[644,662],{"type":182,"tag":237,"props":645,"children":646},{},[647,649],{"type":188,"value":648},"不只是“把文档切块”，而是显式建图：\n",{"type":182,"tag":248,"props":650,"children":651},{},[652,657],{"type":182,"tag":237,"props":653,"children":654},{},[655],{"type":188,"value":656},"节点：服务、模块、类、数据库表、API、队列等",{"type":182,"tag":237,"props":658,"children":659},{},[660],{"type":188,"value":661},"边：调用关系、依赖关系、数据流向、事件订阅",{"type":182,"tag":237,"props":663,"children":664},{},[665,667],{"type":188,"value":666},"架构层面可以用来：\n",{"type":182,"tag":248,"props":668,"children":669},{},[670,675,680],{"type":182,"tag":237,"props":671,"children":672},{},[673],{"type":188,"value":674},"自动生成或更新 C4 模型中的 C2/C3 级别图",{"type":182,"tag":237,"props":676,"children":677},{},[678],{"type":188,"value":679},"自动识别“高耦合簇”与“潜在拆分边界”",{"type":182,"tag":237,"props":681,"children":682},{},[683],{"type":188,"value":684},"支持“基于图”的提问，例如：“所有依赖用户服务的下游服务有哪些？影响面如何？”",{"type":182,"tag":237,"props":686,"children":687},{},[688,693],{"type":182,"tag":202,"props":689,"children":690},{},[691],{"type":188,"value":692},"成本与收益考量（架构视角）",{"type":182,"tag":248,"props":694,"children":695},{},[696,719],{"type":182,"tag":237,"props":697,"children":698},{},[699,701],{"type":188,"value":700},"成本随代码规模和复杂度增加：\n",{"type":182,"tag":248,"props":702,"children":703},{},[704,709,714],{"type":182,"tag":237,"props":705,"children":706},{},[707],{"type":188,"value":708},"代码索引与向量化时间",{"type":182,"tag":237,"props":710,"children":711},{},[712],{"type":188,"value":713},"图构建与维护成本",{"type":182,"tag":237,"props":715,"children":716},{},[717],{"type":188,"value":718},"安全与访问控制（避免将敏感代码泄露到第三方）",{"type":182,"tag":237,"props":720,"children":721},{},[722,724],{"type":188,"value":723},"但收益在架构活动中高度稳定：\n",{"type":182,"tag":248,"props":725,"children":726},{},[727,732],{"type":182,"tag":237,"props":728,"children":729},{},[730],{"type":188,"value":731},"需求：系统重构、云迁移、微服务拆分、合规审计、并购系统整合",{"type":182,"tag":237,"props":733,"children":734},{},[735],{"type":188,"value":736},"目标：缩短“理解阶段”的时间，让架构师把时间放在“设计决策”而不是“翻代码”",{"type":182,"tag":221,"props":738,"children":740},{"id":739},"_4-在架构活动中的典型应用场景",[741],{"type":188,"value":742},"4. 在架构活动中的典型应用场景",{"type":182,"tag":191,"props":744,"children":745},{},[746],{"type":188,"value":747},"可以在内部分享时用以下几个“故事化场景”来说明：",{"type":182,"tag":233,"props":749,"children":750},{},[751,803,848,894],{"type":182,"tag":237,"props":752,"children":753},{},[754,759],{"type":182,"tag":202,"props":755,"children":756},{},[757],{"type":188,"value":758},"遗留单体 → 微服务拆分",{"type":182,"tag":248,"props":760,"children":761},{},[762,780],{"type":182,"tag":237,"props":763,"children":764},{},[765,767],{"type":188,"value":766},"用 GenAI：\n",{"type":182,"tag":248,"props":768,"children":769},{},[770,775],{"type":182,"tag":237,"props":771,"children":772},{},[773],{"type":188,"value":774},"列出业务能力与相应代码位置",{"type":182,"tag":237,"props":776,"children":777},{},[778],{"type":188,"value":779},"找出跨能力的共享数据库表与强耦合模块",{"type":182,"tag":237,"props":781,"children":782},{},[783,785],{"type":188,"value":784},"产出：\n",{"type":182,"tag":248,"props":786,"children":787},{},[788,793,798],{"type":182,"tag":237,"props":789,"children":790},{},[791],{"type":188,"value":792},"候选领域上下文划分",{"type":182,"tag":237,"props":794,"children":795},{},[796],{"type":188,"value":797},"优先拆分的服务列表",{"type":182,"tag":237,"props":799,"children":800},{},[801],{"type":188,"value":802},"拆分风险（共享事务、跨上下文业务规则）",{"type":182,"tag":237,"props":804,"children":805},{},[806,811],{"type":182,"tag":202,"props":807,"children":808},{},[809],{"type":188,"value":810},"云迁移或平台迁移（如上云、从自建 ESB 到 API 网关）",{"type":182,"tag":248,"props":812,"childr