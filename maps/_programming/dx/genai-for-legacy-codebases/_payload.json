,{"type":186,"tag":241,"props":1004,"children":1005},{},[1006,1008],{"type":192,"value":1007},"要刻意提出架构级问题，例如：\n",{"type":186,"tag":252,"props":1009,"children":1010},{},[1011,1016],{"type":186,"tag":241,"props":1012,"children":1013},{},[1014],{"type":192,"value":1015},"“从架构分层角度总结本项目的结构，并指出不一致之处。”",{"type":186,"tag":241,"props":1017,"children":1018},{},[1019],{"type":192,"value":1020},"“按领域边界帮我重新分组这些模块，给出分组依据。”",{"type":186,"tag":241,"props":1022,"children":1023},{},[1024,1029],{"type":186,"tag":206,"props":1025,"children":1026},{},[1027],{"type":192,"value":1028},"结合人工判断，避免“AI 版本的错觉式架构图”",{"type":186,"tag":252,"props":1030,"children":1031},{},[1032,1055],{"type":186,"tag":241,"props":1033,"children":1034},{},[1035,1037],{"type":192,"value":1036},"所有自动生成的：\n",{"type":186,"tag":252,"props":1038,"children":1039},{},[1040,1045,1050],{"type":186,"tag":241,"props":1041,"children":1042},{},[1043],{"type":192,"value":1044},"架构图",{"type":186,"tag":241,"props":1046,"children":1047},{},[1048],{"type":192,"value":1049},"依赖总结",{"type":186,"tag":241,"props":1051,"children":1052},{},[1053],{"type":192,"value":1054},"业务规则列表",{"type":186,"tag":241,"props":1056,"children":1057},{},[1058],{"type":192,"value":1059},"都要通过抽样验证和代码 spot check 来确认准确性，逐步修正。",{"type":186,"tag":241,"props":1061,"children":1062},{},[1063,1068],{"type":186,"tag":206,"props":1064,"children":1065},{},[1066],{"type":192,"value":1067},"注意安全与合规",{"type":186,"tag":252,"props":1069,"children":1070},{},[1071],{"type":186,"tag":241,"props":1072,"children":1073},{},[1074,1076],{"type":192,"value":1075},"对含敏感代码的项目：\n",{"type":186,"tag":252,"props":1077,"children":1078},{},[1079,1084],{"type":186,"tag":241,"props":1080,"children":1081},{},[1082],{"type":192,"value":1083},"优先选择本地部署或企业版 LLM 方案",{"type":186,"tag":241,"props":1085,"children":1086},{},[1087],{"type":192,"value":1088},"在组织层面明确：哪些仓库可以、哪些不可以接入外部云端 AI 工具。",{"title":178,"searchDepth":1090,"depth":1090,"links":1091},2,[1092,1093],{"id":189,"depth":1090,"text":193},{"id":220,"depth":1090,"text":223,"children":1094},[1095,1097,1098,1099,1100],{"id":227,"depth":1096,"text":230},3,{"id":344,"depth":1096,"text":347},{"id":532,"depth":1096,"text":535},{"id":743,"depth":1096,"text":746},{"id":951,"depth":1096,"text":954},"markdown","content:6.maps:_programming:dx:genai-for-legacy-codebases.md","content","6.maps/_programming/dx/genai-for-legacy-codebases.md","6.maps/_programming/dx/genai-for-legacy-codebases","md",[1108,1112],{"_path":1109,"title":1110,"description":1111},"/maps/_programming/dx/genai-for-forward-engineering","GenAI for Forward Engineering","GenAI用于前向工程是一种新兴技术，通过AI生成的遗留代码库描述来实现系统现代化。它引入了一个显式步骤，专注于遗留代码的功能（其规范），同时刻意隐藏当前实现方式。这与规范驱动开发相关，但专门应用于遗留系统现代化。",{"_path":1113,"title":1114,"description":1115},"/maps/_programming/frameworks/frameworks","框架与工具","开发框架、工具库与 TUI 框架",1772185473659]