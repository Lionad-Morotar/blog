acy-codebases","dx",false,true,"","GenAI for Legacy Codebases","借助生成式 AI 来理解遗留系统，现在已经是一个实用的默认选择",{"type":182,"children":183,"toc":1088},"root",[184,193,199,212,217,223,230,235,323,328,341,347,352,529,535,540,740,746,751,948,954],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"brief",[190],{"type":191,"value":192},"text","Brief",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"最近几个月，我们已经看到清晰的证据：使用生成式 AI 来理解遗留代码库，能够显著加速对大型、复杂系统的理解。像 Cursor、Claude Code、Copilot、Windsurf、Aider、Cody、Swimm、Unblocked 以及 PocketFlow-Tutorial-Codebase-Knowledge 这样的工具，可以帮助开发人员挖掘业务规则、总结业务与技术逻辑，并识别系统依赖关系。配合开放的技术框架和直接对大模型进行提示（prompt），这些工具能大幅缩短理解遗留代码库所需的时间。",{"type":185,"tag":194,"props":200,"children":201},{},[202,204,210],{"type":191,"value":203},"我们在多个客户项目中的经验表明：借助生成式 AI 来理解遗留系统，现在已经是一个",{"type":185,"tag":205,"props":206,"children":207},"strong",{},[208],{"type":191,"value":209},"实用的默认选择",{"type":191,"value":211},"，而不再只是试验性的做法。前期的环境与数据准备工作量会有所不同，尤其是像 GraphRAG 这类高级方法，其成本通常会随着被分析代码库的规模和复杂度而增长。尽管如此，对生产力的正向影响却是持续而且显著的。生成式 AI 已经成为我们探索和理解遗留系统方式中的一个关键组成部分。",{"type":185,"tag":194,"props":213,"children":214},{},[215],{"type":191,"value":216},"来源：技术雷达",{"type":185,"tag":186,"props":218,"children":220},{"id":219},"guide",[221],{"type":191,"value":222},"Guide",{"type":185,"tag":224,"props":225,"children":227},"h3",{"id":226},"_1-诉求与意义",[228],{"type":191,"value":229},"1. 诉求与意义",{"type":185,"tag":194,"props":231,"children":232},{},[233],{"type":191,"value":234},"从架构视角看，理解遗留代码库通常有几类核心诉求：",{"type":185,"tag":236,"props":237,"children":238},"ol",{},[239,269,296],{"type":185,"tag":240,"props":241,"children":242},"li",{},[243,248,250],{"type":185,"tag":205,"props":244,"children":245},{},[246],{"type":191,"value":247},"业务能力映射",{"type":191,"value":249},"：",{"type":185,"tag":251,"props":252,"children":253},"ul",{},[254,259,264],{"type":185,"tag":240,"props":255,"children":256},{},[257],{"type":191,"value":258},"当前系统是如何实现核心业务流程的？",{"type":185,"tag":240,"props":260,"children":261},{},[262],{"type":191,"value":263},"哪些模块对应哪些领域边界（领域驱动设计中的 $$Bounded\\ Context$$）？",{"type":185,"tag":240,"props":265,"children":266},{},[267],{"type":191,"value":268},"有哪些隐性业务规则只存在于代码里而没有文档？",{"type":185,"tag":240,"props":270,"children":271},{},[272,277,278],{"type":185,"tag":205,"props":273,"children":274},{},[275],{"type":191,"value":276},"架构结构与依赖图谱",{"type":191,"value":249},{"type":185,"tag":251,"props":279,"children":280},{},[281,286,291],{"type":185,"tag":240,"props":282,"children":283},{},[284],{"type":191,"value":285},"分层（UI/服务层/领域层/基础设施层）是否清晰？",{"type":185,"tag":240,"props":287,"children":288},{},[289],{"type":191,"value":290},"系统内部、系统间有哪些高耦合依赖？",{"type":185,"tag":240,"props":292,"children":293},{},[294],{"type":191,"value":295},"哪些模块是“关键路径”或“热点服务”，是未来演进和拆分的重点？",{"type":185,"tag":240,"props":297,"children":298},{},[299,304,305],{"type":185,"tag":205,"props":300,"children":301},{},[302],{"type":191,"value":303},"质量属性与风险点",{"type":191,"value":249},{"type":185,"tag":251,"props":306,"children":307},{},[308,313,318],{"type":185,"tag":240,"props":309,"children":310},{},[311],{"type":191,"value":312},"性能瓶颈可能集中在哪些模块（如同步远程调用、复杂循环、IO 密集逻辑等）？",{"type":185,"tag":240,"props":314,"children":315},{},[316],{"type":191,"value":317},"安全、审计、合规逻辑分布位置？",{"type":185,"tag":240,"props":319,"children":320},{},[321],{"type":191,"value":322},"技术债的集中区域（上古框架、过时库、硬编码配置、临时补丁等）？",{"type":185,"tag":194,"props":324,"children":325},{},[326],{"type":191,"value":327},"生成式 AI 为以上问题提供了一个**高效率“放大镜 + 导游”**的组合：",{"type":185,"tag":251,"props":329,"children":330},{},[331,336],{"type":185,"tag":240,"props":332,"children":333},{},[334],{"type":191,"value":335},"“放大镜”：细粒度阅读与解释代码、注释、配置、脚本。",{"type":185,"tag":240,"props":337,"children":338},{},[339],{"type":191,"value":340},"“导游”：根据我们的问题视角（业务/性能/安全/架构），组织和重构信息，形成更贴合架构决策的视图。",{"type":185,"tag":224,"props":342,"children":344},{"id":343},"_2-工具在分析中的典型用法",[345],{"type":191,"value":346},"2. 工具在分析中的典型用法",{"type":185,"tag":194,"props":348,"children":349},{},[350],{"type":191,"value":351},"原文提到的工具（Cursor、Claude Code、Copilot、Windsurf、Aider、Cody、Swimm、Unblocked、PocketFlow-…）本质上都围绕几个共同能力：",{"type":185,"tag":236,"props":353,"children":354},{},[355,376,438,477],{"type":185,"tag":240,"props":356,"children":357},{},[358,363],{"type":185,"tag":205,"props":359,"children":360},{},[361],{"type":191,"value":362},"代码语义搜索与问答",{"type":185,"tag":251,"props":364,"children":365},{},[366,371],{"type":185,"tag":240,"props":367,"children":368},{},[369],{"type":191,"value":370},"按“业务概念”搜索：例如询问“订单取消流程从哪里开始？涉及哪些服务和数据库表？”",{"type":185,"tag":240,"props":372,"children":373},{},[374],{"type":191,"value":375},"按“架构关注点”搜索：“系统中所有调用外部支付网关的代码与配置有哪些？请画出依赖图。”",{"type":185,"tag":240,"props":377,"children":378},{},[379,384],{"type":185,"tag":205,"props":380,"children":381},{},[382],{"type":191,"value":383},"自动摘要与结构化输出",{"type":185,"tag":251,"props":385,"children":386},{},[387,415],{"type":185,"tag":240,"props":388,"children":389},{},[390,392],{"type":191,"value":391},"对一个模块/服务/目录，让模型生成：\n",{"type":185,"tag":251,"props":393,"children":394},{},[395,400,405,410],{"type":185,"tag":240,"props":396,"children":397},{},[398],{"type":191,"value":399},"功能摘要",{"type":185,"tag":240,"props":401,"children":402},{},[403],{"type":191,"value":404},"输入输出",{"type":185,"tag":240,"props":406,"children":407},{},[408],{"type":191,"value":409},"关键业务规则",{"type":185,"tag":240,"props":411,"children":412},{},[413],{"type":191,"value":414},"主要依赖（服务/库/外部系统）",{"type":185,"tag":240,"props":416,"children":417},{},[418,420],{"type":191,"value":419},"架构师可以据此快速构建：\n",{"type":185,"tag":251,"props":421,"children":422},{},[423,428,433],{"type":185,"tag":240,"props":424,"children":425},{},[426],{"type":191,"value":427},"业务能力清单",{"type":185,"tag":240,"props":429,"children":430},{},[431],{"type":191,"value":432},"服务拓扑图",{"type":185,"tag":240,"props":434,"children":435},{},[436],{"type":191,"value":437},"数据流图 / 依赖图",{"type":185,"tag":240,"props":439,"children":440},{},[441,446],{"type":185,"tag":205,"props":442,"children":443},{},[444],{"type":191,"value":445},"跨文件/跨服务的依赖分析",{"type":185,"tag":251,"props":447,"children":448},{},[449,454],{"type":185,"tag":240,"props":450,"children":451},{},[452],{"type":191,"value":453},"借助工具内置的“项目索引”能力或 GraphRAG，一次性回答：“从 Web 层到数据库，‘用户注册’这条调用链完整路径是什么？”",{"type":185,"tag":240,"props":455,"children":456},{},[457,459],{"type":191,"value":458},"对微服务或模块化单体，帮助识别：\n",{"type":185,"tag":251,"props":460,"children":461},{},[462,467,472],{"type":185,"tag":240,"props":463,"children":464},{},[465],{"type":191,"value":466},"循环依赖",{"type":185,"tag":240,"props":468,"children":469},{},[470],{"type":191,"value":471},"未经网关直接互调",{"type":185,"tag":240,"props":473,"children":474},{},[475],{"type":191,"value":476},"隐式共享数据库/表",{"type":185,"tag":240,"props":478,"children":479},{},[480,485],{"type":185,"tag":205,"props":481,"children":482},{},[483],{"type":191,"value":484},"业务规则“挖掘”",{"type":185,"tag":251,"props":486,"children":487},{},[488,493,511],{"type":185,"tag":240,"props":489,"children":490},{},[491],{"type":191,"value":492},"传统问题：很多老系统的业务规则只存在于代码条件判断中。",{"type":185,"tag":240,"props":494,"children":495},{},[496,498],{"type":191,"value":497},"生成式 AI 能把分散在多处的 if/else、校验、状态机逻辑聚合成：\n",{"type":185,"tag":251,"props":499,"children":500},{},[501,506],{"type":185,"tag":240,"props":502,"children":503},{},[504],{"type":191,"value":505},"“订单状态流转规则一览”",{"type":185,"tag":240,"props":507,"children":508},{},[509],{"type":191,"value":510},"“贷款审批的所有规则及其触发条件”",{"type":185,"tag":240,"props":512,"children":513},{},[514,516],{"type":191,"value":515},"架构层面可以用这些结果去：\n",{"type":185,"tag":251,"props":517,"children":518},{},[519,524],{"type":185,"tag":240,"props":520,"children":521},{},[522],{"type":191,"value":523},"反推领域模型",{"type":185,"tag":240,"props":525,"children":526},{},[527],{"type":191,"value":528},"识别跨上下文的“业务泄漏”（某个上下文不该关心的规则却出现在了这里）",{"type":185,"tag":224,"props":530,"children":532},{"id":531},"_3-与开源框架-graphrag-的结合方式",[533],{"type":191,"value":534},"3. 与开源框架 & GraphRAG 的结合方式",{"type":185,"tag":194,"props":536,"children":537},{},[538],{"type":191,"value":539},"原文提到 “open frameworks and direct LLM prompting” 和 “GraphRAG”等，更偏工程实践，但对架构也很关键：",{"type":185,"tag":236,"props":541,"children":542},{},[543,590,636,688],{"type":185,"tag":240,"props":544,"children":545},{},[546,551],{"type":185,"tag":205,"props":547,"children":548},{},[549],{"type":191,"value":550},"直接 Prompt + 编辑器/IDE 插件",{"type":185,"tag":251,"props":552,"children":553},{},[554,572],{"type":185,"tag":240,"props":555,"children":556},{},[557,559],{"type":191,"value":558},"适合：\n",{"type":185,"tag":251,"props":560,"children":561},{},[562,567],{"type":185,"tag":240,"props":563,"children":564},{},[565],{"type":191,"value":566},"较小代码库",{"type":185,"tag":240,"props":568,"children":569},{},[570],{"type":191,"value":571},"初步摸底、临时问题排查",{"type":185,"tag":240,"props":573,"children":574},{},[575,577],{"type":191,"value":576},"架构侧用途：\n",{"type":185,"tag":251,"props":578,"children":579},{},[580,585],{"type":185,"tag":240,"props":581,"children":582},{},[583],{"type":191,"value":584},"快速查看某个模块的设计意图和实现差异",{"type":185,"tag":240,"props":586,"children":587},{},[588],{"type":191,"value":589},"比对“架构蓝图”与“代码现状”的偏差",{"type":185,"tag":240,"props":591,"children":592},{},[593,598],{"type":185,"tag":205,"props":594,"children":595},{},[596],{"type":191,"value":597},"自建文档/代码知识库 + RAG（检索增强生成）",{"type":185,"tag":251,"props":599,"children":600},{},[601,614],{"type":185,"tag":240,"props":602,"children":603},{},[604,606],{"type":191,"value":605},"将代码、README、API 文档、架构图、接口说明导入向量库：\n",{"type":185,"tag":251,"props":607,"children":608},{},[609],{"type":185,"tag":240,"props":610,"children":611},{},[612],{"type":191,"value":613},"支持 “在整个系统知识库上提问”",{"type":185,"tag":240,"props":615,"children":616},{},[617,618],{"type":191,"value":576},{"type":185,"tag":251,"props":619,"children":620},{},[621,626,631],{"type":185,"tag":240,"props":622,"children":623},{},[624],{"type":191,"value":625},"做“系统级问答平台”",{"type":185,"tag":240,"props":627,"children":628},{},[629],{"type":191,"value":630},"支持新成员快速理解架构",{"type":185,"tag":240,"props":632,"children":633},{},[634],{"type":191,"value":635},"支撑架构评审、方案论证时的事实核查",{"type":185,"tag":240,"props":637,"children":638},{},[639,644],{"type":185,"tag":205,"props":640,"children":641},{},[642],{"type":191,"value":643},"GraphRAG（图结构 + RAG）在架构场景的好处",{"type":185,"tag":251,"props":645,"children":646},{},[647,665],{"type":185,"tag":240,"props":648,"children":649},{},[650,652],{"type":191,"value":651},"不只是“把文档切块”，而是显式建图：\n",{"type":185,"tag":251,"props":653,"children":654},{},[655,660],{"type":185,"tag":240,"props":656,"children":657},{},[658],{"type":191,"value":659},"节点：服务、模块、类、数据库表、API、队列等",{"type":185,"tag":240,"props":661,"children":662},{},[663],{"type":191,"value":664},"边：调用关系、依赖关系、数据流向、事件订阅",{"type":185,"tag":240,"props":666,"children":667},{},[668,670],{"type":191,"value":669},"架构层面可以用来：\n",{"type":185,"tag":251,"props":671,"children":672},{},[673,678,683],{"type":185,"tag":240,"props":674,"children":675},{},[676],{"type":191,"value":677},"自动生成或更新 C4 模型中的 C2/C3 级别图",{"type":185,"tag":240,"props":679,"children":680},{},[681],{"type":191,"value":682},"自动识别“高耦合簇”与“潜在拆分边界”",{"type":185,"tag":240,"props":684,"children":685},{},[686],{"type":191,"value":687},"支持“基于图”的提问，例如：“所有依赖用户服务的下游服务有哪些？影响面如何？”",{"type":185,"tag":240,"props":689,"children":690},{},[691,696],{"type":185,"tag":205,"props":692,"children":693},{},[694],{"type":191,"value":695},"成本与收益考量（架构视角）",{"type":185,"tag":251,"props":697,"children":698},{},[699,722],{"type":185,"tag":240,"props":700,"children":701},{},[702,704],{"type":191,"value":703},"成本随代码规模和复杂度增加：\n",{"type":185,"tag":251,"props":705,"children":706},{},[707,712,717],{"type":185,"tag":240,"props":708,"children":709},{},[710],{"type":191,"value":711},"代码索引与向量化时间",{"type":185,"tag":240,"props":713,"children":714},{},[715],{"type":191,"value":716},"图构建与维护成本",{"type":185,"tag":240,"props":718,"children":719},{},[720],{"type":191,"value":721},"安全与访问控制（避免将敏感代码泄露到第三方）",{"type":185,"tag":240,"props":723,"children":724},{},[725,727],{"type":191,"value":726},"但收益在架构活动中高度稳定：\n",{"type":185,"tag":251,"props":728,"children":729},{},[730,735],{"type":185,"tag":240,"props":731,"children":732},{},[733],{"type":191,"value":734},"需求：系统重构、云迁移、微服务拆分、合规审计、并购系统整合",{"type":185,"tag":240,"props":736,"children":737},{},[738],{"type":191,"value":739},"目标：缩短“理解阶段”的时间，让架构师把时间放在“设计决策”而不是“翻代码”",{"type":185,"tag":224,"props":741,"children":743},{"id":742},"_4-在架构活动中的典型应用场景",[744],{"type":191,"value":745},"4. 在架构活动中的典型应用场景",{"type":185,"tag":194,"props":747,"children":748},{},[749],{"type":191,"value":750},"可以在内部分享时用以下几个“故事化场景”来说明：",{"type":185,"tag":236,"props":752,"children":753},{},[754,806,851,897],{"type":185,"tag":240,"props":755,"children":756},{},[757,762],{"type":185,"tag":205,"props":758,"children":759},{},[760],{"type":191,"value":761},"遗留单体 → 微服务拆分",{"type":185,"tag":251,"props":763,"children":764},{},[765,783],{"type":185,"tag":240,"props":766,"children":767},{},[768,770],{"type":191,"value":769},"用 GenAI：\n",{"type":185,"tag":251,"props":771,"children":772},{},[773,778],{"type":185,"tag":240,"props":774,"children":775},{},[776],{"type":191,"value":777},"列出业务能力与相应代码位置",{"type":185,"tag":240,"props":779,"children":780},{},[781],{"type":191,"value":782},"找出跨能力的共享数据库表与强耦合模块",{"type":185,"tag":240,"props":784,"children":785},{},[786,788],{"type":191,"value":787},"产出：\n",{"type":185,"tag":251,"props":789,"children":790},{},[791,796,801],{"type":185,"tag":240,"props":792,"children":793},{},[794],{"type":191,"value":795},"候选领域上下文划分",{"type":185,"tag":240,"props":797,"children":798},{},[799],{"type":191,"value":800},"优先拆分的服务列表",{"type":185,"tag":240,"props":802,"children":803},{},[804],{"type":191,"value":805},"拆分风险（共享事务、跨上下文业务规则）",{"type":185,"tag":240,"props":807,"children":808},{},[809,814],{"type":185,"tag":205,"props":810,"children":811},{},[812],{"type":191,"value":813},"云迁移或平台迁移（如上云、从自建 ESB 到 API 网关）",{"type":185,"tag":251,"props":815,"children":816},{},[817,834],{"type":185,"tag":240,"props":818,"children":819},{},[820,821],{"type":191,"value":769},{"type":185,"tag":251,"props":822,"children":823},{},[824,829],{"type":185,"tag":240,"props":825,"children":826},{},[827],{"type":191,"value":828},"盘点所有外部系统调用、消息通道、定时任务",{"type":185,"tag":240,"props":830,"children":831},{},[832],{"type":191,"value":833},"分类现有集成模式（同步调用、异步事件、批处理）",{"type":185,"tag":240,"props":835,"children":836},{},[837,838],{"type":191,"value":787},{"type":185,"tag":251,"props":839,"children":840},{},[841,846],{"type":185,"tag":240,"props":842,"children":843},{},[844],{"type":191,"value":845},"集成点清单",{"type":185,"tag":240,"props":847,"children":848},{},[849],{"type":191,"value":850},"演进式迁移路线（先“包裹”再“替换”）",{"type":185,"tag":240,"props":852,"children":853},{},[854,859],{"type":185,"tag":205,"props":855,"children":856},{},[857],{"type":191,"value":858},"性能/可靠性治理",{"type":185,"tag":251,"props":860,"children":861},{},[862,880],{"type":185,"tag":240,"props":863,"children":864},{},[865,867],{"type":191,"value":866},"用 GenAI 分析：\n",{"type":185,"tag":251,"props":868,"children":869},{},[870,875],{"type":185,"tag":240,"props":871,"children":872},{},[873],{"type":191,"value":874},"所有远程调用点、重试机制、降级策略实现",{"type":185,"tag":240,"props":876,"children":877},{},[878],{"type":191,"value":879},"事务边界与锁使用",{"type":185,"tag":240,"props":881,"children":882},{},[883,884],{"type":191,"value":787},{"type":185,"tag":251,"props":885,"children":886},{},[887,892],{"type":185,"tag":240,"props":888,"children":889},{},[890],{"type":191,"value":891},"容错架构现状图",{"type":185,"tag":240,"props":893,"children":894},{},[895],{"type":191,"value":896},"性能/可靠性改造切入点",{"type":185,"tag":240,"props":898,"children":899},{},[900,905],{"type":185,"tag":205,"props":901,"children":902},{},[903],{"type":191,"value":904},"合规与安全审计",{"type":185,"tag":251,"props":906,"children":907},{},[908,931],{"type":185,"tag":240,"props":909,"children":910},{},[911,913],{"type":191,"value":912},"用 GenAI 搜索与聚合：\n",{"type":185,"tag":251,"props":914,"children":915},{},[916,921,926],{"type":185,"tag":240,"props":917,"children":918},{},[919],{"type":191,"value":920},"密码/秘钥处理逻辑",{"type":185,"tag":240,"props":922,"children":923},{},[924],{"type":191,"value":925},"个人数据处理与脱敏逻辑",{"type":185,"tag":240,"props":927,"children":928},{},[929],{"type":191,"value":930},"审计日志记录位置",{"type":185,"tag":240,"props":932,"children":933},{},[934,935],{"type":191,"value":787},{"type":185,"tag":251,"props":936,"children":937},{},[938,943],{"type":185,"tag":240,"props":939,"children":940},{},[941],{"type":191,"value":942},"与法规（如 GDPR、数据安全要求）对齐的“现状对照表”",{"type":185,"tag":240,"props":944,"children":945},{},[946],{"type":191,"value":947},"缺口与整改优先级",{"type":185,"tag":224,"props":949,"children":951},{"id":950},"_5-实施建议",[952],{"type":191,"value":953},"5. 实施建议",{"type":185,"tag":236,"props":955,"children":956},{},[957,986,1020,1059],{"type":185,"tag":240,"props":958,"children":959},{},[960,965],{"type":185,"tag":205,"props":961,"children":962},{},[963],{"type":191,"value":964},"把 “GenAI 辅助理解” 设为默认动作",{"type":185,"tag":251,"props":966,"children":967},{},[968,981],{"type":185,"tag":240,"props":969,"children":970},{},[971,973],{"type":191,"value":972},"新接管一个遗留系统时：\n",{"type":185,"tag":251,"props":974,"children":975},{},[976],{"type":185,"tag":240,"props":977,"children":978},{},[979],{"type":191,"value":980},"第一周就搭建基本的 AI 助手（哪怕只是 IDE 插件 + 项目索引）",{"type":185,"tag":240,"props":982,"children":983},{},[984],{"type":191,"value":985},"把“问 AI”当作与“全文搜索”“读文档”同等优先的手段。",{"type":185,"tag":240,"props":987,"children":988},{},[989,994],{"type":185,"tag":205,"props":990,"children":991},{},[992],{"type":191,"value":993},"架构师主导问题视角",{"type":185,"tag":251,"props":995,"children":996},{},[997,1002],{"type":185,"tag":240,"props":998,"children":999},{},[1000],{"type":191,"value":1001},"避免只用来写代码或解释局部函数；",{"type":185,"tag":240,"props":1003,"children":1004},{},[1005,1007],{"type":191,"value":1006},"要刻意提出架构级问题，例如：\n",{"type":185,"tag":251,"props":1008,"children":1009},{},[1010,1015],{"type":185,"tag":240,"props":1011,"children":1012},{},[1013],{"type":191,"value":1014},"“从架构分层角度总结本项目的结构，并指出不一致之处。”",{"type":185,"tag":240,"props":1016,"children":1017},{},[1018],{"type":191,"value":1019},"“按领域边界帮我重新分组这些模块，给出分组依据。”",{"type":185,"tag":240,"props":1021,"children":1022},{},[1023,1028],{"type":185,"tag":205,"props":1024,"children":1025},{},[1026],{"type":191,"value":1027},"结合人工判断，避免“AI 版本的错觉式架构图”",{"type":185,"tag":251,"props":1029,"children":1030},{},[1031,1054],{"type":185,"tag":240,"props":1032,"children":1033},{},[1034,1036],{"type":191,"value":1035},"所有自动生成的：\n",{"type":185,"tag":251,"props":1037,"children":1038},{},[1039,1044,1049],{"type":185,"tag":240,"props":1040,"children":1041},{},[1042],{"type":191,"value":1043},"架构图",{"type":185,"tag":240,"props":1045,"children":1046},{},[1047],{"type":191,"value":1048},"依赖总结",{"type":185,"tag":240,"props":1050,"children":1051},{},[1052],{"type":191,"value":1053},"业务规则列表",{"type":185,"tag":240,"props":1055,"children":1056},{},[1057],{"type":191,"value":1058},"都要通过抽样验证和代码 spot check 来确认准确性，逐步修正。",{"type":185,"tag":240,"props":1060,"children":1061},{},[1062,1067],{"type":185,"tag":205,"props":1063,"children":1064},{},[1065],{"type":191,"value":1066},"注意安全与合规",{"type":185,"tag":251,"props":1068,"children":1069},{},[1070],{"type":185,"tag":240,"props":1071,"children":1072},{},[1073,1075],{"type":191,"value":1074},"对含敏感代码的项目：\n",{"type":185,"tag":251,"props":1076,"children":1077},{},[1078,1083],{"type":185,"tag":240,"props":1079,"children":1080},{},[1081],{"type":191,"value":1082},"优先选择本地部署或企业版 LLM 方案",{"type":185,"tag":240,"props":1084,"children":1085},{},[1086],{"type":191,"value":1087},"在组织层面明确：哪些仓库可以、哪些不可以接入外部云端 AI 工具。",{"title":178,"searchDepth":1089,"depth":1089,"links":1090},2,[1091,1092],{"id":188,"depth":1089,"text":192},{"id":219,"depth":1089,"text":222,"children":1093},[1094,1096,1097,1098,1099],{"id":226,"depth":1095,"text":229},3,{"id":343,"depth":1095,"text":346},{"id":531,"depth":1095,"text":534},{"id":742,"depth":1095,"text":745},{"id":950,"depth":1095,"text":953},"markdown","content:6.maps:_programming:dx:genai-for-legacy-codebases.md","content","6.maps/_programming/dx/genai-for-legacy-codebases.md","6.maps/_programming/dx/genai-for-legacy-codebases","md",[1107,1111],{"_path":1108,"title":1109,"description":1110},"/maps/_programming/dx/genai-for-forward-engineering","GenAI for Forward Engineering","GenAI用于前向工程是一种新兴技术，通过AI生成的遗留代码库描述来实现系统现代化。它引入了一个显式步骤，专注于遗留代码的功能（其规范），同时刻意隐藏当前实现方式。这与规范驱动开发相关，但专门应用于遗留系统现代化。",{"_path":1112,"title":1113,"description":1114},"/maps/_programming/functional","函数式","函数式编程是一种编程范式，它将计算机运算视为数学函数的计算，并且避免使用程序状态以及易变对象。",1771690611135]