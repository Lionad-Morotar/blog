xperience，DX）是指开发者在使用产品、工具、框架等过程中的感受和体验。它是用户体验（User Experience，UX）的一个子集，专注于开发者的需求和体验。",{"type":182,"children":183,"toc":406},"root",[184,193,217,223,244,250,264,270,304,309,392,397],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"domain",[190],{"type":191,"value":192},"text","Domain",{"type":185,"tag":194,"props":195,"children":196},"ul",{},[197,208],{"type":185,"tag":198,"props":199,"children":200},"li",{},[201],{"type":185,"tag":202,"props":203,"children":205},"a",{"href":204},"/maps/_programming/dx/genai-for-legacy-codebases",[206],{"type":191,"value":207},"GenAI for legacy codebases",{"type":185,"tag":198,"props":209,"children":210},{},[211],{"type":185,"tag":202,"props":212,"children":214},{"href":213},"/maps/_programming/dx/genai-for-forward-engineering",[215],{"type":191,"value":216},"GenAI for forward engineering",{"type":185,"tag":186,"props":218,"children":220},{"id":219},"cross-domain",[221],{"type":191,"value":222},"Cross Domain",{"type":185,"tag":194,"props":224,"children":225},{},[226,235],{"type":185,"tag":198,"props":227,"children":228},{},[229],{"type":185,"tag":202,"props":230,"children":232},{"href":231},"/maps/_ai/prompt/team-based-instructions",[233],{"type":191,"value":234},"Team based Instructions",{"type":185,"tag":198,"props":236,"children":237},{},[238],{"type":185,"tag":202,"props":239,"children":241},{"href":240},"/maps/_ai/vibe/agents-md",[242],{"type":191,"value":243},"agents.md",{"type":185,"tag":186,"props":245,"children":247},{"id":246},"gists",[248],{"type":191,"value":249},"Gists",{"type":185,"tag":251,"props":252,"children":254},"h4",{"id":253},"developer-exception-engineering",[255,262],{"type":185,"tag":256,"props":257,"children":261},"link",{"type":258,"to":259,"source":260},"h5","https://mgear-file.oss-cn-shanghai.aliyuncs.com/Developer%20Exception%20Engineering.html","https://www.swyx.io/developer-exception/",[],{"type":191,"value":263},"《Developer Exception Engineering》",{"type":185,"tag":265,"props":266,"children":267},"p",{},[268],{"type":191,"value":269},"SWYX 认为社区在过去讨论 Developer Experience 的角度稍稍狭隘了。",{"type":185,"tag":194,"props":271,"children":272},{},[273,284,294],{"type":185,"tag":198,"props":274,"children":275},{},[276,282],{"type":185,"tag":277,"props":278,"children":279},"strong",{},[280],{"type":191,"value":281},"能效提升",{"type":191,"value":283},"：提高代码效率、自动化、代码生成器、开箱即用。..",{"type":185,"tag":198,"props":285,"children":286},{},[287,292],{"type":185,"tag":277,"props":288,"children":289},{},[290],{"type":191,"value":291},"富文档",{"type":191,"value":293},"：起步文档、代码示例、可交互示例、API 清单、最佳实践、可搜索。..",{"type":185,"tag":198,"props":295,"children":296},{},[297,302],{"type":185,"tag":277,"props":298,"children":299},{},[300],{"type":191,"value":301},"开发者工具",{"type":191,"value":303},"：脚手架、编辑器插件、代码片段、代码展示、版本控制。..",{"type":185,"tag":265,"props":305,"children":306},{},[307],{"type":191,"value":308},"这些东西对开发者来说时“友好的”，但是也很“简单”。也许是时候主动跳出站在开发者的角度思考 DX 的舒适区，开始转向终端用户。也许可以尝试保证这些东西：",{"type":185,"tag":194,"props":310,"children":311},{},[312,322,332,342,352,362,372,382],{"type":185,"tag":198,"props":313,"children":314},{},[315,320],{"type":185,"tag":277,"props":316,"children":317},{},[318],{"type":191,"value":319},"服务可用",{"type":191,"value":321},"：产品数据页面和报错页面会说谎吗？...",{"type":185,"tag":198,"props":323,"children":324},{},[325,330],{"type":185,"tag":277,"props":326,"children":327},{},[328],{"type":191,"value":329},"反馈有效",{"type":191,"value":331},"：是否及时有效的解决了客户反馈？...",{"type":185,"tag":198,"props":333,"children":334},{},[335,340],{"type":185,"tag":277,"props":336,"children":337},{},[338],{"type":191,"value":339},"功能完整",{"type":191,"value":341},"：是否发布了不完整甚至需要返工的功能？...",{"type":185,"tag":198,"props":343,"children":344},{},[345,350],{"type":185,"tag":277,"props":346,"children":347},{},[348],{"type":191,"value":349},"产品路线完整",{"type":191,"value":351},"：对产品路线的规划是否清晰合理？...",{"type":185,"tag":198,"props":353,"children":354},{},[355,360],{"type":185,"tag":277,"props":356,"children":357},{},[358],{"type":191,"value":359},"计价合理",{"type":191,"value":361},"：用户会对你的报价产生疑惑么，它是否是可计算和比较的？...",{"type":185,"tag":198,"props":363,"children":364},{},[365,370],{"type":185,"tag":277,"props":366,"children":367},{},[368],{"type":191,"value":369},"兼容性",{"type":191,"value":371},"：废弃的 API 是否合理？...",{"type":185,"tag":198,"props":373,"children":374},{},[375,380],{"type":185,"tag":277,"props":376,"children":377},{},[378],{"type":191,"value":379},"报错优雅",{"type":191,"value":381},"：出错后是否可调试？...",{"type":185,"tag":198,"props":383,"children":384},{},[385,390],{"type":185,"tag":277,"props":386,"children":387},{},[388],{"type":191,"value":389},"访问控制",{"type":191,"value":391},"：客户有审计日志或访问控制的权力吗？...",{"type":185,"tag":265,"props":393,"children":394},{},[395],{"type":191,"value":396},"正如面对漏水的桶下雨解决不了问题，如果只是一直站在开发者的角度思考 DX，对解决品牌满意度下降、客户流失这些“异常”没有办法带来帮助。此外，根据康威定律，一个不合理的 DX 会反映出公司的组织架构的不合理之处，这值得引起注意。",{"type":185,"tag":265,"props":398,"children":399},{},[400],{"type":185,"tag":401,"props":402,"children":405},"img",{"alt":403,"src":404},"The Experience of Developer | https://www.swyx.io/developer-exception/","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20210917170405.png",[],{"title":178,"searchDepth":407,"depth":407,"links":408},2,[409,410,411],{"id":188,"depth":407,"text":192},{"id":219,"depth":407,"text":222},{"id":246,"depth":407,"text":249},"markdown","content:6.maps:_programming:dx.md","content","6.maps/_programming/dx.md","6.maps/_programming/dx","md",[419,423],{"_path":420,"title":421,"description":422},"/maps/_programming/debug","Debug","系统化 Bug 修复方法",{"_path":213,"title":424,"description":425},"GenAI for Forward Engineering","GenAI用于前向工程是一种新兴技术，通过AI生成的遗留代码库描述来实现系统现代化。它引入了一个显式步骤，专注于遗留代码的功能（其规范），同时刻意隐藏当前实现方式。这与规范驱动开发相关，但专门应用于遗留系统现代化。",1771695775761]