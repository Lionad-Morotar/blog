perience，UX）的一个子集，专注于开发者的需求和体验。",{"type":179,"children":180,"toc":403},"root",[181,190,214,220,241,247,261,267,301,306,389,394],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"domain",[187],{"type":188,"value":189},"text","Domain",{"type":182,"tag":191,"props":192,"children":193},"ul",{},[194,205],{"type":182,"tag":195,"props":196,"children":197},"li",{},[198],{"type":182,"tag":199,"props":200,"children":202},"a",{"href":201},"/maps/_programming/dx/genai-for-legacy-codebases",[203],{"type":188,"value":204},"GenAI for legacy codebases",{"type":182,"tag":195,"props":206,"children":207},{},[208],{"type":182,"tag":199,"props":209,"children":211},{"href":210},"/maps/_programming/dx/genai-for-forward-engineering",[212],{"type":188,"value":213},"GenAI for forward engineering",{"type":182,"tag":183,"props":215,"children":217},{"id":216},"cross-domain",[218],{"type":188,"value":219},"Cross Domain",{"type":182,"tag":191,"props":221,"children":222},{},[223,232],{"type":182,"tag":195,"props":224,"children":225},{},[226],{"type":182,"tag":199,"props":227,"children":229},{"href":228},"/maps/_ai/prompt/team-based-instructions",[230],{"type":188,"value":231},"Team based Instructions",{"type":182,"tag":195,"props":233,"children":234},{},[235],{"type":182,"tag":199,"props":236,"children":238},{"href":237},"/maps/_ai/vibe/agents-md",[239],{"type":188,"value":240},"agents.md",{"type":182,"tag":183,"props":242,"children":244},{"id":243},"gists",[245],{"type":188,"value":246},"Gists",{"type":182,"tag":248,"props":249,"children":251},"h4",{"id":250},"developer-exception-engineering",[252,259],{"type":182,"tag":253,"props":254,"children":258},"link",{"type":255,"to":256,"source":257},"h5","https://mgear-file.oss-cn-shanghai.aliyuncs.com/Developer%20Exception%20Engineering.html","https://www.swyx.io/developer-exception/",[],{"type":188,"value":260},"《Developer Exception Engineering》",{"type":182,"tag":262,"props":263,"children":264},"p",{},[265],{"type":188,"value":266},"SWYX 认为社区在过去讨论 Developer Experience 的角度稍稍狭隘了。",{"type":182,"tag":191,"props":268,"children":269},{},[270,281,291],{"type":182,"tag":195,"props":271,"children":272},{},[273,279],{"type":182,"tag":274,"props":275,"children":276},"strong",{},[277],{"type":188,"value":278},"能效提升",{"type":188,"value":280},"：提高代码效率、自动化、代码生成器、开箱即用。..",{"type":182,"tag":195,"props":282,"children":283},{},[284,289],{"type":182,"tag":274,"props":285,"children":286},{},[287],{"type":188,"value":288},"富文档",{"type":188,"value":290},"：起步文档、代码示例、可交互示例、API 清单、最佳实践、可搜索。..",{"type":182,"tag":195,"props":292,"children":293},{},[294,299],{"type":182,"tag":274,"props":295,"children":296},{},[297],{"type":188,"value":298},"开发者工具",{"type":188,"value":300},"：脚手架、编辑器插件、代码片段、代码展示、版本控制。..",{"type":182,"tag":262,"props":302,"children":303},{},[304],{"type":188,"value":305},"这些东西对开发者来说时“友好的”，但是也很“简单”。也许是时候主动跳出站在开发者的角度思考 DX 的舒适区，开始转向终端用户。也许可以尝试保证这些东西：",{"type":182,"tag":191,"props":307,"children":308},{},[309,319,329,339,349,359,369,379],{"type":182,"tag":195,"props":310,"children":311},{},[312,317],{"type":182,"tag":274,"props":313,"children":314},{},[315],{"type":188,"value":316},"服务可用",{"type":188,"value":318},"：产品数据页面和报错页面会说谎吗？...",{"type":182,"tag":195,"props":320,"children":321},{},[322,327],{"type":182,"tag":274,"props":323,"children":324},{},[325],{"type":188,"value":326},"反馈有效",{"type":188,"value":328},"：是否及时有效的解决了客户反馈？...",{"type":182,"tag":195,"props":330,"children":331},{},[332,337],{"type":182,"tag":274,"props":333,"children":334},{},[335],{"type":188,"value":336},"功能完整",{"type":188,"value":338},"：是否发布了不完整甚至需要返工的功能？...",{"type":182,"tag":195,"props":340,"children":341},{},[342,347],{"type":182,"tag":274,"props":343,"children":344},{},[345],{"type":188,"value":346},"产品路线完整",{"type":188,"value":348},"：对产品路线的规划是否清晰合理？...",{"type":182,"tag":195,"props":350,"children":351},{},[352,357],{"type":182,"tag":274,"props":353,"children":354},{},[355],{"type":188,"value":356},"计价合理",{"type":188,"value":358},"：用户会对你的报价产生疑惑么，它是否是可计算和比较的？...",{"type":182,"tag":195,"props":360,"children":361},{},[362,367],{"type":182,"tag":274,"props":363,"children":364},{},[365],{"type":188,"value":366},"兼容性",{"type":188,"value":368},"：废弃的 API 是否合理？...",{"type":182,"tag":195,"props":370,"children":371},{},[372,377],{"type":182,"tag":274,"props":373,"children":374},{},[375],{"type":188,"value":376},"报错优雅",{"type":188,"value":378},"：出错后是否可调试？...",{"type":182,"tag":195,"props":380,"children":381},{},[382,387],{"type":182,"tag":274,"props":383,"children":384},{},[385],{"type":188,"value":386},"访问控制",{"type":188,"value":388},"：客户有审计日志或访问控制的权力吗？...",{"type":182,"tag":262,"props":390,"children":391},{},[392],{"type":188,"value":393},"正如面对漏水的桶下雨解决不了问题，如果只是一直站在开发者的角度思考 DX，对解决品牌满意度下降、客户流失这些“异常”没有办法带来帮助。此外，根据康威定律，一个不合理的 DX 会反映出公司的组织架构的不合理之处，这值得引起注意。",{"type":182,"tag":262,"props":395,"children":396},{},[397],{"type":182,"tag":398,"props":399,"children":402},"img",{"alt":400,"src":401},"The Experience of Developer | https://www.swyx.io/developer-exception/","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20210917170405.png",[],{"title":175,"searchDepth":404,"depth":404,"links":405},2,[406,407,408],{"id":185,"depth":404,"text":189},{"id":216,"depth":404,"text":219},{"id":243,"depth":404,"text":246},"markdown","content:6.maps:_programming:dx.md","content","6.maps/_programming/dx.md","6.maps/_programming/dx","md",[416,420],{"_path":417,"title":418,"description":419},"/maps/_products/zapier","Zapier","Connectors for APP Ocean",{"_path":210,"title":421,"description":422},"GenAI for Forward Engineering","GenAI用于前向工程是一种新兴技术，通过AI生成的遗留代码库描述来实现系统现代化。它引入了一个显式步骤，专注于遗留代码的功能（其规范），同时刻意隐藏当前实现方式。这与规范驱动开发相关，但专门应用于遗留系统现代化。",1771264623962]