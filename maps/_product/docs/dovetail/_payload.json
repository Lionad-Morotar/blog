[{"data":1,"prerenderedAt":601},["ShallowReactive",2],{"navigation":3,"/maps/_product/docs/dovetail":173,"/maps/_product/docs/dovetail-surround":593},[4,35,92,98,125,134,158,164],{"title":5,"_path":6,"children":7},"心流思绪 / Heart Flows","/flows",[8,11,14,17,20,23,26,29,32],{"title":9,"_path":10},"📕 狮子的书单推荐","/flows/books",{"title":12,"_path":13},"🚝 四十二篇系列","/flows/forty-two",{"title":15,"_path":16},"🌃 长夜梦","/flows/long-night-dream",{"title":18,"_path":19},"🌌 万物联结与幸福感","/flows/everything",{"title":21,"_path":22},"⌛ 偷取时间","/flows/stealing-time-from-god",{"title":24,"_path":25},"🌆 表达和孤独","/flows/expression-and-loneliness",{"title":27,"_path":28},"🌧️ 我的腼腆","/flows/shy",{"title":30,"_path":31},"🥛 新工作，喝新饮料","/flows/drinking-while-thinking",{"title":33,"_path":34},"📝 心流归档","/flows/archive",{"title":36,"_path":37,"children":38},"技术博客 / Coder","/articles",[39,41,44,47,50,53,56,59,62,65,68,71,74,77,80,83,86,89],{"title":40,"_path":37},"🦁 欢迎",{"title":42,"_path":43},"📦 一个简单有效的端口命名策略：","/articles/simple-naming-method",{"title":45,"_path":46},"🌪️ Tailwind v4 如何兼容预处理器","/articles/tailwind4-with-sass",{"title":48,"_path":49},"🥞 在 tailwind 中使用现代化 CSS Layers","/articles/tailwind-sass-and-css-layer",{"title":51,"_path":52},"💻 本地部署 Qwen 翻译网页","/articles/local-translator",{"title":54,"_path":55},"🧊 模板解析器轻考古","/articles/micro-templating",{"title":57,"_path":58},"Ⓜ️ Mini CSS Parser","/articles/mini-css-parser",{"title":60,"_path":61},"🚩 向AI咨询前端问题","/articles/use-gpt-learn-complex-frontend",{"title":63,"_path":64},"⛸️ 怎样定制复杂组件的自定义滚动条？","/articles/use-scrollbars",{"title":66,"_path":67},"⚖️ 统一多组件库的层叠顺序","/articles/zindex-manager",{"title":69,"_path":70},"🕷️ 滑动验证码破解思路","/articles/crack-the-slider",{"title":72,"_path":73},"🌟 探秘 CSS 光影效果","/articles/css-light-travel",{"title":75,"_path":76},"🍲 设计模式与 JS 魔法锅","/articles/design-patterns-and-js-magic-pot",{"title":78,"_path":79},"🌐 Anysort：灵活、优雅的多属性排序","/articles/anysort-2th",{"title":81,"_path":82},"💫 CSS 幻术 | 抗锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"body":181,"_type":587,"_id":588,"_source":589,"_file":590,"_stem":591,"_extension":592},"/maps/_product/docs/dovetail","docs",false,true,"","Dovetail","定性研究证据链与洞察管理：将访谈与主题化洞察集中管理、可追溯地关联至产品假设与ROI，强化定性数据在决策中的作用。",{"type":182,"children":183,"toc":572},"root",[184,193,199,204,210,216,236,241,264,269,275,293,299,327,332,338,351,356,369,374,379,392,397,410,415,423,428,446,451,456,474,480,503,508,531,536,541,554,559],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"brief",[190],{"type":191,"value":192},"text","Brief",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"Dovetail 平台解决管理碎片化定性研究数据的长期挑战。它为用户访谈、转写与洞察提供集中式存储库，将原始数据转化为可结构化、可分析的资产。我们发现在产品发现工作流中它极具价值，尤其用于建立证据链：把客户引述与归纳主题直接关联到产品假设与ROI估算。由此，Dovetail 强化了定性数据在产品决策中的作用。",{"type":185,"tag":194,"props":200,"children":201},{},[202],{"type":191,"value":203},"来源：技术雷达",{"type":185,"tag":186,"props":205,"children":207},{"id":206},"details",[208],{"type":191,"value":209},"Details",{"type":185,"tag":211,"props":212,"children":214},"h3",{"id":213},"背景与现状",[215],{"type":191,"value":213},{"type":185,"tag":217,"props":218,"children":219},"ul",{},[220,226,231],{"type":185,"tag":221,"props":222,"children":223},"li",{},[224],{"type":191,"value":225},"定性研究产出（录音/视频、转写、便签、主题、结论）常分散在多工具中，难以复用与追溯。",{"type":185,"tag":221,"props":227,"children":228},{},[229],{"type":191,"value":230},"产品探索需要“证据到决策”的可审计链路，以支撑假设验证、ROI 估算与对外说明。",{"type":185,"tag":221,"props":232,"children":233},{},[234],{"type":191,"value":235},"传统做法依赖手工整理（文档/表格/知识库），在规模化、跨团队协作时易失真和丢失上下文。",{"type":185,"tag":211,"props":237,"children":239},{"id":238},"问题与风险",[240],{"type":191,"value":238},{"type":185,"tag":217,"props":242,"children":243},{},[244,249,254,259],{"type":185,"tag":221,"props":245,"children":246},{},[247],{"type":191,"value":248},"证据不可追溯：难以从结论回溯到原始引述与访谈上下文，影响可信度与复核效率。",{"type":185,"tag":221,"props":250,"children":251},{},[252],{"type":191,"value":253},"洞察难结构化：主题、编码口径不统一，复用与查询成本高。",{"type":185,"tag":221,"props":255,"children":256},{},[257],{"type":191,"value":258},"决策“黑箱化”：缺少证据链支撑时，假设与ROI估算说服力不足。",{"type":185,"tag":221,"props":260,"children":261},{},[262],{"type":191,"value":263},"安全与合规：涉及个人信息与敏感业务线索，权限与脱敏若处理不善，风险累积。",{"type":185,"tag":211,"props":265,"children":267},{"id":266},"模式与原理",[268],{"type":191,"value":266},{"type":185,"tag":270,"props":271,"children":273},"h4",{"id":272},"核心抽象与角色",[274],{"type":191,"value":272},{"type":185,"tag":217,"props":276,"children":277},{},[278,283,288],{"type":185,"tag":221,"props":279,"children":280},{},[281],{"type":191,"value":282},"证据与洞察分层：原始素材（录音/转写）→ 编码/标签 → 主题 → 洞察 → 决策/假设。",{"type":185,"tag":221,"props":284,"children":285},{},[286],{"type":191,"value":287},"关系可追溯：客户引述、归纳主题与产品假设、ROI 估算形成链式关联。",{"type":185,"tag":221,"props":289,"children":290},{},[291],{"type":191,"value":292},"角色协作：研究者负责采集与编码，产品/设计负责假设与机会评估，工程/数据协同验证与落地。",{"type":185,"tag":270,"props":294,"children":296},{"id":295},"工作机制典型流水线",[297],{"type":191,"value":298},"工作机制（典型流水线）",{"type":185,"tag":217,"props":300,"children":301},{},[302,307,312,317,322],{"type":185,"tag":221,"props":303,"children":304},{},[305],{"type":191,"value":306},"采集与转写：导入访谈媒体并自动/半自动转写。",{"type":185,"tag":221,"props":308,"children":309},{},[310],{"type":191,"value":311},"编码与主题化：基于标签/代码本统一抽象典型需求、痛点与动机。",{"type":185,"tag":221,"props":313,"children":314},{},[315],{"type":191,"value":316},"洞察沉淀：将主题整合为结论项，标注证据来源与置信度。",{"type":185,"tag":221,"props":318,"children":319},{},[320],{"type":191,"value":321},"证据链绑定：洞察关联到具体产品假设、待办、ROI 估算与评审记录。",{"type":185,"tag":221,"props":323,"children":324},{},[325],{"type":191,"value":326},"查询与复核：按主题、用户画像、功能域等维度检索，快速回溯到原话片段。",{"type":185,"tag":211,"props":328,"children":330},{"id":329},"对比与演进",[331],{"type":191,"value":329},{"type":185,"tag":270,"props":333,"children":335},{"id":334},"旧做法-vs-新模式",[336],{"type":191,"value":337},"旧做法 vs 新模式",{"type":185,"tag":217,"props":339,"children":340},{},[341,346],{"type":185,"tag":221,"props":342,"children":343},{},[344],{"type":191,"value":345},"旧：分散文档/表格/笔记工具，弱结构、弱查询、弱追溯。",{"type":185,"tag":221,"props":347,"children":348},{},[349],{"type":191,"value":350},"新：集中仓库与统一编码体系，支持纵深检索与端到端证据链。",{"type":185,"tag":270,"props":352,"children":354},{"id":353},"演进方向",[355],{"type":191,"value":353},{"type":185,"tag":217,"props":357,"children":358},{},[359,364],{"type":185,"tag":221,"props":360,"children":361},{},[362],{"type":191,"value":363},"与交付侧集成：将洞察链接至需求管理与路线图，形成从发现到交付的闭环。",{"type":185,"tag":221,"props":365,"children":366},{},[367],{"type":191,"value":368},"与定量互证：把定性主题映射到埋点/实验指标，构建“定性-定量”相互印证的证据网。",{"type":185,"tag":211,"props":370,"children":372},{"id":371},"系统影响",[373],{"type":191,"value":371},{"type":185,"tag":270,"props":375,"children":377},{"id":376},"架构与数据治理",[378],{"type":191,"value":376},{"type":185,"tag":217,"props":380,"children":381},{},[382,387],{"type":185,"tag":221,"props":383,"children":384},{},[385],{"type":191,"value":386},"引入统一的“研究知识层”，需要稳定的模式与标签治理（命名、合并、废弃策略）。",{"type":185,"tag":221,"props":388,"children":389},{},[390],{"type":191,"value":391},"对存储与权限模型提出更精细的需求（项目隔离、字段级脱敏、外部共享控制）。",{"type":185,"tag":270,"props":393,"children":395},{"id":394},"工程效率与协作",[396],{"type":191,"value":394},{"type":185,"tag":217,"props":398,"children":399},{},[400,405],{"type":185,"tag":221,"props":401,"children":402},{},[403],{"type":191,"value":404},"缩短从素材到可用洞察的周期，减少重复访谈与决策拉扯。",{"type":185,"tag":221,"props":406,"children":407},{},[408],{"type":191,"value":409},"决策透明度提升，有利于评审与跨部门对齐。",{"type":185,"tag":270,"props":411,"children":413},{"id":412},"安全与合规",[414],{"type":191,"value":412},{"type":185,"tag":217,"props":416,"children":417},{},[418],{"type":185,"tag":221,"props":419,"children":420},{},[421],{"type":191,"value":422},"必须明确数据驻留、PII/敏感信息处理与访问审计；对外分享需模板化脱敏。",{"type":185,"tag":211,"props":424,"children":426},{"id":425},"适用边界",[427],{"type":191,"value":425},{"type":185,"tag":217,"props":429,"children":430},{},[431,436,441],{"type":185,"tag":221,"props":432,"children":433},{},[434],{"type":191,"value":435},"更适合：中大型产品线、持续性用户研究、需为路线图与ROI提供证据链的团队。",{"type":185,"tag":221,"props":437,"children":438},{},[439],{"type":191,"value":440},"谨慎使用：纯定量驱动、需求简单的小团队；或数据出境/本地化要求极严、难以合规时。",{"type":185,"tag":221,"props":442,"children":443},{},[444],{"type":191,"value":445},"不适用：仅一次性调研、无持续沉淀需求的场景。",{"type":185,"tag":211,"props":447,"children":449},{"id":448},"落地建议",[450],{"type":191,"value":448},{"type":185,"tag":270,"props":452,"children":454},{"id":453},"前置条件",[455],{"type":191,"value":453},{"type":185,"tag":217,"props":457,"children":458},{},[459,464,469],{"type":185,"tag":221,"props":460,"children":461},{},[462],{"type":191,"value":463},"明确研究工作流与“从证据到假设/ROI”的产出模板。",{"type":185,"tag":221,"props":465,"children":466},{},[467],{"type":191,"value":468},"建立最小可用代码本（标签体系），定义命名规范与治理机制。",{"type":185,"tag":221,"props":470,"children":471},{},[472],{"type":191,"value":473},"明确敏感数据处理策略（脱敏、留存周期、访问控制）。",{"type":185,"tag":270,"props":475,"children":477},{"id":476},"试点路径契合-trial-阶段",[478],{"type":191,"value":479},"试点路径（契合 Trial 阶段）",{"type":185,"tag":217,"props":481,"children":482},{},[483,488,493,498],{"type":185,"tag":221,"props":484,"children":485},{},[486],{"type":191,"value":487},"选择1条产品线、2–3个研究项目作为试点；限定范围与成功标准。",{"type":185,"tag":221,"props":489,"children":490},{},[491],{"type":191,"value":492},"打通最小闭环：访谈导入→转写→编码→主题→洞察→链接到需求/假设与ROI记录。",{"type":185,"tag":221,"props":494,"children":495},{},[496],{"type":191,"value":497},"与现有工具集成：将洞察链接到需求系统（如工单/路线图），用双向链接保留追溯。",{"type":185,"tag":221,"props":499,"children":500},{},[501],{"type":191,"value":502},"评估指标：可复用洞察比例、回溯平均用时、决策通过率、重复研究减少率。",{"type":185,"tag":270,"props":504,"children":506},{"id":505},"风险与对策",[507],{"type":191,"value":505},{"type":185,"tag":217,"props":509,"children":510},{},[511,516,521,526],{"type":185,"tag":221,"props":512,"children":513},{},[514],{"type":191,"value":515},"标签漂移与口径不一：设立编码评审与定期清理（合并/废弃），提供示例库。",{"type":185,"tag":221,"props":517,"children":518},{},[519],{"type":191,"value":520},"自动转写误差：设置信心阈值与抽样人工校对；对关键证据片段强制复核。",{"type":185,"tag":221,"props":522,"children":523},{},[524],{"type":191,"value":525},"成本与供给侧约束：控制席位与项目并发量，分层授权与阶段性归档。",{"type":185,"tag":221,"props":527,"children":528},{},[529],{"type":191,"value":530},"供应商锁定：导出策略（原文与标注）、保留关键结构化字段的中性格式。",{"type":185,"tag":211,"props":532,"children":534},{"id":533},"实施要点",[535],{"type":191,"value":533},{"type":185,"tag":270,"props":537,"children":539},{"id":538},"与产品决策的耦合",[540],{"type":191,"value":538},{"type":185,"tag":217,"props":542,"children":543},{},[544,549],{"type":185,"tag":221,"props":545,"children":546},{},[547],{"type":191,"value":548},"在评审模板中要求“洞察-引述-主题-假设-ROI”的链路字段为必填。",{"type":185,"tag":221,"props":550,"children":551},{},[552],{"type":191,"value":553},"为关键路线图项配置证据看板，确保高优先级事项可一键追溯到原话。",{"type":185,"tag":270,"props":555,"children":557},{"id":556},"与度量与质量的结合",[558],{"type":191,"value":556},{"type":185,"tag":217,"props":560,"children":561},{},[562,567],{"type":185,"tag":221,"props":563,"children":564},{},[565],{"type":191,"value":566},"为洞察设置信任度与样本覆盖度标记；将“定性洞察被复用次数”纳入研究资产指标。",{"type":185,"tag":221,"props":568,"children":569},{},[570],{"type":191,"value":571},"将负向证据（与假设相反的引述）同样记录，避免“只收集支持证据”的偏差。",{"title":178,"searchDepth":573,"depth":573,"links":574},2,[575,576],{"id":188,"depth":573,"text":192},{"id":206,"depth":573,"text":209,"children":577},[578,580,581,582,583,584,585,586],{"id":213,"depth":579,"text":213},3,{"id":238,"depth":579,"text":238},{"id":266,"depth":579,"text":266},{"id":329,"depth":579,"text":329},{"id":371,"depth":579,"text":371},{"id":425,"depth":579,"text":425},{"id":448,"depth":579,"text":448},{"id":533,"depth":579,"text":533},"markdown","content:6.maps:_product:docs:dovetail.md","content","6.maps/_product/docs/dovetail.md","6.maps/_product/docs/dovetail","md",[594,597],{"_path":595,"title":596,"description":178},"/maps/_policy/policy","政策",{"_path":598,"title":599,"description":600},"/maps/_product/gamification","游戏化","游戏化是将游戏元素及游戏设计技术用于非游戏领域的设计",1771696727089]