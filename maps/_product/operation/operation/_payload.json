se,true,"","运营","在产品全生命周期提供支持。","content/6.maps/_product/operation.md",{"type":183,"children":184,"toc":730},"root",[185,193,200,206,211,218,223,228,703,709,714,720,725],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"数据",[191],{"type":192,"value":189},"text",{"type":186,"tag":194,"props":195,"children":197},"h4",{"id":196},"nps-是什么",[198],{"type":192,"value":199},"NPS 是什么？",{"type":186,"tag":201,"props":202,"children":203},"p",{},[204],{"type":192,"value":205},"NPS（Net Promoter Score） 是衡量客户忠诚度的关键指标，由贝恩咨询公司 Fred Reichheld 于 2003 年提出。其核心是通过一个问题\"你会推荐我们的产品/服务给朋友吗？\"来衡量客户对产品的满意度，并将结果分为推荐者（9 ~ 10 分）、中立者（7 ~ 8 分）、批评者（0 ~ 6 分）三类，由推荐者减去批评者再除以有效问卷数量得到 NPS 值。一般来说，NPS 60+ 为优秀，少数公司能做到在某次更新后达到 80+ 的高 NPS 值。",{"type":186,"tag":201,"props":207,"children":208},{},[209],{"type":192,"value":210},"相比 CSAT（Customer Satisfaction） 和 CES（Customer Effort Score），NPS 更能反映用户对产品的忠诚度，但他也有自身的局限性，如无法解释具体痛点、只能反应品牌总体满意度等。所以一般需要都流程上结合多种数据来评估分析，如，对于初创企业，NPS 可快速验证市场接受度；对于成熟企业，则是优化用户忠诚度的战略工具。NPS 的成功取决于数据驱动的行动闭环，绝非单一的数字追求。",{"type":186,"tag":212,"props":213,"children":215},"mermaid",{"size":214},"md",[216],{"type":192,"value":217},"\ngraph TD\n    A[收集用户评分数据] --> B{评分范围}\n    B -->|9-10 分| C[**推荐者 Promoters**]\n    B -->|7-8 分| D[**被动者 Passives**]\n    B -->|0-6 分| E[**贬损者 Detractors**]\n    C --> F[计算推荐者比例]\n    E --> G[计算贬损者比例]\n    F --> H[NPS = 推荐者比例 - 贬损者比例]\n    G --> H\n    H --> I[结果乘以 100]\n    I --> J[最终 NPS 值]\n",{"type":186,"tag":187,"props":219,"children":221},{"id":220},"广告",[222],{"type":192,"value":220},{"type":186,"tag":194,"props":224,"children":226},{"id":225},"广告投放策略",[227],{"type":192,"value":225},{"type":186,"tag":229,"props":230,"children":231},"table",{},[232,271],{"type":186,"tag":233,"props":234,"children":235},"thead",{},[236],{"type":186,"tag":237,"props":238,"children":239},"tr",{},[240,246,251,256,261,266],{"type":186,"tag":241,"props":242,"children":243},"th",{},[244],{"type":192,"value":245},"模型",{"type":186,"tag":241,"props":247,"children":2