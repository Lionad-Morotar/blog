],{"type":192,"value":552},"零风险",{"type":186,"tag":279,"props":554,"children":555},{},[556],{"type":192,"value":557},"客单价提升",{"type":186,"tag":279,"props":559,"children":560},{},[561],{"type":192,"value":562},"淘宝客（佣金比例 20%）",{"type":186,"tag":237,"props":564,"children":565},{},[566,574,579,584,588,593],{"type":186,"tag":279,"props":567,"children":568},{},[569],{"type":186,"tag":283,"props":570,"children":571},{},[572],{"type":192,"value":573},"PPC(pay per customer)",{"type":186,"tag":279,"props":575,"children":576},{},[577],{"type":192,"value":578},"每潜在客户",{"type":186,"tag":279,"props":580,"children":581},{},[582],{"type":192,"value":583},"B2B 营销期",{"type":186,"tag":279,"props":585,"children":586},{},[587],{"type":192,"value":374},{"type":186,"tag":279,"props":589,"children":590},{},[591],{"type":192,"value":592},"线索质量筛选",{"type":186,"tag":279,"props":594,"children":595},{},[596],{"type":192,"value":597},"Salesforce 获客（100 元/条）",{"type":186,"tag":237,"props":599,"children":600},{},[601,609,614,619,623,628],{"type":186,"tag":279,"props":602,"children":603},{},[604],{"type":186,"tag":283,"props":605,"children":606},{},[607],{"type":192,"value":608},"CPE(cost per engagement)",{"type":186,"tag":279,"props":610,"children":611},{},[612],{"type":192,"value":613},"深度互动",{"type":186,"tag":279,"props":615,"children":616},{},[617],{"type":192,"value":618},"社交互动期",{"type":186,"tag":279,"props":620,"children":621},{},[622],{"type":192,"value":374},{"type":186,"tag":279,"props":624,"children":625},{},[626],{"type":192,"value":627},"社交平台互动指标",{"type":186,"tag":279,"props":629,"children":630},{},[631],{"type":192,"value":632},"抖音挑战赛（0.5 元/次）",{"type":186,"tag":237,"props":634,"children":635},{},[636,644,649,654,658,663],{"type":186,"tag":279,"props":637,"children":638},{},[639],{"type":186,"tag":283,"props":640,"children":641},{},[642],{"type":192,"value":643},"dCPM",{"type":186,"tag":279,"props":645,"children":646},{},[647],{"type":192,"value":648},"动态 CPM",{"type":186,"tag":279,"props":650,"children":651},{},[652],{"type":192,"value":653},"实时竞价期",{"type":186,"tag":279,"props":655,"children":656},{},[657],{"type":192,"value":410},{"type":186,"tag":279,"props":659,"children":660},{},[661],{"type":192,"value":662},"用户价值预测",{"type":186,"tag":279,"props":664,"children":665},{},[666],{"type":192,"value":667},"汽车广告（300%提升）",{"type":186,"tag":237,"props":669,"children":670},{},[671,679,684,689,693,698],{"type":186,"tag":279,"props":672,"children":673},{},[674],{"type":186,"tag":283,"props":675,"children":676},{},[677],{"type":192,"value":678},"PPE",{"type":186,"tag":279,"props":680,"children":681},{},[682],{"type":192,"value":683},"深度交互",{"type":186,"tag":279,"props":685,"children":686},{},[687],{"type":192,"value":688},"互动营销期",{"type":186,"tag":279,"props":690,"children":691},{},[692],{"type":192,"value":410},{"type":186,"tag":279,"props":694,"children":695},{},[696],{"type":192,"value":697},"完整留资率",{"type":186,"tag":279,"props":699,"children":700},{},[701],{"type":192,"value":702},"保险行业（120 元/条）",{"type":186,"tag":194,"props":704,"children":706},{"id":705},"为什么没有考核点在付费阶段的投放策略",[707],{"type":192,"value":708},"为什么没有考核点在付费阶段的投放策略？",{"type":186,"tag":201,"props":710,"children":711},{},[712],{"type":192,"value":713},"如果用户为广告付费才算作有效广告，这给了广告主很大的作弊空间。",{"type":186,"tag":194,"props":715,"children":717},{"id":716},"ocpm-和-cpm-相比有什么优势",[718],{"type":192,"value":719},"oCPM 和 CPM 相比有什么优势？",{"type":186,"tag":201,"props":721,"children":722},{},[723],{"type":192,"value":724},"oCPM 是 Facebook 率先使用的一种广告投放方式，它在 CPM 投放方式的基础上，将广告主的出价点从曝光下移到转化，达到激励相容的效果。",{"type":186,"tag":201,"props":726,"children":727},{},[728],{"type":192,"value":729},"具体来看，CPM 是苹果花费 20 块钱买 B 站 2000 次曝光，平台只需要保证曝光量就能拿到钱，oCPM 是苹果花费 20 块钱买 B 站 2 次曝光，但平台保证这 2 次曝光中至少有 1 次转化。这样看来，如果转换率不达标，苹果会亏钱，所以平台会更加努力提升转化率，达到正和博弈效果。一般平台还会设置赔率，如 20 块钱买 2 次曝光，但没有转化就退 2 块钱。",{"title":178,"searchDepth":731,"depth":731,"links":732},2,[733,734],{"id":189,"depth":731,"text":189},{"id":220,"depth":731,"text":220},"markdown","content:6.maps:_product:operation:operation.md","content","6.maps/_product/operation/operation.md","6.maps/_product/operation/operation",[741,745],{"_path":742,"title":743,"description":744},"/maps/_product/growth/growth","增长","产品增长是指通过不断优化产品和服务，提高用户体验，增加用户数量和用户活跃度，从而实现企业的长期发展目标。",{"_path":746,"title":747,"description":178},"/maps/_product/product","产品",1772185455063]