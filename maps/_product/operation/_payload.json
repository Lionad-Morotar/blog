en":183,"toc":729},"root",[184,192,199,205,210,217,222,227,702,708,713,719,724],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"数据",[190],{"type":191,"value":188},"text",{"type":185,"tag":193,"props":194,"children":196},"h4",{"id":195},"nps-是什么",[197],{"type":191,"value":198},"NPS 是什么？",{"type":185,"tag":200,"props":201,"children":202},"p",{},[203],{"type":191,"value":204},"NPS（Net Promoter Score） 是衡量客户忠诚度的关键指标，由贝恩咨询公司 Fred Reichheld 于 2003 年提出。其核心是通过一个问题“你会推荐我们的产品/服务给朋友吗？”来衡量客户对产品的满意度，并将结果分为推荐者（9 ~ 10 分）、中立者（7 ~ 8 分）、批评者（0 ~ 6 分）三类，由推荐者减去批评者再除以有效问卷数量得到 NPS 值。一般来说，NPS 60+ 为优秀，少数公司能做到在某次更新后达到 80+ 的高 NPS 值。",{"type":185,"tag":200,"props":206,"children":207},{},[208],{"type":191,"value":209},"相比 CSAT（Customer Satisfaction） 和 CES（Customer Effort Score），NPS 更能反映用户对产品的忠诚度，但他也有自身的局限性，如无法解释具体痛点、只能反应品牌总体满意度等。所以一般需要都流程上结合多种数据来评估分析，如，对于初创企业，NPS 可快速验证市场接受度；对于成熟企业，则是优化用户忠诚度的战略工具。NPS 的成功取决于数据驱动的行动闭环，绝非单一的数字追求。",{"type":185,"tag":211,"props":212,"children":214},"mermaid",{"size":213},"md",[215],{"type":191,"value":216},"\ngraph TD\n    A[收集用户评分数据] --> B{评分范围}\n    B -->|9-10 分| C[**推荐者 Promoters**]\n    B -->|7-8 分| D[**被动者 Passives**]\n    B -->|0-6 分| E[**贬损者 Detractors**]\n    C --> F[计算推荐者比例]\n    E --> G[计算贬损者比例]\n    F --> H[NPS = 推荐者比例 - 贬损者比例]\n    G --> H\n    H --> I[结果乘以 100]\n    I --> J[最终 NPS 值]\n",{"type":185,"tag":186,"props":218,"children":220},{"id":219},"广告",[221],{"type":191,"value":219},{"type":185,"tag":193,"props":223,"children":225},{"id":224},"广告投放策略",[226],{"type":191,"value":224},{"type":185,"tag":228,"props":229,"children":230},"table",{},[231,270],{"type":185,"tag":232,"props":233,"children":234},"thead",{},[235],{"type":185,"tag":236,"props":237,"children":238},"tr",{},[239,245,250,255,260,265],{"type":185,"tag":240,"props":241,"children":242},"th",{},[243],{"type":191,"value":244},"模型",{"type":185,"tag":240,"props":246,"children":247},{},[248],{"type":191,"value":249},"计费依据",{"type":185,"tag":240,"props":251,"children":25