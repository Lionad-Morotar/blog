,"props":555,"children":556},{},[557],{"type":188,"value":558},"淘宝客（佣金比例 20%）",{"type":182,"tag":233,"props":560,"children":561},{},[562,570,575,580,584,589],{"type":182,"tag":275,"props":563,"children":564},{},[565],{"type":182,"tag":279,"props":566,"children":567},{},[568],{"type":188,"value":569},"PPC(pay per customer)",{"type":182,"tag":275,"props":571,"children":572},{},[573],{"type":188,"value":574},"每潜在客户",{"type":182,"tag":275,"props":576,"children":577},{},[578],{"type":188,"value":579},"B2B 营销期",{"type":182,"tag":275,"props":581,"children":582},{},[583],{"type":188,"value":370},{"type":182,"tag":275,"props":585,"children":586},{},[587],{"type":188,"value":588},"线索质量筛选",{"type":182,"tag":275,"props":590,"children":591},{},[592],{"type":188,"value":593},"Salesforce 获客（100 元/条）",{"type":182,"tag":233,"props":595,"children":596},{},[597,605,610,615,619,624],{"type":182,"tag":275,"props":598,"children":599},{},[600],{"type":182,"tag":279,"props":601,"children":602},{},[603],{"type":188,"value":604},"CPE(cost per engagement)",{"type":182,"tag":275,"props":606,"children":607},{},[608],{"type":188,"value":609},"深度互动",{"type":182,"tag":275,"props":611,"children":612},{},[613],{"type":188,"value":614},"社交互动期",{"type":182,"tag":275,"props":616,"children":617},{},[618],{"type":188,"value":370},{"type":182,"tag":275,"props":620,"children":621},{},[622],{"type":188,"value":623},"社交平台互动指标",{"type":182,"tag":275,"props":625,"children":626},{},[627],{"type":188,"value":628},"抖音挑战赛（0.5 元/次）",{"type":182,"tag":233,"props":630,"children":631},{},[632,640,645,650,654,659],{"type":182,"tag":275,"props":633,"children":634},{},[635],{"type":182,"tag":279,"props":636,"children":637},{},[638],{"type":188,"value":639},"dCPM",{"type":182,"tag":275,"props":641,"children":642},{},[643],{"type":188,"value":644},"动态 CPM",{"type":182,"tag":275,"props":646,"children":647},{},[648],{"type":188,"value":649},"实时竞价期",{"type":182,"tag":275,"props":651,"children":652},{},[653],{"type":188,"value":406},{"type":182,"tag":275,"props":655,"children":656},{},[657],{"type":188,"value":658},"用户价值预测",{"type":182,"tag":275,"props":660,"children":661},{},[662],{"type":188,"value":663},"汽车广告（300%提升）",{"type":182,"tag":233,"props":665,"children":666},{},[667,675,680,685,689,694],{"type":182,"tag":275,"props":668,"children":669},{},[670],{"type":182,"tag":279,"props":671,"children":672},{},[673],{"type":188,"value":674},"PPE",{"type":182,"tag":275,"props":676,"children":677},{},[678],{"type":188,"value":679},"深度交互",{"type":182,"tag":275,"props":681,"children":682},{},[683],{"type":188,"value":684},"互动营销期",{"type":182,"tag":275,"props":686,"children":687},{},[688],{"type":188,"value":406},{"type":182,"tag":275,"props":690,"children":691},{},[692],{"type":188,"value":693},"完整留资率",{"type":182,"tag":275,"props":695,"children":696},{},[697],{"type":188,"value":698},"保险行业（120 元/条）",{"type":182,"tag":190,"props":700,"children":702},{"id":701},"为什么没有考核点在付费阶段的投放策略",[703],{"type":188,"value":704},"为什么没有考核点在付费阶段的投放策略？",{"type":182,"tag":197,"props":706,"children":707},{},[708],{"type":188,"value":709},"如果用户为广告付费才算作有效广告，这给了广告主很大的作弊空间。",{"type":182,"tag":190,"props":711,"children":713},{"id":712},"ocpm-和-cpm-相比有什么优势",[714],{"type":188,"value":715},"oCPM 和 CPM 相比有什么优势？",{"type":182,"tag":197,"props":717,"children":718},{},[719],{"type":188,"value":720},"oCPM 是 Facebook 率先使用的一种广告投放方式，它在 CPM 投放方式的基础上，将广告主的出价点从曝光下移到转化，达到激励相容的效果。",{"type":182,"tag":197,"props":722,"children":723},{},[724],{"type":188,"value":725},"具体来看，CPM 是苹果花费 20 块钱买 B 站 2000 次曝光，平台只需要保证曝光量就能拿到钱，oCPM 是苹果花费 20 块钱买 B 站 2 次曝光，但平台保证这 2 次曝光中至少有 1 次转化。这样看来，如果转换率不达标，苹果会亏钱，所以平台会更加努力提升转化率，达到正和博弈效果。一般平台还会设置赔率，如 20 块钱买 2 次曝光，但没有转化就退 2 块钱。",{"title":175,"searchDepth":727,"depth":727,"links":728},2,[729,730],{"id":185,"depth":727,"text":185},{"id":216,"depth":727,"text":216},"markdown","content:6.maps:_product:operation.md","content","6.maps/_product/operation.md","6.maps/_product/operation",[737,741],{"_path":738,"title":739,"description":740},"/maps/_product/growth","增长","产品增长是指通过不断优化产品和服务，提高用户体验，增加用户数量和用户活跃度，从而实现企业的长期发展目标。",{"_path":742,"title":743,"description":175},"/maps/_product/product","产品",1771264630358]