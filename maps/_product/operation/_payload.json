,224,699,705,710,716,721],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"数据",[187],{"type":188,"value":185},"text",{"type":182,"tag":190,"props":191,"children":193},"h4",{"id":192},"nps-是什么",[194],{"type":188,"value":195},"NPS 是什么？",{"type":182,"tag":197,"props":198,"children":199},"p",{},[200],{"type":188,"value":201},"NPS（Net Promoter Score） 是衡量客户忠诚度的关键指标，由贝恩咨询公司 Fred Reichheld 于 2003 年提出。其核心是通过一个问题“你会推荐我们的产品/服务给朋友吗？”来衡量客户对产品的满意度，并将结果分为推荐者（9 ~ 10 分）、中立者（7 ~ 8 分）、批评者（0 ~ 6 分）三类，由推荐者减去批评者再除以有效问卷数量得到 NPS 值。一般来说，NPS 60+ 为优秀，少数公司能做到在某次更新后达到 80+ 的高 NPS 值。",{"type":182,"tag":197,"props":203,"children":204},{},[205],{"type":188,"value":206},"相比 CSAT（Customer Satisfaction） 和 CES（Customer Effort Score），NPS 更能反映用户对产品的忠诚度，但他也有自身的局限性，如无法解释具体痛点、只能反应品牌总体满意度等。所以一般需要都流程上结合多种数据来评估分析，如，对于初创企业，NPS 可快速验证市场接受度；对于成熟企业，则是优化用户忠诚度的战略工具。NPS 的成功取决于数据驱动的行动闭环，绝非单一的数字追求。",{"type":182,"tag":208,"props":209,"children":211},"mermaid",{"size":210},"md",[212],{"type":188,"value":213},"\ngraph TD\n    A[收集用户评分数据] --> B{评分范围}\n    B -->|9-10 分| C[**推荐者 Promoters**]\n    B -->|7-8 分| D[**被动者 Passives**]\n    B -->|0-6 分| E[**贬损者 Detractors**]\n    C --> F[计算推荐者比例]\n    E --> G[计算贬损者比例]\n    F --> H[NPS = 推荐者比例 - 贬损者比例]\n    G --> H\n    H --> I[结果乘以 100]\n    I --> J[最终 NPS 值]\n",{"type":182,"tag":183,"props":215,"children":217},{"id":216},"广告",[218],{"type":188,"value":216},{"type":182,"tag":190,"props":220,"children":222},{"id":221},"广告投放策略",[223],{"type":188,"value":221},{"type":182,"tag":225,"props":226,"children":227},"table",{},[228,267],{"type":182,"tag":229,"props":230,"children":231},"thead",{},[232],{"type":182,"tag":233,"props":234,"children":235},"tr",{},[236,242,247,252,257,262],{"type":182,"tag":237,"props":238,"children":239},"th",{},[240],{"type":188,"value":241},"模型",{"type":182,"tag":237,"props":243,"children":244},{},[245],{"type":188,"value":246},"计费依据",{"type":182,"tag":237,"props":248,"children":249},{},[250],{"type":188,"value":251},"适用阶段",{"type":18