props":654,"children":655},{},[656],{"type":191,"value":409},{"type":185,"tag":278,"props":658,"children":659},{},[660],{"type":191,"value":661},"用户价值预测",{"type":185,"tag":278,"props":663,"children":664},{},[665],{"type":191,"value":666},"汽车广告（300%提升）",{"type":185,"tag":236,"props":668,"children":669},{},[670,678,683,688,692,697],{"type":185,"tag":278,"props":671,"children":672},{},[673],{"type":185,"tag":282,"props":674,"children":675},{},[676],{"type":191,"value":677},"PPE",{"type":185,"tag":278,"props":679,"children":680},{},[681],{"type":191,"value":682},"深度交互",{"type":185,"tag":278,"props":684,"children":685},{},[686],{"type":191,"value":687},"互动营销期",{"type":185,"tag":278,"props":689,"children":690},{},[691],{"type":191,"value":409},{"type":185,"tag":278,"props":693,"children":694},{},[695],{"type":191,"value":696},"完整留资率",{"type":185,"tag":278,"props":698,"children":699},{},[700],{"type":191,"value":701},"保险行业（120 元/条）",{"type":185,"tag":193,"props":703,"children":705},{"id":704},"为什么没有考核点在付费阶段的投放策略",[706],{"type":191,"value":707},"为什么没有考核点在付费阶段的投放策略？",{"type":185,"tag":200,"props":709,"children":710},{},[711],{"type":191,"value":712},"如果用户为广告付费才算作有效广告，这给了广告主很大的作弊空间。",{"type":185,"tag":193,"props":714,"children":716},{"id":715},"ocpm-和-cpm-相比有什么优势",[717],{"type":191,"value":718},"oCPM 和 CPM 相比有什么优势？",{"type":185,"tag":200,"props":720,"children":721},{},[722],{"type":191,"value":723},"oCPM 是 Facebook 率先使用的一种广告投放方式，它在 CPM 投放方式的基础上，将广告主的出价点从曝光下移到转化，达到激励相容的效果。",{"type":185,"tag":200,"props":725,"children":726},{},[727],{"type":191,"value":728},"具体来看，CPM 是苹果花费 20 块钱买 B 站 2000 次曝光，平台只需要保证曝光量就能拿到钱，oCPM 是苹果花费 20 块钱买 B 站 2 次曝光，但平台保证这 2 次曝光中至少有 1 次转化。这样看来，如果转换率不达标，苹果会亏钱，所以平台会更加努力提升转化率，达到正和博弈效果。一般平台还会设置赔率，如 20 块钱买 2 次曝光，但没有转化就退 2 块钱。",{"title":178,"searchDepth":730,"depth":730,"links":731},2,[732,733],{"id":188,"depth":730,"text":188},{"id":219,"depth":730,"text":219},"markdown","content:6.maps:_product:operation.md","content","6.maps/_product/operation.md","6.maps/_product/operation",[740,744],{"_path":741,"title":742,"description":743},"/maps/_product/growth","增长","产品增长是指通过不断优化产品和服务，提高用户体验，增加用户数量和用户活跃度，从而实现企业的长期发展目标。",{"_path":745,"title":746,"description":178},"/maps/_product/product","产品",1771521485951]