"manage",false,true,"","项目管理","项目管理实践指南，涵盖项目类型、目标设定、里程碑规划、风险管理等核心环节的系统性介绍。","content/6.maps/_manage/project-management.md",{"type":183,"children":184,"toc":362},"root",[185,193,200,206,212,237,243,248,254,259,264,278,284,289,295,300,306,351,357],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"简介",[191],{"type":192,"value":189},"text",{"type":186,"tag":194,"props":195,"children":197},"h4",{"id":196},"什么事情适合做项目",[198],{"type":192,"value":199},"什么事情适合做项目？",{"type":186,"tag":201,"props":202,"children":203},"p",{},[204],{"type":192,"value":205},"项目是在限定的资源及限定的时间内需要完成的一次性任务，具有限定性、独特性和明确的目标，所以和\"维护\"、\"日常\"是两码事。",{"type":186,"tag":194,"props":207,"children":209},{"id":208},"项目分哪几种类型",[210],{"type":192,"value":211},"项目分哪几种类型？",{"type":186,"tag":201,"props":213,"children":214},{},[215,221,223,228,230,235],{"type":186,"tag":216,"props":217,"children":218},"strong",{},[219],{"type":192,"value":220},"技术性",{"type":192,"value":222},"：提效为主；",{"type":186,"tag":216,"props":224,"children":225},{},[226],{"type":192,"value":227},"运营型",{"type":192,"value":229},"：业绩导向；",{"type":186,"tag":216,"props":231,"children":232},{},[233],{"type":192,"value":234},"产品型",{"type":192,"value":236},"：用户增长或留存指标导向",{"type":186,"tag":194,"props":238,"children":240},{"id":239},"项目管理的核心是什么",[241],{"type":192,"value":242},"项目管理的核心是什么？",{"type":186,"tag":201,"props":244,"children":245},{},[246],{"type":192,"value":247},"项目管理的核心就是基于目标的管理。项目的质量三角围绕范围、时间和成本进行权衡，即以清晰可控的目标为导向，权衡人力及其它资源成本，使用里程碑分析、任务拆分 WBS 等工具管理目标。",{"type":186,"tag":194,"props":249,"children":251},{"id":250},"怎么设计项目目标",[252],{"type":192,"value":253},"怎么设计项目目标？",{"type":186,"tag":201,"props":255,"children":256},{},[257],{"type":192,"value":258},"通过 SMART 法则：Specific、Measurable、Attainable、Relevant、Time-based。",{"type":186,"tag":201,"props":260,"children":261},{},[262],{"type":192,"value":263},"一个简单的示例，比\"提升客户续费率 50%\"更好的项目目标是\"在保证新开业绩前提下，9 月底季度续费率提升 20% 以上\"。",{"type":186,"tag":201,"props":265,"children":266},{},[267,269],{"type":192,"value":268},"见：",{"type":186,"tag":270,"props":271,"children":275},"a",{"href":272,"rel":273},"https://wiki.mbalib.com/zh-tw/SMART%E5%8E%9F%E5%89%87",[274],"nofollow",[276],{"type":192,"value":277},"TODO，SMART@MBA",{"type":186,"tag":194,"props":279,"children":281},{"id":280},"确定项目目标前要做什么",[282],{"type":192,"value":283},"确定项目目标前要做什么？",{"type":186,"tag":201,"props":285,"children":286},{},[287],{"type":192,"value":288},"如果说目标是要解决的问题，那么在解决问题前还有发现问题和分析问题两个步骤。了解项目背景后，在项目前期进行充分的访谈和调研，才能分析出问题的解决路径，以及确定衡量目标得到解决的办法。",{"type":186,"tag":194,"props":290,"children":292},{"id":291},"什么是项目里程碑",[293],{"type":192,"value":294},"什么是项目里程碑？",{"type":186,"tag":201,"props":296,"children":297},{},[298],{"type":192,"value":299},"项目目标 > 项目里程碑 > 个人任务，作为中介，里程碑可以辅助拆分任务目标，并关注上下游依赖风险。好的任务拆分要保证目标的完整性和任务独立性，分解工作不能漏掉某项，而工作之间要相互独立，没有交叉依赖。",{"type":186,"tag":194,"props":301,"children":303},{"id":302},"自查清单应该包括哪些",[304],{"type":192,"value":305},"自查清单应该包括哪些？",{"type":186,"tag":307,"props":308,"children":309},"ol",{},[310,316,321,326,331,336,341,346],{"type":186,"tag":311,"props":312,"children":313},"li",{},[314],{"type":192,"value":315},"项目背景：目前的痛点是什么",{"type":186,"tag":311,"props":317,"children":318},{},[319],{"type":192,"value":320},"项目目标：希望达成什么",{"type":186,"tag":311,"props":322,"children":323},{},[324],{"type":192,"value":325},"衡量指标：关键指标是什么，如何衡量最终价值",{"type":186,"tag":311,"props":327,"children":328},{},[329],{"type":192,"value":330},"项目负责：谁对于最终目标负责",{"type":186,"tag":311,"props":332,"children":333},{},[334],{"type":192,"value":335},"项目人员：项目参与团队及人员",{"type":186,"tag":311,"props":337,"children":338},{},[339],{"type":192,"value":340},"项目范围：什么在范围内，什么不在",{"type":186,"tag":311,"props":342,"children":343},{},[344],{"type":192,"value":345},"时间规划：分哪几个阶段",{"type":186,"tag":311,"props":347,"children":348},{},[349],{"type":192,"value":350},"风险管理：项目风险及应对方式",{"type":186,"tag":194,"props":352,"children":354},{"id":353},"什么时候结项",[355],{"type":192,"value":356},"什么时候结项？",{"type":186,"tag":201,"props":358,"children":359},{},[360],{"type":192,"value":361},"如果项目目标在计划时间内得到实现，且能够在短时间内收集到业务数据辅助验证结果，那么就应该结项。项目收尾时应包括成果总结、经验复盘和文档沉淀：计划交付、实际交付与未交付的成果，经验教训、最佳实践，产品、运营和技术类文档，并总结为项目总结文档。",{"title":178,"searchDepth":363,"depth":363,"links":364},2,[365],{"id":189,"depth":363,"text":189},"markdown","content:6.maps:_manage:manage:project-management.md","content","6.maps/_manage/manage/project-management.md","6.maps/_manage/manage/project-management","md",[373,376],{"_path":374,"title":179,"description":375},"/maps/_manage/manage","项目管理实践与方法论，涵盖项目规划、目标设定、里程碑管理、风险控制等核心领域",{"_path":377,"title":378,"description":379},"/maps/_management/capacity-driven-development/capacity-driven-development","Capacity-driven development（产能驱动开发）","警惕用「填满人」替代「保障价值流」的局部最优，建议用系统健康与组织调度来管理空闲产能。",1772185482036]