ren":180,"toc":358},"root",[181,189,196,202,208,233,239,244,250,255,260,274,280,285,291,296,302,347,353],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"简介",[187],{"type":188,"value":185},"text",{"type":182,"tag":190,"props":191,"children":193},"h4",{"id":192},"什么事情适合做项目",[194],{"type":188,"value":195},"什么事情适合做项目？",{"type":182,"tag":197,"props":198,"children":199},"p",{},[200],{"type":188,"value":201},"项目是在限定的资源及限定的时间内需要完成的一次性任务，具有限定性、独特性和明确的目标，所以和\"维护\"、\"日常\"是两码事。",{"type":182,"tag":190,"props":203,"children":205},{"id":204},"项目分哪几种类型",[206],{"type":188,"value":207},"项目分哪几种类型？",{"type":182,"tag":197,"props":209,"children":210},{},[211,217,219,224,226,231],{"type":182,"tag":212,"props":213,"children":214},"strong",{},[215],{"type":188,"value":216},"技术性",{"type":188,"value":218},"：提效为主；",{"type":182,"tag":212,"props":220,"children":221},{},[222],{"type":188,"value":223},"运营型",{"type":188,"value":225},"：业绩导向；",{"type":182,"tag":212,"props":227,"children":228},{},[229],{"type":188,"value":230},"产品型",{"type":188,"value":232},"：用户增长或留存指标导向",{"type":182,"tag":190,"props":234,"children":236},{"id":235},"项目管理的核心是什么",[237],{"type":188,"value":238},"项目管理的核心是什么？",{"type":182,"tag":197,"props":240,"children":241},{},[242],{"type":188,"value":243},"项目管理的核心就是基于目标的管理。项目的质量三角围绕范围、时间和成本进行权衡，即以清晰可控的目标为导向，权衡人力及其它资源成本，使用里程碑分析、任务拆分 WBS 等工具管理目标。",{"type":182,"tag":190,"props":245,"children":247},{"id":246},"怎么设计项目目标",[248],{"type":188,"value":249},"怎么设计项目目标？",{"type":182,"tag":197,"props":251,"children":252},{},[253],{"type":188,"value":254},"通过 SMART 法则：Specific、Measurable、Attainable、Relevant、Time-based。",{"type":182,"tag":197,"props":256,"children":257},{},[258],{"type":188,"value":259},"一个简单的示例，比\"提升客户续费率 50%\"更好的项目目标是\"在保证新开业绩前提下，9 月底季度续费率提升 20% 以上\"。",{"type":182,"tag":197,"props":261,"children":262},{},[263,265],{"type":188,"value":264},"见：",{"type":182,"tag":266,"props":267,"children":271},"a",{"href":268,"rel":269},"https://wiki.mbalib.com/zh-tw/SMART%E5%8E%9F%E5%89%87",[270],"nofollow",[272],{"type":188,"value":273},"TODO，SMART@MBA",{"type":182,"tag":190,"props":275,"children":277},{"id":276},"确定项目目标前要做什么",[278],{"type":188,"value":279},"确定项目目标前要做什么？",{"type":182,"tag":197,"props":281,"children":282},{},[283],{"type":188,"value":284},"如果说目标是要解决的问题，那么在解决问题前还有发现问题和分析问题两个步骤。了解项目背景后，在项目前期进行充分的访谈和调研，才能分析出问题的解决路径，以及确定衡量目标得到解决的办法。",{"type":182,"tag":190,"props":286,"children":288},{"id":287},"什么是项目里程碑",[289],{"type":188,"value":290},"什么是项目里程碑？",{"type":182,"tag":197,"props":292,"children":293},{},[294],{"type":188,"value":295},"项目目标 > 项目里程碑 > 个人任务，作为中介，里程碑可以辅助拆分任务目标，并关注上下游依赖风险。好的任务拆分要保证目标的完整性和任务独立性，分解工作不能漏掉某项，而工作之间要相互独立，没有交叉依赖。",{"type":182,"tag":190,"props":297,"children":299},{"id":298},"自查清单应该包括哪些",[300],{"type":188,"value":301},"自查清单应该包括哪些？",{"type":182,"tag":303,"props":304,"children":305},"ol",{},[306,312,317,322,327,332,337,342],{"type":182,"tag":307,"props":308,"children":309},"li",{},[310],{"type":188,"value":311},"项目背景：目前的痛点是什么",{"type":182,"tag":307,"props":313,"children":314},{},[315],{"type":188,"value":316},"项目目标：希望达成什么",{"type":182,"tag":307,"props":318,"children":319},{},[320],{"type":188,"value":321},"衡量指标：关键指标是什么，如何衡量最终价值",{"type":182,"tag":307,"props":323,"children":324},{},[325],{"type":188,"value":326},"项目负责：谁对于最终目标负责",{"type":182,"tag":307,"props":328,"children":329},{},[330],{"type":188,"value":331},"项目人员：项目参与团队及人员",{"type":182,"tag":307,"props":333,"children":334},{},[335],{"type":188,"value":336},"项目范围：什么在范围内，什么不在",{"type":182,"tag":307,"props":338,"children":339},{},[340],{"type":188,"value":341},"时间规划：分哪几个阶段",{"type":182,"tag":307,"props":343,"children":344},{},[345],{"type":188,"value":346},"风险管理：项目风险及应对方式",{"type":182,"tag":190,"props":348,"children":350},{"id":349},"什么时候结项",[351],{"type":188,"value":352},"什么时候结项？",{"type":182,"tag":197,"props":354,"children":355},{},[356],{"type":188,"value":357},"如果项目目标在计划时间内得到实现，且能够在短时间内收集到业务数据辅助验证结果，那么就应该结项。项目收尾时应包括成果总结、经验复盘和文档沉淀：计划交付、实际交付与未交付的成果，经验教训、最佳实践，产品、运营和技术类文档，并总结为项目总结文档。",{"title":175,"searchDepth":359,"depth":359,"links":360},2,[361],{"id":185,"depth":359,"text":185},"markdown","content:6.maps:_manage:project-management.md","content","6.maps/_manage/project-management.md","6.maps/_manage/project-management","md",[369,373],{"_path":370,"title":371,"description":372},"/maps/_machine-learning/prompt/seo","SEO","传统 SEO、AI SEO、内容优化等",{"_path":374,"title":375,"description":376},"/maps/_management/capacity-driven-development","Capacity-driven development（产能驱动开发）","警惕用「填满人」替代「保障价值流」的局部最优，建议用系统健康与组织调度来管理空闲产能。",1771071658963]