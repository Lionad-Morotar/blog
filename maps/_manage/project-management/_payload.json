涵盖项目类型、目标设定、里程碑规划、风险管理等核心环节的系统性介绍。",{"type":182,"children":183,"toc":361},"root",[184,192,199,205,211,236,242,247,253,258,263,277,283,288,294,299,305,350,356],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"简介",[190],{"type":191,"value":188},"text",{"type":185,"tag":193,"props":194,"children":196},"h4",{"id":195},"什么事情适合做项目",[197],{"type":191,"value":198},"什么事情适合做项目？",{"type":185,"tag":200,"props":201,"children":202},"p",{},[203],{"type":191,"value":204},"项目是在限定的资源及限定的时间内需要完成的一次性任务，具有限定性、独特性和明确的目标，所以和\"维护\"、\"日常\"是两码事。",{"type":185,"tag":193,"props":206,"children":208},{"id":207},"项目分哪几种类型",[209],{"type":191,"value":210},"项目分哪几种类型？",{"type":185,"tag":200,"props":212,"children":213},{},[214,220,222,227,229,234],{"type":185,"tag":215,"props":216,"children":217},"strong",{},[218],{"type":191,"value":219},"技术性",{"type":191,"value":221},"：提效为主；",{"type":185,"tag":215,"props":223,"children":224},{},[225],{"type":191,"value":226},"运营型",{"type":191,"value":228},"：业绩导向；",{"type":185,"tag":215,"props":230,"children":231},{},[232],{"type":191,"value":233},"产品型",{"type":191,"value":235},"：用户增长或留存指标导向",{"type":185,"tag":193,"props":237,"children":239},{"id":238},"项目管理的核心是什么",[240],{"type":191,"value":241},"项目管理的核心是什么？",{"type":185,"tag":200,"props":243,"children":244},{},[245],{"type":191,"value":246},"项目管理的核心就是基于目标的管理。项目的质量三角围绕范围、时间和成本进行权衡，即以清晰可控的目标为导向，权衡人力及其它资源成本，使用里程碑分析、任务拆分 WBS 等工具管理目标。",{"type":185,"tag":193,"props":248,"children":250},{"id":249},"怎么设计项目目标",[251],{"type":191,"value":252},"怎么设计项目目标？",{"type":185,"tag":200,"props":254,"children":255},{},[256],{"type":191,"value":257},"通过 SMART 法则：Specific、Measurable、Attainable、Relevant、Time-based。",{"type":185,"tag":200,"props":259,"children":260},{},[261],{"type":191,"value":262},"一个简单的示例，比\"提升客户续费率 50%\"更好的项目目标是\"在保证新开业绩前提下，9 月底季度续费率提升 20% 以上\"。",{"type":185,"tag":200,"props":264,"children":265},{},[266,268],{"type":191,"value":267},"见：",{"type":185,"tag":269,"props":270,"children":274},"a",{"href":271,"rel":272},"https://wiki.mbalib.com/zh-tw/SMART%E5%8E%9F%E5%89%87",[273],"nofollow",[275],{"type":191,"value":276},"TODO，SMART@MBA",{"type":185,"tag":193,"props":278,"children":280},{"id":279},"确定项目目标前要做什么",[281],{"type":191,"value":282},"确定项目目标前要做什么？",{"type":185,"tag":200,"props":284,"children":285},{},[286],{"type":191,"value":287},"如果说目标是要解决的问题，那么在解决问题前还有发现问题和分析问题两个步骤。了解项目背景后，在项目前期进行充分的访谈和调研，才能分析出问题的解决路径，以及确定衡量目标得到解决的办法。",{"type":185,"tag":193,"props":289,"children":291},{"id":290},"什么是项目里程碑",[292],{"type":191,"value":293},"什么是项目里程碑？",{"type":185,"tag":200,"props":295,"children":296},{},[297],{"type":191,"value":298},"项目目标 > 项目里程碑 > 个人任务，作为中介，里程碑可以辅助拆分任务目标，并关注上下游依赖风险。好的任务拆分要保证目标的完整性和任务独立性，分解工作不能漏掉某项，而工作之间要相互独立，没有交叉依赖。",{"type":185,"tag":193,"props":300,"children":302},{"id":301},"自查清单应该包括哪些",[303],{"type":191,"value":304},"自查清单应该包括哪些？",{"type":185,"tag":306,"props":307,"children":308},"ol",{},[309,315,320,325,330,335,340,345],{"type":185,"tag":310,"props":311,"children":312},"li",{},[313],{"type":191,"value":314},"项目背景：目前的痛点是什么",{"type":185,"tag":310,"props":316,"children":317},{},[318],{"type":191,"value":319},"项目目标：希望达成什么",{"type":185,"tag":310,"props":321,"children":322},{},[323],{"type":191,"value":324},"衡量指标：关键指标是什么，如何衡量最终价值",{"type":185,"tag":310,"props":326,"children":327},{},[328],{"type":191,"value":329},"项目负责：谁对于最终目标负责",{"type":185,"tag":310,"props":331,"children":332},{},[333],{"type":191,"value":334},"项目人员：项目参与团队及人员",{"type":185,"tag":310,"props":336,"children":337},{},[338],{"type":191,"value":339},"项目范围：什么在范围内，什么不在",{"type":185,"tag":310,"props":341,"children":342},{},[343],{"type":191,"value":344},"时间规划：分哪几个阶段",{"type":185,"tag":310,"props":346,"children":347},{},[348],{"type":191,"value":349},"风险管理：项目风险及应对方式",{"type":185,"tag":193,"props":351,"children":353},{"id":352},"什么时候结项",[354],{"type":191,"value":355},"什么时候结项？",{"type":185,"tag":200,"props":357,"children":358},{},[359],{"type":191,"value":360},"如果项目目标在计划时间内得到实现，且能够在短时间内收集到业务数据辅助验证结果，那么就应该结项。项目收尾时应包括成果总结、经验复盘和文档沉淀：计划交付、实际交付与未交付的成果，经验教训、最佳实践，产品、运营和技术类文档，并总结为项目总结文档。",{"title":178,"searchDepth":362,"depth":362,"links":363},2,[364],{"id":188,"depth":362,"text":188},"markdown","content:6.maps:_manage:project-management.md","content","6.maps/_manage/project-management.md","6.maps/_manage/project-management","md",[372,376],{"_path":373,"title":374,"description":375},"/maps/_machine-learning/prompt/seo","SEO","传统 SEO、AI SEO、内容优化等",{"_path":377,"title":378,"description":379},"/maps/_management/capacity-driven-development","Capacity-driven development（产能驱动开发）","警惕用「填满人」替代「保障价值流」的局部最优，建议用系统健康与组织调度来管理空闲产能。",1771693393595]