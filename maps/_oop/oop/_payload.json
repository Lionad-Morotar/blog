en":183,"toc":403},"root",[184,193,199,215,221,226,236,243,248,283,292,300,305,310,315,320,343,349,354,372,377,382,390,395],{"type":185,"tag":186,"props":187,"children":189},"element","h4",{"id":188},"面向对象主要关注哪些方面",[190],{"type":191,"value":192},"text","面向对象主要关注哪些方面？",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"四个核心概念：封装（Encapsulation）、继承（Inheritance）、多态（Polymorphism）、抽象（Abstraction）。",{"type":185,"tag":194,"props":200,"children":201},{},[202,204,213],{"type":191,"value":203},"见：",{"type":185,"tag":205,"props":206,"children":210},"a",{"href":207,"rel":208},"https://www.bilibili.com/video/BV1gb411w7eW",[209],"nofollow",[211],{"type":191,"value":212},"JavaScript OOP 面向对象编程 @Mosh",{"type":191,"value":214},"，非常基础，适合新手入门",{"type":185,"tag":186,"props":216,"children":218},{"id":217},"面相对象和设计模式的关系",[219],{"type":191,"value":220},"面相对象和设计模式的关系？",{"type":185,"tag":194,"props":222,"children":223},{},[224],{"type":191,"value":225},"一般意义上的设计模式指的是在 OOP 编程范式的实践下总结出来的一些用来解决特定问题的代码设计经验。",{"type":185,"tag":194,"props":227,"children":228},{},[229,230],{"type":191,"value":203},{"type":185,"tag":205,"props":231,"children":233},{"href":232},"/maps/_software/design-patterns",[234],{"type":191,"value":235},"设计模式",{"type":185,"tag":237,"props":238,"children":240},"h2",{"id":239},"uml",[241],{"type":191,"value":242},"UML",{"type":185,"tag":194,"props":244,"children":245},{},[246],{"type":191,"value":247},"类之间的关系总的来说可以包含这几种：",{"type":185,"tag":249,"props":250,"children":251},"ul",{},[252,258,263,268,273,278],{"type":185,"tag":253,"props":254,"children":255},"li",{},[256],{"type":191,"value":257},"A 依赖 B：对类 B 的修改会影响到类 A",{"type":185,"tag":253,"props":259,"children":260},{},[261],{"type":191,"value":262},"A 关联 B：对象 A 知道对象 B，类 A 依赖于类 B",{"type":185,"tag":253,"props":264,"children":265},{},[266],{"type":191,"value":267},"A 聚合 B：对象 A 由 B 构成，类 A 依赖于类 B",{"type":185,"tag":253,"props":269,"children":270},{},[271],{"type":191,"value":272},"A 组合 B：对象 A 由 B 构成且管理 B 的生命周期，类 A 依赖于类 B",{"type":185,"tag":253,"props":274,"children":275},{},[276],{"type":191,"value":277},"A 实现 B：对象 A 可视为对象 B，类 A 定义了接口 B 声明的方法，类 A 依赖于类 B",{"type":185,"tag":253,"props":279,"children":280},{},[281],{"type":191,"value":282},"A 继承 B：对象 A 可视为对象 B，类 A 继承类 B 的接口和实现，还可以对其扩展，类 A 依赖于类 B",{"type":185,"tag":194,"props":284,"children":285},{},[286],{"type":185,"tag":287,"props":288,"children":291},"img",{"alt":289,"src":290},"Class Relations","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/b3612320-5822-48fc-8041-ead5c269f8e5.svg",[],{"type":185,"tag":194,"props":293,"children":294},{},[295],{"type":185,"tag":287,"props":296,"children":299},{"alt":297,"src":298},"Object Relations","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/cff33e77-e9aa-48eb-ae0d-01dd1561abd0.svg",[],{"type":185,"tag":237,"props":301,"children":303},{"id":302},"设计原则",[304],{"type":191,"value":302},{"type":185,"tag":194,"props":306,"children":307},{},[308],{"type":191,"value":309},"什么是优秀的软件设计？",{"type":185,"tag":194,"props":311,"children":312},{},[313],{"type":191,"value":314},"显然，在不同的公司、不同的项目，软件设计并没有一个恒定的标准，不过总的来说我们会讨论代码复用以及代码的扩展性。",{"type":185,"tag":194,"props":316,"children":317},{},[318],{"type":191,"value":319},"有几个基础的设计准则能帮助你做到这两点：",{"type":185,"tag":249,"props":321,"children":322},{},[323,328,333,338],{"type":185,"tag":253,"props":324,"children":325},{},[326],{"type":191,"value":327},"封装变化：找到程序中易变的内容并将其和不变的内容区分开来",{"type":185,"tag":253,"props":329,"children":330},{},[331],{"type":191,"value":332},"面向接口：依赖抽象通常优于依赖具体",{"type":185,"tag":253,"props":334,"children":335},{},[336],{"type":191,"value":337},"优先组合：组合优于继承，因为继承有着挺多保守诟病之处",{"type":185,"tag":253,"props":339,"children":340},{},[341],{"type":191,"value":342},"SOLID 原则",{"type":185,"tag":344,"props":345,"children":347},"h3",{"id":346},"组合优于继承",[348],{"type":191,"value":346},{"type":185,"tag":194,"props":350,"children":351},{},[352],{"type":191,"value":353},"继承通常会引发大量问题：",{"type":185,"tag":249,"props":355,"children":356},{},[357,362,367],{"type":185,"tag":253,"props":358,"children":359},{},[360],{"type":191,"value":361},"子类不能减少父类的接口，并且需要保证兼容",{"type":185,"tag":253,"props":363,"children":364},{},[365],{"type":191,"value":366},"继承使状态逃离了父类的封装，子类和父类关系过于紧密",{"type":185,"tag":253,"props":368,"children":369},{},[370],{"type":191,"value":371},"继承经常被滥用，导致平行继承体系的出现",{"type":185,"tag":194,"props":373,"children":374},{},[375],{"type":191,"value":376},"假设你在售卖一些计算机，这些计算机包含笔记本，台式电脑以及算盘！",{"type":185,"tag":194,"props":378,"children":379},{},[380],{"type":191,"value":381},"如果使用继承的思路组织代码，你很可能对得到以下结构：",{"type":185,"tag":194,"props":383,"children":384},{},[385],{"type":185,"tag":287,"props":386,"children":389},{"alt":387,"src":388},"Computer Structure V1","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/348faf14-874b-410d-b4b9-ff00b04ab14e.svg",[],{"type":185,"tag":194,"props":391,"children":392},{},[393],{"type":191,"value":394},"使用组合可以方便地把不同的“维度”之间的并行关联拆分出来，降低代码复杂度：",{"type":185,"tag":194,"props":396,"children":397},{},[398],{"type":185,"tag":287,"props":399,"children":402},{"alt":400,"src":401},"Computer Structure V2","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/6cbffe1a-8efd-4de6-9ed3-bfef8392bab5.svg",[],{"title":178,"searchDepth":404,"depth":404,"links":405},2,[406,407],{"id":239,"depth":404,"text":242},{"id":302,"depth":404,"text":302,"children":408},[409],{"id":346,"depth":410,"text":346},3,"markdown","content:6.maps:_oop:oop.md","content","6.maps/_oop/oop.md","6.maps/_oop/oop","md",[418,422],{"_path":419,"title":420,"description":421},"/maps/_medicine/medicine","医疗","常见医疗知识、疾病、药物等。",{"_path":423,"title":424,"description":425},"/maps/_person","人物","包括虚拟人物在内的重要人物或角色",1771693391121]