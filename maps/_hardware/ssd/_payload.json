CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133,"children":134},"造物 / Make","/tools",[135,137,140,143,146,149,152],{"title":136,"_path":133},"🧰 工具收集",{"title":138,"_path":139},"📕 博客","/tools/blog",{"title":141,"_path":142},"🥥 Coconut","/tools/coconut",{"title":144,"_path":145},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":147,"_path":148},"🌐 AnySort","/tools/anysort",{"title":150,"_path":151},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":153,"_path":154},"👓 Crapto","/tools/crypto-inline",{"title":156,"_path":157,"children":158},"我 / About","/hire",[159],{"title":160,"_path":157},"📬 技术简历",{"title":162,"_path":163,"children":164},"En","/en",[165],{"title":166,"_path":167,"children":168},"🦁 Welcome","/en/articles",[169],{"title":166,"_path":167},{"_path":171,"_dir":172,"_draft":173,"_partial":174,"_locale":175,"title":176,"description":177,"body":178,"_type":373,"_id":374,"_source":375,"_file":376,"_stem":377,"_extension":378},"/maps/_hardware/ssd","_hardware",false,true,"","SSD（Solid State Driver）","SSD 是一种基于闪存技术的硬盘，相比传统的机械硬盘，它具有更快的读写速度、更低的延迟、更小的体积和更低的功耗。",{"type":179,"children":180,"toc":364},"root",[181,190,209,214,221,226,234,255,263,268,276,281,289,294,302,310,316,332],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"rtx-io",[187],{"type":188,"value":189},"text","RTX IO",{"type":182,"tag":191,"props":192,"children":193},"p",{},[194,200,205],{"type":182,"tag":195,"props":196,"children":199},"img",{"alt":197,"src":198},"games bottlenecked by traditional IO","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220406092957.png",[],{"type":182,"tag":195,"props":201,"children":204},{"alt":202,"src":203},"compressed data needed, but CPU cant keep up","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220406093020.png",[],{"type":182,"tag":195,"props":206,"children":208},{"alt":189,"src":207},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220406093202.png",[],{"type":182,"tag":183,"props":210,"children":212},{"id":211},"ssdsolid-state-driver",[213],{"type":188,"value":176},{"type":182,"tag":215,"props":216,"children":218},"h4",{"id":217},"vnand-是什么",[219],{"type":188,"value":220},"VNAND 是什么？",{"type":182,"tag":191,"props":222,"children":223},{},[224],{"type":188,"value":225},"SSD 的基本储存单位是 CTF 单元（Charge Trap Flash memoery cell），它通过控制电子的数量以电流通路来判断单个位的信息，即 0 或 1。2020 年，前沿的 CTF 单元可以单单元储存 4 Bits 的信息，且其控制电子的数量级可以保持 10 年（也即 SSD 的寿命）。",{"type":182,"tag":191,"props":227,"children":228},{},[229],{"type":182,"tag":195,"props":230,"children":233},{"alt":231,"src":232},"single CTF cell","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220324200320.png?w=40",[],{"type":182,"tag":191,"props":235,"children":236},{},[237,239,253],{"type":188,"value":238},"在 VNAND 技术中，CTF 单元在 Z 轴方向上，层叠 10 个在一起 ",{"type":182,"tag":240,"props":241,"children":242},"sup",{},[243],{"type":182,"tag":244,"props":245,"children":250},"a",{"href":246,"ariaDescribedBy":247,"dataFootnoteRef":175,"id":249},"#user-content-fn-string",[248],"footnote-label","user-content-fnref-string",[251],{"type":188,"value":252},"1",{"type":188,"value":254},"，在结构上形成串（String）。在读取时，控制栅（Control Gate）自底向上逐个询问单 CTF 单元的电荷水平，并向上信号到串顶端的位线（Bitline）上。同理，写入也必须通过控制栅逐层操作。",{"type":182,"tag":191,"props":256,"children":257},{},[258],{"type":182,"tag":195,"props":259,"children":262},{"alt":260,"src":261},"control gate & bitline","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220324201156.png?w=60",[],{"type":182,"tag":191,"props":264,"children":265},{},[266],{"type":188,"value":267},"每个控制栅连接了 32 个水平的 CTF，这叫页（Page）。可以发现，页和串分别共享了单个控制栅和单个位线。如果把页和串组成的平面结构，在 Z 轴方向层叠起来，就得到了行（Row）。行在 Y 轴方向排列，每 6 行又组成了一个块（Block）。我们已经知道了块在 X 轴方向的平面结构是行，剩下 Y、Z 轴向的平面也有名称，分别是列（Column）和层（Layer）。",{"type":182,"tag":191,"props":269,"children":270},{},[271],{"type":182,"tag":195,"props":272,"children":275},{"alt":273,"src":274},"Block's Structure","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220324202434.png?w=60",[],{"type":182,"tag":191,"props":277,"children":278},{},[279],{"type":188,"value":280},"要获得块中具体的单元的信息，我们需要从位线和控制栅中选定指定位置，所以就有了位线选择器（Bitline Selector）和控制栅选择器（Control Gate Selector）。这两者共同组成了行地址解析器（Row Decoder）。见下图，电信号从右边输入，通过了控制栅选择器，可以选中一整层的 CTF 单元。再配合位线选择器（图中未展示），就可以按页操作了。",{"type":182,"tag":191,"props":282,"children":283},{},[284],{"type":182,"tag":195,"props":285,"children":288},{"alt":286,"src":287},"选择器","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220324204211.png?w=60",[],{"type":182,"tag":191,"props":290,"children":291},{},[292],{"type":188,"value":293},"最后，单页的信号分别由内 CTF 单元对应的位线，经页缓存区（Page Buffer）汇集，就得到了一整页的信息。页缓存器是平面（Plane）的一部分；平面总共包括 VNAND 单元、行解析器、页缓存器和周边电路，而它最终会在 Z 轴方向层叠多层，塞进芯片中。",{"type":182,"tag":191,"props":295,"children":296},{},[297],{"type":182,"tag":195,"props":298,"children":301},{"alt":299,"src":300},"Plane","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220324205655.png?w=60",[],{"type":182,"tag":191,"props":303,"children":304},{},[305],{"type":182,"tag":195,"props":306,"children":309},{"alt":307,"src":308},"Chips","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220324210230.png?w=60",[],{"type":182,"tag":311,"props":312,"children":314},"h3",{"id":313},"阅读更多",[315],{"type":188,"value":313},{"type":182,"tag":317,"props":318,"children":319},"ul",{},[320],{"type":182,"tag":321,"props":322,"children":323},"li",{},[324],{"type":182,"tag":244,"props":325,"children":329},{"href":326,"rel":327},"https://www.bilibili.com/video/BV1WR4y1L7io",[328],"nofollow",[330],{"type":188,"value":331},"SSD 固态硬盘基本原理 Flash 闪存/VNAND 是如何工作的",{"type":182,"tag":333,"props":334,"children":337},"section",{"className":335,"dataFootnotes":175},[336],"footnotes",[338,345],{"type":182,"tag":183,"props":339,"children":342},{"className":340,"id":248},[341],"sr-only",[343],{"type":188,"value":344},"Footnotes",{"type":182,"tag":346,"props":347,"children":348},"ol",{},[349],{"type":182,"tag":321,"props":350,"children":352},{"id":351},"user-content-fn-string",[353,355],{"type":188,"value":354},"事实上，由于技术发展十分迅速，三星在 2019 年就可以层叠 136 个 CTF 为一个串了。同理，下文组成结构的数量只是一个示例，不代表真实世界的比例。 ",{"type":182,"tag":244,"props":356,"children":361},{"href":357,"ariaLabel":358,"className":359,"dataFootnoteBackref":175},"#user-content-fnref-string","Back to reference 1",[360],"data-footnote-backref",[362],{"type":188,"value":363},"↩",{"title":175,"searchDepth":365,"depth":365,"links":366},2,[367,368,372],{"id":185,"depth":365,"text":189},{"id":211,"depth":365,"text":176,"children":369},[370],{"id":313,"depth":371,"text":313},3,{"id":248,"depth":365,"text":344},"markdown","content:6.maps:_hardware:ssd.md","content","6.maps/_hardware/ssd.md","6.maps/_hardware/ssd","md",[380,384],{"_path":381,"title":382,"description":383},"/maps/_hardware/hardware","硬件","硬件是指计算机的物理部分，包括 CPU、内存、硬盘、显卡等。",{"_path":385,"title":386,"description":387},"/maps/_hire/intern","前端笔试题库","面向实习生或 B 端 3~5 年经验前端",1771214952541]