CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"body":181,"_type":376,"_id":377,"_source":378,"_file":379,"_stem":380,"_extension":381},"/maps/_hardware/ssd","_hardware",false,true,"","SSD（Solid State Driver）","SSD 是一种基于闪存技术的硬盘，相比传统的机械硬盘，它具有更快的读写速度、更低的延迟、更小的体积和更低的功耗。",{"type":182,"children":183,"toc":367},"root",[184,193,212,217,224,229,237,258,266,271,279,284,292,297,305,313,319,335],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"rtx-io",[190],{"type":191,"value":192},"text","RTX IO",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197,203,208],{"type":185,"tag":198,"props":199,"children":202},"img",{"alt":200,"src":201},"games bottlenecked by traditional IO","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220406092957.png",[],{"type":185,"tag":198,"props":204,"children":207},{"alt":205,"src":206},"compressed data needed, but CPU cant keep up","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220406093020.png",[],{"type":185,"tag":198,"props":209,"children":211},{"alt":192,"src":210},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220406093202.png",[],{"type":185,"tag":186,"props":213,"children":215},{"id":214},"ssdsolid-state-driver",[216],{"type":191,"value":179},{"type":185,"tag":218,"props":219,"children":221},"h4",{"id":220},"vnand-是什么",[222],{"type":191,"value":223},"VNAND 是什么？",{"type":185,"tag":194,"props":225,"children":226},{},[227],{"type":191,"value":228},"SSD 的基本储存单位是 CTF 单元（Charge Trap Flash memoery cell），它通过控制电子的数量以电流通路来判断单个位的信息，即 0 或 1。2020 年，前沿的 CTF 单元可以单单元储存 4 Bits 的信息，且其控制电子的数量级可以保持 10 年（也即 SSD 的寿命）。",{"type":185,"tag":194,"props":230,"children":231},{},[232],{"type":185,"tag":198,"props":233,"children":236},{"alt":234,"src":235},"single CTF cell","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220324200320.png?w=40",[],{"type":185,"tag":194,"props":238,"children":239},{},[240,242,256],{"type":191,"value":241},"在 VNAND 技术中，CTF 单元在 Z 轴方向上，层叠 10 个在一起 ",{"type":185,"tag":243,"props":244,"children":245},"sup",{},[246],{"type":185,"tag":247,"props":248,"children":253},"a",{"href":249,"ariaDescribedBy":250,"dataFootnoteRef":178,"id":252},"#user-content-fn-string",[251],"footnote-label","user-content-fnref-string",[254],{"type":191,"value":255},"1",{"type":191,"value":257},"，在结构上形成串（String）。在读取时，控制栅（Control Gate）自底向上逐个询问单 CTF 单元的电荷水平，并向上信号到串顶端的位线（Bitline）上。同理，写入也必须通过控制栅逐层操作。",{"type":185,"tag":194,"props":259,"children":260},{},[261],{"type":185,"tag":198,"props":262,"children":265},{"alt":263,"src":264},"control gate & bitline","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220324201156.png?w=60",[],{"type":185,"tag":194,"props":267,"children":268},{},[269],{"type":191,"value":270},"每个控制栅连接了 32 个水平的 CTF，这叫页（Page）。可以发现，页和串分别共享了单个控制栅和单个位线。如果把页和串组成的平面结构，在 Z 轴方向层叠起来，就得到了行（Row）。行在 Y 轴方向排列，每 6 行又组成了一个块（Block）。我们已经知道了块在 X 轴方向的平面结构是行，剩下 Y、Z 轴向的平面也有名称，分别是列（Column）和层（Layer）。",{"type":185,"tag":194,"props":272,"children":273},{},[274],{"type":185,"tag":198,"props":275,"children":278},{"alt":276,"src":277},"Block's Structure","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220324202434.png?w=60",[],{"type":185,"tag":194,"props":280,"children":281},{},[282],{"type":191,"value":283},"要获得块中具体的单元的信息，我们需要从位线和控制栅中选定指定位置，所以就有了位线选择器（Bitline Selector）和控制栅选择器（Control Gate Selector）。这两者共同组成了行地址解析器（Row Decoder）。见下图，电信号从右边输入，通过了控制栅选择器，可以选中一整层的 CTF 单元。再配合位线选择器（图中未展示），就可以按页操作了。",{"type":185,"tag":194,"props":285,"children":286},{},[287],{"type":185,"tag":198,"props":288,"children":291},{"alt":289,"src":290},"选择器","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220324204211.png?w=60",[],{"type":185,"tag":194,"props":293,"children":294},{},[295],{"type":191,"value":296},"最后，单页的信号分别由内 CTF 单元对应的位线，经页缓存区（Page Buffer）汇集，就得到了一整页的信息。页缓存器是平面（Plane）的一部分；平面总共包括 VNAND 单元、行解析器、页缓存器和周边电路，而它最终会在 Z 轴方向层叠多层，塞进芯片中。",{"type":185,"tag":194,"props":298,"children":299},{},[300],{"type":185,"tag":198,"props":301,"children":304},{"alt":302,"src":303},"Plane","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220324205655.png?w=60",[],{"type":185,"tag":194,"props":306,"children":307},{},[308],{"type":185,"tag":198,"props":309,"children":312},{"alt":310,"src":311},"Chips","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220324210230.png?w=60",[],{"type":185,"tag":314,"props":315,"children":317},"h3",{"id":316},"阅读更多",[318],{"type":191,"value":316},{"type":185,"tag":320,"props":321,"children":322},"ul",{},[323],{"type":185,"tag":324,"props":325,"children":326},"li",{},[327],{"type":185,"tag":247,"props":328,"children":332},{"href":329,"rel":330},"https://www.bilibili.com/video/BV1WR4y1L7io",[331],"nofollow",[333],{"type":191,"value":334},"SSD 固态硬盘基本原理 Flash 闪存/VNAND 是如何工作的",{"type":185,"tag":336,"props":337,"children":340},"section",{"className":338,"dataFootnotes":178},[339],"footnotes",[341,348],{"type":185,"tag":186,"props":342,"children":345},{"className":343,"id":251},[344],"sr-only",[346],{"type":191,"value":347},"Footnotes",{"type":185,"tag":349,"props":350,"children":351},"ol",{},[352],{"type":185,"tag":324,"props":353,"children":355},{"id":354},"user-content-fn-string",[356,358],{"type":191,"value":357},"事实上，由于技术发展十分迅速，三星在 2019 年就可以层叠 136 个 CTF 为一个串了。同理，下文组成结构的数量只是一个示例，不代表真实世界的比例。 ",{"type":185,"tag":247,"props":359,"children":364},{"href":360,"ariaLabel":361,"className":362,"dataFootnoteBackref":178},"#user-content-fnref-string","Back to reference 1",[363],"data-footnote-backref",[365],{"type":191,"value":366},"↩",{"title":178,"searchDepth":368,"depth":368,"links":369},2,[370,371,375],{"id":188,"depth":368,"text":192},{"id":214,"depth":368,"text":179,"children":372},[373],{"id":316,"depth":374,"text":316},3,{"id":251,"depth":368,"text":347},"markdown","content:6.maps:_hardware:ssd.md","content","6.maps/_hardware/ssd.md","6.maps/_hardware/ssd","md",[383,387],{"_path":384,"title":385,"description":386},"/maps/_hardware/hardware","硬件","硬件是指计算机的物理部分，包括 CPU、内存、硬盘、显卡等。",{"_path":388,"title":389,"description":390},"/maps/_hire/intern","前端笔试题库","面向实习生或 B 端 3~5 年经验前端",1771696723213]