外部特性和行为。技术架构设计是软件开发的重要环节，它决定了软件系统的质量、性能、可维护性和可扩展性。",{"type":179,"children":180,"toc":371},"root",[181,189,206,211,217,224,230,236,250,256,261,289,301,312,317,336,341,352,358],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"相关资料",[187],{"type":188,"value":185},"text",{"type":182,"tag":190,"props":191,"children":192},"ul",{},[193],{"type":182,"tag":194,"props":195,"children":196},"li",{},[197],{"type":182,"tag":198,"props":199,"children":203},"a",{"href":200,"rel":201},"https://bytebytego.com/guides/",[202],"nofollow",[204],{"type":188,"value":205},"System Design 101",{"type":182,"tag":183,"props":207,"children":209},{"id":208},"认证过程",[210],{"type":188,"value":208},{"type":182,"tag":212,"props":213,"children":215},"h3",{"id":214},"用户密码",[216],{"type":188,"value":214},{"type":182,"tag":218,"props":219,"children":221},"h4",{"id":220},"如何储存用户密码",[222],{"type":188,"value":223},"如何储存用户密码？",{"type":182,"tag":225,"props":226,"children":227},"p",{},[228],{"type":188,"value":229},"除开双因素认证等鉴权方式，单看用户密码的落库。一般人都知道不能明文存储，但是简单的加密也并不安全：MD5、SHA-1、SHA-256 等哈希算法，都可以通过彩虹表等方式破解。所以，一般会选择加盐哈希算法，比如 bcrypt、scrypt，并采用多层加密策略。",{"type":182,"tag":218,"props":231,"children":233},{"id":232},"加盐过程有哪些容易出现的错误",[234],{"type":188,"value":235},"加盐过程有哪些容易出现的错误？",{"type":182,"tag":225,"props":237,"children":238},{},[239,241,248],{"type":188,"value":240},"盐太短或重复使用都会导致问题，此外，应该使用安全的随机函数生成盐，如 C/C++ 的 ",{"type":182,"tag":242,"props":243,"children":245},"code",{"className":244},[],[246],{"type":188,"value":247},"CryptGenRandom",{"type":188,"value":249},"。",{"type":182,"tag":218,"props":251,"children":253},{"id":252},"什么是-password-hashing",[254],{"type":188,"value":255},"什么是 Password Hashing？",{"type":182,"tag":225,"props":257,"children":258},{},[259],{"type":188,"value":260},"加盐哈希在现代计算机来看已经不够安全，Password Hashing 应当能应付以下几种攻击：",{"type":182,"tag":190,"props":262,"children":263},{},[264,269,274,279,284],{"type":182,"tag":194,"props":265,"children":266},{},[267],{"type":188,"value":268},"加密算法破解（原值还原、哈希碰撞等）",{"type":182,"tag":194,"props":270,"children":271},{},[272],{"type":188,"value":273},"查表、彩虹表",{"type":182,"tag":194,"props":275,"children":276},{},[277],{"type":188,"value":278},"CPU 优化攻击",{"type":182,"tag":194,"props":280,"children":281},{},[282],{"type":188,"value":283},"GPU、FPGA、ASIC 等专用硬件攻击",{"type":182,"tag":194,"props":285,"children":286},{},[287],{"type":188,"value":288},"旁路攻击：通过检测电磁波、功耗等信息来推算信息",{"type":182,"tag":225,"props":290,"children":291},{},[292,294],{"type":188,"value":293},"见：",{"type":182,"tag":198,"props":295,"children":298},{"href":296,"rel":297},"https://www.cnblogs.com/xinzhao/p/6035847.html",[202],[299],{"type":188,"value":300},"用户密码加密存储十问十答，一文说透密码安全存储",{"type":182,"tag":218,"props":302,"children":304},{"id":303},"how-dropbox-securely-stores-your-passwords",[305],{"type":182,"tag":198,"props":306,"children":309},{"href":307,"rel":308},"https://dropbox.tech/security/how-dropbox-securely-stores-your-passwords",[202],[310],{"type":188,"value":311},"How Dropbox securely stores your passwords",{"type":182,"tag":225,"props":313,"children":314},{},[315],{"type":188,"value":316},"Dropbox 的密码存储策略是什么",{"type":182,"tag":318,"props":319,"children":320},"ol",{},[321,326,331],{"type":182,"tag":194,"props":322,"children":323},{},[324],{"type":188,"value":325},"将用户密码使用 sha256 归一化，因为 bcrypt 的结果对长度敏感",{"type":182,"tag":194,"props":327,"children":328},{},[329],{"type":188,"value":330},"使用 bcrypt 每用户加盐加密",{"type":182,"tag":194,"props":332,"children":333},{},[334],{"type":188,"value":335},"使用 AES256 全局加密，并使用专用的硬件及定期更换策略等",{"type":182,"tag":225,"props":337,"children":338},{},[339],{"type":188,"value":340},"此外，Dropbox 表示也在关注 Argon2 等竞赛新秀。",{"type":182,"tag":218,"props":342,"children":344},{"id":343},"how-instagram-scaled-to-14-million-users-with-only-3-engineers",[345],{"type":182,"tag":198,"props":346,"children":349},{"href":347,"rel":348},"https://read.engineerscodex.com/p/how-instagram-scaled-to-14-million",[202],[350],{"type":188,"value":351},"