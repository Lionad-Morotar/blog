字电路设计、原码反码补码等核心概念的详细解析。",{"type":182,"children":183,"toc":409},"root",[184,192,199,214,220,226,285,290,296,301,307,325,339,345,350,373,379,392,398],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"进制",[190],{"type":191,"value":188},"text",{"type":185,"tag":193,"props":194,"children":196},"h4",{"id":195},"十进制如何转二进制",[197],{"type":191,"value":198},"十进制如何转二进制？",{"type":185,"tag":200,"props":201,"children":202},"ul",{},[203,209],{"type":185,"tag":204,"props":205,"children":206},"li",{},[207],{"type":191,"value":208},"整数除二倒序取余",{"type":185,"tag":204,"props":210,"children":211},{},[212],{"type":191,"value":213},"小数乘二顺序取整",{"type":185,"tag":193,"props":215,"children":217},{"id":216},"十进制转二进制的示例",[218],{"type":191,"value":219},"十进制转二进制的示例？",{"type":185,"tag":221,"props":222,"children":223},"p",{},[224],{"type":191,"value":225},"以 $(4.1)_{10}$ 为例，先算小数部分，再算整数部分：",{"type":185,"tag":227,"props":228,"children":229},"ol",{},[230,235,240,245,250,255,260,265,270,275,280],{"type":185,"tag":204,"props":231,"children":232},{},[233],{"type":191,"value":234},"$0.1;*;2;=;0.2$，得整数位 $0$，取小数位 $0.2$ 继续运算；",{"type":185,"tag":204,"props":236,"children":237},{},[238],{"type":191,"value":239},"$0.2;*;2;=;0.4$，得整数位 $0$，取小数位 $0.4$ 继续运算；",{"type":185,"tag":204,"props":241,"children":242},{},[243],{"type":191,"value":244},"$0.4;*;2;=;0.8$，得整数位 $0$，取小数位 $0.8$ 继续运算；",{"type":185,"tag":204,"props":246,"children":247},{},[248],{"type":191,"value":249},"$0.8;*;2;=;1.6$，得整数位 $1$，取小数位 $0.6$ 继续运算；",{"type":185,"tag":204,"props":251,"children":252},{},[253],{"type":191,"value":254},"$0.6;*;2;=;1.2$，得整数位 $1$，取小数位 $0.2$ 继续运算（从第二步开始循环）；",{"type":185,"tag":204,"props":256,"children":257},{},[258],{"type":191,"value":259},"得 $(0.1)_{10}$ 转为二进制的结果：$(0.0\\overline{0011})_2$",{"type":185,"tag":204,"props":261,"children":262},{},[263],{"type":191,"value":264},"$4;mod;2 = 0$，得余数 $0$，取结果 $4;/;2 = 2$ 继续运算；",{"type":185,"tag":204,"props":266,"children":267},{},[268],{"type":191,"value":269},"$2;mod;2 = 0$，得余数 $0$，取结果 $2;/;2 = 1$ 继续运算；",{"type":185,"tag":204,"props":271,"children":272},{},[273],{"type":191,"value":274},"$1;mod;2 = 1$，得余数 $1$，结束运算；",{"type":185,"tag":204,"props":276,"children":277},{},[278],{"type":191,"value":279},"得 $(4)_{10}$ 的二进制结果：$(100)_2$",{"type":185,"tag":204,"props":281,"children":282},{},[283],{"type":191,"value":284},"得 $(4.1)_{10}$ 的二进制结果：$(100.0\\overline{0011})_2$，可以用 (4.1).toString(2) 验证一下。",{"type":185,"tag":186,"props":286,"children":288},{"id":287},"数字电路",[289],{"type":191,"value":287},{"type":185,"tag":193,"props":291,"children":293},{"id":292},"为什么减法要转换为加法的形式",[294],{"type":191,"value":295},"为什么减法要转换为加法的形式？",{"type":185,"tag":221,"props":297,"children":298},{},[299],{"type":191,"value":300},"负数在用原码表示时，需要在最高位带上符号。但是加减乘法作为最基础的运算，其电路应该设计得简单，识别\"符号位\"会让基础电路变得复杂，所以需要一种算法来把基础运算转换为二进制加法。使用反码计算减法会带来正负零的问题，使用补码则不会发生异常。",{"type":185,"tag":193,"props":302,"children":304},{"id":303},"什么是原码反码和补码",[305],{"type":191,"value":306},"什么是原码反码和补码？",{"type":185,"tag":200,"props":308,"children":309},{},[310,315,320],{"type":185,"tag":204,"props":311,"children":312},{},[313],{"type":191,"value":314},"最高位为符号位,其余为数值位，这是原码",{"type":185,"tag":204,"props":316,"children":317},{},[318],{"type":191,"value":319},"正数的反码为其本身，负数的反码为值位取反",{"type":185,"tag":204,"props":321,"children":322},{},[323],{"type":191,"value":324},"正数的补码为其本身，负数的补码为其反码加一（符号位不进位）",{"type":185,"tag":221,"props":326,"children":327},{},[328,330],{"type":191,"value":329},"见：",{"type":185,"tag":331,"props":332,"children":336},"a",{"href":333,"rel":334},"http://www.atoolbox.net/Tool.php?Id=952",[335],"nofollow",[337],{"type":191,"value":338},"原码/反码/补码计算器",{"type":185,"tag":193,"props":340,"children":342},{"id":341},"使用补码进行减法的示例",[343],{"type":191,"value":344},"使用补码进行减法的示例？",{"type":185,"tag":221,"props":346,"children":347},{},[348],{"type":191,"value":349},"以四位整形举例如下，计算表达式 $5 - 2$：",{"type":185,"tag":227,"props":351,"children":352},{},[353,358,363,368],{"type":185,"tag":204,"props":354,"children":355},{},[356],{"type":191,"value":357},"将减法用加法表示为 $5 + (-2)$。",{"type":185,"tag":204,"props":359,"children":360},{},[361],{"type":191,"value":362},"$5$ 是正数，直接得补码 $0101$。",{"type":185,"tag":204,"props":364,"children":365},{},[366],{"type":191,"value":367},"$-2$ 的原码是 $1010$，数值位取反得 $1101$，最后数值位加一得补码 $1110$。",{"type":185,"tag":204,"props":369,"children":370},{},[371],{"type":191,"value":372},"补码相加，$0101 + 1110$，得 $0011$，换算回十进制，答案是 $3$。",{"type":185,"tag":193,"props":374,"children":376},{"id":375},"_8-位补码的极值是多少",[377],{"type":191,"value":378},"8 位补码的极值是多少？",{"type":185,"tag":221,"props":380,"children":381},{},[382,384,390],{"type":191,"value":383},"8 位补码正数的最大值是 $01111111$，即 $(127)",{"type":185,"tag":385,"props":386,"children":387},"em",{},[388],{"type":191,"value":389},"{10}$。因为补码没有负零，所以其负数的最小值为 $-(127 - 1)",{"type":191,"value":391},"{10}$，即 $(-128)_{10}$",{"type":185,"tag":186,"props":393,"children":395},{"id":394},"todo",[396],{"type":191,"value":397},"TODO",{"type":185,"tag":193,"props":399,"children":401},{"id":400},"原码-反码-补码详解",[402],{"type":185,"tag":331,"props":403,"children":406},{"href":404,"rel":405},"https://www.cnblogs.com/zhangziqiu/archive/2011/03/30/ComputerCode.html",[335],[407],{"type":191,"value":408},"原码, 反码, 补码详解",{"title":178,"searchDepth":410,"depth":410,"links":411},2,[412,413,414],{"id":188,"depth":410,"text":188},{"id":287,"depth":410,"text":287},{"id":394,"depth":410,"text":397},"markdown","content:6.maps:_computer:computer.md","content","6.maps/_computer/computer.md","6.maps/_computer/computer","md",[422,426],{"_path":423,"title":424,"description":425},"/maps/_company/company","公司","注册和经营的流程及注意事项",{"_path":427,"title":428,"description":429},"/maps/_computer/encoding","编码","编码是将信息从一种形式或格式转换为另一种形式或格式的过程。",1771695778368]