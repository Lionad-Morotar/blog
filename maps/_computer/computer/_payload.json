oc":406},"root",[181,189,196,211,217,223,282,287,293,298,304,322,336,342,347,370,376,389,395],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"进制",[187],{"type":188,"value":185},"text",{"type":182,"tag":190,"props":191,"children":193},"h4",{"id":192},"十进制如何转二进制",[194],{"type":188,"value":195},"十进制如何转二进制？",{"type":182,"tag":197,"props":198,"children":199},"ul",{},[200,206],{"type":182,"tag":201,"props":202,"children":203},"li",{},[204],{"type":188,"value":205},"整数除二倒序取余",{"type":182,"tag":201,"props":207,"children":208},{},[209],{"type":188,"value":210},"小数乘二顺序取整",{"type":182,"tag":190,"props":212,"children":214},{"id":213},"十进制转二进制的示例",[215],{"type":188,"value":216},"十进制转二进制的示例？",{"type":182,"tag":218,"props":219,"children":220},"p",{},[221],{"type":188,"value":222},"以 $(4.1)_{10}$ 为例，先算小数部分，再算整数部分：",{"type":182,"tag":224,"props":225,"children":226},"ol",{},[227,232,237,242,247,252,257,262,267,272,277],{"type":182,"tag":201,"props":228,"children":229},{},[230],{"type":188,"value":231},"$0.1;*;2;=;0.2$，得整数位 $0$，取小数位 $0.2$ 继续运算；",{"type":182,"tag":201,"props":233,"children":234},{},[235],{"type":188,"value":236},"$0.2;*;2;=;0.4$，得整数位 $0$，取小数位 $0.4$ 继续运算；",{"type":182,"tag":201,"props":238,"children":239},{},[240],{"type":188,"value":241},"$0.4;*;2;=;0.8$，得整数位 $0$，取小数位 $0.8$ 继续运算；",{"type":182,"tag":201,"props":243,"children":244},{},[245],{"type":188,"value":246},"$0.8;*;2;=;1.6$，得整数位 $1$，取小数位 $0.6$ 继续运算；",{"type":182,"tag":201,"props":248,"children":249},{},[250],{"type":188,"value":251},"$0.6;*;2;=;1.2$，得整数位 $1$，取小数位 $0.2$ 继续运算（从第二步开始循环）；",{"type":182,"tag":201,"props":253,"children":254},{},[255],{"type":188,"value":256},"得 $(0.1)_{10}$ 转为二进制的结果：$(0.0\\overline{0011})_2$",{"type":182,"tag":201,"props":258,"children":259},{},[260],{"type":188,"value":261},"$4;mod;2 = 0$，得余数 $0$，取结果 $4;/;2 = 2$ 继续运算；",{"type":182,"tag":201,"props":263,"children":264},{},[265],{"type":188,"value":266},"$2;mod;2 = 0$，得余数 $0$，取结果 $2;/;2 = 1$ 继续运算；",{"type":182,"tag":201,"props":268,"children":269},{},[270],{"type":188,"value":271},"$1;mod;2 = 1$，得余数 $1$，结束运算；",{"type":182,"tag":201,"props":273,"children":274},{},[275],{"type":188,"value":276},"得 $(4)_{10}$ 的二进制结果：$(100)_2$",{"type":182,"tag":201,"props":278,"children":279},{},[280],{"type":188,"value":281},"得 $(4.1)_{10}$ 的二进制结果：$(100.0\\overline{0011})_2$，可以用 (4.1).toString(2) 验证一下。",{"type":182,"tag":183,"props":283,"children":285},{"id":284},"数字电路",[286],{"type":188,"value":284},{"type":182,"tag":190,"props":288,"children":290},{"id":289},"为什么减法要转换为加法的形式",[291],{"type":188,"value":292},"为什么减法要转换为加法的形式？",{"type":182,"tag":218,"props":294,"children":295},{},[296],{"type":188,"value":297},"负数在用原码表示时，需要在最高位带上符号。但是加减乘法作为最基础的运算，其电路应该设计得简单，识别\"符号位\"会让基础电路变得复杂，所以需要一种算法来把基础运算转换为二进制加法。使用反码计算减法会带来正负零的问题，使用补码则不会发生异常。",{"type":182,"tag":190,"props":299,"children":301},{"id":300},"什么是原码反码和补码",[302],{"type":188,"value":303},"什么是原码反码和补码？",{"type":182,"tag":197,"props":305,"children":306},{},[307,312,317],{"type":182,"tag":201,"props":308,"children":309},{},[310],{"type":188,"value":311},"最高位为符号位,其余为数值位，这是原码",{"type":182,"tag":201,"props":313,"children":314},{},[315],{"type":188,"value":316},"正数的反码为其本身，负数的反码为值位取反",{"type":182,"tag":201,"props":318,"children":319},{},[320],{"type":188,"value":321},"正数的补码为其本身，负数的补码为其反码加一（符号位不进位）",{"type":182,"tag":218,"props":323,"children":324},{},[325,327],{"type":188,"value":326},"见：",{"type":182,"tag":328,"props":329,"children":333},"a",{"href":330,"rel":331},"http://www.atoolbox.net/Tool.php?Id=952",[332],"nofollow",[334],{"type":188,"value":335},"原码/反码/补码计算器",{"type":182,"tag":190,"props":337,"children":339},{"id":338},"使用补码进行减法的示例",[340],{"type":188,"value":341},"使用补码进行减法的示例？",{"type":182,"tag":218,"props":343,"children":344},{},[345],{"type":188,"value":346},"以四位整形举例如下，计算表达式 $5 - 2$：",{"type":182,"tag":224,"props":348,"children":349},{},[350,355,360,365],{"type":182,"tag":201,"props":351,"children":352},{},[353],{"type":188,"value":354},"将减法用加法表示为 $5 + (-2)$。",{"type":182,"tag":201,"props":356,"children":357},{},[358],{"type":188,"value":359},"$5$ 是正数，直接得补码 $0101$。",{"type":182,"tag":201,"props":361,"children":362},{},[363],{"type":188,"value":364},"$-2$ 的原码是 $1010$，数值位取反得 $1101$，最后数值位加一得补码 $1110$。",{"type":182,"tag":201,"props":366,"children":367},{},[368],{"type":188,"value":369},"补码相加，$0101 + 1110$，得 $0011$，换算回十进制，答案是 $3$。",{"type":182,"tag":190,"props":371,"children":373},{"id":372},"_8-位补码的极值是多少",[374],{"type":188,"value":375},"8 位补码的极值是多少？",{"type":182,"tag":218,"props":377,"children":378},{},[379,381,387],{"type":188,"value":380},"8 位补码正数的最大值是 $01111111$，即 $(127)",{"type":182,"tag":382,"props":383,"children":384},"em",{},[385],{"type":188,"value":386},"{10}$。因为补码没有负零，所以其负数的最小值为 $-(127 - 1)",{"type":188,"value":388},"{10}$，即 $(-128)_{10}$",{"type":182,"tag":183,"props":390,"children":392},{"id":391},"todo",[393],{"type":188,"value":394},"TODO",{"type":182,"tag":190,"props":396,"children":398},{"id":397},"原码-反码-补码详解",[399],{"type":182,"tag":328,"props":400,"children":403},{"href":401,"rel":402},"https://www.cnblogs.com/zhangziqiu/archive/2011/03/30/ComputerCode.html",[332],[404],{"type":188,"value":405},"原码, 反码, 补码详解",{"title":175,"searchDepth":407,"depth":407,"links":408},2,[409,410,411],{"id":185,"depth":407,"text":185},{"id":284,"depth":407,"text":284},{"id":391,"depth":407,"text":394},"markdown","content:6.maps:_computer:computer.md","content","6.maps/_computer/computer.md","6.maps/_computer/computer","md",[419,423],{"_path":420,"title":421,"description":422},"/maps/_company/company","公司","注册和经营的流程及注意事项",{"_path":424,"title":425,"description":426},"/maps/_computer/encoding","编码","编码是将信息从一种形式或格式转换为另一种形式或格式的过程。",1771214926761]