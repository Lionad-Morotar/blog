"children":180,"toc":1192},"root",[181,200,206,213,219,228,234,240,245,257,263,271,277,282,290,296,301,309,315,320,328,334,339,357,369,375,380,403,409,415,573,579,584,589,594,600,605,611,616,624,634,640,645,651,656,662,667,690,695,700,705,710,730,736,741,749,760,766,777,782,805,810,817,822,828,836,850,856,863,868,873,878,884,889,896,902,907,915,921,927,938,944,949,957,963,968,979,985,990,995,1001,1006,1012,1026,1037,1043,1048,1061,1067,1073,1078,1083,1089,1094,1100,1105,1110,1116,1121,1127,1132,1138,1143,1163,1174,1179],{"type":182,"tag":183,"props":184,"children":185},"element","ul",{},[186],{"type":182,"tag":187,"props":188,"children":189},"li",{},[190],{"type":182,"tag":191,"props":192,"children":196},"a",{"href":193,"rel":194},"https://beej.us/guide/bgnet0/html/split/index.html",[195],"nofollow",[197],{"type":198,"value":199},"text","Beej's Guide to Network Concepts",{"type":182,"tag":201,"props":202,"children":204},"h2",{"id":203},"网络模型",[205],{"type":198,"value":203},{"type":182,"tag":207,"props":208,"children":210},"h4",{"id":209},"各网络层有哪些代表性的协议",[211],{"type":198,"value":212},"各网络层有哪些代表性的协议？",{"type":182,"tag":214,"props":215,"children":216},"p",{},[217],{"type":198,"value":218},"应用层有 HTTP、DNS、FTP，表示层有 SSL、TSL、base64、MIDI、JPEG，会话层有 xxx，传输层则是 TCP、UDP，网络层有 IP，数据链路层 xxx，物理层有以太网协议。",{"type":182,"tag":214,"props":220,"children":221},{},[222],{"type":182,"tag":223,"props":224,"children":227},"img",{"alt":225,"src":226},"OSI 参考模型","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220620033400.png?type=win11&w=60",[],{"type":182,"tag":201,"props":229,"children":231},{"id":230},"tcp",[232],{"type":198,"value":233},"TCP",{"type":182,"tag":207,"props":235,"children":237},{"id":236},"tcpip-是什么",[238],{"type":198,"value":239},"TCP/IP 是什么？",{"type":182,"tag":214,"props":241,"children":242},{},[243],{"type":198,"value":244},"TCP/IP 协议是一个协议集。TCP/IP 包括了应用层、传输层、网络层、数据链路层和网络层，是一个四层体系结构。各层有代表性的协议有 HTTP、DNS，TLS，IP 和 xxx。",{"type":182,"tag":214,"props":246,"children":247},{},[248,250],{"type":198,"value":249},"TODO，",{"type":182,"tag":191,"props":251,"children":254},{"href":252,"rel":253},"https://developer.51cto.com/article/597961.html",[195],[255],{"type":198,"value":256},"终于有人能把 TCP/IP 协议讲的明明白白了！",{"type":182,"tag":207,"props":258,"children":260},{"id":259},"tcp-header-由哪些部分组成",[261],{"type":198,"value":262},"TCP Header 由哪些部分组成？",{"type":182,"tag":214,"props":264,"children":265},{},[266],{"type":182,"tag":223,"props":267,"children":270},{"alt":268,"src":269},"TCP Header","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200731153510.png?type=win11&w=60",[],{"type":182,"tag":207,"props":272,"children":274},{"id":273},"三次握手具体过程",[275],{"type":198,"value":276},"三次握手具体过程？",{"type":182,"tag":214,"props":278,"children":279},{},[280],{"type":198,"value":281},"从三次握手图示可以发现，仅仅是连接的建立，就需要大量时间消耗。客户端想发送数据，至少要等 1.5xRTT；服务端想发送数据，至少要 2xRTT。",{"type":182,"tag":214,"props":283,"children":284},{},[285],{"type":182,"tag":223,"props":286,"children":289},{"alt":287,"src":288},"Three-way Handshake","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200731162450.png?type=win11&w=40",[],{"type":182,"tag":207,"props":291,"children":293},{"id":292},"tcp-fast-open-如何优化握手过程",[294],{"type":198,"value":295},"TCP Fast Open 如何优化握手过程？",{"type":182,"tag":214,"props":297,"children":298},{},[299],{"type":198,"value":300},"TFO 规定服务器第一次返回 ACK 时，携带一个用以标志客户端身份的 Cookie。后续客户端发送 SYN 建立连接的时候带上这个 Cookie，服务端确认身份之后，就能直接返回数据了（节约了 1.5 RTT）。",{"type":182,"tag":214,"props":302,"children":303},{},[304],{"type":182,"tag":223,"props":305,"children":308},{"alt":306,"src":307},"TFO","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200807054219.png?type=win11&w=80",[],{"type":182,"tag":207,"props":310,"children":312},{"id":311},"四次挥手的具体过程",[313],{"type":198,"value":314},"四次挥手的具体过程？",{"type":182,"tag":214,"props":316,"children":317},{},[318],{"type":198,"value":319},"四次挥手如下所示。为什么建立连接要三次，而断开连接要四次请求呢？从图中可以看出，接收到 FIN 请求时，服务端立即返回 ACK 表示收到请求，但是要等自己这边剩余一些工作（可能时未发送完的请求内容）完成之后，才会返回 FIN。",{"type":182,"tag":214,"props":321,"children":322},{},[323],{"type":182,"tag":223,"props":324,"children":327},{"alt":325,"src":326},"Four-way Wavehand","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200731165331.png?type=win11&w=40",[],{"type":182,"tag":207,"props":329,"children":331},{"id":330},"tcp-链接中如果某端出故障了会怎么办",[332],{"type":198,"value":333},"TCP 链接中如果某端出故障了会怎么办？",{"type":182,"tag":214,"props":335,"children":336},{},[337],{"type":198,"value":338},"会通过计时器来保证链接的稳定性。",{"type":182,"tag":183,"props":340,"children":341},{},[342,347,352],{"type":182,"tag":187,"props":343,"children":344},{},[345],{"type":198,"value":346},"超时重传计时器：对方没有返回 ACK 时，发送方需要重新发送数据。一般计时器的时间选择 2RTT。",{"type":182,"tag":187,"props":348,"children":349},{},[350],{"type":198,"value":351},"2MSL 定时器：主动断开连接的一方发送 FIN 后需要等待 2MSL 时间。因为如果服务端没有收到最后一个 ACK，它将重新发送 FIN。",{"type":182,"tag":187,"props":353,"children":354},{},[355],{"type":198,"value":356},"保活计时器：每当接收方收到消息，将计时器重设为两小时。计时器到期时，每 75s 发送一次探测报文段，如果连续 10 次都没有被响应则断开连接。",{"type":182,"tag":214,"props":358,"children":359},{},[360,362],{"type":198,"value":361},"见：",{"type":182,"tag":191,"props":363,"children":366},{"href":364,"rel":365},"https://www.cnblogs.com/13224ACMer/p/6616960.html",[195],[367],{"type":198,"value":368},"TCP 四种计时器",{"type":182,"tag":201,"props":370,"children":372},{"id":371},"udp",[373],{"type":198,"value":374},"UDP",{"type":182,"tag":214,"props":376,"children":377},{},[378],{"type":198,"value":379},"UDP，即 User Datagram Protocol 用户数据报协议。数据报不保证信息的传达是否到位，所以 UDP 也被普遍称作 Unreliable Datagram Protocol。",{"type":182,"tag":183,"props":381,"children":382},{},[383,388,393,398],{"type":182,"tag":187,"props":384,"children":385},{},[386],{"type":198,"value":387},"不保证消息交付",{"type":182,"tag":187,"props":389,"children":390},{},[391],{"type":198,"value":392},"不保证交付顺序",{"type":182,"tag":187,"props":394,"children":395},{},[396],{"type":198,"value":397},"不跟踪连接状态",{"type":182,"tag":187,"props":399,"children":400},{},[401],{"type":198,"value":402},"不需要拥塞控制",{"type":182,"tag":201,"props":404,"children":406},{"id":405},"http",[407],{"type":198,"value":408},"HTTP",{"type":182,"tag":207,"props":410,"children":412},{"id":411},"有哪些常见的状态码",[413],{"type":198,"value":414},"有哪些常见的状态码？",{"type":182,"tag":416,"props":417,"children":418},"table",{},[419,438],{"type":182,"tag":420,"props":421,"children":422},"thead",{},[423],{"type":182,"tag":424,"props":425,"children":426},"tr",{},[427,433],{"type":182,"tag":428,"props":429,"children":430},"th",{},[431],{"type":198,"value":432},"状态码",{"type":182,"tag":428,"props":434,"children":435},{},[436],{"type":198,"value":437},"描述",{"type":182,"tag":439,"props":440,"children":441},"tbody",{},[442,456,469,482,495,508,521,534,547,560],{"type":182,"tag":424,"props":443,"children":444},{},[445,451],{"type":182,"tag":446,"props":447,"children":448},"td",{},[449],{"type":198,"value":450},"200",{"type":182,"tag":446,"props":452,"children":453},{},[454],{"type":198,"value":455},"成功并返回数据",{"type":182,"tag":424,"props":457,"children":458},{},[459,464],{"type":182,"tag":446,"props":460,"children":461},{},[462],{"type":198,"value":463},"301",{"type":182,"tag":446,"props":465,"children":466},{},[467],{"type":198,"value":468},"永久转移，重定向",{"type":182,"tag":424,"props":470,"children":471},{},[472,477],{"type":182,"tag":446,"props":473,"children":474},{},[475],{"type":198,"value":476},"302",{"type":182,"tag":446,"props":478,"children":479},{},[480],{"type":198,"value":481},"临时重定向",{"type":182,"tag":424,"props":483,"children":484},{},[485,490],{"type":182,"tag":446,"props":486,"children":487},{},[488],{"type":198,"value":489},"303",{"type":182,"tag":446,"props":491,"children":492},{},[493],{"type":198,"value":494},"临时重定向（客户端必须使用 Get 方法重新请求资源）",{"type":182,"tag":424,"props":496,"children":497},{},[498,503],{"type":182,"tag":446,"props":499,"children":500},{},[501],{"type":198,"value":502},"304",{"type":182,"tag":446,"props":504,"children":505},{},[506],{"type":198,"value":507},"资源未修改，可使用缓存",{"type":182,"tag":424,"props":509,"children":510},{},[511,516],{"type":182,"tag":446,"props":512,"children":513},{},[514],{"type":198,"value":515},"400",{"type":182,"tag":446,"props":517,"children":518},{},[519],{"type":198,"value":520},"请求语法错误",{"type":182,"tag":424,"props":522,"children":523},{},[524,529],{"type":182,"tag":446,"props":525,"children":526},{},[527],{"type":198,"value":528},"401",{"type":182,"tag":446,"props":530,"children":531},{},[532],{"type":198,"value":533},"要求身份认证",{"type":182,"tag":424,"props":535,"children":536},{},[537,542],{"type":182,"tag":446,"props":538,"children":539},{},[540],{"type":198,"value":541},"403",{"type":182,"tag":446,"props":543,"children":544},{},[545],{"type":198,"value":546},"请求拒绝",{"type":182,"tag":424,"props":548,"children":549},{},[550,555],{"type":182,"tag":446,"props":551,"children":552},{},[553],{"type":198,"value":554},"404",{"type":182,"tag":446,"props":556,"children":557},{},[558],{"type":198,"value":559},"资源不存在",{"type":182,"tag":424,"props":561,"children":562},{},[563,568],{"type":182,"tag":446,"props":564,"children":565},{},[566],{"type":198,"value":567},"500",{"type":182,"tag":446,"props":569,"children":570},{},[571],{"type":198,"value":572},"服务器错误",{"type":182,"tag":207,"props":574,"children":576},{"id":575},"http-报文由哪些部分组成",[577],{"type":198,"value":578},"HTTP 报文由哪些部分组成？",{"type":182,"tag":214,"props":580,"children":581},{},[582],{"type":198,"value":583},"请求报文由请求行、请求头、空行和请求数据组成，相应报文类似。",{"type":182,"tag":214,"props":585,"children":586},{},[587],{"type":198,"value":588},"请求报文实例：",{"type":182,"tag":214,"props":590,"children":591},{},[592],{"type":198,"value":593},"相应报文实例：",{"type":182,"tag":207,"props":595,"children":597},{"id":596},"http-11-对比-http-10-做了哪些改进",[598],{"type":198,"value":599},"HTTP 1.1 对比 HTTP 1.0 做了哪些改进？",{"type":182,"tag":214,"props":601,"children":602},{},[603],{"type":198,"value":604},"长链接（keep-alive）、断点续传、HTTP 缓存。",{"type":182,"tag":207,"props":606,"children":608},{"id":607},"http-缓存分几种",[609],{"type":198,"value":610},"HTTP 缓存分几种？",{"type":182,"tag":214,"props":612,"children":613},{},[614],{"type":198,"value":615},"分强缓存和协商缓存：Expires、Cache-Control、Last-Modified、Etag。",{"type":182,"tag":214,"props":617,"children":618},{},[619],{"type":182,"tag":223,"props":620,"children":623},{"alt":621,"src":622},"HTTP Cache","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220630205606.png?type=win11&w=60",[],{"type":182,"tag":214,"props":625,"children":626},{},[627,628],{"type":198,"value":249},{"type":182,"tag":191,"props":629,"children":632},{"href":630,"rel":631},"https://imweb.io/topic/55c6f9bac222e3af6ce235b9",[195],[633],{"type":198,"value":630},{"type":182,"tag":207,"props":635,"children":637},{"id":636},"强缓存和协商缓存的主要区别是",[638],{"type":198,"value":639},"强缓存和协商缓存的主要区别是？",{"type":182,"tag":214,"props":641,"children":642},{},[643],{"type":198,"value":644},"强缓存是一但匹配就无条件使用缓存，而面对协商缓存的资源，浏览器需要向服务端发请求，对比资源是否变更，并依靠服务端的响应来判断是否使用缓存。如果资源同时应用了强缓存和协商缓存，那么浏览器优先使用强缓存。",{"type":182,"tag":207,"props":646,"children":648},{"id":647},"no-store-和-no-cache-的区别",[649],{"type":198,"value":650},"no-store 和 no-cache 的区别？",{"type":182,"tag":214,"props":652,"children":653},{},[654],{"type":198,"value":655},"no-store 告诉客户端每次都在服务器取最新的资源。no-cache 也要求每次都要重新请求，但服务器可能返回 304 告诉客户端资源未改变。",{"type":182,"tag":207,"props":657,"children":659},{"id":658},"http2-的改进在哪里",[660],{"type":198,"value":661},"HTTP2 的改进在哪里？",{"type":182,"tag":214,"props":663,"children":664},{},[665],{"type":198,"value":666},"HTTP/2 主要包含以下几个方面的变化，显著增强了性能，也增加了安全性。",{"type":182,"tag":183,"props":668,"children":669},{},[670,675,680,685],{"type":182,"tag":187,"props":671,"children":672},{},[673],{"type":198,"value":674},"二进制分帧层",{"type":182,"tag":187,"props":676,"children":677},{},[678],{"type":198,"value":679},"头部压缩（HPACK、Huffman）",{"type":182,"tag":187,"props":681,"children":682},{},[683],{"type":198,"value":684},"多路复用",{"type":182,"tag":187,"props":686,"children":687},{},[688],{"type":198,"value":689},"服务端推送",{"type":182,"tag":214,"props":691,"children":692},{},[693],{"type":198,"value":694},"二进制分帧层是在应用层（HTTP）和传输层（TCP、UDP）之间新增的一个层级关系。二进制分帧层将传输的 HTTP 消息分割为更小的帧，并采用二进制格式编码传输。帧分为头部帧和消息帧。这意味着 HTTP/2 请求的所有内容都是二进制传输的。",{"type":182,"tag":214,"props":696,"children":697},{},[698],{"type":198,"value":699},"HTTP 头部被转为帧之前，会通过维护一个表结构，通过序号记录已发送的键值对。这是一种索引算法，叫 HPACK。具体的表结构分静态表和动态表，静态表给一些常用的头部标号了号，直接使用就好，动态表则是根据发送的内容动态确定的记号。需要被发送具体内容会被哈夫曼编码以减小体积。",{"type":182,"tag":214,"props":701,"children":702},{},[703],{"type":198,"value":704},"多路复用是指，多个 HTTP 请求可以在同一个 TCP 连接中并行传输。这和 HTTP 1.1 的 Connection：keep-alive 不同，keep-alive 虽然复用 TCP 连接，但是多个响应之间是串行的。",{"type":182,"tag":214,"props":706,"children":707},{},[708],{"type":198,"value":709},"建立连接后，双方通过交换 SETTING 帧，以确认双向的流量窗口控制大小。然后开始发送帧。帧可以在一个连接中根据优先级发送，或是被乱序发送，响应方也能乱序接收。由于流是双向的，只要服务端 SETTING 帧设置的流量窗口大小不为 0，服务端可按照同源策略推送资源给客户端。",{"type":182,"tag":214,"props":711,"children":712},{},[713,714,721,723],{"type":198,"value":361},{"type":182,"tag":191,"props":715,"children":718},{"href":716,"rel":717},"https://coffe1891.gitbook.io/frontend-hard-mode-interview/1/1.5.3",[195],[719],{"type":198,"value":720},"HTTP/2 和 HTTP/1.X 相比的新特性",{"type":198,"value":722},"、",{"type":182,"tag":191,"props":724,"children":727},{"href":725,"rel":726},"https://blog.csdn.net/gaoliang1719/article/details/106346201/",[195],[728],{"type":198,"value":729},"HTTP/2 协议之头部压缩",{"type":182,"tag":207,"props":731,"children":733},{"id":732},"http3-相比-http2-改变了什么东西",[734],{"type":198,"value":735},"HTTP3 相比 HTTP2 改变了什么东西？",{"type":182,"tag":214,"props":737,"children":738},{},[739],{"type":198,"value":740},"HTTP3 使用全新的传输层协议 QUIC，实现了 H2 中的流式传输（HTTP2）、多路复用（TCP）、流量控制（TCP）以及可靠性（TCP）等内容，其网络层协议应用的是 UDP 而不是 TCP，本意是用来解决 TCP 建立链接需要  1.5 RTT 延迟的问题。这种改善在移动端更加有效。",{"type":182,"tag":214,"props":742,"children":743},{},[744],{"type":182,"tag":223,"props":745,"children":748},{"alt":746,"src":747},"HTTP3 VS HTTP2 VS HTTP1.1","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220621003527.png?type=draw&w=80",[],{"type":182,"tag":214,"props":750,"children":751},{},[752,753],{"type":198,"value":361},{"type":182,"tag":191,"props":754,"children":757},{"href":755,"rel":756},"https://mp.weixin.qq.com/s/40YBEWZBaHakDuRuh27fMg",[195],[758],{"type":198,"value":759},"HTTP3 发布了！",{"type":182,"tag":201,"props":761,"children":763},{"id":762},"tls",[764],{"type":198,"value":765},"TLS",{"type":182,"tag":214,"props":767,"children":768},{},[769,770],{"type":198,"value":249},{"type":182,"tag":191,"props":771,"children":774},{"href":772,"rel":773},"https://www.oschina.net/translate/rfc-8446-aka-tls-1-3",[195],[775],{"type":198,"value":776},"详细介绍 RFC 8446（即 TLS 1.3）",{"type":182,"tag":214,"props":778,"children":779},{},[780],{"type":198,"value":781},"TLS 是一种混合式加密系统，同时使用对称加密和非对称加密。它使用非对称加密以加密对称加密所需的密钥。它有多个版本。TLS 1.3 是一种比起 TLS1.2 而言更清晰、更快速、更安全的现代化安全协议。TLS 1.2 有两点问题：1. 包括 POODLE 在内的众多可行漏洞；2. 性能低。为了改善这些问题，IETF 在 2013 年，着手 TLS 1.3 的讨论，主要改进：",{"type":182,"tag":183,"props":783,"children":784},{},[785,790,795,800],{"type":182,"tag":187,"props":786,"children":787},{},[788],{"type":198,"value":789},"减少握手时间",{"type":182,"tag":187,"props":791,"children":792},{},[793],{"type":198,"value":794},"加密更多的握手",{"type":182,"tag":187,"props":796,"children":797},{},[798],{"type":198,"value":799},"改善跨协议攻击的弹性",{"type":182,"tag":187,"props":801,"children":802},{},[803],{"type":198,"value":804},"删除遗留特征",{"type":182,"tag":214,"props":806,"children":807},{},[808],{"type":198,"value":809},"经过 4 年的争论。最终，形成了 RFC 8446 规范。",{"type":182,"tag":811,"props":812,"children":814},"h3",{"id":813},"tls-12-的缺陷",[815],{"type":198,"value":816},"TLS 1.2 的缺陷",{"type":182,"tag":214,"props":818,"children":819},{},[820],{"type":198,"value":821},"TLS 1.2 使用的加密方式有缺陷。其中，非对称加密有如 RSA 和 Diffie-Hellman 协议。",{"type":182,"tag":207,"props":823,"children":825},{"id":824},"rsa",[826],{"type":198,"value":827},"RSA",{"type":182,"tag":214,"props":829,"children":830},{},[831],{"type":182,"tag":223,"props":832,"children":835},{"alt":833,"src":834},"RSA Handshake","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200807082140.png?w=70",[],{"type":182,"tag":214,"props":837,"children":838},{},[839,841,848],{"type":198,"value":840},"RSA 不保证前向保密。即，如果有人记录了加密对话，然后获取服务器的 RSA 私钥，他们可以将对话解密。而攻击者可能只需 ",{"type":182,"tag":191,"props":842,"children":845},{"href":843,"rel":844},"https://www.wikiwand.com/zh/%E5%BF%83%E8%84%8F%E5%87%BA%E8%A1%80%E6%BC%8F%E6%B4%9E",[195],[846],{"type":198,"value":847},"HeartBleed 漏洞",{"type":198,"value":849},"（缓存区过读）就可以顺利窃取私钥。",{"type":182,"tag":207,"props":851,"children":853},{"id":852},"diffie-hellman",[854],{"type":198,"value":855},"Diffie-Hellman",{"type":182,"tag":214,"props":857,"children":858},{},[859],{"type":182,"tag":223,"props":860,"children":862},{"alt":855,"src":861},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200807082812.png?w=70",[],{"type":182,"tag":214,"props":864,"children":865},{},[866],{"type":198,"value":867},"Diffie-Hellman 的缺陷在于，协议的某些参数不安全，且能够被操纵设置；不安全的参数能导致加密更容易被破解。",{"type":182,"tag":207,"props":869,"children":871},{"id":870},"对称加密缺陷",[872],{"type":198,"value":870},{"type":182,"tag":214,"props":874,"children":875},{},[876],{"type":198,"value":877},"TLS 1.2 的对称加密使用的 CBC 模式密码和流式密码也有缺陷。",{"type":182,"tag":207,"props":879,"children":881},{"id":880},"downgrade-attack",[882],{"type":198,"value":883},"Downgrade Attack",{"type":182,"tag":214,"props":885,"children":886},{},[887],{"type":198,"value":888},"由于 TLS 1.2 握手协商密钥的部分没有加密。所以中间人可以拦截客户端的请求，选择发送方和接收方都支持的弱密码，伪造请求。",{"type":182,"tag":214,"props":890,"children":891},{},[892],{"type":182,"tag":223,"props":893,"children":895},{"alt":883,"src":894},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200807090034.png?w=70",[],{"type":182,"tag":811,"props":897,"children":899},{"id":898},"_0-rtt",[900],{"type":198,"value":901},"0-RTT",{"type":182,"tag":214,"props":903,"children":904},{},[905],{"type":198,"value":906},"TLS 1.3 中，通讯双方可以得到一个“恢复主密钥”的密钥，用于从中断的连接中直接恢复通讯。但是有被拦截导致重放攻击的风险。",{"type":182,"tag":214,"props":908,"children":909},{},[910],{"type":182,"tag":223,"props":911,"children":914},{"alt":912,"src":913},"0-RTT 重放攻击","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200807081140.png?w=70",[],{"type":182,"tag":201,"props":916,"children":918},{"id":917},"https",[919],{"type":198,"value":920},"HTTPS",{"type":182,"tag":811,"props":922,"children":924},{"id":923},"links",[925],{"type":198,"value":926},"Links",{"type":182,"tag":214,"props":928,"children":929},{},[930,931],{"type":198,"value":249},{"type":182,"tag":191,"props":932,"children":935},{"href":933,"rel":934},"https://zhuanlan.zhihu.com/p/26682342",[195],[936],{"type":198,"value":937},"深入理解 HTTPS 原理、过程与实践",{"type":182,"tag":207,"props":939,"children":941},{"id":940},"https-的握手过程是怎样的",[942],{"type":198,"value":943},"HTTPS 的握手过程是怎样的？",{"type":182,"tag":214,"props":945,"children":946},{},[947],{"type":198,"value":948},"总的来说是一个非对称加密+对称加密的过程。客户端通过一个随机数加上服务器的公钥来生成预主密钥，然后双方再通过 Client Hello 和 Server Hello 时的两个随机数生成会话密钥。生成预主密钥的过程是非对称加密的，因为只有服务端用私钥才能解得客户端的随机数。而之后使用会话密钥主要是出于性能考虑。",{"type":182,"tag":214,"props":950,"children":951},{},[952],{"type":182,"tag":223,"props":953,"children":956},{"alt":954,"src":955},"HTTPS 握手过程","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220620024738.png",[],{"type":182,"tag":207,"props":958,"children":960},{"id":959},"ca-怎么解决中间人问题",[961],{"type":198,"value":962},"CA 怎么解决中间人问题？",{"type":182,"tag":214,"props":964,"children":965},{},[966],{"type":198,"value":967},"CA 主要是用来防范服务器端返回 Server Hello 前就和客户端提供了假的公钥。CA 是一个可信的第三方机构，客户端想要服务器的公钥，需要从 CA 获得。CA 返回公钥以及数字签名。客户端只要拿到公钥后根据 CA 公钥对其计算获得摘要，再将摘要和签名进行对比，就能知道是否拿到了可信的公钥。",{"type":182,"tag":214,"props":969,"children":970},{},[971,972],{"type":198,"value":361},{"type":182,"tag":191,"props":973,"children":976},{"href":974,"rel":975},"https://www.jianshu.com/p/9de06222793b",[195],[977],{"type":198,"value":978},"HTTPS CA 原理",{"type":182,"tag":207,"props":980,"children":982},{"id":981},"数字签名是什么",[983],{"type":198,"value":984},"数字签名是什么？",{"type":182,"tag":214,"props":986,"children":987},{},[988],{"type":198,"value":989},"数字签名是只有信息发送者才能产生的一段文本，信息接收方可以通过签名计算出接受到的文本是否经过了修改。如果我要发送 A，我会用私钥将 A 进行加密获得 B，并把 A 和 B 同时发送过去。B 就是数字签名。因为我的公钥是公开的，所以接受方可以通过使用我的公钥去计算 A，如果获得和 B 一致的结果，那么说明信息没有被篡改。",{"type":182,"tag":201,"props":991,"children":993},{"id":992},"攻防",[994],{"type":198,"value":992},{"type":182,"tag":207,"props":996,"children":998},{"id":997},"https-降级攻击的原理是什么",[999],{"type":198,"value":1000},"HTTPS 降级攻击的原理是什么？",{"type":182,"tag":214,"props":1002,"children":1003},{},[1004],{"type":198,"value":1005},"客服端与服务端协商加密协议的过程当中，如果攻击者拦截了客户端（或操控客户端）并代替它向服务端协商使用仅支持有漏洞的协议。如果服务端同意了，那么建立连接后，攻击者就能使用该协议的已知漏洞的破解手段，去破解通讯内容了。",{"type":182,"tag":207,"props":1007,"children":1009},{"id":1008},"syn-攻击的基本原理是什么",[1010],{"type":198,"value":1011},"SYN 攻击的基本原理是什么？",{"type":182,"tag":214,"props":1013,"children":1014},{},[1015,1017,1024],{"type":198,"value":1016},"SYN 洪水攻击是 DDOS 攻击中最常见的攻击类型。攻击者向服务器发送大量伪造的 TCP 连接请求，而源 IP 是伪造的。由于服务器收不到伪造源回应的 ACK 数据包，就会不断重发。一般应对方式是：减少重发次数、使用 ",{"type":182,"tag":191,"props":1018,"children":1021},{"href":1019,"rel":1020},"https://baike.baidu.com/item/syn%20cookie/6898884?fr=aladdin",[195],[1022],{"type":198,"value":1023},"SYN Cookie",{"type":198,"value":1025},"、增加 backlog 队列长度、限制 SYN 并发数。",{"type":182,"tag":214,"props":1027,"children":1028},{},[1029,1030],{"type":198,"value":361},{"type":182,"tag":191,"props":1031,"children":1034},{"href":1032,"rel":1033},"https://www.qycn.com/about/hd/2049.html",[195],[1035],{"type":198,"value":1036},"服务器遭到 SYN 攻击该如何处理呢？",{"type":182,"tag":207,"props":1038,"children":1040},{"id":1039},"请求头加-csrf-参数为什么能防止-csrf-攻击",[1041],{"type":198,"value":1042},"请求头加 CSRF 参数为什么能防止 CSRF 攻击？",{"type":182,"tag":214,"props":1044,"children":1045},{},[1046],{"type":198,"value":1047},"跨站请求伪造是攻击者通过在钓鱼站点发起被钓网站请求（如图片地址），以达到攻击目的。防御方式一般有两种：",{"type":182,"tag":183,"props":1049,"children":1050},{},[1051,1056],{"type":182,"tag":187,"props":1052,"children":1053},{},[1054],{"type":198,"value":1055},"使用 SameSite Cookie，禁用第三方 Cookie",{"type":182,"tag":187,"props":1057,"children":1058},{},[1059],{"type":198,"value":1060},"在请求头中加入 CSRF Token，这样攻击者使用钓鱼站点发起请求时，由于不能设置请求头，所以请求在服务端会被拒绝",{"type":182,"tag":201,"props":1062,"children":1064},{"id":1063},"cdn",[1065],{"type":198,"value":1066},"CDN",{"type":182,"tag":207,"props":1068,"children":1070},{"id":1069},"cdn-有什么好处",[1071],{"type":198,"value":1072},"CDN 有什么好处？",{"type":182,"tag":214,"props":1074,"children":1075},{},[1076],{"type":198,"value":1077},"对页面加载而言，CDN 可以减少请求时间、突破浏览器同域的 TCP 并发数、节约 Cookie 带宽。",{"type":182,"tag":201,"props":1079,"children":1081},{"id":1080},"浏览器",[1082],{"type":198,"value":1080},{"type":182,"tag":207,"props":1084,"children":1086},{"id":1085},"url-由哪些部分组成",[1087],{"type":198,"value":1088},"URL 由哪些部分组成？",{"type":182,"tag":214,"props":1090,"children":1091},{},[1092],{"type":198,"value":1093},"协议头、域名、端口、目录、文件名（index.html）、页面锚、参数。",{"type":182,"tag":207,"props":1095,"children":1097},{"id":1096},"怎么做跨域",[1098],{"type":198,"value":1099},"怎么做跨域？",{"type":182,"tag":214,"props":1101,"children":1102},{},[1103],{"type":198,"value":1104},"用代理服务器、CORS、iFrame 或者 WebSocket 都可以。",{"type":182,"tag":214,"props":1106,"children":1107},{},[1108],{"type":198,"value":1109},"服务器可以忽略同源限制；WebSocket 和 CORS 不受同源影响；iFrame 需要浏览器加载一个跨域页面，然后和主页面用 postMessage 或者哈希监听的方式通信，让 iFrame 中的脚本代替主页面发送请求。",{"type":182,"tag":207,"props":1111,"children":1113},{"id":1112},"正向代理和反向代理的区别是",[1114],{"type":198,"value":1115},"正向代理和反向代理的区别是？",{"type":182,"tag":214,"props":1117,"children":1118},{},[1119],{"type":198,"value":1120},"正向代理为用户服务，反向代理为服务器服务，分别对应“VPN”和“负载均衡”的概念。",{"type":182,"tag":207,"props":1122,"children":1124},{"id":1123},"cors-运作流程是怎样的",[1125],{"type":198,"value":1126},"CORS 运作流程是怎样的？",{"type":182,"tag":214,"props":1128,"children":1129},{},[1130],{"type":198,"value":1131},"CORS 即跨域资源共享机制。浏览器在请求资源前通过携带 Origin 字段的 OPTIONS 请求向服务器索取设置有 Access-Control-Allow-Methods、Access-Control-Allow-Headers、Access-Control-Allow-Origin 的响应。在得到响应的允许后再继续发送请求。",{"type":182,"tag":207,"props":1133,"children":1135},{"id":1134},"什么是私有网络请求攻击",[1136],{"type":198,"value":1137},"什么是私有网络请求攻击？",{"type":182,"tag":214,"props":1139,"children":1140},{},[1141],{"type":198,"value":1142},"在内网域名向 localhost 发起请求就算一种私有网络请求。而恶意代码通过向比浏览器当前浏览页面的域名 IP 更私密的 IP 地址发起请求，以达到获取信息或攻击手段的方式就是私有网络请求攻击。",{"type":182,"tag":214,"props":1144,"children":1145},{},[1146,1148,1155,1157],{"type":198,"value":1147},"自 Chrome 96 后， Chrome 开始实施私有网络控制策略，需要部署以下两个请求头以解除控制：",{"type":182,"tag":1149,"props":1150,"children":1152},"code",{"className":1151},[],[1153],{"type":198,"value":1154},"Access-Control-Request-Private-Network: true",{"type":198,"value":1156}," 和 ",{"type":182,"tag":1149,"props":1158,"children":1160},{"className":1159},[],[1161],{"type":198,"value":1162},"Access-Control-Allow-Private-Network: true",{"type":182,"tag":214,"props":1164,"children":1165},{},[1166,1167],{"type":198,"value":361},{"type":182,"tag":191,"props":1168,"children":1171},{"href":1169,"rel":1170},"https://mp.weixin.qq.com/s?__biz=Mzk0MDMwMzQyOA==&mid=2247491913&idx=1&sn=2bb0a28358c02a8ec1832781205df72c&chksm=c2e11462f5969d74fac277131e1ba8c417ec86754b2f1b2dbe8e238ca27d5c2eaebe602ec803&token=1851580176&lang=zh_CN&scene=21#wechat_redirect",[195],[1172],{"type":198,"value":1173},"Chrome 重大更新，CORS 增加了两个新的请求头？ |  code 秘密花园",{"type":182,"tag":201,"props":1175,"children":1177},{"id":1176},"阅读更多",[1178],{"type":198,"value":1176},{"type":182,"tag":183,"props":1180,"children":1181},{},[1182],{"type":182,"tag":187,"props":1183,"children":1184},{},[1185],{"type":182,"tag":191,"props":1186,"children":1189},{"href":1187,"rel":1188},"https://juejin.im/post/6844903518826921998",[195],[1190],{"type":198,"value":1191},"为你的网站带上帽子 | 使用 helmet 保护 Express 应用",{"title":175,"searchDepth":1193,"depth":1193,"links":1194},2,[1195,1196,1197,1198,1199,1204,1207,1208,1209,1210],{"id":203,"depth":1193,"text":203},{"id":230,"depth":1193,"text":233},{"id":371,"depth":1193,"text":374},{"id":405,"depth":1193,"text":408},{"id":762,"depth":1193,"text":765,"children":1200},[1201,1203],{"id":813,"depth":1202,"text":816},3,{"id":898,"depth":1202,"text":901},{"id":917,"depth":1193,"text":920,"children":1205},[1206],{"id":923,"depth":1202,"text":926},{"id":992,"depth":1193,"text":992},{"id":1063,"depth":1193,"text":1066},{"id":1080,"depth":1193,"text":1080},{"id":1176,"depth":1193,"text":1176},"markdown","content:6.maps:_computer:network.md","content","6.maps/_computer/network.md","6.maps/_computer/network","md",[1218,1222],{"_path":1219,"title":1220,"description":1221},"/maps/_computer/encoding/hash-collision","哈希冲突","哈希冲突是指两个不同的键值被哈希函数映射到了同一个位置。",{"_path":1223,"title":1224,"description":175},"/maps/_computer/segments/http-request-example","Http Request Example",1771264627260]