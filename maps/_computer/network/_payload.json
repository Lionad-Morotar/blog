IP 和 xxx。",{"type":185,"tag":217,"props":249,"children":250},{},[251,253],{"type":201,"value":252},"TODO，",{"type":185,"tag":194,"props":254,"children":257},{"href":255,"rel":256},"https://developer.51cto.com/article/597961.html",[198],[258],{"type":201,"value":259},"终于有人能把 TCP/IP 协议讲的明明白白了！",{"type":185,"tag":210,"props":261,"children":263},{"id":262},"tcp-header-由哪些部分组成",[264],{"type":201,"value":265},"TCP Header 由哪些部分组成？",{"type":185,"tag":217,"props":267,"children":268},{},[269],{"type":185,"tag":226,"props":270,"children":273},{"alt":271,"src":272},"TCP Header","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200731153510.png?type=win11&w=60",[],{"type":185,"tag":210,"props":275,"children":277},{"id":276},"三次握手具体过程",[278],{"type":201,"value":279},"三次握手具体过程？",{"type":185,"tag":217,"props":281,"children":282},{},[283],{"type":201,"value":284},"从三次握手图示可以发现，仅仅是连接的建立，就需要大量时间消耗。客户端想发送数据，至少要等 1.5xRTT；服务端想发送数据，至少要 2xRTT。",{"type":185,"tag":217,"props":286,"children":287},{},[288],{"type":185,"tag":226,"props":289,"children":292},{"alt":290,"src":291},"Three-way Handshake","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200731162450.png?type=win11&w=40",[],{"type":185,"tag":210,"props":294,"children":296},{"id":295},"tcp-fast-open-如何优化握手过程",[297],{"type":201,"value":298},"TCP Fast Open 如何优化握手过程？",{"type":185,"tag":217,"props":300,"children":301},{},[302],{"type":201,"value":303},"TFO 规定服务器第一次返回 ACK 时，携带一个用以标志客户端身份的 Cookie。后续客户端发送 SYN 建立连接的时候带上这个 Cookie，服务端确认身份之后，就能直接返回数据了（节约了 1.5 RTT）。",{"type":185,"tag":217,"props":305,"children":306},{},[307],{"type":185,"tag":226,"props":308,"children":311},{"alt":309,"src":310},"TFO","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200807054219.png?type=win11&w=80",[],{"type":185,"tag":210,"props":313,"children":315},{"id":314},"四次挥手的具体过程",[316],{"type":201,"value":317},"四次挥手的具体过程？",{"type":185,"tag":217,"props":319,"children":320},{},[321],{"type":201,"value":322},"四次挥手如下所示。为什么建立连接要三次，而断开连接要四次请求呢？从图中可以看出，接收到 FIN 请求时，服务端立即返回 ACK 表示收到请求，但是要等自己这边剩余一些工作（可能时未发送完的请求内容）完成之后，才会返回 FIN。",{"type":185,"tag":217,"props":324,"children":325},{},[326],{"type":185,"tag":226,"props":327,"children":330},{"alt":328,"src":329},"Four-way Wavehand","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200731165331.png?type=win11&w=40",[],{"type":185,"tag":210,"props":332,"children":334},{"id":333},"tcp-链接中如果某端出故障了会怎么办",[335],{"type":201,"value":336},"TCP 链接中如果某端出故障了会怎么办？",{"type":185,"tag":217,"props":338,"children":339},{},[340],{"type":201,"value":341},"会通过计时器来保证链接的稳定性。",{"type":185,"tag":186,"props":343,"children":344},{},[345,350,355],{"type":185,"tag":190,"props":346,"children":347},{},[348],{"type":201,"value":349},"超时重传计时器：对方没有返回 ACK 时，发送方需要重新发送数据。一般计时器的时间选择 2RTT。",{"type":185,"tag":190,"props":351,"children":352},{},[353],{"type":201,"value":354},"2MSL 定时器：主动断开连接的一方发送 FIN 后需要等待 2MSL 时间。因为如果服务端没有收到最后一个 ACK，它将重新发送 FIN。",{"type":185,"tag":190,"props":356,"children":357},{},[358],{"type":201,"value":359},"保活计时器：每当接收方收到消息，将计时器重设为两小时。计时器到期时，每 75s 发送一次探测报文段，如果连续 10 次都没有被响应则断开连接。",{"type":185,"tag":217,"props":361,"children":362},{},[363,365],{"type":201,"value":364},"见：",{"type":185,"tag":194,"props":366,"children":369},{"href":367,"rel":368},"https://www.cnblogs.com/13224ACMer/p/6616960.html",[198],[370],{"type":201,"value":371},"TCP 四种计时器",{"type":185,"tag":204,"props":373,"children":375},{"id":374},"udp",[376],{"type":201,"value":377},"UDP",{"type":185,"tag":217,"props":379,"children":380},{},[381],{"type":201,"value":382},"UDP，即 User Datagram Protocol 用户数据报协议。数据报不保证信息的传达是否到位，所以 UDP 也被普遍称作 Unreliable Datagram Protocol。",{"type":185,"tag":186,"props":384,"children":385},{},[386,391,396,401],{"type":185,"tag":190,"props":387,"children":388},{},[389],{"type":201,"value":390},"不保证消息交付",{"type":185,"tag":190,"props":392,"children":393},{},[394],{"type":201,"value":395},"不保证交付顺序",{"type":185,"tag":190,"props":397,"children":398},{},[399],{"type":201,"value":400},"不跟踪连接状态",{"type":185,"tag":190,"props":402,"children":403},{},[404],{"type":201,"value":405},"不需要拥塞控制",{"type":185,"tag":204,"props":407,"children":409},{"id":408},"http",[410],{"type":201,"value":411},"HTTP",{"type":185,"tag":210,"props":413,"children":415},{"id":414},"有哪些常见的状态码",[416],{"type":201,"value":417},"有哪些常见的状态码？",{"type":185,"tag":419,"props":420,"children":421},"table",{},[422,441],{"type":185,"tag":423,"props":424,"children":425},"thead",{},[426],{"type":185,"tag":427,"props":428,"children":429},"tr",{},[430,436],{"type":185,"tag":431,"props":432,"children":433},"th",{},[434],{"type":201,"value":435},"状态码",{"type":185,"tag":431,"props":437,"children":438},{},[439],{"type":201,"value":440},"描述",{"type":185,"tag":442,"props":443,"children":444},"tbody",{},[445,459,472,485,498,511,524,537,550,563],{"type":185,"tag":427,"props":446,"children":447},{},[448,454],{"type":185,"tag":449,"props":450,"children":451},"td",{},[452],{"type":201,"value":453},"200",{"type":185,"tag":449,"props":455,"children":456},{},[457],{"type":201,"value":458},"成功并返回数据",{"type":185,"tag":427,"props":460,"children":461},{},[462,467],{"type":185,"tag":449,"props":463,"children":464},{},[465],{"type":201,"value":466},"301",{"type":185,"tag":449,"props":468,"children":469},{},[470],{"type":201,"value":471},"永久转移，重定向",{"type":185,"tag":427,"props":473,"children":474},{},[475,480],{"type":185,"tag":449,"props":476,"children":477},{},[478],{"type":201,"value":479},"302",{"type":185,"tag":449,"props":481,"children":482},{},[483],{"type":201,"value":484},"临时重定向",{"type":185,"tag":427,"props":486,"children":487},{},[488,493],{"type":185,"tag":449,"props":489,"children":490},{},[491],{"type":201,"value":492},"303",{"type":185,"tag":449,"props":494,"children":495},{},[496],{"type":201,"value":497},"临时重定向（客户端必须使用 Get 方法重新请求资源）",{"type":185,"tag":427,"props":499,"children":500},{},[501,506],{"type":185,"tag":449,"props":502,"children":503},{},[504],{"type":201,"value":505},"304",{"type":185,"tag":449,"props":507,"children":508},{},[509],{"type":201,"value":510},"资源未修改，可使用缓存",{"type":185,"tag":427,"props":512,"children":513},{},[514,519],{"type":185,"tag":449,"props":515,"children":516},{},[517],{"type":201,"value":518},"400",{"type":185,"tag":449,"props":520,"children":521},{},[522],{"type":201,"value":523},"请求语法错误",{"type":185,"tag":427,"props":525,"children":526},{},[527,532],{"type":185,"tag":449,"props":528,"children":529},{},[530],{"type":201,"value":531},"401",{"type":185,"tag":449,"props":533,"children":534},{},[535],{"type":201,"value":536},"要求身份认证",{"type":185,"tag":427,"props":538,"children":539},{},[540,545],{"type":185,"tag":449,"props":541,"children":542},{},[543],{"type":201,"value":544},"403",{"type":185,"tag":449,"props":546,"children":547},{},[548],{"type":201,"value":549},"请求拒绝",{"type":185,"tag":427,"props":551,"children":552},{},[553,558],{"type":185,"tag":449,"props":554,"children":555},{},[556],{"type":201,"value":557},"404",{"type":185,"tag":449,"props":559,"children":560},{},[561],{"type":201,"value":562},"资源不存在",{"type":185,"tag":427,"props":564,"children":565},{},[566,571],{"type":185,"tag":449,"props":567,"children":568},{},[569],{"type":201,"value":570},"500",{"type":185,"tag":449,"props":572,"children":573},{},[574],{"type":201,"value":575},"服务器错误",{"type":185,"tag":210,"props":577,"children":579},{"id":578},"http-报文由哪些部分组成",[580],{"type":201,"value":581},"HTTP 报文由哪些部分组成？",{"type":185,"tag":217,"props":583,"children":584},{},[585],{"type":201,"value":586},"请求报文由请求行、请求头、空行和请求数据组成，相应报文类似。",{"type":185,"tag":217,"props":588,"children":589},{},[590],{"type":201,"value":591},"请求报文实例：",{"type":185,"tag":217,"props":593,"children":594},{},[595],{"type":201,"value":596},"相应报文实例：",{"type":185,"tag":210,"props":598,"children":600},{"id":599},"http-11-对比-http-10-做了哪些改进",[601],{"type":201,"value":602},"HTTP 1.1 对比 HTTP 1.0 做了哪些改进？",{"type":185,"tag":217,"props":604,"children":605},{},[606],{"type":201,"value":607},"长链接（keep-alive）、断点续传、HTTP 缓存。",{"type":185,"tag":210,"props":609,"children":611},{"id":610},"http-缓存分几种",[612],{"type":201,"value":613},"HTTP 缓存分几种？",{"type":185,"tag":217,"props":615,"children":616},{},[617],{"type":201,"value":618},"分强缓存和协商缓存：Expires、Cache-Control、Last-Modified、Etag。",{"type":185,"tag":217,"props":620,"children":621},{},[622],{"type":185,"tag":226,"props":623,"children":626},{"alt":624,"src":625},"HTTP Cache","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220630205606.png?type=win11&w=60",[],{"type":185,"tag":217,"props":628,"children":629},{},[630,631],{"type":201,"value":252},{"type":185,"tag":194,"props":632,"children":635},{"href":633,"rel":634},"https://imweb.io/topic/55c6f9bac222e3af6ce235b9",[198],[636],{"type":201,"value":633},{"type":185,"tag":210,"props":638,"children":640},{"id":639},"强缓存和协商缓存的主要区别是",[641],{"type":201,"value":642},"强缓存和协商缓存的主要区别是？",{"type":185,"tag":217,"props":644,"children":645},{},[646],{"type":201,"value":647},"强缓存是一但匹配就无条件使用缓存，而面对协商缓存的资源，浏览器需要向服务端发请求，对比资源是否变更，并依靠服务端的响应来判断是否使用缓存。如果资源同时应用了强缓存和协商缓存，那么浏览器优先使用强缓存。",{"type":185,"tag":210,"props":649,"children":651},{"id":650},"no-store-和-no-cache-的区别",[652],{"type":201,"value":653},"no-store 和 no-cache 的区别？",{"type":185,"tag":217,"props":655,"children":656},{},[657],{"type":201,"value":658},"no-store 告诉客户端每次都在服务器取最新的资源。no-cache 也要求每次都要重新请求，但服务器可能返回 304 告诉客户端资源未改变。",{"type":185,"tag":210,"props":660,"children":662},{"id":661},"http2-的改进在哪里",[663],{"type":201,"value":664},"HTTP2 的改进在哪里？",{"type":185,"tag":217,"props":666,"children":667},{},[668],{"type":201,"value":669},"HTTP/2 主要包含以下几个方面的变化，显著增强了性能，也增加了安全性。",{"type":185,"tag":186,"props":671,"children":672},{},[673,678,683,688],{"type":185,"tag":190,"props":674,"children":675},{},[676],{"type":201,"value":677},"二进制分帧层",{"type":185,"tag":190,"props":679,"children":680},{},[681],{"type":201,"value":682},"头部压缩（HPACK、Huffman）",{"type":185,"tag":190,"props":684,"children":685},{},[686],{"type":201,"value":687},"多路复用",{"type":185,"tag":190,"props":689,"children":690},{},[691],{"type":201,"value":692},"服务端推送",{"type":185,"tag":217,"props":694,"children":695},{},[696],{"type":201,"value":697},"二进制分帧层是在应用层（HTTP）和传输层（TCP、UDP）之间新增的一个层级关系。二进制分帧层将传输的 HTTP 消息分割为更小的帧，并采用二进制格式编码传输。帧分为头部帧和消息帧。这意味着 HTTP/2 请求的所有内容都是二进制传输的。",{"type":185,"tag":217,"props":699,"children":700},{},[701],{"type":201,"value":702},"HTTP 头部被转为帧之前，会通过维护一个表结构，通过序号记录已发送的键值对。这是一种索引算法，叫 HPACK。具体的表结构分静态表和动态表，静态表给一些常用的头部标号了号，直接使用就好，动态表则是根据发送的内容动态确定的记号。需要被发送具体内容会被哈夫曼编码以减小体积。",{"type":185,"tag":217,"props":704,"children":705},{},[706],{"type":201,"value":707},"多路复用是指，多个 HTTP 请求可以在同一个 TCP 连接中并行传输。这和 HTTP 1.1 的 Connection：keep-alive 不同，keep-alive 虽然复用 TCP 连接，但是多个响应之间是串行的。",{"type":185,"tag":217,"props":709,"children":710},{},[711],{"type":201,"value":712},"建立连接后，双方通过交换 SETTING 帧，以确认双向的流量窗口控制大小。然后开始发送帧。帧可以在一个连接中根据优先级发送，或是被乱序发送，响应方也能乱序接收。由于流是双向的，只要服务端 SETTING 帧设置的流量窗口大小不为 0，服务端可按照同源策略推送资源给客户端。",{"type":185,"tag":217,"props":714,"children":715},{},[716,717,724,726],{"type":201,"value":364},{"type":185,"tag":194,"props":718,"children":721},{"href":719,"rel":720},"https://coffe1891.gitbook.io/frontend-hard-mode-interview/1/1.5.3",[198],[722],{"type":201,"value":723},"HTTP/2 和 HTTP/1.X 相比的新特性",{"type":201,"value":725},"、",{"type":185,"tag":194,"props":727,"children":730},{"href":728,"rel":729},"https://blog.csdn.net/gaoliang1719/article/details/106346201/",[198],[731],{"type":201,"value":732},"HTTP/2 协议之头部压缩",{"type":185,"tag":210,"props":734,"children":736},{"id":735},"http3-相比-http2-改变了什么东西",[737],{"type":201,"value":738},"HTTP3 相比 HTTP2 改变了什么东西？",{"type":185,"tag":217,"props":740,"children":741},{},[742],{"type":201,"value":743},"HTTP3 使用全新的传输层协议 QUIC，实现了 H2 中的流式传输（HTTP2）、多路复用（TCP）、流量控制（TCP）以及可靠性（TCP）等内容，其网络层协议应用的是 UDP 而不是 TCP，本意是用来解决 TCP 建立链接需要  1.5 RTT 延迟的问题。这种改善在移动端更加有效。",{"type":185,"tag":217,"props":745,"children":746},{},[747],{"type":185,"tag":226,"props":748,"children":751},{"alt":749,"src":750},"HTTP3 VS HTTP2 VS HTTP1.1","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220621003527.png?type=draw&w=80",[],{"type":185,"tag":217,"props":753,"children":754},{},[755,756],{"type":201,"value":364},{"type":185,"tag":194,"props":757,"children":760},{"href":758,"rel":759},"https://mp.weixin.qq.com/s/40YBEWZBaHakDuRuh27fMg",[198],[761],{"type":201,"value":762},"HTTP3 发布了！",{"type":185,"tag":204,"props":764,"children":766},{"id":765},"tls",[767],{"type":201,"value":768},"TLS",{"type":185,"tag":217,"props":770,"children":771},{},[772,773],{"type":201,"value":252},{"type":185,"tag":194,"props":774,"children":777},{"href":775,"rel":776},"https://www.oschina.net/translate/rfc-8446-aka-tls-1-3",[198],[778],{"type":201,"value":779},"详细介绍 RFC 8446（即 TLS 1.3）",{"type":185,"tag":217,"props":781,"children":782},{},[783],{"type":201,"value":784},"TLS 是一种混合式加密系统，同时使用对称加密和非对称加密。它使用非对称加密以加密对称加密所需的密钥。它有多个版本。TLS 1.3 是一种比起 TLS1.2 而言更清晰、更快速、更安全的现代化安全协议。TLS 1.2 有两点问题：1. 包括 POODLE 在内的众多可行漏洞；2. 性能低。为了改善这些问题，IETF 在 2013 年，着手 TLS 1.3 的讨论，主要改进：",{"type":185,"tag":186,"props":786,"children":787},{},[788,793,798,803],{"type":185,"tag":190,"props":789,"children":790},{},[791],{"type":201,"value":792},"减少握手时间",{"type":185,"tag":190,"props":794,"children":795},{},[796],{"type":201,"value":797},"加密更多的握手",{"type":185,"tag":190,"props":799,"children":800},{},[801],{"type":201,"value":802},"改善跨协议攻击的弹性",{"type":185,"tag":190,"props":804,"children":805},{},[806],{"type":201,"value":807},"删除遗留特征",{"type":185,"tag":217,"props":809,"children":810},{},[811],{"type":201,"value":812},"经过 4 年的争论。最终，形成了 RFC 8446 规范。",{"type":185,"tag":814,"props":815,"children":817},"h3",{"id":816},"tls-12-的缺陷",[818],{"type":201,"value":819},"TLS 1.2 的缺陷",{"type":185,"tag":217,"props":821,"children":822},{},[823],{"type":201,"value":824},"TLS 1.2 使用的加密方式有缺陷。其中，非对称加密有如 RSA 和 Diffie-Hellman 协议。",{"type":185,"tag":210,"props":826,"children":828},{"id":827},"rsa",[829],{"type":201,"value":830},"RSA",{"type":185,"tag":217,"props":832,"children":833},{},[834],{"type":185,"tag":226,"props":835,"children":838},{"alt":836,"src":837},"RSA Handshake","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200807082140.png?w=70",[],{"type":185,"tag":217,"props":840,"children":841},{},[842,844,851],{"type":201,"value":843},"RSA 不保证前向保密。即，如果有人记录了加密对话，然后获取服务器的 RSA 私钥，他们可以将对话解密。而攻击者可能只需 ",{"type":185,"tag":194,"props":845,"children":848},{"href":846,"rel":847},"https://www.wikiwand.com/zh/%E5%BF%83%E8%84%8F%E5%87%BA%E8%A1%80%E6%BC%8F%E6%B4%9E",[198],[849],{"type":201,"value":850},"HeartBleed 漏洞",{"type":201,"value":852},"（缓存区过读）就可以顺利窃取私钥。",{"type":185,"tag":210,"props":854,"children":856},{"id":855},"diffie-hellman",[857],{"type":201,"value":858},"Diffie-Hellman",{"type":185,"tag":217,"props":860,"children":861},{},[862],{"type":185,"tag":226,"props":863,"children":865},{"alt":858,"src":864},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200807082812.png?w=70",[],{"type":185,"tag":217,"props":867,"children":868},{},[869],{"type":201,"value":870},"Diffie-Hellman 的缺陷在于，协议的某些参数不安全，且能够被操纵设置；不安全的参数能导致加密更容易被破解。",{"type":185,"tag":210,"props":872,"children":874},{"id":873},"对称加密缺陷",[875],{"type":201,"value":873},{"type":185,"tag":217,"props":877,"children":878},{},[879],{"type":201,"value":880},"TLS 1.2 的对称加密使用的 CBC 模式密码和流式密码也有缺陷。",{"type":185,"tag":210,"props":882,"children":884},{"id":883},"downgrade-attack",[885],{"type":201,"value":886},"Downgrade Attack",{"type":185,"tag":217,"props":888,"children":889},{},[890],{"type":201,"value":891},"由于 TLS 1.2 握手协商密钥的部分没有加密。所以中间人可以拦截客户端的请求，选择发送方和接收方都支持的弱密码，伪造请求。",{"type":185,"tag":217,"props":893,"children":894},{},[895],{"type":185,"tag":226,"props":896,"children":898},{"alt":886,"src":897},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200807090034.png?w=70",[],{"type":185,"tag":814,"props":900,"children":902},{"id":901},"_0-rtt",[903],{"type":201,"value":904},"0-RTT",{"type":185,"tag":217,"props":906,"children":907},{},[908],{"type":201,"value":909},"TLS 1.3 中，通讯双方可以得到一个“恢复主密钥”的密钥，用于从中断的连接中直接恢复通讯。但是有被拦截导致重放攻击的风险。",{"type":185,"tag":217,"props":911,"children":912},{},[913],{"type":185,"tag":226,"props":914,"children":917},{"alt":915,"src":916},"0-RTT 重放攻击","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200807081140.png?w=70",[],{"type":185,"tag":204,"props":919,"children":921},{"id":920},"https",[922],{"type":201,"value":923},"HTTPS",{"type":185,"tag":814,"props":925,"children":927},{"id":926},"links",[928],{"type":201,"value":929},"Links",{"type":185,"tag":217,"props":931,"children":932},{},[933,934],{"type":201,"value":252},{"type":185,"tag":194,"props":935,"children":938},{"href":936,"rel":937},"https://zhuanlan.zhihu.com/p/26682342",[198],[939],{"type":201,"value":940},"深入理解 HTTPS 原理、过程与实践",{"type":185,"tag":210,"props":942,"children":944},{"id":943},"https-的握手过程是怎样的",[945],{"type":201,"value":946},"HTTPS 的握手过程是怎样的？",{"type":185,"tag":217,"props":948,"children":949},{},[950],{"type":201,"value":951},"总的来说是一个非对称加密+对称加密的过程。客户端通过一个随机数加上服务器的公钥来生成预主密钥，然后双方再通过 Client Hello 和 Server Hello 时的两个随机数生成会话密钥。生成预主密钥的过程是非对称加密的，因为只有服务端用私钥才能解得客户端的随机数。而之后使用会话密钥主要是出于性能考虑。",{"type":185,"tag":217,"props":953,"children":954},{},[955],{"type":185,"tag":226,"props":956,"children":959},{"alt":957,"src":958},"HTTPS 握手过程","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220620024738.png",[],{"type":185,"tag":210,"props":961,"children":963},{"id":962},"ca-怎么解决中间人问题",[964],{"type":201,"value":965},"CA 怎么解决中间人问题？",{"type":185,"tag":217,"props":967,"children":968},{},[969],{"type":201,"value":970},"CA 主要是用来防范服务器端返回 Server Hello 前就和客户端提供了假的公钥。CA 是一个可信的第三方机构，客户端想要服务器的公钥，需要从 CA 获得。CA 返回公钥以及数字签名。客户端只要拿到公钥后根据 CA 公钥对其计算获得摘要，再将摘要和签名进行对比，就能知道是否拿到了可信的公钥。",{"type":185,"tag":217,"props":972,"children":973},{},[974,975],{"type":201,"value":364},{"type":185,"tag":194,"props":976,"children":979},{"href":977,"rel":978},"https://www.jianshu.com/p/9de06222793b",[198],[980],{"type":201,"value":981},"HTTPS CA 原理",{"type":185,"tag":210,"props":983,"children":985},{"id":984},"数字签名是什么",[986],{"type":201,"value":987},"数字签名是什么？",{"type":185,"tag":217,"props":989,"children":990},{},[991],{"type":201,"value":992},"数字签名是只有信息发送者才能产生的一段文本，信息接收方可以通过签名计算出接受到的文本是否经过了修改。如果我要发送 A，我会用私钥将 A 进行加密获得 B，并把 A 和 B 同时发送过去。B 就是数字签名。因为我的公钥是公开的，所以接受方可以通过使用我的公钥去计算 A，如果获得和 B 一致的结果，那么说明信息没有被篡改。",{"type":185,"tag":204,"props":994,"children":996},{"id":995},"攻防",[997],{"type":201,"value":995},{"type":185,"tag":210,"props":999,"children":1001},{"id":1000},"https-降级攻击的原理是什么",[1002],{"type":201,"value":1003},"HTTPS 降级攻击的原理是什么？",{"type":185,"tag":217,"props":1005,"children":1006},{},[1007],{"type":201,"value":1008},"客服端与服务端协商加密协议的过程当中，如果攻击者拦截了客户端（或操控客户端）并代替它向服务端协商使用仅支持有漏洞的协议。如果服务端同意了，那么建立连接后，攻击者就能使用该协议的已知漏洞的破解手段，去破解通讯内容了。",{"type":185,"tag":210,"props":1010,"children":1012},{"id":1011},"syn-攻击的基本原理是什么",[1013],{"type":201,"value":1014},"SYN 攻击的基本原理是什么？",{"type":185,"tag":217,"props":1016,"children":1017},{},[1018,1020,1027],{"type":201,"value":1019},"SYN 洪水攻击是 DDOS 攻击中最常见的攻击类型。攻击者向服务器发送大量伪造的 TCP 连接请求，而源 IP 是伪造的。由于服务器收不到伪造源回应的 ACK 数据包，就会不断重发。一般应对方式是：减少重发次数、使用 ",{"type":185,"tag":194,"props":1021,"children":1024},{"href":1022,"rel":1023},"https://baike.baidu.com/item/syn%20cookie/6898884?fr=aladdin",[198],[1025],{"type":201,"value":1026},"SYN Cookie",{"type":201,"value":1028},"、增加 backlog 队列长度、限制 SYN 并发数。",{"type":185,"tag":217,"props":1030,"children":1031},{},[1032,1033],{"type":201,"value":364},{"type":185,"tag":194,"props":1034,"children":1037},{"href":1035,"rel":1036},"https://www.qycn.com/about/hd/2049.html",[198],[1038],{"type":201,"value":1039},"服务器遭到 SYN 攻击该如何处理呢？",{"type":185,"tag":210,"props":1041,"children":1043},{"id":1042},"请求头加-csrf-参数为什么能防止-csrf-攻击",[1044],{"type":201,"value":1045},"请求头加 CSRF 参数为什么能防止 CSRF 攻击？",{"type":185,"tag":217,"props":1047,"children":1048},{},[1049],{"type":201,"value":1050},"跨站请求伪造是攻击者通过在钓鱼站点发起被钓网站请求（如图片地址），以达到攻击目的。防御方式一般有两种：",{"type":185,"tag":186,"props":1052,"children":1053},{},[1054,1059],{"type":185,"tag":190,"props":1055,"children":1056},{},[1057],{"type":201,"value":1058},"使用 SameSite Cookie，禁用第三方 Cookie",{"type":185,"tag":190,"props":1060,"children":1061},{},[1062],{"type":201,"value":1063},"在请求头中加入 CSRF Token，这样攻击者使用钓鱼站点发起请求时，由于不能设置请求头，所以请求在服务端会被拒绝",{"type":185,"tag":204,"props":1065,"children":1067},{"id":1066},"cdn",[1068],{"type":201,"value":1069},"CDN",{"type":185,"tag":210,"props":1071,"children":1073},{"id":1072},"cdn-有什么好处",[1074],{"type":201,"value":1075},"CDN 有什么好处？",{"type":185,"tag":217,"props":1077,"children":1078},{},[1079],{"type":201,"value":1080},"对页面加载而言，CDN 可以减少请求时间、突破浏览器同域的 TCP 并发数、节约 Cookie 带宽。",{"type":185,"tag":204,"props":1082,"children":1084},{"id":1083},"浏览器",[1085],{"type":201,"value":1083},{"type":185,"tag":210,"props":1087,"children":1089},{"id":1088},"url-由哪些部分组成",[1090],{"type":201,"value":1091},"URL 由哪些部分组成？",{"type":185,"tag":217,"props":1093,"children":1094},{},[1095],{"type":201,"value":1096},"协议头、域名、端口、目录、文件名（index.html）、页面锚、参数。",{"type":185,"tag":210,"props":1098,"children":1100},{"id":1099},"怎么做跨域",[1101],{"type":201,"value":1102},"怎么做跨域？",{"type":185,"tag":217,"props":1104,"children":1105},{},[1106],{"type":201,"value":1107},"用代理服务器、CORS、iFrame 或者 WebSocket 都可以。",{"type":185,"tag":217,"props":1109,"children":1110},{},[1111],{"type":201,"value":1112},"服务器可以忽略同源限制；WebSocket 和 CORS 不受同源影响；iFrame 需要浏览器加载一个跨域页面，然后和主页面用 postMessage 或者哈希监听的方式通信，让 iFrame 中的脚本代替主页面发送请求。",{"type":185,"tag":210,"props":1114,"children":1116},{"id":1115},"正向代理和反向代理的区别是",[1117],{"type":201,"value":1118},"正向代理和反向代理的区别是？",{"type":185,"tag":217,"props":1120,"children":1121},{},[1122],{"type":201,"value":1123},"正向代理为用户服务，反向代理为服务器服务，分别对应“VPN”和“负载均衡”的概念。",{"type":185,"tag":210,"props":1125,"children":1127},{"id":1126},"cors-运作流程是怎样的",[1128],{"type":201,"value":1129},"CORS 运作流程是怎样的？",{"type":185,"tag":217,"props":1131,"children":1132},{},[1133],{"type":201,"value":1134},"CORS 即跨域资源共享机制。浏览器在请求资源前通过携带 Origin 字段的 OPTIONS 请求向服务器索取设置有 Access-Control-Allow-Methods、Access-Control-Allow-Headers、Access-Control-Allow-Origin 的响应。在得到响应的允许后再继续发送请求。",{"type":185,"tag":210,"props":1136,"children":1138},{"id":1137},"什么是私有网络请求攻击",[1139],{"type":201,"value":1140},"什么是私有网络请求攻击？",{"type":185,"tag":217,"props":1142,"children":1143},{},[1144],{"type":201,"value":1145},"在内网域名向 localhost 发起请求就算一种私有网络请求。而恶意代码通过向比浏览器当前浏览页面的域名 IP 更私密的 IP 地址发起请求，以达到获取信息或攻击手段的方式就是私有网络请求攻击。",{"type":185,"tag":217,"props":1147,"children":1148},{},[1149,1151,1158,1160],{"type":201,"value":1150},"自 Chrome 96 后， Chrome 开始实施私有网络控制策略，需要部署以下两个请求头以解除控制：",{"type":185,"tag":1152,"props":1153,"children":1155},"code",{"className":1154},[],[1156],{"type":201,"value":1157},"Access-Control-Request-Private-Network: true",{"type":201,"value":1159}," 和 ",{"type":185,"tag":1152,"props":1161,"children":1163},{"className":1162},[],[1164],{"type":201,"value":1165},"Access-Control-Allow-Private-Network: true",{"type":185,"tag":217,"props":1167,"children":1168},{},[1169,1170],{"type":201,"value":364},{"type":185,"tag":194,"props":1171,"children":1174},{"href":1172,"rel":1173},"https://mp.weixin.qq.com/s?__biz=Mzk0MDMwMzQyOA==&mid=2247491913&idx=1&sn=2bb0a28358c02a8ec1832781205df72c&chksm=c2e11462f5969d74fac277131e1ba8c417ec86754b2f1b2dbe8e238ca27d5c2eaebe602ec803&token=1851580176&lang=zh_CN&scene=21#wechat_redirect",[198],[1175],{"type":201,"value":1176},"Chrome 重大更新，CORS 增加了两个新的请求头？ |  code 秘密花园",{"type":185,"tag":204,"props":1178,"children":1180},{"id":1179},"阅读更多",[1181],{"type":201,"value":1179},{"type":185,"tag":186,"props":1183,"children":1184},{},[1185],{"type":185,"tag":190,"props":1186,"children":1187},{},[1188],{"type":185,"tag":194,"props":1189,"children":1192},{"href":1190,"rel":1191},"https://juejin.im/post/6844903518826921998",[198],[1193],{"type":201,"value":1194},"为你的网站带上帽子 | 使用 helmet 保护 Express 应用",{"title":178,"searchDepth":1196,"depth":1196,"links":1197},2,[1198,1199,1200,1201,1202,1207,1210,1211,1212,1213],{"id":206,"depth":1196,"text":206},{"id":233,"depth":1196,"text":236},{"id":374,"depth":1196,"text":377},{"id":408,"depth":1196,"text":411},{"id":765,"depth":1196,"text":768,"children":1203},[1204,1206],{"id":816,"depth":1205,"text":819},3,{"id":901,"depth":1205,"text":904},{"id":920,"depth":1196,"text":923,"children":1208},[1209],{"id":926,"depth":1205,"text":929},{"id":995,"depth":1196,"text":995},{"id":1066,"depth":1196,"text":1069},{"id":1083,"depth":1196,"text":1083},{"id":1179,"depth":1196,"text":1179},"markdown","content:6.maps:_computer:network.md","content","6.maps/_computer/network.md","6.maps/_computer/network","md",[1221,1225],{"_path":1222,"title":1223,"description":1224},"/maps/_computer/encoding/hash-collision","哈希冲突","哈希冲突是指两个不同的键值被哈希函数映射到了同一个位置。",{"_path":1226,"title":1227,"description":178},"/maps/_computer/segments/http-request-example","Http Request Example",1771695778314]