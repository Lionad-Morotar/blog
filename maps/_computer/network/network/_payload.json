P/IP 协议是一个协议集。TCP/IP 包括了应用层、传输层、网络层、数据链路层和网络层，是一个四层体系结构。各层有代表性的协议有 HTTP、DNS，TLS，IP 和 xxx。",{"type":186,"tag":218,"props":250,"children":251},{},[252,254],{"type":202,"value":253},"TODO，",{"type":186,"tag":195,"props":255,"children":258},{"href":256,"rel":257},"https://developer.51cto.com/article/597961.html",[199],[259],{"type":202,"value":260},"终于有人能把 TCP/IP 协议讲的明明白白了！",{"type":186,"tag":211,"props":262,"children":264},{"id":263},"tcp-header-由哪些部分组成",[265],{"type":202,"value":266},"TCP Header 由哪些部分组成？",{"type":186,"tag":218,"props":268,"children":269},{},[270],{"type":186,"tag":227,"props":271,"children":274},{"alt":272,"src":273},"TCP Header","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200731153510.png?type=win11&w=60",[],{"type":186,"tag":211,"props":276,"children":278},{"id":277},"三次握手具体过程",[279],{"type":202,"value":280},"三次握手具体过程？",{"type":186,"tag":218,"props":282,"children":283},{},[284],{"type":202,"value":285},"从三次握手图示可以发现，仅仅是连接的建立，就需要大量时间消耗。客户端想发送数据，至少要等 1.5xRTT；服务端想发送数据，至少要 2xRTT。",{"type":186,"tag":218,"props":287,"children":288},{},[289],{"type":186,"tag":227,"props":290,"children":293},{"alt":291,"src":292},"Three-way Handshake","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200731162450.png?type=win11&w=40",[],{"type":186,"tag":211,"props":295,"children":297},{"id":296},"tcp-fast-open-如何优化握手过程",[298],{"type":202,"value":299},"TCP Fast Open 如何优化握手过程？",{"type":186,"tag":218,"props":301,"children":302},{},[303],{"type":202,"value":304},"TFO 规定服务器第一次返回 ACK 时，携带一个用以标志客户端身份的 Cookie。后续客户端发送 SYN 建立连接的时候带上这个 Cookie，服务端确认身份之后，就能直接返回数据了（节约了 1.5 RTT）。",{"type":186,"tag":218,"props":306,"children":307},{},[308],{"type":186,"tag":227,"props":309,"children":312},{"alt":310,"src":311},"TFO","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200807054219.png?type=win11&w=80",[],{"type":186,"tag":211,"props":314,"children":316},{"id":315},"四次挥手的具体过程",[317],{"type":202,"value":318},"四次挥手的具体过程？",{"type":186,"tag":218,"props":320,"children":321},{},[322],{"type":202,"value":323},"四次挥手如下所示。为什么建立连接要三次，而断开连接要四次请求呢？从图中可以看出，接收到 FIN 请求时，服务端立即返回 ACK 表示收到请求，但是要等自己这边剩余一些工作（可能时未发送完的请求内容）完成之后，才会返回 FIN。",{"type":186,"tag":218,"props":325,"children":326},{},[327],{"type":186,"tag":227,"props":328,"children":331},{"alt":329,"src":330},"Four-way Wavehand","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200731165331.png?type=win11&w=40",[],{"type":186,"tag":211,"props":333,"children":335},{"id":334},"tcp-链接中如果某端出故障了会怎么办",[336],{"type":202,"value":337},"TCP 链接中如果某端出故障了会怎么办？",{"type":186,"tag":218,"props":339,"children":340},{},[341],{"type":202,"value":342},"会通过计时器来保证链接的稳定性。",{"type":186,"tag":187,"props":344,"children":345},{},[346,351,356],{"type":186,"tag":191,"props":347,"children":348},{},[349],{"type":202,"value":350},"超时重传计时器：对方没有返回 ACK 时，发送方需要重新发送数据。一般计时器的时间选择 2RTT。",{"type":186,"tag":191,"props":352,"children":353},{},[354],{"type":202,"value":355},"2MSL 定时器：主动断开连接的一方发送 FIN 后需要等待 2MSL 时间。因为如果服务端没有收到最后一个 ACK，它将重新发送 FIN。",{"type":186,"tag":191,"props":357,"children":358},{},[359],{"type":202,"value":360},"保活计时器：每当接收方收到消息，将计时器重设为两小时。计时器到期时，每 75s 发送一次探测报文段，如果连续 10 次都没有被响应则断开连接。",{"type":186,"tag":218,"props":362,"children":363},{},[364,366],{"type":202,"value":365},"见：",{"type":186,"tag":195,"props":367,"children":370},{"href":368,"rel":369},"https://www.cnblogs.com/13224ACMer/p/6616960.html",[199],[371],{"type":202,"value":372},"TCP 四种计时器",{"type":186,"tag":205,"props":374,"children":376},{"id":375},"udp",[377],{"type":202,"value":378},"UDP",{"type":186,"tag":218,"props":380,"children":381},{},[382],{"type":202,"value":383},"UDP，即 User Datagram Protocol 用户数据报协议。数据报不保证信息的传达是否到位，所以 UDP 也被普遍称作 Unreliable Datagram Protocol。",{"type":186,"tag":187,"props":385,"children":386},{},[387,392,397,402],{"type":186,"tag":191,"props":388,"children":389},{},[390],{"type":202,"value":391},"不保证消息交付",{"type":186,"tag":191,"props":393,"children":394},{},[395],{"type":202,"value":396},"不保证交付顺序",{"type":186,"tag":191,"props":398,"children":399},{},[400],{"type":202,"value":401},"不跟踪连接状态",{"type":186,"tag":191,"props":403,"children":404},{},[405],{"type":202,"value":406},"不需要拥塞控制",{"type":186,"tag":205,"props":408,"children":410},{"id":409},"http",[411],{"type":202,"value":412},"HTTP",{"type":186,"tag":211,"props":414,"children":416},{"id":415},"有哪些常见的状态码",[417],{"type":202,"value":418},"有哪些常见的状态码？",{"type":186,"tag":420,"props":421,"children":422},"table",{},[423,442],{"type":186,"tag":424,"props":425,"children":426},"thead",{},[427],{"type":186,"tag":428,"props":429,"children":430},"tr",{},[431,437],{"type":186,"tag":432,"props":433,"children":434},"th",{},[435],{"type":202,"value":436},"状态码",{"type":186,"tag":432,"props":438,"children":439},{},[440],{"type":202,"value":441},"描述",{"type":186,"tag":443,"props":444,"children":445},"tbody",{},[446,460,473,486,499,512,525,538,551,564],{"type":186,"tag":428,"props":447,"children":448},{},[449,455],{"type":186,"tag":450,"props":451,"children":452},"td",{},[453],{"type":202,"value":454},"200",{"type":186,"tag":450,"props":456,"children":457},{},[458],{"type":202,"value":459},"成功并返回数据",{"type":186,"tag":428,"props":461,"children":462},{},[463,468],{"type":186,"tag":450,"props":464,"children":465},{},[466],{"type":202,"value":467},"301",{"type":186,"tag":450,"props":469,"children":470},{},[471],{"type":202,"value":472},"永久转移，重定向",{"type":186,"tag":428,"props":474,"children":475},{},[476,481],{"type":186,"tag":450,"props":477,"children":478},{},[479],{"type":202,"value":480},"302",{"type":186,"tag":450,"props":482,"children":483},{},[484],{"type":202,"value":485},"临时重定向",{"type":186,"tag":428,"props":487,"children":488},{},[489,494],{"type":186,"tag":450,"props":490,"children":491},{},[492],{"type":202,"value":493},"303",{"type":186,"tag":450,"props":495,"children":496},{},[497],{"type":202,"value":498},"临时重定向（客户端必须使用 Get 方法重新请求资源）",{"type":186,"tag":428,"props":500,"children":501},{},[502,507],{"type":186,"tag":450,"props":503,"children":504},{},[505],{"type":202,"value":506},"304",{"type":186,"tag":450,"props":508,"children":509},{},[510],{"type":202,"value":511},"资源未修改，可使用缓存",{"type":186,"tag":428,"props":513,"children":514},{},[515,520],{"type":186,"tag":450,"props":516,"children":517},{},[518],{"type":202,"value":519},"400",{"type":186,"tag":450,"props":521,"children":522},{},[523],{"type":202,"value":524},"请求语法错误",{"type":186,"tag":428,"props":526,"children":527},{},[528,533],{"type":186,"tag":450,"props":529,"children":530},{},[531],{"type":202,"value":532},"401",{"type":186,"tag":450,"props":534,"children":535},{},[536],{"type":202,"value":537},"要求身份认证",{"type":186,"tag":428,"props":539,"children":540},{},[541,546],{"type":186,"tag":450,"props":542,"children":543},{},[544],{"type":202,"value":545},"403",{"type":186,"tag":450,"props":547,"children":548},{},[549],{"type":202,"value":550},"请求拒绝",{"type":186,"tag":428,"props":552,"children":553},{},[554,559],{"type":186,"tag":450,"props":555,"children":556},{},[557],{"type":202,"value":558},"404",{"type":186,"tag":450,"props":560,"children":561},{},[562],{"type":202,"value":563},"资源不存在",{"type":186,"tag":428,"props":565,"children":566},{},[567,572],{"type":186,"tag":450,"props":568,"children":569},{},[570],{"type":202,"value":571},"500",{"type":186,"tag":450,"props":573,"children":574},{},[575],{"type":202,"value":576},"服务器错误",{"type":186,"tag":211,"props":578,"children":580},{"id":579},"http-报文由哪些部分组成",[581],{"type":202,"value":582},"HTTP 报文由哪些部分组成？",{"type":186,"tag":218,"props":584,"children":585},{},[586],{"type":202,"value":587},"请求报文由请求行、请求头、空行和请求数据组成，相应报文类似。",{"type":186,"tag":218,"props":589,"children":590},{},[591],{"type":202,"value":592},"请求报文实例：",{"type":186,"tag":218,"props":594,"children":595},{},[596],{"type":202,"value":597},"相应报文实例：",{"type":186,"tag":211,"props":599,"children":601},{"id":600},"http-11-对比-http-10-做了哪些改进",[602],{"type":202,"value":603},"HTTP 1.1 对比 HTTP 1.0 做了哪些改进？",{"type":186,"tag":218,"props":605,"children":606},{},[607],{"type":202,"value":608},"长链接（keep-alive）、断点续传、HTTP 缓存。",{"type":186,"tag":211,"props":610,"children":612},{"id":611},"http-缓存分几种",[613],{"type":202,"value":614},"HTTP 缓存分几种？",{"type":186,"tag":218,"props":616,"children":617},{},[618],{"type":202,"value":619},"分强缓存和协商缓存：Expires、Cache-Control、Last-Modified、Etag。",{"type":186,"tag":218,"props":621,"children":622},{},[623],{"type":186,"tag":227,"props":624,"children":627},{"alt":625,"src":626},"HTTP Cache","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220630205606.png?type=win11&w=60",[],{"type":186,"tag":218,"props":629,"children":630},{},[631,632],{"type":202,"value":253},{"type":186,"tag":195,"props":633,"children":636},{"href":634,"rel":635},"https://imweb.io/topic/55c6f9bac222e3af6ce235b9",[199],[637],{"type":202,"value":634},{"type":186,"tag":211,"props":639,"children":641},{"id":640},"强缓存和协商缓存的主要区别是",[642],{"type":202,"value":643},"强缓存和协商缓存的主要区别是？",{"type":186,"tag":218,"props":645,"children":646},{},[647],{"type":202,"value":648},"强缓存是一但匹配就无条件使用缓存，而面对协商缓存的资源，浏览器需要向服务端发请求，对比资源是否变更，并依靠服务端的响应来判断是否使用缓存。如果资源同时应用了强缓存和协商缓存，那么浏览器优先使用强缓存。",{"type":186,"tag":211,"props":650,"children":652},{"id":651},"no-store-和-no-cache-的区别",[653],{"type":202,"value":654},"no-store 和 no-cache 的区别？",{"type":186,"tag":218,"props":656,"children":657},{},[658],{"type":202,"value":659},"no-store 告诉客户端每次都在服务器取最新的资源。no-cache 也要求每次都要重新请求，但服务器可能返回 304 告诉客户端资源未改变。",{"type":186,"tag":211,"props":661,"children":663},{"id":662},"http2-的改进在哪里",[664],{"type":202,"value":665},"HTTP2 的改进在哪里？",{"type":186,"tag":218,"props":667,"children":668},{},[669],{"type":202,"value":670},"HTTP/2 主要包含以下几个方面的变化，显著增强了性能，也增加了安全性。",{"type":186,"tag":187,"props":672,"children":673},{},[674,679,684,689],{"type":186,"tag":191,"props":675,"children":676},{},[677],{"type":202,"value":678},"二进制分帧层",{"type":186,"tag":191,"props":680,"children":681},{},[682],{"type":202,"value":683},"头部压缩（HPACK、Huffman）",{"type":186,"tag":191,"props":685,"children":686},{},[687],{"type":202,"value":688},"多路复用",{"type":186,"tag":191,"props":690,"children":691},{},[692],{"type":202,"value":693},"服务端推送",{"type":186,"tag":218,"props":695,"children":696},{},[697],{"type":202,"value":698},"二进制分帧层是在应用层（HTTP）和传输层（TCP、UDP）之间新增的一个层级关系。二进制分帧层将传输的 HTTP 消息分割为更小的帧，并采用二进制格式编码传输。帧分为头部帧和消息帧。这意味着 HTTP/2 请求的所有内容都是二进制传输的。",{"type":186,"tag":218,"props":700,"children":701},{},[702],{"type":202,"value":703},"HTTP 头部被转为帧之前，会通过维护一个表结构，通过序号记录已发送的键值对。这是一种索引算法，叫 HPACK。具体的表结构分静态表和动态表，静态表给一些常用的头部标号了号，直接使用就好，动态表则是根据发送的内容动态确定的记号。需要被发送具体内容会被哈夫曼编码以减小体积。",{"type":186,"tag":218,"props":705,"children":706},{},[707],{"type":202,"value":708},"多路复用是指，多个 HTTP 请求可以在同一个 TCP 连接中并行传输。这和 HTTP 1.1 的 Connection：keep-alive 不同，keep-alive 虽然复用 TCP 连接，但是多个响应之间是串行的。",{"type":186,"tag":218,"props":710,"children":711},{},[712],{"type":202,"value":713},"建立连接后，双方通过交换 SETTING 帧，以确认双向的流量窗口控制大小。然后开始发送帧。帧可以在一个连接中根据优先级发送，或是被乱序发送，响应方也能乱序接收。由于流是双向的，只要服务端 SETTING 帧设置的流量窗口大小不为 0，服务端可按照同源策略推送资源给客户端。",{"type":186,"tag":218,"props":715,"children":716},{},[717,718,725,727],{"type":202,"value":365},{"type":186,"tag":195,"props":719,"children":722},{"href":720,"rel":721},"https://coffe1891.gitbook.io/frontend-hard-mode-interview/1/1.5.3",[199],[723],{"type":202,"value":724},"HTTP/2 和 HTTP/1.X 相比的新特性",{"type":202,"value":726},"、",{"type":186,"tag":195,"props":728,"children":731},{"href":729,"rel":730},"https://blog.csdn.net/gaoliang1719/article/details/106346201/",[199],[732],{"type":202,"value":733},"HTTP/2 协议之头部压缩",{"type":186,"tag":211,"props":735,"children":737},{"id":736},"http3-相比-http2-改变了什么东西",[738],{"type":202,"value":739},"HTTP3 相比 HTTP2 改变了什么东西？",{"type":186,"tag":218,"props":741,"children":742},{},[743],{"type":202,"value":744},"HTTP3 使用全新的传输层协议 QUIC，实现了 H2 中的流式传输（HTTP2）、多路复用（TCP）、流量控制（TCP）以及可靠性（TCP）等内容，其网络层协议应用的是 UDP 而不是 TCP，本意是用来解决 TCP 建立链接需要  1.5 RTT 延迟的问题。这种改善在移动端更加有效。",{"type":186,"tag":218,"props":746,"children":747},{},[748],{"type":186,"tag":227,"props":749,"children":752},{"alt":750,"src":751},"HTTP3 VS HTTP2 VS HTTP1.1","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220621003527.png?type=draw&w=80",[],{"type":186,"tag":218,"props":754,"children":755},{},[756,757],{"type":202,"value":365},{"type":186,"tag":195,"props":758,"children":761},{"href":759,"rel":760},"https://mp.weixin.qq.com/s/40YBEWZBaHakDuRuh27fMg",[199],[762],{"type":202,"value":763},"HTTP3 发布了！",{"type":186,"tag":205,"props":765,"children":767},{"id":766},"tls",[768],{"type":202,"value":769},"TLS",{"type":186,"tag":218,"props":771,"children":772},{},[773,774],{"type":202,"value":253},{"type":186,"tag":195,"props":775,"children":778},{"href":776,"rel":777},"https://www.oschina.net/translate/rfc-8446-aka-tls-1-3",[199],[779],{"type":202,"value":780},"详细介绍 RFC 8446（即 TLS 1.3）",{"type":186,"tag":218,"props":782,"children":783},{},[784],{"type":202,"value":785},"TLS 是一种混合式加密系统，同时使用对称加密和非对称加密。它使用非对称加密以加密对称加密所需的密钥。它有多个版本。TLS 1.3 是一种比起 TLS1.2 而言更清晰、更快速、更安全的现代化安全协议。TLS 1.2 有两点问题：1. 包括 POODLE 在内的众多可行漏洞；2. 性能低。为了改善这些问题，IETF 在 2013 年，着手 TLS 1.3 的讨论，主要改进：",{"type":186,"tag":187,"props":787,"children":788},{},[789,794,799,804],{"type":186,"tag":191,"props":790,"children":791},{},[792],{"type":202,"value":793},"减少握手时间",{"type":186,"tag":191,"props":795,"children":796},{},[797],{"type":202,"value":798},"加密更多的握手",{"type":186,"tag":191,"props":800,"children":801},{},[802],{"type":202,"value":803},"改善跨协议攻击的弹性",{"type":186,"tag":191,"props":805,"children":806},{},[807],{"type":202,"value":808},"删除遗留特征",{"type":186,"tag":218,"props":810,"children":811},{},[812],{"type":202,"value":813},"经过 4 年的争论。最终，形成了 RFC 8446 规范。",{"type":186,"tag":815,"props":816,"children":818},"h3",{"id":817},"tls-12-的缺陷",[819],{"type":202,"value":820},"TLS 1.2 的缺陷",{"type":186,"tag":218,"props":822,"children":823},{},[824],{"type":202,"value":825},"TLS 1.2 使用的加密方式有缺陷。其中，非对称加密有如 RSA 和 Diffie-Hellman 协议。",{"type":186,"tag":211,"props":827,"children":829},{"id":828},"rsa",[830],{"type":202,"value":831},"RSA",{"type":186,"tag":218,"props":833,"children":834},{},[835],{"type":186,"tag":227,"props":836,"children":839},{"alt":837,"src":838},"RSA Handshake","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200807082140.png?w=70",[],{"type":186,"tag":218,"props":841,"children":842},{},[843,845,852],{"type":202,"value":844},"RSA 不保证前向保密。即，如果有人记录了加密对话，然后获取服务器的 RSA 私钥，他们可以将对话解密。而攻击者可能只需 ",{"type":186,"tag":195,"props":846,"children":849},{"href":847,"rel":848},"https://www.wikiwand.com/zh/%E5%BF%83%E8%84%8F%E5%87%BA%E8%A1%80%E6%BC%8F%E6%B4%9E",[199],[850],{"type":202,"value":851},"HeartBleed 漏洞",{"type":202,"value":853},"（缓存区过读）就可以顺利窃取私钥。",{"type":186,"tag":211,"props":855,"children":857},{"id":856},"diffie-hellman",[858],{"type":202,"value":859},"Diffie-Hellman",{"type":186,"tag":218,"props":861,"children":862},{},[863],{"type":186,"tag":227,"props":864,"children":866},{"alt":859,"src":865},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200807082812.png?w=70",[],{"type":186,"tag":218,"props":868,"children":869},{},[870],{"type":202,"value":871},"Diffie-Hellman 的缺陷在于，协议的某些参数不安全，且能够被操纵设置；不安全的参数能导致加密更容易被破解。",{"type":186,"tag":211,"props":873,"children":875},{"id":874},"对称加密缺陷",[876],{"type":202,"value":874},{"type":186,"tag":218,"props":878,"children":879},{},[880],{"type":202,"value":881},"TLS 1.2 的对称加密使用的 CBC 模式密码和流式密码也有缺陷。",{"type":186,"tag":211,"props":883,"children":885},{"id":884},"downgrade-attack",[886],{"type":202,"value":887},"Downgrade Attack",{"type":186,"tag":218,"props":889,"children":890},{},[891],{"type":202,"value":892},"由于 TLS 1.2 握手协商密钥的部分没有加密。所以中间人可以拦截客户端的请求，选择发送方和接收方都支持的弱密码，伪造请求。",{"type":186,"tag":218,"props":894,"children":895},{},[896],{"type":186,"tag":227,"props":897,"children":899},{"alt":887,"src":898},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200807090034.png?w=70",[],{"type":186,"tag":815,"props":901,"children":903},{"id":902},"_0-rtt",[904],{"type":202,"value":905},"0-RTT",{"type":186,"tag":218,"props":907,"children":908},{},[909],{"type":202,"value":910},"TLS 1.3 中，通讯双方可以得到一个\"恢复主密钥\"的密钥，用于从中断的连接中直接恢复通讯。但是有被拦截导致重放攻击的风险。",{"type":186,"tag":218,"props":912,"children":913},{},[914],{"type":186,"tag":227,"props":915,"children":918},{"alt":916,"src":917},"0-RTT 重放攻击","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200807081140.png?w=70",[],{"type":186,"tag":205,"props":920,"children":922},{"id":921},"https",[923],{"type":202,"value":924},"HTTPS",{"type":186,"tag":815,"props":926,"children":928},{"id":927},"links",[929],{"type":202,"value":930},"Links",{"type":186,"tag":218,"props":932,"children":933},{},[934,935],{"type":202,"value":253},{"type":186,"tag":195,"props":936,"children":939},{"href":937,"rel":938},"https://zhuanlan.zhihu.com/p/26682342",[199],[940],{"type":202,"value":941},"深入理解 HTTPS 原理、过程与实践",{"type":186,"tag":211,"props":943,"children":945},{"id":944},"https-的握手过程是怎样的",[946],{"type":202,"value":947},"HTTPS 的握手过程是怎样的？",{"type":186,"tag":218,"props":949,"children":950},{},[951],{"type":202,"value":952},"总的来说是一个非对称加密+对称加密的过程。客户端通过一个随机数加上服务器的公钥来生成预主密钥，然后双方再通过 Client Hello 和 Server Hello 时的两个随机数生成会话密钥。生成预主密钥的过程是非对称加密的，因为只有服务端用私钥才能解得客户端的随机数。而之后使用会话密钥主要是出于性能考虑。",{"type":186,"tag":218,"props":954,"children":955},{},[956],{"type":186,"tag":227,"props":957,"children":960},{"alt":958,"src":959},"HTTPS 握手过程","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220620024738.png",[],{"type":186,"tag":211,"props":962,"children":964},{"id":963},"ca-怎么解决中间人问题",[965],{"type":202,"value":966},"CA 怎么解决中间人问题？",{"type":186,"tag":218,"props":968,"children":969},{},[970],{"type":202,"value":971},"CA 主要是用来防范服务器端返回 Server Hello 前就和客户端提供了假的公钥。CA 是一个可信的第三方机构，客户端想要服务器的公钥，需要从 CA 获得。CA 返回公钥以及数字签名。客户端只要拿到公钥后根据 CA 公钥对其计算获得摘要，再将摘要和签名进行对比，就能知道是否拿到了可信的公钥。",{"type":186,"tag":218,"props":973,"children":974},{},[975,976],{"type":202,"value":365},{"type":186,"tag":195,"props":977,"children":980},{"href":978,"rel":979},"https://www.jianshu.com/p/9de06222793b",[199],[981],{"type":202,"value":982},"HTTPS CA 原理",{"type":186,"tag":211,"props":984,"children":986},{"id":985},"数字签名是什么",[987],{"type":202,"value":988},"数字签名是什么？",{"type":186,"tag":218,"props":990,"children":991},{},[992],{"type":202,"value":993},"数字签名是只有信息发送者才能产生的一段文本，信息接收方可以通过签名计算出接受到的文本是否经过了修改。如果我要发送 A，我会用私钥将 A 进行加密获得 B，并把 A 和 B 同时发送过去。B 就是数字签名。因为我的公钥是公开的，所以接受方可以通过使用我的公钥去计算 A，如果获得和 B 一致的结果，那么说明信息没有被篡改。",{"type":186,"tag":205,"props":995,"children":997},{"id":996},"攻防",[998],{"type":202,"value":996},{"type":186,"tag":211,"props":1000,"children":1002},{"id":1001},"https-降级攻击的原理是什么",[1003],{"type":202,"value":1004},"HTTPS 降级攻击的原理是什么？",{"type":186,"tag":218,"props":1006,"children":1007},{},[1008],{"type":202,"value":1009},"客服端与服务端协商加密协议的过程当中，如果攻击者拦截了客户端（或操控客户端）并代替它向服务端协商使用仅支持有漏洞的协议。如果服务端同意了，那么建立连接后，攻击者就能使用该协议的已知漏洞的破解手段，去破解通讯内容了。",{"type":186,"tag":211,"props":1011,"children":1013},{"id":1012},"syn-攻击的基本原理是什么",[1014],{"type":202,"value":1015},"SYN 攻击的基本原理是什么？",{"type":186,"tag":218,"props":1017,"children":1018},{},[1019,1021,1028],{"type":202,"value":1020},"SYN 洪水攻击是 DDOS 攻击中最常见的攻击类型。攻击者向服务器发送大量伪造的 TCP 连接请求，而源 IP 是伪造的。由于服务器收不到伪造源回应的 ACK 数据包，就会不断重发。一般应对方式是：减少重发次数、使用 ",{"type":186,"tag":195,"props":1022,"children":1025},{"href":1023,"rel":1024},"https://baike.baidu.com/item/syn%20cookie/6898884?fr=aladdin",[199],[1026],{"type":202,"value":1027},"SYN Cookie",{"type":202,"value":1029},"、增加 backlog 队列长度、限制 SYN 并发数。",{"type":186,"tag":218,"props":1031,"children":1032},{},[1033,1034],{"type":202,"value":365},{"type":186,"tag":195,"props":1035,"children":1038},{"href":1036,"rel":1037},"https://www.qycn.com/about/hd/2049.html",[199],[1039],{"type":202,"value":1040},"服务器遭到 SYN 攻击该如何处理呢？",{"type":186,"tag":211,"props":1042,"children":1044},{"id":1043},"请求头加-csrf-参数为什么能防止-csrf-攻击",[1045],{"type":202,"value":1046},"请求头加 CSRF 参数为什么能防止 CSRF 攻击？",{"type":186,"tag":218,"props":1048,"children":1049},{},[1050],{"type":202,"value":1051},"跨站请求伪造是攻击者通过在钓鱼站点发起被钓网站请求（如图片地址），以达到攻击目的。防御方式一般有两种：",{"type":186,"tag":187,"props":1053,"children":1054},{},[1055,1060],{"type":186,"tag":191,"props":1056,"children":1057},{},[1058],{"type":202,"value":1059},"使用 SameSite Cookie，禁用第三方 Cookie",{"type":186,"tag":191,"props":1061,"children":1062},{},[1063],{"type":202,"value":1064},"在请求头中加入 CSRF Token，这样攻击者使用钓鱼站点发起请求时，由于不能设置请求头，所以请求在服务端会被拒绝",{"type":186,"tag":205,"props":1066,"children":1068},{"id":1067},"cdn",[1069],{"type":202,"value":1070},"CDN",{"type":186,"tag":211,"props":1072,"children":1074},{"id":1073},"cdn-有什么好处",[1075],{"type":202,"value":1076},"CDN 有什么好处？",{"type":186,"tag":218,"props":1078,"children":1079},{},[1080],{"type":202,"value":1081},"对页面加载而言，CDN 可以减少请求时间、突破浏览器同域的 TCP 并发数、节约 Cookie 带宽。",{"type":186,"tag":205,"props":1083,"children":1085},{"id":1084},"浏览器",[1086],{"type":202,"value":1084},{"type":186,"tag":211,"props":1088,"children":1090},{"id":1089},"url-由哪些部分组成",[1091],{"type":202,"value":1092},"URL 由哪些部分组成？",{"type":186,"tag":218,"props":1094,"children":1095},{},[1096],{"type":202,"value":1097},"协议头、域名、端口、目录、文件名（index.html）、页面锚、参数。",{"type":186,"tag":211,"props":1099,"children":1101},{"id":1100},"怎么做跨域",[1102],{"type":202,"value":1103},"怎么做跨域？",{"type":186,"tag":218,"props":1105,"children":1106},{},[1107],{"type":202,"value":1108},"用代理服务器、CORS、iFrame 或者 WebSocket 都可以。",{"type":186,"tag":218,"props":1110,"children":1111},{},[1112],{"type":202,"value":1113},"服务器可以忽略同源限制；WebSocket 和 CORS 不受同源影响；iFrame 需要浏览器加载一个跨域页面，然后和主页面用 postMessage 或者哈希监听的方式通信，让 iFrame 中的脚本代替主页面发送请求。",{"type":186,"tag":211,"props":1115,"children":1117},{"id":1116},"正向代理和反向代理的区别是",[1118],{"type":202,"value":1119},"正向代理和反向代理的区别是？",{"type":186,"tag":218,"props":1121,"children":1122},{},[1123],{"type":202,"value":1124},"正向代理为用户服务，反向代理为服务器服务，分别对应\"VPN\"和\"负载均衡\"的概念。",{"type":186,"tag":211,"props":1126,"children":1128},{"id":1127},"cors-运作流程是怎样的",[1129],{"type":202,"value":1130},"CORS 运作流程是怎样的？",{"type":186,"tag":218,"props":1132,"children":1133},{},[1134],{"type":202,"value":1135},"CORS 即跨域资源共享机制。浏览器在请求资源前通过携带 Origin 字段的 OPTIONS 请求向服务器索取设置有 Access-Control-Allow-Methods、Access-Control-Allow-Headers、Access-Control-Allow-Origin 的响应。在得到响应的允许后再继续发送请求。",{"type":186,"tag":211,"props":1137,"children":1139},{"id":1138},"什么是私有网络请求攻击",[1140],{"type":202,"value":1141},"什么是私有网络请求攻击？",{"type":186,"tag":218,"props":1143,"children":1144},{},[1145],{"type":202,"value":1146},"在内网域名向 localhost 发起请求就算一种私有网络请求。而恶意代码通过向比浏览器当前浏览页面的域名 IP 更私密的 IP 地址发起请求，以达到获取信息或攻击手段的方式就是私有网络请求攻击。",{"type":186,"tag":218,"props":1148,"children":1149},{},[1150,1152,1159,1161],{"type":202,"value":1151},"自 Chrome 96 后， Chrome 开始实施私有网络控制策略，需要部署以下两个请求头以解除控制：",{"type":186,"tag":1153,"props":1154,"children":1156},"code",{"className":1155},[],[1157],{"type":202,"value":1158},"Access-Control-Request-Private-Network: true",{"type":202,"value":1160}," 和 ",{"type":186,"tag":1153,"props":1162,"children":1164},{"className":1163},[],[1165],{"type":202,"value":1166},"Access-Control-Allow-Private-Network: true",{"type":186,"tag":218,"props":1168,"children":1169},{},[1170,1171],{"type":202,"value":365},{"type":186,"tag":195,"props":1172,"children":1175},{"href":1173,"rel":1174},"https://mp.weixin.qq.com/s?__biz=Mzk0MDMwMzQyOA==&mid=2247491913&idx=1&sn=2bb0a28358c02a8ec1832781205df72c&chksm=c2e11462f5969d74fac277131e1ba8c417ec86754b2f1b2dbe8e238ca27d5c2eaebe602ec803&token=1851580176&lang=zh_CN&scene=21#wechat_redirect",[199],[1176],{"type":202,"value":1177},"Chrome 重大更新，CORS 增加了两个新的请求头？ |  code 秘密花园",{"type":186,"tag":205,"props":1179,"children":1181},{"id":1180},"阅读更多",[1182],{"type":202,"value":1180},{"type":186,"tag":187,"props":1184,"children":1185},{},[1186],{"type":186,"tag":191,"props":1187,"children":1188},{},[1189],{"type":186,"tag":195,"props":1190,"children":1193},{"href":1191,"rel":1192},"https://juejin.im/post/6844903518826921998",[199],[1194],{"type":202,"value":1195},"为你的网站带上帽子 | 使用 helmet 保护 Express 应用",{"title":178,"searchDepth":1197,"depth":1197,"links":1198},2,[1199,1200,1201,1202,1203,1208,1211,1212,1213,1214],{"id":207,"depth":1197,"text":207},{"id":234,"depth":1197,"text":237},{"id":375,"depth":1197,"text":378},{"id":409,"depth":1197,"text":412},{"id":766,"depth":1197,"text":769,"children":1204},[1205,1207],{"id":817,"depth":1206,"text":820},3,{"id":902,"depth":1206,"text":905},{"id":921,"depth":1197,"text":924,"children":1209},[1210],{"id":927,"depth":1206,"text":930},{"id":996,"depth":1197,"text":996},{"id":1067,"depth":1197,"text":1070},{"id":1084,"depth":1197,"text":1084},{"id":1180,"depth":1197,"text":1180},"markdown","content:6.maps:_computer:network:network.md","content","6.maps/_computer/network/network.md","6.maps/_computer/network/network","md",[1222,1226],{"_path":1223,"title":1224,"description":1225},"/maps/_computer/fundamentals/fundamentals","计算机基础","计算机基础知识导图，包含进制转换、数字电路设计、原码反码补码等核心概念的详细解析。",{"_path":1227,"title":1228,"description":178},"/maps/_computer/network/segments/http-request-example","Http Request Example",1772504904744]