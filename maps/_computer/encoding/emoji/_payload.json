，是一种用来在电子通信中传达情感的符号。",{"type":182,"children":183,"toc":352},"root",[184,200,206,221,226,244,255,260,265,270,288,294,300,305,323,329],{"type":185,"tag":186,"props":187,"children":189},"element","h4",{"id":188},"javascript-下含有-emoji-字符串的处理",[190,197],{"type":185,"tag":191,"props":192,"children":196},"link",{"type":193,"to":194,"source":195},"h5","https://mgear-file.oss-cn-shanghai.aliyuncs.com/JavaScript%E4%B8%8B%E5%90%AB%E6%9C%89emoji%E5%AD%97%E7%AC%A6%E4%B8%B2%E7%9A%84%E5%A4%84%E7%90%86%20-%20%E6%8E%98%E9%87%91.html","https://juejin.cn/post/6941276804472635405",[],{"type":198,"value":199},"text","《JavaScript 下含有 emoji 字符串的处理》",{"type":185,"tag":201,"props":202,"children":203},"p",{},[204],{"type":198,"value":205},"在处理 emoji 字符时有些坑。",{"type":185,"tag":207,"props":208,"children":209},"ul",{},[210,216],{"type":185,"tag":211,"props":212,"children":213},"li",{},[214],{"type":198,"value":215},"String 原型上的 length、split、substr 等函数不能正确计算带 emoji 字符串",{"type":185,"tag":211,"props":217,"children":218},{},[219],{"type":198,"value":220},"展开运算符会把组合 emoji 拆开",{"type":185,"tag":201,"props":222,"children":223},{},[224],{"type":198,"value":225},"另一些坑可使用常规方法规避。",{"type":185,"tag":207,"props":227,"children":228},{},[229,234,239],{"type":185,"tag":211,"props":230,"children":231},{},[232],{"type":198,"value":233},"String 原型上的 charAt 和 fromCharCode 函数可分别使用 ES6 新增的 charPointAt、fromCharPoint 代替",{"type":185,"tag":211,"props":235,"children":236},{},[237],{"type":198,"value":238},"字符串遍历 for...in 可以使用 for...of 代替",{"type":185,"tag":211,"props":240,"children":241},{},[242],{"type":198,"value":243},"正则匹配时可以在后面加一个 unicode 标记",{"type":185,"tag":186,"props":245,"children":247},{"id":246},"从-unicode-到-emoji",[248,253],{"type":185,"tag":191,"props":249,"children":252},{"type":193,"to":250,"source":251},"https://mgear-file.oss-cn-shanghai.aliyuncs.com/%E4%BB%8EUnicode%E5%88%B0emoji%20-%20%E7%9F%A5%E4%B9%8E.html","https://zhuanlan.zhihu.com/p/41203455",[],{"type":198,"value":254},"《从 Unicode 到 emoji》",{"type":185,"tag":201,"props":256,"children":257},{},[258],{"type":198,"value":259},"ASCII 使用一个字节来编码，所以远远不够用，但因为它的编码集只占用了 128 种，所以一个字节开头的高位就用不上了。所以类似 GBK 字符集的解决方案是如果高位是 0 那么就是一字节的英文字符，否则使用连续的两字节来表示其他字符，这种方案叫做“代码页”。",{"type":185,"tag":201,"props":261,"children":262},{},[263],{"type":198,"value":264},"不过代码页不好用，因为在不同的操作系统、不同的厂商、软件中代码页不尽相同，所以后来出现了 Unicode，它尝试将世界上所有的字符统一编码。Unicode 一开始是两个字节的，后来不够用才变成了四个字节。传输的时候为了不要传输那么多“0”，所以需要对编码进行序列化及压缩。所以后来出现了 UTF 这种编码方式。",{"type":185,"tag":201,"props":266,"children":267},{},[268],{"type":198,"value":269},"Emoji 就更好玩了，出现了一些特殊的用法：",{"type":185,"tag":207,"props":271,"children":272},{},[273,278,283],{"type":185,"tag":211,"props":274,"children":275},{},[276],{"type":198,"value":277},"使用单色修饰符确定 emoji 是单色还是彩色的，如 ⚠︎ === U+26A0 + U+FE0E，⚠️ === U+26A0 + U+FE0F",{"type":185,"tag":211,"props":279,"children":280},{},[281],{"type":198,"value":282},"使用肤色修饰符确定 emoji 中出现的人物的肤色，如 🧒 === U+1f9d2，🧒🏿 === U+1f9d2 + U+1f3ff",{"type":185,"tag":211,"props":284,"children":285},{},[286],{"type":198,"value":287},"使用零宽连接符 U+200D 将不同的 emoji 组合起来成为一个单独的符号（不支持的系统会自动回退为多个 emoji）",{"type":185,"tag":289,"props":290,"children":292},"h2",{"id":291},"跨平台实现差异",[293],{"type":198,"value":291},{"type":185,"tag":186,"props":295,"children":297},{"id":296},"华为鸿蒙-emoji-的差异化设计",[298],{"type":198,"value":299},"华为鸿蒙 Emoji 的差异化设计",{"type":185,"tag":201,"props":301,"children":302},{},[303],{"type":198,"value":304},"表情符号（emoji）在各系统的实现趋势是向苹果设计靠拢（如\"枪\"都变成\"水枪\"），但华为鸿蒙系统是例外。华为采用了独特的本土文化设计：\"恳求\"表情只有华为是双手合十（其他系统是🥺）；\"风筝\"表情只有华为是中式的纸鸢（其他系统是菱形风筝）。这种差异化既体现了文化自信，也可能造成跨平台沟通的理解偏差。",{"type":185,"tag":306,"props":307,"children":308},"blockquote",{},[309],{"type":185,"tag":201,"props":310,"children":311},{},[312,314],{"type":198,"value":313},"#周刊摘录 见：",{"type":185,"tag":315,"props":316,"children":320},"a",{"href":317,"rel":318},"https://www.ruanyifeng.com/blog/2026/02/weekly-issue-385.html",[319],"nofollow",[321],{"type":198,"value":322},"科技周刊第385期",{"type":185,"tag":289,"props":324,"children":326},{"id":325},"todo",[327],{"type":198,"value":328},"TODO",{"type":185,"tag":207,"props":330,"children":331},{},[332,342],{"type":185,"tag":211,"props":333,"children":334},{},[335],{"type":185,"tag":315,"props":336,"children":339},{"href":337,"rel":338},"https://tao.zz.ac/utf-8.html",[319],[340],{"type":198,"value":341},"《UTF-8 往事》",{"type":185,"tag":211,"props":343,"children":344},{},[345],{"type":185,"tag":315,"props":346,"children":349},{"href":347,"rel":348},"https://tao.zz.ac/emoji.html",[319],[350],{"type":198,"value":351},"《Emoji 的奥秘》",{"title":178,"searchDepth":353,"depth":353,"links":354},2,[355,356],{"id":291,"depth":353,"text":291},{"id":325,"depth":353,"text":328},"markdown","content:6.maps:_computer:encoding:emoji.md","content","6.maps/_computer/encoding/emoji.md","6.maps/_computer/encoding/emoji","md",[364,368],{"_path":365,"title":366,"description":367},"/maps/_computer/encoding","编码","编码是将信息从一种形式或格式转换为另一种形式或格式的过程。",{"_path":369,"title":370,"description":371},"/maps/_computer/encoding/hash-collision","哈希冲突","哈希冲突是指两个不同的键值被哈希函数映射到了同一个位置。",1771695801892]