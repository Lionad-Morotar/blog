type":182,"children":183,"toc":288},"root",[184,192,207,212,224,229,243,249,254,263,268,273,278,283],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"字符编码",[190],{"type":191,"value":188},"text",{"type":185,"tag":193,"props":194,"children":195},"ul",{},[196],{"type":185,"tag":197,"props":198,"children":199},"li",{},[200],{"type":185,"tag":201,"props":202,"children":204},"a",{"href":203},"/maps/_computer/encoding/emoji",[205],{"type":191,"value":206},"Emoji",{"type":185,"tag":186,"props":208,"children":210},{"id":209},"哈希",[211],{"type":191,"value":209},{"type":185,"tag":193,"props":213,"children":214},{},[215],{"type":185,"tag":197,"props":216,"children":217},{},[218],{"type":185,"tag":201,"props":219,"children":221},{"href":220},"/maps/_computer/encoding/hash-collision",[222],{"type":191,"value":223},"哈希冲突",{"type":185,"tag":186,"props":225,"children":227},{"id":226},"图像编码",[228],{"type":191,"value":226},{"type":185,"tag":230,"props":231,"children":233},"h4",{"id":232},"understanding-proraw",[234,241],{"type":185,"tag":235,"props":236,"children":240},"link",{"type":237,"to":238,"source":239},"h5","https://mgear-file.oss-cn-shanghai.aliyuncs.com/Understanding%20ProRAW%20%E2%80%93%20Lux.html","https://lux.camera/understanding-proraw/",[],{"type":191,"value":242},"《Understanding ProRAW》",{"type":185,"tag":244,"props":245,"children":246},"p",{},[247],{"type":191,"value":248},"成像到出图有三个步骤：去像素化、色调映射和压缩。",{"type":185,"tag":244,"props":250,"children":251},{},[252],{"type":191,"value":253},"根据传感器上不同像素获得的颜色数据，去像素化会使用不同算法猜出原像素的颜色。",{"type":185,"tag":244,"props":255,"children":256},{},[257],{"type":185,"tag":258,"props":259,"children":262},"img",{"alt":260,"src":261},"去像素化 | https://lux.camera/understanding-proraw/","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20210920022854.png",[],{"type":185,"tag":244,"props":264,"children":265},{},[266],{"type":191,"value":267},"色调映射时会涉及到色彩空间转换、白平衡和动态处理相关的技术。",{"type":185,"tag":244,"props":269,"children":270},{},[271],{"type":191,"value":272},"压缩则是把原始数据砍精度，再通过有损压缩方案输出成一张 JEPG 之类的图片。",{"type":185,"tag":244,"props":274,"children":275},{},[276],{"type":191,"value":277},"因为 JPEG 的压缩有损，所以对 JPEG 进行后期就好比还原一个烘焙好的蛋糕一样艰难。而 RAW 文件保存的不是有损压缩后的图片数据，而是从传感器获取的原始数据，所以允许你使用最大限度的对图像进行改动。",{"type":185,"tag":244,"props":279,"children":280},{},[281],{"type":191,"value":282},"RAW 的缺陷就在于预览时非常难看，除非用来打开 RAW 的软件能用上 iPhone 一样的预览 RAW 时自动优化的功能。",{"type":185,"tag":244,"props":284,"children":285},{},[286],{"type":191,"value":287},"这时候，ProRAW 来了，它保存的不再是传感器的原始数据，而是去像素化后的数据，也就是说 iPhone 把传感器数据优化后的那部分内容保存下来了。苹果和 Adobe 公司共同开发了 DNG 文件标准，里面定义了 RAW 文件能用上的不同的数据标签，第三方软件可以直接从 ProRAW 拿到成像、精度、色调等信息，也就可以很方便的处理图片了。",{"title":178,"searchDepth":289,"depth":289,"links":290},2,[291,292,293],{"id":188,"depth":289,"text":188},{"id":209,"depth":289,"text":209},{"id":226,"depth":289,"text":226},"markdown","content:6.maps:_computer:encoding.md","content","6.maps/_computer/encoding.md","6.maps/_computer/encoding","md",[301,305],{"_path":302,"title":303,"description":304},"/maps/_computer/computer","Computer Mind Map","计算机基础知识导图，包含进制转换、数字电路设计、原码反码补码等核心概念的详细解析。",{"_path":203,"title":206,"description":306},"Emoji 是一种表情符号，是一种用来在电子通信中传达情感的符号。",1771693390791]