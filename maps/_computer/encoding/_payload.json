4,209,221,226,240,246,251,260,265,270,275,280],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"字符编码",[187],{"type":188,"value":185},"text",{"type":182,"tag":190,"props":191,"children":192},"ul",{},[193],{"type":182,"tag":194,"props":195,"children":196},"li",{},[197],{"type":182,"tag":198,"props":199,"children":201},"a",{"href":200},"/maps/_computer/encoding/emoji",[202],{"type":188,"value":203},"Emoji",{"type":182,"tag":183,"props":205,"children":207},{"id":206},"哈希",[208],{"type":188,"value":206},{"type":182,"tag":190,"props":210,"children":211},{},[212],{"type":182,"tag":194,"props":213,"children":214},{},[215],{"type":182,"tag":198,"props":216,"children":218},{"href":217},"/maps/_computer/encoding/hash-collision",[219],{"type":188,"value":220},"哈希冲突",{"type":182,"tag":183,"props":222,"children":224},{"id":223},"图像编码",[225],{"type":188,"value":223},{"type":182,"tag":227,"props":228,"children":230},"h4",{"id":229},"understanding-proraw",[231,238],{"type":182,"tag":232,"props":233,"children":237},"link",{"type":234,"to":235,"source":236},"h5","https://mgear-file.oss-cn-shanghai.aliyuncs.com/Understanding%20ProRAW%20%E2%80%93%20Lux.html","https://lux.camera/understanding-proraw/",[],{"type":188,"value":239},"《Understanding ProRAW》",{"type":182,"tag":241,"props":242,"children":243},"p",{},[244],{"type":188,"value":245},"成像到出图有三个步骤：去像素化、色调映射和压缩。",{"type":182,"tag":241,"props":247,"children":248},{},[249],{"type":188,"value":250},"根据传感器上不同像素获得的颜色数据，去像素化会使用不同算法猜出原像素的颜色。",{"type":182,"tag":241,"props":252,"children":253},{},[254],{"type":182,"tag":255,"props":256,"children":259},"img",{"alt":257,"src":258},"去像素化 | https://lux.camera/understanding-proraw/","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20210920022854.png",[],{"type":182,"tag":241,"props":261,"children":262},{},[263],{"type":188,"value":264},"色调映射时会涉及到色彩空间转换、白平衡和动态处理相关的技术。",{"type":182,"tag":241,"props":266,"children":267},{},[268],{"type":188,"value":269},"压缩则是把原始数据砍精度，再通过有损压缩方案输出成一张 JEPG 之类的图片。",{"type":182,"tag":241,"props":271,"children":272},{},[273],{"type":188,"value":274},"因为 JPEG 的压缩有损，所以对 JPEG 进行后期就好比还原一个烘焙好的蛋糕一样艰难。而 RAW 文件保存的不是有损压缩后的图片数据，而是从传感器获取的原始数据，所以允许你使用最大限度的对图像进行改动。",{"type":182,"tag":241,"props":276,"children":277},{},[278],{"type":188,"value":279},"RAW 的缺陷就在于预览时非常难看，除非用来打开 RAW 的软件能用上 iPhone 一样的预览 RAW 时自动优化的功能。",{"type":182,"tag":241,"props":281,"children":282},{},[283],{"type":188,"value":284},"这时候，ProRAW 来了，它保存的不再是传感器的原始数据，而是去像素化后的数据，也就是说 iPhone 把传感器数据优化后的那部分内容保存下来了。苹果和 Adobe 公司共同开发了 DNG 文件标准，里面定义了 RAW 文件能用上的不同的数据标签，第三方软件可以直接从 ProRAW 拿到成像、精度、色调等信息，也就可以很方便的处理图片了。",{"title":175,"searchDepth":286,"depth":286,"links":287},2,[288,289,290],{"id":185,"depth":286,"text":185},{"id":206,"depth":286,"text":206},{"id":223,"depth":286,"text":223},"markdown","content:6.maps:_computer:encoding.md","content","6.maps/_computer/encoding.md","6.maps/_computer/encoding","md",[298,302],{"_path":299,"title":300,"description":301},"/maps/_computer/computer","Computer Mind Map","计算机基础知识导图，包含进制转换、数字电路设计、原码反码补码等核心概念的详细解析。",{"_path":200,"title":203,"description":303},"Emoji 是一种表情符号，是一种用来在电子通信中传达情感的符号。",1771071657064]