tals","fundamentals",false,true,"","计算机基础","计算机基础知识导图，包含进制转换、数字电路设计、原码反码补码等核心概念的详细解析。","content/6.maps/_computer/computer.md",{"type":183,"children":184,"toc":410},"root",[185,193,200,215,221,227,286,291,297,302,308,326,340,346,351,374,380,393,399],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"进制",[191],{"type":192,"value":189},"text",{"type":186,"tag":194,"props":195,"children":197},"h4",{"id":196},"十进制如何转二进制",[198],{"type":192,"value":199},"十进制如何转二进制？",{"type":186,"tag":201,"props":202,"children":203},"ul",{},[204,210],{"type":186,"tag":205,"props":206,"children":207},"li",{},[208],{"type":192,"value":209},"整数除二倒序取余",{"type":186,"tag":205,"props":211,"children":212},{},[213],{"type":192,"value":214},"小数乘二顺序取整",{"type":186,"tag":194,"props":216,"children":218},{"id":217},"十进制转二进制的示例",[219],{"type":192,"value":220},"十进制转二进制的示例？",{"type":186,"tag":222,"props":223,"children":224},"p",{},[225],{"type":192,"value":226},"以 $(4.1)_{10}$ 为例，先算小数部分，再算整数部分：",{"type":186,"tag":228,"props":229,"children":230},"ol",{},[231,236,241,246,251,256,261,266,271,276,281],{"type":186,"tag":205,"props":232,"children":233},{},[234],{"type":192,"value":235},"$0.1;*;2;=;0.2$，得整数位 $0$，取小数位 $0.2$ 继续运算；",{"type":186,"tag":205,"props":237,"children":238},{},[239],{"type":192,"value":240},"$0.2;*;2;=;0.4$，得整数位 $0$，取小数位 $0.4$ 继续运算；",{"type":186,"tag":205,"props":242,"children":243},{},[244],{"type":192,"value":245},"$0.4;*;2;=;0.8$，得整数位 $0$，取小数位 $0.8$ 继续运算；",{"type":186,"tag":205,"props":247,"children":248},{},[249],{"type":192,"value":250},"$0.8;*;2;=;1.6$，得整数位 $1$，取小数位 $0.6$ 继续运算；",{"type":186,"tag":205,"props":252,"children":253},{},[254],{"type":192,"value":255},"$0.6;*;2;=;1.2$，得整数位 $1$，取小数位 $0.2$ 继续运算（从第二步开始循环）；",{"type":186,"tag":205,"props":257,"children":258},{},[259],{"type":192,"value":260},"得 $(0.1)_{10}$ 转为二进制的结果：$(0.0\\overline{0011})_2$",{"type":186,"tag":205,"props":262,"children":263},{},[264],{"type":192,"value":265},"$4;mod;2 = 0$，得余数 $0$，取结果 $4;/;2 = 2$ 继续运算；",{"type":186,"tag":205,"props":267,"children":268},{},[269],{"type":192,"value":270},"$2;mod;2 = 0$，得余数 $0$，取结果 $2;/;2 = 1$ 继续运算；",{"type":186,"tag":205,"props":272,"children":273},{},[274],{"type":192,"value":275},"$1;mod;2 = 1$，得余数 $1$，结束运算；",{"type":186,"tag":205,"props":277,"children":278},{},[279],{"type":192,"value":280},"得 $(4)_{10}$ 的二进制结果：$(100)_2$",{"type":186,"tag":205,"props":282,"children":283},{},[284],{"type":192,"value":285},"得 $(4.1)_{10}$ 的二进制结果：$(100.0\\overline{0011})_2$，可以用 (4.1).toString(2) 验证一下。",{"type":186,"tag":187,"props":287,"children":289},{"id":288},"数字电路",[290],{"type":192,"value":288},{"type":186,"tag":194,"props":292,"children":294},{"id":293},"为什么减法要转换为加法的形式",[295],{"type":192,"value":296},"为什么减法要转换为加法的形式？",{"type":186,"tag":222,"props":298,"children":299},{},[300],{"type":192,"value":301},"负数在用原码表示时，需要在最高位带上符号。但是加减乘法作为最基础的运算，其电路应该设计得简单，识别\"符号位\"会让基础电路变得复杂，所以需要一种算法来把基础运算转换为二进制加法。使用反码计算减法会带来正负零的问题，使用补码则不会发生异常。",{"type":186,"tag":194,"props":303,"children":305},{"id":304},"什么是原码反码和补码",[306],{"type":192,"value":307},"什么是原码反码和补码？",{"type":186,"tag":201,"props":309,"children":310},{},[311,316,321],{"type":186,"tag":205,"props":312,"children":313},{},[314],{"type":192,"value":315},"最高位为符号位,其余为数值位，这是原码",{"type":186,"tag":205,"props":317,"children":318},{},[319],{"type":192,"value":320},"正数的反码为其本身，负数的反码为值位取反",{"type":186,"tag":205,"props":322,"children":323},{},[324],{"type":192,"value":325},"正数的补码为其本身，负数的补码为其反码加一（符号位不进位）",{"type":186,"tag":222,"props":327,"children":328},{},[329,331],{"type":192,"value":330},"见：",{"type":186,"tag":332,"props":333,"children":337},"a",{"href":334,"rel":335},"http://www.atoolbox.net/Tool.php?Id=952",[336],"nofollow",[338],{"type":192,"value":339},"原码/反码/补码计算器",{"type":186,"tag":194,"props":341,"children":343},{"id":342},"使用补码进行减法的示例",[344],{"type":192,"value":345},"使用补码进行减法的示例？",{"type":186,"tag":222,"props":347,"children":348},{},[349],{"type":192,"value":350},"以四位整形举例如下，计算表达式 $5 - 2$：",{"type":186,"tag":228,"props":352,"children":353},{},[354,359,364,369],{"type":186,"tag":205,"props":355,"children":356},{},[357],{"type":192,"value":358},"将减法用加法表示为 $5 + (-2)$。",{"type":186,"tag":205,"props":360,"children":361},{},[362],{"type":192,"value":363},"$5$ 是正数，直接得补码 $0101$。",{"type":186,"tag":205,"props":365,"children":366},{},[367],{"type":192,"value":368},"$-2$ 的原码是 $1010$，数值位取反得 $1101$，最后数值位加一得补码 $1110$。",{"type":186,"tag":205,"props":370,"children":371},{},[372],{"type":192,"value":373},"补码相加，$0101 + 1110$，得 $0011$，换算回十进制，答案是 $3$。",{"type":186,"tag":194,"props":375,"children":377},{"id":376},"_8-位补码的极值是多少",[378],{"type":192,"value":379},"8 位补码的极值是多少？",{"type":186,"tag":222,"props":381,"children":382},{},[383,385,391],{"type":192,"value":384},"8 位补码正数的最大值是 $01111111$，即 $(127)",{"type":186,"tag":386,"props":387,"children":388},"em",{},[389],{"type":192,"value":390},"{10}$。因为补码没有负零，所以其负数的最小值为 $-(127 - 1)",{"type":192,"value":392},"{10}$，即 $(-128)_{10}$",{"type":186,"tag":187,"props":394,"children":396},{"id":395},"todo",[397],{"type":192,"value":398},"TODO",{"type":186,"tag":194,"props":400,"children":402},{"id":401},"原码-反码-补码详解",[403],{"type":186,"tag":332,"props":404,"children":407},{"href":405,"rel":406},"https://www.cnblogs.com/zhangziqiu/archive/2011/03/30/ComputerCode.html",[336],[408],{"type":192,"value":409},"原码, 反码, 补码详解",{"title":178,"searchDepth":411,"depth":411,"links":412},2,[413,414,415],{"id":189,"depth":411,"text":189},{"id":288,"depth":411,"text":288},{"id":395,"depth":411,"text":398},"markdown","content:6.maps:_computer:fundamentals:fundamentals.md","content","6.maps/_computer/fundamentals/fundamentals.md","6.maps/_computer/fundamentals/fundamentals","md",[423,427],{"_path":424,"title":425,"description":426},"/maps/_computer/encoding/hash-collision","哈希冲突","哈希冲突是指两个不同的键值被哈希函数映射到了同一个位置。",{"_path":428,"title":429,"description":430},"/maps/_computer/network/network","计算机网络","计算机网络基础知识全览，包含 TCP/IP、HTTP、HTTPS、TLS 等协议的详细解析，以及网络安全、CDN、跨域等实践内容。",17721