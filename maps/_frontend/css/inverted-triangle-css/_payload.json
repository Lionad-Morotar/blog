dren":179,"toc":314},"root",[180,188,195,212,218,223,243,249,254,262,300,306],{"type":181,"tag":182,"props":183,"children":185},"element","h2",{"id":184},"简介",[186],{"type":187,"value":184},"text",{"type":181,"tag":189,"props":190,"children":192},"h4",{"id":191},"itcss-是什么",[193],{"type":187,"value":194},"ITCSS 是什么？",{"type":181,"tag":196,"props":197,"children":198},"p",{},[199,201,210],{"type":187,"value":200},"ITCSS 是由 ",{"type":181,"tag":202,"props":203,"children":207},"a",{"href":204,"rel":205},"https://csswizardry.com/",[206],"nofollow",[208],{"type":187,"value":209},"Sentinel（csswizardry）",{"type":187,"value":211}," 提倡的一种用来组织与管理项目中的样式文件的体系结构，或一种 CSS 方法论。遵守 ITCSS 理论能够约束我们写的 CSS，在一定程度解决 CSS 弱逻辑带来的问题。",{"type":181,"tag":189,"props":213,"children":215},{"id":214},"css-弱逻辑的特性会碰到什么问题",[216],{"type":187,"value":217},"CSS 弱逻辑的特性会碰到什么问题？",{"type":181,"tag":196,"props":219,"children":220},{},[221],{"type":187,"value":222},"CSS 本身是弱逻辑的，“装饰性”的，这注定了一般情况下我们不会重视它——没有文档、没有质量保证机制——所以写 CSS 时常常陷入“用新的样式去覆盖旧的样式”的怪圈。",{"type":181,"tag":224,"props":225,"children":226},"ul",{},[227,233,238],{"type":181,"tag":228,"props":229,"children":230},"li",{},[231],{"type":187,"value":232},"CSS 的组织结构很松散，有时按页面，有时按组件组织",{"type":181,"tag":228,"props":234,"children":235},{},[236],{"type":187,"value":237},"不良的开发习惯导致页面样式的继承很凌乱",{"type":181,"tag":228,"props":239,"children":240},{},[241],{"type":187,"value":242},"凌乱的继承引来更多的选择器特殊性问题",{"type":181,"tag":189,"props":244,"children":246},{"id":245},"itcss-如何组织-css-层级",[247],{"type":187,"value":248},"ITCSS 如何组织 CSS 层级？",{"type":181,"tag":196,"props":250,"children":251},{},[252],{"type":187,"value":253},"ITCSS 使用倒立的三角形表示项目的样式继承关系。三角中的每一层都代表一类样式，而每一层都会被下一层更高的优先级覆盖。所以实践 ITCSS 意味着，随着层级自上而下，选择器特殊性递增，能影响的 DOM 数量也越来越少，我们可以轻易修改特定样式，而不影响其它样式，或是导致样式继承的崩塌这种连锁效应。",{"type":181,"tag":196,"props":255,"children":256},{},[257],{"type":181,"tag":258,"props":259,"children":261},"img",{"alt":176,"src":260},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/200621/20200628214218.png?type=win11",[],{"type":181,"tag":224,"props":263,"children":264},{},[265,270,275,280,285,290,295],{"type":181,"tag":228,"props":266,"children":267},{},[268],{"type":187,"value":269},"Settings：Global variables、Config switches",{"type":181,"tag":228,"props":271,"children":272},{},[273],{"type":187,"value":274},"Tools：Mixins、Functions",{"type":181,"tag":228,"props":276,"children":277},{},[278],{"type":187,"value":279},"Generic：Ground-zero styles（Normalize.css，resets.css）",{"type":181,"tag":228,"props":281,"children":282},{},[283],{"type":187,"value":284},"Base：Unclassed HTML elements（Type selectors）",{"type":181,"tag":228,"props":286,"children":287},{},[288],{"type":187,"value":289},"Objects：Cosmetic-free design patterns",{"type":181,"tag":228,"props":291,"children":292},{},[293],{"type":187,"value":294},"Components：Designed components",{"type":181,"tag":228,"props":296,"children":297},{},[298],{"type":187,"value":299},"Trumps：Helpers、Overrides",{"type":181,"tag":189,"props":301,"children":303},{"id":302},"一个使用-itcss-项目示例",[304],{"type":187,"value":305},"一个使用 ITCSS 项目示例？",{"type":181,"tag":196,"props":307,"children":308},{},[309],{"type":181,"tag":258,"props":310,"children":313},{"alt":311,"src":312},"ITCSS index.css","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/200621/20200628215447.png",[],{"title":175,"searchDepth":315,"depth":315,"links":316},2,[317],{"id":184,"depth":315,"text":184},"markdown","content:6.maps:_frontend:css:inverted-triangle-css.md","content","6.maps/_frontend/css/inverted-triangle-css.md","6.maps/_frontend/css/inverted-triangle-css","md",[325,329],{"_path":326,"title":327,"description":328},"/maps/_frontend/css/bem","BEM","Block__Element–-Modifier",{"_path":330,"title":331,"description":175},"/maps/_frontend/css/layers","CSS Layers",1771071669702]