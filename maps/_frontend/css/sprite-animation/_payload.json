efault-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html .sepia .shiki span {color: var(--shiki-sepia);background: var(--shiki-sepia-bg);font-style: var(--shiki-sepia-font-style);font-weight: var(--shiki-sepia-font-weight);text-decoration: var(--shiki-sepia-text-decoration);}html.sepia .shiki span {color: var(--shiki-sepia);background: var(--shiki-sepia-bg);font-style: var(--shiki-sepia-font-style);font-weight: var(--shiki-sepia-font-weight);text-decoration: var(--shiki-sepia-text-decoration);}",{"title":178,"searchDepth":278,"depth":278,"links":726},[],"markdown","content:6.maps:_frontend:css:sprite-animation.md","content","6.maps/_frontend/css/sprite-animation.md","6.maps/_frontend/css/sprite-animation","md",[734,738],{"_path":735,"title":736,"description":737},"/maps/_frontend/css/snapshot-2024","CSS Snapshot 2024","截止 2024 年底，CSS 规范的状态",{"_path":739,"title":740,"description":741},"/maps/_frontend/css/tailwind","Tailwind CSS","Tailwind CSS 是一个 utility-first 的 CSS 框架，提供大量小而可组合的类名，用于在标记层面直接控制样式。它关注可定制性（`theme`）、按需构建（content 扫描）与插件生态。",1772504919613]