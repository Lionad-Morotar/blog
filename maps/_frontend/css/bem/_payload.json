le":676},[793],{"type":191,"value":794},"      grid-area",{"type":185,"tag":263,"props":796,"children":797},{"style":270},[798],{"type":191,"value":684},{"type":185,"tag":263,"props":800,"children":801},{"style":293},[802],{"type":191,"value":713},{"type":185,"tag":263,"props":804,"children":805},{"style":299},[806],{"type":191,"value":718},{"type":185,"tag":263,"props":808,"children":809},{"style":293},[810],{"type":191,"value":723},{"type":185,"tag":263,"props":812,"children":813},{"style":270},[814],{"type":191,"value":695},{"type":185,"tag":263,"props":816,"children":818},{"class":265,"line":817},18,[819],{"type":185,"tag":263,"props":820,"children":821},{"style":270},[822],{"type":191,"value":823},"    }\n",{"type":185,"tag":263,"props":825,"children":827},{"class":265,"line":826},19,[828],{"type":185,"tag":263,"props":829,"children":830},{"style":763},[831],{"type":191,"value":832},"  }\n",{"type":185,"tag":263,"props":834,"children":836},{"class":265,"line":835},20,[837,841,845],{"type":185,"tag":263,"props":838,"children":839},{"style":270},[840],{"type":191,"value":624},{"type":185,"tag":263,"props":842,"children":843},{"style":276},[844],{"type":191,"value":645},{"type":185,"tag":263,"props":846,"children":847},{"style":270},[848],{"type":191,"value":311},{"type":185,"tag":194,"props":850,"children":851},{},[852],{"type":185,"tag":228,"props":853,"children":854},{},[855],{"type":191,"value":856},"我发现用了这样的命名空间是我的代码可读性大大提高。即使我不会在 BEM 上打包卖给你，但它的确是一个关键的外卖。",{"type":185,"tag":858,"props":859,"children":860},"ul",{},[861,867,872,877,882],{"type":185,"tag":862,"props":863,"children":864},"li",{},[865],{"type":191,"value":866},"\"c-\"，组件的主干，如 “c-card”",{"type":185,"tag":862,"props":868,"children":869},{},[870],{"type":191,"value":871},"“l-”，单纯用于布局的元素，如 “l-grid”、“l-grid__item”",{"type":185,"tag":862,"props":873,"children":874},{},[875],{"type":191,"value":876},"“h-”，Helper，具有单个功能，通常使用 !important 提升其重要性",{"type":185,"tag":862,"props":878,"children":879},{},[880],{"type":191,"value":881},"“is-”，组件状态",{"type":185,"tag":862,"props":883,"children":884},{},[885],{"type":191,"value":886},"“js-”，JS 行为控制的钩子",{"type":185,"tag":194,"props":888,"children":889},{},[890],{"type":191,"value":891},"不少大佬都说过命名空间这玩意儿，比如张鑫旭曾在某篇博客中提过自己喜欢用 “x” 结尾的 CSS 类名作为布局容器的命名。",{"type":185,"tag":194,"props":893,"children":894},{},[895],{"type":185,"tag":228,"props":896,"children":897},{},[898],{"type":191,"value":899},"坚持一套标准状态钩子是有道理的",{"type":185,"tag":194,"props":901,"children":902},{},[903],{"type":191,"value":904},"如果写组件多于 HTML 的话，也许不会碰到需要探索 “l-” 这种命名空间策略的场景，因为布局组件（栅格组件或者现代 CSS 网格布局）已经可以屏蔽掉这层知识。随着 JS 变得复杂，在实际的代码中 “is-” 可以覆盖掉 “l-”、“h-”、“js-” 等其他钩子函数，达到一样的效果，并减少心智负担。",{"type":185,"tag":194,"props":906,"children":907},{},[908,910],{"type":191,"value":909},"相关见：",{"type":185,"tag":205,"props":911,"children":914},{"href":912,"rel":913},"https://csswizardry.com/2015/03/more-transparent-ui-code-with-namespaces/",[209],[915],{"type":191,"value":916},"More Transparent UI Code with Namespaces",{"type":185,"tag":194,"props":918,"children":919},{},[920],{"type":185,"tag":228,"props":921,"children":922},{},[923],{"type":191,"value":924},"真正模块化的 UI 元素的修饰不应该去关心元素的父容器。无论你放在哪，它们应该看起来是一样的。",{"type":185,"tag":194,"props":926,"children":927},{},[928],{"type":191,"value":929},"单纯喜欢这个说法，但实际上感觉就算在 B 端产品也很难办到。",{"type":185,"tag":194,"props":931,"children":932},{},[933],{"type":185,"tag":228,"props":934,"children":935},{},[936],{"type":191,"value":937},"通常，我会在组件的上下文中将需要样式化的标签都加上类名。我经常很少给 p 标签加样式名。除非该组件要求他们在上下文中独一无二。",{"type":185,"tag":194,"props":939,"children":940},{},[941],{"type":191,"value":942},"等于在说：“只有在用到的时候才会加类名，并且简单的标签加不加都行”。",{"type":185,"tag":194,"props":944,"children":945},{},[946],{"type":185,"tag":228,"props":947,"children":948},{},[949],{"type":191,"value":950},"我们可以灵活的更改组件的类型吗？比如一个下拉菜单当它在某个屏幕尺寸的时候转换为一组选项卡，或者在某个触发点又变为菜单栏的屏幕外的导航。",{"type":185,"tag":194,"props":952,"children":953},{},[954],{"type":191,"value":955},"感觉作者提到的重新写个组件或者使用“响应式后缀”的方法都不是很理想。现代组件库已经可以并且多数使用 JS 处理这种问题，主要靠 JS，类似上文说的 “is-” 钩子。",{"type":185,"tag":645,"props":957,"children":958},{},[959],{"type":191,"value":960},"html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html .sepia .shiki span {color: var(--shiki-sepia);background: var(--shiki-sepia-bg);font-style: var(--shiki-sepia-font-style);font-weight: var(--shiki-sepia-font-weight);text-decoration: var(--shiki-sepia-text-decoration);}html.sepia .shiki span {color: var(--shiki-sepia);background: var(--shiki-sepia-bg);font-style: var(--shiki-sepia-font-style);font-weight: var(--shiki-sepia-font-weight);text-decoration: var(--shiki-sepia-text-decoration);}",{"title":178,"searchDepth":314,"depth":314,"links":962},[],"markdown","content:6.maps:_fr