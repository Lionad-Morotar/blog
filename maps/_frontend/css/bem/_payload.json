ue":710}," '",{"type":182,"tag":260,"props":712,"children":713},{"style":296},[714],{"type":188,"value":715},"xxx",{"type":182,"tag":260,"props":717,"children":718},{"style":290},[719],{"type":188,"value":720},"'",{"type":182,"tag":260,"props":722,"children":723},{"style":267},[724],{"type":188,"value":692},{"type":182,"tag":260,"props":726,"children":728},{"class":262,"line":727},15,[729,734,738,742,746,750],{"type":182,"tag":260,"props":730,"children":731},{"style":673},[732],{"type":188,"value":733},"    grid-template-areas",{"type":182,"tag":260,"props":735,"children":736},{"style":267},[737],{"type":188,"value":681},{"type":182,"tag":260,"props":739,"children":740},{"style":290},[741],{"type":188,"value":710},{"type":182,"tag":260,"props":743,"children":744},{"style":296},[745],{"type":188,"value":715},{"type":182,"tag":260,"props":747,"children":748},{"style":290},[749],{"type":188,"value":720},{"type":182,"tag":260,"props":751,"children":752},{"style":267},[753],{"type":188,"value":692},{"type":182,"tag":260,"props":755,"children":757},{"class":262,"line":756},16,[758,764,769,774,779],{"type":182,"tag":260,"props":759,"children":761},{"style":760},"--shiki-light:#90A4AE;--shiki-default:#24292E;--shiki-dark:#E1E4E8;--shiki-sepia:#F8F8F2",[762],{"type":188,"value":763},"    .",{"type":182,"tag":260,"props":765,"children":767},{"style":766},"--shiki-light:#90A4AE;--shiki-default:#005CC5;--shiki-dark:#79B8FF;--shiki-sepia:#F8F8F2",[768],{"type":188,"value":299},{"type":182,"tag":260,"props":770,"children":771},{"style":760},[772],{"type":188,"value":773},"__",{"type":182,"tag":260,"props":775,"children":776},{"style":766},[777],{"type":188,"value":778},"title",{"type":182,"tag":260,"props":780,"children":781},{"style":760},[782],{"type":188,"value":666},{"type":182,"tag":260,"props":784,"children":786},{"class":262,"line":785},17,[787,792,796,800,804,808],{"type":182,"tag":260,"props":788,"children":789},{"style":673},[790],{"type":188,"value":791},"      grid-area",{"type":182,"tag":260,"props":793,"children":794},{"style":267},[795],{"type":188,"value":681},{"type":182,"tag":260,"props":797,"children":798},{"style":290},[799],{"type":188,"value":710},{"type":182,"tag":260,"props":801,"children":802},{"style":296},[803],{"type":188,"value":715},{"type":182,"tag":260,"props":805,"children":806},{"style":290},[807],{"type":188,"value":720},{"type":182,"tag":260,"props":809,"children":810},{"style":267},[811],{"type":188,"value":692},{"type":182,"tag":260,"props":813,"children":815},{"class":262,"line":814},18,[816],{"type":182,"tag":260,"props":817,"children":818},{"style":267},[819],{"type":188,"value":820},"    }\n",{"type":182,"tag":260,"props":822,"children":824},{"class":262,"line":823},19,[825],{"type":182,"tag":260,"props":826,"children":827},{"style":760},[828],{"type":188,"value":829},"  }\n",{"type":182,"tag":260,"props":831,"children":833},{"class":262,"line":832},20,[834,838,842],{"type":182,"tag":260,"props":835,"children":836},{"style":267},[837],{"type":188,"value":621},{"type":182,"tag":260,"props":839,"children":840},{"style":273},[841],{"type":188,"value":642},{"type":182,"tag":260,"props":843,"children":844},{"style":267},[845],{"type":188,"value":308},{"type":182,"tag":191,"props":847,"children":848},{},[849],{"type":182,"tag":225,"props":850,"children":851},{},[852],{"type":188,"value":853},"我发现用了这样的命名空间是我的代码可读性大大提高。即使我不会在 BEM 上打包卖给你，但它的确是一个关键的外卖。",{"type":182,"tag":855,"props":856,"children":857},"ul",{},[858,864,869,874,879],{"type":182,"tag":859,"props":860,"children":861},"li",{},[862],{"type":188,"value":863},"\"c-\"，组件的主干，如 “c-card”",{"type":182,"tag":859,"props":865,"children":866},{},[867],{"type":188,"value":868},"“l-”，单纯用于布局的元素，如 “l-grid”、“l-grid__item”",{"type":182,"tag":859,"props":870,"children":871},{},[872],{"type":188,"value":873},"“h-”，Helper，具有单个功能，通常使用 !important 提升其重要性",{"type":182,"tag":859,"props":875,"children":876},{},[877],{"type":188,"value":878},"“is-”，组件状态",{"type":182,"tag":859,"props":880,"children":881},{},[882],{"type":188,"value":883},"“js-”，JS 行为控制的钩子",{"type":182,"tag":191,"props":885,"children":886},{},[887],{"type":188,"value":888},"不少大佬都说过命名空间这玩意儿，比如张鑫旭曾在某篇博客中提过自己喜欢用 “x” 结尾的 CSS 类名作为布局容器的命名。",{"type":182,"tag":191,"props":890,"children":891},{},[892],{"type":182,"tag":225,"props":893,"children":894},{},[895],{"type":188,"value":896},"坚持一套标准状态钩子是有道理的",{"type":182,"tag":191,"props":898,"children":899},{},[900],{"type":188,"value":901},"如果写组件多于 HTML 的话，也许不会碰到需要探索 “l-” 这种命名空间策略的场景，因为布局组件（栅格组件或者现代 CSS 网格布局）已经可以屏蔽掉这层知识。随着 JS 变得复杂，在实际的代码中 “is-” 可以覆盖掉 “l-”、“h-”、“js-” 等其他钩子函数，达到一样的效果，并减少心智负担。",{"type":182,"tag":191,"props":903,"children":904},{},[905,907],{"type":188,"value":906},"相关见：",{"type":182,"tag":202,"props":908,"children":911},{"href":909,"rel":910},"https://csswizardry.com/2015/03/more-transparent-ui-code-with-namespaces/",[206],[912],{"type":188,"value":913},"More Transparent UI Code with Namespaces",{"type":182,"tag":191,"props":915,"children":916},{},[917],{"type":182,"tag":225,"props":918,"children":919},{},[920],{"type":188,"value":921},"真正模块化的 UI 元素的修饰不应该去关心元素的父容器。无论你放在哪，它们应该看起来是一样的。",{"type":182,"tag":191,"props":923,"children":924},{},[925],{"type":188,"value":926},"单纯喜欢这个说法，但实际上感觉就算在 B 端产品也很难办到。",{"type":182,"tag":191,"props":928,"children":929},{},[930],{"type":182,"tag":225,"props":931,"children":932},{},[933],{"type":188,"value":934},"通常，我会在组件的上下文中将需要样式化的标签都加上类名。我经常很少给 p 标签加样式名。除非该组件要求他们在上下文中独一无二。",{"type":182,"tag":191,"props":936,"children":937},{},[938],{"type":188,"value":939},"等于在说：“只有在用到的时候才会加类名，并且简单的标签加不加都行”。",{"type":182,"tag":191,"props":941,"children":942},{},[943],{"type":182,"tag":225,"props":944,"children":945},{},[946],{"type":188,"value":947},"我们可以灵活的更改组件的类型吗？比如一个下拉菜单当它在某个屏幕尺寸的时候转换为一组选项卡，或者在某个触发点又变为菜单栏的屏幕外的导航。",{"type":182,"tag":191,"props":949,"children":950},{},[951],{"type":188,"value":952},"感觉作者提到的重新写个组件或者使用“响应式后缀”的方法都不是很理想。现代组件库已经可以并且多数使用 JS 处理这种问题，主要靠 JS，类似上文说的 “is-” 钩子。",{"type":182,"tag":642,"props":954,"children":955},{},[956],{"type":188,"value":957},"html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html .sepia .shiki span {color: var(--shiki-sepia);background: var(--shiki-sepia-bg);font-style: var(--shiki-sepia-font-style);font-weight: var(--shiki-sepia-font-weight);text-decoration: var(--shiki-sepia-text-decoration);}html.sepia .shiki span {color: var(--shiki-sepia);background: var(--shiki-sepia-bg);font-style: var(--shiki-sepia-font-style);font-weight: var(--shiki-sepia-font-weight);text-decoration: var(--shiki-sepia-text-decoration);}",{"title":175,"searchDepth":311,"depth":311,"links":959},[],"markdown","content:6.maps:_frontend:css:bem.md","content","6.maps/_frontend/css/bem