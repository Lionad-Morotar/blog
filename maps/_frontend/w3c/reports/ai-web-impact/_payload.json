cles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"original_path":174,"body":181,"_type":335,"_id":336,"_source":337,"_file":338,"_stem":339,"_extension":340},"/maps/_frontend/w3c/reports/ai-web-impact","reports",false,true,"","AI & Web：理解与管理机器学习模型对Web的影响","W3C 对 Web-AI 交叉领域进展的共同理解及标准化路线图",{"type":182,"children":183,"toc":332},"root",[184,193,199,204,218,224,229,242,248,253,258,264,276,282,287,293,298,304,309,314,320],{"type":185,"tag":186,"props":187,"children":189},"element","h4",{"id":188},"ai-与-web-的系统性影响",[190],{"type":191,"value":192},"text","AI 与 Web 的系统性影响？",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"机器学习模型支撑着新一代 AI 系统，它们使用 Web 内容训练，通过 Web 界面大规模部署，并能以前所未有的速度低成本生成内容。",{"type":185,"tag":194,"props":200,"children":201},{},[202],{"type":191,"value":203},"Web 既是 AI 的训练数据来源，又是 AI 生成内容的分发平台。这种交叉正在对 Web 生态产生潜在的系统性影响。",{"type":185,"tag":194,"props":205,"children":206},{},[207,209],{"type":191,"value":208},"见：",{"type":185,"tag":210,"props":211,"children":215},"a",{"href":212,"rel":213},"https://www.w3.org/reports/ai-web-impact/index-zh.html",[214],"nofollow",[216],{"type":191,"value":217},"AI & Web 报告",{"type":185,"tag":186,"props":219,"children":221},{"id":220},"ai-生成内容的透明度问题",[222],{"type":191,"value":223},"AI 生成内容的透明度问题？",{"type":185,"tag":194,"props":225,"children":226},{},[227],{"type":191,"value":228},"最新的 AI 系统能辅助或替代人类创作文本、图像、音频和视频，且质量可接受、数量远超人类创作。这给消费者带来系统性风险——难以辨别内容的真实性与权威性。",{"type":185,"tag":194,"props":230,"children":231},{},[232,234,240],{"type":191,"value":233},"目前没有可行的技术方案（如密码学方法）来验证内容是否由 AI 生成。标准组织可以推动",{"type":185,"tag":235,"props":236,"children":237},"strong",{},[238],{"type":191,"value":239},"内容标注",{"type":191,"value":241},"机制，通过元数据标明内容是否为计算机生成。已有提案包括 C2PA 指南、IPTC 合成媒体标准、HTML 的 AI 生成内容元标签建议。",{"type":185,"tag":186,"props":243,"children":245},{"id":244},"ai-服务的偏见与透明度",[246],{"type":191,"value":247},"AI 服务的偏见与透明度？",{"type":185,"tag":194,"props":249,"children":250},{},[251],{"type":191,"value":252},"机器学习模型可能吸收并强化训练数据中的偏见，对训练数据中未被充分代表的用户（非主流语言、外表或行为者）影响更大。由于模型像\"黑盒\"一样运行，难以审计和纠正。",{"type":185,"tag":194,"props":254,"children":255},{},[256],{"type":191,"value":257},"W3C 建议在模型卡片中公开是否使用机器学习、如何训练和检测偏见，帮助用户做出知情选择。",{"type":185,"tag":186,"props":259,"children":261},{"id":260},"隐私风险与去中心化存储",[262],{"type":191,"value":263},"隐私风险与去中心化存储？",{"type":185,"tag":194,"props":265,"children":266},{},[267,269,274],{"type":191,"value":268},"模型训练可能包含个人可识别信息（PII），攻击者可能通过特定提示提取这些隐私数据。这引发对分布式架构的新呼吁，如 ",{"type":185,"tag":235,"props":270,"children":271},{},[272],{"type":191,"value":273},"Solid",{"type":191,"value":275},"（个人数据存储）——清晰区分数据存储与数据处理角色，让用户更细粒度地控制自己的数据。Web Neural Network API 允许在浏览器本地运行模型，无需上传数据到服务器。",{"type":185,"tag":186,"props":277,"children":279},{"id":278},"ai-放大的安全与冒充风险",[280],{"type":191,"value":281},"AI 放大的安全与冒充风险？",{"type":185,"tag":194,"props":283,"children":284},{},[285],{"type":191,"value":286},"机器学习模型能以极低成本模仿人类生成逼真的文本和视频，显著放大了网络钓鱼和诈骗风险，提高了在线建立信任的门槛。如果用户对数字媒介中的交际失去安全感，Web 将失去作为交际平台的核心价值。",{"type":185,"tag":186,"props":288,"children":290},{"id":289},"ai-的环境可持续性",[291],{"type":191,"value":292},"AI 的环境可持续性？",{"type":185,"tag":194,"props":294,"children":295},{},[296],{"type":191,"value":297},"训练和运行机器学习模型消耗大量电力和水资源。W3C 缺少评估其标准对环境影响的框架，需要主动探索 AI 标准化工作对环境的预期影响及应对方案。",{"type":185,"tag":186,"props":299,"children":301},{"id":300},"内容创作者权益与搜索引擎契约",[302],{"type":191,"value":303},"内容创作者权益与搜索引擎契约？",{"type":185,"tag":194,"props":305,"children":306},{},[307],{"type":191,"value":308},"大型机器学习模型常在未获创作者同意的情况下使用 Web 内容训练，引发版权争议。搜索引擎与内容创作者存在隐式契约：爬虫获取内容，同时给来源带来曝光和流量；而 AI 系统缺乏这种系统性等效机制——即使能标注训练数据来源，也难以像搜索引擎那样刺激用户访问原始网站。",{"type":185,"tag":194,"props":310,"children":311},{},[312],{"type":191,"value":313},"robots.txt 基于用户代理的爬虫管理对快速增长的 AI 爬虫列表难以持续维护。早期 Web 的无许可模式是否能满足内容发布的长期可持续性仍是问题。",{"type":185,"tag":186,"props":315,"children":317},{"id":316},"机器学习对-web-互用性的挑战",[318],{"type":191,"value":319},"机器学习对 Web 互用性的挑战？",{"type":185,"tag":194,"props":321,"children":322},{},[323,325,330],{"type":191,"value":324},"机器学习模型给 W3C 的互用性目标带来两方面挑战：1）模型通常不是基于明确算法步骤构建的，难以规定标准化行为；2）许多模型具有",{"type":185,"tag":235,"props":326,"children":327},{},[328],{"type":191,"value":329},"非确定性",{"type":191,"value":331},"——相同输入可能产生不同输出，这与传统确定性算法的互用测试范式冲突。这可能导致基于 AI 实现的标准化特性范围缩小。",{"title":178,"searchDepth":333,"depth":333,"links":334},2,[],"markdown","content:6.maps:_frontend:w3c:reports:ai-web-impact.md","content","6.maps/_frontend/w3c/reports/ai-web-impact.md","6.maps/_frontend/w3c/reports/ai-web-impact","md",[342,346],{"_path":343,"title":344,"description":345},"/maps/_frontend/w3c/es/proposal-regexp-v-flag","proposal-regexp-v-flag","正则的 v 模式兼容 u 模式并带来了 emoji 多码匹配等改进",{"_path":347,"title":348,"description":178},"/maps/_frontend/w3c/screen/multi-screen-window-lacement","Multi-Screen Window Placement",1772185468729]