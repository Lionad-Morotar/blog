应。",{"type":179,"children":180,"toc":950},"root",[181,189,194,199,204,210,217,222,238,690,695,944],{"type":182,"tag":183,"props":184,"children":185},"element","p",{},[186],{"type":187,"value":188},"text","JS 执行会抢占 UI 渲染的时间，若 JS 任务长时间运作，页面看起来就会像“假死”，连滚动操作都无法正常进行。使用任务切片技术能使页面在不使用 Web Worker 的情况下榨干页面性能，并保持 UI 响应。",{"type":182,"tag":183,"props":190,"children":191},{},[192],{"type":187,"value":193},"以下图形中有 400 个圆形。每 600ms 会对圆形进行一次更新。使用全量更新策略在我的个人电脑需要耗时约 360ms，也就意味着只有 2/5 的时间留给浏览器响应 UI 渲染。若使用任务切片，虽然总任务执行时间延长到 460ms，但令人惊喜的是，无论是滚动操作，还是界面中的动画，滚动页面带来的卡顿都得到缓解。",{"type":182,"tag":183,"props":195,"children":196},{},[197],{"type":187,"value":198},"Article-G200919-TaskSlice",{"type":182,"tag":183,"props":200,"children":201},{},[202],{"type":187,"value":203},"滚动测试滚动测试滚动测试滚动测试滚动测试滚动测试滚动测试滚动测试。",{"type":182,"tag":205,"props":206,"children":208},"h2",{"id":207},"关键代码",[209],{"type":187,"value":207},{"type":182,"tag":211,"props":212,"children":214},"h4",{"id":213},"fps",[215],{"type":187,"value":216},"FPS",{"type":182,"tag":183,"props":218,"children":219},{},[220],{"type":187,"value":221},"FPS 统计使用了 requestAnimationFrame API。",{"type":182,"tag":183,"props":223,"children":224},{},[225,227,236],{"type":187,"value":226},"第一种方法来自 ",{"type":182,"tag":228,"props":229,"children":233},"a",{"href":230,"rel":231},"https://mp.weixin.qq.com/s/fD-jtZ0ETUWwyL3YhmA3kw",[232],"nofollow",[234],{"type":187,"value":235},"AlloyTeam 的示例代码",{"type":187,"value":237},"，通过累计时间以计算每一秒的帧率。",{"type":182,"tag":239,"props":240,"children":244},"pre",{"className":241,"code":242,"language":243,"meta":175,"style":175},"language-js shiki shiki-themes material-theme-lighter github-light github-dark monokai","let lastTime = performance.now()\nlet frames = 0\nconst loop = () => {\n    const currentTime = performance.now()\n    frames += 1\n    if (currentTime > 1000 + lastTime) {\n        fps = Math.round((frames * 1000) / (currentTime - lastTime))\n        frames = 0\n        lastTime = currentTime\n        console.log(`fp