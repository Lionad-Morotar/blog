e","neuroscience",false,true,"","神经科学","神经科学是一门以脑结构和功能为研究对象的综合学科，横跨了多个学科领域。现代神经科学有三个主流分支：细胞和分子神经科学、认知神经科学和发育神经学。","content/6.maps/_science/neuroscience.md",{"type":183,"children":184,"toc":485},"root",[185,193,199,208,293,300,311,319,362,372,386,391,401,406,447,452],{"type":186,"tag":187,"props":188,"children":189},"element","p",{},[190],{"type":191,"value":192},"text","神经科学也即脑科学，是一门以脑结构和功能为研究对象的综合学科，横跨了多个学科领域。现代神经科学有三个主流分支：细胞和分子神经科学、认知神经科学和发育神经学。",{"type":186,"tag":194,"props":195,"children":197},"h2",{"id":196},"时间线",[198],{"type":191,"value":196},{"type":186,"tag":187,"props":200,"children":201},{},[202],{"type":186,"tag":203,"props":204,"children":207},"img",{"alt":205,"src":206},"象形字\"脑\"","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20211208004256.png?w=30",[],{"type":186,"tag":209,"props":210,"children":211},"ul",{},[212,218,223,228,233,238,243,248,253,258,263,268,273,278,283,288],{"type":186,"tag":213,"props":214,"children":215},"li",{},[216],{"type":191,"value":217},"古埃及人的象形字作品《史密斯外科纸草书》（约 BC3000 ~ BC1700）中第一次出现了文字\"脑\"，并记录一些相关的有趣的案例。",{"type":186,"tag":213,"props":219,"children":220},{},[221],{"type":191,"value":222},"希波克拉底（约 BC500）认为脑是精神的载体，\"人们应当认识到：我们的愉悦、欢乐、笑声和谈谐都来自脑，而且仅仅来自脑；还有我们的忧愁、痛苦及爱恋和哭泣。\"",{"type":186,"tag":213,"props":224,"children":225},{},[226],{"type":191,"value":227},"与希波克拉底相反，亚里士多德（BC384 ~ BC322）认为精神在心。",{"type":186,"tag":213,"props":229,"children":230},{},[231],{"type":191,"value":232},"加仑（BC129 ~ D.C. 199）支持精神在脑，并且通过实验证明了发音受喉返神经控制。",{"type":186,"tag":213,"props":234,"children":235},{},[236],{"type":191,"value":237},"达芬奇（1452~1519）在人体解剖学有所建树，他绘制了拥有四个脑室的脑图，并制作了牛脑室的灌注蜡模。",{"type":186,"tag":213,"props":239,"children":240},{},[241],{"type":191,"value":242},"维萨里（1514~1564）通过解剖，基本完善了今日神经科学教科书上关于脑的描述。著有《人体构造》（1543）。",{"type":186,"tag":213,"props":244,"children":245},{},[246],{"type":191,"value":247},"笛卡尔（1596~1650）认为脑只是和其它器官别无两样的器官，可以比拟为机械运动而加以描述和研究，因此开创了脑功能的分析和实验研究。",{"type":186,"tag":213,"props":249,"children":250},{},[251],{"type":191,"value":252},"威利斯（1621~1675）在《大脑解剖》（1664）中广泛讨论了脑的生理、解剖、化学、临床神经学。",{"type":186,"tag":213,"props":254,"children":255},{},[256],{"type":191,"value":257},"18 世纪末，伽伐尼发现动物电：蛙腿可因神经接受电刺激而收缩，神经肌肉活动时有电产生。神经活动的实质是生物电活动，这种观念一句扫除了过去把精神归结为灵魂、元气、精灵或微小颗粒的活动等旧观念。",{"type":186,"tag":213,"props":259,"children":260},{},[261],{"type":191,"value":262},"1839 年施莱登和施旺提出细胞理论，拉蒙-卡哈尔在此基础上提出神经元学说，认为细胞理论同样适用于神经细胞。",{"type":186,"tag":213,"props":264,"children":265},{},[266],{"type":191,"value":267},"1887 年，弗里乔夫·南森认为智力存在于脑中大量的神经细胞连接之中。",{"type":186,"tag":213,"props":269,"children":270},{},[271],{"type":191,"value":272},"1897 年，谢灵顿提出突触理论，后提出神经系统整合作用理论：中枢神经系统接受神经传入形成输出主要靠抑制作用，并在 1932 年受诺贝尔奖。突触理论在 1950 年代电子显微镜出现后得到了实验证实。",{"type":186,"tag":213,"props":274,"children":275},{},[276],{"type":191,"value":277},"19 世纪末，加尔提出颅相学，最早认为大脑各区具有功能上的特异性。",{"type":186,"tag":213,"props":279,"children":280},{},[281],{"type":191,"value":282},"1950 年代，里奥克成立第一个神经科学实验室。",{"type":186,"tag":213,"props":284,"children":285},{},[286],{"type":191,"value":287},"1968 年，米勒、杰拉尔德和芒卡斯尔创办了第一次神经科学学会会议，与会 600 人。",{"type":186,"tag":213,"props":289,"children":290},{},[291],{"type":191,"value":292},"1978 年，考恩出版《神经科学年鉴》。",{"type":186,"tag":294,"props":295,"children":297},"h4",{"id":296},"恐音症misophonia对特定声音的强烈情绪反应",[298],{"type":191,"value":299},"恐音症（Misophonia）：对特定声音的强烈情绪反应",{"type":186,"tag":187,"props":301,"children":302},{},[303,309],{"type":186,"tag":304,"props":305,"children":306},"strong",{},[307],{"type":191,"value":308},"恐音症",{"type":191,"value":310},"（希腊语意为\"对声音的厌恶\"）是一种神经系统疾病，\n患者听到特定声音时会触发强烈的负面情绪、思想和身体反应，\n常见反应包括愤怒、厌恶和逃避冲动。",{"type":186,"tag":187,"props":312,"children":313},{},[314],{"type":186,"tag":304,"props":315,"children":316},{},[317],{"type":191,"value":318},"主要特征：",{"type":186,"tag":209,"props":320,"children":321},{},[322,332,342,352],{"type":186,"tag":213,"props":323,"children":324},{},[325,330],{"type":186,"tag":304,"props":326,"children":327},{},[328],{"type":191,"value":329},"常见诱因",{"type":191,"value":331},"：咀嚼声、呼吸声、打字/敲笔声、吸鼻子声等重复性声音",{"type":186,"tag":213,"props":333,"children":334},{},[335,340],{"type":186,"tag":304,"props":336,"children":337},{},[338],{"type":191,"value":339},"患病率",{"type":191,"value":341},"：约 5%~20% 的成年人存在不同程度的恐音症状",{"type":186,"tag":213,"props":343,"children":344},{},[345,350],{"type":186,"tag":304,"props":346,"children":347},{},[348],{"type":191,"value":349},"发病时间",{"type":191,"value":351},"：通常始于青春期，无性别差异",{"type":186,"tag":213,"props":353,"children":354},{},[355,360],{"type":186,"tag":304,"props":356,"children":357},{},[358],{"type":191,"value":359},"神经机制",{"type":191,"value":361},"：大脑的杏仁核和听觉皮层异常活跃，血清素水平变化、\n上下行听觉系统或耳蜗功能异常可能相关",{"type":186,"tag":187,"props":363,"children":364},{},[365,370],{"type":186,"tag":304,"props":366,"children":367},{},[368],{"type":191,"value":369},"治疗现状：",{"type":191,"value":371}," 目前尚无有效医治办法，患者主要依靠忍耐，\n许多患者甚至未意识到这是一种疾病。",{"type":186,"tag":187,"props":373,"children":374},{},[375,377],{"type":191,"value":376},"见：",{"type":186,"tag":378,"props":379,"children":383},"a",{"href":380,"rel":381},"http://misophonia.com/",[382],"nofollow",[384],{"type":191,"value":385},"Misophonia.com",{"type":186,"tag":194,"props":387,"children":389},{"id":388},"阅读",[390],{"type":191,"value":388},{"type":186,"tag":294,"props":392,"children":394},{"id":393},"大脑帝国",[395],{"type":186,"tag":378,"props":396,"children":398},{"href":397},"/_books/9787508692876",[399],{"type":191,"value":400},"《大脑帝国》",{"type":186,"tag":194,"props":402,"children":404},{"id":403},"名词译注",[405],{"type":191,"value":403},{"type":186,"tag":407,"props":408,"children":409},"table",{},[410,429],{"type":186,"tag":411,"props":412,"children":413},"thead",{},[414],{"type":186,"tag":415,"props":416,"children":417},"tr",{},[418,424],{"type":186,"tag":419,"props":420,"children":421},"th",{},[422],{"type":191,"value":423},"中译",{"type":186,"tag":419,"props":425,"children":426},{},[427],{"type":191,"value":428},"英文",{"type":186,"tag":430,"props":431,"children":432},"tbody",{},[433],{"type":186,"tag":415,"props":434,"children":435},{},[436,442],{"type":186,"tag":437,"props":438,"children":439},"td",{},[440],{"type":191,"value":441},"精神",{"type":186,"tag":437,"props":443,"children":444},{},[445],{"type":191,"value":446},"mind",{"type":186,"tag":194,"props":448,"children":450},{"id":449},"阅读更多",[451],{"type":191,"value":449},{"type":186,"tag":209,"props":453,"children":454},{},[455,465,475],{"type":186,"tag":213,"props":456,"children":457},{},[458],{"type":186,"tag":378,"props":459,"children":462},{"href":460,"rel":461},"https://xueshu.baidu.com/usercenter/paper/show?paperid=13cd1e266dc30588916159be12586884&site=xueshu_se",[382],[463],{"type":191,"value":464},"《神经科学的发展历史》",{"type":186,"tag":213,"props":466,"children":467},{},[468],{"type":186,"tag":378,"props":469,"children":472},{"href":470,"rel":471},"https://zhuanlan.zhihu.com/p/20420048",[382],[473],{"type":191,"value":474},"《艾德温·史密斯（外科）纸草文稿》",{"type":186,"tag":213,"props":476,"children":477},{},[478],{"type":186,"tag":378,"props":479,"children":482},{"href":480,"rel":481},"https://baijiahao.baidu.com/s?id=1664289015456647938",[382],[483],{"type":191,"value":484},"《颅相学：一门伪科学的兴衰史》",{"title":178,"searchDepth":486,"depth":486,"links":487},2,[488,489,490,491],{"id":196,"depth":486,"text":196},{"id":388,"depth":486,"text":388},{"id":403,"depth":486,"text":403},{"id":449,"depth":486,"text":449},"markdown","content:6.maps:_science:neuroscience:neuroscience.md","content","6.maps/_science/neuroscience/neuroscience.md","6.maps/_science/neuroscience/neuroscience","md",[499,503],{"_path":500,"title":501,"description":502},"/maps/_science/environment/environment","环保","低碳 Web 实践指南",{"_path":504,"title":505,"description":506},"/maps/_science/quantum/quantum","量子理论","量子力学是描述微观世界的物理学。",1772504909868]