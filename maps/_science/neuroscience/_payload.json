ype":179,"children":180,"toc":391},"root",[181,189,195,204,289,294,306,311,352,357],{"type":182,"tag":183,"props":184,"children":185},"element","p",{},[186],{"type":187,"value":188},"text","神经科学也即脑科学，是一门以脑结构和功能为研究对象的综合学科，横跨了多个学科领域。现代神经科学有三个主流分支：细胞和分子神经科学、认知神经科学和发育神经学。",{"type":182,"tag":190,"props":191,"children":193},"h2",{"id":192},"时间线",[194],{"type":187,"value":192},{"type":182,"tag":183,"props":196,"children":197},{},[198],{"type":182,"tag":199,"props":200,"children":203},"img",{"alt":201,"src":202},"象形字“脑”","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20211208004256.png?w=30",[],{"type":182,"tag":205,"props":206,"children":207},"ul",{},[208,214,219,224,229,234,239,244,249,254,259,264,269,274,279,284],{"type":182,"tag":209,"props":210,"children":211},"li",{},[212],{"type":187,"value":213},"古埃及人的象形字作品《史密斯外科纸草书》（约 BC3000 ~ BC1700）中第一次出现了文字“脑”，并记录一些相关的有趣的案例。",{"type":182,"tag":209,"props":215,"children":216},{},[217],{"type":187,"value":218},"希波克拉底（约 BC500）认为脑是精神的载体，“人们应当认识到：我们的愉悦、欢乐、笑声和谈谐都来自脑，而且仅仅来自脑；还有我们的忧愁、痛苦及爱恋和哭泣。”",{"type":182,"tag":209,"props":220,"children":221},{},[222],{"type":187,"value":223},"与希波克拉底相反，亚里士多德（BC384 ~ BC322）认为精神在心。",{"type":182,"tag":209,"props":225,"children":226},{},[227],{"type":187,"value":228},"加仑（BC129 ~ D.C. 199）支持精神在脑，并且通过实验证明了发音受喉返神经控制。",{"type":182,"tag":209,"props":230,"children":231},{},[232],{"type":187,"value":233},"达芬奇（1452~1519）在人体解剖学有所建树，他绘制了拥有四个脑室的脑图，并制作了牛脑室的灌注蜡模。",{"type":182,"tag":209,"props":235,"children":236},{},[237],{"type":187,"value":238},"维萨里（1514~1564）通过解剖，基本完善了今日神经科学教科书上关于脑的描述。著有《人体构造》（1543）。",{"type":182,"tag":209,"props":240,"children":241},{},[242],{"type":187,"value":243},"笛卡尔（1596~1650）认为脑只是和其它器官别无两样的器官，可以比拟为机械运动而加以描述和研究，因此开创了脑功能的分析和实验研究。",{"type":182,"tag":209,"props":245,"children":246},{},[247],{"type":187,"value":248},"威利斯（1621~1675）在《大脑解剖》（1664）中广泛讨论了脑的生理、解剖、化学、临床神经学。",{"type":182,"tag":209,"props":250,"children":251},{},[252],{"type":187,"value":253},"18 世纪末，伽伐尼发现动物电：蛙腿可因神经接受电刺激而收缩，神经肌肉活动时有电产生。神经活动的实质是生物电活动，这种观念一句扫除了过去把精神归结为灵魂、元气、精灵或微小颗粒的活动等旧观念。",{"type":182,"tag":209,"props":255,"children":256},{},[257],{"type":187,"value":258},"1839 年施莱登和施旺提出细胞理论，拉蒙-卡哈尔在此基础上提出神经元学说，认为细胞理论同样适用于神经细胞。",{"type":182,"tag":209,"props":260,"children":261},{},[262],{"type":187,"value":263},"1887 年，弗里乔夫·南森认为智力存在于脑中大量的神经细胞连接之中。",{"type":182,"tag":209,"props":265,"children":266},{},[267],{"type":187,"value":268},"1897 年，谢灵顿提出突触理论，后提出神经系统整合作用理论：中枢神经系统接受神经传入形成输出主要靠抑制作用，并在 1932 年受诺贝尔奖。突触理论在 1950 年代电子显微镜出现后得到了实验证实。",{"type":182,"tag":209,"props":270,"children":271},{},[272],{"type":187,"value":273},"19 世纪末，加尔提出颅相学，最早认为大脑各区具有功能上的特异性。",{"type":182,"tag":209,"props":275,"children":276},{},[277],{"type":187,"value":278},"1950 年代，里奥克成立第一个神经科学实验室。",{"type":182,"tag":209,"props":280,"children":281},{},[282],{"type":187,"value":283},"1968 年，米勒、杰拉尔德和芒卡斯尔创办了第一次神经科学学会会议，与会 600 人。",{"type":182,"tag":209,"props":285,"children":286},{},[287],{"type":187,"value":288},"1978 年，考恩出版《神经科学年鉴》。",{"type":182,"tag":190,"props":290,"children":292},{"id":291},"阅读",[293],{"type":187,"value":291},{"type":182,"tag":295,"props":296,"children":298},"h4",{"id":297},"大脑帝国",[299],{"type":182,"tag":300,"props":301,"children":303},"a",{"href":302},"/_books/9787508692876",[304],{"type":187,"value":305},"《大脑帝国》",{"type":182,"tag":190,"props":307,"children":309},{"id":308},"名词译注",[310],{"type":187,"value":308},{"type":182,"tag":312,"props":313,"children":314},"table",{},[315,334],{"type":182,"tag":316,"props":317,"children":318},"thead",{},[319],{"type":182,"tag":320,"props":321,"children":322},"tr",{},[323,329],{"type":182,"tag":324,"props":325,"children":326},"th",{},[327],{"type":187,"value":328},"中译",{"type":182,"tag":324,"props":330,"children":331},{},[332],{"type":187,"value":333},"英文",{"type":182,"tag":335,"props":336,"children":337},"tbody",{},[338],{"type":182,"tag":320,"props":339,"children":340},{},[341,347],{"type":182,"tag":342,"props":343,"children":344},"td",{},[345],{"type":187,"value":346},"精神",{"type":182,"tag":342,"props":348,"children":349},{},[350],{"type":187,"value":351},"mind",{"type":182,"tag":190,"props":353,"children":355},{"id":354},"阅读更多",[356],{"type":187,"value":354},{"type":182,"tag":205,"props":358,"children":359},{},[360,371,381],{"type":182,"tag":209,"props":361,"children":362},{},[363],{"type":182,"tag":300,"props":364,"children":368},{"href":365,"rel":366},"https://xueshu.baidu.com/usercenter/paper/show?paperid=13cd1e266dc30588916159be12586884&site=xueshu_se",[367],"nofollow",[369],{"type":187,"value":370},"《神经科学的发展历史》",{"type":182,"tag":209,"props":372,"children":373},{},[374],{"type":182,"tag":300,"props":375,"children":378},{"href":376,"rel":377},"https://zhuanlan.zhihu.com/p/20420048",[367],[379],{"type":187,"value":380},"《艾德温·史密斯（外科）纸草文稿》",{"type":182,"tag":209,"props":382,"children":383},{},[384],{"type":182,"tag":300,"props":385,"children":388},{"href":386,"rel":387},"https://baijiahao.baidu.com/s?id=1664289015456647938",[367],[389],{"type":187,"value":390},"《颅相学：一门伪科学的兴衰史》",{"title":175,"searchDepth":392,"depth":392,"links":393},2,[394,395,396,397],{"id":192,"depth":392,"text":192},{"id":291,"depth":392,"text":291},{"id":308,"depth":392,"text":308},{"id":354,"depth":392,"text":354},"markdown","content:6.maps:_science:neuroscience.md","content","6.maps/_science/neuroscience.md","6.maps/_science/neuroscience","md",[405,409],{"_path":406,"title":407,"description":408},"/maps/_science/environment","环保","低碳 Web 实践指南",{"_path":410,"title":411,"description":412},"/maps/_science/quantum","量子理论","量子力学是描述微观世界的物理学。",1771071661474]