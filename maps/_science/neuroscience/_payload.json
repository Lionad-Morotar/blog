科，横跨了多个学科领域。现代神经科学有三个主流分支：细胞和分子神经科学、认知神经科学和发育神经学。",{"type":182,"children":183,"toc":394},"root",[184,192,198,207,292,297,309,314,355,360],{"type":185,"tag":186,"props":187,"children":188},"element","p",{},[189],{"type":190,"value":191},"text","神经科学也即脑科学，是一门以脑结构和功能为研究对象的综合学科，横跨了多个学科领域。现代神经科学有三个主流分支：细胞和分子神经科学、认知神经科学和发育神经学。",{"type":185,"tag":193,"props":194,"children":196},"h2",{"id":195},"时间线",[197],{"type":190,"value":195},{"type":185,"tag":186,"props":199,"children":200},{},[201],{"type":185,"tag":202,"props":203,"children":206},"img",{"alt":204,"src":205},"象形字“脑”","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20211208004256.png?w=30",[],{"type":185,"tag":208,"props":209,"children":210},"ul",{},[211,217,222,227,232,237,242,247,252,257,262,267,272,277,282,287],{"type":185,"tag":212,"props":213,"children":214},"li",{},[215],{"type":190,"value":216},"古埃及人的象形字作品《史密斯外科纸草书》（约 BC3000 ~ BC1700）中第一次出现了文字“脑”，并记录一些相关的有趣的案例。",{"type":185,"tag":212,"props":218,"children":219},{},[220],{"type":190,"value":221},"希波克拉底（约 BC500）认为脑是精神的载体，“人们应当认识到：我们的愉悦、欢乐、笑声和谈谐都来自脑，而且仅仅来自脑；还有我们的忧愁、痛苦及爱恋和哭泣。”",{"type":185,"tag":212,"props":223,"children":224},{},[225],{"type":190,"value":226},"与希波克拉底相反，亚里士多德（BC384 ~ BC322）认为精神在心。",{"type":185,"tag":212,"props":228,"children":229},{},[230],{"type":190,"value":231},"加仑（BC129 ~ D.C. 199）支持精神在脑，并且通过实验证明了发音受喉返神经控制。",{"type":185,"tag":212,"props":233,"children":234},{},[235],{"type":190,"value":236},"达芬奇（1452~1519）在人体解剖学有所建树，他绘制了拥有四个脑室的脑图，并制作了牛脑室的灌注蜡模。",{"type":185,"tag":212,"props":238,"children":239},{},[240],{"type":190,"value":241},"维萨里（1514~1564）通过解剖，基本完善了今日神经科学教科书上关于脑的描述。著有《人体构造》（1543）。",{"type":185,"tag":212,"props":243,"children":244},{},[245],{"type":190,"value":246},"笛卡尔（1596~1650）认为脑只是和其它器官别无两样的器官，可以比拟为机械运动而加以描述和研究，因此开创了脑功能的分析和实验研究。",{"type":185,"tag":212,"props":248,"children":249},{},[250],{"type":190,"value":251},"威利斯（1621~1675）在《大脑解剖》（1664）中广泛讨论了脑的生理、解剖、化学、临床神经学。",{"type":185,"tag":212,"props":253,"children":254},{},[255],{"type":190,"value":256},"18 世纪末，伽伐尼发现动物电：蛙腿可因神经接受电刺激而收缩，神经肌肉活动时有电产生。神经活动的实质是生物电活动，这种观念一句扫除了过去把精神归结为灵魂、元气、精灵或微小颗粒的活动等旧观念。",{"type":185,"tag":212,"props":258,"children":259},{},[260],{"type":190,"value":261},"1839 年施莱登和施旺提出细胞理论，拉蒙-卡哈尔在此基础上提出神经元学说，认为细胞理论同样适用于神经细胞。",{"type":185,"tag":212,"props":263,"children":264},{},[265],{"type":190,"value":266},"1887 年，弗里乔夫·南森认为智力存在于脑中大量的神经细胞连接之中。",{"type":185,"tag":212,"props":268,"children":269},{},[270],{"type":190,"value":271},"1897 年，谢灵顿提出突触理论，后提出神经系统整合作用理论：中枢神经系统接受神经传入形成输出主要靠抑制作用，并在 1932 年受诺贝尔奖。突触理论在 1950 年代电子显微镜出现后得到了实验证实。",{"type":185,"tag":212,"props":273,"children":274},{},[275],{"type":190,"value":276},"19 世纪末，加尔提出颅相学，最早认为大脑各区具有功能上的特异性。",{"type":185,"tag":212,"props":278,"children":279},{},[280],{"type":190,"value":281},"1950 年代，里奥克成立第一个神经科学实验室。",{"type":185,"tag":212,"props":283,"children":284},{},[285],{"type":190,"value":286},"1968 年，米勒、杰拉尔德和芒卡斯尔创办了第一次神经科学学会会议，与会 600 人。",{"type":185,"tag":212,"props":288,"children":289},{},[290],{"type":190,"value":291},"1978 年，考恩出版《神经科学年鉴》。",{"type":185,"tag":193,"props":293,"children":295},{"id":294},"阅读",[296],{"type":190,"value":294},{"type":185,"tag":298,"props":299,"children":301},"h4",{"id":300},"大脑帝国",[302],{"type":185,"tag":303,"props":304,"children":306},"a",{"href":305},"/_books/9787508692876",[307],{"type":190,"value":308},"《大脑帝国》",{"type":185,"tag":193,"props":310,"children":312},{"id":311},"名词译注",[313],{"type":190,"value":311},{"type":185,"tag":315,"props":316,"children":317},"table",{},[318,337],{"type":185,"tag":319,"props":320,"children":321},"thead",{},[322],{"type":185,"tag":323,"props":324,"children":325},"tr",{},[326,332],{"type":185,"tag":327,"props":328,"children":329},"th",{},[330],{"type":190,"value":331},"中译",{"type":185,"tag":327,"props":333,"children":334},{},[335],{"type":190,"value":336},"英文",{"type":185,"tag":338,"props":339,"children":340},"tbody",{},[341],{"type":185,"tag":323,"props":342,"children":343},{},[344,350],{"type":185,"tag":345,"props":346,"children":347},"td",{},[348],{"type":190,"value":349},"精神",{"type":185,"tag":345,"props":351,"children":352},{},[353],{"type":190,"value":354},"mind",{"type":185,"tag":193,"props":356,"children":358},{"id":357},"阅读更多",[359],{"type":190,"value":357},{"type":185,"tag":208,"props":361,"children":362},{},[363,374,384],{"type":185,"tag":212,"props":364,"children":365},{},[366],{"type":185,"tag":303,"props":367,"children":371},{"href":368,"rel":369},"https://xueshu.baidu.com/usercenter/paper/show?paperid=13cd1e266dc30588916159be12586884&site=xueshu_se",[370],"nofollow",[372],{"type":190,"value":373},"《神经科学的发展历史》",{"type":185,"tag":212,"props":375,"children":376},{},[377],{"type":185,"tag":303,"props":378,"children":381},{"href":379,"rel":380},"https://zhuanlan.zhihu.com/p/20420048",[370],[382],{"type":190,"value":383},"《艾德温·史密斯（外科）纸草文稿》",{"type":185,"tag":212,"props":385,"children":386},{},[387],{"type":185,"tag":303,"props":388,"children":391},{"href":389,"rel":390},"https://baijiahao.baidu.com/s?id=1664289015456647938",[370],[392],{"type":190,"value":393},"《颅相学：一门伪科学的兴衰史》",{"title":178,"searchDepth":395,"depth":395,"links":396},2,[397,398,399,400],{"id":195,"depth":395,"text":195},{"id":294,"depth":395,"text":294},{"id":311,"depth":395,"text":311},{"id":357,"depth":395,"text":357},"markdown","content:6.maps:_science:neuroscience.md","content","6.maps/_science/neuroscience.md","6.maps/_science/neuroscience","md",[408,412],{"_path":409,"title":410,"description":411},"/maps/_science/environment","环保","低碳 Web 实践指南",{"_path":413,"title":414,"description":415},"/maps/_science/quantum","量子理论","量子力学是描述微观世界的物理学。",1771521487515]