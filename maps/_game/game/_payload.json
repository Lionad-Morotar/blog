,[184,193,199,259,273,279,284,295,323,333,356,366,389,399],{"type":185,"tag":186,"props":187,"children":189},"element","h4",{"id":188},"中国游戏版号简史",[190],{"type":191,"value":192},"text","中国游戏版号简史？",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"以下是按照时间线对中国游戏版号发展历程的总结：",{"type":185,"tag":200,"props":201,"children":202},"ul",{},[203,209,214,219,224,229,234,239,244,249,254],{"type":185,"tag":204,"props":205,"children":206},"li",{},[207],{"type":191,"value":208},"上世纪 90 年代：游戏载体演变成光盘，印制游戏光盘需要取得出版许可，即“光盘号”。",{"type":185,"tag":204,"props":210,"children":211},{},[212],{"type":191,"value":213},"2004：新闻出版总署出台《电子出版物管理规定（暂行）》等，将网络游戏纳入出版物管理范畴，实施上线前审查审批，旨在严格网络游戏内容审查，注重未成年人内容把关。",{"type":185,"tag":204,"props":215,"children":216},{},[217],{"type":191,"value":218},"2009：中央编办下发文件明确职责，规定经新闻出版总署前置审批过的网络游戏，文化部应允许上网，不再重复审查；未经审批擅自上网的，由文化部执法查处。《魔兽世界》代理权更换风波，暴露出新闻出版总署与文化部在游戏监管上的职责交叉问题。",{"type":185,"tag":204,"props":220,"children":221},{},[222],{"type":191,"value":223},"2016：原国家新闻出版广电总局发布新规，要求所有手游上线前均需取得版号，取消了早先对无剧情轻度游戏的备案制特例，版号成为所有游戏的刚性门槛。",{"type":185,"tag":204,"props":225,"children":226},{},[227],{"type":191,"value":228},"2018：中央宣传部接管大部分国家新闻出版署的职能，负责包含游戏在内的出版物审批监管，原新闻出版广电总局不再保留。版号审批工作因机构整合陷入停滞，直到当年 12 月才恢复。8 月，《综合防控儿童青少年近视实施方案》首次提出“实施网络游戏总量调控”，预示着监管部门要大幅压缩每年发放版号的数量。12 月，中央层面成立网络游戏道德委员会，对存量游戏展开评议整改。版号审批正式重启。",{"type":185,"tag":204,"props":230,"children":231},{},[232],{"type":191,"value":233},"2019：国家新闻出版署出台《关于防止未成年人沉迷网络游戏的通知》，要求实行实名制和游戏时长限制。",{"type":185,"tag":204,"props":235,"children":236},{},[237],{"type":191,"value":238},"2021：7 月起，版号冻结直至 2022 年 4 月恢复。8 月 30 日，国家新闻出版署等部门联合出台“830 新规”，要求严控未成年人游戏时间，每周仅限周末 3 天、每天 1 小时。",{"type":185,"tag":204,"props":240,"children":241},{},[242],{"type":191,"value":243},"2022：4 月 11 日，版号发放恢复。下半年重启进口游戏审批。",{"type":185,"tag":204,"props":245,"children":246},{},[247],{"type":191,"value":248},"2023：12 月发布新版《网络游戏管理办法（草案）》征求意见稿，尝试补全政策漏洞，规范游戏审批与运营要求。",{"type":185,"tag":204,"props":250,"children":251},{},[252],{"type":191,"value":253},"2024：版号发放数量继续增长，进口版号恢复每月稳定发放。各地发布地方性政策，解决厂商申请 ICP 证前置备案的困境。",{"type":185,"tag":204,"props":255,"children":256},{},[257],{"type":191,"value":258},"2025：1 月，中宣部联合多部委发布《关于推动文化高质量发展的若干经济政策》，支持符合条件的文化企业上市和再融资。",{"type":185,"tag":194,"props":260,"children":261},{},[262,264],{"type":191,"value":263},"见：",{"type":185,"tag":265,"props":266,"children":270},"a",{"href":267,"rel":268},"https://www.chuapp.com/article/290488.html",[269],"nofollow",[271],{"type":191,"value":272},"中国游戏版号简史 @艾谢德",{"type":185,"tag":186,"props":274,"children":276},{"id":275},"_2d-web-游戏框架选型指南",[277],{"type":191,"value":278},"2D Web 游戏框架选型指南？",{"type":185,"tag":194,"props":280,"children":281},{},[282],{"type":191,"value":283},"开发者通过构建同一个 Sonic 主题无限跑酷游戏，对比了三个主流 2D Web 游戏框架：",{"type":185,"tag":194,"props":285,"children":286},{},[287,293],{"type":185,"tag":288,"props":289,"children":290},"strong",{},[291],{"type":191,"value":292},"Phaser",{"type":191,"value":294}," —— 商业项目的首选",{"type":185,"tag":200,"props":296,"children":297},{},[298,303,308,313,318],{"type":185,"tag":204,"props":299,"children":300},{},[301],{"type":191,"value":302},"性能与稳定性最佳，在 Safari（WebKit）上表现尤为出色，意味着 iOS 移动端兼容性最好",{"type":185,"tag":204,"props":304,"children":305},{},[306],{"type":191,"value":307},"AI 辅助优势显著，ChatGPT 对 Phaser 问题的回答准确率远高于其他两个框架",{"type":185,"tag":204,"props":309,"children":310},{},[311],{"type":191,"value":312},"社区最大，资源丰富，寻求帮助更容易",{"type":185,"tag":204,"props":314,"children":315},{},[316],{"type":191,"value":317},"支持 headless 模式在服务器端运行，便于开发多人游戏的状态同步",{"type":185,"tag":204,"props":319,"children":320},{},[321],{"type":191,"value":322},"虽然 API 较冗长，但性能与稳定性的回报值得学习成本",{"type":185,"tag":194,"props":324,"children":325},{},[326,331],{"type":185,"tag":288,"props":327,"children":328},{},[329],{"type":191,"value":330},"Kaboom.js (Klay)",{"type":191,"value":332}," —— 快速原型与教学利器",{"type":185,"tag":200,"props":334,"children":335},{},[336,341,346,351],{"type":185,"tag":204,"props":337,"children":338},{},[339],{"type":191,"value":340},"学习曲线最平缓，组件化设计让游戏设计迭代极快",{"type":185,"tag":204,"props":342,"children":343},{},[344],{"type":191,"value":345},"适合游戏原型开发、Game Jam 和教学（甚至被用于儿童编程教育）",{"type":185,"tag":204,"props":347,"children":348},{},[349],{"type":191,"value":350},"性能是三者中最差的，近期虽有优化但仍与 Phaser 差距明显",{"type":185,"tag":204,"props":352,"children":353},{},[354],{"type":191,"value":355},"可扩展性有限，复杂项目会遇到瓶颈",{"type":185,"tag":194,"props":357,"children":358},{},[359,364],{"type":185,"tag":288,"props":360,"children":361},{},[362],{"type":191,"value":363},"Excalibur",{"type":191,"value":365}," —— 有亮点但差异化不足",{"type":185,"tag":200,"props":367,"children":368},{},[369,374,379,384],{"type":185,"tag":204,"props":370,"children":371},{},[372],{"type":191,"value":373},"与 Phaser 同为面向对象范式，API 平均更简洁一些",{"type":185,"tag":204,"props":375,"children":376},{},[377],{"type":191,"value":378},"Debug 模式体验独特（浏览器扩展形式，在 DevTools 中切换和配置）",{"type":185,"tag":204,"props":380,"children":381},{},[382],{"type":191,"value":383},"但场景状态管理需要手动处理（如返回游戏场景时敌人位置未重置），Phaser 则自动处理",{"type":185,"tag":204,"props":385,"children":386},{},[387],{"type":191,"value":388},"总体感觉与 Phaser 相似度太高，性能、功能和生态均不如 Phaser，切换动力不足",{"type":185,"tag":194,"props":390,"children":391},{},[392,397],{"type":185,"tag":288,"props":393,"children":394},{},[395],{"type":191,"value":396},"选型建议",{"type":191,"value":398},"：商业项目选 Phaser；快速原型或教学选 Kaboom.js；Excalibur 的差异化优势不足以支撑迁移成本。",{"type":185,"tag":194,"props":400,"children":401},{},[402,403],{"type":191,"value":263},{"type":185,"tag":265,"props":404,"children":407},{"href":405,"rel":406},"https://www.youtube.com/watch?v=fv4KhkjMr34",[269],[408],{"type":191,"value":409},"2D Web Game Framework Comparison",{"title":178,"searchDepth":411,"depth":411,"links":412},2,[],"markdown","content:6.maps:_game:game.md","content","6.maps/_game/game.md","6.maps/_game/game","md",[420,424],{"_path":421,"title":422,"description":423},"/maps/_frontend/w3c/security/subresource-integrity","Subresource Integrity","子资源完整性协议允许浏览器通过检查哈希值来判断资源是否经过篡改。",{"_path":425,"title":426,"description":427},"/maps/_games/escape-from-tarkov","逃离塔克夫","逃离塔克夫是一款由俄罗斯游戏公司 BattleState Games 开发的第一人称射击游戏。",1771696700798]