.maps/_game/game.md",{"type":183,"children":184,"toc":411},"root",[185,194,200,260,274,280,285,296,324,334,357,367,390,400],{"type":186,"tag":187,"props":188,"children":190},"element","h4",{"id":189},"中国游戏版号简史",[191],{"type":192,"value":193},"text","中国游戏版号简史？",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198],{"type":192,"value":199},"以下是按照时间线对中国游戏版号发展历程的总结：",{"type":186,"tag":201,"props":202,"children":203},"ul",{},[204,210,215,220,225,230,235,240,245,250,255],{"type":186,"tag":205,"props":206,"children":207},"li",{},[208],{"type":192,"value":209},"上世纪 90 年代：游戏载体演变成光盘，印制游戏光盘需要取得出版许可，即\"光盘号\"。",{"type":186,"tag":205,"props":211,"children":212},{},[213],{"type":192,"value":214},"2004：新闻出版总署出台《电子出版物管理规定（暂行）》等，将网络游戏纳入出版物管理范畴，实施上线前审查审批，旨在严格网络游戏内容审查，注重未成年人内容把关。",{"type":186,"tag":205,"props":216,"children":217},{},[218],{"type":192,"value":219},"2009：中央编办下发文件明确职责，规定经新闻出版总署前置审批过的网络游戏，文化部应允许上网，不再重复审查；未经审批擅自上网的，由文化部执法查处。《魔兽世界》代理权更换风波，暴露出新闻出版总署与文化部在游戏监管上的职责交叉问题。",{"type":186,"tag":205,"props":221,"children":222},{},[223],{"type":192,"value":224},"2016：原国家新闻出版广电总局发布新规，要求所有手游上线前均需取得版号，取消了早先对无剧情轻度游戏的备案制特例，版号成为所有游戏的刚性门槛。",{"type":186,"tag":205,"props":226,"children":227},{},[228],{"type":192,"value":229},"2018：中央宣传部接管大部分国家新闻出版署的职能，负责包含游戏在内的出版物审批监管，原新闻出版广电总局不再保留。版号审批工作因机构整合陷入停滞，直到当年 12 月才恢复。8 月，《综合防控儿童青少年近视实施方案》首次提出\"实施网络游戏总量调控\"，预示着监管部门要大幅压缩每年发放版号的数量。12 月，中央层面成立网络游戏道德委员会，对存量游戏展开评议整改。版号审批正式重启。",{"type":186,"tag":205,"props":231,"children":232},{},[233],{"type":192,"value":234},"2019：国家新闻出版署出台《关于防止未成年人沉迷网络游戏的通知》，要求实行实名制和游戏时长限制。",{"type":186,"tag":205,"props":236,"children":237},{},[238],{"type":192,"value":239},"2021：7 月起，版号冻结直至 2022 年 4 月恢复。8 月 30 日，国家新闻出版署等部门联合出台\"830 新规\"，要求严控未成年人游戏时间，每周仅限周末 3 天、每天 1 小时。",{"type":186,"tag":205,"props":241,"children":242},{},[243],{"type":192,"value":244},"2022：4 月 11 日，版号发放恢复。下半年重启进口游戏审批。",{"type":186,"tag":205,"props":246,"children":247},{},[248],{"type":192,"value":249},"2023：12 月发布新版《网络游戏管理办法（草案）》征求意见稿，尝试补全政策漏洞，规范游戏审批与运营要求。",{"type":186,"tag":205,"props":251,"children":252},{},[253],{"type":192,"value":254},"2024：版号发放数量继续增长，进口版号恢复每月稳定发放。各地发布地方性政策，解决厂商申请 ICP 证前置备案的困境。",{"type":186,"tag":205,"props":256,"children":257},{},[258],{"type":192,"value":259},"2025：1 月，中宣部联合多部委发布《关于推动文化高质量发展的若干经济政策》，支持符合条件的文化企业上市和再融资。",{"type":186,"tag":195,"props":261,"children":262},{},[263,265],{"type":192,"value":264},"见：",{"type":186,"tag":266,"props":267,"children":271},"a",{"href":268,"rel":269},"https://www.chuapp.com/article/290488.html",[270],"nofollow",[272],{"type":192,"value":273},"中国游戏版号简史 @艾谢德",{"type":186,"tag":187,"props":275,"children":277},{"id":276},"_2d-web-游戏框架选型指南",[278],{"type":192,"value":279},"2D Web 游戏框架选型指南？",{"type":186,"tag":195,"props":281,"children":282},{},[283],{"type":192,"value":284},"开发者通过构建同一个 Sonic 主题无限跑酷游戏，对比了三个主流 2D Web 游戏框架：",{"type":186,"tag":195,"props":286,"children":287},{},[288,294],{"type":186,"tag":289,"props":290,"children":291},"strong",{},[292],{"type":192,"value":293},"Phaser",{"type":192,"value":295}," —— 商业项目的首选",{"type":186,"tag":201,"props":297,"children":298},{},[299,304,309,314,319],{"type":186,"tag":205,"props":300,"children":301},{},[302],{"type":192,"value":303},"性能与稳定性最佳，在 Safari（WebKit）上表现尤为出色，意味着 iOS 移动端兼容性最好",{"type":186,"tag":205,"props":305,"children":306},{},[307],{"type":192,"value":308},"AI 辅助优势显著，ChatGPT 对 Phaser 问题的回答准确率远高于其他两个框架",{"type":186,"tag":205,"props":310,"children":311},{},[312],{"type":192,"value":313},"社区最大，资源丰富，寻求帮助更容易",{"type":186,"tag":205,"props":315,"children":316},{},[317],{"type":192,"value":318},"支持 headless 模式在服务器端运行，便于开发多人游戏的状态同步",{"type":186,"tag":205,"props":320,"children":321},{},[322],{"type":192,"value":323},"虽然 API 较冗长，但性能与稳定性的回报值得学习成本",{"type":186,"tag":195,"props":325,"children":326},{},[327,332],{"type":186,"tag":289,"props":328,"children":329},{},[330],{"type":192,"value":331},"Kaboom.js (Klay)",{"type":192,"value":333}," —— 快速原型与教学利器",{"type":186,"tag":201,"props":335,"children":336},{},[337,342,347,352],{"type":186,"tag":205,"props":338,"children":339},{},[340],{"type":192,"value":341},"学习曲线最平缓，组件化设计让游戏设计迭代极快",{"type":186,"tag":205,"props":343,"children":344},{},[345],{"type":192,"value":346},"适合游戏原型开发、Game Jam 和教学（甚至被用于儿童编程教育）",{"type":186,"tag":205,"props":348,"children":349},{},[350],{"type":192,"value":351},"性能是三者中最差的，近期虽有优化但仍与 Phaser 差距明显",{"type":186,"tag":205,"props":353,"children":354},{},[355],{"type":192,"value":356},"可扩展性有限，复杂项目会遇到瓶颈",{"type":186,"tag":195,"props":358,"children":359},{},[360,365],{"type":186,"tag":289,"props":361,"children":362},{},[363],{"type":192,"value":364},"Excalibur",{"type":192,"value":366}," —— 有亮点但差异化不足",{"type":186,"tag":201,"props":368,"children":369},{},[370,375,380,385],{"type":186,"tag":205,"props":371,"children":372},{},[373],{"type":192,"value":374},"与 Phaser 同为面向对象范式，API 平均更简洁一些",{"type":186,"tag":205,"props":376,"children":377},{},[378],{"type":192,"value":379},"Debug 模式体验独特（浏览器扩展形式，在 DevTools 中切换和配置）",{"type":186,"tag":205,"props":381,"children":382},{},[383],{"type":192,"value":384},"但场景状态管理需要手动处理（如返回游戏场景时敌人位置未重置），Phaser 则自动处理",{"type":186,"tag":205,"props":386,"children":387},{},[388],{"type":192,"value":389},"总体感觉与 Phaser 相似度太高，性能、功能和生态均不如 Phaser，切换动力不足",{"type":186,"tag":195,"props":391,"children":392},{},[393,398],{"type":186,"tag":289,"props":394,"children":395},{},[396],{"type":192,"value":397},"选型建议",{"type":192,"value":399},"：商业项目选 Phaser；快速原型或教学选 Kaboom.js；Excalibur 的差异化优势不足以支撑迁移成本。",{"type":186,"tag":195,"props":401,"children":402},{},[403,404],{"type":192,"value":264},{"type":186,"tag":266,"props":405,"children":408},{"href":406,"rel":407},"https://www.youtube.com/watch?v=fv4KhkjMr34",[270],[409],{"type":192,"value":410},"2D Web Game Framework Comparison",{"title":178,"searchDepth":412,"depth":412,"links":413},2,[],"markdown","content:6.maps:_game:game:game.md","content","6.maps/_game/game/game.md","6.maps/_game/game/game","md",[421,423],{"_path":422,"title":179,"description":180},"/maps/_game/game",{"_path":424,"title":179,"description":425},"/maps/_games/games","游戏领域知识与攻略，涵盖游戏机制解析、策略指南与相关资源",1772504908446]