dren":180,"toc":321},"root",[181,190,196,202,207,212,217,222,227,232,237,282,287,292,297,302],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"护甲穿透机制",[187],{"type":188,"value":189},"text","护甲&穿透机制",{"type":182,"tag":191,"props":192,"children":193},"p",{},[194],{"type":188,"value":195},"伤害的成因非常复杂，但可以按照数据和公式推导出概率。一些非常繁琐的细节我会忽略，这里着重介绍：碰撞检测、跳蛋、穿透、耐久、碎蛋。",{"type":182,"tag":197,"props":198,"children":200},"h4",{"id":199},"碰撞检测",[201],{"type":188,"value":199},{"type":182,"tag":191,"props":203,"children":204},{},[205],{"type":188,"value":206},"首先要理清的是，护甲的形状并不是真实的碰撞检测形状——这几乎在所有竞技 FPS 中是通用的法则——所以有些带护手的甲连手掌都能防。很离谱。不过这也不算坏消息，有些玩家可能宁愿买不带护手的甲来提高机动性。同时，击中手部位造成的伤害并不致命，所以把甲的耐久点数留给更重要的胸口部位也许反而更加明智。",{"type":182,"tag":197,"props":208,"children":210},{"id":209},"跳蛋",[211],{"type":188,"value":209},{"type":182,"tag":191,"props":213,"children":214},{},[215],{"type":188,"value":216},"只有头盔（和面罩）有跳蛋机制：当子弹以特定角度击中头盔时，根据头盔跳蛋概率和子弹的跳蛋概率一起计算出此次命中是否跳蛋。",{"type":182,"tag":197,"props":218,"children":220},{"id":219},"穿透",[221],{"type":188,"value":219},{"type":182,"tag":191,"props":223,"children":224},{},[225],{"type":188,"value":226},"只有与护甲相比同等级或更高等级的子弹才能对其造成有效击穿。六种等级的护甲其等级可以约等于其等级乘 10。这个数据并不精确，但很方便用于估算第一发子弹的击穿概率。比方说，要第一发子弹就大概率击穿满耐久的五级护甲，需要 50 穿透力的子弹。如果没有穿透护甲，护甲只减少 1 点耐久，并且依子弹和护甲的不同种类，身体会受到轻微冲击伤害。如果穿透，越高等级的护甲（以及越高耐久）越能减免此次伤害：可以简单记住满耐久护甲能减免 25% 的同等级子弹的伤害。",{"type":182,"tag":197,"props":228,"children":230},{"id":229},"耐久",[231],{"type":188,"value":229},{"type":182,"tag":191,"props":233,"children":234},{},[235],{"type":188,"value":236},"护甲的耐久和材料相关，受“毁伤系数”影响，所以不能只看纸面点数。比如玻璃的毁伤系数是 0.8，这意味着伤害为 50，对护甲伤害为 40% 的子弹穿透玻璃后，会对其造成 $40% * 50 * 0.8 = 16$ 点伤害。材料的毁伤系数如下：",{"type":182,"tag":238,"props":239,"children":240},"ul",{},[241,247,252,257,262,267,272,277],{"type":182,"tag":242,"props":243,"children":244},"li",{},[245],{"type":188,"value":246},"Aramid（凯夫拉）：0.25",{"type":182,"tag":242,"props":248,"children":249},{},[250],{"type":188,"value":251},"UHMWPE（超聚乙烯）：0.45",{"type":182,"tag":242,"props":253,"children":254},{},[255],{"type":188,"value":256},"Titan（钛）：0.55",{"type":182,"tag":242,"props":258,"children":259},{},[260],{"type":188,"value":261},"Aluminium（铝）：0.6",{"type":182,"tag":242,"props":263,"children":264},{},[265],{"type":188,"value":266},"Combine Materials（复合材料）： 0.5",{"type":182,"tag":242,"props":268,"children":269},{},[270],{"type":188,"value":271},"Steel（铁）：0.7",{"type":182,"tag":242,"props":273,"children":274},{},[275],{"type":188,"value":276},"Ceramic（陶瓷）：0.8",{"type":182,"tag":242,"props":278,"children":279},{},[280],{"type":188,"value":281},"Glass（玻璃纤维）：0.8",{"type":182,"tag":197,"props":283,"children":285},{"id":284},"碎蛋",[286],{"type":188,"value":284},{"type":182,"tag":191,"props":288,"children":289},{},[290],{"type":188,"value":291},"子弹击中目标后，无论穿透与否，都依据其碎蛋率，分裂出数个弹头。这些弹头的穿透性和伤害等于原子弹的穿透和伤害总数的 50% 再平分。碎蛋的方向不定，所以可能对身体多个区域造成额外伤害。此外，每个弹头对护甲的耐久损耗都至少是 1——这个散弹的子弹计算耐久损耗是一致的。",{"type":182,"tag":191,"props":293,"children":294},{},[295],{"type":188,"value":296},"子弹的碎蛋率不能仅看 WIKI 的纸面数据。游戏中目前有个严重的 BUG，低于 29 穿透力的子弹不会碎蛋。",{"type":182,"tag":183,"props":298,"children":300},{"id":299},"相关阅读",[301],{"type":188,"value":299},{"type":182,"tag":238,"props":303,"children":304},{},[305],{"type":182,"tag":242,"props":306,"children":307},{},[308],{"type":182,"tag":309,"props":310,"children":314},"a",{"href":311,"rel":312},"https://tarkovaftermidnight.wordpress.com/",[313],"nofollow",[315],{"type":182,"tag":316,"props":317,"children":318},"i",{},[319],{"type":188,"value":320},"Armor, Penetration, and Damage",{"title":175,"searchDepth":322,"depth":322,"links":323},2,[324,325],{"id":185,"depth":322,"text":189},{"id":299,"depth":322,"text":299},"markdown","content:6.maps:_games:escape-from-tarkov.md","content","6.maps/_games/escape-from-tarkov.md","6.maps/_games/escape-from-tarkov","md",[333,337],{"_path":334,"title":335,"description":336},"/maps/_game/game","游戏","游戏开发、游戏设计、游戏行业等",{"_path":338,"title":339,"description":340},"/maps/_go/go","Go","Go（又称 Golang）是 Google 开发的一种静态强类型、编译型、并发型，并具有垃圾回收功能的编程语言。Go 被誉为是未来的服务器端编程语言。",1771264632185]