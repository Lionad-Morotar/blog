le":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"body":181,"_type":329,"_id":330,"_source":331,"_file":332,"_stem":333,"_extension":334},"/maps/_games/escape-from-tarkov","_games",false,true,"","逃离塔克夫","逃离塔克夫是一款由俄罗斯游戏公司 BattleState Games 开发的第一人称射击游戏。",{"type":182,"children":183,"toc":324},"root",[184,193,199,205,210,215,220,225,230,235,240,285,290,295,300,305],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"护甲穿透机制",[190],{"type":191,"value":192},"text","护甲&穿透机制",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"伤害的成因非常复杂，但可以按照数据和公式推导出概率。一些非常繁琐的细节我会忽略，这里着重介绍：碰撞检测、跳蛋、穿透、耐久、碎蛋。",{"type":185,"tag":200,"props":201,"children":203},"h4",{"id":202},"碰撞检测",[204],{"type":191,"value":202},{"type":185,"tag":194,"props":206,"children":207},{},[208],{"type":191,"value":209},"首先要理清的是，护甲的形状并不是真实的碰撞检测形状——这几乎在所有竞技 FPS 中是通用的法则——所以有些带护手的甲连手掌都能防。很离谱。不过这也不算坏消息，有些玩家可能宁愿买不带护手的甲来提高机动性。同时，击中手部位造成的伤害并不致命，所以把甲的耐久点数留给更重要的胸口部位也许反而更加明智。",{"type":185,"tag":200,"props":211,"children":213},{"id":212},"跳蛋",[214],{"type":191,"value":212},{"type":185,"tag":194,"props":216,"children":217},{},[218],{"type":191,"value":219},"只有头盔（和面罩）有跳蛋机制：当子弹以特定角度击中头盔时，根据头盔跳蛋概率和子弹的跳蛋概率一起计算出此次命中是否跳蛋。",{"type":185,"tag":200,"props":221,"children":223},{"id":222},"穿透",[224],{"type":191,"value":222},{"type":185,"tag":194,"props":226,"children":227},{},[228],{"type":191,"value":229},"只有与护甲相比同等级或更高等级的子弹才能对其造成有效击穿。六种等级的护甲其等级可以约等于其等级乘 10。这个数据并不精确，但很方便用于估算第一发子弹的击穿概率。比方说，要第一发子弹就大概率击穿满耐久的五级护甲，需要 50 穿透力的子弹。如果没有穿透护甲，护甲只减少 1 点耐久，并且依子弹和护甲的不同种类，身体会受到轻微冲击伤害。如果穿透，越高等级的护甲（以及越高耐久）越能减免此次伤害：可以简单记住满耐久护甲能减免 25% 的同等级子弹的伤害。",{"type":185,"tag":200,"props":231,"children":233},{"id":232},"耐久",[234],{"type":191,"value":232},{"type":185,"tag":194,"props":236,"children":237},{},[238],{"type":191,"value":239},"护甲的耐久和材料相关，受“毁伤系数”影响，所以不能只看纸面点数。比如玻璃的毁伤系数是 0.8，这意味着伤害为 50，对护甲伤害为 40% 的子弹穿透玻璃后，会对其造成 $40% * 50 * 0.8 = 16$ 点伤害。材料的毁伤系数如下：",{"type":185,"tag":241,"props":242,"children":243},"ul",{},[244,250,255,260,265,270,275,280],{"type":185,"tag":245,"props":246,"children":247},"li",{},[248],{"type":191,"value":249},"Aramid（凯夫拉）：0.25",{"type":185,"tag":245,"props":251,"children":252},{},[253],{"type":191,"value":254},"UHMWPE（超聚乙烯）：0.45",{"type":185,"tag":245,"props":256,"children":257},{},[258],{"type":191,"value":259},"Titan（钛）：0.55",{"type":185,"tag":245,"props":261,"children":262},{},[263],{"type":191,"value":264},"Aluminium（铝）：0.6",{"type":185,"tag":245,"props":266,"children":267},{},[268],{"type":191,"value":269},"Combine Materials（复合材料）： 0.5",{"type":185,"tag":245,"props":271,"children":272},{},[273],{"type":191,"value":274},"Steel（铁）：0.7",{"type":185,"tag":245,"props":276,"children":277},{},[278],{"type":191,"value":279},"Ceramic（陶瓷）：0.8",{"type":185,"tag":245,"props":281,"children":282},{},[283],{"type":191,"value":284},"Glass（玻璃纤维）：0.8",{"type":185,"tag":200,"props":286,"children":288},{"id":287},"碎蛋",[289],{"type":191,"value":287},{"type":185,"tag":194,"props":291,"children":292},{},[293],{"type":191,"value":294},"子弹击中目标后，无论穿透与否，都依据其碎蛋率，分裂出数个弹头。这些弹头的穿透性和伤害等于原子弹的穿透和伤害总数的 50% 再平分。碎蛋的方向不定，所以可能对身体多个区域造成额外伤害。此外，每个弹头对护甲的耐久损耗都至少是 1——这个散弹的子弹计算耐久损耗是一致的。",{"type":185,"tag":194,"props":296,"children":297},{},[298],{"type":191,"value":299},"子弹的碎蛋率不能仅看 WIKI 的纸面数据。游戏中目前有个严重的 BUG，低于 29 穿透力的子弹不会碎蛋。",{"type":185,"tag":186,"props":301,"children":303},{"id":302},"相关阅读",[304],{"type":191,"value":302},{"type":185,"tag":241,"props":306,"children":307},{},[308],{"type":185,"tag":245,"props":309,"children":310},{},[311],{"type":185,"tag":312,"props":313,"children":317},"a",{"href":314,"rel":315},"https://tarkovaftermidnight.wordpress.com/",[316],"nofollow",[318],{"type":185,"tag":319,"props":320,"children":321},"i",{},[322],{"type":191,"value":323},"Armor, Penetration, and Damage",{"title":178,"searchDepth":325,"depth":325,"links":326},2,[327,328],{"id":188,"depth":325,"text":192},{"id":302,"depth":325,"text":302},"markdown","content:6.maps:_games:escape-from-tarkov.md","content","6.maps/_games/escape-from-tarkov.md","6.maps/_games/escape-from-tarkov","md",[336,340],{"_path":337,"title":338,"description":339},"/maps/_game/game","游戏","游戏开发、游戏设计、游戏行业等",{"_path":341,"title":342,"description":343},"/maps/_go/go","Go","Go（又称 Golang）是 Google 开发的一种静态强类型、编译型、并发型，并具有垃圾回收功能的编程语言。Go 被誉为是未来的服务器端编程语言。",1771304517157]