e","云原生技术概论",{"type":182,"children":183,"toc":693},"root",[184,193,210,216,228,232,246,252,258,265,271,283,289,294,300,305,311,316,325,336,342,396,402,407,413,418,456,462,467,472,478,483,489,494,500,505,511,516,525,531,536,542,560,566,571,576,582,587,593,598,604,609,615,628,633,639,644,650,655,661,666,672],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"overview",[190],{"type":191,"value":192},"text","Overview",{"type":185,"tag":194,"props":195,"children":196},"ul",{},[197],{"type":185,"tag":198,"props":199,"children":200},"li",{},[201],{"type":185,"tag":202,"props":203,"children":207},"a",{"href":204,"rel":205},"https://landscape.cncf.io/?group=projects-and-products",[206],"nofollow",[208],{"type":191,"value":209},"CNCF CloudNative Landscapes",{"type":185,"tag":186,"props":211,"children":213},{"id":212},"components",[214],{"type":191,"value":215},"Components",{"type":185,"tag":194,"props":217,"children":218},{},[219],{"type":185,"tag":198,"props":220,"children":221},{},[222],{"type":185,"tag":202,"props":223,"children":225},{"href":224},"/maps/_cloud-native/kubernetes",[226],{"type":191,"value":227},"Kubernetes",{"type":185,"tag":186,"props":229,"children":230},{"id":180},[231],{"type":191,"value":180},{"type":185,"tag":194,"props":233,"children":234},{},[235],{"type":185,"tag":198,"props":236,"children":237},{},[238,240],{"type":191,"value":239},"云原生技术概览：",{"type":185,"tag":202,"props":241,"children":244},{"href":242,"rel":243},"https://www.thebyte.com.cn/architecture/summary.html",[206],[245],{"type":191,"value":242},{"type":185,"tag":186,"props":247,"children":249},{"id":248},"quick-question",[250],{"type":191,"value":251},"Quick Question",{"type":185,"tag":253,"props":254,"children":256},"h3",{"id":255},"云原生",[257],{"type":191,"value":255},{"type":185,"tag":259,"props":260,"children":262},"h4",{"id":261},"云原生是什么",[263],{"type":191,"value":264},"云原生是什么？",{"type":185,"tag":266,"props":267,"children":268},"p",{},[269],{"type":191,"value":270},"云原生是一种架构理论，旨在充分发挥云平台的弹性和分布式优势，构建在云上以最佳姿势运行应用程序。",{"type":185,"tag":266,"props":272,"children":273},{},[274,276],{"type":191,"value":275},"见：",{"type":185,"tag":202,"props":277,"children":280},{"href":278,"rel":279},"https://zhuanlan.zhihu.com/p/150190166",[206],[281],{"type":191,"value":282},"什么是云原生？",{"type":185,"tag":259,"props":284,"children":286},{"id":285},"云原生架构的特点是什么",[287],{"type":191,"value":288},"云原生架构的特点是什么？",{"type":185,"tag":266,"props":290,"children":291},{},[292],{"type":191,"value":293},"基于微服务架构，配合服务网格，降低业务单体的复杂性；借助敏捷方法和 DevOps 方法提高迭代效率，同时采用 K8S + 容器支持运维自动化；最后，利用云平台基础设施提供的声明式基础设施配置，实现资源的弹性伸缩、动态调度，提高资源利用率。",{"type":185,"tag":259,"props":295,"children":297},{"id":296},"云原生不可能三角",[298],{"type":191,"value":299},"云原生不可能三角？",{"type":185,"tag":266,"props":301,"children":302},{},[303],{"type":191,"value":304},"高可用、规模化、敏捷；其间关系分别可戏称为大象起舞、空中换发和巨人绣花。",{"type":185,"tag":259,"props":306,"children":308},{"id":307},"云原生架构的定义",[309],{"type":191,"value":310},"云原生架构的定义？",{"type":185,"tag":266,"props":312,"children":313},{},[314],{"type":191,"value":315},"云原生基金会 CNCF 给出的云原生的定义的 V1 版本。",{"type":185,"tag":317,"props":318,"children":319},"blockquote",{},[320],{"type":185,"tag":266,"props":321,"children":322},{},[323],{"type":191,"value":324},"云原生技术有利于各组织在公有云、私有云和混合云等新型动态环境中，构建和运行可弹性扩展的应用。云原生的代表技术包括容器、服务网格、微服务、不可变基础设施和声明式 API。\n这些技术能够构建容错性好、易于管理和便于观察的松耦合系统。结合可靠的自动化手段，云原生技术使工程师能够轻松地对系统作出频繁和可预测的重大变更。\n云原生计算基金会（CNCF）致力于培育和维护一个厂商中立的开源生态系统，来推广云原生技术。我们通过将最前沿的模式民主化，让这些创新为大众所用。",{"type":185,"tag":266,"props":326,"children":327},{},[328,329],{"type":191,"value":275},{"type":185,"tag":202,"props":330,"children":333},{"href":331,"rel":332},"https://github.com/cncf/toc/blob/main/DEFINITION.md#%E4%B8%AD%E6%96%87%E7%89%88%E6%9C%AC",[206],[334],{"type":191,"value":335},"CNCF DEFINITION",{"type":185,"tag":259,"props":337,"children":339},{"id":338},"云原生架构相关哪些技术",[340],{"type":191,"value":341},"云原生架构相关哪些技术？",{"type":185,"tag":343,"props":344,"children":345},"ol",{},[346,351,356,361,366,371,376,381,386,391],{"type":185,"tag":198,"props":347,"children":348},{},[349],{"type":191,"value":350},"容器和镜像：Docker、Containerd、CRI-O、Kata Containers",{"type":185,"tag":198,"props":352,"children":353},{},[354],{"type":191,"value":355},"镜像仓库：Harbor、Nydus",{"type":185,"tag":198,"props":357,"children":358},{},[359],{"type":191,"value":360},"应用封装：Kustomize、Helm",{"type":185,"tag":198,"props":362,"children":363},{},[364],{"type":191,"value":365},"持续集成：Gitlab、Tekton",{"type":185,"tag":198,"props":367,"children":368},{},[369],{"type":191,"value":370},"持续部署：FluxCD、argoCD",{"type":185,"tag":198,"props":372,"children":373},{},[374],{"type":191,"value":375},"容器编排：Kubernetes",{"type":185,"tag":198,"props":377,"children":378},{},[379],{"type":191,"value":380},"网关：Ingress-Nginx、APISIX",{"type":185,"tag":198,"props":382,"children":383},{},[384],{"type":191,"value":385},"日志：Fluentd、Grafana Loki",{"type":185,"tag":198,"props":387,"children":388},{},[389],{"type":191,"value":390},"监控：Grafana、Prometheus",{"type":185,"tag":198,"props":392,"children":393},{},[394],{"type":191,"value":395},"应用开发：Nocalhost",{"type":185,"tag":259,"props":397,"children":399},{"id":398},"从架构发展来看用户和平台的关注点是怎么变化的",[400],{"type":191,"value":401},"从架构发展来看，用户和平台的关注点是怎么变化的？",{"type":185,"tag":266,"props":403,"children":404},{},[405],{"type":191,"value":406},"从用户自建、IaaS、PaaS、SaaS 到 FaaS，客户和平台关注的东西并不一样。\n以 SaaS 举例，客户只需要关注数据，而平台关注包括应用程序、应用依赖、中间件、操作系统、虚拟化服务器、存储、网格等其余所有基础设施。",{"type":185,"tag":259,"props":408,"children":410},{"id":409},"有哪些亿级-dau-规模的移动应用",[411],{"type":191,"value":412},"有哪些亿级 DAU 规模的移动应用？",{"type":185,"tag":266,"props":414,"children":415},{},[416],{"type":191,"value":417},"POE Assistant：以下是一些拥有亿级日活跃用户（DAU）规模的知名移动应用的例子（截至 2021 年）",{"type":185,"tag":343,"props":419,"children":420},{},[421,426,431,436,441,446,451],{"type":185,"tag":198,"props":422,"children":423},{},[424],{"type":191,"value":425},"Facebook：Facebook 是全球最大的社交媒体平台，拥有超过 20 亿月活跃用户，其中大部分用户通过移动应用进行访问。",{"type":185,"tag":198,"props":427,"children":428},{},[429],{"type":191,"value":430},"WhatsApp：WhatsApp 是一款全球领先的即时通讯应用程序，每天有超过 20 亿用户使用该应用进行消息传递和语音通话。",{"type":185,"tag":198,"props":432,"children":433},{},[434],{"type":191,"value":435},"WeChat（微信）：WeChat 是中国最流行的社交媒体和消息应用之一，拥有超过 10 亿活跃用户。它提供了聊天、社交、支付、游戏和其他功能。",{"type":185,"tag":198,"props":437,"children":438},{},[439],{"type":191,"value":440},"TikTok（抖音）：TikTok 是一款全球流行的短视频社交平台，拥有超过 10 亿用户。它提供了用户生成的短视频内容，吸引了大量的年轻用户。",{"type":185,"tag":198,"props":442,"children":443},{},[444],{"type":191,"value":445},"Instagram：Instagram 是一款图片和视频分享社交平台，拥有超过 10 亿用户。它提供了用户上传和编辑照片、视频以及与其他用户互动的功能。",{"type":185,"tag":198,"props":447,"children":448},{},[449],{"type":191,"value":450},"Snapchat：Snapchat 是一款以瞬间分享和自动消失的照片和视频为特点的移动应用，拥有超过 5 亿用户。",{"type":185,"tag":198,"props":452,"children":453},{},[454],{"type":191,"value":455},"Twitter：Twitter 是一款全球知名的社交媒体平台，用户可以发布和阅读短消息（推文）。它拥有超过 3 亿的活跃用户。",{"type":185,"tag":259,"props":457,"children":459},{"id":458},"如何按照规模和变更速度将软件企业划分为四个象限",[460],{"type":191,"value":461},"如何按照规模和变更速度将软件企业划分为四个象限？",{"type":185,"tag":266,"props":463,"children":464},{},[465],{"type":191,"value":466},"援引 Netflix 的说法，按照规模大小、变更速度的快慢可以将软件划分为：互联网企业（规模大、变化快）、初创公司（规模小、变化快）、电信业务（规模大、变化慢）、企业 IT（规模小、变化慢）。",{"type":185,"tag":266,"props":468,"children":469},{},[470],{"type":191,"value":471},"初创公司面临软件失败的风险、电信业务面临硬件失败风险，企业 IT 要面对来自市场的冲击，而互联网企业是最危险的“Everything is Broken”。",{"type":185,"tag":259,"props":473,"children":475},{"id":474},"什么是虚拟化技术",[476],{"type":191,"value":477},"什么是虚拟化技术？",{"type":185,"tag":266,"props":479,"children":480},{},[481],{"type":191,"value":482},"虚拟化技术是一种资源管理技术，它可以将一台计算机的各种资源，如处理器、内存、硬盘、网络接口卡等，抽象、转换后提供给多个用户和应用程序使用。",{"type":185,"tag":259,"props":484,"children":486},{"id":485},"最早的容器技术",[487],{"type":191,"value":488},"最早的容器技术？",{"type":185,"tag":266,"props":490,"children":491},{},[492],{"type":191,"value":493},"Chroot Jail；使用 chroot 系统调用将进程的 root 目录重定向到新位置，仪表创造独立的环境用于软件编译、测试以及安装。",{"type":185,"tag":259,"props":495,"children":497},{"id":496},"linux-容器是什么",[498],{"type":191,"value":499},"Linux 容器是什么？",{"type":185,"tag":266,"props":501,"children":502},{},[503],{"type":191,"value":504},"LXC，Linux Container；Google 推出的进程容器合并进入 Linux 内核后重命名为 Control Groups，它允许给进程提供操作系统级别的资源限制、优先级控制、审计能力。配合 namepace 称为 LXC，再配合安全防护机制形成了容器运行环境隔离的容器核心能力。",{"type":185,"tag":259,"props":506,"children":508},{"id":507},"docker-继-lxc-解决的问题是",[509],{"type":191,"value":510},"Docker 继 LXC 解决的问题是？",{"type":185,"tag":266,"props":512,"children":513},{},[514],{"type":191,"value":515},"Docker 封装了应用程序的代码、依赖、工具、资源文件和元信息，可以做到将应用分发到任意平台或运行环境，即“Build once，Ship and Run Anywhere”",{"type":185,"tag":266,"props":517,"children":518},{},[519],{"type":185,"tag":520,"props":521,"children":524},"img",{"alt":522,"src":523},"Docker","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20231118201706.png",[],{"type":185,"tag":259,"props":526,"children":528},{"id":527},"为什么称-kubernetes-成了容器编排事实标准",[529],{"type":191,"value":530},"为什么称 Kubernetes 成了容器编排事实标准？",{"type":185,"tag":266,"props":532,"children":533},{},[534],{"type":191,"value":535},"在于 Docker Swarm、Apache Mesos 的斗争中，K8s 没有历史包袱，预置了服务发现、容器网格等关键特性，并提供了用于描述集群架构、定义服务状态的声明式 API，帮助系统维持在这个状态，有明显的后发优势。最重要的是，K8s 拥有一套稳定可扩展的 API 盘活了生态。",{"type":185,"tag":259,"props":537,"children":539},{"id":538},"容器兴起和编排大战的三个里程碑",[540],{"type":191,"value":541},"容器兴起和编排大战的三个里程碑？",{"type":185,"tag":343,"props":543,"children":544},{},[545,550,555],{"type":185,"tag":198,"props":546,"children":547},{},[548],{"type":191,"value":549},"2013 ，Doocker 发布，云计算进入容器时代",{"type":185,"tag":198,"props":551,"children":552},{},[553],{"type":191,"value":554},"2017 ，K8s 赢得容器编排的胜利，云计算进入 K8s 时代",{"type":185,"tag":198,"props":556,"children":557},{},[558],{"type":191,"value":559},"2018，Istio 发布，服务网格的理念走向成熟",{"type":185,"tag":259,"props":561,"children":563},{"id":562},"oci-和-cncf-的关系",[564],{"type":191,"value":565},"OCI 和 CNCF 的关系？",{"type":185,"tag":266,"props":567,"children":568},{},[569],{"type":191,"value":570},"合作关系。",{"type":185,"tag":266,"props":572,"children":573},{},[574],{"type":191,"value":575},"TODO",{"type":185,"tag":259,"props":577,"children":579},{"id":578},"微服务带来了哪些技术挑战",[580],{"type":191,"value":581},"微服务带来了哪些技术挑战？",{"type":185,"tag":266,"props":583,"children":584},{},[585],{"type":191,"value":586},"服务发现、服务熔断、负载均衡和通讯相关问题。通讯包括调用协议、加密、认证、鉴权等。",{"type":185,"tag":259,"props":588,"children":590},{"id":589},"什么是服务网格",[591],{"type":191,"value":592},"什么是服务网格？",{"type":185,"tag":266,"props":594,"children":595},{},[596],{"type":191,"value":597},"服务网格是云原生的基础设施，用于云原生应用微服务组成的的复杂拓扑结构下的可靠请求传送。在实践中，它是一组和应用服务部署在一起的轻量级网络代理（Sidecar）。",{"type":185,"tag":259,"props":599,"children":601},{"id":600},"istio-初始架构是怎样的",[602],{"type":191,"value":603},"Istio 初始架构是怎样的？",{"type":185,"tag":266,"props":605,"children":606},{},[607],{"type":191,"value":608},"Istio 分为数据平面和控制平面。数据平面使用轻量级 Sidecar 如 Envoy 协调与控制服务之间的通信和流量处理；控制平面负责配置和管理数据平面，以及提供服务发现、智能路由、流量控制、安全控制等功能。",{"type":185,"tag":259,"props":610,"children":612},{"id":611},"sidecar-面临的问题或者说缺陷是",[613],{"type":191,"value":614},"Sidecar 面临的问题或者说缺陷是？",{"type":185,"tag":343,"props":616,"children":617},{},[618,623],{"type":185,"tag":198,"props":619,"children":620},{},[621],{"type":191,"value":622},"在规模巨大化的服务集群下，网络通信的拓扑结构非常复杂，对作为独立容器的 Sidecar 下发配置会导致内存剧烈增长；",{"type":185,"tag":198,"props":624,"children":625},{},[626],{"type":191,"value":627},"某些性能要求极高的业务场景，毫秒级别的延迟也不能接受。",{"type":185,"tag":266,"props":629,"children":630},{},[631],{"type":191,"value":632},"作为改进，Proxyless 模式可以去 Sidecard 容器、消除跨进程调用，并降低延迟。但本质上，它只是使用 Istio Agent 把服务注册等工作和 gRPC  等框架绑定在了一起。",{"type":185,"tag":259,"props":634,"children":636},{"id":635},"sidecarless-模式是什么",[637],{"type":191,"value":638},"Sidecarless 模式是什么？",{"type":185,"tag":266,"props":640,"children":641},{},[642],{"type":191,"value":643},"通过 Agent（代理）、注入式库或者云原生平台功能将 Sidecar 干掉。从原理来说，在 L4 和 L7 分别建立用途不一样的代理，托管不同的流量。L4 层建立了 TCP 路由，有简单的鉴权机制，使用 eBFP 通讯，能观测 TCP 指标和日志。L7 层建立了 HTTP 路由，有完善的鉴权。\nIstio 未来的发展方向就是完善 Ambient Mesh（一种无边车模式的实现）。其使用 DaemonSet 部署 Waypoint Proxy 作为 L7 代理，而在 L4 使用 ztunnel。",{"type":185,"tag":259,"props":645,"children":647},{"id":646},"不可变基础设施的核心思想是",[648],{"type":191,"value":649},"不可变基础设施的核心思想是？",{"type":185,"tag":266,"props":651,"children":652},{},[653],{"type":191,"value":654},"不可变基础设施的核心思想是基础设施的示例一旦创建就变成只读状态，如果需要修改或省级，应先修改配置模板，在根据模板创建新示例并替换旧实例。",{"type":185,"tag":259,"props":656,"children":658},{"id":657},"不可变基础设施能解决什么问题",[659],{"type":191,"value":660},"不可变基础设施能解决什么问题？",{"type":185,"tag":266,"props":662,"children":663},{},[664],{"type":191,"value":665},"以解决传统运维时代需要大量手工操作带来的构建难以自动化，以及环境变量改变等问题。其最大的优势是“一致性”，使基础设施管理简单、可部署、可规模化、可恢复，也提高了安全性。",{"type":185,"tag":186,"props":667,"children":669},{"id":668},"domain",[670],{"type":191,"value":671},"Domain",{"type":185,"tag":194,"props":673,"children":674},{},[675,684],{"type":185,"tag":198,"props":676,"children":677},{},[678],{"type":185,"tag":202,"props":679,"children":681},{"href":680},"/maps/_cloud-native/sidecar/sidecar",[682],{"type":191,"value":683},"Sidecar",{"type":185,"tag":198,"props":685,"children":686},{},[687],{"type":185,"tag":202,"props":688,"children":690},{"href":689},"/maps/_cloud-native/hardware/arm-on-cloud-native",[691],{"type":191,"value":692},"Arm on Cloud Native",{"title":178,"searchDepth":694,"depth":694,"links":695},2,[696,697,698,699,703],{"id":188,"depth":694,"text":192},{"id":212,"depth":694,"text":215},{"id":180,"depth":694,"text":180},{"id":248,"depth":694,"text":251,"children":700},[701],{"id":255,"depth":702,"text":255},3,{"id":668,"depth":694,"text":671},"markdown","content:6.maps:_cloud-native:cloud-native.md","content","6.maps/_cloud-native/cloud-native.md","6.maps/_cloud-native/cloud-native","md",[711,715],{"_path":712,"title":713,"description":714},"/maps/_cli/ffmpeg","ffmpeg & imagemagick","最常使用的视频和图片处理工具。",{"_path":689,"title":716,"description":717},"Arm 云计算实例 — 建议默认采用","将 Arm 视为云端计算实例的默认选择，除非存在明确的 x86 架构依赖。",1771304513831]