，是一个基于容器的集群管理平台，主要用于控制容器",{"type":182,"children":183,"toc":339},"root",[184,192,217,223,228,233,251,268,273,301,306,311],{"type":185,"tag":186,"props":187,"children":188},"element","p",{},[189],{"type":190,"value":191},"text","Kubernetes，K8s，是一个基于容器的集群管理平台，主要用于控制容器",{"type":185,"tag":193,"props":194,"children":195},"ul",{},[196,202,207,212],{"type":185,"tag":197,"props":198,"children":199},"li",{},[200],{"type":190,"value":201},"可集群：容器的移动或删除，服务对外暴露的静态 IP 不变",{"type":185,"tag":197,"props":203,"children":204},{},[205],{"type":190,"value":206},"扩缩容：根据资源负载，自动调整容器副本数",{"type":185,"tag":197,"props":208,"children":209},{},[210],{"type":190,"value":211},"自修复：自动重启容器，或选择新的工作节点",{"type":185,"tag":197,"props":213,"children":214},{},[215],{"type":190,"value":216},"零或限制：通过亲缘性控制容器运行在指定机器",{"type":185,"tag":218,"props":219,"children":221},"h2",{"id":220},"整体架构",[222],{"type":190,"value":220},{"type":185,"tag":186,"props":224,"children":225},{},[226],{"type":190,"value":227},"一个 K8s 系统，常常包括一个 Master 节点，用于管理和控制多个 Node 计算节点。",{"type":185,"tag":186,"props":229,"children":230},{},[231],{"type":190,"value":232},"Master 节点大体包括：",{"type":185,"tag":193,"props":234,"children":235},{},[236,241,246],{"type":185,"tag":197,"props":237,"children":238},{},[239],{"type":190,"value":240},"API Server：系统对外接口，比如用于处理外部的命令行交互",{"type":185,"tag":197,"props":242,"children":243},{},[244],{"type":190,"value":245},"Scheduler：调度器，用于分配 Pod",{"type":185,"tag":197,"props":247,"children":248},{},[249],{"type":190,"value":250},"Controller Manager：控制器，跟踪节点状态，复制 Pod",{"type":185,"tag":193,"props":252,"children":253},{},[254],{"type":185,"tag":197,"props":255,"children":256},{},[257,266],{"type":185,"tag":258,"props":259,"children":263},"a",{"href":260,"rel":261},"https://zhuanlan.zhihu.com/p/96428375",[262],"nofollow",[264],{"type":190,"value":265},"ETCD",{"type":190,"value":267},"：分布式数据存储，存集群配置文件；可用于服务发现（保证一个集群中的不同进程可以互相找到并建立链接），并通过 Raft 协议使各个节点的状态保持一致。",{"type":185,"tag":186,"props":269,"children":270},{},[271],{"type":190,"value":272},"Node 节点由许多的 Pod 组成，每一个 Pod 都是集群中的一个进程。Node 通过以下几个组件管理 Pod：",{"type":185,"tag":193,"props":274,"children":275},{},[276,281,286,291,296],{"type":185,"tag":197,"props":277,"children":278},{},[279],{"type":190,"value":280},"Docker：容器运行时，用于拉取、创建、启动镜像",{"type":185,"tag":197,"props":282,"children":283},{},[284],{"type":190,"value":285},"Kubelet：用于中转 API Server 和 Docker 的交互行为，以进行 Pod 的创建、删除、修改、监控",{"type":185,"tag":197,"props":287,"children":288},{},[289],{"type":190,"value":290},"Kube-proxy：用于 Pod 的代理（？）",{"type":185,"tag":197,"props":292,"children":293},{},[294],{"type":190,"value":295},"Fluentd：用于日志收集、储存和查询",{"type":185,"tag":197,"props":297,"children":298},{},[299],{"type":190,"value":300},"Service：一组相同功能的 Pod 可以通过 Service 提供对外的接口",{"type":185,"tag":186,"props":302,"children":303},{},[304],{"type":190,"value":305},"Pod 写入磁盘的数据可能随时会丢失，它自身也随时可能被重启，如内存耗尽，进程崩溃，或存活指针返回失败。Pod 重启的时间以指数时间避退，直到满 5 分钟。",{"type":185,"tag":218,"props":307,"children":309},{"id":308},"常用子指令",[310],{"type":190,"value":308},{"type":185,"tag":193,"props":312,"children":313},{},[314,319,324,329,334],{"type":185,"tag":197,"props":315,"children":316},{},[317],{"type":190,"value":318},"Apply：从配置文件更新对象，如 kubectl apply -f x.yaml；",{"type":185,"tag":197,"props":320,"children":321},{},[322],{"type":190,"value":323},"Delete：删除对象，如 kubectl delete deploy x；",{"type":185,"tag":197,"props":325,"children":326},{},[327],{"type":190,"value":328},"Describe：获取对象信息，如 kubectl describe pod x；",{"type":185,"tag":197,"props":330,"children":331},{},[332],{"type":190,"value":333},"Exec：执行容器的指令，如 kubectl exec -it pod x bash；",{"type":185,"tag":197,"props":335,"children":336},{},[337],{"type":190,"value":338},"Get：获取对象状态，如 kubectl get pods（获取所有 pods 状态）、kubectl get svc（获取所有服务及其状态，如端口和所在集群 IP）；",{"title":178,"searchDepth":340,"depth":340,"links":341},2,[342,343],{"id":220,"depth":340,"text":220},{"id":308,"depth":340,"text":308},"markdown","content:6.maps:_cloud-native:kubernetes.md","content","6.maps/_cloud-native/kubernetes.md","6.maps/_cloud-native/kubernetes","md",[351,355],{"_path":352,"title":353,"description":354},"/maps/_cloud-native/hardware/arm-on-cloud-native","Arm 云计算实例 — 建议默认采用","将 Arm 视为云端计算实例的默认选择，除非存在明确的 x86 架构依赖。",{"_path":356,"title":357,"description":358},"/maps/_cloud-native/serverless","Serverless","无服务器计算，是一种云计算架构模式，其中云提供商负责执行代码，并动态分配计算资源",1771695803835]