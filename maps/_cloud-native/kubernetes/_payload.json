toc":336},"root",[181,189,214,220,225,230,248,265,270,298,303,308],{"type":182,"tag":183,"props":184,"children":185},"element","p",{},[186],{"type":187,"value":188},"text","Kubernetes，K8s，是一个基于容器的集群管理平台，主要用于控制容器",{"type":182,"tag":190,"props":191,"children":192},"ul",{},[193,199,204,209],{"type":182,"tag":194,"props":195,"children":196},"li",{},[197],{"type":187,"value":198},"可集群：容器的移动或删除，服务对外暴露的静态 IP 不变",{"type":182,"tag":194,"props":200,"children":201},{},[202],{"type":187,"value":203},"扩缩容：根据资源负载，自动调整容器副本数",{"type":182,"tag":194,"props":205,"children":206},{},[207],{"type":187,"value":208},"自修复：自动重启容器，或选择新的工作节点",{"type":182,"tag":194,"props":210,"children":211},{},[212],{"type":187,"value":213},"零或限制：通过亲缘性控制容器运行在指定机器",{"type":182,"tag":215,"props":216,"children":218},"h2",{"id":217},"整体架构",[219],{"type":187,"value":217},{"type":182,"tag":183,"props":221,"children":222},{},[223],{"type":187,"value":224},"一个 K8s 系统，常常包括一个 Master 节点，用于管理和控制多个 Node 计算节点。",{"type":182,"tag":183,"props":226,"children":227},{},[228],{"type":187,"value":229},"Master 节点大体包括：",{"type":182,"tag":190,"props":231,"children":232},{},[233,238,243],{"type":182,"tag":194,"props":234,"children":235},{},[236],{"type":187,"value":237},"API Server：系统对外接口，比如用于处理外部的命令行交互",{"type":182,"tag":194,"props":239,"children":240},{},[241],{"type":187,"value":242},"Scheduler：调度器，用于分配 Pod",{"type":182,"tag":194,"props":244,"children":245},{},[246],{"type":187,"value":247},"Controller Manager：控制器，跟踪节点状态，复制 Pod",{"type":182,"tag":190,"props":249,"children":250},{},[251],{"type":182,"tag":194,"props":252,"children":253},{},[254,263],{"type":182,"tag":255,"props":256,"children":260},"a",{"href":257,"rel":258},"https://zhuanlan.zhihu.com/p/96428375",[259],"nofollow",[261],{"type":187,"value":262},"ETCD",{"type":187,"value":264},"：分布式数据存储，存集群配置文件；可用于服务发现（保证一个集群中的不同进程可以互相找到并建立链接），并通过 Raft 协议使各个节点的状态保持一致。",{"type":182,"tag":183,"props":266,"children":267},{},[268],{"type":187,"value":269},"Node 节点由许多的 Pod 组成，每一个 Pod 都是集群中的一个进程。Node 通过以下几个组件管理 Pod：",{"type":182,"tag":190,"props":271,"children":272},{},[273,278,283,288,293],{"type":182,"tag":194,"props":274,"children":275},{},[276],{"type":187,"value":277},"Docker：容器运行时，用于拉取、创建、启动镜像",{"type":182,"tag":194,"props":279,"children":280},{},[281],{"type":187,"value":282},"Kubelet：用于中转 API Server 和 Docker 的交互行为，以进行 Pod 的创建、删除、修改、监控",{"type":182,"tag":194,"props":284,"children":285},{},[286],{"type":187,"value":287},"Kube-proxy：用于 Pod 的代理（？）",{"type":182,"tag":194,"props":289,"children":290},{},[291],{"type":187,"value":292},"Fluentd：用于日志收集、储存和查询",{"type":182,"tag":194,"props":294,"children":295},{},[296],{"type":187,"value":297},"Service：一组相同功能的 Pod 可以通过 Service 提供对外的接口",{"type":182,"tag":183,"props":299,"children":300},{},[301],{"type":187,"value":302},"Pod 写入磁盘的数据可能随时会丢失，它自身也随时可能被重启，如内存耗尽，进程崩溃，或存活指针返回失败。Pod 重启的时间以指数时间避退，直到满 5 分钟。",{"type":182,"tag":215,"props":304,"children":306},{"id":305},"常用子指令",[307],{"type":187,"value":305},{"type":182,"tag":190,"props":309,"children":310},{},[311,316,321,326,331],{"type":182,"tag":194,"props":312,"children":313},{},[314],{"type":187,"value":315},"Apply：从配置文件更新对象，如 kubectl apply -f x.yaml；",{"type":182,"tag":194,"props":317,"children":318},{},[319],{"type":187,"value":320},"Delete：删除对象，如 kubectl delete deploy x；",{"type":182,"tag":194,"props":322,"children":323},{},[324],{"type":187,"value":325},"Describe：获取对象信息，如 kubectl describe pod x；",{"type":182,"tag":194,"props":327,"children":328},{},[329],{"type":187,"value":330},"Exec：执行容器的指令，如 kubectl exec -it pod x bash；",{"type":182,"tag":194,"props":332,"children":333},{},[334],{"type":187,"value":335},"Get：获取对象状态，如 kubectl get pods（获取所有 pods 状态）、kubectl get svc（获取所有服务及其状态，如端口和所在集群 IP）；",{"title":175,"searchDepth":337,"depth":337,"links":338},2,[339,340],{"id":217,"depth":337,"text":217},{"id":305,"depth":337,"text":305},"markdown","content:6.maps:_cloud-native:kubernetes.md","content","6.maps/_cloud-native/kubernetes.md","6.maps/_cloud-native/kubernetes","md",[348,352],{"_path":349,"title":350,"description":351},"/maps/_cloud-native/hardware/arm-on-cloud-native","Arm 云计算实例 — 建议默认采用","将 Arm 视为云端计算实例的默认选择，除非存在明确的 x86 架构依赖。",{"_path":353,"title":354,"description":355},"/maps/_cloud-native/serverless","Serverless","无服务器计算，是一种云计算架构模式，其中云提供商负责执行代码，并动态分配计算资源",1771071680428]