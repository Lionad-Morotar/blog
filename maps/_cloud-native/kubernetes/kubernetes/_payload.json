etes","kubernetes",false,true,"","Kubernetes","K8s，是一个基于容器的集群管理平台，主要用于控制容器","content/6.maps/_cloud-native/kubernetes.md",{"type":183,"children":184,"toc":340},"root",[185,193,218,224,229,234,252,269,274,302,307,312],{"type":186,"tag":187,"props":188,"children":189},"element","p",{},[190],{"type":191,"value":192},"text","Kubernetes，K8s，是一个基于容器的集群管理平台，主要用于控制容器",{"type":186,"tag":194,"props":195,"children":196},"ul",{},[197,203,208,213],{"type":186,"tag":198,"props":199,"children":200},"li",{},[201],{"type":191,"value":202},"可集群：容器的移动或删除，服务对外暴露的静态 IP 不变",{"type":186,"tag":198,"props":204,"children":205},{},[206],{"type":191,"value":207},"扩缩容：根据资源负载，自动调整容器副本数",{"type":186,"tag":198,"props":209,"children":210},{},[211],{"type":191,"value":212},"自修复：自动重启容器，或选择新的工作节点",{"type":186,"tag":198,"props":214,"children":215},{},[216],{"type":191,"value":217},"零或限制：通过亲缘性控制容器运行在指定机器",{"type":186,"tag":219,"props":220,"children":222},"h2",{"id":221},"整体架构",[223],{"type":191,"value":221},{"type":186,"tag":187,"props":225,"children":226},{},[227],{"type":191,"value":228},"一个 K8s 系统，常常包括一个 Master 节点，用于管理和控制多个 Node 计算节点。",{"type":186,"tag":187,"props":230,"children":231},{},[232],{"type":191,"value":233},"Master 节点大体包括：",{"type":186,"tag":194,"props":235,"children":236},{},[237,242,247],{"type":186,"tag":198,"props":238,"children":239},{},[240],{"type":191,"value":241},"API Server：系统对外接口，比如用于处理外部的命令行交互",{"type":186,"tag":198,"props":243,"children":244},{},[245],{"type":191,"value":246},"Scheduler：调度器，用于分配 Pod",{"type":186,"tag":198,"props":248,"children":249},{},[250],{"type":191,"value":251},"Controller Manager：控制器，跟踪节点状态，复制 Pod",{"type":186,"tag":194,"props":253,"children":254},{},[255],{"type":186,"tag":198,"props":256,"children":257},{},[258,267],{"type":186,"tag":259,"props":260,"children":264},"a",{"href":261,"rel":262},"https://zhuanlan.zhihu.com/p/96428375",[263],"nofollow",[265],{"type":191,"value":266},"ETCD",{"type":191,"value":268},"：分布式数据存储，存集群配置文件；可用于服务发现（保证一个集群中的不同进程可以互相找到并建立链接），并通过 Raft 协议使各个节点的状态保持一致。",{"type":186,"tag":187,"props":270,"children":271},{},[272],{"type":191,"value":273},"Node 节点由许多的 Pod 组成，每一个 Pod 都是集群中的一个进程。Node 通过以下几个组件管理 Pod：",{"type":186,"tag":194,"props":275,"children":276},{},[277,282,287,292,297],{"type":186,"tag":198,"props":278,"children":279},{},[280],{"type":191,"value":281},"Docker：容器运行时，用于拉取、创建、启动镜像",{"type":186,"tag":198,"props":283,"children":284},{},[285],{"type":191,"value":286},"Kubelet：用于中转 API Server 和 Docker 的交互行为，以进行 Pod 的创建、删除、修改、监控",{"type":186,"tag":198,"props":288,"children":289},{},[290],{"type":191,"value":291},"Kube-proxy：用于 Pod 的代理（？）",{"type":186,"tag":198,"props":293,"children":294},{},[295],{"type":191,"value":296},"Fluentd：用于日志收集、储存和查询",{"type":186,"tag":198,"props":298,"children":299},{},[300],{"type":191,"value":301},"Service：一组相同功能的 Pod 可以通过 Service 提供对外的接口",{"type":186,"tag":187,"props":303,"children":304},{},[305],{"type":191,"value":306},"Pod 写入磁盘的数据可能随时会丢失，它自身也随时可能被重启，如内存耗尽，进程崩溃，或存活指针返回失败。Pod 重启的时间以指数时间避退，直到满 5 分钟。",{"type":186,"tag":219,"props":308,"children":310},{"id":309},"常用子指令",[311],{"type":191,"value":309},{"type":186,"tag":194,"props":313,"children":314},{},[315,320,325,330,335],{"type":186,"tag":198,"props":316,"children":317},{},[318],{"type":191,"value":319},"Apply：从配置文件更新对象，如 kubectl apply -f x.yaml；",{"type":186,"tag":198,"props":321,"children":322},{},[323],{"type":191,"value":324},"Delete：删除对象，如 kubectl delete deploy x；",{"type":186,"tag":198,"props":326,"children":327},{},[328],{"type":191,"value":329},"Describe：获取对象信息，如 kubectl describe pod x；",{"type":186,"tag":198,"props":331,"children":332},{},[333],{"type":191,"value":334},"Exec：执行容器的指令，如 kubectl exec -it pod x bash；",{"type":186,"tag":198,"props":336,"children":337},{},[338],{"type":191,"value":339},"Get：获取对象状态，如 kubectl get pods（获取所有 pods 状态）、kubectl get svc（获取所有服务及其状态，如端口和所在集群 IP）；",{"title":178,"searchDepth":341,"depth":341,"links":342},2,[343,344],{"id":221,"depth":341,"text":221},{"id":309,"depth":341,"text":309},"markdown","content:6.maps:_cloud-native:kubernetes:kubernetes.md","content","6.maps/_cloud-native/kubernetes/kubernetes.md","6.maps/_cloud-native/kubernetes/kubernetes","md",[352,356],{"_path":353,"title":354,"description":355},"/maps/_cloud-native/hardware/hardware","云原生硬件","云原生环境下的硬件架构选择，包括 Arm 架构应用",{"_path":357,"title":358,"description":359},"/maps/_cloud-native/serverless/serverless","Serverless","无服务器计算，是一种云计算架构模式，其中云提供商负责执行代码，并动态分配计算资源",1772185480619]