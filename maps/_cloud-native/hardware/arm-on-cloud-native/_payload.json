 | 抗锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133,"children":134},"造物 / Make","/tools",[135,137,140,143,146,149,152],{"title":136,"_path":133},"🧰 工具收集",{"title":138,"_path":139},"📕 博客","/tools/blog",{"title":141,"_path":142},"🥥 Coconut","/tools/coconut",{"title":144,"_path":145},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":147,"_path":148},"🌐 AnySort","/tools/anysort",{"title":150,"_path":151},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":153,"_path":154},"👓 Crapto","/tools/crypto-inline",{"title":156,"_path":157,"children":158},"我 / About","/hire",[159],{"title":160,"_path":157},"📬 技术简历",{"title":162,"_path":163,"children":164},"En","/en",[165],{"title":166,"_path":167,"children":168},"🦁 Welcome","/en/articles",[169],{"title":166,"_path":167},{"_path":171,"_dir":172,"_draft":173,"_partial":174,"_locale":175,"title":176,"description":177,"body":178,"_type":798,"_id":799,"_source":800,"_file":801,"_stem":802,"_extension":803},"/maps/_cloud-native/hardware/arm-on-cloud-native","hardware",false,true,"","Arm 云计算实例 — 建议默认采用","将 Arm 视为云端计算实例的默认选择，除非存在明确的 x86 架构依赖。",{"type":179,"children":180,"toc":787},"root",[181,190,196,201,207,214,239,244,257,263,269,274,292,297,310,316,321,356,361,374,380,386,404,410,415,433,438,451,457,462,467,485,490,503,508,513,531,537,542,547,565,570,578,583,588,601,606,619,625,630,635,653,658,671,676,681,694,707,719,732,744,757,769,782],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"brief",[187],{"type":188,"value":189},"text","Brief",{"type":182,"tag":191,"props":192,"children":193},"p",{},[194],{"type":188,"value":195},"在主流公有云（AWS、Azure、GCP）中，Arm 架构计算实例因相较传统 x86 实例更具成本和能效优势，已经成为许多场景下的优先选项。我们的多支团队已经在微服务、开源数据库乃至部分高性能计算场景中成功迁移到 Arm，只需少量代码调整和轻微构建脚本修改。新的云上应用和系统也越来越多地直接以 Arm 为默认目标。基于这些经验，我们建议：在不存在特定架构依赖的前提下，大多数工作负载应优先采用 Arm 计算实例。现代工具链（如多架构 Docker 镜像）也进一步简化了在 Arm 与 x86 环境之间的构建与部署。",{"type":182,"tag":191,"props":197,"children":198},{},[199],{"type":188,"value":200},"来源：技术雷达",{"type":182,"tag":183,"props":202,"children":204},{"id":203},"details",[205],{"type":188,"value":206},"Details",{"type":182,"tag":208,"props":209,"children":211},"h3",{"id":210},"背景与现状arm-已从尝试选项变成默认选项候选",[212],{"type":188,"value":213},"背景与现状：Arm 已从“尝试选项”变成“默认选项候选”",{"type":182,"tag":215,"props":216,"children":217},"ul",{},[218,224,229,234],{"type":182,"tag":219,"props":220,"children":221},"li",{},[222],{"type":188,"value":223},"主流云厂商（AWS、Azure、GCP）都已经提供成熟的 Arm 实例家族，并持续迭代。",{"type":182,"tag":219,"props":225,"children":226},{},[227],{"type":188,"value":228},"Arm 在能耗和性价比上的优势，使其对大规模、成本敏感型工作负载尤为有吸引力。",{"type":182,"tag":219,"props":230,"children":231},{},[232],{"type":188,"value":233},"文本给出的组织内部经验表明：微服务、开源数据库、高性能计算等多类负载已经在 Arm 上稳定运行。",{"type":182,"tag":219,"props":235,"children":236},{},[237],{"type":188,"value":238},"趋势上，新建云上系统开始“默认跑在 Arm 上”，x86 更像是在有特殊依赖时的例外选择。",{"type":182,"tag":191,"props":240,"children":241},{},[242],{"type":188,"value":243},"对架构与技术负责人而言，这意味着：",{"type":182,"tag":215,"props":245,"children":246},{},[247,252],{"type":182,"tag":219,"props":248,"children":249},{},[250],{"type":188,"value":251},"“选 Arm 还是 x86”不再只是底层 Infra 选择，而会反过来影响技术栈、依赖库与第三方组件的选择。",{"type":182,"tag":219,"props":253,"children":254},{},[255],{"type":188,"value":256},"在技术决策模板中，应增加“是否具备 Arm 兼容性”这一项，而不是事后再补。",{"type":182,"tag":208,"props":258,"children":260},{"id":259},"核心模式与技术要点多架构构建与轻量迁移",[261],{"type":188,"value":262},"核心模式与技术要点：多架构构建与轻量迁移",{"type":182,"tag":264,"props":265,"children":267},"h4",{"id":266},"典型工作负载类型",[268],{"type":188,"value":266},{"type":182,"tag":191,"props":270,"children":271},{},[272],{"type":188,"value":273},"基于文中描述和常见实践，Arm 适配良好的类型通常包括：",{"type":182,"tag":215,"props":275,"children":276},{},[277,282,287],{"type":182,"tag":219,"props":278,"children":279},{},[280],{"type":188,"value":281},"容器化微服务：尤其是以 Go/Java/Rust/Node/Python 等为主的 stateless 服务。",{"type":182,"tag":219,"props":283,"children":284},{},[285],{"type":188,"value":286},"开源数据库与中间件：如常见的关系型数据库、KV/缓存系统，只要官方或社区已提供 arm64 支持。",{"type":182,"tag":219,"props":288,"children":289},{},[290],{"type":188,"value":291},"批量计算与部分 HPC 工作负载：在编译链支持 Arm 的前提下，往往可以复用绝大部分代码。",{"type":182,"tag":191,"props":293,"children":294},{},[295],{"type":188,"value":296},"这些场景的共同特征是：",{"type":182,"tag":215,"props":298,"children":299},{},[300,305],{"type":182,"tag":219,"props":301,"children":302},{},[303],{"type":188,"value":304},"源码可控，或至少可获取源码进行重编译。",{"type":182,"tag":219,"props":306,"children":307},{},[308],{"type":188,"value":309},"构建与发布已经容器化或自动化，能把“增加一个 arm64 目标”变成流水线配置问题，而不是人工手工活。",{"type":182,"tag":264,"props":311,"children":313},{"id":312},"多架构-docker-镜像与工具链",[314],{"type":188,"value":315},"多架构 Docker 镜像与工具链",{"type":182,"tag":191,"props":317,"children":318},{},[319],{"type":188,"value":320},"文中明确提到“多架构 Docker 镜像”作为关键支撑手段，隐含的模式包括：",{"type":182,"tag":215,"props":322,"children":323},{},[324,346,351],{"type":182,"tag":219,"props":325,"children":326},{},[327,329,336,338,344],{"type":188,"value":328},"构建阶段同时产出 ",{"type":182,"tag":330,"props":331,"children":333},"code",{"className":332},[],[334],{"type":188,"value":335},"linux/amd64",{"type":188,"value":337}," 与 ",{"type":182,"tag":330,"props":339,"children":341},{"className":340},[],[342],{"type":188,"value":343},"linux/arm64",{"type":188,"value":345}," 两种镜像，并推送到同一镜像仓库。",{"type":182,"tag":219,"props":347,"children":348},{},[349],{"type":188,"value":350},"通过 manifest list 让运行时根据节点架构自动拉取对应镜像，减少上层系统感知架构差异的需求。",{"type":182,"tag":219,"props":352,"children":353},{},[354],{"type":188,"value":355},"在 CI/CD 侧通过 matrix / buildx / QEMU 等方式，统一维护一套构建脚本，对两种架构同时生效。",{"type":182,"tag":191,"props":357,"children":358},{},[359],{"type":188,"value":360},"对团队的启示：",{"type":182,"tag":215,"props":362,"children":363},{},[364,369],{"type":182,"tag":219,"props":365,"children":366},{},[367],{"type":188,"value":368},"只要构建链路已经工程化，增加 Arm 支持更多是“一次性工程投入 + 持续的自动化校验”，而不是长期的人力负担。",{"type":182,"tag":219,"props":370,"children":371},{},[372],{"type":188,"value":373},"与其在项目后期临时“为了省成本”改 Arm，不如在项目早期就把 Arm 纳入 pipeline，以避免后期技术债集中爆发。",{"type":182,"tag":208,"props":375,"children":377},{"id":376},"旧做法-vs-新模式从架构特定到架构无关",[378],{"type":188,"value":379},"旧做法 vs 新模式：从“架构特定”到“架构无关”",{"type":182,"tag":264,"props":381,"children":383},{"id":382},"传统模式x86-作为默认且唯一的假设",[384],{"type":188,"value":385},"传统模式：x86 作为“默认且唯一”的假设",{"type":182,"tag":215,"props":387,"children":388},{},[389,394,399],{"type":182,"tag":219,"props":390,"children":391},{},[392],{"type":188,"value":393},"许多老系统在设计和依赖引入时，都默认运行在 x86 服务器上。",{"type":182,"tag":219,"props":395,"children":396},{},[397],{"type":188,"value":398},"依赖中可能夹杂：只提供 x86 二进制的第三方组件、脚本中写死的 CPU 架构判断、针对特定 SIMD 指令集做的优化等。",{"type":182,"tag":219,"props":400,"children":401},{},[402],{"type":188,"value":403},"在这种前提下，任何非 x86 目标（包括 Arm）都要付出额外适配成本，因此很少在规划阶段被真正考虑。",{"type":182,"tag":264,"props":405,"children":407},{"id":406},"新模式主动追求多架构友好",[408],{"type":188,"value":409},"新模式：主动追求“多架构友好”",{"type":182,"tag":191,"props":411,"children":412},{},[413],{"type":188,"value":414},"Arm 普及之后，合理的默认心智模型变为：",{"type":182,"tag":215,"props":416,"children":417},{},[418,423,428],{"type":182,"tag":219,"props":419,"children":420},{},[421],{"type":188,"value":422},"业务代码与核心依赖在设计时，优先选择已支持 arm64 的语言运行时与第三方库。",{"type":182,"tag":219,"props":424,"children":425},{},[426],{"type":188,"value":427},"构建脚本与部署脚本中不再隐含“x86-only”的假设，而是对架构差异进行显式建模（比如通过变量或配置）。",{"type":182,"tag":219,"props":429,"children":430},{},[431],{"type":188,"value":432},"在引入第三方闭源组件时，将“是否支持 arm64”作为评估指标之一。",{"type":182,"tag":191,"props":434,"children":435},{},[436],{"type":188,"value":437},"这种模式的收益：",{"type":182,"tag":215,"props":439,"children":440},{},[441,446],{"type":182,"tag":219,"props":442,"children":443},{},[444],{"type":188,"value":445},"架构选择变得更加“可插拔”：相同的应用可以根据成本、性能和容量动态在 x86/Arm 之间迁移或混合部署。",{"type":182,"tag":219,"props":447,"children":448},{},[449],{"type":188,"value":450},"云资源采购与弹性伸缩策略更灵活，可基于 Spot、预留实例和不同实例族做更精细的成本优化。",{"type":182,"tag":208,"props":452,"children":454},{"id":453},"风险与局限何时不适合把-arm-当成默认",[455],{"type":188,"value":456},"风险与局限：何时不适合把 Arm 当成默认",{"type":182,"tag":264,"props":458,"children":460},{"id":459},"架构依赖与二进制兼容性",[461],{"type":188,"value":459},{"type":182,"tag":191,"props":463,"children":464},{},[465],{"type":188,"value":466},"文中明确给出边界条件：“除非存在特定架构依赖”：",{"type":182,"tag":215,"props":468,"children":469},{},[470,475,480],{"type":182,"tag":219,"props":471,"children":472},{},[473],{"type":188,"value":474},"闭源的 x86-only 组件或 SDK：如只提供 x86 动态库、驱动或 agent。",{"type":182,"tag":219,"props":476,"children":477},{},[478],{"type":188,"value":479},"强绑定特定 x86 指令集（如 AVX 系列）进行高度手写优化的计算核心，迁移到 Arm 可能需要大量重写与性能再评估。",{"type":182,"tag":219,"props":481,"children":482},{},[483],{"type":188,"value":484},"某些历史遗留系统中的脚本、配置或运维工具链，可能在架构检测/路径/包名上假定 x86。",{"type":182,"tag":191,"props":486,"children":487},{},[488],{"type":188,"value":489},"这类场景中，如果要强推 Arm：",{"type":182,"tag":215,"props":491,"children":492},{},[493,498],{"type":182,"tag":219,"props":494,"children":495},{},[496],{"type":188,"value":497},"短期成本往往集中在“替换组件 + 深层回归验证”，对稳定性要求高的核心系统风险会比较大。",{"type":182,"tag":219,"props":499,"children":500},{},[501],{"type":188,"value":502},"对长期收益的判断要更审慎，避免为了一定比例的成本优化，付出不可控的回归与运维代价。",{"type":182,"tag":264,"props":504,"children":506},{"id":505},"生态与工具支持尚不完善的角落",[507],{"type":188,"value":505},{"type":182,"tag":191,"props":509,"children":510},{},[511],{"type":188,"value":512},"尽管主流语言与工具链已普遍支持 Arm，但在一些边角地带仍需要注意：",{"type":182,"tag":215,"props":514,"children":515},{},[516,521,526],{"type":182,"tag":219,"props":517,"children":518},{},[519],{"type":188,"value":520},"少数原生扩展（Python/Node/Ruby 等）可能缺乏稳定的 arm64 预编译包，导致构建时间增加或偶发编译问题。",{"type":182,"tag":219,"props":522,"children":523},{},[524],{"type":188,"value":525},"某些监控、APM、安全代理、备份工具在 Arm 上的支持成熟度不一，可能引入观测与安全盲区。",{"type":182,"tag":219,"props":527,"children":528},{},[529],{"type":188,"value":530},"内部自研的自动化脚本、运维工具（如用于镜像扫描、合规检查等）若写死架构假设，也会成为迁移阻力。",{"type":182,"tag":208,"props":532,"children":534},{"id":533},"系统性影响对架构治理与工程体系的要求",[535],{"type":188,"value":536},"系统性影响：对架构治理与工程体系的要求",{"type":182,"tag":264,"props":538,"children":540},{"id":539},"对架构一致性与环境抽象的推动",[541],{"type":188,"value":539},{"type":182,"tag":191,"props":543,"children":544},{},[545],{"type":188,"value":546},"当组织开始大规模使用 Arm：",{"type":182,"tag":215,"props":548,"children":549},{},[550,555,560],{"type":182,"tag":219,"props":551,"children":552},{},[553],{"type":188,"value":554},"会倒逼团队更好地抽象“运行环境”，避免在业务逻辑层出现硬编码的架构假设。",{"type":182,"tag":219,"props":556,"children":557},{},[558],{"type":188,"value":559},"容器镜像、基础镜像与中间件镜像需要统一管理多架构版本，促进基础设施层做标准化。",{"type":182,"tag":219,"props":561,"children":562},{},[563],{"type":188,"value":564},"对“环境即代码”（Infra as Code）、自动化测试矩阵、多环境回归提出更高要求。",{"type":182,"tag":191,"props":566,"children":567},{},[568],{"type":188,"value":569},"长期看，这有助于：",{"type":182,"tag":215,"props":571,"children":572},{},[573],{"type":182,"tag":219,"props":574,"children":575},{},[576],{"type":188,"value":577},"减少“环境绑定型技术债”，让系统更容易迁移到不同形态的算力资源（例如进一步延伸到边缘计算）。",{"type":182,"tag":264,"props":579,"children":581},{"id":580},"对工程效率与成本治理的拉动",[582],{"type":188,"value":580},{"type":182,"tag":191,"props":584,"children":585},{},[586],{"type":188,"value":587},"Arm 的成本与能效优势，会直接影响：",{"type":182,"tag":215,"props":589,"children":590},{},[591,596],{"type":182,"tag":219,"props":592,"children":593},{},[594],{"type":188,"value":595},"预算敏感场景（如批处理任务、在线微服务大规模集群）更有动力向 Arm 收敛。",{"type":182,"tag":219,"props":597,"children":598},{},[599],{"type":188,"value":600},"团队会更频繁地评估“运行在哪类机器上最划算”，而不是仅仅盯着“每个 Pod 的资源 Requests/Limit”。",{"type":182,"tag":191,"props":602,"children":603},{},[604],{"type":188,"value":605},"前提是：",{"type":182,"tag":215,"props":607,"children":608},{},[609,614],{"type":182,"tag":219,"props":610,"children":611},{},[612],{"type":188,"value":613},"指标体系和观测要能清晰分解“架构差异”对性能和成本的影响。",{"type":182,"tag":219,"props":615,"children":616},{},[617],{"type":188,"value":618},"平台团队需要提供统一的实例选择策略与模板，而不是让每个服务各自为战。",{"type":182,"tag":208,"props":620,"children":622},{"id":621},"落地建议如何在团队内推进arm-优先策略",[623],{"type":188,"value":624},"落地建议：如何在团队内推进“Arm 优先策略”",{"type":182,"tag":264,"props":626,"children":628},{"id":627},"适用场景与前置条件",[629],{"type":188,"value":627},{"type":182,"tag":191,"props":631,"children":632},{},[633],{"type":188,"value":634},"更适合优先尝试 Arm 的情形：",{"type":182,"tag":215,"props":636,"children":637},{},[638,643,648],{"type":182,"tag":219,"props":639,"children":640},{},[641],{"type":188,"value":642},"新建服务、对外部二进制依赖较少，或完全基于主流开源栈。",{"type":182,"tag":219,"props":644,"children":645},{},[646],{"type":188,"value":647},"已经具备成熟的 CI/CD，构建和部署流程标准化，增加一个架构目标代价可控。",{"type":182,"tag":219,"props":649,"children":650},{},[651],{"type":188,"value":652},"有统一的容器基础镜像和中间件组件仓库，便于集中治理多架构镜像。",{"type":182,"tag":191,"props":654,"children":655},{},[656],{"type":188,"value":657},"不建议贸然切入的情形：",{"type":182,"tag":215,"props":659,"children":660},{},[661,666],{"type":182,"tag":219,"props":662,"children":663},{},[664],{"type":188,"value":665},"核心生产系统依赖大量闭源 x86 组件，且当前对运行时稳定性要求极高。",{"type":182,"tag":219,"props":667,"children":668},{},[669],{"type":188,"value":670},"团队缺乏自动化回归、性能基准测试与灰度发布能力，难以分阶段评估迁移影响。",{"type":182,"tag":264,"props":672,"children":674},{"id":673},"推进路径与控制风险的方式",[675],{"type":188,"value":673},{"type":182,"tag":191,"props":677,"children":678},{},[679],{"type":188,"value":680},"一个相对稳健的推进路径可以是：",{"type":182,"tag":682,"props":683,"children":684},"ol",{},[685],{"type":182,"tag":219,"props":686,"children":687},{},[688],{"type":182,"tag":689,"props":690,"children":691},"strong",{},[692],{"type":188,"value":693},"从新项目与边缘服务开始",{"type":182,"tag":215,"props":695,"children":696},{},[697,702],{"type":182,"tag":219,"props":698,"children":699},{},[700],{"type":188,"value":701},"新的云上应用默认在 Arm 上规划和验证，构建链路一开始就支持多架构。",{"type":182,"tag":219,"props":703,"children":704},{},[705],{"type":188,"value":706},"对现有系统，从非核心、流量较小的服务先做试点，建立经验与模板。",{"type":182,"tag":682,"props":708,"children":710},{"start":709},2,[711],{"type":182,"tag":219,"props":712,"children":713},{},[714],{"type":182,"tag":689,"props":715,"children":716},{},[717],{"type":188,"value":718},"平台层先把基础设施“铺平”",{"type":182,"tag":215,"props":720,"children":721},{},[722,727],{"type":182,"tag":219,"props":723,"children":724},{},[725],{"type":188,"value":726},"建立统一的多架构基础镜像和中间件镜像仓库。",{"type":182,"tag":219,"props":728,"children":729},{},[730],{"type":188,"value":731},"在 CI/CD 中增加 arm64 构建与测试矩阵，并对关键语言栈做一次性适配。",{"type":182,"tag":682,"props":733,"children":735},{"start":734},3,[736],{"type":182,"tag":219,"props":737,"children":738},{},[739],{"type":182,"tag":689,"props":740,"children":741},{},[742],{"type":188,"value":743},"引入观测与基准测试",{"type":182,"tag":215,"props":745,"children":746},{},[747,752],{"type":182,"tag":219,"props":748,"children":749},{},[750],{"type":188,"value":751},"为迁移到 Arm 的服务设计明确的性能基线和回归指标（P99 延迟、吞吐、CPU 利用率、成本等）。",{"type":182,"tag":219,"props":753,"children":754},{},[755],{"type":188,"value":756},"在灰度阶段维持 x86 与 Arm 双跑，通过对比观察性能与稳定性差异。",{"type":182,"tag":682,"props":758,"children":760},{"start":759},4,[761],{"type":182,"tag":219,"props":762,"children":763},{},[764],{"type":182,"tag":689,"props":765,"children":766},{},[767],{"type":188,"value":768},"控制范围与节奏",{"type":182,"tag":215,"props":770,"children":771},{},[772,777],{"type":182,"tag":219,"props":773,"children":774},{},[775],{"type":188,"value":776},"使用灰度环境或分批 rollout，将 Arm 迁移与日常功能发布解耦。",{"type":182,"tag":219,"props":778,"children":779},{},[780],{"type":188,"value":781},"对依赖复杂的系统，先迁移外围组件或只迁移一部分实例比例，保留 x86 作为 fallback。",{"type":182,"tag":191,"props":783,"children":784},{},[785],{"type":188,"value":786},"通过上述路径，可以在不牺牲稳定性的前提下，逐步把 Arm 从“成本优化选项”升级为“默认架构”，并让架构与工程体系自然适应多架构的长期演进。",{"title":175,"searchDepth":709,"depth":709,"links":788},[789,790],{"id":185,"depth":709,"text":189},{"id":203,"depth":709,"text":206,"children":791},[792,793,794,795,796,797],{"id":210,"depth":734,"text":213},{"id":259,"depth":734,"text":262},{"id":376,"depth":734,"text":379},{"id":453,"depth":734,"text":456},{"id":533,"depth":734,"text":536},{"id":621,"depth":734,"text":624},"markdown","content:6.maps:_cloud-native:hardware:arm-on-cloud-native.md","content","6.maps/_cloud-native/hardware/arm-on-cloud-native.md","6.maps/_cloud-native/hardware/arm-on-cloud-native","md",[805,809],{"_path":806,"title":807,"description":808},"/maps/_cloud-native/cloud-native","CloudNative","云原生技术概论",{"_path":810,"title":811,"description":812},"/maps/_cloud-native/kubernetes","Kubernetes","K8s，是一个基于容器的集群管理平台，主要用于控制容器",1771214953911]