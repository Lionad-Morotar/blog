 | 抗锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"body":181,"_type":801,"_id":802,"_source":803,"_file":804,"_stem":805,"_extension":806},"/maps/_cloud-native/hardware/arm-on-cloud-native","hardware",false,true,"","Arm 云计算实例 — 建议默认采用","将 Arm 视为云端计算实例的默认选择，除非存在明确的 x86 架构依赖。",{"type":182,"children":183,"toc":790},"root",[184,193,199,204,210,217,242,247,260,266,272,277,295,300,313,319,324,359,364,377,383,389,407,413,418,436,441,454,460,465,470,488,493,506,511,516,534,540,545,550,568,573,581,586,591,604,609,622,628,633,638,656,661,674,679,684,697,710,722,735,747,760,772,785],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"brief",[190],{"type":191,"value":192},"text","Brief",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"在主流公有云（AWS、Azure、GCP）中，Arm 架构计算实例因相较传统 x86 实例更具成本和能效优势，已经成为许多场景下的优先选项。我们的多支团队已经在微服务、开源数据库乃至部分高性能计算场景中成功迁移到 Arm，只需少量代码调整和轻微构建脚本修改。新的云上应用和系统也越来越多地直接以 Arm 为默认目标。基于这些经验，我们建议：在不存在特定架构依赖的前提下，大多数工作负载应优先采用 Arm 计算实例。现代工具链（如多架构 Docker 镜像）也进一步简化了在 Arm 与 x86 环境之间的构建与部署。",{"type":185,"tag":194,"props":200,"children":201},{},[202],{"type":191,"value":203},"来源：技术雷达",{"type":185,"tag":186,"props":205,"children":207},{"id":206},"details",[208],{"type":191,"value":209},"Details",{"type":185,"tag":211,"props":212,"children":214},"h3",{"id":213},"背景与现状arm-已从尝试选项变成默认选项候选",[215],{"type":191,"value":216},"背景与现状：Arm 已从“尝试选项”变成“默认选项候选”",{"type":185,"tag":218,"props":219,"children":220},"ul",{},[221,227,232,237],{"type":185,"tag":222,"props":223,"children":224},"li",{},[225],{"type":191,"value":226},"主流云厂商（AWS、Azure、GCP）都已经提供成熟的 Arm 实例家族，并持续迭代。",{"type":185,"tag":222,"props":228,"children":229},{},[230],{"type":191,"value":231},"Arm 在能耗和性价比上的优势，使其对大规模、成本敏感型工作负载尤为有吸引力。",{"type":185,"tag":222,"props":233,"children":234},{},[235],{"type":191,"value":236},"文本给出的组织内部经验表明：微服务、开源数据库、高性能计算等多类负载已经在 Arm 上稳定运行。",{"type":185,"tag":222,"props":238,"children":239},{},[240],{"type":191,"value":241},"趋势上，新建云上系统开始“默认跑在 Arm 上”，x86 更像是在有特殊依赖时的例外选择。",{"type":185,"tag":194,"props":243,"children":244},{},[245],{"type":191,"value":246},"对架构与技术负责人而言，这意味着：",{"type":185,"tag":218,"props":248,"children":249},{},[250,255],{"type":185,"tag":222,"props":251,"children":252},{},[253],{"type":191,"value":254},"“选 Arm 还是 x86”不再只是底层 Infra 选择，而会反过来影响技术栈、依赖库与第三方组件的选择。",{"type":185,"tag":222,"props":256,"children":257},{},[258],{"type":191,"value":259},"在技术决策模板中，应增加“是否具备 Arm 兼容性”这一项，而不是事后再补。",{"type":185,"tag":211,"props":261,"children":263},{"id":262},"核心模式与技术要点多架构构建与轻量迁移",[264],{"type":191,"value":265},"核心模式与技术要点：多架构构建与轻量迁移",{"type":185,"tag":267,"props":268,"children":270},"h4",{"id":269},"典型工作负载类型",[271],{"type":191,"value":269},{"type":185,"tag":194,"props":273,"children":274},{},[275],{"type":191,"value":276},"基于文中描述和常见实践，Arm 适配良好的类型通常包括：",{"type":185,"tag":218,"props":278,"children":279},{},[280,285,290],{"type":185,"tag":222,"props":281,"children":282},{},[283],{"type":191,"value":284},"容器化微服务：尤其是以 Go/Java/Rust/Node/Python 等为主的 stateless 服务。",{"type":185,"tag":222,"props":286,"children":287},{},[288],{"type":191,"value":289},"开源数据库与中间件：如常见的关系型数据库、KV/缓存系统，只要官方或社区已提供 arm64 支持。",{"type":185,"tag":222,"props":291,"children":292},{},[293],{"type":191,"value":294},"批量计算与部分 HPC 工作负载：在编译链支持 Arm 的前提下，往往可以复用绝大部分代码。",{"type":185,"tag":194,"props":296,"children":297},{},[298],{"type":191,"value":299},"这些场景的共同特征是：",{"type":185,"tag":218,"props":301,"children":302},{},[303,308],{"type":185,"tag":222,"props":304,"children":305},{},[306],{"type":191,"value":307},"源码可控，或至少可获取源码进行重编译。",{"type":185,"tag":222,"props":309,"children":310},{},[311],{"type":191,"value":312},"构建与发布已经容器化或自动化，能把“增加一个 arm64 目标”变成流水线配置问题，而不是人工手工活。",{"type":185,"tag":267,"props":314,"children":316},{"id":315},"多架构-docker-镜像与工具链",[317],{"type":191,"value":318},"多架构 Docker 镜像与工具链",{"type":185,"tag":194,"props":320,"children":321},{},[322],{"type":191,"value":323},"文中明确提到“多架构 Docker 镜像”作为关键支撑手段，隐含的模式包括：",{"type":185,"tag":218,"props":325,"children":326},{},[327,349,354],{"type":185,"tag":222,"props":328,"children":329},{},[330,332,339,341,347],{"type":191,"value":331},"构建阶段同时产出 ",{"type":185,"tag":333,"props":334,"children":336},"code",{"className":335},[],[337],{"type":191,"value":338},"linux/amd64",{"type":191,"value":340}," 与 ",{"type":185,"tag":333,"props":342,"children":344},{"className":343},[],[345],{"type":191,"value":346},"linux/arm64",{"type":191,"value":348}," 两种镜像，并推送到同一镜像仓库。",{"type":185,"tag":222,"props":350,"children":351},{},[352],{"type":191,"value":353},"通过 manifest list 让运行时根据节点架构自动拉取对应镜像，减少上层系统感知架构差异的需求。",{"type":185,"tag":222,"props":355,"children":356},{},[357],{"type":191,"value":358},"在 CI/CD 侧通过 matrix / buildx / QEMU 等方式，统一维护一套构建脚本，对两种架构同时生效。",{"type":185,"tag":194,"props":360,"children":361},{},[362],{"type":191,"value":363},"对团队的启示：",{"type":185,"tag":218,"props":365,"children":366},{},[367,372],{"type":185,"tag":222,"props":368,"children":369},{},[370],{"type":191,"value":371},"只要构建链路已经工程化，增加 Arm 支持更多是“一次性工程投入 + 持续的自动化校验”，而不是长期的人力负担。",{"type":185,"tag":222,"props":373,"children":374},{},[375],{"type":191,"value":376},"与其在项目后期临时“为了省成本”改 Arm，不如在项目早期就把 Arm 纳入 pipeline，以避免后期技术债集中爆发。",{"type":185,"tag":211,"props":378,"children":380},{"id":379},"旧做法-vs-新模式从架构特定到架构无关",[381],{"type":191,"value":382},"旧做法 vs 新模式：从“架构特定”到“架构无关”",{"type":185,"tag":267,"props":384,"children":386},{"id":385},"传统模式x86-作为默认且唯一的假设",[387],{"type":191,"value":388},"传统模式：x86 作为“默认且唯一”的假设",{"type":185,"tag":218,"props":390,"children":391},{},[392,397,402],{"type":185,"tag":222,"props":393,"children":394},{},[395],{"type":191,"value":396},"许多老系统在设计和依赖引入时，都默认运行在 x86 服务器上。",{"type":185,"tag":222,"props":398,"children":399},{},[400],{"type":191,"value":401},"依赖中可能夹杂：只提供 x86 二进制的第三方组件、脚本中写死的 CPU 架构判断、针对特定 SIMD 指令集做的优化等。",{"type":185,"tag":222,"props":403,"children":404},{},[405],{"type":191,"value":406},"在这种前提下，任何非 x86 目标（包括 Arm）都要付出额外适配成本，因此很少在规划阶段被真正考虑。",{"type":185,"tag":267,"props":408,"children":410},{"id":409},"新模式主动追求多架构友好",[411],{"type":191,"value":412},"新模式：主动追求“多架构友好”",{"type":185,"tag":194,"props":414,"children":415},{},[416],{"type":191,"value":417},"Arm 普及之后，合理的默认心智模型变为：",{"type":185,"tag":218,"props":419,"children":420},{},[421,426,431],{"type":185,"tag":222,"props":422,"children":423},{},[424],{"type":191,"value":425},"业务代码与核心依赖在设计时，优先选择已支持 arm64 的语言运行时与第三方库。",{"type":185,"tag":222,"props":427,"children":428},{},[429],{"type":191,"value":430},"构建脚本与部署脚本中不再隐含“x86-only”的假设，而是对架构差异进行显式建模（比如通过变量或配置）。",{"type":185,"tag":222,"props":432,"children":433},{},[434],{"type":191,"value":435},"在引入第三方闭源组件时，将“是否支持 arm64”作为评估指标之一。",{"type":185,"tag":194,"props":437,"children":438},{},[439],{"type":191,"value":440},"这种模式的收益：",{"type":185,"tag":218,"props":442,"children":443},{},[444,449],{"type":185,"tag":222,"props":445,"children":446},{},[447],{"type":191,"value":448},"架构选择变得更加“可插拔”：相同的应用可以根据成本、性能和容量动态在 x86/Arm 之间迁移或混合部署。",{"type":185,"tag":222,"props":450,"children":451},{},[452],{"type":191,"value":453},"云资源采购与弹性伸缩策略更灵活，可基于 Spot、预留实例和不同实例族做更精细的成本优化。",{"type":185,"tag":211,"props":455,"children":457},{"id":456},"风险与局限何时不适合把-arm-当成默认",[458],{"type":191,"value":459},"风险与局限：何时不适合把 Arm 当成默认",{"type":185,"tag":267,"props":461,"children":463},{"id":462},"架构依赖与二进制兼容性",[464],{"type":191,"value":462},{"type":185,"tag":194,"props":466,"children":467},{},[468],{"type":191,"value":469},"文中明确给出边界条件：“除非存在特定架构依赖”：",{"type":185,"tag":218,"props":471,"children":472},{},[473,478,483],{"type":185,"tag":222,"props":474,"children":475},{},[476],{"type":191,"value":477},"闭源的 x86-only 组件或 SDK：如只提供 x86 动态库、驱动或 agent。",{"type":185,"tag":222,"props":479,"children":480},{},[481],{"type":191,"value":482},"强绑定特定 x86 指令集（如 AVX 系列）进行高度手写优化的计算核心，迁移到 Arm 可能需要大量重写与性能再评估。",{"type":185,"tag":222,"props":484,"children":485},{},[486],{"type":191,"value":487},"某些历史遗留系统中的脚本、配置或运维工具链，可能在架构检测/路径/包名上假定 x86。",{"type":185,"tag":194,"props":489,"children":490},{},[491],{"type":191,"value":492},"这类场景中，如果要强推 Arm：",{"type":185,"tag":218,"props":494,"children":495},{},[496,501],{"type":185,"tag":222,"props":497,"children":498},{},[499],{"type":191,"value":500},"短期成本往往集中在“替换组件 + 深层回归验证”，对稳定性要求高的核心系统风险会比较大。",{"type":185,"tag":222,"props":502,"children":503},{},[504],{"type":191,"value":505},"对长期收益的判断要更审慎，避免为了一定比例的成本优化，付出不可控的回归与运维代价。",{"type":185,"tag":267,"props":507,"children":509},{"id":508},"生态与工具支持尚不完善的角落",[510],{"type":191,"value":508},{"type":185,"tag":194,"props":512,"children":513},{},[514],{"type":191,"value":515},"尽管主流语言与工具链已普遍支持 Arm，但在一些边角地带仍需要注意：",{"type":185,"tag":218,"props":517,"children":518},{},[519,524,529],{"type":185,"tag":222,"props":520,"children":521},{},[522],{"type":191,"value":523},"少数原生扩展（Python/Node/Ruby 等）可能缺乏稳定的 arm64 预编译包，导致构建时间增加或偶发编译问题。",{"type":185,"tag":222,"props":525,"children":526},{},[527],{"type":191,"value":528},"某些监控、APM、安全代理、备份工具在 Arm 上的支持成熟度不一，可能引入观测与安全盲区。",{"type":185,"tag":222,"props":530,"children":531},{},[532],{"type":191,"value":533},"内部自研的自动化脚本、运维工具（如用于镜像扫描、合规检查等）若写死架构假设，也会成为迁移阻力。",{"type":185,"tag":211,"props":535,"children":537},{"id":536},"系统性影响对架构治理与工程体系的要求",[538],{"type":191,"value":539},"系统性影响：对架构治理与工程体系的要求",{"type":185,"tag":267,"props":541,"children":543},{"id":542},"对架构一致性与环境抽象的推动",[544],{"type":191,"value":542},{"type":185,"tag":194,"props":546,"children":547},{},[548],{"type":191,"value":549},"当组织开始大规模使用 Arm：",{"type":185,"tag":218,"props":551,"children":552},{},[553,558,563],{"type":185,"tag":222,"props":554,"children":555},{},[556],{"type":191,"value":557},"会倒逼团队更好地抽象“运行环境”，避免在业务逻辑层出现硬编码的架构假设。",{"type":185,"tag":222,"props":559,"children":560},{},[561],{"type":191,"value":562},"容器镜像、基础镜像与中间件镜像需要统一管理多架构版本，促进基础设施层做标准化。",{"type":185,"tag":222,"props":564,"children":565},{},[566],{"type":191,"value":567},"对“环境即代码”（Infra as Code）、自动化测试矩阵、多环境回归提出更高要求。",{"type":185,"tag":194,"props":569,"children":570},{},[571],{"type":191,"value":572},"长期看，这有助于：",{"type":185,"tag":218,"props":574,"children":575},{},[576],{"type":185,"tag":222,"props":577,"children":578},{},[579],{"type":191,"value":580},"减少“环境绑定型技术债”，让系统更容易迁移到不同形态的算力资源（例如进一步延伸到边缘计算）。",{"type":185,"tag":267,"props":582,"children":584},{"id":583},"对工程效率与成本治理的拉动",[585],{"type":191,"value":583},{"type":185,"tag":194,"props":587,"children":588},{},[589],{"type":191,"value":590},"Arm 的成本与能效优势，会直接影响：",{"type":185,"tag":218,"props":592,"children":593},{},[594,599],{"type":185,"tag":222,"props":595,"children":596},{},[597],{"type":191,"value":598},"预算敏感场景（如批处理任务、在线微服务大规模集群）更有动力向 Arm 收敛。",{"type":185,"tag":222,"props":600,"children":601},{},[602],{"type":191,"value":603},"团队会更频繁地评估“运行在哪类机器上最划算”，而不是仅仅盯着“每个 Pod 的资源 Requests/Limit”。",{"type":185,"tag":194,"props":605,"children":606},{},[607],{"type":191,"value":608},"前提是：",{"type":185,"tag":218,"props":610,"children":611},{},[612,617],{"type":185,"tag":222,"props":613,"children":614},{},[615],{"type":191,"value":616},"指标体系和观测要能清晰分解“架构差异”对性能和成本的影响。",{"type":185,"tag":222,"props":618,"children":619},{},[620],{"type":191,"value":621},"平台团队需要提供统一的实例选择策略与模板，而不是让每个服务各自为战。",{"type":185,"tag":211,"props":623,"children":625},{"id":624},"落地建议如何在团队内推进arm-优先策略",[626],{"type":191,"value":627},"落地建议：如何在团队内推进“Arm 优先策略”",{"type":185,"tag":267,"props":629,"children":631},{"id":630},"适用场景与前置条件",[632],{"type":191,"value":630},{"type":185,"tag":194,"props":634,"children":635},{},[636],{"type":191,"value":637},"更适合优先尝试 Arm 的情形：",{"type":185,"tag":218,"props":639,"children":640},{},[641,646,651],{"type":185,"tag":222,"props":642,"children":643},{},[644],{"type":191,"value":645},"新建服务、对外部二进制依赖较少，或完全基于主流开源栈。",{"type":185,"tag":222,"props":647,"children":648},{},[649],{"type":191,"value":650},"已经具备成熟的 CI/CD，构建和部署流程标准化，增加一个架构目标代价可控。",{"type":185,"tag":222,"props":652,"children":653},{},[654],{"type":191,"value":655},"有统一的容器基础镜像和中间件组件仓库，便于集中治理多架构镜像。",{"type":185,"tag":194,"props":657,"children":658},{},[659],{"type":191,"value":660},"不建议贸然切入的情形：",{"type":185,"tag":218,"props":662,"children":663},{},[664,669],{"type":185,"tag":222,"props":665,"children":666},{},[667],{"type":191,"value":668},"核心生产系统依赖大量闭源 x86 组件，且当前对运行时稳定性要求极高。",{"type":185,"tag":222,"props":670,"children":671},{},[672],{"type":191,"value":673},"团队缺乏自动化回归、性能基准测试与灰度发布能力，难以分阶段评估迁移影响。",{"type":185,"tag":267,"props":675,"children":677},{"id":676},"推进路径与控制风险的方式",[678],{"type":191,"value":676},{"type":185,"tag":194,"props":680,"children":681},{},[682],{"type":191,"value":683},"一个相对稳健的推进路径可以是：",{"type":185,"tag":685,"props":686,"children":687},"ol",{},[688],{"type":185,"tag":222,"props":689,"children":690},{},[691],{"type":185,"tag":692,"props":693,"children":694},"strong",{},[695],{"type":191,"value":696},"从新项目与边缘服务开始",{"type":185,"tag":218,"props":698,"children":699},{},[700,705],{"type":185,"tag":222,"props":701,"children":702},{},[703],{"type":191,"value":704},"新的云上应用默认在 Arm 上规划和验证，构建链路一开始就支持多架构。",{"type":185,"tag":222,"props":706,"children":707},{},[708],{"type":191,"value":709},"对现有系统，从非核心、流量较小的服务先做试点，建立经验与模板。",{"type":185,"tag":685,"props":711,"children":713},{"start":712},2,[714],{"type":185,"tag":222,"props":715,"children":716},{},[717],{"type":185,"tag":692,"props":718,"children":719},{},[720],{"type":191,"value":721},"平台层先把基础设施“铺平”",{"type":185,"tag":218,"props":723,"children":724},{},[725,730],{"type":185,"tag":222,"props":726,"children":727},{},[728],{"type":191,"value":729},"建立统一的多架构基础镜像和中间件镜像仓库。",{"type":185,"tag":222,"props":731,"children":732},{},[733],{"type":191,"value":734},"在 CI/CD 中增加 arm64 构建与测试矩阵，并对关键语言栈做一次性适配。",{"type":185,"tag":685,"props":736,"children":738},{"start":737},3,[739],{"type":185,"tag":222,"props":740,"children":741},{},[742],{"type":185,"tag":692,"props":743,"children":744},{},[745],{"type":191,"value":746},"引入观测与基准测试",{"type":185,"tag":218,"props":748,"children":749},{},[750,755],{"type":185,"tag":222,"props":751,"children":752},{},[753],{"type":191,"value":754},"为迁移到 Arm 的服务设计明确的性能基线和回归指标（P99 延迟、吞吐、CPU 利用率、成本等）。",{"type":185,"tag":222,"props":756,"children":757},{},[758],{"type":191,"value":759},"在灰度阶段维持 x86 与 Arm 双跑，通过对比观察性能与稳定性差异。",{"type":185,"tag":685,"props":761,"children":763},{"start":762},4,[764],{"type":185,"tag":222,"props":765,"children":766},{},[767],{"type":185,"tag":692,"props":768,"children":769},{},[770],{"type":191,"value":771},"控制范围与节奏",{"type":185,"tag":218,"props":773,"children":774},{},[775,780],{"type":185,"tag":222,"props":776,"children":777},{},[778],{"type":191,"value":779},"使用灰度环境或分批 rollout，将 Arm 迁移与日常功能发布解耦。",{"type":185,"tag":222,"props":781,"children":782},{},[783],{"type":191,"value":784},"对依赖复杂的系统，先迁移外围组件或只迁移一部分实例比例，保留 x86 作为 fallback。",{"type":185,"tag":194,"props":786,"children":787},{},[788],{"type":191,"value":789},"通过上述路径，可以在不牺牲稳定性的前提下，逐步把 Arm 从“成本优化选项”升级为“默认架构”，并让架构与工程体系自然适应多架构的长期演进。",{"title":178,"searchDepth":712,"depth":712,"links":791},[792,793],{"id":188,"depth":712,"text":192},{"id":206,"depth":712,"text":209,"children":794},[795,796,797,798,799,800],{"id":213,"depth":737,"text":216},{"id":262,"depth":737,"text":265},{"id":379,"depth":737,"text":382},{"id":456,"depth":737,"text":459},{"id":536,"depth":737,"text":539},{"id":624,"depth":737,"text":627},"markdown","content:6.maps:_cloud-native:hardware:arm-on-cloud-native.md","content","6.maps/_cloud-native/hardware/arm-on-cloud-native.md","6.maps/_cloud-native/hardware/arm-on-cloud-native","md",[808,812],{"_path":809,"title":810,"description":811},"/maps/_cloud-native/cloud-native","CloudNative","云原生技术概论",{"_path":813,"title":814,"description":815},"/maps/_cloud-native/kubernetes","Kubernetes","K8s，是一个基于容器的集群管理平台，主要用于控制容器",1771696724818]