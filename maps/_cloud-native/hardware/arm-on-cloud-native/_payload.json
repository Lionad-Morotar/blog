 | 抗锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"original_path":181,"body":182,"_type":802,"_id":803,"_source":804,"_file":805,"_stem":806,"_extension":807},"/maps/_cloud-native/hardware/arm-on-cloud-native","hardware",false,true,"","Arm 云计算实例 — 建议默认采用","将 Arm 视为云端计算实例的默认选择，除非存在明确的 x86 架构依赖。","content/6.maps/_cloud-native/hardware/arm-on-cloud-native.md",{"type":183,"children":184,"toc":791},"root",[185,194,200,205,211,218,243,248,261,267,273,278,296,301,314,320,325,360,365,378,384,390,408,414,419,437,442,455,461,466,471,489,494,507,512,517,535,541,546,551,569,574,582,587,592,605,610,623,629,634,639,657,662,675,680,685,698,711,723,736,748,761,773,786],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"brief",[191],{"type":192,"value":193},"text","Brief",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198],{"type":192,"value":199},"在主流公有云（AWS、Azure、GCP）中，Arm 架构计算实例因相较传统 x86 实例更具成本和能效优势，已经成为许多场景下的优先选项。我们的多支团队已经在微服务、开源数据库乃至部分高性能计算场景中成功迁移到 Arm，只需少量代码调整和轻微构建脚本修改。新的云上应用和系统也越来越多地直接以 Arm 为默认目标。基于这些经验，我们建议：在不存在特定架构依赖的前提下，大多数工作负载应优先采用 Arm 计算实例。现代工具链（如多架构 Docker 镜像）也进一步简化了在 Arm 与 x86 环境之间的构建与部署。",{"type":186,"tag":195,"props":201,"children":202},{},[203],{"type":192,"value":204},"来源：技术雷达",{"type":186,"tag":187,"props":206,"children":208},{"id":207},"details",[209],{"type":192,"value":210},"Details",{"type":186,"tag":212,"props":213,"children":215},"h3",{"id":214},"背景与现状arm-已从尝试选项变成默认选项候选",[216],{"type":192,"value":217},"背景与现状：Arm 已从“尝试选项”变成“默认选项候选”",{"type":186,"tag":219,"props":220,"children":221},"ul",{},[222,228,233,238],{"type":186,"tag":223,"props":224,"children":225},"li",{},[226],{"type":192,"value":227},"主流云厂商（AWS、Azure、GCP）都已经提供成熟的 Arm 实例家族，并持续迭代。",{"type":186,"tag":223,"props":229,"children":230},{},[231],{"type":192,"value":232},"Arm 在能耗和性价比上的优势，使其对大规模、成本敏感型工作负载尤为有吸引力。",{"type":186,"tag":223,"props":234,"children":235},{},[236],{"type":192,"value":237},"文本给出的组织内部经验表明：微服务、开源数据库、高性能计算等多类负载已经在 Arm 上稳定运行。",{"type":186,"tag":223,"props":239,"children":240},{},[241],{"type":192,"value":242},"趋势上，新建云上系统开始“默认跑在 Arm 上”，x86 更像是在有特殊依赖时的例外选择。",{"type":186,"tag":195,"props":244,"children":245},{},[246],{"type":192,"value":247},"对架构与技术负责人而言，这意味着：",{"type":186,"tag":219,"props":249,"children":250},{},[251,256],{"type":186,"tag":223,"props":252,"children":253},{},[254],{"type":192,"value":255},"“选 Arm 还是 x86”不再只是底层 Infra 选择，而会反过来影响技术栈、依赖库与第三方组件的选择。",{"type":186,"tag":223,"props":257,"children":258},{},[259],{"type":192,"value":260},"在技术决策模板中，应增加“是否具备 Arm 兼容性”这一项，而不是事后再补。",{"type":186,"tag":212,"props":262,"children":264},{"id":263},"核心模式与技术要点多架构构建与轻量迁移",[265],{"type":192,"value":266},"核心模式与技术要点：多架构构建与轻量迁移",{"type":186,"tag":268,"props":269,"children":271},"h4",{"id":270},"典型工作负载类型",[272],{"type":192,"value":270},{"type":186,"tag":195,"props":274,"children":275},{},[276],{"type":192,"value":277},"基于文中描述和常见实践，Arm 适配良好的类型通常包括：",{"type":186,"tag":219,"props":279,"children":280},{},[281,286,291],{"type":186,"tag":223,"props":282,"children":283},{},[284],{"type":192,"value":285},"容器化微服务：尤其是以 Go/Java/Rust/Node/Python 等为主的 stateless 服务。",{"type":186,"tag":223,"props":287,"children":288},{},[289],{"type":192,"value":290},"开源数据库与中间件：如常见的关系型数据库、KV/缓存系统，只要官方或社区已提供 arm64 支持。",{"type":186,"tag":223,"props":292,"children":293},{},[294],{"type":192,"value":295},"批量计算与部分 HPC 工作负载：在编译链支持 Arm 的前提下，往往可以复用绝大部分代码。",{"type":186,"tag":195,"props":297,"children":298},{},[299],{"type":192,"value":300},"这些场景的共同特征是：",{"type":186,"tag":219,"props":302,"children":303},{},[304,309],{"type":186,"tag":223,"props":305,"children":306},{},[307],{"type":192,"value":308},"源码可控，或至少可获取源码进行重编译。",{"type":186,"tag":223,"props":310,"children":311},{},[312],{"type":192,"value":313},"构建与发布已经容器化或自动化，能把“增加一个 arm64 目标”变成流水线配置问题，而不是人工手工活。",{"type":186,"tag":268,"props":315,"children":317},{"id":316},"多架构-docker-镜像与工具链",[318],{"type":192,"value":319},"多架构 Docker 镜像与工具链",{"type":186,"tag":195,"props":321,"children":322},{},[323],{"type":192,"value":324},"文中明确提到“多架构 Docker 镜像”作为关键支撑手段，隐含的模式包括：",{"type":186,"tag":219,"props":326,"children":327},{},[328,350,355],{"type":186,"tag":223,"props":329,"children":330},{},[331,333,340,342,348],{"type":192,"value":332},"构建阶段同时产出 ",{"type":186,"tag":334,"props":335,"children":337},"code",{"className":336},[],[338],{"type":192,"value":339},"linux/amd64",{"type":192,"value":341}," 与 ",{"type":186,"tag":334,"props":343,"children":345},{"className":344},[],[346],{"type":192,"value":347},"linux/arm64",{"type":192,"value":349}," 两种镜像，并推送到同一镜像仓库。",{"type":186,"tag":223,"props":351,"children":352},{},[353],{"type":192,"value":354},"通过 manifest list 让运行时根据节点架构自动拉取对应镜像，减少上层系统感知架构差异的需求。",{"type":186,"tag":223,"props":356,"children":357},{},[358],{"type":192,"value":359},"在 CI/CD 侧通过 matrix / buildx / QEMU 等方式，统一维护一套构建脚本，对两种架构同时生效。",{"type":186,"tag":195,"props":361,"children":362},{},[363],{"type":192,"value":364},"对团队的启示：",{"type":186,"tag":219,"props":366,"children":367},{},[368,373],{"type":186,"tag":223,"props":369,"children":370},{},[371],{"type":192,"value":372},"只要构建链路已经工程化，增加 Arm 支持更多是“一次性工程投入 + 持续的自动化校验”，而不是长期的人力负担。",{"type":186,"tag":223,"props":374,"children":375},{},[376],{"type":192,"value":377},"与其在项目后期临时“为了省成本”改 Arm，不如在项目早期就把 Arm 纳入 pipeline，以避免后期技术债集中爆发。",{"type":186,"tag":212,"props":379,"children":381},{"id":380},"旧做法-vs-新模式从架构特定到架构无关",[382],{"type":192,"value":383},"旧做法 vs 新模式：从“架构特定”到“架构无关”",{"type":186,"tag":268,"props":385,"children":387},{"id":386},"传统模式x86-作为默认且唯一的假设",[388],{"type":192,"value":389},"传统模式：x86 作为“默认且唯一”的假设",{"type":186,"tag":219,"props":391,"children":392},{},[393,398,403],{"type":186,"tag":223,"props":394,"children":395},{},[396],{"type":192,"value":397},"许多老系统在设计和依赖引入时，都默认运行在 x86 服务器上。",{"type":186,"tag":223,"props":399,"children":400},{},[401],{"type":192,"value":402},"依赖中可能夹杂：只提供 x86 二进制的第三方组件、脚本中写死的 CPU 架构判断、针对特定 SIMD 指令集做的优化等。",{"type":186,"tag":223,"props":404,"children":405},{},[406],{"type":192,"value":407},"在这种前提下，任何非 x86 目标（包括 Arm）都要付出额外适配成本，因此很少在规划阶段被真正考虑。",{"type":186,"tag":268,"props":409,"children":411},{"id":410},"新模式主动追求多架构友好",[412],{"type":192,"value":413},"新模式：主动追求“多架构友好”",{"type":186,"tag":195,"props":415,"children":416},{},[417],{"type":192,"value":418},"Arm 普及之后，合理的默认心智模型变为：",{"type":186,"tag":219,"props":420,"children":421},{},[422,427,432],{"type":186,"tag":223,"props":423,"children":424},{},[425],{"type":192,"value":426},"业务代码与核心依赖在设计时，优先选择已支持 arm64 的语言运行时与第三方库。",{"type":186,"tag":223,"props":428,"children":429},{},[430],{"type":192,"value":431},"构建脚本与部署脚本中不再隐含“x86-only”的假设，而是对架构差异进行显式建模（比如通过变量或配置）。",{"type":186,"tag":223,"props":433,"children":434},{},[435],{"type":192,"value":436},"在引入第三方闭源组件时，将“是否支持 arm64”作为评估指标之一。",{"type":186,"tag":195,"props":438,"children":439},{},[440],{"type":192,"value":441},"这种模式的收益：",{"type":186,"tag":219,"props":443,"children":444},{},[445,450],{"type":186,"tag":223,"props":446,"children":447},{},[448],{"type":192,"value":449},"架构选择变得更加“可插拔”：相同的应用可以根据成本、性能和容量动态在 x86/Arm 之间迁移或混合部署。",{"type":186,"tag":223,"props":451,"children":452},{},[453],{"type":192,"value":454},"云资源采购与弹性伸缩策略更灵活，可基于 Spot、预留实例和不同实例族做更精细的成本优化。",{"type":186,"tag":212,"props":456,"children":458},{"id":457},"风险与局限何时不适合把-arm-当成默认",[459],{"type":192,"value":460},"风险与局限：何时不适合把 Arm 当成默认",{"type":186,"tag":268,"props":462,"children":464},{"id":463},"架构依赖与二进制兼容性",[465],{"type":192,"value":463},{"type":186,"tag":195,"props":467,"children":468},{},[469],{"type":192,"value":470},"文中明确给出边界条件：“除非存在特定架构依赖”：",{"type":186,"tag":219,"props":472,"children":473},{},[474,479,484],{"type":186,"tag":223,"props":475,"children":476},{},[477],{"type":192,"value":478},"闭源的 x86-only 组件或 SDK：如只提供 x86 动态库、驱动或 agent。",{"type":186,"tag":223,"props":480,"children":481},{},[482],{"type":192,"value":483},"强绑定特定 x86 指令集（如 AVX 系列）进行高度手写优化的计算核心，迁移到 Arm 可能需要大量重写与性能再评估。",{"type":186,"tag":223,"props":485,"children":486},{},[487],{"type":192,"value":488},"某些历史遗留系统中的脚本、配置或运维工具链，可能在架构检测/路径/包名上假定 x86。",{"type":186,"tag":195,"props":490,"children":491},{},[492],{"type":192,"value":493},"这类场景中，如果要强推 Arm：",{"type":186,"tag":219,"props":495,"children":496},{},[497,502],{"type":186,"tag":223,"props":498,"children":499},{},[500],{"type":192,"value":501},"短期成本往往集中在“替换组件 + 深层回归验证”，对稳定性要求高的核心系统风险会比较大。",{"type":186,"tag":223,"props":503,"children":504},{},[505],{"type":192,"value":506},"对长期收益的判断要更审慎，避免为了一定比例的成本优化，付出不可控的回归与运维代价。",{"type":186,"tag":268,"props":508,"children":510},{"id":509},"生态与工具支持尚不完善的角落",[511],{"type":192,"value":509},{"type":186,"tag":195,"props":513,"children":514},{},[515],{"type":192,"value":516},"尽管主流语言与工具链已普遍支持 Arm，但在一些边角地带仍需要注意：",{"type":186,"tag":219,"props":518,"children":519},{},[520,525,530],{"type":186,"tag":223,"props":521,"children":522},{},[523],{"type":192,"value":524},"少数原生扩展（Python/Node/Ruby 等）可能缺乏稳定的 arm64 预编译包，导致构建时间增加或偶发编译问题。",{"type":186,"tag":223,"props":526,"children":527},{},[528],{"type":192,"value":529},"某些监控、APM、安全代理、备份工具在 Arm 上的支持成熟度不一，可能引入观测与安全盲区。",{"type":186,"tag":223,"props":531,"children":532},{},[533],{"type":192,"value":534},"内部自研的自动化脚本、运维工具（如用于镜像扫描、合规检查等）若写死架构假设，也会成为迁移阻力。",{"type":186,"tag":212,"props":536,"children":538},{"id":537},"系统性影响对架构治理与工程体系的要求",[539],{"type":192,"value":540},"系统性影响：对架构治理与工程体系的要求",{"type":186,"tag":268,"props":542,"children":544},{"id":543},"对架构一致性与环境抽象的推动",[545],{"type":192,"value":543},{"type":186,"tag":195,"props":547,"children":548},{},[549],{"type":192,"value":550},"当组织开始大规模使用 Arm：",{"type":186,"tag":219,"props":552,"children":553},{},[554,559,564],{"type":186,"tag":223,"props":555,"children":556},{},[557],{"type":192,"value":558},"会倒逼团队更好地抽象“运行环境”，避免在业务逻辑层出现硬编码的架构假设。",{"type":186,"tag":223,"props":560,"children":561},{},[562],{"type":192,"value":563},"容器镜像、基础镜像与中间件镜像需要统一管理多架构版本，促进基础设施层做标准化。",{"type":186,"tag":223,"props":565,"children":566},{},[567],{"type":192,"value":568},"对“环境即代码”（Infra as Code）、自动化测试矩阵、多环境回归提出更高要求。",{"type":186,"tag":195,"props":570,"children":571},{},[572],{"type":192,"value":573},"长期看，这有助于：",{"type":186,"tag":219,"props":575,"children":576},{},[577],{"type":186,"tag":223,"props":578,"children":579},{},[580],{"type":192,"value":581},"减少“环境绑定型技术债”，让系统更容易迁移到不同形态的算力资源（例如进一步延伸到边缘计算）。",{"type":186,"tag":268,"props":583,"children":585},{"id":584},"对工程效率与成本治理的拉动",[586],{"type":192,"value":584},{"type":186,"tag":195,"props":588,"children":589},{},[590],{"type":192,"value":591},"Arm 的成本与能效优势，会直接影响：",{"type":186,"tag":219,"props":593,"children":594},{},[595,600],{"type":186,"tag":223,"props":596,"children":597},{},[598],{"type":192,"value":599},"预算敏感场景（如批处理任务、在线微服务大规模集群）更有动力向 Arm 收敛。",{"type":186,"tag":223,"props":601,"children":602},{},[603],{"type":192,"value":604},"团队会更频繁地评估“运行在哪类机器上最划算”，而不是仅仅盯着“每个 Pod 的资源 Requests/Limit”。",{"type":186,"tag":195,"props":606,"children":607},{},[608],{"type":192,"value":609},"前提是：",{"type":186,"tag":219,"props":611,"children":612},{},[613,618],{"type":186,"tag":223,"props":614,"children":615},{},[616],{"type":192,"value":617},"指标体系和观测要能清晰分解“架构差异”对性能和成本的影响。",{"type":186,"tag":223,"props":619,"children":620},{},[621],{"type":192,"value":622},"平台团队需要提供统一的实例选择策略与模板，而不是让每个服务各自为战。",{"type":186,"tag":212,"props":624,"children":626},{"id":625},"落地建议如何在团队内推进arm-优先策略",[627],{"type":192,"value":628},"落地建议：如何在团队内推进“Arm 优先策略”",{"type":186,"tag":268,"props":630,"children":632},{"id":631},"适用场景与前置条件",[633],{"type":192,"value":631},{"type":186,"tag":195,"props":635,"children":636},{},[637],{"type":192,"value":638},"更适合优先尝试 Arm 的情形：",{"type":186,"tag":219,"props":640,"children":641},{},[642,647,652],{"type":186,"tag":223,"props":643,"children":644},{},[645],{"type":192,"value":646},"新建服务、对外部二进制依赖较少，或完全基于主流开源栈。",{"type":186,"tag":223,"props":648,"children":649},{},[650],{"type":192,"value":651},"已经具备成熟的 CI/CD，构建和部署流程标准化，增加一个架构目标代价可控。",{"type":186,"tag":223,"props":653,"children":654},{},[655],{"type":192,"value":656},"有统一的容器基础镜像和中间件组件仓库，便于集中治理多架构镜像。",{"type":186,"tag":195,"props":658,"children":659},{},[660],{"type":192,"value":661},"不建议贸然切入的情形：",{"type":186,"tag":219,"props":663,"children":664},{},[665,670],{"type":186,"tag":223,"props":666,"children":667},{},[668],{"type":192,"value":669},"核心生产系统依赖大量闭源 x86 组件，且当前对运行时稳定性要求极高。",{"type":186,"tag":223,"props":671,"children":672},{},[673],{"type":192,"value":674},"团队缺乏自动化回归、性能基准测试与灰度发布能力，难以分阶段评估迁移影响。",{"type":186,"tag":268,"props":676,"children":678},{"id":677},"推进路径与控制风险的方式",[679],{"type":192,"value":677},{"type":186,"tag":195,"props":681,"children":682},{},[683],{"type":192,"value":684},"一个相对稳健的推进路径可以是：",{"type":186,"tag":686,"props":687,"children":688},"ol",{},[689],{"type":186,"tag":223,"props":690,"children":691},{},[692],{"type":186,"tag":693,"props":694,"children":695},"strong",{},[696],{"type":192,"value":697},"从新项目与边缘服务开始",{"type":186,"tag":219,"props":699,"children":700},{},[701,706],{"type":186,"tag":223,"props":702,"children":703},{},[704],{"type":192,"value":705},"新的云上应用默认在 Arm 上规划和验证，构建链路一开始就支持多架构。",{"type":186,"tag":223,"props":707,"children":708},{},[709],{"type":192,"value":710},"对现有系统，从非核心、流量较小的服务先做试点，建立经验与模板。",{"type":186,"tag":686,"props":712,"children":714},{"start":713},2,[715],{"type":186,"tag":223,"props":716,"children":717},{},[718],{"type":186,"tag":693,"props":719,"children":720},{},[721],{"type":192,"value":722},"平台层先把基础设施“铺平”",{"type":186,"tag":219,"props":724,"children":725},{},[726,731],{"type":186,"tag":223,"props":727,"children":728},{},[729],{"type":192,"value":730},"建立统一的多架构基础镜像和中间件镜像仓库。",{"type":186,"tag":223,"props":732,"children":733},{},[734],{"type":192,"value":735},"在 CI/CD 中增加 arm64 构建与测试矩阵，并对关键语言栈做一次性适配。",{"type":186,"tag":686,"props":737,"children":739},{"start":738},3,[740],{"type":186,"tag":223,"props":741,"children":742},{},[743],{"type":186,"tag":693,"props":744,"children":745},{},[746],{"type":192,"value":747},"引入观测与基准测试",{"type":186,"tag":219,"props":749,"children":750},{},[751,756],{"type":186,"tag":223,"props":752,"children":753},{},[754],{"type":192,"value":755},"为迁移到 Arm 的服务设计明确的性能基线和回归指标（P99 延迟、吞吐、CPU 利用率、成本等）。",{"type":186,"tag":223,"props":757,"children":758},{},[759],{"type":192,"value":760},"在灰度阶段维持 x86 与 Arm 双跑，通过对比观察性能与稳定性差异。",{"type":186,"tag":686,"props":762,"children":764},{"start":763},4,[765],{"type":186,"tag":223,"props":766,"children":767},{},[768],{"type":186,"tag":693,"props":769,"children":770},{},[771],{"type":192,"value":772},"控制范围与节奏",{"type":186,"tag":219,"props":774,"children":775},{},[776,781],{"type":186,"tag":223,"props":777,"children":778},{},[779],{"type":192,"value":780},"使用灰度环境或分批 rollout，将 Arm 迁移与日常功能发布解耦。",{"type":186,"tag":223,"props":782,"children":783},{},[784],{"type":192,"value":785},"对依赖复杂的系统，先迁移外围组件或只迁移一部分实例比例，保留 x86 作为 fallback。",{"type":186,"tag":195,"props":787,"children":788},{},[789],{"type":192,"value":790},"通过上述路径，可以在不牺牲稳定性的前提下，逐步把 Arm 从“成本优化选项”升级为“默认架构”，并让架构与工程体系自然适应多架构的长期演进。",{"title":178,"searchDepth":713,"depth":713,"links":792},[793,794],{"id":189,"depth":713,"text":193},{"id":207,"depth":713,"text":210,"children":795},[796,797,798,799,800,801],{"id":214,"depth":738,"text":217},{"id":263,"depth":738,"text":266},{"id":380,"depth":738,"text":383},{"id":457,"depth":738,"text":460},{"id":537,"depth":738,"text":540},{"id":625,"depth":738,"text":628},"markdown","content:6.maps:_cloud-native:hardware:arm-on-cloud-native.md","content","6.maps/_cloud-native/hardware/arm-on-cloud-native.md","6.maps/_cloud-native/hardware/arm-on-cloud-native","md",[809,813],{"_path":810,"title":811,"description":812},"/maps/_cloud-native/cloud-native","CloudNative","云原生技术概论",{"_path":814,"title":815,"description":816},"/maps/_cloud-native/hardware/hardware","云原生硬件","云原生环境下的硬件架构选择，包括 Arm 架构应用",1772185480598]