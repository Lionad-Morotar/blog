工具、系统库和配置打包到一个镜像中，运行在有有独立命名空间的容器进程内，可以使软件的所有依赖都标准化。",{"type":182,"children":183,"toc":749},"root",[184,192,199,205,211,216,221,242,247,252,257,262,287,292,297,302,307,312,317,322,412,417,422,626,631,667,678,683,694,699,704,712,743],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"简介",[190],{"type":191,"value":188},"text",{"type":185,"tag":193,"props":194,"children":196},"h4",{"id":195},"docker-是什么",[197],{"type":191,"value":198},"Docker 是什么？",{"type":185,"tag":200,"props":201,"children":202},"p",{},[203],{"type":191,"value":204},"Docker 本身不是容器，而是容器标准的一种实现及其管理工具。",{"type":185,"tag":193,"props":206,"children":208},{"id":207},"容器是什么",[209],{"type":191,"value":210},"容器是什么？",{"type":185,"tag":200,"props":212,"children":213},{},[214],{"type":191,"value":215},"容器是一种软件打包的技术。通过对系统资源的控制与隔离，把软件、软件运行时、系统工具、系统库和配置打包到一个镜像中，运行在有有独立命名空间的容器进程内，可以使软件的所有依赖都标准化。所以使用容器技术能方便地将软件打包成标准单元。",{"type":185,"tag":186,"props":217,"children":219},{"id":218},"原理",[220],{"type":191,"value":218},{"type":185,"tag":200,"props":222,"children":223},{},[224,226,240],{"type":191,"value":225},"Docker 和虚拟机都希望能提供一个虚拟、完整、独立的运行时环境，通过提高虚拟环境的隔离型，以便管理。一般来说，虚拟机的原理是模拟硬件环境，所以需要安装客户端操作系统",{"type":185,"tag":227,"props":228,"children":229},"sup",{},[230],{"type":185,"tag":231,"props":232,"children":237},"a",{"href":233,"ariaDescribedBy":234,"dataFootnoteRef":178,"id":236},"#user-content-fn-%E6%A8%A1%E6%8B%9F%E7%A1%AC%E4%BB%B6",[235],"footnote-label","user-content-fnref-%E6%A8%A1%E6%8B%9F%E7%A1%AC%E4%BB%B6",[238],{"type":191,"value":239},"1",{"type":191,"value":241},"，而 Docker 并不需要这层客户端操作系统，所以 Docker 更加轻量，硬件利用率也更高。",{"type":185,"tag":200,"props":243,"children":244},{},[245],{"type":191,"value":246},"虚拟机使用 Hypervisor 实现操作系统级别的模拟，而 Docker 通过操作系统的文件系统、命名空间、控制组实现进程级别的模拟。",{"type":185,"tag":200,"props":248,"children":249},{},[250],{"type":191,"value":251},"命名空间：所有 Linux 的进程都从 init 进程 fork 派生。Linux 容器的一个主要组件是新的命名空间下的一个 init 进程，所以我们有能力去创建一个不影响外界的进程树出来。",{"type":185,"tag":200,"props":253,"children":254},{},[255],{"type":191,"value":256},"控制组：通过控制组，我们能限制进程对 CPU、磁盘、内存的使用。",{"type":185,"tag":186,"props":258,"children":260},{"id":259},"概念",[261],{"type":191,"value":259},{"type":185,"tag":263,"props":264,"children":265},"ol",{},[266,272,277,282],{"type":185,"tag":267,"props":268,"children":269},"li",{},[270],{"type":191,"value":271},"隔离环境：虚拟文件系统；POSIX API；文件的只读和屏蔽；命名空间、环境变量等；",{"type":185,"tag":267,"props":273,"children":274},{},[275],{"type":191,"value":276},"生命周期：created、running、pausing、paused、stopped；可以通过 update 动态调整硬件资源使用率",{"type":185,"tag":267,"props":278,"children":279},{},[280],{"type":191,"value":281},"数据卷：数据卷由自己的独立的生命周期",{"type":185,"tag":267,"props":283,"children":284},{},[285],{"type":191,"value":286},"网络：独立的网络命名空间、共享其他实例的网络命名空间、共享主机的网络命名空间",{"type":185,"tag":186,"props":288,"children":290},{"id":289},"架构",[291],{"type":191,"value":289},{"type":185,"tag":200,"props":293,"children":294},{},[295],{"type":191,"value":296},"Docker 引擎实际上由 Dockerd、Containerd、RunC 等组件构成",{"type":185,"tag":200,"props":298,"children":299},{},[300],{"type":191,"value":301},"Dockerd：容器管理 -> 编排管理和集群管理。它接受来自外部的 HTTP 请求并作为 API 调用执行，对内与 Containerd 进行通讯。",{"type":185,"tag":200,"props":303,"children":304},{},[305],{"type":191,"value":306},"Containerd：对镜像、容器的管理提供了一个更进一步的抽象，提供了内容、快照、差异、容器、镜像、任务等更加细粒度的概念。",{"type":185,"tag":200,"props":308,"children":309},{},[310],{"type":191,"value":311},"Container 包含 Containerd-shim，用于正确处理由操作系统发送过来的信号。",{"type":185,"tag":200,"props":313,"children":314},{},[315],{"type":191,"value":316},"RunC：Containerd 提供的容器管理等 API 的执行者是 RunC。",{"type":185,"tag":186,"props":318,"children":320},{"id":319},"常见指令",[321],{"type":191,"value":319},{"type":185,"tag":323,"props":324,"children":325},"ul",{},[326,344,361,378,395],{"type":185,"tag":267,"props":327,"children":328},{},[329,336,338],{"type":185,"tag":330,"props":331,"children":333},"code",{"className":332},[],[334],{"type":191,"value":335},"ps",{"type":191,"value":337},"：列表，如 ",{"type":185,"tag":330,"props":339,"childre