"type":179,"children":180,"toc":746},"root",[181,189,196,202,208,213,218,239,244,249,254,259,284,289,294,299,304,309,314,319,409,414,419,623,628,664,675,680,691,696,701,709,740],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"简介",[187],{"type":188,"value":185},"text",{"type":182,"tag":190,"props":191,"children":193},"h4",{"id":192},"docker-是什么",[194],{"type":188,"value":195},"Docker 是什么？",{"type":182,"tag":197,"props":198,"children":199},"p",{},[200],{"type":188,"value":201},"Docker 本身不是容器，而是容器标准的一种实现及其管理工具。",{"type":182,"tag":190,"props":203,"children":205},{"id":204},"容器是什么",[206],{"type":188,"value":207},"容器是什么？",{"type":182,"tag":197,"props":209,"children":210},{},[211],{"type":188,"value":212},"容器是一种软件打包的技术。通过对系统资源的控制与隔离，把软件、软件运行时、系统工具、系统库和配置打包到一个镜像中，运行在有有独立命名空间的容器进程内，可以使软件的所有依赖都标准化。所以使用容器技术能方便地将软件打包成标准单元。",{"type":182,"tag":183,"props":214,"children":216},{"id":215},"原理",[217],{"type":188,"value":215},{"type":182,"tag":197,"props":219,"children":220},{},[221,223,237],{"type":188,"value":222},"Docker 和虚拟机都希望能提供一个虚拟、完整、独立的运行时环境，通过提高虚拟环境的隔离型，以便管理。一般来说，虚拟机的原理是模拟硬件环境，所以需要安装客户端操作系统",{"type":182,"tag":224,"props":225,"children":226},"sup",{},[227],{"type":182,"tag":228,"props":229,"children":234},"a",{"href":230,"ariaDescribedBy":231,"dataFootnoteRef":175,"id":233},"#user-content-fn-%E6%A8%A1%E6%8B%9F%E7%A1%AC%E4%BB%B6",[232],"footnote-label","user-content-fnref-%E6%A8%A1%E6%8B%9F%E7%A1%AC%E4%BB%B6",[235],{"type":188,"value":236},"1",{"type":188,"value":238},"，而 Docker 并不需要这层客户端操作系统，所以 Docker 更加轻量，硬件利用率也更高。",{"type":182,"tag":197,"props":240,"children":241},{},[242],{"type":188,"value":243},"虚拟机使用 Hypervisor 实现操作系统级别的模拟，而 Docker 通过操作系统的文件系统、命名空间、控制组实现进程级别的模拟。",{"type":182,"tag":197,"props":245,"children":246},{},[247],{"type":188,"value":248},"命名空间：所有 Linux 的进程都从 init 进程 fork 派生。Linux 容器的一个主要组件是新的命名空间下的一个 init 进程，所以我们有能力去创建一个不影响外界的进程树出来。",{"type":182,"tag":197,"props":250,"children":251},{},[252],{"type":188,"value":253},"控制组：通过控制组，我们能限制进程对 CPU、磁盘、内存的使用。",{"type":182,"tag":183,"props":255,"children":257},{"id":256},"概念",[258],{"type":188,"value":256},{"type":182,"tag":260,"props":261,"children":262},"ol",{},[263,269,274,279],{"type":182,"tag":264,"props":265,"children":266},"li",{},[267],{"type":188,"value":268},"隔离环境：虚拟文件系统；POSIX API；文件的只读和屏蔽；命名空间、环境变量等；",{"type":182,"tag":264,"props":270,"children":271},{},[272],{"type":188,"value":273},"生命周期：created、running、pausing、paused、stopped；可以通过 update 动态调整硬件资源使用率",{"type":182,"tag":264,"props":275,"children":276},{},[277],{"type":188,"value":278},"数据卷：数据卷由自己的独立的生命周期",{"type":182,"tag":264,"props":280,"children":281},{},[282],{"type":188,"value":283},"网络：独立的网络命名空间、共享其他实例的网络命名空间、共享主机的网络命名空间",{"type":182,"tag":183,"props":285,"children":287},{"id":286},"架构",[288],{"type":188,"value":286},{"type":182,"tag":197,"props":290,"children":291},{},[292],{"type":188,"value":293},"Docker 引擎实际上由 Dockerd、Containerd、RunC 等组件构成",{"type":182,"tag":197,"props":295,"children":296},{},[297],{"type":188,"value":298},"Dockerd：容器管理 -> 编排管理和集群管理。它接受来自外部的 HTTP 请求并作为 API 调用执行，对内与 Containerd 进行通讯。",{"type":182,"tag":197,"props":300,"children":301},{},[302],{"type":188,"value":303},"Containerd：对镜像、容器的管理提供了一个更进一步的抽象，提供了内容、快照、差异、容器、镜像、任务等更加细粒度的概念。",{"type":182,"tag":197,"props":305,"children":306},{},[307],{"type":188,"value":308},"Container 包含 Containerd-shim，用于正确处理由操作系统发送过来的信号。",{"type":182,"tag":197,"props":310,"children":311},{},[312],{"type":188,"value":313},"RunC：Containerd 提供的容器管理等 API 的执行者是 RunC。",{"type":182,"tag":183,"props":315,"children":317},{"id":316},"常见指令",[318],{"type":188,"value":316},{"type":182,"tag":320,"props":321,"children":322},"ul",{},[323,341,358,375,392],{"type":182,"tag":264,"props":324,"children":325},{},[326,333,335],{"type":182,"tag":327,"props":328,"children":330},"code",{"className":329},[],[331],{"type":188,"value":332},"ps",{"type":188,"value":334},"：列表，如 ",{"type":182,"tag":327,"props":336,"children":338},{"className":337},[],[339],{"type":188,"value"