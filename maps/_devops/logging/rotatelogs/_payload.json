"","rotatelogs","Apache 内置的日志轮转工具，通过管道机制实现按时间或大小切割日志文件。","content/6.maps/_devops/rotatelogs.md",{"type":183,"children":184,"toc":625},"root",[185,193,200,206,212,234,239,244,253,258,263,292,297,303,308,313,318,323,328,333,338,343,349,354,359,364,378,384,506,517,522,527,556,561,575,581,595,608,619],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"简介",[191],{"type":192,"value":189},"text",{"type":186,"tag":194,"props":195,"children":197},"h4",{"id":196},"rotatelogs-是什么",[198],{"type":192,"value":199},"rotatelogs 是什么？",{"type":186,"tag":201,"props":202,"children":203},"p",{},[204],{"type":192,"value":205},"Apache 自带的日志轮转程序。它不独立运行，而是作为管道的接收端——Apache 往管道写日志，rotatelogs 从另一头读，到点就换个新文件接着写。",{"type":186,"tag":194,"props":207,"children":209},{"id":208},"管道机制怎么工作",[210],{"type":192,"value":211},"管道机制怎么工作？",{"type":186,"tag":201,"props":213,"children":214},{},[215,217,224,226,232],{"type":192,"value":216},"配置里写一行 ",{"type":186,"tag":218,"props":219,"children":221},"code",{"className":220},[],[222],{"type":192,"value":223},"CustomLog \"|rotatelogs /var/log/access.%Y%m%d.log 86400\" common",{"type":192,"value":225},"。Apache 启动时，管道符 ",{"type":186,"tag":218,"props":227,"children":229},{"className":228},[],[230],{"type":192,"value":231},"|",{"type":192,"value":233}," 告诉它：别写文件，启动 rotatelogs 进程，把日志喂给它。rotatelogs 拿到数据后，按你指定的规则（每天、每小时、每 100MB）切分。",{"type":186,"tag":187,"props":235,"children":237},{"id":236},"原理",[238],{"type":192,"value":236},{"type":186,"tag":194,"props":240,"children":242},{"id":241},"数据流向",[243],{"type":192,"value":241},{"type":186,"tag":245,"props":246,"children":248},"pre",{"code":247},"Apache (写 stdout) → 管道 → rotatelogs (读 stdin) → 文件系统\n",[249],{"type":186,"tag":218,"props":250,"children":251},{"__ignoreMap":178},[252],{"type":192,"value":247},{"type":186,"tag":201,"props":254,"children":255},{},[256],{"type":192,"value":257},"Apache 只管往标准输出写，不关心后面是谁。rotatelogs 只管从标准输入读，不关心前面是谁。这种解耦让 rotatelogs 可以被任何支持管道的程序使用。",{"type":186,"tag":194,"props":259,"children":261},{"id":260},"轮转触发",[262],{"type":192,"value":260},{"type":186,"tag":201,"props":264,"children":265},{},[266,268,274,276,282,284,290],{"type":192,"value":267},"两种模式：时间间隔（秒数，如 ",{"type":186,"tag":218,"props":269,"children":271},{"className":270},[],[272],{"type":192,"value":273},"86400",{"type":192,"value":275}," 表示每天）或文件大小（字节数）。时间到了或文件大了，关闭当前文件，打开新文件。文件名支持 strftime 格式，所以 ",{"type":186,"tag":218,"props":277,"children":279},{"className":278},[],[280],{"type":192,"value":281},"/var/log/access.%Y%m%d.log",{"type":192,"value":283}," 在 2024 年 3 月 15 日会变成 ",{"type":186,"tag":218,"props":285,"children":287},{"className":286},[],[288],{"type":192,"value":289},"/var/log/access.20240315.log",{"type":192,"value":291},"。",{"type":186,"tag":187,"props":293,"children":295},{"id":294},"消息边界问题",[296],{"type":192,"value":294},{"type":186,"tag":194,"props":298,"children":300},{"id":299},"问题在哪",[301],{"type":192,"value":302},"问题在哪？",{"type":186,"tag":201,"props":304,"children":305},{},[306],{"type":192,"value":307},"rotatelogs 处理的是字节流，不是消息。它不知道什么是\"一行日志\"，更不知道什么是\"一个 JSON\"。轮转时刻到了，它就切一刀——不管你写到哪。",{"type":186,"tag":194,"props":309,"children":311},{"id":310},"举个例子",[312],{"type":192,"value":310},{"type":186,"tag":201,"props":314,"children":315},{},[316],{"type":192,"value":317},"23:59:59，你的程序开始写一个 10MB 的 JSON。00:00:00，轮转时间到。这个 JSON 的前半截留在昨天的文件，后半截进了今天的文件。两边都不完整，解析时全挂。",{"type":186,"tag":194,"props":319,"children":321},{"id":320},"根本原因",[322],{"type":192,"value":320},{"type":186,"tag":201,"props":324,"children":325},{},[326],{"type":192,"value":327},"管道是字节流。rotatelogs 读到什么写什么，不缓冲、不等待、不理解边界。这不是 bug，是设计如此——简单、高效、不阻塞上游。",{"type":186,"tag":187,"props":329,"children":331},{"id":330},"解决方案",[332],{"type":192,"value":330},{"type":186,"tag":194,"props":334,"children":336},{"id":335},"应用层保证",[337],{"type":192,"value":335},{"type":186,"tag":201,"props":339,"children":340},{},[341],{"type":192,"value":342},"写入端自己负责：每条日志一行，行尾换行符作为边界。大多数日志框架都这么干。",{"type":186,"tag":194,"props":344,"children":346},{"id":345},"使用-logrotate",[347],{"type":192,"value":348},"使用 logrotate",{"type":186,"tag":201,"props":350,"children":351},{},[352],{"type":192,"value":353},"logrotate 是操作系统层面的工具，它不依赖管道。它的工作方式是：等文件写完，重命名，发信号让程序重新打开文件。这种方式尊重程序内部的缓冲逻辑，不会在半截切断消息。缺点是时间精度不如 rotatelogs——可能差几分钟。",{"type":186,"tag":194,"props":355,"children":357},{"id":356},"接受它",[358],{"type":192,"value":356},{"type":186,"tag":201,"props":360,"children":361},{},[362],{"type":192,"value":363},"如果你的日志格式本身就是行导向的（大多数 Web 服务器日志都是），而每行又足够短（几百字节到几 KB），那这个问题几乎不会遇到。只有当日志行特别大（比如嵌了 base64 图片、大 JSON）时才需要担心。",{"type":186,"tag":201,"props":365,"children":366},{},[367,369],{"type":192,"value":368},"见：",{"type":186,"tag":370,"props":371,"children":375},"a",{"href":372,"rel":373},"https://github.com/rsyslog/rsyslog/issues/409",[374],"nofollow",[376],{"type":192,"value":377},"Log messages split between files on log rotation · Issue #409",{"type":186,"tag":187,"props":379,"children":381},{"id":380},"与-logrotate-对比",[382],{"type":192,"value":383},"与 logrotate 对比",{"type":186,"tag":385,"props":386,"children":387},"table",{},[388,411],{"type":186,"tag":389,"props":390,"children":391},"thead",{},[392],{"type":186,"tag":393,"props":394,"children":395},"tr",{},[396,402,406],{"type":186,"tag":397,"props":398,"children":399},"th",{},[400],{"type":192,"value":401},"特性",{"type":186,"tag":397,"props":403,"children":404},{},[405],{"type":192,"value":179},{"type":186,"tag":397,"props":407,"children":408},{},[409],{"type":192,"value":410},"logrotate",{"type":186,"tag":412,"props":413,"children":414},"tbody",{},[415,434,452,470,488],{"type":186,"tag":393,"props":416,"children":417},{},[418,424,429],{"type":186,"tag":419,"props":420,"children":421},"td",{},[422],{"type":192,"value":423},"运行方式",{"type":186,"tag":419,"props":425,"children":426},{},[427],{"type":192,"value":428},"常驻进程，实时处理",{"type":186,"tag":419,"props":430,"children":431},{},[432],{"type":192,"value":433},"定时任务，批处理",{"type":186,"tag":393,"props":435,"child