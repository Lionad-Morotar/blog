1,189,216,222,232,237,245,250,255,260,293,298,316,321,326,331],{"type":182,"tag":183,"props":184,"children":185},"element","p",{},[186],{"type":187,"value":188},"text","以下在 LeanCloud CM Guide 的基础上，我们整理了一份尽量简单且能记录代码提交意义的约定。",{"type":182,"tag":190,"props":191,"children":192},"ul",{},[193,206],{"type":182,"tag":194,"props":195,"children":196},"li",{},[197],{"type":182,"tag":198,"props":199,"children":203},"a",{"href":200,"rel":201},"https://www.conventionalcommits.org/zh-hans/v1.0.0/",[202],"nofollow",[204],{"type":187,"value":205},"Conventional commits",{"type":182,"tag":194,"props":207,"children":208},{},[209],{"type":182,"tag":198,"props":210,"children":213},{"href":211,"rel":212},"https://conventional-branch.github.io/zh/",[202],[214],{"type":187,"value":215},"Conventional branch",{"type":182,"tag":217,"props":218,"children":220},"h4",{"id":219},"主要格式",[221],{"type":187,"value":219},{"type":182,"tag":223,"props":224,"children":226},"pre",{"code":225},"提交类型：变动内容，简短描述，50 个字符\n\n提交描述，可选，72 字符内，说明该提交的原因，或是提交的副作用。与第一行之间存在空行\n\n注释及其它，可选\n",[227],{"type":182,"tag":228,"props":229,"children":230},"code",{"__ignoreMap":175},[231],{"type":187,"value":225},{"type":182,"tag":217,"props":233,"children":235},{"id":234},"简单示例",[236],{"type":187,"value":234},{"type":182,"tag":223,"props":238,"children":240},{"code":239},"fix: 更改 VuePress 版本，修复布局错乱问题\n\nhttps://github.com/vuejs/vuepress/issues/1321\n",[241],{"type":182,"tag":228,"props":242,"children":243},{"__ignoreMap":175},[244],{"type":187,"value":239},{"type":182,"tag":183,"props":246,"children":247},{},[248],{"type":187,"value":249},"上面这个示例是一种“修复类型（fix）”示例，其描述链接了一个 GitHub Issue。",{"type":182,"tag":217,"props":251,"children":253},{"id":252},"类型说明",[254],{"type":187,"value":252},{"type":182,"tag":183,"props":256,"children":257},{},[258],{"type":187,"value":259},"类型有多种可能，以下几种是必须遵守的约定：",{"type":182,"tag":190,"props":261,"children":262},{},[263,268,273,278,283,288],{"type":182,"tag":194,"props":264,"children":265},{},[266],{"type":187,"value":267},"fix：错误修复",{"type":182,"tag":194,"props":269,"children":270},{},[271],{"type":187,"value":272},"feat：新功能",{"type":182,"tag":194,"props":274,"children":275},{},[276],{"type":187,"value":277},"chore：其它修改，如项目配置变动，构建任务变动",{"type":182,"tag":194,"props":279,"children":280},{},[281],{"type":187,"value":282},"doc：注释或文档",{"type":182,"tag":194,"props":284,"children":285},{},[286],{"type":187,"value":287},"format：代码改动（仅代码样式变更，如换行、分号）",{"type":182,"tag":194,"props":289,"children":290},{},[291],{"type":187,"value":292},"css：前端界面样式变更",{"type":182,"tag":183,"props":294,"children":295},{},[296],{"type":187,"value":297},"此外，还有一些类型可供参考及选用：",{"type":182,"tag":190,"props":299,"children":300},{},[301,306,311],{"type":182,"tag":194,"props":302,"children":303},{},[304],{"type":187,"value":305},"refactor：代码重构",{"type":182,"tag":194,"props":307,"children":308},{},[309],{"type":187,"value":310},"perf：代码重构（仅性能改进）",{"type":182,"tag":194,"props":312,"children":313},{},[314],{"type":187,"value":315},"test：与测试相关的改动",{"type":182,"tag":183,"props":317,"children":318},{},[319],{"type":187,"value":320},"原则来说，依据不同项目，CM 规范可以做适当调整。以上只展现了一种通用的基础约定，具体项目可以在此基础上自行增添规则。如我的个人博客项目 CM 中，有一种“blogs”类型专门用作记录博客文字内容的修改。",{"type":182,"tag":217,"props":322,"children":324},{"id":323},"特殊标记",[325],{"type":187,"value":323},{"type":182,"tag":183,"props":327,"children":328},{},[329],{"type":187,"value":330},"特殊标记用作标注注意事项，如“BREAKING”、“close”标记的使用。特殊标记通常与项目工程化实践中其它工具配合使用，如用于关闭 GitLab Issues，后续有需要再展开约定。",{"type":182,"tag":223,"props":332,"children":334},{"code":333},"feat: 大盘中国地图增加地图下钻功能\n\n引入中国的省市映射文件，以通过选取的省找到省下所有城市内的店铺。\n\nBREAKING: 下钻功能导致了地图缩放时错位的问题，所以暂时禁用了地图的拖拽能力\n",[335],{"type":182,"tag":228,"props":336,"children":337},{"__ignoreMap":175},[338],{"type":187,"value":333},{"title":175,"searchDepth":340,"depth":340,"links":341},2,[],"markdown","content:6.maps:_devops:git:dorothy.md","content","6.maps/_devops/git/dorothy.md","6.maps/_devops/git/dorothy","md",[349,353],{"_path":350,"title":351,"description"