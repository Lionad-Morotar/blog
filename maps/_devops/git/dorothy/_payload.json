的约定。",{"type":182,"children":183,"toc":342},"root",[184,192,219,225,235,240,248,253,258,263,296,301,319,324,329,334],{"type":185,"tag":186,"props":187,"children":188},"element","p",{},[189],{"type":190,"value":191},"text","以下在 LeanCloud CM Guide 的基础上，我们整理了一份尽量简单且能记录代码提交意义的约定。",{"type":185,"tag":193,"props":194,"children":195},"ul",{},[196,209],{"type":185,"tag":197,"props":198,"children":199},"li",{},[200],{"type":185,"tag":201,"props":202,"children":206},"a",{"href":203,"rel":204},"https://www.conventionalcommits.org/zh-hans/v1.0.0/",[205],"nofollow",[207],{"type":190,"value":208},"Conventional commits",{"type":185,"tag":197,"props":210,"children":211},{},[212],{"type":185,"tag":201,"props":213,"children":216},{"href":214,"rel":215},"https://conventional-branch.github.io/zh/",[205],[217],{"type":190,"value":218},"Conventional branch",{"type":185,"tag":220,"props":221,"children":223},"h4",{"id":222},"主要格式",[224],{"type":190,"value":222},{"type":185,"tag":226,"props":227,"children":229},"pre",{"code":228},"提交类型：变动内容，简短描述，50 个字符\n\n提交描述，可选，72 字符内，说明该提交的原因，或是提交的副作用。与第一行之间存在空行\n\n注释及其它，可选\n",[230],{"type":185,"tag":231,"props":232,"children":233},"code",{"__ignoreMap":178},[234],{"type":190,"value":228},{"type":185,"tag":220,"props":236,"children":238},{"id":237},"简单示例",[239],{"type":190,"value":237},{"type":185,"tag":226,"props":241,"children":243},{"code":242},"fix: 更改 VuePress 版本，修复布局错乱问题\n\nhttps://github.com/vuejs/vuepress/issues/1321\n",[244],{"type":185,"tag":231,"props":245,"children":246},{"__ignoreMap":178},[247],{"type":190,"value":242},{"type":185,"tag":186,"props":249,"children":250},{},[251],{"type":190,"value":252},"上面这个示例是一种“修复类型（fix）”示例，其描述链接了一个 GitHub Issue。",{"type":185,"tag":220,"props":254,"children":256},{"id":255},"类型说明",[257],{"type":190,"value":255},{"type":185,"tag":186,"props":259,"children":260},{},[261],{"type":190,"value":262},"类型有多种可能，以下几种是必须遵守的约定：",{"type":185,"tag":193,"props":264,"children":265},{},[266,271,276,281,286,291],{"type":185,"tag":197,"props":267,"children":268},{},[269],{"type":190,"value":270},"fix：错误修复",{"type":185,"tag":197,"props":272,"children":273},{},[274],{"type":190,"value":275},"feat：新功能",{"type":185,"tag":197,"props":277,"children":278},{},[279],{"type":190,"value":280},"chore：其它修改，如项目配置变动，构建任务变动",{"type":185,"tag":197,"props":282,"children":283},{},[284],{"type":190,"value":285},"doc：注释或文档",{"type":185,"tag":197,"props":287,"children":288},{},[289],{"type":190,"value":290},"format：代码改动（仅代码样式变更，如换行、分号）",{"type":185,"tag":197,"props":292,"children":293},{},[294],{"type":190,"value":295},"css：前端界面样式变更",{"type":185,"tag":186,"props":297,"children":298},{},[299],{"type":190,"value":300},"此外，还有一些类型可供参考及选用：",{"type":185,"tag":193,"props":302,"children":303},{},[304,309,314],{"type":185,"tag":197,"props":305,"children":306},{},[307],{"type":190,"value":308},"refactor：代码重构",{"type":185,"tag":197,"props":310,"children":311},{},[312],{"type":190,"value":313},"perf：代码重构（仅性能改进）",{"type":185,"tag":197,"props":315,"children":316},{},[317],{"type":190,"value":318},"test：与测试相关的改动",{"type":185,"tag":186,"props":320,"children":321},{},[322],{"type":190,"value":323},"原则来说，依据不同项目，CM 规范可以做适当调整。以上只展现了一种通用的基础约定，具体项目可以在此基础上自行增添规则。如我的个人博客项目 CM 中，有一种“blogs”类型专门用作记录博客文字内容的修改。",{"type":185,"tag":220,"props":325,"children":327},{"id":326},"特殊标记",[328],{"type":190,"value":326},{"type":185,"tag":186,"props":330,"children":331},{},[332],{"type":190,"value":333},"特殊标记用作标注注意事项，如“BREAKING”、“close”标记的使用。特殊标记通常与项目工程化实践中其它工具配合使用，如用于关闭 GitLab Issues，后续有需要再展开约定。",{"type":185,"tag":226,"props":335,"children":337},{"code":336},"feat: 大盘中国地图增加地图下钻功能\n\n引入中国的省市映射文件，以通过选取的省找到省下所有城市内的店铺。\n\nBREAKING: 下钻功能导致了地图缩放时错位的问题，所以暂时禁用了地图的拖拽能力\n",[338],{"type":185,"tag":231,"props":339,"children":340},{"__ignoreMap":178},[341],{"type":190,"value":336},{"title":178,"searchDepth":343,"depth":343,"links":344},2,[],"markdown","content:6.maps:_devops:git:dorothy.md","content","6.maps/_devops/git/dorothy.md","6.maps/_devops/git/dorothy"