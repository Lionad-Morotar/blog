Git 的 pre-commit hook 用来在提交代码前执行一些检查或操作",{"type":179,"children":180,"toc":1499},"root",[181,188,195,200,205,210,216,223,325,331,342,622,635,728,734,739,813,823,837,849,867,1243,1248,1292,1305,1311,1445,1453,1493],{"type":182,"tag":183,"props":184,"children":185},"element","p",{},[186],{"type":187,"value":177},"text",{"type":182,"tag":189,"props":190,"children":192},"h2",{"id":191},"brief",[193],{"type":187,"value":194},"Brief",{"type":182,"tag":183,"props":196,"children":197},{},[198],{"type":187,"value":199},"Git 钩子已经存在很久了，但我们认为它们依然没有被充分利用。随着 AI 辅助与智能体式编程（agentic coding）的兴起，意外提交密钥或有问题的代码的风险正在增加。虽然已有很多代码校验机制（比如持续集成 CI），但预提交钩子是一种简单而有效的安全防线，值得更多团队采用。",{"type":182,"tag":183,"props":201,"children":202},{},[203],{"type":187,"value":204},"不过，如果在钩子中塞入大量运行缓慢的检查，会让开发者不愿意使用它们。因此，最好保持预提交钩子“精简”和“聚焦”，只做那些在工作流的这一阶段最适合发现的高价值风险，比如密钥扫描（secret scanning）。",{"type":182,"tag":183,"props":206,"children":207},{},[208],{"type":187,"value":209},"来源：技术雷达",{"type":182,"tag":189,"props":211,"children":213},{"id":212},"guide",[214],{"type":187,"value":215},"Guide",{"type":182,"tag":217,"props":218,"children":220},"h3",{"id":219},"一为什么预提交钩子在-ai-时代更重要",[221],{"type":187,"value":222},"一、为什么预提交钩子在 AI 时代更重要？",{"type":182,"tag":224,"props":225,"children":226},"ol",{},[227,267,300],{"type":182,"tag":228,"props":229,"children":230},"li",{},[231,237,241,243,262,265],{"type":182,"tag":232,"props":233,"children":234},"strong",{},[235],{"type":187,"value":236},"AI 生成代码的“过度自信”问题",{"type":182,"tag":238,"props":239,"children":240},"br",{},[],{"type":187,"value":242},"\nAI 工具（包括智能体型 Coding Agent）能快速生成大量代码、配置和脚本，其中可能包含：",{"type":182,"tag":244,"props":245,"children":246},"ul",{},[247,252,257],{"type":182,"tag":228,"props":248,"children":249},{},[250],{"type":187,"value":251},"硬编码的访问密钥、Token、密码",{"type":182,"tag":228,"props":253,"children":254},{},[255],{"type":187,"value":256},"临时调试代码（如关闭鉴权、跳过校验）",{"type":182,"tag":228,"props":258,"children":259},{},[260],{"type":187,"value":261},"不符合团队规范的接口调用或依赖",{"type":182,"tag":238,"props":263,"children":264},{},[],{"type":187,"value":266},"在高速度迭代下，开发者很容易“复制-粘贴-提交”，预提交钩子相当于最后一道“本地闸门”。",{"type":182,"tag":228,"props":268,"children":269},{},[270,275,295,298],{"type":182,"tag":232,"props":271,"children":272},{},[273],{"type":187,"value":274},"补充而不是替代 CI / 代码审查",{"type":182,"tag":244,"props":276,"children":277},{},[278,283],{"type":182,"tag":228,"props":279,"children":280},{},[281],{"type":187,"value":282},"CI 更适合：完整测试、构建、静态分析、复杂安全扫描。",{"type":182,"tag":228,"props":284,"children":285},{},[286,288,293],{"type":187,"value":287},"Pre-commit 更适合：",{"type":182,"tag":232,"props":289,"children":290},{},[291],{"type":187,"value":292},"极快速、与“变更内容”强绑定",{"type":187,"value":294},"的检查。",{"type":182,"tag":238,"props":296,"children":297},{},[],{"type":187,"value":299},"换句话说，预提交钩子是“低成本、即时反馈”；CI 是“高覆盖、稍延时反馈”。",{"type":182,"tag":228,"props":301,"children":302},{},[303,308,311,313,316,318,323],{"type":182,"tag":232,"props":304,"children":305},{},[306],{"type":187,"value":307},"把错误截断在最便宜的阶段",{"type":182,"tag":238,"props":309,"children":310},{},[],{"type":187,"value":312},"\n错误在不同阶段被发现的成本呈指数上升：\n$$本地开发 \u003C pre-commit \u003C PR 代码审查 \u003C CI \u003C 生产环境$$",{"type":182,"tag":238,"props":314,"children":315},{},[],{"type":187,"value":317},"\n预提交钩子的目标就是：",{"type":182,"tag":232,"props":319,"children":320},{},[321],{"type":187,"value":322},"在提交之前阻止显而易见的错误泄漏到后续环节",{"type":187,"value":324},"。",{"type":182,"tag":217,"props":326,"children":328},{"id":327},"二预提交钩子适合放哪些检查",[329],{"type":187,"value":330},"二、预提交钩子适合放哪些检查？",{"type":182,"tag":183,"props":332,"children":333},{},[334,336,341],{"type":187,"value":335},"原则：",{"type":182,"tag":232,"props":337,"children":338},{},[339],{"type":187,"value":340},"秒级完成、直接作用于当前变更、价值高于打扰成本",{"type":187,"value":324},{"type":182,"tag":224,"props":343,"children":344},{},[345,433,506,573],{"type":182,"tag":228,"props":346,"children":347},{},[348,353],{"type":182,"tag":232,"props":349,"children":350},{},[351],{"type":187,"value":352},"密钥 / 