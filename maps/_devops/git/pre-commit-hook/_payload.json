,1283,1287],{"type":182,"tag":878,"props":1280,"children":1281},{"style":1262},[1282],{"type":187,"value":834},{"type":182,"tag":878,"props":1284,"children":1285},{"style":926},[1286],{"type":187,"value":1270},{"type":182,"tag":878,"props":1288,"children":1289},{"style":901},[1290],{"type":187,"value":1291},"   # 在 .git/hooks 配置 pre-commit\n",{"type":182,"tag":183,"props":1293,"children":1294},{},[1295,1297,1303],{"type":187,"value":1296},"之后每次 ",{"type":182,"tag":391,"props":1298,"children":1300},{"className":1299},[],[1301],{"type":187,"value":1302},"git commit",{"type":187,"value":1304},"，这些检查都会在本地自动运行。",{"type":182,"tag":217,"props":1306,"children":1308},{"id":1307},"六团队落地与推广建议",[1309],{"type":187,"value":1310},"六、团队落地与推广建议",{"type":182,"tag":224,"props":1312,"children":1313},{},[1314,1335,1384,1424],{"type":182,"tag":228,"props":1315,"children":1316},{},[1317,1322],{"type":182,"tag":232,"props":1318,"children":1319},{},[1320],{"type":187,"value":1321},"从最小可用集合开始",{"type":182,"tag":244,"props":1323,"children":1324},{},[1325,1330],{"type":182,"tag":228,"props":1326,"children":1327},{},[1328],{"type":187,"value":1329},"第一步只上：密钥扫描 + 基础格式化 + 大文件检查",{"type":182,"tag":228,"props":1331,"children":1332},{},[1333],{"type":187,"value":1334},"观察一段时间后，根据反馈逐步添加其他规则。",{"type":182,"tag":228,"props":1336,"children":1337},{},[1338,1343],{"type":182,"tag":232,"props":1339,"children":1340},{},[1341],{"type":187,"value":1342},"给开发者提供“快速修复指引”",{"type":182,"tag":244,"props":1344,"children":1345},{},[1346],{"type":182,"tag":228,"props":1347,"children":1348},{},[1349,1351],{"type":187,"value":1350},"不只是报错信息，更要告诉开发者：\n",{"type":182,"tag":244,"props":1352,"children":1353},{},[1354,1359,1379],{"type":182,"tag":228,"props":1355,"children":1356},{},[1357],{"type":187,"value":1358},"问题是什么？",{"type":182,"tag":228,"props":1360,"children":1361},{},[1362,1364,1370,1371,1377],{"type":187,"value":1363},"如何一条命令修复（例如：",{"type":182,"tag":391,"props":1365,"children":1367},{"className":1366},[],[1368],{"type":187,"value":1369},"npm run lint-fix",{"type":187,"value":398},{"type":182,"tag":391,"props":1372,"children":1374},{"className":1373},[],[1375],{"type":187,"value":1376},"prettier --write ...",{"type":187,"value":1378},"）",{"type":182,"tag":228,"props":1380,"children":1381},{},[1382],{"type":187,"value":1383},"若是疑似密钥，提示使用环境变量 / 密钥管理服务并从历史中清理。",{"type":182,"tag":228,"props":1385,"children":1386},{},[1387,1392],{"type":182,"tag":232,"props":1388,"children":1389},{},[1390],{"type":187,"value":1391},"建立“允许临时跳过，但要留痕”的机制",{"type":182,"tag":244,"props":1393,"children":1394},{},[1395,1419],{"type":182,"tag":228,"props":1396,"children":1397},{},[1398,1400],{"type":187,"value":1399},"比如约定：\n",{"type":182,"tag":244,"props":1401,"children":1402},{},[1403,1414],{"type":182,"tag":228,"props":1404,"children":1405},{},[1406,1408],{"type":187,"value":1407},"只有在特殊情况下允许 ",{"type":182,"tag":391,"props":1409,"children":1411},{"className":1410},[],[1412],{"type":187,"value":1413},"git commit --no-verify",{"type":182,"tag":228,"props":1415,"children":1416},{},[1417],{"type":187,"value":1418},"在 PR 描述中写明原因",{"type":182,"tag":228,"props":1420,"children":1421},{},[1422],{"type":187,"value":1423},"这样在保持灵活性的同时，降低滥用风险。",{"type":182,"tag":228,"props":1425,"children":1426},{},[1427,1432],{"type":182,"tag":232,"props":1428,"children":1429},{},[1430],{"type":187,"value":1431},"将 pre-commit 规则视为“团队契约”",{"type":182,"tag":244,"props":1433,"children":1434},{},[1435,1440],{"type":182,"tag":228,"props":1436,"children":1437},{},[1438],{"type":187,"value":1439},"不要个人随意修改；",{"type":182,"tag":228,"props":1441,"children":1442},{},[1443],{"type":187,"value":1444},"通过 PR 调整，团队评审后合入，保证所有人理解这些检查的价值。",{"type":182,"tag":183,"props":1446,"children":1447},{},[1448],{"type":182,"tag":232,"props":1449,"children":1450},{},[1451],{"type":187,"value":1452},"总结",{"type":182,"tag":244,"props":1454,"children":1455},{},[1456,1461,1473],{"type":182,"tag":228,"props":1457,"children":1458},{},[1459],{"type":187,"value":1460},"预提交钩子是 AI 时代防止意外提交密钥、危险代码的一道“本地防线”。",{"type":182,"tag":228,"props":1462,"children":1463},{},[1464,1466,1471],{"type":187,"value":1465},"关键在于：",{"type":182,"tag":232,"props":1467,"children":1468},{},[1469],{"type":187,"value":1470},"轻量、高频、高价值",{"type":187,"value":1472},"，而不是“把所有检查都塞进去”。",{"type":182,"tag":228,"props":1474,"children":1475},{},[1476,1478,1481,1483,1486,1488,1491],{"type":187,"value":1477},"推荐至少启用：",{"type":182,"tag":238,"props":1479,"children":1480},{},[],{"type":187,"value":1482},"\n1）密钥 / 凭证扫描",{"type":182,"tag":238,"props":1484,"children":1485},{},[],{"type":187,"value":1487},"\n2）基础格式化 & 简单 lint",{"type":182,"tag":238,"props":1489,"children":1490},{},[],{"type":187,"value":1492},"\n3）阻止大文件、临时文件、生成产物进入仓库",{"type":182,"tag":1494,"props":1495,"children":1496},"style",{},[1497],{"type":187,"value":1498},"html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--s