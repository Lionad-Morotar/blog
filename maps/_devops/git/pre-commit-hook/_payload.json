,454],{"type":182,"tag":228,"props":450,"children":451},{},[452],{"type":187,"value":453},"自动修正能自动修的（格式化、简单 lint）",{"type":182,"tag":228,"props":455,"children":456},{},[457],{"type":187,"value":458},"减少 PR 上来回评论“多了个空格”这类低价值沟通",{"type":182,"tag":238,"props":460,"children":461},{},[],{"type":187,"value":463},"例如：",{"type":182,"tag":244,"props":465,"children":466},{},[467,493],{"type":182,"tag":228,"props":468,"children":469},{},[470,472,478,479,485,486,492],{"type":187,"value":471},"自动格式化：",{"type":182,"tag":391,"props":473,"children":475},{"className":474},[],[476],{"type":187,"value":477},"prettier",{"type":187,"value":398},{"type":182,"tag":391,"props":480,"children":482},{"className":481},[],[483],{"type":187,"value":484},"black",{"type":187,"value":398},{"type":182,"tag":391,"props":487,"children":489},{"className":488},[],[490],{"type":187,"value":491},"gofmt",{"type":187,"value":413},{"type":182,"tag":228,"props":494,"children":495},{},[496,498,504],{"type":187,"value":497},"关键的快速 Lint：例如只对变更文件执行 ",{"type":182,"tag":391,"props":499,"children":501},{"className":500},[],[502],{"type":187,"value":503},"eslint --max-warnings=0",{"type":187,"value":505},"（简单规则集）",{"type":182,"tag":228,"props":507,"children":508},{},[509,514],{"type":182,"tag":232,"props":510,"children":511},{},[512],{"type":187,"value":513},"禁止明显危险的文件 / 内容进入仓库",{"type":182,"tag":244,"props":515,"children":516},{},[517,568],{"type":182,"tag":228,"props":518,"children":519},{},[520,522],{"type":187,"value":521},"阻止：\n",{"type":182,"tag":244,"props":523,"children":524},{},[525,530,549],{"type":182,"tag":228,"props":526,"children":527},{},[528],{"type":187,"value":529},"大体积二进制文件（超过某阈值）",{"type":182,"tag":228,"props":531,"children":532},{},[533,535,541,542,548],{"type":187,"value":534},"临时文件：",{"type":182,"tag":391,"props":536,"children":538},{"className":537},[],[539],{"type":187,"value":540},"*.log",{"type":187,"value":398},{"type":182,"tag":391,"props":543,"children":545},{"className":544},[],[546],{"