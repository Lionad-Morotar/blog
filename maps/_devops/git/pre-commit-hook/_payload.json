ype":185,"tag":247,"props":450,"children":451},{},[452,457],{"type":185,"tag":231,"props":453,"children":454},{},[455],{"type":190,"value":456},"自动修正能自动修的（格式化、简单 lint）",{"type":185,"tag":231,"props":458,"children":459},{},[460],{"type":190,"value":461},"减少 PR 上来回评论“多了个空格”这类低价值沟通",{"type":185,"tag":241,"props":463,"children":464},{},[],{"type":190,"value":466},"例如：",{"type":185,"tag":247,"props":468,"children":469},{},[470,496],{"type":185,"tag":231,"props":471,"children":472},{},[473,475,481,482,488,489,495],{"type":190,"value":474},"自动格式化：",{"type":185,"tag":394,"props":476,"children":478},{"className":477},[],[479],{"type":190,"value":480},"prettier",{"type":190,"value":401},{"type":185,"tag":394,"props":483,"children":485},{"className":484},[],[486],{"type":190,"value":487},"black",{"type":190,"value":401},{"type":185,"tag":394,"props":490,"children":492},{"className":491},[],[493],{"type":190,"value":494},"gofmt",{"type":190,"value":416},{"type":185,"tag":231,"props":497,"children":498},{},[499,501,507],{"type":190,"value":500},"关键的快速 Lint：例如只对变更文件执行 ",{"type":185,"tag":394,"props":502,"children":504},{"className":503},[],[505],{"type":190,"value":506},"eslint --max-warnings=0",{"type":190,"value":508},"（简单规则集）",{"type":185,"tag":231,"props":510,"children":511},{},[512,517],{"type":185,"tag":235,"props":513,"children":514},{},[515],{"type":190,"value":516},"禁止明显危险的文件 / 内容进入仓库",{"type":185,"tag":247,"props":518,"children":519},{},[520,571],{"type":185,"tag":231,"props":521,"children":522},{},[523,525],{"type":190,"value":524},"阻止：\n",{"type":185,"tag":247,"props":526,"children":527},{},[528,533,552],{"type":185,"tag":231,"props":529,"children":530},{},[531],{"type":190,"value":532},"大体积二进制文件（超过某阈值）",{"type":185,"tag":231,"props":534,"children":535},{},[536,538,544,545,551],{"type":190,"value":537},"临时文件：",{"type":185,"tag":394,"props":539,"children":541},{"className":540},[],[542],{"type":190,"value":543},"*.log",{"type":190,"value":401},{"type":185,"tag":394,"pr