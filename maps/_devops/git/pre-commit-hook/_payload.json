t Hook","title: 预提交钩子（Pre-commit hooks）\ndescription: Git 的 pre-commit hook 用来在提交代码前执行一些检查或操作",{"type":182,"children":183,"toc":1502},"root",[184,191,198,203,208,213,219,226,328,334,345,625,638,731,737,742,816,826,840,852,870,1246,1251,1295,1308,1314,1448,1456,1496],{"type":185,"tag":186,"props":187,"children":188},"element","p",{},[189],{"type":190,"value":180},"text",{"type":185,"tag":192,"props":193,"children":195},"h2",{"id":194},"brief",[196],{"type":190,"value":197},"Brief",{"type":185,"tag":186,"props":199,"children":200},{},[201],{"type":190,"value":202},"Git 钩子已经存在很久了，但我们认为它们依然没有被充分利用。随着 AI 辅助与智能体式编程（agentic coding）的兴起，意外提交密钥或有问题的代码的风险正在增加。虽然已有很多代码校验机制（比如持续集成 CI），但预提交钩子是一种简单而有效的安全防线，值得更多团队采用。",{"type":185,"tag":186,"props":204,"children":205},{},[206],{"type":190,"value":207},"不过，如果在钩子中塞入大量运行缓慢的检查，会让开发者不愿意使用它们。因此，最好保持预提交钩子“精简”和“聚焦”，只做那些在工作流的这一阶段最适合发现的高价值风险，比如密钥扫描（secret scanning）。",{"type":185,"tag":186,"props":209,"children":210},{},[211],{"type":190,"value":212},"来源：技术雷达",{"type":185,"tag":192,"props":214,"children":216},{"id":215},"guide",[217],{"type":190,"value":218},"Guide",{"type":185,"tag":220,"props":221,"children":223},"h3",{"id":222},"一为什么预提交钩子在-ai-时代更重要",[224],{"type":190,"value":225},"一、为什么预提交钩子在 AI 时代更重要？",{"type":185,"tag":227,"props":228,"children":229},"ol",{},[230,270,303],{"type":185,"tag":231,"props":232,"children":233},"li",{},[234,240,244,246,265,268],{"type":185,"tag":235,"props":236,"children":237},"strong",{},[238],{"type":190,"value":239},"AI 生成代码的“过度自信”问题",{"type":185,"tag":241,"props":242,"children":243},"br",{},[],{"type":190,"value":245},"\nAI 工具（包括智能体型 Coding Agent）能快速生成大量代码、配置和脚本，其中可能包含：",{"type":185,"tag":247,"props":248,"children":249},"ul",{},[250,255,260],{"type":185,"tag":231,"props":251,"children":252},{},[253],{"type":190,"value":254},"硬编码的访问密钥、Token、密码",{"type":185,"tag":231,"props":256,"children":257},{},[258],{"type":190,"value":259},"临时调试代码（如关闭鉴权、跳过校验）",{"type":185,"tag":231,"props":261,"children":262},{},[263],{"type":190,"value":264},"不符合团队规范的接口调用或依赖",{"type":185,"tag":241,"props":266,"children":267},{},[],{"type":190,"value":269},"在高速度迭代下，开发者很容易“复制-粘贴-提交”，预提交钩子相当于最后一道“本地闸门”。",{"type":185,"tag":231,"props":271,"children":272},{},[273,278,298,301],{"type":185,"tag":235,"props":274,"children":275},{},[276],{"type":190,"value":277},"补充而不是替代 CI / 代码审查",{"type":185,"tag":247,"props":279,"children":280},{},[281,286],{"type":185,"tag":231,"props":282,"children":283},{},[284],{"type":190,"value":285},"CI 更适合：完整测试、构建、静态分析、复杂安全扫描。",{"type":185,"tag":231,"props":287,"children":288},{},[289,291,296],{"type":190,"value":290},"Pre-commit 更适合：",{"type":185,"tag":235,"props":292,"children":293},{},[294],{"type":190,"value":295},"极快速、与“变更内容”强绑定",{"type":190,"value":297},"的检查。",{"type":185,"tag":241,"props":299,"children":300},{},[],{"type":190,"value":302},"换句话说，预提交钩子是“低成本、即时反馈”；CI 是“高覆盖、稍延时反馈”。",{"type":185,"tag":231,"props":304,"children":305},{},[306,311,314,316,319,321,326],{"type":185,"tag":235,"props":307,"children":308},{},[309],{"type":190,"value":310},"把错误截断在最便宜的阶段",{"type":185,"tag":241,"props":312,"children":313},{},[],{"type":190,"value":315},"\n错误在不同阶段被发现的成本呈指数上升：\n$$本地开发 \u003C pre-commit \u003C PR 代码审查 \u003C CI \u003C 生产环境$$",{"type":185,"tag":241,"props":317,"children":318},{},[],{"type":190,"value":320},"\n预提交钩子的目标就是：",{"type":185,"tag":235,"props":322,"children":323},{},[324],{"type":190,"value":325},"在提交之前阻止显而易见的错误泄漏到后续环节",{"type":190,"value":327},"。",{"type":185,"tag":220,"props":329,"children":331},{"id":330},"二预提交钩子适合放哪些检查",[332],{"type":190,"value":333},"二、预提交钩子适合放哪些检查？",{"type":185,"tag":186,"props":335,"children":336},{},[337,339,344],{"type":190,"value":338},"原则：",{"type":185,"tag":235,"props":340,"children":341},{},[342],{"type":190,"value":343},"秒级完成、直接作用于当前变更、价值高于打扰成本",{"type":190,"value":327},{"type":185,"tag":227,"props":346,"children":347},{},[348,436,509,576],{"type":185,"tag":231,"props":349,"children":350},{},[351,356],{"type":185,"tag":235,"props":352,"c