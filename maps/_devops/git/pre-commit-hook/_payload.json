ops":1280,"children":1281},{"class":883,"line":900},[1282,1286,1290],{"type":185,"tag":881,"props":1283,"children":1284},{"style":1265},[1285],{"type":190,"value":837},{"type":185,"tag":881,"props":1287,"children":1288},{"style":929},[1289],{"type":190,"value":1273},{"type":185,"tag":881,"props":1291,"children":1292},{"style":904},[1293],{"type":190,"value":1294},"   # 在 .git/hooks 配置 pre-commit\n",{"type":185,"tag":186,"props":1296,"children":1297},{},[1298,1300,1306],{"type":190,"value":1299},"之后每次 ",{"type":185,"tag":394,"props":1301,"children":1303},{"className":1302},[],[1304],{"type":190,"value":1305},"git commit",{"type":190,"value":1307},"，这些检查都会在本地自动运行。",{"type":185,"tag":220,"props":1309,"children":1311},{"id":1310},"六团队落地与推广建议",[1312],{"type":190,"value":1313},"六、团队落地与推广建议",{"type":185,"tag":227,"props":1315,"children":1316},{},[1317,1338,1387,1427],{"type":185,"tag":231,"props":1318,"children":1319},{},[1320,1325],{"type":185,"tag":235,"props":1321,"children":1322},{},[1323],{"type":190,"value":1324},"从最小可用集合开始",{"type":185,"tag":247,"props":1326,"children":1327},{},[1328,1333],{"type":185,"tag":231,"props":1329,"children":1330},{},[1331],{"type":190,"value":1332},"第一步只上：密钥扫描 + 基础格式化 + 大文件检查",{"type":185,"tag":231,"props":1334,"children":1335},{},[1336],{"type":190,"value":1337},"观察一段时间后，根据反馈逐步添加其他规则。",{"type":185,"tag":231,"props":1339,"children":1340},{},[1341,1346],{"type":185,"tag":235,"props":1342,"children":1343},{},[1344],{"type":190,"value":1345},"给开发者提供“快速修复指引”",{"type":185,"tag":247,"props":1347,"children":1348},{},[1349],{"type":185,"tag":231,"props":1350,"children":1351},{},[1352,1354],{"type":190,"value":1353},"不只是报错信息，更要告诉开发者：\n",{"type":185,"tag":247,"props":1355,"children":1356},{},[1357,1362,1382],{"type":185,"tag":231,"props":1358,"children":1359},{},[1360],{"type":190,"value":1361},"问题是什么？",{"type":185,"tag":231,"props":1363,"children":1364},{},[1365,1367,1373,1374,1380],{"type":190,"value":1366},"如何一条命令修复（例如：",{"type":185,"tag":394,"props":1368,"children":1370},{"className":1369},[],[1371],{"type":190,"value":1372},"npm run lint-fix",{"type":190,"value":401},{"type":185,"tag":394,"props":1375,"children":1377},{"className":1376},[],[1378],{"type":190,"value":1379},"prettier --write ...",{"type":190,"value":1381},"）",{"type":185,"tag":231,"props":1383,"children":1384},{},[1385],{"type":190,"value":1386},"若是疑似密钥，提示使用环境变量 / 密钥管理服务并从历史中清理。",{"type":185,"tag":231,"props":1388,"children":1389},{},[1390,1395],{"type":185,"tag":235,"props":1391,"children":1392},{},[1393],{"type":190,"value":1394},"建立“允许临时跳过，但要留痕”的机制",{"type":185,"tag":247,"props":1396,"children":1397},{},[1398,1422],{"type":185,"tag":231,"props":1399,"children":1400},{},[1401,1403],{"type":190,"value":1402},"比如约定：\n",{"type":185,"tag":247,"props":1404,"children":1405},{},[1406,1417],{"type":185,"tag":231,"props":1407,"children":1408},{},[1409,1411],{"type":190,"value":1410},"只有在特殊情况下允许 ",{"type":185,"tag":394,"props":1412,"children":1414},{"className":1413},[],[1415],{"type":190,"value":1416},"git commit --no-verify",{"type":185,"tag":231,"props":1418,"children":1419},{},[1420],{"type":190,"value":1421},"在 PR 描述中写明原因",{"type":185,"tag":231,"props":1423,"children":1424},{},[1425],{"type":190,"value":1426},"这样在保持灵活性的同时，降低滥用风险。",{"type":185,"tag":231,"props":1428,"children":1429},{},[1430,1435],{"type":185,"tag":235,"props":1431,"children":1432},{},[1433],{"type":190,"value":1434},"将 pre-commit 规则视为“团队契约”",{"type":185,"tag":247,"props":1436,"children":1437},{},[1438,1443],{"type":185,"tag":231,"props":1439,"children":1440},{},[1441],{"type":190,"value":1442},"不要个人随意修改；",{"type":185,"tag":231,"props":1444,"children":1445},{},[1446],{"type":190,"value":1447},"通过 PR 调整，团队评审后合入，保证所有人理解这些检查的价值。",{"type":185,"tag":186,"props":1449,"children":1450},{},[1451],{"type":185,"tag":235,"props":1452,"children":1453},{},[1454],{"type":190,"value":1455},"总结",{"type":185,"tag":247,"props":1457,"children":1458},{},[1459,1464,1476],{"type":185,"tag":231,"props":1460,"children":1461},{},[1462],{"type":190,"value":1463},"预提交钩子是 AI 时代防止意外提交密钥、危险代码的一道“本地防线”。",{"type":185,"tag":231,"props":1465,"children":1466},{},[1467,1469,1474],{"type":190,"value":1468},"关键在于：",{"type":185,"tag":235,"props":1470,"children":1471},{},[1472],{"type":190,"value":1473},"轻量、高频、高价值",{"type":190,"value":1475},"，而不是“把所有检查都塞进去”。",{"type":185,"tag":231,"props":1477,"children":1478},{},[1479,1481,1484,1486,1489,1491,1494],{"type":190,"value":1480},"推荐至少启用：",{"type":185,"tag":241,"props":1482,"children":1483},{},[],{"type":190,"value":1485},"\n1）密钥 / 凭证扫描",{"type":185,"tag":241,"props":1487,"children":1488},{},[],{"type":190,"value":1490},"\n2）基础格式化 & 简单 lint",{"type":185,"tag":241,"props":1492,"children":1493},{},[],{"type":190,"value":1495},"\n3）阻止大文件、临时文件、生成产物进入仓库",{"type":185,"tag":1497,"props":1498,"children":1499},"style",{},[1500],{"type":190,"value":1501},"html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dar