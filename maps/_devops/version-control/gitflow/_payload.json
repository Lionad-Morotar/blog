on-control",false,true,"","Gitflow","Gitflow 是一种使用 Git 合作时使用的工作流程。","content/6.maps/_devops/git/gitflow.md",{"type":183,"children":184,"toc":444},"root",[185,194,201,207,213,218,259,273,279,284,295,301,306,312,317,328,334,339,345,350,358,380,385,391,396,405,416,421],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"quick-questions",[191],{"type":192,"value":193},"text","Quick Questions",{"type":186,"tag":195,"props":196,"children":198},"h4",{"id":197},"gitflow-是什么",[199],{"type":192,"value":200},"Gitflow 是什么？",{"type":186,"tag":202,"props":203,"children":204},"p",{},[205],{"type":192,"value":206},"Gitflow 是一种使用 Git 合作时使用的工作流程。与之类似的概念有 Centralized Workflow、Feature Branch Workflow、Forking Workflow 等。",{"type":186,"tag":195,"props":208,"children":210},{"id":209},"选用工作流前需要注意什么",[211],{"type":192,"value":212},"选用工作流前需要注意什么？",{"type":186,"tag":202,"props":214,"children":215},{},[216],{"type":192,"value":217},"工作流应该是“指南”，而不是手册，没有一种工作流程是能解决所有问题而没有显著副作用的，所以应该根据团队规模、业务流程（如需求大小、需求频次）选用更适合团队的工作流。",{"type":186,"tag":219,"props":220,"children":221},"ul",{},[222,236,248],{"type":186,"tag":223,"props":224,"children":225},"li",{},[226,228,234],{"type":192,"value":227},"工作流能否",{"type":186,"tag":229,"props":230,"children":231},"strong",{},[232],{"type":192,"value":233},"容错",{"type":192,"value":235},"，或是可以避免犯错？",{"type":186,"tag":223,"props":237,"children":238},{},[239,241,246],{"type":192,"value":240},"工作流能否可以随着团队人数变更而",{"type":186,"tag":229,"props":242,"children":243},{},[244],{"type":192,"value":245},"扩展",{"type":192,"value":247},"？",{"type":186,"tag":223,"props":249,"children":250},{},[251,253,258],{"type":192,"value":252},"工作流能否带来了不必要的",{"type":186,"tag":229,"props":254,"children":255},{},[256],{"type":192,"value":257},"认知负担",{"type":192,"value":247},{"type":186,"tag":202,"props":260,"children":261},{},[262,264],{"type":192,"value":263},"见：",{"type":186,"tag":265,"props":266,"children":270},"a",{"href":267,"rel":268},"http://fresky.github.io/2020/03/10/common-branching-models/",[269],"nofollow",[271],{"type":192,"value":272},"常见的代码分支模型和比较",{"type":186,"tag":195,"props":274,"children":276},{"id":275},"centralized-workflow-是怎么运作的",[277],{"type":192,"value":278},"Centralized Workflow 是怎么运作的？",{"type":186,"tag":202,"props":280,"children":281},{},[282],{"type":192,"value":283},"如果其他版本管理工具过渡到 Git，那么 Centralized Workflow 是学习成本最小的方案。在此工作流中，团队成员围绕 main 分支开发：拉取代码、开发，然后提交，就这么简单。因为没有额外的分支，所以 main 分支的历史记录开起来像是一条干净的线，这种感觉就像是传统的 SVN 工作流一样。",{"type":186,"tag":202,"props":285,"children":286},{},[287,288],{"type":192,"value":263},{"type":186,"tag":265,"props":289,"children":292},{"href":290,"rel":291},"https://trunkbaseddevelopment.com/",[269],[293],{"type":192,"value":294},"Trunk Based Development",{"type":186,"tag":195,"props":296,"children":298},{"id":297},"feature-branch-workflow-是怎么运作的",[299],{"type":192,"value":300},"Feature Branch Workflow 是怎么运作的？",{"type":186,"tag":202,"props":302,"children":303},{},[304],{"type":192,"value":305},"Feature Branch Workflow 是在 Centraolized Workflow 之上的扩展。开发人员在单独的 feature 分支开发新功能，然后通过 PR 请求提交回 main 分支。在需要帮助时，可以提前请求 PR，邀请他们代码审阅或是提交修复。这种流程隐含的约定是：main 分支上的代码一定是可用的（至少测试通过，能跑），这种小步快跑的模式对持续集成环境来说是一个巨大的优势。",{"type":186,"tag":195,"props":307,"children":309},{"id":308},"pr-是什么",[310],{"type":192,"value":311},"PR 是什么？",{"type":186,"tag":202,"props":313,"children":314},{},[315],{"type":192,"value":316},"Pull Request（PR）是一种使用 GitLab 或其它版本管理系统附带的一种工作流程。PR 可以作为一种告知团队其它成员当前分支功能已经完成的提醒。每个 PR 还附带有代码变更内容和讨论区，团队成员可以通过 PR 进行 Code Review，讨论方案，或者评论代码。使开发人员从邮件或者即时通讯软件中解脱出来。",{"type":186,"tag":202,"props":318,"children":319},{},[320,321],{"type":192,"value":263},{"type":186,"tag":265,"props":322,"children":325},{"href":323,"rel":324},"https://guides.github.com/introduction/flow/",[269],[326],{"type":192,"value":327},"GitHub flow",{"type":186,"tag":195,"props":329,"children":331},{"id":330},"forking-workflow-是怎么运作的",[332],{"type":192,"value":333},"Forking Workflow 是怎么运作的？",{"type":186,"tag":202,"props":335,"children":336},{},[337],{"type":192,"value":338},"在 Forking Workflow 流程中，开发使用单独的仓库来开发一个完整的功能，一旦功能开发完毕，再通过 PR 合并回主仓库 main 分支。因为主仓库管理员并不关心代码的具体实现，所以开发没有主仓库的写入权限，Code Review 也不用在主仓库进行。",{"type":186,"tag":195,"props":340,"children":342},{"id":341},"gitflow-workflow-是怎么运作的",[343],{"type":192,"value":344},"Gitflow Workflow 是怎么运作的？",{"type":186,"tag":202,"props":346,"children":347},{},[348],{"type":192,"value":349},"Gitflow Workflow 最早在 Vincent Driessen 2010 年写的一篇博客中被提出。作为 Feature Branch Workflow 的补充，它仅仅是规范各分支的行为。不同分支有不同的作用，比方说 release 分支用来测试，main 分支用来发布，hotfix 分支用来提交热修复，等等。Gitflow 还规定了分支与分支应该如何合并。",{"type":186,"tag":202,"props":351,"children":352},{},[353],{"type":186,"tag":354,"props":355,"children":357},"img",{"alt":179,"src":356},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20220627173845.png?w=40",[],{"type":186,"tag":202,"props":359,"children":360},{},[361,362,369,371,378],{"type":192,"value":263},{"type":186,"tag":265,"props":363,"children":366},{"href":364,"rel":365},"https://www.atlassian.com/git/tutorials/comparing-workflows/gitflow-workflow",[269],[367],{"type":192,"value":368},"Gitflow Workflow",{"type":192,"value":370},"、",{"type":186,"tag":265,"props":372,"children":375},{"href":373,"rel":374},"https://nvie.com/posts/a-successful-git-branching-model/",[269],[376],{"type":192,"value":377},"A successful Git branching model",{"type":192,"value":379},"，在 2020 年的补充中，作者提及类似 Web 应用这种不需要经常回滚的应用，使用更简单的 GitHub Flow 可能会更合适。",{"type":186,"tag":187,"props":381,"children":383},{"id":382},"评价",[384],{"type":192,"value":382},{"type":186,"tag":195,"props":386,"children":388},{"id":387},"gitflow-的负面影响",[389],{"type":192,"value":390},"Gitflow 的负面影响？",{"type":186,"tag":202,"props":392,"children":393},{},[394],{"type":192,"value":395},"Thoughtworks 认为短生命周期的分支策略给实施 CI/CD 带来更小的伤害，反之类似 Gitflow 中经常用到的长生命周期分治策略反而是在鼓励后期集成（late integration）。",{"type":186,"tag":202,"props":397,"children":398},{},[399],{"type":186,"tag":400,"props":401,"children":402},"q",{},[403],{"type":192,"value":404},"We firmly believe that long-lived version-control branches harm valuable engineering practieces such as CI, and this belief underlies our dislike for Gitflow.",{"type":186,"tag":202,"props":406,"children":407},{},[408,409],{"type":192,"value":263},{"type":186,"tag":265,"props":410,"children":413},{"href":411,"rel":412},"https://www.thoughtworks.com/cn/radar/techniques/long-lived-branches-with-gitflow",[269],[414],{"type":192,"value":415},"Gitflow long-lived-branch on Tech Radar",{"type":186,"tag":187,"props":417,"children":419},{"id":418},"相关资源",[420],{"type":192,"value":418},{"type":186,"tag":219,"props":422,"children":423},{},[424,434],{"type":186,"tag":223,"props":425,"children":426},{},[427],{"type":186,"tag":265,"props":428,"children":431},{"href":429,"rel":430},"https://devblogs.microsoft.com/oldnewthing/20180323-01/?p=98325",[269],[432],{"type":192,"value":433},"Stop cherry-picking, start merging",{"type":186,"tag":223,"props":435,"children":436},{},[437],{"type":186,"tag":265,"props":438,"children":441},{"href":439,"rel":440},"https://martinfowler.com/articles/branching-patterns.html",[269],[442],{"type":192,"value":443},"Patterns for Managing Source Code Branches",{"title":178,"searchDepth":445,"depth":445,"links":446},2,[447,448,449],{"id":189,"depth":445,"text":193},{"id":382,"depth":445,"text":382},{"id":418,"depth":445,"text":418},"markdown","content:6.maps:_devops:version-control:gitflow.md","content","6.maps/_devops/version-control/gitflow.md","6.maps/_devops/version-control/gitflow","md",[457,461],{"_path":458,"title":459,"description":460},"/maps/_devops/version-control/dorothy","Dorothy","Dorothy 是我的 Git Commit Message 的约定。",{"_path":462,"title":463,"description":464},"/maps/_devops/version-control/pre-commit-hook","预提交钩子（Pre-commit hooks）","Git 的 pre-commit hook 用来在提交代码前执行一些检查或操作",1772504934689]