法，它通过对软件的版本号进行管理，以便于开发者和用户了解软件的变动情况。",{"type":182,"children":183,"toc":306},"root",[184,192,216,230,235,242,247,259,265,270,284,290,295],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"源码管理",[190],{"type":191,"value":188},"text",{"type":185,"tag":193,"props":194,"children":195},"ul",{},[196,207],{"type":185,"tag":197,"props":198,"children":199},"li",{},[200],{"type":185,"tag":201,"props":202,"children":204},"a",{"href":203},"/maps/_devops/git",[205],{"type":191,"value":206},"Git",{"type":185,"tag":197,"props":208,"children":209},{},[210],{"type":185,"tag":201,"props":211,"children":213},{"href":212},"/maps/_devops/git/gitflow",[214],{"type":191,"value":215},"Gitflow",{"type":185,"tag":217,"props":218,"children":219},"p",{},[220,222],{"type":191,"value":221},"TODO：",{"type":185,"tag":201,"props":223,"children":227},{"href":224,"rel":225},"https://sapling-scm.com/docs/introduction/differences-git",[226],"nofollow",[228],{"type":191,"value":229},"Sapling",{"type":185,"tag":186,"props":231,"children":233},{"id":232},"版本号管理",[234],{"type":191,"value":232},{"type":185,"tag":236,"props":237,"children":239},"h4",{"id":238},"语义化版本是什么",[240],{"type":191,"value":241},"语义化版本是什么？",{"type":185,"tag":217,"props":243,"children":244},{},[245],{"type":191,"value":246},"语义化版本（Semantic Version）是一种版本号码标记方法，它要求版本号由“主版本号。次版本号。修订号”组成，分别代表不兼容的 API 改动、向下兼容的功能性改动或新增、向下兼容的问题修正。",{"type":185,"tag":217,"props":248,"children":249},{},[250,252],{"type":191,"value":251},"见：",{"type":185,"tag":201,"props":253,"children":256},{"href":254,"rel":255},"https://semver.org/lang/zh-CN/",[226],[257],{"type":191,"value":258},"语义化版本 @semver.org",{"type":185,"tag":236,"props":260,"children":262},{"id":261},"语义化版本解决了什么问题",[263],{"type":191,"value":264},"语义化版本解决了什么问题？",{"type":185,"tag":217,"props":266,"children":267},{},[268],{"type":191,"value":269},"Semver 被设计用来解决依赖地狱的问题，常用于定义了公共 API 的项目，因为其各个版本号的意义都和 API 的变动挂钩。但 Semver 从某种意义上来说过于理想化，主要因为实际开发中代码变动没用绝对意义上的 no breaking change 这么一说。bug 和 breaking change 的界限本身就很模糊，所以实际上，任何改动都可能带来意料之外的 breaking change。",{"type":185,"tag":217,"props":271,"children":272},{},[273,275,282],{"type":191,"value":274},"许多项目并不遵循 Semver，如 TS 的开发者声称，其 minor 版本可能引入 Breaking Change，见：",{"type":185,"tag":201,"props":276,"children":279},{"href":277,"rel":278},"https://github.com/microsoft/TypeScript/issues/14116",[226],[280],{"type":191,"value":281},"TypeScript should follow semantic versioning @GitHub",{"type":191,"value":283},"。",{"type":185,"tag":236,"props":285,"children":287},{"id":286},"如何解决版本号膨胀问题",[288],{"type":191,"value":289},"如何解决版本号膨胀问题？",{"type":185,"tag":217,"props":291,"children":292},{},[293],{"type":191,"value":294},"在单仓多包项目中，如果遵循语义化版本，那么版本同步会使版本号迅速膨胀。一个好的方案是现在其他项目使用 0.x 版本号开发，等 API 稳定后再合并到单仓中升级成为 1.0.0 版本。",{"type":185,"tag":217,"props":296,"children":297},{},[298,299],{"type":191,"value":251},{"type":185,"tag":201,"props":300,"children":303},{"href":301,"rel":302},"https://medium.com/netscape/the-case-for-monorepos-907c1361708a",[226],[304],{"type":191,"value":305},"The Case for MonoreposJJJ",{"title":178,"searchDepth":307,"depth":307,"links":308},2,[309,310],{"id":188,"depth":307,"text":188},{"id":232,"depth":307,"text":232},"markdown","content:6.maps:_devops:version-control.md","content","6.maps/_devops/version-control.md","6.maps/_devops/version-control","md",[318,322],{"_path":319,"title":320,"description":321},"/maps/_devops/rotatelogs","rotatelogs","Apache 内置的日志轮转工具，通过管道机制实现按时间或大小切割日志文件。",{"_path":323,"title":324,"description":325},"/maps/_docs/doc-manage/doc-manage","文档管理","文档管理相关",1771695781225]