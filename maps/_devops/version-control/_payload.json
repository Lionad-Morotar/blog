ldren":180,"toc":303},"root",[181,189,213,227,232,239,244,256,262,267,281,287,292],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"源码管理",[187],{"type":188,"value":185},"text",{"type":182,"tag":190,"props":191,"children":192},"ul",{},[193,204],{"type":182,"tag":194,"props":195,"children":196},"li",{},[197],{"type":182,"tag":198,"props":199,"children":201},"a",{"href":200},"/maps/_devops/git",[202],{"type":188,"value":203},"Git",{"type":182,"tag":194,"props":205,"children":206},{},[207],{"type":182,"tag":198,"props":208,"children":210},{"href":209},"/maps/_devops/git/gitflow",[211],{"type":188,"value":212},"Gitflow",{"type":182,"tag":214,"props":215,"children":216},"p",{},[217,219],{"type":188,"value":218},"TODO：",{"type":182,"tag":198,"props":220,"children":224},{"href":221,"rel":222},"https://sapling-scm.com/docs/introduction/differences-git",[223],"nofollow",[225],{"type":188,"value":226},"Sapling",{"type":182,"tag":183,"props":228,"children":230},{"id":229},"版本号管理",[231],{"type":188,"value":229},{"type":182,"tag":233,"props":234,"children":236},"h4",{"id":235},"语义化版本是什么",[237],{"type":188,"value":238},"语义化版本是什么？",{"type":182,"tag":214,"props":240,"children":241},{},[242],{"type":188,"value":243},"语义化版本（Semantic Version）是一种版本号码标记方法，它要求版本号由“主版本号。次版本号。修订号”组成，分别代表不兼容的 API 改动、向下兼容的功能性改动或新增、向下兼容的问题修正。",{"type":182,"tag":214,"props":245,"children":246},{},[247,249],{"type":188,"value":248},"见：",{"type":182,"tag":198,"props":250,"children":253},{"href":251,"rel":252},"https://semver.org/lang/zh-CN/",[223],[254],{"type":188,"value":255},"语义化版本 @semver.org",{"type":182,"tag":233,"props":257,"children":259},{"id":258},"语义化版本解决了什么问题",[260],{"type":188,"value":261},"语义化版本解决了什么问题？",{"type":182,"tag":214,"props":263,"children":264},{},[265],{"type":188,"value":266},"Semver 被设计用来解决依赖地狱的问题，常用于定义了公共 API 的项目，因为其各个版本号的意义都和 API 的变动挂钩。但 Semver 从某种意义上来说过于理想化，主要因为实际开发中代码变动没用绝对意义上的 no breaking change 这么一说。bug 和 breaking change 的界限本身就很模糊，所以实际上，任何改动都可能带来意料之外的 breaking change。",{"type":182,"tag":214,"props":268,"children":269},{},[270,272,279],{"type":188,"value":271},"许多项目并不遵循 Semver，如 TS 的开发者声称，其 minor 版本可能引入 Breaking Change，见：",{"type":182,"tag":198,"props":273,"children":276},{"href":274,"rel":275},"https://github.com/microsoft/TypeScript/issues/14116",[223],[277],{"type":188,"value":278},"TypeScript should follow semantic versioning @GitHub",{"type":188,"value":280},"。",{"type":182,"tag":233,"props":282,"children":284},{"id":283},"如何解决版本号膨胀问题",[285],{"type":188,"value":286},"如何解决版本号膨胀问题？",{"type":182,"tag":214,"props":288,"children":289},{},[290],{"type":188,"value":291},"在单仓多包项目中，如果遵循语义化版本，那么版本同步会使版本号迅速膨胀。一个好的方案是现在其他项目使用 0.x 版本号开发，等 API 稳定后再合并到单仓中升级成为 1.0.0 版本。",{"type":182,"tag":214,"props":293,"children":294},{},[295,296],{"type":188,"value":248},{"type":182,"tag":198,"props":297,"children":300},{"href":298,"rel":299},"https://medium.com/netscape/the-case-for-monorepos-907c1361708a",[223],[301],{"type":188,"value":302},"The Case for MonoreposJJJ",{"title":175,"searchDepth":304,"depth":304,"links":305},2,[306,307],{"id":185,"depth":304,"text":185},{"id":229,"depth":304,"text":229},"markdown","content:6.maps:_devops:version-control.md","content","6.maps/_devops/version-control.md","6.maps/_devops/version-control","md",[315,319],{"_path":316,"title":317,"description":318},"/maps/_devops/rotatelogs","rotatelogs","Apache 内置的日志轮转工具，通过管道机制实现按时间或大小切割日志文件。",{"_path":320,"title":321,"description":322},"/maps/_docs/doc-manage/doc-manage","文档管理","文档管理相关",1771264629375]