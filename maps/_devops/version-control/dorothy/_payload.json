on-control",false,true,"","Dorothy","Dorothy 是我的 Git Commit Message 的约定。","content/6.maps/_devops/git/dorothy.md",{"type":183,"children":184,"toc":343},"root",[185,193,220,226,236,241,249,254,259,264,297,302,320,325,330,335],{"type":186,"tag":187,"props":188,"children":189},"element","p",{},[190],{"type":191,"value":192},"text","以下在 LeanCloud CM Guide 的基础上，我们整理了一份尽量简单且能记录代码提交意义的约定。",{"type":186,"tag":194,"props":195,"children":196},"ul",{},[197,210],{"type":186,"tag":198,"props":199,"children":200},"li",{},[201],{"type":186,"tag":202,"props":203,"children":207},"a",{"href":204,"rel":205},"https://www.conventionalcommits.org/zh-hans/v1.0.0/",[206],"nofollow",[208],{"type":191,"value":209},"Conventional commits",{"type":186,"tag":198,"props":211,"children":212},{},[213],{"type":186,"tag":202,"props":214,"children":217},{"href":215,"rel":216},"https://conventional-branch.github.io/zh/",[206],[218],{"type":191,"value":219},"Conventional branch",{"type":186,"tag":221,"props":222,"children":224},"h4",{"id":223},"主要格式",[225],{"type":191,"value":223},{"type":186,"tag":227,"props":228,"children":230},"pre",{"code":229},"提交类型：变动内容，简短描述，50 个字符\n\n提交描述，可选，72 字符内，说明该提交的原因，或是提交的副作用。与第一行之间存在空行\n\n注释及其它，可选\n",[231],{"type":186,"tag":232,"props":233,"children":234},"code",{"__ignoreMap":178},[235],{"type":191,"value":229},{"type":186,"tag":221,"props":237,"children":239},{"id":238},"简单示例",[240],{"type":191,"value":238},{"type":186,"tag":227,"props":242,"children":244},{"code":243},"fix: 更改 VuePress 版本，修复布局错乱问题\n\nhttps://github.com/vuejs/vuepress/issues/1321\n",[245],{"type":186,"tag":232,"props":246,"children":247},{"__ignoreMap":178},[248],{"type":191,"value":243},{"type":186,"tag":187,"props":250,"children":251},{},[252],{"type":191,"value":253},"上面这个示例是一种“修复类型（fix）”示例，其描述链接了一个 GitHub Issue。",{"type":186,"tag":221,"props":255,"children":257},{"id":256},"类型说明",[258],{"type":191,"value":256},{"type":186,"tag":187,"props":260,"children":261},{},[262],{"type":191,"value":263},"类型有多种可能，以下几种是必须遵守的约定：",{"type":186,"tag":194,"props":265,"children":266},{},[267,272,277,282,287,292],{"type":186,"tag":198,"props":268,"children":269},{},[270],{"type":191,"value":271},"fix：错误修复",{"type":186,"tag":198,"props":273,"children":274},{},[275],{"type":191,"value":276},"feat：新功能",{"type":186,"tag":198,"props":278,"children":279},{},[280],{"type":191,"value":281},"chore：其它修改，如项目配置变动，构建任务变动",{"type":186,"tag":198,"props":283,"children":284},{},[285],{"type":191,"value":286},"doc：注释或文档",{"type":186,"tag":198,"props":288,"children":289},{},[290],{"type":191,"value":291},"format：代码改动（仅代码样式变更，如换行、分号）",{"type":186,"tag":198,"props":293,"children":294},{},[295],{"type":191,"value":296},"css：前端界面样式变更",{"type":186,"tag":187,"props":298,"children":299},{},[300],{"type":191,"value":301},"此外，还有一些类型可供参考及选用：",{"type":186,"tag":194,"props":303,"children":304},{},[305,310,315],{"type":186,"tag":198,"props":306,"children":307},{},[308],{"type":191,"value":309},"refactor：代码重构",{"type":186,"tag":198,"props":311,"children":312},{},[313],{"type":191,"value":314},"perf：代码重构（仅性能改进）",{"type":186,"tag":198,"props":316,"children":317},{},[318],{"type":191,"value":319},"test：与测试相关的改动",{"type":186,"tag":187,"props":321,"children":322},{},[323],{"type":191,"value":324},"原则来说，依据不同项目，CM 规范可以做适当调整。以上只展现了一种通用的基础约定，具体项目可以在此基础上自行增添规则。如我的个人博客项目 CM 中，有一种“blogs”类型专门用作记录博客文字内容的修改。",{"type":186,"tag":221,"props":326,"children":328},{"id":327},"特殊标记",[329],{"type":191,"value":327},{"type":186,"tag":187,"props":331,"children":332},{},[333],{"type":191,"value":334},"特殊标记用作标注注意事项，如“BREAKING”、“close”标记的使用。特殊标记通常与项目工程化实践中其它工具配合使用，如用于关闭 GitLab Issues，后续有需要再展开约定。",{"type":186,"tag":227,"props":336,"children":338},{"code":337},"feat: 大盘中国地图增加地图下钻功能\n\n引入中国的省市映射文件，以通过选取的省找到省下所有城市内的店铺。\n\nBREAKING: 下钻功能导致了地图缩放时错位的问题，所以暂时禁用了地图的拖拽能力\n",[339],{"type":186,"tag":232,"props":340,"children":341},{"__ignoreMap":178},[342],{"type":191,"value":337},{"title":178,"searchDepth":344,"depth":344,"links":345},2,[],"markdown","content:6.maps:_devops:version-control:dorothy.md","content","6.maps/_devops/version-control/dorothy.md","6.maps/_devops/version-control/dorothy","md",[353,357],{"_path":354,"title":355,"description":356},"/maps/_devops/logging/rotatelogs","rotatelogs","Apache 内置的日志轮转工具，通过管道机制实现按时间或大小切割日志文件。",{"_path":358,"title":359,"description":360},"/maps/_devops/version-control/gitflow","Gitflow","Gitflow 是一种使用 Git 合作时使用的工作流程。",1772504934675]