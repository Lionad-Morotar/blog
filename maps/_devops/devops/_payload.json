6,"props":270,"children":271},{},[272,278],{"type":185,"tag":273,"props":274,"children":275},"strong",{},[276],{"type":200,"value":277},"持续集成/持续部署（CI/CD）",{"type":200,"value":279},"：自动化构建、测试和部署流程",{"type":185,"tag":206,"props":281,"children":282},{},[283,288],{"type":185,"tag":273,"props":284,"children":285},{},[286],{"type":200,"value":287},"基础设施即代码（IaC）",{"type":200,"value":289},"：使用代码管理和配置基础设施",{"type":185,"tag":206,"props":291,"children":292},{},[293,298],{"type":185,"tag":273,"props":294,"children":295},{},[296],{"type":200,"value":297},"监控与日志",{"type":200,"value":299},"：实时监控系统状态，收集和分析日志",{"type":185,"tag":206,"props":301,"children":302},{},[303,307],{"type":185,"tag":273,"props":304,"children":305},{},[306],{"type":200,"value":215},{"type":200,"value":308},"：追踪代码变更，支持协作开发",{"type":185,"tag":206,"props":310,"children":311},{},[312,317],{"type":185,"tag":273,"props":313,"children":314},{},[315],{"type":200,"value":316},"自动化测试",{"type":200,"value":318},"：确保代码质量，减少人工错误",{"type":185,"tag":186,"props":320,"children":321},{},[322],{"type":200,"value":323},"通过这些实践，DevOps 帮助团队实现更频繁的发布、更低的故障率和更快的恢复时间。",{"title":178,"searchDepth":325,"depth":325,"links":326},2,[327,328],{"id":197,"depth":325,"text":197},{"id":253,"depth":325,"text":253},"markdown","content:6.maps:_devops:devops.md","content","6.maps/_devops/devops.md","6.maps/_devops/devops","md",[336,339],{"_path":234,"title":337,"description":338},"Docker","Docker 是一种容器管理工具，通过对系统资源的控制与隔离，把软件、软件运行时、系统工具、系统库和配置打包到一个镜像中，运行在有有独立命名空间的容器进程内，可以使软件的所有依赖都标准化。",{"_path":245,"title":340,"description":341},"rotatelogs","Apache 内置的日志轮转工具，通过管道机制实现按时间或大小切割日志文件。",1772504906903]