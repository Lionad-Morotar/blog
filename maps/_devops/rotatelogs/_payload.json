ot",[181,189,196,202,208,230,235,240,249,254,259,288,293,299,304,309,314,319,324,329,334,339,345,350,355,360,374,380,502,513,518,523,552,557,571,577,591,604,615],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"简介",[187],{"type":188,"value":185},"text",{"type":182,"tag":190,"props":191,"children":193},"h4",{"id":192},"rotatelogs-是什么",[194],{"type":188,"value":195},"rotatelogs 是什么？",{"type":182,"tag":197,"props":198,"children":199},"p",{},[200],{"type":188,"value":201},"Apache 自带的日志轮转程序。它不独立运行，而是作为管道的接收端——Apache 往管道写日志，rotatelogs 从另一头读，到点就换个新文件接着写。",{"type":182,"tag":190,"props":203,"children":205},{"id":204},"管道机制怎么工作",[206],{"type":188,"value":207},"管道机制怎么工作？",{"type":182,"tag":197,"props":209,"children":210},{},[211,213,220,222,228],{"type":188,"value":212},"配置里写一行 ",{"type":182,"tag":214,"props":215,"children":217},"code",{"className":216},[],[218],{"type":188,"value":219},"CustomLog \"|rotatelogs /var/log/access.%Y%m%d.log 86400\" common",{"type":188,"value":221},"。Apache 启动时，管道符 ",{"type":182,"tag":214,"props":223,"children":225},{"className":224},[],[226],{"type":188,"value":227},"|",{"type":188,"value":229}," 告诉它：别写文件，启动 rotatelogs 进程，把日志喂给它。rotatelogs 拿到数据后，按你指定的规则（每天、每小时、每 100MB）切分。",{"type":182,"tag":183,"props":231,"children":233},{"id":232},"原理",[234],{"type":188,"value":232},{"type":182,"tag":190,"props":236,"children":238},{"id":237},"数据流向",[239],{"type":188,"value":237},{"type":182,"tag":241,"props":242,"children":244},"pre",{"code":243},"Apache (写 stdout) → 管道 → rotatelogs (读 stdin) → 文件系统\n",[245],{"type":182,"tag":214,"props":246,"children":247},{"__ignoreMap":175},[248],{"type":188,"value":243},{"type":182,"tag":197,"props":250,"children":251},{},[252],{"type":188,"value":253},"Apache 只管往标准输出写，不关心后面是谁。rotatelogs 只管从标准输入读，不关心前面是谁。这种解耦让 rotatelogs 可以被任何支持管道的程序使用。",{"type":182,"tag":190,"props":255,"children":257},{"id":256},"轮转触发",[258],{"type":188,"value":256},{"type":182,"tag":197,"props":260,"children":261},{},[262,264,270,272,278,280,286],{"type":188,"value":263},"两种模式：时间间隔（秒数，如 ",{"type":182,"tag":214,"props":265,"children":267},{"className":266},[],[268],{"type":188,"value":269},"86400",{"type":188,"value":271}," 表示每天）或文件大小（字节数）。时间到了或文件大了，关闭当前文件，打开新文件。文件名支持 strftime 格式，所以 ",{"type":182,"tag":214,"props":273,"children":275},{"className":274},[],[276],{"type":188,"value":277},"/var/log/access.%Y%m%d.log",{"type":188,"value":279}," 在 2024 年 3 月 15 日会变成 ",{"type":182,"tag":214,"props":281,"children":283},{"className":282},[],[284],{"type":188,"value":285},"/var/log/access.20240315.log",{"type":188,"value":287},"。",{"type":182,"tag":183,"props":289,"children":291},{"id":290},"消息边界问题",[292],{"type":188,"value":290},{"type":182,"tag":190,"props":294,"children":296},{"id":295},"问题在哪",[297],{"type":188,"value":298},"问题在哪？",{"type":182,"tag":197,"props":300,"children":301},{},[302],{"type":188,"value":303},"rotatelogs 处理的是字节流，不是消息。它不知道什么是\"一行日志\"，更不知道什么是\"一个 JSON\"。轮转时刻到了，它就切一刀——不管你写到哪。",{"type":182,"tag":190,"props":305,"children":307},{"id":306},"举个例子",[308],{"type":188,"value":306},{"type":182,"tag":197,"props":310,"children":311},{},[312],{"type":188,"value":313},"23:59:59，你的程序开始写一个 10MB 的 JSON。00:00:00，轮转时间到。这个 JSON 的前半截留在昨天的文件，后半截进了今天的文件。两边都不完整，解析时全挂。",{"type":182,"tag":190,"props":315,"children":317},{"id":316},"根本原因",[318],{"type":188,"value":316},{"type":182,"tag":197,"props":320,"children":321},{},[322],{"type":188,"value":323},"管道是字节流。rotatelogs 读到什么写什么，不缓冲、不等待、不理解边界。这不是 bug，是设计如此——简单、高效、不阻塞上游。",{"type":182,"tag":183,"props":325,"children":327},{"id":326},"解决方案",[328],{"type":188,"value":326},{"type":182,"tag":190,"props":330,"children":332},{"id":331},"应用层保证",[333],{"type":188,"value":331},{"type":182,"tag":197,"props":335,"children":336},{},[337],{"type":188,"value":338},"写入端自己负责：每条日志一行，行尾换行符作为边界。大多数日志框架都这么干。",{"type":182,"tag":190,"props":340,"children":342},{"id":341},"使用-logrotate",[343],{"type":188,"value":344},"使用 logrotate",{"type":182,"tag":197,"props":346,"children":347},{},[348],{"type":188,"value":349},"logrotate 是操作系统层面的工具，它不依赖管道。它的工作方式是：等文件写完，重命名，发信号让程序重新打开文件。这种方式尊重程序内部的缓冲逻辑，不会在半截切断消息。缺点是时间精度不如 rotatelogs——可能差几分钟。",{"type":182,"tag":190,"props":351,"children":353},{"id":352},"接受它",[354],{"type":188,"value":352},{"type":182,"tag":197,"props":356,"children":357},{},[358],{"type":188,"value":359},"如果你的日志格式本身就是行导向的（大多数 Web 服务器日志都是），而每行又足够短（几百字节到几 KB），那这个问题几乎不会遇到。只有当日志行特别大（比如嵌了 base64 图片、大 JSON）时才需要担心。",{"type":182,"tag":197,"props":361,"children":362},{},[363,365],{"type":188,"value":364},"见：",{"type":182,"tag":366,"props":367,"children":371},"a",{"href":368,"rel":369},"https://github.com/rsyslog/rsyslog/issues/409",[370],"nofollow",[372],{"type":188,"value":373},"Log messages split between files on log rotation · Issue #409",{"type":182,"tag":183,"props":375,"children":377},{"id":376},"与-logrotate-对比",[378],{"type":188,"value":379},"与 logrotate 对比",{"type":182,"tag":381,"props":382,"children":383},"table",{},[384,407],{"type":182,"tag":385,"props":386,"children":387},"thead",{},[388],{"type":182,"tag":389,"props":390,"children":391},"tr",{},[392,398,402],{"type":182,"tag":393,"props":394,"children":395},"th",{},[396],{"type":188,"value":397},"特性",{"type":182,"tag":393,"props":399,"children":400},{},[401],{"type":188,"value":176},{"type":182,"tag":393,"props":403,"children":404},{},[405],{"type":188,"value":406},"logrotate",{"type":182,"tag":408,"props":409,"children":410},"tbody",{},[411,430,448,466,484],{"type":182,"tag":389,"props":412,"children":413},{},[414,420,425],{"type":182,"tag":415,"props":416,"children":417},"td",{},[418],{"type":188,"value":419},"运行方式",{"type":182,"tag":415,"props":421,"children":422},{},[423],{"type":188,"value":424},"常驻进程，实时处理",{"type":182,"tag":415,"props":426,"children":427},{},[428],{"type":188,"value":429},"定时任务，批处理",{"type":182,"tag":389,"props":431,"children":432},{},[433,438,443],{"type":182,"tag":415,"props":434,"children":435},{},[436],{"type":188,"value":437},"时间精度",{"type":182,"tag":4