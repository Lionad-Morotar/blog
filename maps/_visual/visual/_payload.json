"toc":260},"root",[184,192,225,230,236,246,255],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"子领域",[190],{"type":191,"value":188},"text",{"type":185,"tag":193,"props":194,"children":195},"ul",{},[196,207,216],{"type":185,"tag":197,"props":198,"children":199},"li",{},[200],{"type":185,"tag":201,"props":202,"children":204},"a",{"href":203},"/maps/_visual/info-design/info-design",[205],{"type":191,"value":206},"信息设计",{"type":185,"tag":197,"props":208,"children":209},{},[210],{"type":185,"tag":201,"props":211,"children":213},{"href":212},"/maps/_visual/visualization/visualization",[214],{"type":191,"value":215},"可视化技术",{"type":185,"tag":197,"props":217,"children":218},{},[219],{"type":185,"tag":201,"props":220,"children":222},{"href":221},"/maps/_visual/gis/gis",[223],{"type":191,"value":224},"GIS",{"type":185,"tag":186,"props":226,"children":228},{"id":227},"概述",[229],{"type":191,"value":227},{"type":185,"tag":231,"props":232,"children":233},"p",{},[234],{"type":191,"value":235},"可视化领域涵盖三个核心方向：",{"type":185,"tag":231,"props":237,"children":238},{},[239,244],{"type":185,"tag":240,"props":241,"children":242},"strong",{},[243],{"type":191,"value":206},{"type":191,"value":245},"关注如何有效地展示和传达信息。它不仅涉及形状、色彩、容器等视觉映像，还涉及视角、情绪、隐喻等心理层面因素。设计师作为信息和受众之间的桥梁，需要将深奥复杂的信息转化为能被受众理解的形式，目标是实现清晰、准确而高效的传达。",{"type":185,"tag":231,"props":247,"children":248},{},[249,253],{"type":185,"tag":240,"props":250,"children":251},{},[252],{"type":191,"value":215},{"type":191,"value":254},"是将数据转换为可视化图形的技术手段，是数据分析的重要工具。包括各种图表、图形的实现原理，如模糊效果、视错觉等视觉技术的实现，以及数据可视化系统的搭建方法。",{"type":185,"tag":231,"props":256,"children":257},{},[258],{"type":191,"value":259},"**地理信息系统（GIS）**是一种用于捕获、存储、管理、分析和展示地理空间数据的计算机系统。GIS 技术广泛应用于地图制作、空间分析、城市规划、环境监测等领域，为空间数据的可视化和分析提供了强大的工具支持。",{"title":178,"searchDepth":261,"depth":261,"links":262},2,[263,264],{"id":188,"depth":261,"text":188},{"id":227,"depth":261,"text":227},"markdown","content:6.maps:_visual:visual.md","content","6.maps/_visual/visual.md","6.maps/_visual/visual","md",[272,274],{"_path":203,"title":206,"description":273},"研究如何展示信息。",{"_path":212,"title":179,"description":275},"可视化是一种通过图表、图形、地图等视觉元素来传达信息的方式。可视化技术是一种将数据转换为可视化图形的技术，是数据分析的重要手段之一。",1772504942406]