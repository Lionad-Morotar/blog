-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"original_path":181,"body":182,"_type":596,"_id":597,"_source":598,"_file":599,"_stem":600,"_extension":601},"/maps/_visual/info-design/info-design","info-design",false,true,"","信息设计","研究如何展示信息。","content/6.maps/_visual/info-design.md",{"type":183,"children":184,"toc":594},"root",[185,193,198,203,208,213,220,225,234,239,247,261,267,322,331,336,349,357,375,383,388,396,429,437,442,450,458,588],{"type":186,"tag":187,"props":188,"children":189},"element","p",{},[190],{"type":191,"value":192},"text","信息设计包含两个重要的概念：设计以及信息。即研究如何展示信息。",{"type":186,"tag":187,"props":194,"children":195},{},[196],{"type":191,"value":197},"不仅是\"展示\"，也许换个词\"呈现\"，意思更加确切一些，因为设计工作中，我们不仅仅只面向形状、色彩、容器等信息的视觉映像，通常还会涉及视角、情绪、隐喻等心理层面因素。比方说，字体衬线体的古典对比非衬线体的现代感；文字的严肃对比图文的冲击力；黑白的冷淡对比红色的热情。",{"type":186,"tag":187,"props":199,"children":200},{},[201],{"type":191,"value":202},"可以发现，所有信息都会经过设计（设计师）的诠释，后者将其中关建以及内涵（理想、信念）\"呈现\"给其他人。所以，不论是你闲下来在看的博客、工作日使用的汽车还是街道上的路牌。.. 所有信息都需要设计，最终目标是使清晰、准确而高效的传达。",{"type":186,"tag":187,"props":204,"children":205},{},[206],{"type":191,"value":207},"评价设计的好坏，一般来说，总是围绕着\"传达\"这个关键点。但\"传达\"是困难的，设计师站在信息和受众两者中间，为将深奥复杂的信息（甚至缺失）转化能被受众理解的玩意儿花尽了心思，仍然常导向设计失败的结果，也就是我们经常听到\"难懂无趣\"、\"晕\"、\"欺骗\"等指摘。当然，我们总能找到许多反例，比如戴维·卡森设计的杂志封面就要求你必须花费比较多的力气来理解他传达的信息。这显然也是一种\"传达\"（带有强烈的戴维·卡森风格），就看你是不是他的受众啦。",{"type":186,"tag":187,"props":209,"children":210},{},[211],{"type":191,"value":212},"信息设计也是有难度的。一方面，困扰设计师的问题可能是信息过载、缺失、深奥或无意义；另一方面，信息的真和假也常常被拿出来大加讨论。可以想象，设计师不仅要做一个\"人肉翻译器\"，用高超的理解力清洗并转换数据，他还需承担设计带来的\"道德风险\"。也就是说，信息本身在转换的过程中，它也在真与假的模糊中丢失了身影。",{"type":186,"tag":214,"props":215,"children":217},"h4",{"id":216},"多个分组之间怎么对比",[218],{"type":191,"value":219},"多个分组之间怎么对比？",{"type":186,"tag":187,"props":221,"children":222},{},[223],{"type":191,"value":224},"使用柱状图能很好的展示数据在某个维度上的变化趋势，当分组数量变成两个时，也可以在一张图中较为清晰地展示多个分组之间的对比。",{"type":186,"tag":187,"props":226,"children":227},{},[228],{"type":186,"tag":229,"props":230,"children":233},"img",{"alt":231,"src":232},"柱状图","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202412240922088.png",[],{"type":186,"tag":187,"props":235,"children":236},{},[237],{"type":191,"value":238},"但是当分组数量急速上升时，使用山脊线图（Ridge Plot）可能是一个更好的选择。",{"type":186,"tag":187,"props":240,"children":241},{},[242],{"type":186,"tag":229,"props":243,"children":246},{"alt":244,"src":245},"Ridge Plot","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202412240931983.png",[],{"type":186,"tag":187,"props":248,"children":249},{},[250,252],{"type":191,"value":251},"见：",{"type":186,"tag":253,"props":254,"children":258},"a",{"href":255,"rel":256},"https://blog.dailydoseofds.com/p/ridgeline-plots-to-depict-multiple",[257],"nofollow",[259],{"type":191,"value":260},"Ridgeline Plots to Depict Multiple Distributions",{"type":186,"tag":214,"props":262,"children":264},{"id":263},"isux-遇见大数据可视化系列",[265],{"type":191,"value":266},"ISUX 遇见大数据可视化系列",{"type":186,"tag":268,"props":269,"children":270},"ul",{},[271,282,292,302,312],{"type":186,"tag":272,"props":273,"children":274},"li",{},[275],{"type":186,"tag":253,"props":276,"children":279},{"href":277,"rel":278},"https://isux.tencent.com/articles/91.html",[257],[280],{"type":191,"value":281},"未来已来，变革中的数据可视化",{"type":186,"tag":272,"props":283,"children":284},{},[285],{"type":186,"tag":253,"props":286,"children":289},{"href":287,"rel":288},"https://isux.tencent.com/articles/90.html",[257],[290],{"type":191,"value":291},"数据可视化基础研究",{"type":186,"tag":272,"props":293,"children":294},{},[295],{"type":186,"tag":253,"props":296,"children":299},{"href":297,"rel":298},"https://isux.tencent.com/articles/89.html",[257],[300],{"type":191,"value":301},"来做一个数据可视化报表",{"type":186,"tag":272,"props":303,"children":304},{},[305],{"type":186,"tag":253,"props":306,"children":309},{"href":307,"rel":308},"https://isux.tencent.com/articles/79.html",[257],[310],{"type":191,"value":311},"可视化系统搭建",{"type":186,"tag":272,"props":313,"children":314},{},[315],{"type":186,"tag":253,"props":316,"children":319},{"href":317,"rel":318},"https://isux.tencent.com/articles/78.html",[257],[320],{"type":191,"value":321},"数据图表设计（一）",{"type":186,"tag":187,"props":323,"children":324},{},[325],{"type":186,"tag":326,"props":327,"children":328},"q",{},[329],{"type":191,"value":330},"世界上 90％的数据是在过去几年内产生的事实上，过去三十年中，全世界的数据量大约每两年增加 10 倍。",{"type":186,"tag":187,"props":332,"children":333},{},[334],{"type":191,"value":335},"因为数据多且增量大，所以需要持续改进可视化形式。技术上来说，可视化形式逐渐从从过去的表格、信息图、图表，逐渐扩充了交互图表、VR 图表等形式。",{"type":186,"tag":268,"props":337,"children":338},{},[339],{"type":186,"tag":272,"props":340,"children":341},{},[342],{"type":186,"tag":253,"props":343,"children":346},{"href":344,"rel":345},"https://www.datavis.ca/milestones/",[257],[347],{"type":191,"value":348},"图表可视化发展史",{"type":186,"tag":187,"props":350,"children":351},{},[352],{"type":186,"tag":326,"props":353,"children":354},{},[355],{"type":191,"value":356},"大数据时代的数据可视化具有哪些特征，笔者大概将其整理归纳为以下三点。",{"type":186,"tag":268,"props":358,"children":359},{},[360,365,370],{"type":186,"tag":272,"props":361,"children":362},{},[363],{"type":191,"value":364},"直观：使用 3D、动效等加强视觉冲击增强图表的可认知性",{"type":186,"tag":272,"props":366,"children":367},{},[368],{"type":191,"value":369},"交互：通过互动改变数据的表现形式",{"type":186,"tag":272,"props":371,"children":372},{},[373],{"type":191,"value":374},"实时：在庞大的数据量及增量的背景下，数据的实时性尤为重要",{"type":186,"tag":187,"props":376,"children":377},{},[378],{"type":186,"tag":326,"props":379,"children":380},{},[381],{"type":191,"value":382},"为什么人们会对信息图的传播内容更有效的认知呢？",{"type":186,"tag":187,"props":384,"children":385},{},[386],{"type":191,"value":387},"主要原因是因为视觉是人类最强的信息输入方式，其次，信息图提供了特定的语境，能展示多个维度数值并且相互比较。",{"type":186,"tag":187,"props":389,"children":390},{},[391],{"type":186,"tag":326,"props":392,"children":393},{},[394],{"type":191,"value":395},"信息图的分类也逐步划分为：图解（Diagram） 、图表（Chart） 、 表格（Table） 、统计图（Graph） 、 地图（Map）和图形符号（Pictogram）这几部分。",{"type":186,"tag":268,"props":397,"children":398},{},[399,404,409,414,419,424],{"type":186,"tag":272,"props":400,"children":401},{},[402],{"type":191,"value":403},"图解 Diagram：主要运用插图对事物进行说明",{"type":186,"tag":272,"props":405,"children":406},{},[407],{"type":191,"value":408},"图表 Chart：运用图形、线条及插图等，阐明事物的相互关系",{"type":186,"tag":272,"props":410,"children":411},{},[412],{"type":191,"value":413},"表格 Table：根据特定信息标准进行区分，设置纵轴与横轴",{"type":186,"tag":272,"props":415,"children":416},{},[417],{"type":191,"value":418},"统计图 Graph：通过数值来表现变化趋势或进行比较",{"type":186,"tag":272,"props":420,"children":421},{},[422],{"type":191,"value":423},"地图 Map：描述在特定区域和空间里的位置关系",{"type":186,"tag":272,"props":425,"children":426},{},[427],{"type":191,"value":428},"图形符号 Pictogram：不使用文字，运用图画直接传达信息",{"type":186,"tag":187,"props":430,"children":431},{},[432],{"type":186,"tag":326,"props":433,"children":434},{},[435],{"type":191,"value":436},"我们来看一个数据：2017 年 1 月 28 号，成都 PM2.5 值 245，从这个数据里能看出什么",{"type":186,"tag":187,"props":438,"children":439},{},[440],{"type":191,"value":441},"作者通过这个例子展现了收集、清洗、设计这三个完整的流程。他先从环境检测总站获取了 1 月份的检测信息，清洗后获得整个月的 PM2.5 值，通过将 PM2.5 映射成天空的照片，最后线性排开。从最后的图表中可以准确并清晰的确认 1 月份中的好天气。",{"type":186,"tag":187,"props":443,"children":444},{},[445],{"type":186,"tag":229,"props":446,"children":449},{"alt":447,"src":448},"pm25.in 已经关停了","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20231029164117.png",[],{"type":186,"tag":187,"props":451,"children":452},{},[453],{"type":186,"tag":326,"props":454,"children":455},{},[456],{"type":191,"value":457},"数据可视化迭代过程",{"type":186,"tag":459,"props":460,"children":464},"pre",{"className":461,"code":462,"language":463,"meta":178,"style":178},"language-mermaid shiki shiki-themes material-theme-lighter github-light github-dark monokai","---\ntitle: 数据可视化迭代过程\n---\nflowchart TD\n    A[\"1. 你有什么数据？\"] -->|还没有数据| A\n    A -->|有想要的数据| B[2. 关于数据你想知道什么？]\n    B -->|还没想法| B\n    B -->|有具体的问题| C[3. 选择数据可视化形式？]\n    C -->|设计| D{{\"`**可视化图表**`\"}}\n    D -->|观察| E[4. 这些数据的展现有意义吗？]\n    E -->|提出新的问题| B\n    E -->|寻找不同的方法| C\n    E -->|找到相关数据| A\n","mermaid",[465],{"type":186,"tag":466,"props":467,"children":468},"code",{"__ignoreMap":178},[469,481,490,498,507,516,525,534,543,552,561,570,579],{"type":186,"tag":470,"props":471,"children":474},"span",{"class":472,"line":473},"line",1,[475],{"type":1