ath":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133,"children":134},"造物 / Make","/tools",[135,137,140,143,146,149,152],{"title":136,"_path":133},"🧰 工具收集",{"title":138,"_path":139},"📕 博客","/tools/blog",{"title":141,"_path":142},"🥥 Coconut","/tools/coconut",{"title":144,"_path":145},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":147,"_path":148},"🌐 AnySort","/tools/anysort",{"title":150,"_path":151},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":153,"_path":154},"👓 Crapto","/tools/crypto-inline",{"title":156,"_path":157,"children":158},"我 / About","/hire",[159],{"title":160,"_path":157},"📬 技术简历",{"title":162,"_path":163,"children":164},"En","/en",[165],{"title":166,"_path":167,"children":168},"🦁 Welcome","/en/articles",[169],{"title":166,"_path":167},{"_path":171,"_dir":172,"_draft":173,"_partial":174,"_locale":175,"title":176,"description":177,"body":178,"_type":1155,"_id":1156,"_source":1157,"_file":1158,"_stem":1159,"_extension":1160},"/maps/_visual/info-design","_visual",false,true,"","信息设计","研究如何展示信息。",{"type":179,"children":180,"toc":1153},"root",[181,189,194,199,204,209,216,221,230,235,243,257,263,318,327,332,345,353,371,379,384,392,425,433,438,446,454,666,679,703,726,747,770,791,812,835,856,1019,1148],{"type":182,"tag":183,"props":184,"children":185},"element","p",{},[186],{"type":187,"value":188},"text","信息设计包含两个重要的概念：设计以及信息。即研究如何展示信息。",{"type":182,"tag":183,"props":190,"children":191},{},[192],{"type":187,"value":193},"不仅是“展示”，也许换个词“呈现”，意思更加确切一些，因为设计工作中，我们不仅仅只面向形状、色彩、容器等信息的视觉映像，通常还会涉及视角、情绪、隐喻等心理层面因素。比方说，字体衬线体的古典对比非衬线体的现代感；文字的严肃对比图文的冲击力；黑白的冷淡对比红色的热情。",{"type":182,"tag":183,"props":195,"children":196},{},[197],{"type":187,"value":198},"可以发现，所有信息都会经过设计（设计师）的诠释，后者将其中关建以及内涵（理想、信念）“呈现”给其他人。所以，不论是你闲下来在看的博客、工作日使用的汽车还是街道上的路牌。.. 所有信息都需要设计，最终目标是使清晰、准确而高效的传达。",{"type":182,"tag":183,"props":200,"children":201},{},[202],{"type":187,"value":203},"评价设计的好坏，一般来说，总是围绕着“传达”这个关键点。但“传达”是困难的，设计师站在信息和受众两者中间，为将深奥复杂的信息（甚至缺失）转化能被受众理解的玩意儿花尽了心思，仍然常导向设计失败的结果，也就是我们经常听到“难懂无趣”、“晕”、“欺骗”等指摘。当然，我们总能找到许多反例，比如戴维·卡森设计的杂志封面就要求你必须花费比较多的力气来理解他传达的信息。这显然也是一种“传达”（带有强烈的戴维·卡森风格），就看你是不是他的受众啦。",{"type":182,"tag":183,"props":205,"children":206},{},[207],{"type":187,"value":208},"信息设计也是有难度的。一方面，困扰设计师的问题可能是信息过载、缺失、深奥或无意义；另一方面，信息的真和假也常常被拿出来大加讨论。可以想象，设计师不仅要做一个“人肉翻译器”，用高超的理解力清洗并转换数据，他还需承担设计带来的“道德风险”。也就是说，信息本身在转换的过程中，它也在真与假的模糊中丢失了身影。",{"type":182,"tag":210,"props":211,"children":213},"h4",{"id":212},"多个分组之间怎么对比",[214],{"type":187,"value":215},"多个分组之间怎么对比？",{"type":182,"tag":183,"props":217,"children":218},{},[219],{"type":187,"value":220},"使用柱状图能很好的展示数据在某个维度上的变化趋势，当分组数量变成两个时，也可以在一张图中较为清晰地展示多个分组之间的对比。",{"type":182,"tag":183,"props":222,"children":223},{},[224],{"type":182,"tag":225,"props":226,"children":229},"img",{"alt":227,"src":228},"柱状图","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202412240922088.png",[],{"type":182,"tag":183,"props":231,"children":232},{},[233],{"type":187,"value":234},"但是当分组数量急速上升时，使用山脊线图（Ridge Plot）可能是一个更好的选择。",{"type":182,"tag":183,"props":236,"children":237},{},[238],{"type":182,"tag":225,"props":239,"children":242},{"alt":240,"src":241},"Ridge Plot","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202412240931983.png",[],{"type":182,"tag":183,"props":244,"children":245},{},[246,248],{"type":187,"value":247},"见：",{"type":182,"tag":249,"props":250,"children":254},"a",{"href":251,"rel":252},"https://blog.dailydoseofds.com/p/ridgeline-plots-to-depict-multiple",[253],"nofollow",[255],{"type":187,"value":256},"Ridgeline Plots to Depict Multiple Distributions",{"type":182,"tag":210,"props":258,"children":260},{"id":259},"isux-遇见大数据可视化系列",[261],{"type":187,"value":262},"ISUX 遇见大数据可视化系列",{"type":182,"tag":264,"props":265,"children":266},"ul",{},[267,278,288,298,308],{"type":182,"tag":268,"props":269,"children":270},"li",{},[271],{"type":182,"tag":249,"props":272,"children":275},{"href":273,"rel":274},"https://isux.tencent.com/articles/91.html",[253],[276],{"type":187,"value":277},"未来已来，变革中的数据可视化",{"type":182,"tag":268,"props":279,"children":280},{},[281],{"type":182,"tag":249,"props":282,"children":285},{"href":283,"rel":284},"https://isux.tencent.com/articles/90.html",[253],[286],{"type":187,"value":287},"数据可视化基础研究",{"type":182,"tag":268,"props":289,"children":290},{},[291],{"type":182,"tag":249,"props":292,"children":295},{"href":293,"rel":294},"https://isux.tencent.com/articles/89.html",[253],[296],{"type":187,"value":297},"来做一个数据可视化报表",{"type":182,"tag":268,"props":299,"children":300},{},[301],{"type":182,"tag":249,"props":302,"children":305},{"href":303,"rel":304},"https://isux.tencent.com/articles/79.html",[253],[306],{"type":187,"value":307},"可视化系统搭建",{"type":182,"tag":268,"props":309,"children":310},{},[311],{"type":182,"tag":249,"props":312,"children":315},{"href":313,"rel":314},"https://isux.tencent.com/articles/78.html",[253],[316],{"type":187,"value":317},"数据图表设计（一）",{"type":182,"tag":183,"props":319,"children":320},{},[321],{"type":182,"tag":322,"props":323,"children":324},"q",{},[325],{"type":187,"value":326},"世界上 90％的数据是在过去几年内产生的事实上，过去三十年中，全世界的数据量大约每两年增加 10 倍。",{"type":182,"tag":183,"props":328,"children":329},{},[330],{"type":187,"value":331},"因为数据多且增量大，所以需要持续改进可视化形式。技术上来说，可视化形式逐渐从从过去的表格、信息图、图表，逐渐扩充了交互图表、VR 图表等形式。",{"type":182,"tag":264,"props":333,"children":334},{},[335],{"type":182,"tag":268,"props":336,"children":337},{},[338],{"type":182,"tag":249,"props":339,"children":342},{"href":340,"rel":341},"https://www.datavis.ca/milestones/",[253],[343],{"type":187,"value":344},"图表可视化发展史",{"type":182,"tag":183,"props":346,"children":347},{},[348],{"type":182,"tag":322,"props":349,"children":350},{},[351],{"type":187,"value":352},"大数据时代的数据可视化具有哪些特征，笔者大概将其整理归纳为以下三点。",{"type":182,"tag":264,"props":354,"children":355},{},[356,361,366],{"type":182,"tag":268,"props":357,"children":358},{},[359],{"type":187,"value":360},"直观：使用 3D、动效等加强视觉冲击增强图表的可认知性",{"type":182,"tag":268,"props":362,"children":363},{},[364],{"type":187,"value":365},"交互：通过互动改变数据的表现形式",{"type":182,"tag":268,"props":367,"children":368},{},[369],{"type":187,"value":370},"实时：在庞大的数据量及增量的背景下，数据的实时性尤为重要",{"type":182,"tag":183,"props":372,"children":373},{},[374],{"type":182,"tag":322,"props":375,"children":376},{},[377],{"type":187,"value":378},"为什么人们会对信息图的传播内容更有效的认知呢？",{"type":182,"tag":183,"props":380,"children":381},{},[382],{"type":187,"value":383},"主要原因是因为视觉是人类最强的信息输入方式，其次，信息图提供了特定的语境，能展示多个维度数值并且相互比较。",{"type":182,"tag":183,"props":385,"children":386},{},[387],{"type":182,"tag":322,"props":388,"children":389},{},[390],{"type":187,"value":391},"信息图的分类也逐步划分为：图解（Diagram） 、图表（Chart） 、 表格（Table） 、统计图（Graph） 、 地图（Map）和图形符号（Pictogram）这几部分。",{"type":182,"tag":264,"props":393,"children":394},{},[395,400,405,410,415,420],{"type":182,"tag":268,"props":396,"children":397},{},[398],{"type":187,"value":399},"图解 Diagram：主要运用插图对事物进行说明",{"type":182,"tag":268,"props":401,"children":402},{},[403],{"type":187,"value":404},"图表 Chart：运用图形、线条及插图等，阐明事物的相互关系",{"type":182,"tag":268,"props":406,"children":407},{},[408],{"type":187,"value":409},"表格 Table：根据特定信息标准进行区分，设置纵轴与横轴",{"type":182,"tag":268,"props":411,"children":412},{},[413],{"type":187,"value":414},"统计图 Graph：通过数值来表现变化趋势或进行比较",{"type":182,"tag":268,"props":416,"children":417},{},[418],{"type":187,"value":419},"地图 Map：描述在特定区域和空间里的位置关系",{"type":182,"tag":268,"props":421,"children":422},{},[423],{"type":187,"value":424},"图形符号 Pictogram：不使用文字，运用图画直接传达信息",{"type":182,"tag":183,"props":426,"children":427},{},[428],{"type":182,"tag":322,"props":429,"children":430},{},[431],{"type":187,"value":432},"我们来看一个数据：2017 年 1 月 28 号，成都 PM2.5 值 245，从这个数据里能看出什么",{"type":182,"tag":183,"props":434,"children":435},{},[436],{"type":187,"value":437},"作者通过这个例子展现了收集、清洗、设计这三个完整的流程。他先从环境检测总站获取了 1 月份的检测信息，清洗后获得整个月的 PM2.5 值，通过将 PM2.5 映射成天空的照片，最后线性排开。从最后的图表中可以准确并清晰的确认 1 月份中的好天气。",{"type":182,"tag":183,"props":439,"children":440},{},[441],{"type":182,"tag":225,"props":442,"children":445},{"alt":443,"src":444},"pm25.in 已经关停了","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20231029164117.png",[],{"type":182,"tag":183,"props":447,"children":448},{},[449],{"type":182,"tag":322,"props":450,"children":451},{},[452],{"type":187,"value":453},"数据可视化迭代过程",{"type":182,"tag":183,"props":455,"children":456},{},[457],{"type":182,"tag":458,"props":459,"children":467},"svg",{"id":460,"width":461,"xmlns":462,"xmlnsXLink":463,"height":464,"style":465,"viewBox":466},"mermaid-1698568127289","100%","http://www.w3.org/2000/svg","http://www.w3.org/1999/xlink","507","max-width: 479.140625px;","0 0 479.140625 507",[468,479],{"type":182,"tag":469,"props":470,"children":471},"style",{},[472,474,477],{"type":187,"value":473},"#mermaid-1698568127289 {font-family:\"trebuchet ms\",verdana,arial,sans-serif;font-size:16px;fill:#333;}#mermaid-1698568127289 .error-icon{fill:#552222;}#mermaid-1698568127289 .error-text{fill:#552222;stroke:#552222;}#mermaid-1698568127289 .edge-thickness-normal{stroke-width:2px;}#mermaid-1698568127289 .edge-thickness-thick{stroke-width:3.5px;}#mermaid-1698568127289 .edge-pattern-solid{stroke-dasharray:0;}#mermaid-1698568127289 .edg