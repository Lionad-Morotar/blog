ath":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"body":181,"_type":1158,"_id":1159,"_source":1160,"_file":1161,"_stem":1162,"_extension":1163},"/maps/_visual/info-design","_visual",false,true,"","信息设计","研究如何展示信息。",{"type":182,"children":183,"toc":1156},"root",[184,192,197,202,207,212,219,224,233,238,246,260,266,321,330,335,348,356,374,382,387,395,428,436,441,449,457,669,682,706,729,750,773,794,815,838,859,1022,1151],{"type":185,"tag":186,"props":187,"children":188},"element","p",{},[189],{"type":190,"value":191},"text","信息设计包含两个重要的概念：设计以及信息。即研究如何展示信息。",{"type":185,"tag":186,"props":193,"children":194},{},[195],{"type":190,"value":196},"不仅是“展示”，也许换个词“呈现”，意思更加确切一些，因为设计工作中，我们不仅仅只面向形状、色彩、容器等信息的视觉映像，通常还会涉及视角、情绪、隐喻等心理层面因素。比方说，字体衬线体的古典对比非衬线体的现代感；文字的严肃对比图文的冲击力；黑白的冷淡对比红色的热情。",{"type":185,"tag":186,"props":198,"children":199},{},[200],{"type":190,"value":201},"可以发现，所有信息都会经过设计（设计师）的诠释，后者将其中关建以及内涵（理想、信念）“呈现”给其他人。所以，不论是你闲下来在看的博客、工作日使用的汽车还是街道上的路牌。.. 所有信息都需要设计，最终目标是使清晰、准确而高效的传达。",{"type":185,"tag":186,"props":203,"children":204},{},[205],{"type":190,"value":206},"评价设计的好坏，一般来说，总是围绕着“传达”这个关键点。但“传达”是困难的，设计师站在信息和受众两者中间，为将深奥复杂的信息（甚至缺失）转化能被受众理解的玩意儿花尽了心思，仍然常导向设计失败的结果，也就是我们经常听到“难懂无趣”、“晕”、“欺骗”等指摘。当然，我们总能找到许多反例，比如戴维·卡森设计的杂志封面就要求你必须花费比较多的力气来理解他传达的信息。这显然也是一种“传达”（带有强烈的戴维·卡森风格），就看你是不是他的受众啦。",{"type":185,"tag":186,"props":208,"children":209},{},[210],{"type":190,"value":211},"信息设计也是有难度的。一方面，困扰设计师的问题可能是信息过载、缺失、深奥或无意义；另一方面，信息的真和假也常常被拿出来大加讨论。可以想象，设计师不仅要做一个“人肉翻译器”，用高超的理解力清洗并转换数据，他还需承担设计带来的“道德风险”。也就是说，信息本身在转换的过程中，它也在真与假的模糊中丢失了身影。",{"type":185,"tag":213,"props":214,"children":216},"h4",{"id":215},"多个分组之间怎么对比",[217],{"type":190,"value":218},"多个分组之间怎么对比？",{"type":185,"tag":186,"props":220,"children":221},{},[222],{"type":190,"value":223},"使用柱状图能很好的展示数据在某个维度上的变化趋势，当分组数量变成两个时，也可以在一张图中较为清晰地展示多个分组之间的对比。",{"type":185,"tag":186,"props":225,"children":226},{},[227],{"type":185,"tag":228,"props":229,"children":232},"img",{"alt":230,"src":231},"柱状图","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202412240922088.png",[],{"type":185,"tag":186,"props":234,"children":235},{},[236],{"type":190,"value":237},"但是当分组数量急速上升时，使用山脊线图（Ridge Plot）可能是一个更好的选择。",{"type":185,"tag":186,"props":239,"children":240},{},[241],{"type":185,"tag":228,"props":242,"children":245},{"alt":243,"src":244},"Ridge Plot","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202412240931983.png",[],{"type":185,"tag":186,"props":247,"children":248},{},[249,251],{"type":190,"value":250},"见：",{"type":185,"tag":252,"props":253,"children":257},"a",{"href":254,"rel":255},"https://blog.dailydoseofds.com/p/ridgeline-plots-to-depict-multiple",[256],"nofollow",[258],{"type":190,"value":259},"Ridgeline Plots to Depict Multiple Distributions",{"type":185,"tag":213,"props":261,"children":263},{"id":262},"isux-遇见大数据可视化系列",[264],{"type":190,"value":265},"ISUX 遇见大数据可视化系列",{"type":185,"tag":267,"props":268,"children":269},"ul",{},[270,281,291,301,311],{"type":185,"tag":271,"props":272,"children":273},"li",{},[274],{"type":185,"tag":252,"props":275,"children":278},{"href":276,"rel":277},"https://isux.tencent.com/articles/91.html",[256],[279],{"type":190,"value":280},"未来已来，变革中的数据可视化",{"type":185,"tag":271,"props":282,"children":283},{},[284],{"type":185,"tag":252,"props":285,"children":288},{"href":286,"rel":287},"https://isux.tencent.com/articles/90.html",[256],[289],{"type":190,"value":290},"数据可视化基础研究",{"type":185,"tag":271,"props":292,"children":293},{},[294],{"type":185,"tag":252,"props":295,"children":298},{"href":296,"rel":297},"https://isux.tencent.com/articles/89.html",[256],[299],{"type":190,"value":300},"来做一个数据可视化报表",{"type":185,"tag":271,"props":302,"children":303},{},[304],{"type":185,"tag":252,"props":305,"children":308},{"href":306,"rel":307},"https://isux.tencent.com/articles/79.html",[256],[309],{"type":190,"value":310},"可视化系统搭建",{"type":185,"tag":271,"props":312,"children":313},{},[314],{"type":185,"tag":252,"props":315,"children":318},{"href":316,"rel":317},"https://isux.tencent.com/articles/78.html",[256],[319],{"type":190,"value":320},"数据图表设计（一）",{"type":185,"tag":186,"props":322,"children":323},{},[324],{"type":185,"tag":325,"props":326,"children":327},"q",{},[328],{"type":190,"value":329},"世界上 90％的数据是在过去几年内产生的事实上，过去三十年中，全世界的数据量大约每两年增加 10 倍。",{"type":185,"tag":186,"props":331,"children":332},{},[333],{"type":190,"value":334},"因为数据多且增量大，所以需要持续改进可视化形式。技术上来说，可视化形式逐渐从从过去的表格、信息图、图表，逐渐扩充了交互图表、VR 图表等形式。",{"type":185,"tag":267,"props":336,"children":337},{},[338],{"type":185,"tag":271,"props":339,"children":340},{},[341],{"type":185,"tag":252,"props":342,"children":345},{"href":343,"rel":344},"https://www.datavis.ca/milestones/",[256],[346],{"type":190,"value":347},"图表可视化发展史",{"type":185,"tag":186,"props":349,"children":350},{},[351],{"type":185,"tag":325,"props":352,"children":353},{},[354],{"type":190,"value":355},"大数据时代的数据可视化具有哪些特征，笔者大概将其整理归纳为以下三点。",{"type":185,"tag":267,"props":357,"children":358},{},[359,364,369],{"type":185,"tag":271,"props":360,"children":361},{},[362],{"type":190,"value":363},"直观：使用 3D、动效等加强视觉冲击增强图表的可认知性",{"type":185,"tag":271,"props":365,"children":366},{},[367],{"type":190,"value":368},"交互：通过互动改变数据的表现形式",{"type":185,"tag":271,"props":370,"children":371},{},[372],{"type":190,"value":373},"实时：在庞大的数据量及增量的背景下，数据的实时性尤为重要",{"type":185,"tag":186,"props":375,"children":376},{},[377],{"type":185,"tag":325,"props":378,"children":379},{},[380],{"type":190,"value":381},"为什么人们会对信息图的传播内容更有效的认知呢？",{"type":185,"tag":186,"props":383,"children":384},{},[385],{"type":190,"value":386},"主要原因是因为视觉是人类最强的信息输入方式，其次，信息图提供了特定的语境，能展示多个维度数值并且相互比较。",{"type":185,"tag":186,"props":388,"children":389},{},[390],{"type":185,"tag":325,"props":391,"children":392},{},[393],{"type":190,"value":394},"信息图的分类也逐步划分为：图解（Diagram） 、图表（Chart） 、 表格（Table） 、统计图（Graph） 、 地图（Map）和图形符号（Pictogram）这几部分。",{"type":185,"tag":267,"props":396,"children":397},{},[398,403,408,413,418,423],{"type":185,"tag":271,"props":399,"children":400},{},[401],{"type":190,"value":402},"图解 Diagram：主要运用插图对事物进行说明",{"type":185,"tag":271,"props":404,"children":405},{},[406],{"type":190,"value":407},"图表 Chart：运用图形、线条及插图等，阐明事物的相互关系",{"type":185,"tag":271,"props":409,"children":410},{},[411],{"type":190,"value":412},"表格 Table：根据特定信息标准进行区分，设置纵轴与横轴",{"type":185,"tag":271,"props":414,"children":415},{},[416],{"type":190,"value":417},"统计图 Graph：通过数值来表现变化趋势或进行比较",{"type":185,"tag":271,"props":419,"children":420},{},[421],{"type":190,"value":422},"地图 Map：描述在特定区域和空间里的位置关系",{"type":185,"tag":271,"props":424,"children":425},{},[426],{"type":190,"value":427},"图形符号 Pictogram：不使用文字，运用图画直接传达信息",{"type":185,"tag":186,"props":429,"children":430},{},[431],{"type":185,"tag":325,"props":432,"children":433},{},[434],{"type":190,"value":435},"我们来看一个数据：2017 年 1 月 28 号，成都 PM2.5 值 245，从这个数据里能看出什么",{"type":185,"tag":186,"props":437,"children":438},{},[439],{"type":190,"value":440},"作者通过这个例子展现了收集、清洗、设计这三个完整的流程。他先从环境检测总站获取了 1 月份的检测信息，清洗后获得整个月的 PM2.5 值，通过将 PM2.5 映射成天空的照片，最后线性排开。从最后的图表中可以准确并清晰的确认 1 月份中的好天气。",{"type":185,"tag":186,"props":442,"children":443},{},[444],{"type":185,"tag":228,"props":445,"children":448},{"alt":446,"src":447},"pm25.in 已经关停了","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20231029164117.png",[],{"type":185,"tag":186,"props":450,"children":451},{},[452],{"type":185,"tag":325,"props":453,"children":454},{},[455],{"type":190,"value":456},"数据可视化迭代过程",{"type":185,"tag":186,"props":458,"children":459},{},[460],{"type":185,"tag":461,"props":462,"children":470},"svg",{"id":463,"width":464,"xmlns":465,"xmlnsXLink":466,"height":467,"style":468,"viewBox":469},"mermaid-1698568127289","100%","http://www.w3.org/2000/svg","http://www.w3.org/1999/xlink","507","max-width: 479.140625px;","0 0 479.140625 507",[471,482],{"type":185,"tag":472,"props":473,"children":474},"style",{},[475,477,480],{"type":190,"value":476},"#mermaid-1698568127289 {font-family:\"trebuchet ms\",verdana,arial,sans-serif;font-size:16px;fill:#333;}#mermaid-1698568127289 .error-icon{fill:#552222;}#mermaid-1698568127289 .error-text{fill:#552222;stroke:#552222;}#mermaid-1698568127289 .edge-thickness-normal{stroke-width:2px;}#mermaid-1698568127289 .edge-thickness-thick{stroke-width:3.5px;}#mermaid-1698568127289 .edge-pattern