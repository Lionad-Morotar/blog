,"children":180,"toc":630},"root",[181,190,205,210,216,222,235,240,245,362,367,379,384,397,402,408,428,443,448,453,466,471,476,509,526,543,548,553],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"domain",[187],{"type":188,"value":189},"text","Domain",{"type":182,"tag":191,"props":192,"children":193},"ul",{},[194],{"type":182,"tag":195,"props":196,"children":197},"li",{},[198],{"type":182,"tag":199,"props":200,"children":202},"a",{"href":201},"/maps/_visual/gis/gis",[203],{"type":188,"value":204},"GIS",{"type":182,"tag":183,"props":206,"children":208},{"id":207},"技术",[209],{"type":188,"value":207},{"type":182,"tag":211,"props":212,"children":214},"h4",{"id":213},"模糊效果的实现",[215],{"type":188,"value":213},{"type":182,"tag":217,"props":218,"children":221},"aspect-ratio",{"h":219,"placeholder":220},"503px","TODO - \u003CArticle-G210206-BlurStandards />",[],{"type":182,"tag":223,"props":224,"children":225},"p",{},[226,228],{"type":188,"value":227},"如果打不开的话 P5.js 官网有个简单的示例：",{"type":182,"tag":199,"props":229,"children":233},{"href":230,"rel":231},"https://editor.p5js.org/p5/sketches/Image:_Blur",[232],"nofollow",[234],{"type":188,"value":230},{"type":182,"tag":223,"props":236,"children":237},{},[238],{"type":188,"value":239},"原理非常简单，模糊后的像素的颜色由它旁边一些像素点的颜色决定。",{"type":182,"tag":223,"props":241,"children":242},{},[243],{"type":188,"value":244},"我这里使用的是最简单的计算方法，一个点的值由其相邻的八个像素点的值决定：",{"type":182,"tag":246,"props":247,"children":248},"table",{},[249,286],{"type":182,"tag":250,"props":251,"children":252},"thead",{},[253],{"type":182,"tag":254,"props":255,"children":256},"tr",{},[257,261,270,278],{"type":182,"tag":258,"props":259,"children":260},"th",{},[],{"type":182,"tag":258,"props":262,"children":263},{},[264],{"type":182,"tag":265,"props":266,"children":267},"strong",{},[268],{"type":188,"value":269},"x-1",{"type":182,"tag":258,"props":271,"children":272},{},[273],{"type":182,"tag":265,"props":274,"children":275},{},[276],{"type":188,"value":277},"x",{"type":182,"tag":258,"props":279,"children":280},{},[281],{"type":182,"tag":265,"props":282,"children":283},{},[284],{"type":188,"value":285},"x+1",{"type":182,"tag":287,"props":288,"children":289},"tbody",{},[290,315,339],{"type":182,"tag":254,"props":291,"children":292},{},[293,302,307,311],{"type":182,"tag":294,"props":295,"children":296},"td",{},[297],{"type":182,"tag":265,"props":298,"children":299},{},[300],{"type":188,"value":301},"y-1",{"type":182,"tag":294,"props":303,"children":304},{},[305],{"type":188,"value":306},"1/8",{"type":182,"tag":294,"props":308,"children":309},{},[310],{"type":188,"value":306},{"type":182,"tag":294,"props":312,"children":313},{},[314],{"type":188,"value":306},{"type":182,"tag":254,"props":316,"children":317},{},[318,326,330,335],{"type":182,"tag":294,"props":319,"children":320},{},[321],{"type":182,"tag":265,"props":322,"children":323},{},[324],{"type":188,"value":325},"y",{"type":182,"tag":294,"props":327,"children":328},{},[329],{"type":188,"value":306},{"type":182,"tag":294,"props":331,"children":332},{},[333],{"type":188,"value":334},"0",{"type":182,"tag":294,"props":336,"children":337},{},[338],{"type":188,"value":306},{"type":182,"tag":254,"props":340,"children":341},{},[342,350,354,358],{"type":182,"tag":294,"props":343,"children":344},{},[345],{"type":182,"tag":265,"props":346,"children":347},{},[348],{"type":188,"value":349},"y+1",{"type":182,"tag":294,"props":351,"children":352},{},[353],{"type":188,"value":306},{"type":182,"tag":294,"props":355,"children":356},{},[357],{"type":188,"value":306},{"type":182,"tag":294,"props":359,"children":360},{},[361],{"type":188,"value":306},{"type":182,"tag":223,"props":363,"children":364},{},[365],{"type":188,"value":366},"我们把某个像素点 (x,y) 附近的八个像素的值代入这个 3x3 表格中与乘积之和，得到的结果，就是模糊后应得的值。这个 3x3 表格也叫掩膜（Mask）。有一种类似原理的算法你们应该听过，叫做“高斯模糊”，只不过高斯模糊的掩膜的权重分配使用了高斯的正态分布函数。",{"type":182,"tag":211,"props":368,"children":370},{"id":369},"高斯模糊的原理是什么怎样在界面中实现",[371,377],{"type":182,"tag":372,"props":373,"children":376},"link",{"type":374,"source":375},"h5","https://www.zhihu.com/question/54918332/answer/142137732",[],{"type":188,"value":378},"《高斯模糊的原理是什么，怎样在界面中实现？》",{"type":182,"tag":223,"props":380,"children":381},{},[382],{"type":188,"value":383},"此回答介绍了高斯模糊算法中的一些优化点：",{"type":182,"tag":191,"props":385,"children":386},{},[387,392],{"type":182,"tag":195,"props":388,"children":389},{},[390],{"type":188,"value":391},"可以使用两个一维高斯滤波替代二维滤波减少运算量",{"type":182,"tag":195,"props":393,"children":394},{},[395],{"type":188,"value":396},"可以使用查表法优化",{"type":182,"tag":183,"props":398,"children":400},{"id":399},"概念",[401],{"type":188,"value":399},{"type":182,"tag":183,"props":403,"children":405},{"id":404},"视错觉的形成原理",[406],{"type":188,"value":407},"视错觉的形成原理？",{"type":182,"tag":223,"props":409,"children":410},{},[411,413,426],{"type":188,"value":412},"神经科学告诉我们，注意力更像一层滤网，而不是探照灯。视觉（包括其它知觉）的形成并不是因为人被动的接受信息（感觉），而是外界信息传入后，脑内负责记忆、情感的神经网络主动参与到信息的解释中来。这也就意味着眼睛看到事物其实包含了两个阶段：一是物体发射或反射出的光进入眼睛，在视网膜上成像；二是光信号被视网膜上的细胞捕捉后，经由视觉神经网络传入大脑，大脑再对这些信号进行判断和解读 ",{"type":182,"tag":414,"props":415,"children":416},"sup",{},[417],{"type":182,"tag":199,"props":418,"children":423},{"href":419,"ariaDescribedBy":420,"dataFootnoteRef":175,"id":422},"#user-content-fn-theory",[421],"footnote-label","user-content-fnref-theory",[424],{"type":188,"value":425},"1",{"type":188,"value":427},"。",{"type":182,"tag":429,"props":430,"children":431},"blockquote",{},[432],{"type":182,"tag":223,"props":433,"children":434},{},[435,437],{"type":188,"value":436},"观看从一开始就是有选择的，眼睛对样本做出什么反应，取决于许多生理与心理因素。\n",{"type":182,"tag":438,"props":439,"children":440},"name",{},[441],{"type":188,"value":442},"贡布里希",{"type":182,"tag":223,"props":444,"children":445},{},[446],{"type":188,"value":447},"物理性错视：色彩的膨胀感、进退感、冷暖感、轻重感。",{"type":182,"tag":223,"props":449,"children":450},{},[451],{"type":188,"value":452},"由于眼球的上、下运动比左、右运动困难，因而容易疲倦 ；因为疲倦 ，也就觉得上下的距离要比左右的更长了。",{"type":182,"tag":191,"props":454,"children":455},{},[456,461],{"type":182,"tag":195,"props":457,"children":458},{},[459],{"type":188,"value":460},"将两条长短相等的直线垂直摆放，垂线要比水平线略显得略长。",{"type":182,"tag":195,"props":462,"children":463},{},[464],{"type":188,"value":465},"徒手画个正方形，是个横向扁长的长方形；标准的正方形倒是看起来竖向扁长。",{"type":182,"tag":223,"props":467,"children":468},{},[469],{"type":188,"value":470},"神经信号的传递并不是像机械电路般“一电到底”：信号在神经细胞传递是依靠生物电，但在神经细胞间的传递则需要依靠物理系统的突触结构。突出结构间产生的物质并不一定会被即刻销毁，所以兴奋的神经网络会产生痕迹效应，也就导致了视觉残像。同时，因为神经细胞兴奋会引起“疲劳”，所以对响应的色彩敏感度也会降低，这导致了补色残像的发生。",{"type":182,"tag":223,"props":472,"children":473},{},[474],{"type":188,"value":475},"错觉的分类：",{"type":182,"tag":191,"props":477,"children":478},{},[479,484,489,494,499,504],{"type":182,"tag":195,"props":480,"children":481},{},[482],{"type":188,"value":483},"角度或方向的错视",{"type":182,"tag":195,"props":485,"children":486},{},[487],{"type":188,"value":488},"分割的错视",{"type":182,"tag":195,"props":490,"children":491},{},[492],{"type":188,"value":493},"对比的错视",{"type":182,"tag":195,"props":495,"children":496},{},[497],{"type":188,"value":498},"垂直水平的错视",{"type":182,"tag":195,"props":500,"children":501},{},[502],{"type":188,"value":503},"上方距离过大错视",{"type":182,"tag":195,"props":505,"children":506},{},[507],{"type":188,"value":508},"反转性实体错视",{"type":182,"tag":223,"props":510,"children":511},{},[512,514,525],{"type":188,"value":513},"错视图形的作用可以总结为：增强艺术作品的感染力，增强画面趣味性，增强画面空间想象；其表现手法则大致可分为：图底反转、矛盾空间、图形同构 ",{"type":182,"tag":414,"props":515,"children":516},{},[517],{"type":182,"tag":199,"props":518,"children":522},{"href":519,"ariaDescribedBy":520,"dataFootnoteRef":175,"id":521},"#user-content-fn-express-methods",[421],"user-content-fnref-express-methods",[523],{"type":188,"value":524},"2",{"type":188,"value":427},{"type":182,"tag":223,"props":527,"children":528},{},[529,531,542],{"type":188,"value":530},"人们在观察一个图形时，我们的视知觉往往会把包围且封闭的部分归结为图，而把未包围的部分看成底，部分情况下也有把大面积的部分看为底，积的部分看为图 ",{"type":182,"tag":414,"props":532,"children":533},{},[534],{"type":182,"tag":199,"props":535,"children":539},{"href":536,"ariaDescribedBy":537,"dataFootnoteRef":175,"id":538},"#user-content-fn-reversal-theory",[421],"user-content-fnref-reversal-theory",[540],{"type":188,"value":541},"3",{"type":188,"value":427},{"type":182,"tag":223,"props":544,"children":545},{},[546],{"type":188,"value":547},"矛盾空间的形成原因是图案违反了现实的透视原理。",{"type":182,"tag":223,"props":549,"children":550},{},[551],{"type":188,"value":552},"同构图形即将事物转化成一种新的形象。",{"type":182,"tag":554,"props":555,"children":558},"section",{"className":556,"dataFootnotes":175},[557],"footnotes",[559,566],{"type":182,"tag":183,"props":560,"children":563},{"className":561,"id":421},[562],"sr-only",[564],{"type":188,"value":565},"Footnotes",{"type":182,"tag":567,"props":568,"children":569},"ol",{},[570,592,611],{"type":182,"tag":195,"props":571,"children":573},{"id":572},"user-content-fn-theory",[574,581,583],{"type":182,"tag":199,"props":575,"children":578},{"href":576,"rel":577},"https://www.zhihu.com/xen/market/pdf-view/paid_magazine/1395853043884298240",[232],[579],{"type":188,"value":580},"《浅析图形中的视觉错视》",{"type":188,"value":582}," ",{"type":182,"tag":199,"props":584,"children":589},{"href":585,"ariaLabel":586,"className":587,"dataFootnoteBackref":175},"#user-content-fnref-theory","Back to reference 1",[588],"data-footnote-backref",[590],{"type":188,"value":591},"↩",{"type":182,"tag":195,"props":593,"children":595},{"id":594},"user-content-fn-express-methods",[596,603,604],{"type":182,"tag":199,"props":597,"children":600},{"href":598,"rel":599},"https://www.zhihu.com/xen/market/pdf-view/paid_magazine/1396623366007263232",[232],[601],{"type":188,"value":602},"《平面设计中错视图形运用探析》",{"type":188,"value":582},{"type":182,"tag":199,"props":605,"children":609},{"href":606,"ariaLabel":607,"className":608,"dataFootnoteBackref":175},"#user-content-fnref-express-methods","Back to reference 2",[588],[610],{"type":188,"value":591},{"type":182,"tag":195,"props":612,"children":614},{"id":613},"user-content-fn-reversal-theory",[615,622,623],{"type":182,"tag":199,"props":616,"children":619},{"href":617,"rel":6