息的方式。可视化技术是一种将数据转换为可视化图形的技术，是数据分析的重要手段之一。",{"type":182,"children":183,"toc":633},"root",[184,193,208,213,219,225,238,243,248,365,370,382,387,400,405,411,431,446,451,456,469,474,479,512,529,546,551,556],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"domain",[190],{"type":191,"value":192},"text","Domain",{"type":185,"tag":194,"props":195,"children":196},"ul",{},[197],{"type":185,"tag":198,"props":199,"children":200},"li",{},[201],{"type":185,"tag":202,"props":203,"children":205},"a",{"href":204},"/maps/_visual/gis/gis",[206],{"type":191,"value":207},"GIS",{"type":185,"tag":186,"props":209,"children":211},{"id":210},"技术",[212],{"type":191,"value":210},{"type":185,"tag":214,"props":215,"children":217},"h4",{"id":216},"模糊效果的实现",[218],{"type":191,"value":216},{"type":185,"tag":220,"props":221,"children":224},"aspect-ratio",{"h":222,"placeholder":223},"503px","TODO - \u003CArticle-G210206-BlurStandards />",[],{"type":185,"tag":226,"props":227,"children":228},"p",{},[229,231],{"type":191,"value":230},"如果打不开的话 P5.js 官网有个简单的示例：",{"type":185,"tag":202,"props":232,"children":236},{"href":233,"rel":234},"https://editor.p5js.org/p5/sketches/Image:_Blur",[235],"nofollow",[237],{"type":191,"value":233},{"type":185,"tag":226,"props":239,"children":240},{},[241],{"type":191,"value":242},"原理非常简单，模糊后的像素的颜色由它旁边一些像素点的颜色决定。",{"type":185,"tag":226,"props":244,"children":245},{},[246],{"type":191,"value":247},"我这里使用的是最简单的计算方法，一个点的值由其相邻的八个像素点的值决定：",{"type":185,"tag":249,"props":250,"children":251},"table",{},[252,289],{"type":185,"tag":253,"props":254,"children":255},"thead",{},[256],{"type":185,"tag":257,"props":258,"children":259},"tr",{},[260,264,273,281],{"type":185,"tag":261,"props":262,"children":263},"th",{},[],{"type":185,"tag":261,"props":265,"children":266},{},[267],{"type":185,"tag":268,"props":269,"children":270},"strong",{},[271],{"type":191,"value":272},"x-1",{"type":185,"tag":261,"props":274,"children":275},{},[276],{"type":185,"tag":268,"props":277,"children":278},{},[279],{"type":191,"value":280},"x",{"type":185,"tag":261,"props":282,"children":283},{},[284],{"type":185,"tag":268,"props":285,"children":286},{},[287],{"type":191,"value":288},"x+1",{"type":185,"tag":290,"props":291,"children":292},"tbody",{},[293,318,342],{"type":185,"tag":257,"props":294,"children":295},{},[296,305,310,314],{"type":185,"tag":297,"props":298,"children":299},"td",{},[300],{"type":185,"tag":268,"props":301,"children":302},{},[303],{"type":191,"value":304},"y-1",{"type":185,"tag":297,"props":306,"children":307},{},[308],{"type":191,"value":309},"1/8",{"type":185,"tag":297,"props":311,"children":312},{},[313],{"type":191,"value":309},{"type":185,"tag":297,"props":315,"children":316},{},[317],{"type":191,"value":309},{"type":185,"tag":257,"props":319,"children":320},{},[321,329,333,338],{"type":185,"tag":297,"props":322,"children":323},{},[324],{"type":185,"tag":268,"props":325,"children":326},{},[327],{"type":191,"value":328},"y",{"type":185,"tag":297,"props":330,"children":331},{},[332],{"type":191,"value":309},{"type":185,"tag":297,"props":334,"children":335},{},[336],{"type":191,"value":337},"0",{"type":185,"tag":297,"props":339,"children":340},{},[341],{"type":191,"value":309},{"type":185,"tag":257,"props":343,"children":344},{},[345,353,357,361],{"type":185,"tag":297,"props":346,"children":347},{},[348],{"type":185,"tag":268,"props":349,"children":350},{},[351],{"type":191,"value":352},"y+1",{"type":185,"tag":297,"props":354,"children":355},{},[356],{"type":191,"value":309},{"type":185,"tag":297,"props":358,"children":359},{},[360],{"type":191,"value":309},{"type":185,"tag":297,"props":362,"children":363},{},[364],{"type":191,"value":309},{"type":185,"tag":226,"props":366,"children":367},{},[368],{"type":191,"value":369},"我们把某个像素点 (x,y) 附近的八个像素的值代入这个 3x3 表格中与乘积之和，得到的结果，就是模糊后应得的值。这个 3x3 表格也叫掩膜（Mask）。有一种类似原理的算法你们应该听过，叫做“高斯模糊”，只不过高斯模糊的掩膜的权重分配使用了高斯的正态分布函数。",{"type":185,"tag":214,"props":371,"children":373},{"id":372},"高斯模糊的原理是什么怎样在界面中实现",[374,380],{"type":185,"tag":375,"props":376,"children":379},"link",{"type":377,"source":378},"h5","https://www.zhihu.com/question/54918332/answer/142137732",[],{"type":191,"value":381},"《高斯模糊的原理是什么，怎样在界面中实现？》",{"type":185,"tag":226,"props":383,"children":384},{},[385],{"type":191,"value":386},"此回答介绍了高斯模糊算法中的一些优化点：",{"type":185,"tag":194,"props":388,"children":389},{},[390,395],{"type":185,"tag":198,"props":391,"children":392},{},[393],{"type":191,"value":394},"可以使用两个一维高斯滤波替代二维滤波减少运算量",{"type":185,"tag":198,"props":396,"children":397},{},[398],{"type":191,"value":399},"可以使用查表法优化",{"type":185,"tag":186,"props":401,"children":403},{"id":402},"概念",[404],{"type":191,"value":402},{"type":185,"tag":186,"props":406,"children":408},{"id":407},"视错觉的形成原理",[409],{"type":191,"value":410},"视错觉的形成原理？",{"type":185,"tag":226,"props":412,"children":413},{},[414,416,429],{"type":191,"value":415},"神经科学告诉我们，注意力更像一层滤网，而不是探照灯。视觉（包括其它知觉）的形成并不是因为人被动的接受信息（感觉），而是外界信息传入后，脑内负责记忆、情感的神经网络主动参与到信息的解释中来。这也就意味着眼睛看到事物其实包含了两个阶段：一是物体发射或反射出的光进入眼睛，在视网膜上成像；二是光信号被视网膜上的细胞捕捉后，经由视觉神经网络传入大脑，大脑再对这些信号进行判断和解读 ",{"type":185,"tag":417,"props":418,"children":419},"sup",{},[420],{"type":185,"tag":202,"props":421,"children":426},{"href":422,"ariaDescribedBy":423,"dataFootnoteRef":178,"id":425},"#user-content-fn-theory",[424],"footnote-label","user-content-fnref-theory",[427],{"type":191,"value":428},"1",{"type":191,"value":430},"。",{"type":185,"tag":432,"props":433,"children":434},"blockquote",{},[435],{"type":185,"tag":226,"props":436,"children":437},{},[438,440],{"type":191,"value":439},"观看从一开始就是有选择的，眼睛对样本做出什么反应，取决于许多生理与心理因素。\n",{"type":185,"tag":441,"props":442,"children":443},"name",{},[444],{"type":191,"value":445},"贡布里希",{"type":185,"tag":226,"props":447,"children":448},{},[449],{"type":191,"value":450},"物理性错视：色彩的膨胀感、进退感、冷暖感、轻重感。",{"type":185,"tag":226,"props":452,"children":453},{},[454],{"type":191,"value":455},"由于眼球的上、下运动比左、右运动困难，因而容易疲倦 ；因为疲倦 ，也就觉得上下的距离要比左右的更长了。",{"type":185,"tag":194,"props":457,"children":458},{},[459,464],{"type":185,"tag":198,"props":460,"children":461},{},[462],{"type":191,"value":463},"将两条长短相等的直线垂直摆放，垂线要比水平线略显得略长。",{"type":185,"tag":198,"props":465,"children":466},{},[467],{"type":191,"value":468},"徒手画个正方形，是个横向扁长的长方形；标准的正方形倒是看起来竖向扁长。",{"type":185,"tag":226,"props":470,"children":471},{},[472],{"type":191,"value":473},"神经信号的传递并不是像机械电路般“一电到底”：信号在神经细胞传递是依靠生物电，但在神经细胞间的传递则需要依靠物理系统的突触结构。突出结构间产生的物质并不一定会被即刻销毁，所以兴奋的神经网络会产生痕迹效应，也就导致了视觉残像。同时，因为神经细胞兴奋会引起“疲劳”，所以对响应的色彩敏感度也会降低，这导致了补色残像的发生。",{"type":185,"tag":226,"props":475,"children":476},{},[477],{"type":191,"value":478},"错觉的分类：",{"type":185,"tag":194,"props":480,"children":481},{},[482,487,492,497,502,507],{"type":185,"tag":198,"props":483,"children":484},{},[485],{"type":191,"value":486},"角度或方向的错视",{"type":185,"tag":198,"props":488,"children":489},{},[490],{"type":191,"value":491},"分割的错视",{"type":185,"tag":198,"props":493,"children":494},{},[495],{"type":191,"value":496},"对比的错视",{"type":185,"tag":198,"props":498,"children":499},{},[500],{"type":191,"value":501},"垂直水平的错视",{"type":185,"tag":198,"props":503,"children":504},{},[505],{"type":191,"value":506},"上方距离过大错视",{"type":185,"tag":198,"props":508,"children":509},{},[510],{"type":191,"value":511},"反转性实体错视",{"type":185,"tag":226,"props":513,"children":514},{},[515,517,528],{"type":191,"value":516},"错视图形的作用可以总结为：增强艺术作品的感染力，增强画面趣味性，增强画面空间想象；其表现手法则大致可分为：图底反转、矛盾空间、图形同构 ",{"type":185,"tag":417,"props":518,"children":519},{},[520],{"type":185,"tag":202,"props":521,"children":525},{"href":522,"ariaDescribedBy":523,"dataFootnoteRef":178,"id":524},"#user-content-fn-express-methods",[424],"user-content-fnref-express-methods",[526],{"type":191,"value":527},"2",{"type":191,"value":430},{"type":185,"tag":226,"props":530,"children":531},{},[532,534,545],{"type":191,"value":533},"人们在观察一个图形时，我们的视知觉往往会把包围且封闭的部分归结为图，而把未包围的部分看成底，部分情况下也有把大面积的部分看为底，积的部分看为图 ",{"type":185,"tag":417,"props":535,"children":536},{},[537],{"type":185,"tag":202,"props":538,"children":542},{"href":539,"ariaDescribedBy":540,"dataFootnoteRef":178,"id":541},"#user-content-fn-reversal-theory",[424],"user-content-fnref-reversal-theory",[543],{"type":191,"value":544},"3",{"type":191,"value":430},{"type":185,"tag":226,"props":547,"children":548},{},[549],{"type":191,"value":550},"矛盾空间的形成原因是图案违反了现实的透视原理。",{"type":185,"tag":226,"props":552,"children":553},{},[554],{"type":191,"value":555},"同构图形即将事物转化成一种新的形象。",{"type":185,"tag":557,"props":558,"children":561},"section",{"className":559,"dataFootnotes":178},[560],"footnotes",[562,569],{"type":185,"tag":186,"props":563,"children":566},{"className":564,"id":424},[565],"sr-only",[567],{"type":191,"value":568},"Footnotes",{"type":185,"tag":570,"props":571,"children":572},"ol",{},[573,595,614],{"type":185,"tag":198,"props":574,"children":576},{"id":575},"user-content-fn-theory",[577,584,586],{"type":185,"tag":202,"props":578,"children":581},{"href":579,"rel":580},"https://www.zhihu.com/xen/market/pdf-view/paid_magazine/1395853043884298240",[235],[582],{"type":191,"value":583},"《浅析图形中的视觉错视》",{"type":191,"value":585}," ",{"type":185,"tag":202,"props":587,"children":592},{"href":588,"ariaLabel":589,"className":590,"dataFootnoteBackref":178},"#user-content-fnref-theory","Back to reference 1",[591],"data-footnote-backref",[593],{"type":191,"value":594},"↩",{"type":185,"tag":198,"props":596,"children":598},{"id":597},"user-content-fn-express-methods",[599,606,607],{"type":185,"tag":202,"props":600,"children":603},{"href":601,"rel":602},"https://www.zhihu.com/xen/market/pdf-view/paid_magazine/1396623366007263232",[235],[604],{"type":191,"value":605},"《平面设计中错视图形运用探析》",{"type":191,"value":585},{"type":185,"tag":202,"props":608,"children":612},{"href":609,"ariaLabel":610,"className":611,"dataFootnoteBackref":178},"#user-content-fnref-express-methods","Back to reference 2",[591],[613],{"type":191,"value":594},{"type":185,"tag":198,"props":615,"children":617},{"id":616},"user-content-fn-reversal-theory",[618,625,626],{"type":185,"ta