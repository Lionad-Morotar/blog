tion","visualization",false,true,"","可视化","可视化是一种通过图表、图形、地图等视觉元素来传达信息的方式。可视化技术是一种将数据转换为可视化图形的技术，是数据分析的重要手段之一。","content/6.maps/_visual/visualization.md",{"type":183,"children":184,"toc":634},"root",[185,194,209,214,220,226,239,244,249,366,371,383,388,401,406,412,432,447,452,457,470,475,480,513,530,547,552,557],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"domain",[191],{"type":192,"value":193},"text","Domain",{"type":186,"tag":195,"props":196,"children":197},"ul",{},[198],{"type":186,"tag":199,"props":200,"children":201},"li",{},[202],{"type":186,"tag":203,"props":204,"children":206},"a",{"href":205},"/maps/_visual/gis/gis",[207],{"type":192,"value":208},"GIS",{"type":186,"tag":187,"props":210,"children":212},{"id":211},"技术",[213],{"type":192,"value":211},{"type":186,"tag":215,"props":216,"children":218},"h4",{"id":217},"模糊效果的实现",[219],{"type":192,"value":217},{"type":186,"tag":221,"props":222,"children":225},"aspect-ratio",{"h":223,"placeholder":224},"503px","TODO - \u003CArticle-G210206-BlurStandards />",[],{"type":186,"tag":227,"props":228,"children":229},"p",{},[230,232],{"type":192,"value":231},"如果打不开的话 P5.js 官网有个简单的示例：",{"type":186,"tag":203,"props":233,"children":237},{"href":234,"rel":235},"https://editor.p5js.org/p5/sketches/Image:_Blur",[236],"nofollow",[238],{"type":192,"value":234},{"type":186,"tag":227,"props":240,"children":241},{},[242],{"type":192,"value":243},"原理非常简单，模糊后的像素的颜色由它旁边一些像素点的颜色决定。",{"type":186,"tag":227,"props":245,"children":246},{},[247],{"type":192,"value":248},"我这里使用的是最简单的计算方法，一个点的值由其相邻的八个像素点的值决定：",{"type":186,"tag":250,"props":251,"children":252},"table",{},[253,290],{"type":186,"tag":254,"props":255,"children":256},"thead",{},[257],{"type":186,"tag":258,"props":259,"children":260},"tr",{},[261,265,274,282],{"type":186,"tag":262,"props":263,"children":264},"th",{},[],{"type":186,"tag":262,"props":266,"children":267},{},[268],{"type":186,"tag":269,"props":270,"children":271},"strong",{},[272],{"type":192,"value":273},"x-1",{"type":186,"tag":262,"props":275,"children":276},{},[277],{"type":186,"tag":269,"props":278,"children":279},{},[280],{"type":192,"value":281},"x",{"type":186,"tag":262,"props":283,"children":284},{},[285],{"type":186,"tag":269,"props":286,"children":287},{},[288],{"type":192,"value":289},"x+1",{"type":186,"tag":291,"props":292,"children":293},"tbody",{},[294,319,343],{"type":186,"tag":258,"props":295,"children":296},{},[297,306,311,315],{"type":186,"tag":298,"props":299,"children":300},"td",{},[301],{"type":186,"tag":269,"props":302,"children":303},{},[304],{"type":192,"value":305},"y-1",{"type":186,"tag":298,"props":307,"children":308},{},[309],{"type":192,"value":310},"1/8",{"type":186,"tag":298,"props":312,"children":313},{},[314],{"type":192,"value":310},{"type":186,"tag":298,"props":316,"children":317},{},[318],{"type":192,"value":310},{"type":186,"tag":258,"props":320,"children":321},{},[322,330,334,339],{"type":186,"tag":298,"props":323,"children":324},{},[325],{"type":186,"tag":269,"props":326,"children":327},{},[328],{"type":192,"value":329},"y",{"type":186,"tag":298,"props":331,"children":332},{},[333],{"type":192,"value":310},{"type":186,"tag":298,"props":335,"children":336},{},[337],{"type":192,"value":338},"0",{"type":186,"tag":298,"props":340,"children":341},{},[342],{"type":192,"value":310},{"type":186,"tag":258,"props":344,"children":345},{},[346,354,358,362],{"type":186,"tag":298,"props":347,"children":348},{},[349],{"type":186,"tag":269,"props":350,"children":351},{},[352],{"type":192,"value":353},"y+1",{"type":186,"tag":298,"props":355,"children":356},{},[357],{"type":192,"value":310},{"type":186,"tag":298,"props":359,"children":360},{},[361],{"type":192,"value":310},{"type":186,"tag":298,"props":363,"children":364},{},[365],{"type":192,"value":310},{"type":186,"tag":227,"props":367,"children":368},{},[369],{"type":192,"value":370},"我们把某个像素点 (x,y) 附近的八个像素的值代入这个 3x3 表格中与乘积之和，得到的结果，就是模糊后应得的值。这个 3x3 表格也叫掩膜（Mask）。有一种类似原理的算法你们应该听过，叫做\"高斯模糊\"，只不过高斯模糊的掩膜的权重分配使用了高斯的正态分布函数。",{"type":186,"tag":215,"props":372,"children":374},{"id":373},"高斯模糊的原理是什么怎样在界面中实现",[375,381],{"type":186,"tag":376,"props":377,"children":380},"link",{"type":378,"source":379},"h5","https://www.zhihu.com/question/54918332/answer/142137732",[],{"type":192,"value":382},"《高斯模糊的原理是什么，怎样在界面中实现？》",{"type":186,"tag":227,"props":384,"children":385},{},[386],{"type":192,"value":387},"此回答介绍了高斯模糊算法中的一些优化点：",{"type":186,"tag":195,"props":389,"children":390},{},[391,396],{"type":186,"tag":199,"props":392,"children":393},{},[394],{"type":192,"value":395},"可以使用两个一维高斯滤波替代二维滤波减少运算量",{"type":186,"tag":199,"props":397,"children":398},{},[399],{"type":192,"value":400},"可以使用查表法优化",{"type":186,"tag":187,"props":402,"children":404},{"id":403},"概念",[405],{"type":192,"value":403},{"type":186,"tag":187,"props":407,"children":409},{"id":408},"视错觉的形成原理",[410],{"type":192,"value":411},"视错觉的形成原理？",{"type":186,"tag":227,"props":413,"children":414},{},[415,417,430],{"type":192,"value":416},"神经科学告诉我们，注意力更像一层滤网，而不是探照灯。视觉（包括其它知觉）的形成并不是因为人被动的接受信息（感觉），而是外界信息传入后，脑内负责记忆、情感的神经网络主动参与到信息的解释中来。这也就意味着眼睛看到事物其实包含了两个阶段：一是物体发射或反射出的光进入眼睛，在视网膜上成像；二是光信号被视网膜上的细胞捕捉后，经由视觉神经网络传入大脑，大脑再对这些信号进行判断和解读 ",{"type":186,"tag":418,"props":419,"children":420},"sup",{},[421],{"type":186,"tag":203,"props":422,"children":427},{"href":423,"ariaDescribedBy":424,"dataFootnoteRef":178,"id":426},"#user-content-fn-theory",[425],"footnote-label","user-content-fnref-theory",[428],{"type":192,"value":429},"1",{"type":192,"value":431},"。",{"type":186,"tag":433,"props":434,"children":435},"blockquote",{},[436],{"type":186,"tag":227,"props":437,"children":438},{},[439,441],{"type":192,"value":440},"观看从一开始就是有选择的，眼睛对样本做出什么反应，取决于许多生理与心理因素。\n",{"type":186,"tag":442,"props":443,"children":444},"name",{},[445],{"type":192,"value":446},"贡布里希",{"type":186,"tag":227,"props":448,"children":449},{},[450],{"type":192,"value":451},"物理性错视：色彩的膨胀感、进退感、冷暖感、轻重感。",{"type":186,"tag":227,"props":453,"children":454},{},[455],{"type":192,"value":456},"由于眼球的上、下运动比左、右运动困难，因而容易疲倦 ；因为疲倦 ，也就觉得上下的距离要比左右的更长了 。",{"type":186,"tag":195,"props":458,"children":459},{},[460,465],{"type":186,"tag":199,"props":461,"children":462},{},[463],{"type":192,"value":464},"将两条长短相等的直线垂直摆放，垂线要比水平线略显得略长。",{"type":186,"tag":199,"props":466,"children":467},{},[468],{"type":192,"value":469},"徒手画个正方形，是个横向扁长的长方形；标准的正方形倒是看起来竖向扁长。",{"type":186,"tag":227,"props":471,"children":472},{},[473],{"type":192,"value":474},"神经信号的传递并不是像机械电路般\"一电到底\"：信号在神经细胞传递是依靠生物电，但在神经细胞间的传递则需要依靠物理系统的突触结构。突出结构间产生的物质并不一定会被即刻销毁，所以兴奋的神经网络会产生痕迹效应，也就导致了视觉残像。同时，因为神经细胞兴奋会引起\"疲劳\"，所以对响应的色彩敏感度也会降低，这导致了补色残像的发生。",{"type":186,"tag":227,"props":476,"children":477},{},[478],{"type":192,"value":479},"错觉的分类：",{"type":186,"tag":195,"props":481,"children":482},{},[483,488,493,498,503,508],{"type":186,"tag":199,"props":484,"children":485},{},[486],{"type":192,"value":487},"角度或方向的错视",{"type":186,"tag":199,"props":489,"children":490},{},[491],{"type":192,"value":492},"分割的错视",{"type":186,"tag":199,"props":494,"children":495},{},[496],{"type":192,"value":497},"对比的错视",{"type":186,"tag":199,"props":499,"children":500},{},[501],{"type":192,"value":502},"垂直水平的错视",{"type":186,"tag":199,"props":504,"children":505},{},[506],{"type":192,"value":507},"上方距离过大错视",{"type":186,"tag":199,"props":509,"children":510},{},[511],{"type":192,"value":512},"反转性实体错视",{"type":186,"tag":227,"props":514,"children":515},{},[516,518,529],{"type":192,"value":517},"错视图形的作用可以总结为：增强艺术作品的感染力，增强画面趣味性，增强画面空间想象；其表现手法则大致可分为：图底反转、矛盾空间、图形同构 ",{"type":186,"tag":418,"props":519,"children":520},{},[521],{"type":186,"tag":203,"props":522,"children":526},{"href":523,"ariaDescribedBy":524,"dataFootnoteRef":178,"id":525},"#user-content-fn-express-methods",[425],"user-content-fnref-express-methods",[527],{"type":192,"value":528},"2",{"type":192,"value":431},{"type":186,"tag":227,"props":531,"children":532},{},[533,535,546],{"type":192,"value":534},"人们在观察一个图形时，我们的视知觉往往会把包围且封闭的部分归结为图，而把未包围的部分看成底，部分情况下也有把大面积的部分看为底，积的部分看为图 ",{"type":186,"tag":418,"props":536,"children":537},{},[538],{"type":186,"tag":203,"props":539,"children":543},{"href":540,"ariaDescribedBy":541,"dataFootnoteRef":178,"id":542},"#user-content-fn-reversal-theory",[425],"user-content-fnref-reversal-theory",[544],{"type":192,"value":545},"3",{"type":192,"value":431},{"type":186,"tag":227,"props":548,"children":549},{},[550],{"type":192,"value":551},"矛盾空间的形成原因是图案违反了现实的透视原理。",{"type":186,"tag":227,"props":553,"children":554},{},[555],{"type":192,"value":556},"同构图形即将事物转化成一种新的形象。",{"type":186,"tag":558,"props":559,"children":562},"section",{"className":560,"dataFootnotes":178},[561],"footnotes",[563,570],{"type":186,"tag":187,"props":564,"children":567},{"className":565,"id":425},[566],"sr-only",[568],{"type":192,"value":569},"Footnotes",{"type":186,"tag":571,"props":572,"children":573},"ol",{},[574,596,615],{"type":186,"tag":199,"props":575,"children":577},{"id":576},"user-content-fn-theory",[578,585,587],{"type":186,"tag":203,"props":579,"children":582},{"href":580,"rel":581},"https://www.zhihu.com/xen/market/pdf-view/paid_magazine/1395853043884298240",[236],[583],{"type":192,"value":584},"《浅析图形中的视觉错视》",{"type":192,"value":586}," ",{"type":186,"tag":203,"props":588,"children":593},{"href":589,"ariaLabel":590,"className":591,"dataFootnoteBackref":178},"#user-content-fnref-theory","Back to reference 1",[592],"data-footnote-backref",[594],{"type":192,"value":595},"↩",{"type":186,"tag":199,"props":597,"children":599},{"id":598},"user-content-fn-express-methods",[600,607,608],{"type":186,"tag":203,"props":601,"children":604},{"href":602,"rel":603},"https://www.zhihu.com/xen/market/pdf-view/paid_magazine/1396623366007263232",[236],[605],{"type":192,"value":606},"《平面设计中错视图形运用探析》",{"type":192,"value":586},{"type":186,"tag":203,"props":609,"children":613},{"href":610,"ariaLabel":611,"className":612,"dataFootnoteBackref":178},"#user-content-fnref-express-methods","Back to reference 2",[592],[614],{"type":192,"value":595},{"type"