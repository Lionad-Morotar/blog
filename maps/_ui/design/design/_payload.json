:85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"original_path":181,"body":182,"_type":1336,"_id":1337,"_source":1338,"_file":1339,"_stem":1340,"_extension":1341},"/maps/_ui/design/design","design",false,true,"","设计","UI 设计原则、设计哲学与视觉风格","content/6.maps/_ui/design-philosophy.md",{"type":183,"children":184,"toc":1331},"root",[185,193,199,206,211,226,232,237,243,248,253,258,272,278,283,288,293,304,310,315,401,406,415,421,426,459,464,474,479,485,511,553,558,563,569,583,978,988,993,1003,1021,1030,1073,1078,1111,1122,1128,1133,1166,1171,1182,1188,1193,1226,1231,1240,1246,1258,1291,1296,1305,1310,1325],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"设计哲学",[191],{"type":192,"value":189},"text",{"type":186,"tag":194,"props":195,"children":196},"p",{},[197],{"type":192,"value":198},"软件界面不仅是功能的载体，更是特定时代价值观与文化信念的具象化表达。从 Winamp 的作者性设计到现代 AI 界面的极简主义，设计范式的变迁折射出我们对技术、美学与人性关系的深层思考。",{"type":186,"tag":200,"props":201,"children":203},"h4",{"id":202},"好界面应该是隐形的吗",[204],{"type":192,"value":205},"好界面应该是「隐形」的吗？",{"type":186,"tag":194,"props":207,"children":208},{},[209],{"type":192,"value":210},"现代设计信条认为最佳界面是「无界面」——用户应专注于音乐、照片、内容本身，而非软件。但这一追求产生了意外的后果：为了视觉上的「干净」，设计师创造了反直觉的多维导航结构，动画不再代表连贯的空间模型（某些屏幕从底部滑入暗示 3D 空间，另一些却从图标中跳出），用户在看似简洁的界面中迷失方向。",{"type":186,"tag":212,"props":213,"children":214},"blockquote",{},[215],{"type":186,"tag":194,"props":216,"children":217},{},[218,220],{"type":192,"value":219},"Winamp 从未让我觉得自己愚蠢。现代应用有时让我感觉快要失去理智。\n",{"type":186,"tag":221,"props":222,"children":223},"name",{},[224],{"type":192,"value":225},"Rakhim",{"type":186,"tag":200,"props":227,"children":229},{"id":228},"winamp-的可见性为何反而更易用",[230],{"type":192,"value":231},"Winamp 的「可见性」为何反而更易用？",{"type":186,"tag":194,"props":233,"children":234},{},[235],{"type":192,"value":236},"Winamp（1997）的独特之处在于其强烈的作者性——创始人 Justin Frankel 将自己对「酷」的理解注入每个设计决策：拟物化按钮、鲜艳配色、高对比度滑块。这些视觉元素并非干扰，而是构建了一致的心理模型。用户面对单一屏幕上的多彩控件，能够直观理解软件的结构和行为，而非在「梦境般流动」的层级中猜测。",{"type":186,"tag":200,"props":238,"children":240},{"id":239},"从-windows-xp-到现代-ai-界面设计范式的转移",[241],{"type":192,"value":242},"从 Windows XP 到现代 AI 界面：设计范式的转移",{"type":186,"tag":194,"props":244,"children":245},{},[246],{"type":192,"value":247},"Windows XP 的 Luna 设计、Office 的 Clippy 助手都体现了同一个理念：软件可以有个性、有情感、甚至有点「人味」。然而当代界面（Apple Music、ChatGPT、Notion）遵循「情感中立」的信条，追求普适性和极简。这不是技术或商业的必然，而是社会价值观的转变——我们不再期待技术产品具有人格。",{"type":186,"tag":200,"props":249,"children":251},{"id":250},"功能主义设计霸权下的个人表达空间",[252],{"type":192,"value":250},{"type":186,"tag":194,"props":254,"children":255},{},[256],{"type":192,"value":257},"现代设计系统强调一致性、可预测性和效率，这带来了可用性提升。但当所有界面都遵循同样的极简美学时，我们失去了什么？Duolingo 的成功证明：即使是现代企业，有个性（哪怕有点烦人）的品牌依然能打动用户。问题的关键不在于「能不能做」，而在于「我们是否还需要它」。",{"type":186,"tag":194,"props":259,"children":260},{},[261,263],{"type":192,"value":262},"见：",{"type":186,"tag":264,"props":265,"children":269},"a",{"href":266,"rel":267},"https://rakhim.exotext.com/modern-ui-is-not-invisible",[268],"nofollow",[270],{"type":192,"value":271},"Modern UI is clean and invisible? Ha, I wish!",{"type":186,"tag":200,"props":273,"children":275},{"id":274},"响应式-ui-与事务式-ui-的根本区别是什么",[276],{"type":192,"value":277},"响应式 UI 与事务式 UI 的根本区别是什么？",{"type":186,"tag":194,"props":279,"children":280},{},[281],{"type":192,"value":282},"Mac OS X（约 2008 年）是首个真正践行\"响应式\"理念的操作系统。在此之前，Windows 的范式是：\n查询信息时一次性获取，从不自动更新——用户必须手动刷新。",{"type":186,"tag":194,"props":284,"children":285},{},[286],{"type":192,"value":287},"这种差异体现在偏好设置界面：Windows 使用「确定/取消/应用」三按钮模式，\n用户无法在提交前看到修改效果；而 Mac 选择即时生效——切换选项立即生效，\n点错只需再点一次即可撤销。前者是事务式（transactional），后者是响应式（reactive）。",{"type":186,"tag":194,"props":289,"children":290},{},[291],{"type":192,"value":292},"响应式 UI 的核心挑战不在于显示数据，而在于处理交互。这需要重新思考数据建模方式——\n传统的 SQL 范式将数据碎片化为 rigid 表格，使得变更影响难以预测，\n更遑论可靠地撤销或同步。",{"type":186,"tag":194,"props":294,"children":295},{},[296,297],{"type":192,"value":262},{"type":186,"tag":264,"props":298,"children":301},{"href":299,"rel":300},"https://acko.net/blog/get-in-zoomer-we-re-saving-react/",[268],[302],{"type":192,"value":303},"Get in Zoomer, We're Saving React",{"type":186,"tag":200,"props":305,"children":307},{"id":306},"桌面软件的黄金时代有哪些已失落的交互细节",[308],{"type":192,"value":309},"桌面软件的黄金时代有哪些已失落的交互细节？",{"type":186,"tag":194,"props":311,"children":312},{},[313],{"type":192,"value":314},"Mac OS X Leopard（2007）时期的桌面软件提供了许多如今 SaaS 应用中已消失的 affordances：",{"type":186,"tag":316,"props":317,"children":318},"ul",{},[319,331,341,351,361,371,381,391],{"type":186,"tag":320,"props":321,"children":322},"li",{},[323,329],{"type":186,"tag":324,"props":325,"children":326},"strong",{},[327],{"type":192,"value":328},"菜单导航",{"type":192,"value":330},"：鼠标可以越过空白区域和其他菜单项，无需严格沿 hover 矩形移动",{"type":186,"tag":320,"props":332,"children":333},{},[334,339],{"type":186,"tag":324,"props":335,"children":336},{},[337],{"type":192,"value":338},"标题栏拖拽",{"type":192,"value":340},"：可直接从文档标题栏拖拽文件图标进行上传等操作",{"type":186,"tag":320,"props":342,"children":343},{},[344,349],{"type":186,"tag":324,"props":345,"children":346},{},[347],{"type":192,"value":348},"快捷键预览",{"type":192,"value":350},"：按住 Ctrl/Alt 等修饰键立即在菜单中反映，让高级功能可被发现在又不突兀",{"type":186,"tag":320,"props":352,"children":353},{},[354,359],{"type":186,"tag":324,"props":355,"children":356},{},[357],{"type":192,"value":358},"离线优先",{"type":192,"value":360},"：可离线浏览多年文档并即时起草新内容，零延迟",{"type":186,"tag":320,"props":362,"children":363},{},[364,369],{"type":186,"tag":324,"props":365,"children":366},{},[367],{"type":192,"value":368},"稳定排序",{"type":192,"value":370},"：任何表格可按任意列排序，并记住先前键值实现稳定排序",{"type":186,"tag":320,"props":372,"children":373},{},[374,379],{"type":186,"tag":324,"props":375,"children":376},{},[377],{"type":192,"value":378},"撤销/重做",{"type":192,"value":380},"：即使在 Finder 中移动整个目录也是标准功能",{"type":186,"tag":320,"props":382,"children":383},{},[384,389],{"type":186,"tag":324,"props":385,"children":386},{},[387],{"type":192,"value":388},"富文本复制粘贴",{"type":192,"value":390},"：与拖拽完全等价的复制粘贴体验",{"type":186,"tag":320,"props":392,"children":393},{},[394,399],{"type":186,"tag":324,"props":395,"children":396},{},[397],{"type":192,"value":398},"实时同步",{"type":192,"value":400},"：重命名或移动正在编辑的文件，窗口即时反映新名称和位置",{"type":186,"tag":194,"props":402,"children":403},{},[404],{"type":192,"value":405},"这些细节不是\"锦上添花\"，而是专业软件可用性的基础。",{"type":186,"tag":194,"props":407,"children":408},{},[409,410],{"type":192,"value":262},{"type":186,"tag":264,"props":411,"children":413},{"href":299,"rel":412},[268],[414],{"type":192,"value":303},{"type":186,"tag":200,"props":416,"children":418},{"id":417},"桌面软件-affordances-的流失在-2026-年是否得到回应",[419],{"type":192,"value":420},"桌面软件 affordances 的流失在 2026 年是否得到回应？",{"type":186,"tag":194,"props":422,"children":423},{},[424],{"type":192,"value":425},"2022 年的批评认为 SaaS 时代已失去桌面软件的基础交互能力。\n2025-2026 年的\"本地优先软件\"（Local-First Software）运动对此作出了强烈回响：",{"type":186,"tag":316,"props":427,"children":428},{},[429,439,449],{"type":186,"tag":320,"props":430,"children":431},{},[432,437],{"type":186,"tag":324,"props":433,"children":434},{},[435],{"type":192,"value":436},"SQLite Wasm",{"type":192,"value":438}," 让浏览器内本地数据库成为可能",{"type":186,"tag":320,"props":440,"children":441},{},[442,447],{"type":186,"tag":324,"props":443,"children":444},{},[445],{"type":192,"value":446},"CRDT 同步",{"type":192,"value":448},"（Automerge、Yjs）提供标准的多端协作方案",{"type":186,"tag":320,"props":450,"children":451},{},[452,457],{"type":186,"tag":324,"props":453,"children":454},{},[455],{"type":192,"value":456},"端到端加密",{"type":192,"value":458},"让用户重新拥有数据主权",{"type":186,"tag":194,"props":460,"children":461},{},[462],{"type":192,"value":463},"AI 辅助编程的兴起意外强化了这一趋势——当代码生成变得廉价，\n开发者开始重新重视\"软件质感\"。Obsidian、Linear、Figma 的离线模式等\n本地优先工具获得追捧，证明 2007 年 Mac OS X 的设计智慧并未被遗忘。",{"type":186,"tag":194,"props":465,"children":466},{},[467,472],{"type":186,"tag":324,"props":468,"children":469},{},[470],{"type":192,"value":471},"修正结论",{"type":192,"value":473},"：原文对\"技术失忆\"的批评是及时的预警，但低估了新一代开发者\n对经典设计范式的重新发现能力。怀旧不应转为绝望，而应成为创新的参照。",{"type":186,"tag":187,"props":475,"children":477},{"id":476},"设计风格",[478],{"type":192,"value":476},{"type":186,"tag":200,"props":480,"children":482},{"id":481},"玻璃拟态是什么",[483],{"type":192,"value":484},"玻璃拟态是什么？",{"type":186,"tag":194,"props":486,"children":487},{},[488,490,495,497,502,504,509],{"type":192,"value":489},"一种现代 UI 视觉风格，通过",{"type":18