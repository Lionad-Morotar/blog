,"children":1138},{},[1139,1144],{"type":186,"tag":324,"props":1140,"children":1141},{},[1142],{"type":192,"value":1143},"大图为先的布局",{"type":192,"value":1145},"：围绕大型视觉内容构建，慷慨的留白和克制的字体系统",{"type":186,"tag":320,"props":1147,"children":1148},{},[1149,1154],{"type":186,"tag":324,"props":1150,"children":1151},{},[1152],{"type":192,"value":1153},"内容层级强化",{"type":192,"value":1155},"：每个元素的位置都为了强化内容层次，让图像保持焦点",{"type":186,"tag":320,"props":1157,"children":1158},{},[1159,1164],{"type":186,"tag":324,"props":1160,"children":1161},{},[1162],{"type":192,"value":1163},"黑白经典美学",{"type":192,"value":1165},"：保持建筑工作室标志性的黑白质感，同时通过强动效系统推动布局创新",{"type":186,"tag":194,"props":1167,"children":1168},{},[1169],{"type":192,"value":1170},"设计意图明确：突出项目而不让界面喧宾夺主。建筑作品依赖强烈意象和精心构图，网站需充当支撑结构。",{"type":186,"tag":194,"props":1172,"children":1173},{},[1174,1175],{"type":192,"value":262},{"type":186,"tag":264,"props":1176,"children":1179},{"href":1177,"rel":1178},"https://tympanus.net/codrops/2026/02/25/reshaping-telha-clarkes-digital-home-from-wordmark-to-motion-system/",[268],[1180],{"type":192,"value":1181},"Reshaping Telha Clarke's Digital Home",{"type":186,"tag":200,"props":1183,"children":1185},{"id":1184},"动效如何成为品牌表达的一部分",[1186],{"type":192,"value":1187},"动效如何成为品牌表达的一部分？",{"type":186,"tag":194,"props":1189,"children":1190},{},[1191],{"type":192,"value":1192},"动效系统可以传递品牌的核心价值观。Telha Clarke 案例中的动效设计原则：",{"type":186,"tag":316,"props":1194,"children":1195},{},[1196,1206,1216],{"type":186,"tag":320,"props":1197,"children":1198},{},[1199,1204],{"type":186,"tag":324,"props":1200,"children":1201},{},[1202],{"type":192,"value":1203},"精致而克制",{"type":192,"value":1205},"：动效反映建筑作品中固有的精准与平静，从不浮夸，始终深思熟虑",{"type":186,"tag":320,"props":1207,"children":1208},{},[1209,1214],{"type":186,"tag":324,"props":1210,"children":1211},{},[1212],{"type":192,"value":1213},"匠心关联",{"type":192,"value":1215},"：加载动画分两步揭示新标识，微妙呼应两位创始人的二元性",{"type":186,"tag":320,"props":1217,"children":1218},{},[1219,1224],{"type":186,"tag":324,"props":1220,"children":1221},{},[1222],{"type":192,"value":1223},"刻意节奏",{"type":192,"value":1225},"：加载器的从容 pace 反映工作室工作的细心与工艺",{"type":186,"tag":194,"props":1227,"children":1228},{},[1229],{"type":192,"value":1230},"这种\"动效即品牌语言\"的方法，在数字体验与建筑实践之间建立了即时联系。",{"type":186,"tag":194,"props":1232,"children":1233},{},[1234,1235],{"type":192,"value":262},{"type":186,"tag":264,"props":1236,"children":1238},{"href":1177,"rel":1237},[268],[1239],{"type":192,"value":1181},{"type":186,"tag":200,"props":1241,"children":1243},{"id":1242},"智能自适应-cta-组件如何解决重复调用问题",[1244],{"type":192,"value":1245},"智能自适应 CTA 组件如何解决重复调用问题？",{"type":186,"tag":194,"props":1247,"children":1248},{},[1249,1251,1256],{"type":192,"value":1250},"为避免页面被重复的CTA淹没，Telha Clarke 网站引入了",{"type":186,"tag":324,"props":1252,"children":1253},{},[1254],{"type":192,"value":1255},"单一浮动CTA组件",{"type":192,"value":1257},"，其核心机制：",{"type":186,"tag":316,"props":1259,"children":1260},{},[1261,1271,1281],{"type":186,"tag":320,"props":1262,"children":1263},{},[1264,1269],{"type":186,"tag":324,"props":1265,"children":1266},{},[1267],{"type":192,"value":1268},"上下文感知",{"type":192,"value":1270},"：根据当前屏幕可见区域动态更新内容和意图",{"type":186,"tag":320,"props":1272,"children":1273},{},[1274,1279],{"type":186,"tag":324,"props":1275,"children":1276},{},[1277],{"type":192,"value":1278},"功能变形",{"type":192,"value":1280},"：同一组件适配多种用途——在作品页作为筛选下拉菜单（移动端），或在项目页底部自动展开为\"下一个项目\"按钮",{"type":186,"tag":320,"props":1282,"children":1283},{},[1284,1289],{"type":186,"tag":324,"props":1285,"children":1286},{},[1287],{"type":192,"value":1288},"界面静音",{"type":192,"value":1290},"：保持界面简洁有意图，同时以有意义的方式引导用户",{"type":186,"tag":194,"props":1292,"children":1293},{},[1294],{"type":192,"value":1295},"这种\"一个组件，多种形态\"的模式，在视觉精致度与信息清晰度之间实现了平衡。",{"type":186,"tag":194,"props":1297,"children":1298},{},[1299,1300],{"type":192,"value":262},{"type":186,"tag":264,"props":1301,"children":1303},{"href":1177,"rel":1302},[268],[1304],{"type":192,"value":1181},{"type":186,"tag":187,"props":1306,"children":