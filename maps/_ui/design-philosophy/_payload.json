_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"body":181,"_type":268,"_id":269,"_source":270,"_file":271,"_stem":272,"_extension":273},"/maps/_ui/design-philosophy","_ui",false,true,"","设计哲学","关于软件界面设计背后的价值观、文化变迁与人性表达",{"type":182,"children":183,"toc":265},"root",[184,192,199,204,219,225,230,236,241,246,251],{"type":185,"tag":186,"props":187,"children":188},"element","p",{},[189],{"type":190,"value":191},"text","软件界面不仅是功能的载体，更是特定时代价值观与文化信念的具象化表达。从 Winamp 的作者性设计到现代 AI 界面的极简主义，设计范式的变迁折射出我们对技术、美学与人性关系的深层思考。",{"type":185,"tag":193,"props":194,"children":196},"h4",{"id":195},"好界面应该是隐形的吗",[197],{"type":190,"value":198},"好界面应该是「隐形」的吗？",{"type":185,"tag":186,"props":200,"children":201},{},[202],{"type":190,"value":203},"现代设计信条认为最佳界面是「无界面」——用户应专注于音乐、照片、内容本身，而非软件。但这一追求产生了意外的后果：为了视觉上的「干净」，设计师创造了反直觉的多维导航结构，动画不再代表连贯的空间模型（某些屏幕从底部滑入暗示 3D 空间，另一些却从图标中跳出），用户在看似简洁的界面中迷失方向。",{"type":185,"tag":205,"props":206,"children":207},"blockquote",{},[208],{"type":185,"tag":186,"props":209,"children":210},{},[211,213],{"type":190,"value":212},"Winamp 从未让我觉得自己愚蠢。现代应用有时让我感觉快要失去理智。\n",{"type":185,"tag":214,"props":215,"children":216},"name",{},[217],{"type":190,"value":218},"Rakhim",{"type":185,"tag":193,"props":220,"children":222},{"id":221},"winamp-的可见性为何反而更易用",[223],{"type":190,"value":224},"Winamp 的「可见性」为何反而更易用？",{"type":185,"tag":186,"props":226,"children":227},{},[228],{"type":190,"value":229},"Winamp（1997）的独特之处在于其强烈的作者性——创始人 Justin Frankel 将自己对「酷」的理解注入每个设计决策：拟物化按钮、鲜艳配色、高对比度滑块。这些视觉元素并非干扰，而是构建了一致的心理模型。用户面对单一屏幕上的多彩控件，能够直观理解软件的结构和行为，而非在「梦境般流动」的层级中猜测。",{"type":185,"tag":193,"props":231,"children":233},{"id":232},"从-windows-xp-到现代-ai-界面设计范式的转移",[234],{"type":190,"value":235},"从 Windows XP 到现代 AI 界面：设计范式的转移",{"type":185,"tag":186,"props":237,"children":238},{},[239],{"type":190,"value":240},"Windows XP 的 Luna 设计、Office 的 Clippy 助手都体现了同一个理念：软件可以有个性、有情感、甚至有点「人味」。然而当代界面（Apple Music、ChatGPT、Notion）遵循「情感中立」的信条，追求普适性和极简。这不是技术或商业的必然，而是社会价值观的转变——我们不再期待技术产品具有人格。",{"type":185,"tag":193,"props":242,"children":244},{"id":243},"功能主义设计霸权下的个人表达空间",[245],{"type":190,"value":243},{"type":185,"tag":186,"props":247,"children":248},{},[249],{"type":190,"value":250},"现代设计系统强调一致性、可预测性和效率，这带来了可用性提升。但当所有界面都遵循同样的极简美学时，我们失去了什么？Duolingo 的成功证明：即使是现代企业，有个性（哪怕有点烦人）的品牌依然能打动用户。问题的关键不在于「能不能做」，而在于「我们是否还需要它」。",{"type":185,"tag":186,"props":252,"children":253},{},[254,256],{"type":190,"value":255},"见：",{"type":185,"tag":257,"props":258,"children":262},"a",{"href":259,"rel":260},"https://rakhim.exotext.com/modern-ui-is-not-invisible",[261],"nofollow",[263],{"type":190,"value":264},"Modern UI is clean and invisible? Ha, I wish!",{"title":178,"searchDepth":266,"depth":266,"links":267},2,[],"markdown","content:6.maps:_ui:design-philosophy.md","content","6.maps/_ui/design-philosophy.md","6.maps/_ui/design-philosophy","md",[275,279],{"_path":276,"title":277,"description":278},"/maps/_ui/awwwards","Awwwards","Awwwards 是全球知名的每日网页设计灵感平台，提供网站评选、设计灵感、学习资源和行业目录。",{"_path":280,"title":281,"description":282},"/maps/_ui/font","字体","字体是文字的视觉表现形式，是视觉设计的基础。字体的选择、排版、字重、字体大小、行高等都是影响视觉效果的重要因素。",1771696729012]