具，帮助提升开发效率和代码质量",{"type":182,"children":183,"toc":417},"root",[184,193,199,204,249,255,260,269,283,291,319,327,360,368,386,394],{"type":185,"tag":186,"props":187,"children":189},"element","h4",{"id":188},"什么是软件工程",[190],{"type":191,"value":192},"text","什么是软件工程？",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"软件工程是指在软件开发过程中，应用工程化的原则和方法，以提高软件质量、降低开发成本、缩短开发周期为目标的一门学科。它涵盖是一个涵盖需求、设计、实现、测试、部署、运维、管理和持续改进的完整闭环体系，贯穿软件从“想法”到“产品”再到“持续运营”的全部过程。每一环节都有专业的方法、流程和工具保障交付的高质高效。",{"type":185,"tag":194,"props":200,"children":201},{},[202],{"type":191,"value":203},"当然可以，以下是用简洁 list 形式概括的软件工程主要内容：",{"type":185,"tag":205,"props":206,"children":207},"ol",{},[208,214,219,224,229,234,239,244],{"type":185,"tag":209,"props":210,"children":211},"li",{},[212],{"type":191,"value":213},"需求分析：调研与获取需求，建模并形成需求规格说明书。",{"type":185,"tag":209,"props":215,"children":216},{},[217],{"type":191,"value":218},"系统设计：设计系统架构，划分模块，设计数据库和接口，输出设计文档。",{"type":185,"tag":209,"props":220,"children":221},{},[222],{"type":191,"value":223},"编码实现：按规范开发模块，代码审查，执行单元测试。",{"type":185,"tag":209,"props":225,"children":226},{},[227],{"type":191,"value":228},"软件测试：开展单元、集成、系统、验收及自动化测试，确保质量。",{"type":185,"tag":209,"props":230,"children":231},{},[232],{"type":191,"value":233},"部署运维：进行CI/CD、配置管理、监控、日志分析和故障恢复，保障系统稳定。",{"type":185,"tag":209,"props":235,"children":236},{},[237],{"type":191,"value":238},"项目管理：管理进度、范围、成本、风险、团队与质量，确保高效协作与交付。",{"type":185,"tag":209,"props":240,"children":241},{},[242],{"type":191,"value":243},"文档与配置管理：完善各类文档，进行版本控制和配置项管理，保证可追溯性与一致性。",{"type":185,"tag":209,"props":245,"children":246},{},[247],{"type":191,"value":248},"过程改进：评估与优化流程，推广自动化工具，持续提升开发效率和软件质量。",{"type":185,"tag":186,"props":250,"children":252},{"id":251},"什么是前端工程化",[253],{"type":191,"value":254},"什么是前端工程化？",{"type":185,"tag":194,"props":256,"children":257},{},[258],{"type":191,"value":259},"前端工程化可以从软件工程借鉴部分定义，泛指将自动化、标准化、流程化等工程领域思想应用于前端开发全过程，以达到提升开发效率、提高代码质量与可维护性、协同团队合作的目的。",{"type":185,"tag":194,"props":261,"children":262},{},[263],{"type":185,"tag":264,"props":265,"children":266},"strong",{},[267],{"type":191,"value":268},"代码规范",{"type":185,"tag":270,"props":271,"children":272},"ul",{},[273,278],{"type":185,"tag":209,"props":274,"children":275},{},[276],{"type":191,"value":277},"代码规范：通过 ESLint 等工具，统一代码风格，减少低级错误。",{"type":185,"tag":209,"props":279,"children":280},{},[281],{"type":191,"value":282},"代码片段：借助 Snippets 或脚本创建代码模版，减少重复性编码工作。",{"type":185,"tag":194,"props":284,"children":285},{},[286],{"type":185,"tag":264,"props":287,"children":288},{},[289],{"type":191,"value":290},"开发模式",{"type":185,"tag":270,"props":292,"children":293},{},[294,299,304,309,314],{"type":185,"tag":209,"props":295,"children":296},{},[297],{"type":191,"value":298},"模块化：采用 ESM 等模块化方式，细化逻辑颗粒度，实现代码复用，提升可维护性。",{"type":185,"tag":209,"props":300,"children":301},{},[302],{"type":191,"value":303},"组件化：使用 Vue 等现代框架，将 UI 拆分为独立、可复用的组件。",{"type":185,"tag":209,"props":305,"children":306},{},[307],{"type":191,"value":308},"依赖管理：使用 pnpm 等包管理工具，规范依赖引入、更新、审计过程。",{"type":185,"tag":209,"props":310,"children":311},{},[312],{"type":191,"value":313},"框架约束：使用 Nuxt 等元框架，减少基础架构工作，提升起步效率。",{"type":185,"tag":209,"props":315,"children":316},{},[317],{"type":191,"value":318},"代码历史：结合 Git 及工作流，优化代码协同流程，提供代码的历史追踪数据。",{"type":185,"tag":194,"props":320,"children":321},{},[322],{"type":185,"tag":264,"props":323,"children":324},{},[325],{"type":191,"value":326},"质量保证",{"type":185,"tag":270,"props":328,"children":329},{},[330,335,340,345,350,355],{"type":185,"tag":209,"props":331,"children":332},{},[333],{"type":191,"value":334},"安全审计：通过 Socket、pnpm audit 等工具，自动化检查依赖包的安全漏洞，确保项目安全。",{"type":185,"tag":209,"props":336,"children":337},{},[338],{"type":191,"value":339},"代码审查：借助 Pull Request、Code Review 流程，保障最低代码质量。",{"type":185,"tag":209,"props":341,"children":342},{},[343],{"type":191,"value":344},"代码质量检测：使用 SonarQube 等平台，静态分析代码，发现潜在的逻辑缺陷和安全隐患。",{"type":185,"tag":209,"props":346,"children":347},{},[348],{"type":191,"value":349},"自动化测试：使用 Playwright、Istanbul 等框架，执行单元测试、覆盖率测试，提高错误检测能力。",{"type":185,"tag":209,"props":351,"children":352},{},[353],{"type":191,"value":354},"监控与日志：集成 Sentry 等工具，埋点后可实时监控应用状态、收集前端错误，作为数据基建。",{"type":185,"tag":209,"props":356,"children":357},{},[358],{"type":191,"value":359},"性能分析：使用 Lighthouse 等工具，分析页面性能和用户体验瓶颈。",{"type":185,"tag":194,"props":361,"children":362},{},[363],{"type":185,"tag":264,"props":364,"children":365},{},[366],{"type":191,"value":367},"构建与部署",{"type":185,"tag":270,"props":369,"children":370},{},[371,376,381],{"type":185,"tag":209,"props":372,"children":373},{},[374],{"type":191,"value":375},"自动化构建：采用 Webpack、Gulp 等构建工具，整合资源编译、压缩、优化与打包流程。",{"type":185,"tag":209,"props":377,"children":378},{},[379],{"type":191,"value":380},"CI/CD：集成 GitHub Actions、GitLab CI 等持续集成工具，实现自动化测试、构建和部署。",{"type":185,"tag":209,"props":382,"children":383},{},[384],{"type":191,"value":385},"版本管理：使用 SemVer 等方法论，管理项目版本，确保兼容性。",{"type":185,"tag":194,"props":387,"children":388},{},[389],{"type":185,"tag":264,"props":390,"children":391},{},[392],{"type":191,"value":393},"文档协作",{"type":185,"tag":270,"props":395,"children":396},{},[397,402,407,412],{"type":185,"tag":209,"props":398,"children":399},{},[400],{"type":191,"value":401},"文档生成：通过 Storybook 等工具，生成 API 文档和可视化组件库，提升团队沟通与维护效率。",{"type":185,"tag":209,"props":403,"children":404},{},[405],{"type":191,"value":406},"在线环境：构建在线演示环境或编辑器，支持团队成员快速分享代码或验证问题，提升协作效率。",{"type":185,"tag":209,"props":408,"children":409},{},[410],{"type":191,"value":411},"前后协同：制定数据规范，使用 yapi 等工具，提升接口文档的可维护性与可用性。",{"type":185,"tag":209,"props":413,"children":414},{},[415],{"type":191,"value":416},"知识积累：使用语雀等工具，记录业务经验、技术文档，形成团队知识库。",{"title":178,"searchDepth":418,"depth":418,"links":419},2,[],"markdown","content:6.maps:_workflow:fe-engineering.md","content","6.maps/_workflow/fe-engineering.md","6.maps/_workflow/fe-engineering","md",[427,431],{"_path":428,"title":429,"description":430},"/maps/_workflow/compiler","Compiler","编译器原理与实践，重点介绍 Babel 等前端编译工具的工作原理和使用方法。",{"_path":432,"title":433,"description":434},"/maps/_workflow/linter/eslint","ESLint","ESLint 是 JavaScript 和 TypeScript 的代码质量检查工具，帮助开发者保持代码风格一致性和减少错误。",1771521479891]