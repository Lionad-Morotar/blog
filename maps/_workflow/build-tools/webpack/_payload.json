79,"children":1180},{"style":1168},[1181],{"type":192,"value":1182},"'",{"type":186,"tag":204,"props":1184,"children":1185},{"style":1114},[1186],{"type":192,"value":1187},",\n",{"type":186,"tag":204,"props":1189,"children":1191},{"class":1103,"line":1190},4,[1192,1197,1201,1205,1210],{"type":186,"tag":204,"props":1193,"children":1194},{"style":1140},[1195],{"type":192,"value":1196},"    admin",{"type":186,"tag":204,"props":1198,"children":1199},{"style":1114},[1200],{"type":192,"value":1148},{"type":186,"tag":204,"props":1202,"children":1203},{"style":1168},[1204],{"type":192,"value":1171},{"type":186,"tag":204,"props":1206,"children":1207},{"style":1174},[1208],{"type":192,"value":1209},"./src/admin.js",{"type":186,"tag":204,"props":1211,"children":1212},{"style":1168},[1213],{"type":192,"value":1214},"'\n",{"type":186,"tag":204,"props":1216,"children":1218},{"class":1103,"line":1217},5,[1219],{"type":186,"tag":204,"props":1220,"children":1221},{"style":1114},[1222],{"type":192,"value":1223},"  }\n",{"type":186,"tag":204,"props":1225,"children":1227},{"class":1103,"line":1226},6,[1228],{"type":186,"tag":204,"props":1229,"children":1230},{"style":1114},[1231],{"type":192,"value":1232},"}\n",{"type":186,"tag":1067,"props":1234,"children":1236},{"id":1235},"loader-是什么",[1237],{"type":192,"value":1238},"Loader 是什么？",{"type":186,"tag":1074,"props":1240,"children":1241},{},[1242],{"type":192,"value":1243},"webpack 提供的 Loader 接口丰富了模块处理的能力。使用自定义 Loader 可以加载诸如图片、样式、字体这些资源，资源经过不同的 Loader 处理，并发往下一个 Loader，所以可以把 Loader 看作基于字符串的流水线式处理。比如说针对样式文件，可以配置 PostCSS Loader，而 PostCSS Loader 可以使用插件接入 StyleLint、CSS Module 等功能。PostCSS Loader 处理后，结果继续交给 CSS Loader 解析 CSS 语法生成 AST，又交由 Style Loader 将 CSS 整合输入到某个文件中。",{"type":186,"tag":1074,"props":1245,"children":1246},{},[1247],{"type":186,"tag":1248,"props":1249,"children":1252},"img",{"alt":1250,"src":1251},"webpack Style Loaders","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200729022653.png?type=draw&w=40",[],{"type":186,"tag":1067,"props":1254,"children":1256},{"id":1255},"plugin-是什么",[1257],{"type":192,"value":1258},"Plugin 是什么？",{"type":186,"tag":1074,"props":1260,"children":1261},{},[1262],{"type":192,"value":1263},"在打包的过程中，Webpack 运行的内部会触发很多事件钩子。可以通过配置 Plugin 介入这些钩子来操作资源，以拓展自定义功能。",{"type":186,"tag":1067,"props":1265,"children":1267},{"id":1266},"hmr-原理",[1268],{"type":192,"value":1269},"HMR 原理？",{"type":186,"tag":1074,"props":1271,"children":1272},{},[1273,1275],{"type":192,"value":1274},"TODO，",{"type":186,"tag":1276,"props":1277,"children":1281},"a",{"href":1278,"rel":1279},"https://zhuanlan.zhihu.com/p/30623057",[1280],"nofollow",[1282],{"type":192,"value":1283},"webpack 热更新实现原理分析",{"type":186,"tag":1074,"props":1285,"children":1286},{},[1287,1288],{"type":192,"value":1274},{"type":186,"tag":1276,"props":1289,"children":1292},{"href":1290,"rel":1291},"https://zhuanlan.zhihu.com/p/30669007",[1280],[1293],{"type":192,"value":1294},"webpack HMR 原理解析",{"type":186,"tag":1067,"props":1296,"children":1298},{"id":1297},"模块联邦是什么",[1299],{"type":192,"value":1300},"模块联邦是什么？",{"type":186,"tag":1074,"props":1302,"children":1303},{},[1304],{"type":192,"value":1305},"使用模块联邦插件后，每次构建都可以作为打包后的容器，向其它容器（构建）提供模块或者消费其它容器提供的模块。能直接解决微前端项目中基础库升级后，其它业务项目也要重新拉新版基础库并构建、发版带来的繁琐的问题。",{"type":186,"tag":1074,"props":1307,"children":1308},{},[1309,1311],{"type":192,"value":1310},"见：",{"type":186,"tag":1276,"props":1312,"children":1315},{"href":1313,"rel":1314},"https://juejin.cn/post/7101457212085633054",[1280],[1316],{"type":192,"value":1317},"模块联邦浅析",{"type":186,"tag":1061,"props":1319,"children":1321},{"id":1320},"links",[1322],{"type":192,"value":1323},"Links",{"type":186,"tag":1074,"props":1325,"children":1326},{},[1327,1328],{"type":192,"value":1274},{"type":186,"tag":1276,"props":1329,"children":1332},{"href":1330,"rel":1331},"https://zhuanlan.zhihu.com/p/193663299",[1280],[1333],{"type":192,"value":1334},"Webpack4 中的 Tree-Shaking",{"type":186,"tag":1074,"props":1336,"children":1337},{},[1338,1339