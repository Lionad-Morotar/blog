true,"","构建工具","前端构建工具全景图，涵盖 Vite、Webpack、Rspack 等主流工具的特性对比和使用说明",{"type":182,"children":183,"toc":370},"root",[184,192,225,230,237,243,249,254,260,265,287,293,298,313,318,324,329,348,354,359],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"主题",[190],{"type":191,"value":188},"text",{"type":185,"tag":193,"props":194,"children":195},"ul",{},[196,207,216],{"type":185,"tag":197,"props":198,"children":199},"li",{},[200],{"type":185,"tag":201,"props":202,"children":204},"a",{"href":203},"/maps/_workflow/build-tools/vite",[205],{"type":191,"value":206},"Vite",{"type":185,"tag":197,"props":208,"children":209},{},[210],{"type":185,"tag":201,"props":211,"children":213},{"href":212},"/maps/_workflow/build-tools/webpack",[214],{"type":191,"value":215},"Webpack",{"type":185,"tag":197,"props":217,"children":218},{},[219],{"type":185,"tag":201,"props":220,"children":222},{"href":221},"/maps/_workflow/build-tools/rspack",[223],{"type":191,"value":224},"Rspack",{"type":185,"tag":186,"props":226,"children":228},{"id":227},"工具对比",[229],{"type":191,"value":227},{"type":185,"tag":231,"props":232,"children":234},"h4",{"id":233},"vite-vs-webpack-什么时候选择哪个",[235],{"type":191,"value":236},"Vite vs Webpack: 什么时候选择哪个？",{"type":185,"tag":238,"props":239,"children":240},"p",{},[241],{"type":191,"value":242},"Vite 适合现代浏览器优先的项目，利用原生 ESM 实现极速的 HMR 和构建速度。Webpack 适合需要复杂构建流程、大量自定义配置或需要兼容旧版浏览器的项目。",{"type":185,"tag":231,"props":244,"children":246},{"id":245},"rspack-的-webpack-兼容性如何实现",[247],{"type":191,"value":248},"Rspack 的 Webpack 兼容性如何实现？",{"type":185,"tag":238,"props":250,"children":251},{},[252],{"type":191,"value":253},"Rspack 基于 Rust 重写，旨在提供与 Webpack 兼容的 API 和配置，同时大幅提升构建性能。它支持大部分 Webpack 的 Loader 和 Plugin 生态。",{"type":185,"tag":231,"props":255,"children":257},{"id":256},"tsup-适合什么场景",[258],{"type":191,"value":259},"tsup 适合什么场景？",{"type":185,"tag":238,"props":261,"children":262},{},[263],{"type":191,"value":264},"tsup 是一个基于 ESBuild、SWC 的小型打包器，适合需要快速编译 TypeScript 库的场景。默认支持 .cjs、.esm、.json，有多入口、类型生成、编译格式（cjs、esm、iife）、编译目标、代码切分、watch、压缩等能力。",{"type":185,"tag":238,"props":266,"children":267},{},[268,270,278,280],{"type":191,"value":269},"见：",{"type":185,"tag":201,"props":271,"children":275},{"href":272,"rel":273},"https://antfu.me/posts/publish-esm-and-cjs#tsup",[274],"nofollow",[276],{"type":191,"value":277},"publish-esm-and-cjs#tsup | antfu",{"type":191,"value":279},"、",{"type":185,"tag":201,"props":281,"children":284},{"href":282,"rel":283},"https://tsup.egoist.dev/",[274],[285],{"type":191,"value":286},"tsup document",{"type":185,"tag":231,"props":288,"children":290},{"id":289},"rollup-的输出体积优势",[291],{"type":191,"value":292},"Rollup 的输出体积优势",{"type":185,"tag":238,"props":294,"children":295},{},[296],{"type":191,"value":297},"对比 Rollup 和 Rspack（Webpack）在输出体积上的差异：",{"type":185,"tag":193,"props":299,"children":300},{},[301],{"type":185,"tag":197,"props":302,"children":303},{},[304,311],{"type":185,"tag":305,"props":306,"children":308},"code",{"className":307},[],[309],{"type":191,"value":310},"@cx/definition",{"type":191,"value":312}," minified，rollup 42kb，webpack 60kb",{"type":185,"tag":186,"props":314,"children":316},{"id":315},"新兴工具",[317],{"type":191,"value":315},{"type":185,"tag":231,"props":319,"children":321},{"id":320},"unbuild-的-stub-模式是什么",[322],{"type":191,"value":323},"Unbuild 的 stub 模式是什么？",{"type":185,"tag":238,"props":325,"children":326},{},[327],{"type":191,"value":328},"stub 即插桩。unbuild 的插桩模式意味着只需要启动一个文件监听进程，就可以监听不同项目的代码的改变并触发对应项目的重新构建。配合 Monorepo 使用，修改某个包不需要触发重新构建，达到类似热更新的效果。",{"type":185,"tag":238,"props":330,"children":331},{},[332,333,340,341],{"type":191,"value":269},{"type":185,"tag":201,"props":334,"children":337},{"href":335,"rel":336},"https://juejin.cn/post/7203968787325992997",[274],[338],{"type":191,"value":339},"还在用 rollup 打包库？试试 unbuild 吧 | markthree",{"type":191,"value":279},{"type":185,"tag":201,"props":342,"children":345},{"href":343,"rel":344},"https://antfu.me/posts/publish-esm-and-cjs#stubbing",[274],[346],{"type":191,"value":347},"publish-esm-and-cjs#stubbing | antfu",{"type":185,"tag":231,"props":349,"children":351},{"id":350},"romebiome-的统一工具链愿景",[352],{"type":191,"value":353},"Rome/Biome 的统一工具链愿景",{"type":185,"tag":238,"props":355,"children":356},{},[357],{"type":191,"value":358},"Rome 致力于统一前端开发工具链，不仅是 Linter，还包括 Compiler、Bundler、Test Runner 等。现在应该叫 Biome 了，他们团队同时赢得了 Prettier 十万美金奖项。",{"type":185,"tag":238,"props":360,"children":361},{},[362,363],{"type":191,"value":269},{"type":185,"tag":201,"props":364,"children":367},{"href":365,"rel":366},"https://rome.tools/blog/2020/08/08/introducing-rome/",[274],[368],{"type":191,"value":369},"Introducing Rome",{"title":178,"searchDepth":371,"depth":371,"links":372},2,[373,374,375],{"id":188,"depth":371,"text":188},{"id":227,"depth":371,"text":227},{"id":315,"depth":371,"text":315},"markdown","content:6.maps:_workflow:build-tools:build-tools.md","content","6.maps/_workflow/build-tools/build-tools.md","6.maps/_workflow/build-tools/build-tools","md",[383,387],{"_path":384,"title":385,"description":386},"/maps/_windows/windows","Windows","记录一些使用 Windows 碰到的问题",{"_path":221,"title":224,"description":388},"Rspack 构建工具的特性分析与生态定位研究。",1772504901100]