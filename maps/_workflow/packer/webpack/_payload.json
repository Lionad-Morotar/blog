le":1110},[1182],{"type":188,"value":1183},",\n",{"type":182,"tag":200,"props":1185,"children":1187},{"class":1099,"line":1186},4,[1188,1193,1197,1201,1206],{"type":182,"tag":200,"props":1189,"children":1190},{"style":1136},[1191],{"type":188,"value":1192},"    admin",{"type":182,"tag":200,"props":1194,"children":1195},{"style":1110},[1196],{"type":188,"value":1144},{"type":182,"tag":200,"props":1198,"children":1199},{"style":1164},[1200],{"type":188,"value":1167},{"type":182,"tag":200,"props":1202,"children":1203},{"style":1170},[1204],{"type":188,"value":1205},"./src/admin.js",{"type":182,"tag":200,"props":1207,"children":1208},{"style":1164},[1209],{"type":188,"value":1210},"'\n",{"type":182,"tag":200,"props":1212,"children":1214},{"class":1099,"line":1213},5,[1215],{"type":182,"tag":200,"props":1216,"children":1217},{"style":1110},[1218],{"type":188,"value":1219},"  }\n",{"type":182,"tag":200,"props":1221,"children":1223},{"class":1099,"line":1222},6,[1224],{"type":182,"tag":200,"props":1225,"children":1226},{"style":1110},[1227],{"type":188,"value":1228},"}\n",{"type":182,"tag":1063,"props":1230,"children":1232},{"id":1231},"loader-是什么",[1233],{"type":188,"value":1234},"Loader 是什么？",{"type":182,"tag":1070,"props":1236,"children":1237},{},[1238],{"type":188,"value":1239},"webpack 提供的 Loader 接口丰富了模块处理的能力。使用自定义 Loader 可以加载诸如图片、样式、字体这些资源，资源经过不同的 Loader 处理，并发往下一个 Loader，所以可以把 Loader 看作基于字符串的流水线式处理。比如说针对样式文件，可以配置 PostCSS Loader，而 PostCSS Loader 可以使用插件接入 StyleLint、CSS Module 等功能。PostCSS Loader 处理后，结果继续交给 CSS Loader 解析 CSS 语法生成 AST，又交由 Style Loader 将 CSS 整合输入到某个文件中。",{"type":182,"tag":1070,"props":1241,"children":1242},{},[1243],{"type":182,"tag":1244,"props":1245,"children":1248},"img",{"alt":1246,"src":1247},"webpack Style Loaders","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200729022653.png?type=draw&w=40",[],{"type":182,"tag":1063,"props":1250,"children":1252},{"id":1251},"plugin-是什么",[1253],{"type":188,"value":1254},"Plugin 是什么？",{"type":182,"tag":1070,"props":1256,"children":1257},{},[1258],{"type":188,"value":1259},"在打包的过程中，Webpack 运行的内部会触发很多事件钩子。可以通过配置 Plugin 介入这些钩子来操作资源，以拓展自定义功能。",{"type":182,"tag":1063,"props":1261,"children":1263},{"id":1262},"hmr-原理",[1264],{"type":188,"value":1265},"HMR 原理？",{"type":182,"tag":1070,"props":1267,"children":1268},{},[1269,1271],{"type":188,"value":1270},"TODO，",{"type":182,"tag":1272,"props":1273,"children":1277},"a",{"href":1274,"rel":1275},"https://zhuanlan.zhihu.com/p/30623057",[1276],"nofollow",[1278],{"type":188,"value":1279},"webpack 热更新实现原理分析",{"type":182,"tag":1070,"props":1281,"children":1282},{},[1283,1284],{"type":188,"value":1270},{"type":182,"tag":1272,"props":1285,"children":1288},{"href":1286,"rel":1287},"https://zhuanlan.zhihu.com/p/30669007",[1276],[1289],{"type":188,"value":1290},"webpack HMR 原理解析",{"type":182,"tag":1063,"props":1292,"children":1294},{"id":1293},"模块联邦是什么",[1295],{"type":188,"value":1296},"模块联邦是什么？",{"type":182,"tag":1070,"props":1298,"children":1299},{},[1300],{"type":188,"value":1301},"使用模块联邦插件后，每次构建都可以作为打包后的容器，向其它容器（构建）提供模块或者消费其它容器提供的模块。能直接解决微前端项目中基础库升级后，其它业务项目也要重新拉新版基础库并构建、发版带来的繁琐的问题。",{"type":182,"tag":1070,"props":1303,"children":1304},{},[1305,1307],{"type":188,"value":1306},"见：",{"type":182,"tag":1272,"props":1308,"children":1311},{"href":1309,"rel":1310},"https://juejin.cn/post/7101457212085633054",[1276],[1312],{"type":188,"value":1313},"模块联邦浅析",{"type":182,"tag":1057,"props":1315,"children":1317},{"id":1316},"links",[1318],{"type":188,"value":1319},"Links",{"type":182,"tag":1070,"props":1321,"children":1322},{},[1323,1324],{"type":188,"value":1270},{"type":182,"tag":1272,"props":1325,"children":1328},{"href":1326,"rel":1327},"https://zhuanlan.zhihu.com/p/193663299",[1276],[1329],{"type":188,"value":1330},"Webpack4 中的 Tree-Shaking",{"type":182,"tag":1070,"props":1332,"children":1333},{},[1334,1335],{"type":188,"value":1270},{"type":182,"tag":1272,"props":1336,"children":1339},{"href":1337,"rel":1338},"https://zhuanlan.zhihu