{"type":185,"tag":203,"props":1183,"children":1184},{"style":1113},[1185],{"type":191,"value":1186},",\n",{"type":185,"tag":203,"props":1188,"children":1190},{"class":1102,"line":1189},4,[1191,1196,1200,1204,1209],{"type":185,"tag":203,"props":1192,"children":1193},{"style":1139},[1194],{"type":191,"value":1195},"    admin",{"type":185,"tag":203,"props":1197,"children":1198},{"style":1113},[1199],{"type":191,"value":1147},{"type":185,"tag":203,"props":1201,"children":1202},{"style":1167},[1203],{"type":191,"value":1170},{"type":185,"tag":203,"props":1205,"children":1206},{"style":1173},[1207],{"type":191,"value":1208},"./src/admin.js",{"type":185,"tag":203,"props":1210,"children":1211},{"style":1167},[1212],{"type":191,"value":1213},"'\n",{"type":185,"tag":203,"props":1215,"children":1217},{"class":1102,"line":1216},5,[1218],{"type":185,"tag":203,"props":1219,"children":1220},{"style":1113},[1221],{"type":191,"value":1222},"  }\n",{"type":185,"tag":203,"props":1224,"children":1226},{"class":1102,"line":1225},6,[1227],{"type":185,"tag":203,"props":1228,"children":1229},{"style":1113},[1230],{"type":191,"value":1231},"}\n",{"type":185,"tag":1066,"props":1233,"children":1235},{"id":1234},"loader-是什么",[1236],{"type":191,"value":1237},"Loader 是什么？",{"type":185,"tag":1073,"props":1239,"children":1240},{},[1241],{"type":191,"value":1242},"webpack 提供的 Loader 接口丰富了模块处理的能力。使用自定义 Loader 可以加载诸如图片、样式、字体这些资源，资源经过不同的 Loader 处理，并发往下一个 Loader，所以可以把 Loader 看作基于字符串的流水线式处理。比如说针对样式文件，可以配置 PostCSS Loader，而 PostCSS Loader 可以使用插件接入 StyleLint、CSS Module 等功能。PostCSS Loader 处理后，结果继续交给 CSS Loader 解析 CSS 语法生成 AST，又交由 Style Loader 将 CSS 整合输入到某个文件中。",{"type":185,"tag":1073,"props":1244,"children":1245},{},[1246],{"type":185,"tag":1247,"props":1248,"children":1251},"img",{"alt":1249,"src":1250},"webpack Style Loaders","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/20200729022653.png?type=draw&w=40",[],{"type":185,"tag":1066,"props":1253,"children":1255},{"id":1254},"plugin-是什么",[1256],{"type":191,"value":1257},"Plugin 是什么？",{"type":185,"tag":1073,"props":1259,"children":1260},{},[1261],{"type":191,"value":1262},"在打包的过程中，Webpack 运行的内部会触发很多事件钩子。可以通过配置 Plugin 介入这些钩子来操作资源，以拓展自定义功能。",{"type":185,"tag":1066,"props":1264,"children":1266},{"id":1265},"hmr-原理",[1267],{"type":191,"value":1268},"HMR 原理？",{"type":185,"tag":1073,"props":1270,"children":1271},{},[1272,1274],{"type":191,"value":1273},"TODO，",{"type":185,"tag":1275,"props":1276,"children":1280},"a",{"href":1277,"rel":1278},"https://zhuanlan.zhihu.com/p/30623057",[1279],"nofollow",[1281],{"type":191,"value":1282},"webpack 热更新实现原理分析",{"type":185,"tag":1073,"props":1284,"children":1285},{},[1286,1287],{"type":191,"value":1273},{"type":185,"tag":1275,"props":1288,"children":1291},{"href":1289,"rel":1290},"https://zhuanlan.zhihu.com/p/30669007",[1279],[1292],{"type":191,"value":1293},"webpack HMR 原理解析",{"type":185,"tag":1066,"props":1295,"children":1297},{"id":1296},"模块联邦是什么",[1298],{"type":191,"value":1299},"模块联邦是什么？",{"type":185,"tag":1073,"props":1301,"children":1302},{},[1303],{"type":191,"value":1304},"使用模块联邦插件后，每次构建都可以作为打包后的容器，向其它容器（构建）提供模块或者消费其它容器提供的模块。能直接解决微前端项目中基础库升级后，其它业务项目也要重新拉新版基础库并构建、发版带来的繁琐的问题。",{"type":185,"tag":1073,"props":1306,"children":1307},{},[1308,1310],{"type":191,"value":1309},"见：",{"type":185,"tag":1275,"props":1311,"children":1314},{"href":1312,"rel":1313},"https://juejin.cn/post/7101457212085633054",[1279],[1315],{"type":191,"value":1316},"模块联邦浅析",{"type":185,"tag":1060,"props":1318,"children":1320},{"id":1319},"links",[1321],{"type":191,"value":1322},"Links",{"type":185,"tag":1073,"props":1324,"children":1325},{},[1326,1327],{"type":191,"value":1273},{"type":185,"tag":1275,"props":1328,"children":1331},{"href":1329,"rel":1330},"https://zhuanlan.zhihu.com/p/193663299",[1279],[1332],{"type":191,"value":1333},"Webpack4 中的 Tree-Shaking",{"type":185,"tag":1073,"props":1335,"children":1336},{},[1337,1338],{"type":191,"value":1273},{"type":185,"tag":1275,"props":1339,"childre