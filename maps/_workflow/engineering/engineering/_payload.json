true,"","工程化","软件工程与前端工程化的理论与实践",{"type":182,"children":183,"toc":570},"root",[184,192,207,212,219,225,230,315,321,326,331,336,358,363,416,421,484,489,522,527],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"主题",[190],{"type":191,"value":188},"text",{"type":185,"tag":193,"props":194,"children":195},"ul",{},[196],{"type":185,"tag":197,"props":198,"children":199},"li",{},[200],{"type":185,"tag":201,"props":202,"children":204},"a",{"href":203},"/maps/_workflow/engineering/fe-engineering",[205],{"type":191,"value":206},"前端工程化",{"type":185,"tag":186,"props":208,"children":210},{"id":209},"核心概念",[211],{"type":191,"value":209},{"type":185,"tag":213,"props":214,"children":216},"h4",{"id":215},"什么是软件工程",[217],{"type":191,"value":218},"什么是软件工程？",{"type":185,"tag":220,"props":221,"children":222},"p",{},[223],{"type":191,"value":224},"软件工程是指在软件开发过程中，应用工程化的原则和方法，以提高软件质量、降低开发成本、缩短开发周期为目标的一门学科。它涵盖是一个涵盖需求、设计、实现、测试、部署、运维、管理和持续改进的完整闭环体系，贯穿软件从\"想法\"到\"产品\"再到\"持续运营\"的全部过程。",{"type":185,"tag":220,"props":226,"children":227},{},[228],{"type":191,"value":229},"软件工程的主要内容包括：",{"type":185,"tag":231,"props":232,"children":233},"ol",{},[234,245,255,265,275,285,295,305],{"type":185,"tag":197,"props":235,"children":236},{},[237,243],{"type":185,"tag":238,"props":239,"children":240},"strong",{},[241],{"type":191,"value":242},"需求分析",{"type":191,"value":244},"：调研与获取需求，建模并形成需求规格说明书",{"type":185,"tag":197,"props":246,"children":247},{},[248,253],{"type":185,"tag":238,"props":249,"children":250},{},[251],{"type":191,"value":252},"系统设计",{"type":191,"value":254},"：设计系统架构，划分模块，设计数据库和接口，输出设计文档",{"type":185,"tag":197,"props":256,"children":257},{},[258,263],{"type":185,"tag":238,"props":259,"children":260},{},[261],{"type":191,"value":262},"编码实现",{"type":191,"value":264},"：按规范开发模块，代码审查，执行单元测试",{"type":185,"tag":197,"props":266,"children":267},{},[268,273],{"type":185,"tag":238,"props":269,"children":270},{},[271],{"type":191,"value":272},"软件测试",{"type":191,"value":274},"：开展单元、集成、系统、验收及自动化测试，确保质量",{"type":185,"tag":197,"props":276,"children":277},{},[278,283],{"type":185,"tag":238,"props":279,"children":280},{},[281],{"type":191,"value":282},"部署运维",{"type":191,"value":284},"：进行CI/CD、配置管理、监控、日志分析和故障恢复，保障系统稳定",{"type":185,"tag":197,"props":286,"children":287},{},[288,293],{"type":185,"tag":238,"props":289,"children":290},{},[291],{"type":191,"value":292},"项目管理",{"type":191,"value":294},"：管理进度、范围、成本、风险、团队与质量，确保高效协作与交付",{"type":185,"tag":197,"props":296,"children":297},{},[298,303],{"type":185,"tag":238,"props":299,"children":300},{},[301],{"type":191,"value":302},"文档与配置管理",{"type":191,"value":304},"：完善各类文档，进行版本控制和配置项管理，保证可追溯性与一致性",{"type":185,"tag":197,"props":306,"children":307},{},[308,313],{"type":185,"tag":238,"props":309,"children":310},{},[311],{"type":191,"value":312},"过程改进",{"type":191,"value":314},"：评估与优化流程，推广自动化工具，持续提升开发效率和软件质量",{"type":185,"tag":213,"props":316,"children":318},{"id":317},"什么是前端工程化",[319],{"type":191,"value":320},"什么是前端工程化？",{"type":185,"tag":220,"props":322,"children":323},{},[324],{"type":191,"value":325},"前端工程化泛指将自动化、标准化、流程化等工程领域思想应用于前端开发全过程，以达到提升开发效率、提高代码质量与可维护性、协同团队合作的目的。",{"type":185,"tag":186,"props":327,"children":329},{"id":328},"最佳实践",[330],{"type":191,"value":328},{"type":185,"tag":213,"props":332,"children":334},{"id":333},"代码规范",[335],{"type":191,"value":333},{"type":185,"tag":193,"props":337,"children":338},{},[339,348],{"type":185,"tag":197,"props":340,"children":341},{},[342,346],{"type":185,"tag":238,"props":343,"children":344},{},[345],{"type":191,"value":333},{"type":191,"value":347},"：通过 ESLint 等工具，统一代码风格，减少低级错误",{"type":185,"tag":197,"props":349,"children":350},{},[351,356],{"type":185,"tag":238,"props":352,"children":353},{},[354],{"type":191,"value":355},"代码片段",{"type":191,"value":357},"：借助 Snippets 或脚本创建代码模版，减少重复性编码工作",{"type":185,"tag":213,"props":359,"children":361},{"id":360},"开发模式",[362],{"type":191,"value":360},{"type":185,"tag":193,"props":364,"children":365},{},[366,376,386,396,406],{"type":185,"tag":197,"props":367,"children":368},{},[369,374],{"type":185,"tag":238,"props":370,"children":371},{},[372],{"type":191,"value":373},"模块化",{"type":191,"value":375},"：采用 ESM 等模块化方式，细化逻辑颗粒度，实现代码复用",{"type":185,"tag":197,"props":377,"children":378},{},[379,384],{"type":185,"tag":238,"props":380,"children":381},{},[382],{"type":191,"value":383},"组件化",{"type":191,"value":385},"：使用 Vue 等现代框架，将 UI 拆分为独立、可复用的组件",{"type":185,"tag":197,"props":387,"children":388},{},[389,394],{"type":185,"tag":238,"props":390,"children":391},{},[392],{"type":191,"value":393},"依赖管理",{"type":191,"value":395},"：使用 pnpm 等包管理工具，规范依赖引入、更新、审计过程",{"type":185,"tag":197,"props":397,"children":398},{},[399,404],{"type":185,"tag":238,"props":400,"children":401},{},[402],{"type":191,"value":403},"框架约束",{"type":191,"value":405},"：使用 Nuxt 等元框架，减少基础架构工作，提升起步效率",{"type":185,"tag":197,"props":407,"children":408},{},[409,414],{"type":185,"tag":238,"props":410,"children":411},{},[412],{"type":191,"value":413},"代码历史",{"type":191,"value":415},"：结合 Git 及工作流，优化代码协同流程，提供代码的历史追踪数据",{"type":185,"tag":213,"props":417,"children":419},{"id":418},"质量保证",[420],{"type":191,"value":418},{"type":185,"tag":193,"props":422,"children":423},{},[424,434,444,454,464,474],{"type":185,"tag":197,"props":425,"children":426},{},[427,432],{"type":185,"tag":238,"props":428,"children":429},{},[430],{"type":191,"value":431},"安全审计",{"type":191,"value":433},"：通过 Socket、pnpm audit 等工具，自动化检查依赖包的安全漏洞",{"type":185,"tag":197,"props":435,"children":436},{},[437,442],{"type":185,"tag":238,"props":438,"children":439},{},[440],{"type":191,"value":441},"代码审查",{"type":191,"value":443},"：借助 Pull Request、Code Review 流程，保障最低代码质量",{"type":185,"tag":197,"props":445,"children":446},{},[447,452],{"type":185,"tag":238,"props":448,"children":449},{},[450],{"type":191,"value":451},"代码质量检测",{"type":191,"value":453},"：使用 SonarQube 等平台，静态分析代码，发现潜在的逻辑缺陷和安全隐患",{"type":185,"tag":197,"props":455,"children":456},{},[457,462],{"type":185,"tag":238,"props":458,"