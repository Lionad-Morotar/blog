neering","engineering",false,true,"","前端工程化","前端工程化的最佳实践和工具，帮助提升开发效率和代码质量","/_workflow/fe-engineering.md",{"type":183,"children":184,"toc":418},"root",[185,194,200,205,250,256,261,270,284,292,320,328,361,369,387,395],{"type":186,"tag":187,"props":188,"children":190},"element","h4",{"id":189},"什么是软件工程",[191],{"type":192,"value":193},"text","什么是软件工程？",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198],{"type":192,"value":199},"软件工程是指在软件开发过程中，应用工程化的原则和方法，以提高软件质量、降低开发成本、缩短开发周期为目标的一门学科。它涵盖是一个涵盖需求、设计、实现、测试、部署、运维、管理和持续改进的完整闭环体系，贯穿软件从\"想法\"到\"产品\"再到\"持续运营\"的全部过程。每一环节都有专业的方法、流程和工具保障交付的高质高效。",{"type":186,"tag":195,"props":201,"children":202},{},[203],{"type":192,"value":204},"以下是用简洁 list 形式概括的软件工程主要内容：",{"type":186,"tag":206,"props":207,"children":208},"ol",{},[209,215,220,225,230,235,240,245],{"type":186,"tag":210,"props":211,"children":212},"li",{},[213],{"type":192,"value":214},"需求分析：调研与获取需求，建模并形成需求规格说明书。",{"type":186,"tag":210,"props":216,"children":217},{},[218],{"type":192,"value":219},"系统设计：设计系统架构，划分模块，设计数据库和接口，输出设计文档。",{"type":186,"tag":210,"props":221,"children":222},{},[223],{"type":192,"value":224},"编码实现：按规范开发模块，代码审查，执行单元测试。",{"type":186,"tag":210,"props":226,"children":227},{},[228],{"type":192,"value":229},"软件测试：开展单元、集成、系统、验收及自动化测试，确保质量。",{"type":186,"tag":210,"props":231,"children":232},{},[233],{"type":192,"value":234},"部署运维：进行CI/CD、配置管理、监控、日志分析和故障恢复，保障系统稳定。",{"type":186,"tag":210,"props":236,"children":237},{},[238],{"type":192,"value":239},"项目管理：管理进度、范围、成本、风险、团队与质量，确保高效协作与交付。",{"type":186,"tag":210,"props":241,"children":242},{},[243],{"type":192,"value":244},"文档与配置管理：完善各类文档，进行版本控制和配置项管理，保证可追溯性与一致性。",{"type":186,"tag":210,"props":246,"children":247},{},[248],{"type":192,"value":249},"过程改进：评估与优化流程，推广自动化工具，持续提升开发效率和软件质量。",{"type":186,"tag":187,"props":251,"children":253},{"id":252},"什么是前端工程化",[254],{"type":192,"value":255},"什么是前端工程化？",{"type":186,"tag":195,"props":257,"children":258},{},[259],{"type":192,"value":260},"前端工程化可以从软件工程借鉴部分定义，泛指将自动化、标准化、流程化等工程领域思想应用于前端开发全过程，以达到提升开发效率、提高代码质量与可维护性、协同团队合作的目的。",{"type":186,"tag":195,"props":262,"children":263},{},[264],{"type":186,"tag":265,"props":266,"children":267},"strong",{},[268],{"type":192,"value":269},"代码规范",{"type":186,"tag":271,"props":272,"children":273},"ul",{},[274,279],{"type":186,"tag":210,"props":275,"children":276},{},[277],{"type":192,"value":278},"代码规范：通过 ESLint 等工具，统一代码风格，减少低级错误。",{"type":186,"tag":210,"props":280,"children":281},{},[282],{"type":192,"value":283},"代码片段：借助 Snippets 或脚本创建代码模版，减少重复性编码工作。",{"type":186,"tag":195,"props":285,"children":286},{},[287],{"type":186,"tag":265,"props":288,"children":289},{},[290],{"type":192,"value":291},"开发模式",{"type":186,"tag":271,"props":293,"children":294},{},[295,300,305,310,315],{"type":186,"tag":210,"props":296,"children":297},{},[298],{"type":192,"value":299},"模块化：采用 ESM 等模块化方式，细化逻辑颗粒度，实现代码复用，提升可维护性。",{"type":186,"tag":210,"props":301,"children":302},{},[303],{"type":192,"value":304},"组件化：使用 Vue 等现代框架，将 UI 拆分为独立、可复用的组件。",{"type":186,"tag":210,"props":306,"children":307},{},[308],{"type":192,"value":309},"依赖管理：使用 pnpm 等包管理工具，规范依赖引入、更新、审计过程。",{"type":186,"tag":210,"props":311,"children":312},{},[313],{"type":192,"value":314},"框架约束：使用 Nuxt 等元框架，减少基础架构工作，提升起步效率。",{"type":186,"tag":210,"props":316,"children":317},{},[318],{"type":192,"value":319},"代码历史：结合 Git 及工作流，优化代码协同流程，提供代码的历史追踪数据。",{"type":186,"tag":195,"props":321,"children":322},{},[323],{"type":186,"tag":265,"props":324,"children":325},{},[326],{"type":192,"value":327},"质量保证",{"type":186,"tag":271,"props":329,"children":330},{},[331,336,341,346,351,356],{"type":186,"tag":210,"props":332,"children":333},{},[334],{"type":192,"value":335},"安全审计：通过 Socket、pnpm audit 等工具，自动化检查依赖包的安全漏洞，确保项目安全。",{"type":186,"tag":210,"props":337,"children":338},{},[339],{"type":192,"value":340},"代码审查：借助 Pull Request、Code Review 流程，保障最低代码质量。",{"type":186,"tag":210,"props":342,"children":343},{},[344],{"type":192,"value":345},"代码质量检测：使用 SonarQube 等平台，静态分析代码，发现潜在的逻辑缺陷和安全隐患。",{"type":186,"tag":210,"props":347,"children":348},{},[349],{"type":192,"value":350},"自动化测试：使用 Playwright、Istanbul 等框架，执行单元测试、覆盖率测试，提高错误检测能力。",{"type":186,"tag":210,"props":352,"children":353},{},[354],{"type":192,"value":355},"监控与日志：集成 Sentry 等工具，埋点后可实时监控应用状态、收集前端错误，作为数据基建。",{"type":186,"tag":210,"props":357,"children":358},{},[359],{"type":192,"value":360},"性能分析：使用 Lighthouse 等工具，分析页面性能和用户体验瓶颈。",{"type":186,"tag":195,"props":362,"children":363},{},[364],{"type":186,"tag":265,"props":365,"children":366},{},[367],{"type":192,"value":368},"构建与部署",{"type":186,"tag":271,"props":370,"children":371},{},[372,377,382],{"type":186,"tag":210,"props":373,"children":374},{},[375],{"type":192,"value":376},"自动化构建：采用 Webpack、Gulp 等构建工具，整合资源编译、压缩、优化与打包流程。",{"type":186,"tag":210,"props":378,"children":379},{},[380],{"type":192,"value":381},"CI/CD：集成 GitHub Actions、GitLab CI 等持续集成工具，实现自动化测试、构建和部署。",{"type":186,"tag":210,"props":383,"children":384},{},[385],{"type":192,"value":386},"版本管理：使用 SemVer 等方法论，管理项目版本，确保兼容性。",{"type":186,"tag":195,"props":388,"children":389},{},[390],{"type":186,"tag":265,"props":391,"children":392},{},[393],{"type":192,"value":394},"文档协作",{"type":186,"tag":271,"props":396,"children":397},{},[398,403,408,413],{"type":186,"tag":210,"props":399,"children":400},{},[401],{"type":192,"value":402},"文档生成：通过 Storybook 等工具，生成 API 文档和可视化组件库，提升团队沟通与维护效率。",{"type":186,"tag":210,"props":404,"children":405},{},[406],{"type":192,"value":407},"在线环境：构建在线演示环境或编辑器，支持团队成员快速分享代码或验证问题，提升协作效率。",{"type":186,"tag":210,"props":409,"children":410},{},[411],{"type":192,"value":412},"前后协同：制定数据规范，使用 yapi 等工具，提升接口文档的可维护性与可用性。",{"type":186,"tag":210,"props":414,"children":415},{},[416],{"type":192,"value":417},"知识积累：使用语雀等工具，记录业务经验、技术文档，形成团队知识库。",{"title":178,"searchDepth":419,"depth":419,"links":420},2,[],"markdown","content:6.maps:_workflow:engineering:fe-engineering.md","content","6.maps/_workflow/engineering/fe-engineering.md","6.maps/_workflow/engineering/fe-engineering","md",[428,432],{"_path":429,"title":430,"description":431},"/maps/_workflow/engineering/engineering","工程化","软件工程与前端工程化的理论与实践",{"_path":433,"title":434,"description":435},"/maps/_workflow/linter/code-style","Code Style","代码风格与格式规范的最佳实践",1772504900991]