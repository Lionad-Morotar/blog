ot",[181,190,197,203,208],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"babel",[187],{"type":188,"value":189},"text","Babel",{"type":182,"tag":191,"props":192,"children":194},"h4",{"id":193},"babel-是什么工作原理是怎样的",[195],{"type":188,"value":196},"babel 是什么？工作原理是怎样的？",{"type":182,"tag":198,"props":199,"children":200},"p",{},[201],{"type":188,"value":202},"Babel 主要的作用是转换与编译，能够将新标准中前沿的代码技术转换为相同（或类似）功能的代码，使其能够在旧的浏览器中运行。babel 使用 Babylon（Babel-parser） 将代码解析为 AST，使用 babel-traverse 维护 AST 的状态，做一些源码级别的转换，最后使用 babel-generator 读取 AST 并生成代码。",{"type":182,"tag":183,"props":204,"children":206},{"id":205},"资源",[207],{"type":188,"value":205},{"type":182,"tag":209,"props":210,"children":211},"ul",{},[212],{"type":182,"tag":213,"props":214,"children":215},"li",{},[216],{"type":182,"tag":217,"props":218,"children":222},"a",{"href":219,"rel":220},"https://c9x.me/compile/bib/",[221],"nofollow",[223],{"type":188,"value":224},"Resources for Amateur Compiler Writers",{"title":175,"searchDepth":226,"depth":226,"links":227},2,[228,229],{"id":185,"depth":226,"text":189},{"id":205,"depth":226,"text":205},"markdown","content:6.maps:_workflow:compiler.md","content","6.maps/_workflow/compiler.md","6.maps/_workflow/compiler","md",[237,241],{"_path":238,"title":239,"description":240},"/maps/_windows/windows","Windows","记录一些使用 Windows 碰到的问题",{"_path":242,"title":243,"description":244},"/maps/_workflow/fe-engineering","前端工程化","前端工程化的最佳实践和工具，帮助提升开发效率和代码质量",1771214923561]