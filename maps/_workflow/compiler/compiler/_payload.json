rue,"","Compiler","编译器原理与实践，重点介绍 Babel 等前端编译工具的工作原理和使用方法。","/_workflow/compiler.md",{"type":183,"children":184,"toc":402},"root",[185,194,201,207,212,218,264,270,313,319,362,367],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"babel",[191],{"type":192,"value":193},"text","Babel",{"type":186,"tag":195,"props":196,"children":198},"h4",{"id":197},"babel-是什么工作原理是怎样的",[199],{"type":192,"value":200},"babel 是什么？工作原理是怎样的？",{"type":186,"tag":202,"props":203,"children":204},"p",{},[205],{"type":192,"value":206},"Babel 主要的作用是转换与编译，能够将新标准中前沿的代码技术转换为相同（或类似）功能的代码，使其能够在旧的浏览器中运行。babel 使用 Babylon（Babel-parser） 将代码解析为 AST，使用 babel-traverse 维护 AST 的状态，做一些源码级别的转换，最后使用 babel-generator 读取 AST 并生成代码。",{"type":186,"tag":187,"props":208,"children":210},{"id":209},"现代编译工具",[211],{"type":192,"value":209},{"type":186,"tag":195,"props":213,"children":215},{"id":214},"swc-相比-babel-的性能优势",[216],{"type":192,"value":217},"SWC 相比 Babel 的性能优势",{"type":186,"tag":219,"props":220,"children":221},"ul",{},[222,234,244,254],{"type":186,"tag":223,"props":224,"children":225},"li",{},[226,232],{"type":186,"tag":227,"props":228,"children":229},"strong",{},[230],{"type":192,"value":231},"Rust 实现",{"type":192,"value":233},"：SWC 使用 Rust 编写，编译为原生代码，无 JavaScript 运行时开销",{"type":186,"tag":223,"props":235,"children":236},{},[237,242],{"type":186,"tag":227,"props":238,"children":239},{},[240],{"type":192,"value":241},"并行处理",{"type":192,"value":243},"：SWC 利用多核 CPU 并行处理文件，Babel 单线程执行",{"type":186,"tag":223,"props":245,"children":246},{},[247,252],{"type":186,"tag":227,"props":248,"children":249},{},[250],{"type":192,"value":251},"速度提升",{"type":192,"value":253},"：大型项目构建速度可提升 10-20 倍",{"type":186,"tag":223,"props":255,"children":256},{},[257,262],{"type":186,"tag":227,"props":258,"children":259},{},[260],{"type":192,"value":261},"兼容性",{"type":192,"value":263},"：SWC 支持 Babel 的大部分插件生态，可作为 drop-in 替代",{"type":186,"tag":195,"props":265,"children":267},{"id":266},"esbuild-的-go-实现带来的构建速度提升",[268],{"t