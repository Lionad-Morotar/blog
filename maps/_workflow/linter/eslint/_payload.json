"type":191,"value":346},"/* eslint xxx: \"off\" */",{"type":191,"value":333},{"type":185,"tag":224,"props":349,"children":351},{"className":350},[],[352],{"type":191,"value":353},"/* eslint-env node */",{"type":185,"tag":269,"props":355,"children":356},{},[357,359,365,366,372,373,379,380],{"type":191,"value":358},"命令行选项：",{"type":185,"tag":224,"props":360,"children":362},{"className":361},[],[363],{"type":191,"value":364},"--global",{"type":191,"value":333},{"type":185,"tag":224,"props":367,"children":369},{"className":368},[],[370],{"type":191,"value":371},"--rule",{"type":191,"value":333},{"type":185,"tag":224,"props":374,"children":376},{"className":375},[],[377],{"type":191,"value":378},"--env",{"type":191,"value":333},{"type":185,"tag":224,"props":381,"children":383},{"className":382},[],[384],{"type":191,"value":385},"--config",{"type":185,"tag":269,"props":387,"children":388},{},[389,391,397],{"type":191,"value":390},"文件配置：首先寻找和校验文件同目录的文件配置和 package.json eslintConfig 配置，没找到则向上级目录寻找，直到根目录，或找到包括 ",{"type":185,"tag":224,"props":392,"children":394},{"className":393},[],[395],{"type":191,"value":396},"root: true",{"type":191,"value":398}," 的配置",{"type":185,"tag":200,"props":400,"children":401},{},[402],{"type":191,"value":403},"Flat Config 配置不存在向上级目录寻找的情况。",{"type":185,"tag":193,"props":405,"children":407},{"id":406},"eslint-相对-glob-模式的坑",[408],{"type":191,"value":409},"ESLint 相对 glob 模式的坑？",{"type":185,"tag":200,"props":411,"children":412},{},[413,415,421],{"type":191,"value":414},"使用相对 glob 模式如 ",{"type":185,"tag":224,"props":416,"children":418},{"className":417},[],[419],{"type":191,"value":420},"**/*.js",{"type":191,"value":422}," 时，如果使用配置文件模式，那么相对路径是相对于配置文件所在目录；如果使用 CLI 传入配置（--config）那么相对路径是相对命令执行的工作目录。",{"type":185,"tag":193,"props":424,"children":426},{"id":425},"为什么-eslint8-废弃了个人配置文件",[427],{"type":191,"value":428},"为什么 ESLint@8 废弃了个人配置文件？",{"type":185,"tag":200,"props":430,"children":431},{},[432,434,440],{"type":191,"value":433},"个人配置文件指 ",{"type":185,"tag":224,"props":435,"children":437},{"className":436},[],[438],{"type":191,"value":439},"~",{"type":191,"value":441}," 目录（用户主目录）下的配置文件，如果 ESLint 在项目中找不到配置文件，那么将自动搜寻用户主目录下的配置文件。但是配置文件这种形式难以共享和修改（因为它从用户主目录下 node_modules 加载共享配置和解析器，而在项目目录加载插件），所以在 ESLint@8 被废弃。",{"type":185,"tag":193,"props":443,"children":445},{"id":444},"如何配置全局变量",[446],{"type":191,"value":447},"如何配置全局变量？",{"type":185,"tag":265,"props":449,"children":450},{},[451,468],{"type":185,"tag":269,"props":452,"children":453},{},[454,455,461,462],{"type":191,"value":325},{"type":185,"tag":224,"props":456,"children":458},{"className":457},[],[459],{"type":191,"value":460},"/* global x1, x2:writable */",{"type":191,"value":333},{"type":185,"tag":224,"props":463,"children":465},{"className":464},[],[466],{"type":191,"value":467},"/* eslint-env es2022, node, mocha */",{"type":185,"tag":269,"props":469,"children":470},{},[471],{"type":191,"value":472},"使用配置文件或 eslintConfig 中的 env 字段",{"type":185,"tag":200,"props":474,"children":475},{},[476],{"type":191,"value":477},"注意，如果直接更改 parserOptions 的 ecmaVersion 而不更改 env 配置，是不会支持对应版本 ES 规范的全局变量的，因为 parserOptions 的 ecmaVersion 只是告诉 ESLint 使用哪个版本的 ECMAScript 语法解析代码。",{"type":185,"tag":200,"props":479,"children":480},{},[481,482],{"type":191,"value":204},{"type":185,"tag":206,"props":483,"children":486},{"href":484,"rel":485},"https://zh-hans.eslint.org/docs/latest/use/configure/language-options#-7",[210],[487],{"type":191,"value":488},"ESLint parserOptions",{"type":185,"tag":193,"props":490,"children":492},{"id":491},"配置和插件有什么区别",[493],{"type":191,"value":494},"配置和插件有什么区别？",{"type":185,"tag":200,"props":496,"children":497},{},[498],{"type":191,"value":499},"配置是 ESLint 的规则和选项的集合（eslint-config-airbnb），而插件是扩展 ESLint 功能的模块（eslint-plugin-vue），插件可以包含自定义规则、解析器和共享配置。",{"type":185,"tag":193,"props":501,"children":503},{"id":502},"共享配置如何实现",[504],{"type":191,"value":505},"共享配置如何实现？",{"type":185,"tag":200,"props":507,"children":508},{},[509,510],{"type":191,"value":204},{"type":185,"t