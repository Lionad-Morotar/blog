","Dynamo 原本是 Revit 中建筑信息模型 (BIM) 的附加模块，后来发展成熟，成为一个给设计师探索可视化编程、解决问题并自行制作工具的平台。","content/6.maps/_products/dynamo.md",{"type":183,"children":184,"toc":723},"root",[185,197,202,210,217,232,287,292,297,302,310,315,321,326,334,393,398,406,414,448,453,458,463,468,473,481,486,493,498,506,511,516,524,529,534,539,544,552,557,565,570,575,582,587,592,597,602,607,612,620,625,633,638,643,648,656,669,674,679,718],{"type":186,"tag":187,"props":188,"children":189},"element","blockquote",{},[190],{"type":186,"tag":191,"props":192,"children":193},"p",{},[194],{"type":195,"value":196},"text","一款可视化编程工具，旨在同时供非编程人员和编程人员使用。它使用户能够直观地查看脚本行为、定义自定义逻辑以及使用各种文本编程语言的脚本。",{"type":186,"tag":191,"props":198,"children":199},{},[200],{"type":195,"value":201},"一个 Dynamo 示例：",{"type":186,"tag":191,"props":203,"children":204},{},[205],{"type":186,"tag":206,"props":207,"children":209},"img",{"alt":178,"src":208},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501311908636.png",[],{"type":186,"tag":211,"props":212,"children":214},"h4",{"id":213},"dynamo-primer",[215],{"type":195,"value":216},"Dynamo Primer",{"type":186,"tag":191,"props":218,"children":219},{},[220,222,230],{"type":195,"value":221},"Autodesk 给 Dynamo 编写了一册全面指南，叫 ",{"type":186,"tag":223,"props":224,"children":228},"a",{"href":225,"rel":226},"https://primer.dynamobim.org/zh-cn/index.html",[227],"nofollow",[229],{"type":195,"value":216},{"type":195,"value":231},"。",{"type":186,"tag":233,"props":234,"children":235},"ul",{},[236,242,247,252,257,262,267,272,277,282],{"type":186,"tag":237,"props":238,"children":239},"li",{},[240],{"type":195,"value":241},"上下文：\"可视化编程\"的确切含义是什么？我需要了解哪些概念才能深入了解 Dynamo？",{"type":186,"tag":237,"props":243,"children":244},{},[245],{"type":195,"value":246},"快速入门：如何获取 Dynamo 并创建第一个程序？",{"type":186,"tag":237,"props":248,"children":249},{},[250],{"type":195,"value":251},"程序中的内容：Dynamo 的功能部分是什么以及如何使用它们？",{"type":186,"tag":237,"props":253,"children":254},{},[255],{"type":195,"value":256},"构建块：\"数据\"是什么，我可以在程序中开始使用哪些基本类型？",{"type":186,"tag":237,"props":258,"children":259},{},[260],{"type":195,"value":261},"用于设计的几何体：如何在 Dynamo 中使用几何元素？",{"type":186,"tag":237,"props":263,"children":264},{},[265],{"type":195,"value":266},"列表、列表、列表：如何管理和协调数据结构？",{"type":186,"tag":237,"props":268,"children":269},{},[270],{"type":195,"value":271},"节点中的代码：如何使用自己的代码开始扩展 Dynamo？",{"type":186,"tag":237,"props":273,"children":274},{},[275],{"type":195,"value":276},"计算 BIM: 如何将 Dynamo 与 Revit 模型结合使用？",{"type":186,"tag":237,"props":278,"children":279},{},[280],{"type":195,"value":281},"自定义节点：如何创建自己的节点？",{"type":186,"tag":237,"props":283,"children":284},{},[285],{"type":195,"value":286},"软件包：如何与社区共享我的工具？",{"type":186,"tag":191,"props":288,"children":289},{},[290],{"type":195,"value":291},"程序需要按照算法来工作，所以这些操作必然遵循输入、处理和输出的基本逻辑。",{"type":186,"tag":191,"props":293,"children":294},{},[295],{"type":195,"value":296},"编程的关键及我们会遇到的第一个障碍是：必须依靠某种形式的抽象形式，才能与计算机进行有效通信。",{"type":186,"tag":191,"props":298,"children":299},{},[300],{"type":195,"value":301},"可视化编程把描述性操作抽象成了节点（及节点关系）。Dynamo 将节点关系描述为\"连接，将定义数据流\"。下面是一个通过中心点和半径创建圆的例子：",{"type":186,"tag":191,"props":303,"children":304},{},[305],{"type":186,"tag":206,"props":306,"children":309},{"alt":307,"src":308},"Dynamo example to create a circle","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501270238695.png",[],{"type":186,"tag":191,"props":311,"children":312},{},[313],{"type":195,"value":314},"Dynamo 的开发版本叫做\"bleeding edge\"。出血（bleeding）是一个设计领域术语，指裁切边缘距材料边缘的距离。",{"type":186,"tag":316,"props":317,"children":319},"h2",{"id":318},"界面",[320],{"type":195,"value":318},{"type":186,"tag":191,"props":322,"children":323},{},[324],{"type":195,"value":325},"节点主要分为如下几个部分，其中，\"核心\"和\"几何\"包含最多数量的节点（\"核心\"是什么？）。",{"type":186,"tag":191,"props":327,"children":328},{},[329],{"type":186,"tag":206,"props":330,"children":333},{"alt":331,"src":332},"Dynamo Libs","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501270249685.png",[],{"type":186,"tag":335,"props":336,"children":337},"ol",{},[338,343,348,353,358,363,368,373,378,383,388],{"type":186,"tag":237,"props":339,"children":340},{},[341],{"type":195,"value":342},"词典",{"type":186,"tag":237,"props":344,"children":345},{},[346],{"type":195,"value":347},"显示",{"type":186,"tag":237,"props":349,"children":350},{},[351],{"type":195,"value":352},"几何",{"type":186,"tag":237,"props":354,"children":355},{},[356],{"type":195,"value":357},"ImportExport",{"type":186,"tag":237,"props":359,"children":360},{},[361],{"type":195,"value":362},"输入",{"type":186,"tag":237,"props":364,"children":365},{},[366],{"type":195,"value":367},"列表",{"type":186,"tag":237,"props":369,"children":370},{},[371],{"type":195,"value":372},"匹配",{"type":186,"tag":237,"props":374,"children":375},{},[376],{"type":195,"value":377},"Revit",{"type":186,"tag":237,"props":379,"children":380},{},[381],{"type":195,"value":382},"脚本",{"type":186,"tag":237,"props":384,"children":385},{},[386],{"type":195,"value":387},"字符串",{"type":186,"tag":237,"props":389,"children":390},{},[391],{"type":195,"value":392},"附加模块",{"type":186,"tag":191,"props":394,"children":395},{},[396],{"type":195,"value":397},"可以参考一下节点布局算法。界面中的\"节点清理\"即节点布局：",{"type":186,"tag":191,"props":399,"children":400},{},[401],{"type":186,"tag":206,"props":402,"children":405},{"alt":403,"src":404},"after clean nodes","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501270257741.png",[],{"type":186,"tag":191,"props":407,"children":408},{},[409],{"type":186,"tag":206,"props":410,"children":413},{"alt":411,"src":412},"一个 Dynamo 节点","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501270309333.png",[],{"type":186,"tag":335,"props":415,"children":416},{},[417,419,424,425,430,431,436,437,442,443],{"type":195,"value":418},"\n  ",{"type":186,"tag":237,"props":420,"children":421},{},[422],{"type":195,"value":423},"名称 - 具有 Category.Name 命名约定的节点名称",{"type":195,"value":418},{"type":186,"tag":237,"props":426,"children":427},{},[428],{"type":195,"value":429},"主节点 - 节点的主体 - 在此处单击鼠标右键可显示整个节点级别的选项",{"type":195,"value":418},{"type":186,"tag":237,"props":432,"children":433},{},[434],{"type":195,"value":435},"端口（输入输出）- 导线的接受器，它们向节点提供输入数据以及节点操作的结果，有类型和值",{"type":195,"value":418},{"type":186,"tag":237,"props":438,"children":439},{},[440],{"type":195,"value":441},"连缀图标 - 表示为匹配列表输入指定的\"连缀\"选项（稍后再做详细介绍）",{"type":195,"value":418},{"type":186,"tag":237,"props":444,"children":445},{},[446],{"type":195,"value":447},"默认值 - 在输入端口上单击鼠标右键 - 某些节点具有可以使用也可以不使用的默认值。",{"type":186,"tag":191,"props":449,"children":450},{},[451],{"type":195,"value":452},"节点根据颜色还划分为：非活动、错误、冻结、选中、警告等状态。",{"type":186,"tag":191,"props":454,"children":455},{},[456],{"type":195,"value":457},"所有节点只分三层排列，其命名惯例为：library.category.nodeName。",{"type":186,"tag":191,"props":459,"children":460},{},[461],{"type":195,"value":462},"如何管理大量节点？通过注释标记节点功能、Watch 节点观察节点输出、Group 分组节点。",{"type":186,"tag":191,"props":464,"children":465},{},[466],{"type":195,"value":467},"因为节点的颜色已经被用来表示节点的状态，所以节点层面还缺少一种视觉方式来表示节点的类型。在 PRay 中也许可以使用图标、背景纹案之类的方案。",{"type":186,"tag":191,"props":469,"children":470},{},[471],{"type":195,"value":472},"在工程中 Dynamo 使用分组颜色来区分不用的功能区域。",{"type":186,"tag":191,"props":474,"children":475},{},[476],{"type":186,"tag":206,"props":477,"children":480},{"alt":478,"src":479},"dynamo project template","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501311703670.png",[],{"type":186,"tag":191,"props":482,"children":483},{},[484],{"type":195,"value":485},"Dynamo 的节点很清晰也很漂亮：",{"type":186,"tag":191,"props":487,"children":488},{},[489],{"type":186,"tag":206,"props":490,"children":492},{"alt":178,"src":491},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501270327205.png",[],{"type":186,"tag":191,"props":494,"children":495},{},[496],{"type":195,"value":497},"节点的抽象层级应该符合用户的认知层级，过高过低都不行，所以产品设计上经常会有\"表达式\"这么一个用来描述公式化逻辑的节点。如果要用节点把公式写出来那就太麻烦了，比如黄金螺旋的公式很简单：$x=r\\cos(\\theta)$, $y=r\\sin(\\theta)$，但是如果用节点来表达就会变得很复杂，如下图：",{"type":186,"tag":191,"props":499,"children":500},{},[501],{"type":186,"tag":206,"props":502,"children":505},{"alt":503,"src":504},"Gold Spiral","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501270345013.png",[],{"type":186,"tag":191,"props":507,"children":508},{},[509],{"type":195,"value":510},"怎么处理混乱的输入？",{"type":186,"tag":191,"props":512,"children":513},{},[514],{"type":195,"value":515},"如图，有三种条件逻辑的表达方式，但是为了给这三个节点输入统一的值，输入连线处理得很难看：",{"type":186,"tag":191,"props":517,"children":518},{},[519],{"type":186,"tag":206,"props":520,"children":523},{"alt":521,"src":522},"three ways to express conditional logic","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501270349782.png",[],{"type":186,"tag":191,"props":525,"children":526},{},[527],{"type":195,"value":528},"应该创建\"节点分身\"之类的概念，或是\"幽灵节点\"？操作逻辑可以是：从一个非分身节点复制出一个分身，分身和节点的数据保持一致，两者都可以修改。然后可以将分身节点拖到任意地方使用，这样就解耦了输入和使用方。不过，这样似乎会导致新的混乱，em...",{"type":186,"tag":316,"props":530,"children":532},{"id":531},"几何体",[533],{"type":195,"value":531},{"type":186,"tag":191,"props":535,"children":536},{},[537],{"type":195,"value":538},"\"维数是一种开始对几何图形进行分类的便捷方法，但它不一定是最佳方法。毕竟，我们不仅使用\"点\"、\"线\"、\"平面\"和\"方框\"建模 - 如果我想要弯曲，该怎么办？\"",{"type":186,"tag":191,"props":540,"children":541},{},[542],{"type":195,"value":543},"正如游戏建模中接触的\"网格\"的概念，Dynamo 中自有一套几何体的数据类型（估计和 Autodesk 其他产品保持一致）：",{"type":186,"tag":191,"props":545,"children":546},{},[547],{"type":186,"tag":206,"props":548,"children":551},{"alt":549,"src":550},"Geometry Data Types","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501270420841.png",[],{"type":186,"tag":191,"props":553,"children":554},{},[555],{"type":195,"value":556},"之前用过 C4D 和 Blender，这些数据类型都和 Dynamo 的类似（或者说几乎一致？）",{"type":186,"tag":191,"props":558,"children":559},{},[560],{"type":186,"tag":206,"props":561,"children":564},{"alt":562,"src":563},"Geometry Types","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501270423147.png",[],{"type":186,"tag":191,"props":566,"children":567},{},[568],{"type":195,"value":569},"\"抽象\"的数据类型不能在屏幕上预览，这和\"headless\"的概念很类似，都是在界面底层通过操作数据结构来创建一种更基本的\"逻辑\"，可以没有界面。说\"可以\"是因为比如\"平面\"之类的数据类型尽管是抽象的，但（为了操作的便利性）仍可以在界面上预览。",{"type":186,"tag":191,"props":571,"children":572},{},[573],{"type":195,"value":574},"节点冻结用于禁用当前及下游节点，可以避免修改上游节点导致下游节点重新计算带来的巨大性能开销，如下图，冻结了圆和圆锥的 Union 操作。",{"type":186,"tag":191,"props":576,"children":577},{},[578],{"type":186,"tag":206,"props":579,"children":581},{"alt":178,"src":580},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501270450836.png",[],{"type":186,"tag":191,"props":583,"children":584},{},[585],{"type":195,"value":586},"Comfy UI 在跑流程时，节点上会有个进度条显示，暗示当前的执行进度。",{"type":186,"tag":191,"props":588,"children":589},{},[590],{"type":195,"value":591},"两种形式分别对应：实时预览和离线计算。鉴于 PRay 的代码编辑需要实时预览，但是节点的执行机制需要设计成离线式的，也就是全部走异步+防抖的形式。不过，这样的话又会碰到副作用的问题。.. 还是再考虑下。",{"type":186,"tag":316,"props":593,"children":595},{"id":594},"数据结构",[596],{"type":195,"value":594},{"type":186,"tag":191,"props":598,"children":599},{},[600],{"type":195,"value":601},"对于能接受列表的节点，比如 PolyCurve.ByPoints 和 Circle.ByCenterPointRadius，他们都能接受点列表作为输入，但是逻辑处理机制不同，前者按照点列表生成多段曲线，后者生成多个圆。也就是说，对于后者，似乎存在一个隐式的\"循环\"操作。",{"type":186,"tag":191,"props":603,"children":604},{},[605],{"type":195,"value":606},"当两个列表长度不匹配时，通过设置\"连缀\"选项来处理，可选\"最短列表\"、\"笛卡尔积（叉积）\"等。鉴于在非绘图绘表的 Web 数据处理一般是操作相同长度的列表，所以这个设计不能直接套用。",{"type":186,"tag":191,"props":608,"children":609},{},[610],{"type":195,"value":611},"因为用节点编排逻辑只是代码的某种子集，所以见到 Dynamo 中有\"节点转换到代码\"这种功能也不足为奇。在 Dynamo Primer 的\"最佳实践\"章节，甚至直接提到了可以使用节点到代码功能降低图形复杂度。只是，他还说节点到代码\"无法轻松返回\"？难道节点到代码丢失了除了节点位置之类的其他信息，或者只是单纯没有代码解析器所以提供这个功能。",{"type":186,"tag":191,"props":613,"children":614},{},[615],{"type":186,"tag":206,"props":616,"children":619},{"alt":617,"src":618},"dynamo nodes 2 codes","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501311638043.png",[],{"type":186,"tag":191,"props":621,"children":622},{},[623],{"type":195,"value":624},"至于在创建、操作数据和编排逻辑这块，代码的表达性要比节点强太多了，以条件逻辑举例，见下图。",{"type":186,"tag":191,"props":626,"children":627},{},[628],{"type":186,"tag":206,"props":629,"children":632},{"alt":630,"src":631},"condition expression","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501311643375.png",[],{"type":186,"tag":191,"props":634,"children":635},{},[636],{"type":195,"value":637},"那么节点强在什么地方呢？举个例子，可视化变成的一个优势是可以直观的观察到数据流，并且提供了更强的人机交互。所以，如果代码块支持用模版语法自定义变量，再由节点作为可控输入，就可以二者的优势。这其实是\"函数\"，也就是说，代码块本身只是代码，并没有显示的切换成\"表达式\"、\"语句\"、\"函数\"等模式，而传统意义上的代码中的\"函数\"在可视化编程中是个外显的界面概念。",{"type":186,"tag":191,"props":639,"children":640},{},[641],{"type":195,"value":642},"实际上，在 Dynamo 的\"代码块\"可以声明\"函数\"。声明后，其他代码块可以直接调用函数而无需连线。在这里，节点的操作和代码创建函数共享了一整个空间，不过事情似乎会变得更难以理解。",{"type":186,"tag":191,"props":644,"children":645},{},[646],{"type":195,"value":647},"最后，一个节点的示例文档，介绍了输入输出、分类、使用案例，以及进阶使用方法。",{"type":186,"tag":191,"props":649,"children":650},{},[651],{"type":186,"tag":206,"props":652,"children":655},{"alt":653,"src":654},"https://dictionary.dynamobim.com/#/Core/Color/Create/Add","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202503200342002.png",[],{"type":186,"tag":233,"props":657,"children":658},{},[659],{"type":186,"tag":237,"props":660,"children":661},{},[662],{"type":186,"tag":223,"props":663,"children":666},{"href":664,"rel":665},"https://dictionary.dynamobim.com",[227],[667],{"type":195,"value":668},"节点文档",{"type":186,"tag":316,"props":670,"children":672},{"id":671},"扩展",[673],{"type":195,"value":671},{"type":186,"tag":191,"props":675,"children":676},{},[677],{"type":195,"value":678},"关于 Dynamo 的自定义节点，找到几个有用的库：",{"type":186,"tag":233,"props":680,"children":681},{},[682,694,706],{"type":186,"tag":237,"props":683,"children":684},{},[685,692],{"type":186,"tag":223,"props":686,"children":689},{"href":687,"rel":688},"https://data-shapes.io/blog/",[227],[690],{"type":195,"value":691},"Data Shapes",{"type":195,"value":693},"：绘图和数据处理用的节点，包含了图表、表单、地图、表格、UI 构建（用户侧的表单等）。",{"type":186,"tag":237,"props":695,"children":696},{},[697,704],{"type":186,"tag":223,"props":698,"children":701},{"href":699,"rel":700},"https://bimorph.com/bimorph-nodes/",[227],[702],{"type":195,"value":703},"BIMORPH Nodes",{"type":195,"value":705},"：包含了碰撞检测等高级功能，主要面向 CAD、Curve、Revit 之类的数据结构。",{"type":186,"tag":237,"props":707,"children":708},{},[709,716],{"type":186,"tag":223,"props":710,"children":713},{"href":711,"rel":712},"https://github.com/ksobon/Bumblebee",[227],[714],{"type":195,"value":715},"Bumblebee",{"type":195,"value":717},"：用于操作 Excel，但是最近一次提交在 2019 年。",{"type":186,"tag":191,"props":719,"children":720},{},[721],{"type":195,"value":722},"Data Shapes 太棒了，可以用图表快速分析图中的数据。但是 Github 上只有 50+ 星星，看来 Dynamo 的用户中懂代码的群体还是太小了。其实就连 Dynamo 仓库本身的 Issue 数量也才 300+（未关闭的）。",{"title":178,"searchDepth":724,"depth":724,"links":725},2,[726,727,728,729],{"id":318,"depth":724,"text":318},{"id":531,"depth":724,"text":531},{"id":594,"depth":724,"text":594},{"id":671,"depth":724,"text":671},"markdown","content:6.maps:_products:dynamo:dynamo.md","content","6.maps/_products/dynamo/dynamo.md","6.maps/_products/dynamo/dynamo","md",[737,740],{"_path":738,"title":739,"description":178},"/maps/_products/budibase/budibase","Budibase",{"_path":741,"title":742,"description":743},"/maps/_products/products","产品工具","产品开发工具、低代码平台、可视化编程和集成工具",1772504944417]