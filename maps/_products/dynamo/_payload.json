块，后来发展成熟，成为一个给设计师探索可视化编程、解决问题并自行制作工具的平台。",{"type":182,"children":183,"toc":722},"root",[184,196,201,209,216,231,286,291,296,301,309,314,320,325,333,392,397,405,413,447,452,457,462,467,472,480,485,492,497,505,510,515,523,528,533,538,543,551,556,564,569,574,581,586,591,596,601,606,611,619,624,632,637,642,647,655,668,673,678,717],{"type":185,"tag":186,"props":187,"children":188},"element","blockquote",{},[189],{"type":185,"tag":190,"props":191,"children":192},"p",{},[193],{"type":194,"value":195},"text","一款可视化编程工具，旨在同时供非编程人员和编程人员使用。它使用户能够直观地查看脚本行为、定义自定义逻辑以及使用各种文本编程语言的脚本。",{"type":185,"tag":190,"props":197,"children":198},{},[199],{"type":194,"value":200},"一个 Dynamo 示例：",{"type":185,"tag":190,"props":202,"children":203},{},[204],{"type":185,"tag":205,"props":206,"children":208},"img",{"alt":178,"src":207},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501311908636.png",[],{"type":185,"tag":210,"props":211,"children":213},"h4",{"id":212},"dynamo-primer",[214],{"type":194,"value":215},"Dynamo Primer",{"type":185,"tag":190,"props":217,"children":218},{},[219,221,229],{"type":194,"value":220},"Autodesk 给 Dynamo 编写了一册全面指南，叫 ",{"type":185,"tag":222,"props":223,"children":227},"a",{"href":224,"rel":225},"https://primer.dynamobim.org/zh-cn/index.html",[226],"nofollow",[228],{"type":194,"value":215},{"type":194,"value":230},"。",{"type":185,"tag":232,"props":233,"children":234},"ul",{},[235,241,246,251,256,261,266,271,276,281],{"type":185,"tag":236,"props":237,"children":238},"li",{},[239],{"type":194,"value":240},"上下文：“可视化编程”的确切含义是什么？我需要了解哪些概念才能深入了解 Dynamo？",{"type":185,"tag":236,"props":242,"children":243},{},[244],{"type":194,"value":245},"快速入门：如何获取 Dynamo 并创建第一个程序？",{"type":185,"tag":236,"props":247,"children":248},{},[249],{"type":194,"value":250},"程序中的内容：Dynamo 的功能部分是什么以及如何使用它们？",{"type":185,"tag":236,"props":252,"children":253},{},[254],{"type":194,"value":255},"构建块：“数据”是什么，我可以在程序中开始使用哪些基本类型？",{"type":185,"tag":236,"props":257,"children":258},{},[259],{"type":194,"value":260},"用于设计的几何体：如何在 Dynamo 中使用几何元素？",{"type":185,"tag":236,"props":262,"children":263},{},[264],{"type":194,"value":265},"列表、列表、列表：如何管理和协调数据结构？",{"type":185,"tag":236,"props":267,"children":268},{},[269],{"type":194,"value":270},"节点中的代码：如何使用自己的代码开始扩展 Dynamo？",{"type":185,"tag":236,"props":272,"children":273},{},[274],{"type":194,"value":275},"计算 BIM: 如何将 Dynamo 与 Revit 模型结合使用？",{"type":185,"tag":236,"props":277,"children":278},{},[279],{"type":194,"value":280},"自定义节点：如何创建自己的节点？",{"type":185,"tag":236,"props":282,"children":283},{},[284],{"type":194,"value":285},"软件包：如何与社区共享我的工具？",{"type":185,"tag":190,"props":287,"children":288},{},[289],{"type":194,"value":290},"程序需要按照算法来工作，所以这些操作必然遵循输入、处理和输出的基本逻辑。",{"type":185,"tag":190,"props":292,"children":293},{},[294],{"type":194,"value":295},"编程的关键及我们会遇到的第一个障碍是：必须依靠某种形式的抽象形式，才能与计算机进行有效通信。",{"type":185,"tag":190,"props":297,"children":298},{},[299],{"type":194,"value":300},"可视化编程把描述性操作抽象成了节点（及节点关系）。Dynamo 将节点关系描述为“连接，将定义数据流”。下面是一个通过中心点和半径创建圆的例子：",{"type":185,"tag":190,"props":302,"children":303},{},[304],{"type":185,"tag":205,"props":305,"children":308},{"alt":306,"src":307},"Dynamo example to create a circle","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501270238695.png",[],{"type":185,"tag":190,"props":310,"children":311},{},[312],{"type":194,"value":313},"Dynamo 的开发版本叫做“bleeding edge”。出血（bleeding）是一个设计领域术语，指裁切边缘距材料边缘的距离。",{"type":185,"tag":315,"props":316,"children":318},"h2",{"id":317},"界面",[319],{"type":194,"value":317},{"type":185,"tag":190,"props":321,"children":322},{},[323],{"type":194,"value":324},"节点主要分为如下几个部分，其中，“核心”和“几何”包含最多数量的节点（“核心”是什么？）。",{"type":185,"tag":190,"props":326,"children":327},{},[328],{"type":185,"tag":205,"props":329,"children":332},{"alt":330,"src":331},"Dynamo Libs","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501270249685.png",[],{"type":185,"tag":334,"props":335,"children":336},"ol",{},[337,342,347,352,357,362,367,372,377,382,387],{"type":185,"tag":236,"props":338,"children":339},{},[340],{"type":194,"value":341},"词典",{"type":185,"tag":236,"props":343,"children":344},{},[345],{"type":194,"value":346},"显示",{"type":185,"tag":236,"props":348,"children":349},{},[350],{"type":194,"value":351},"几何",{"type":185,"tag":236,"props":353,"children":354},{},[355],{"type":194,"value":356},"ImportExport",{"type":185,"tag":236,"props":358,"children":359},{},[360],{"type":194,"value":361},"输入",{"type":185,"tag":236,"props":363,"children":364},{},[365],{"type":194,"value":366},"列表",{"type":185,"tag":236,"props":368,"children":369},{},[370],{"type":194,"value":371},"匹配",{"type":185,"tag":236,"props":373,"children":374},{},[375],{"type":194,"value":376},"Revit",{"type":185,"tag":236,"props":378,"children":379},{},[380],{"type":194,"value":381},"脚本",{"type":185,"tag":236,"props":383,"children":384},{},[385],{"type":194,"value":386},"字符串",{"type":185,"tag":236,"props":388,"children":389},{},[390],{"type":194,"value":391},"附加模块",{"type":185,"tag":190,"props":393,"children":394},{},[395],{"type":194,"value":396},"可以参考一下节点布局算法。界面中的“节点清理”即节点布局：",{"type":185,"tag":190,"props":398,"children":399},{},[400],{"type":185,"tag":205,"props":401,"children":404},{"alt":402,"src":403},"after clean nodes","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501270257741.png",[],{"type":185,"tag":190,"props":406,"children":407},{},[408],{"type":185,"tag":205,"props":409,"children":412},{"alt":410,"src":411},"一个 Dynamo 节点","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501270309333.png",[],{"type":185,"tag":334,"props":414,"children":415},{},[416,418,423,424,429,430,435,436,441,442],{"type":194,"value":417},"\n  ",{"type":185,"tag":236,"props":419,"children":420},{},[421],{"type":194,"value":422},"名称 - 具有 Category.Name 命名约定的节点名称",{"type":194,"value":417},{"type":185,"tag":236,"props":425,"children":426},{},[427],{"type":194,"value":428},"主节点 - 节点的主体 - 在此处单击鼠标右键可显示整个节点级别的选项",{"type":194,"value":417},{"type":185,"tag":236,"props":431,"children":432},{},[433],{"type":194,"value":434},"端口（输入输出）- 导线的接受器，它们向节点提供输入数据以及节点操作的结果，有类型和值",{"type":194,"value":417},{"type":185,"tag":236,"props":437,"children":438},{},[439],{"type":194,"value":440},"连缀图标 - 表示为匹配列表输入指定的“连缀”选项（稍后再做详细介绍）",{"type":194,"value":417},{"type":185,"tag":236,"props":443,"children":444},{},[445],{"type":194,"value":446},"默认值 - 在输入端口上单击鼠标右键 - 某些节点具有可以使用也可以不使用的默认值。",{"type":185,"tag":190,"props":448,"children":449},{},[450],{"type":194,"value":451},"节点根据颜色还划分为：非活动、错误、冻结、选中、警告等状态。",{"type":185,"tag":190,"props":453,"children":454},{},[455],{"type":194,"value":456},"所有节点只分三层排列，其命名惯例为：library.category.nodeName。",{"type":185,"tag":190,"props":458,"children":459},{},[460],{"type":194,"value":461},"如何管理大量节点？通过注释标记节点功能、Watch 节点观察节点输出、Group 分组节点。",{"type":185,"tag":190,"props":463,"children":464},{},[465],{"type":194,"value":466},"因为节点的颜色已经被用来表示节点的状态，所以节点层面还缺少一种视觉方式来表示节点的类型。在 PRay 中也许可以使用图标、背景纹案之类的方案。",{"type":185,"tag":190,"props":468,"children":469},{},[470],{"type":194,"value":471},"在工程中 Dynamo 使用分组颜色来区分不用的功能区域。",{"type":185,"tag":190,"props":473,"children":474},{},[475],{"type":185,"tag":205,"props":476,"children":479},{"alt":477,"src":478},"dynamo project template","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501311703670.png",[],{"type":185,"tag":190,"props":481,"children":482},{},[483],{"type":194,"value":484},"Dynamo 的节点很清晰也很漂亮：",{"type":185,"tag":190,"props":486,"children":487},{},[488],{"type":185,"tag":205,"props":489,"children":491},{"alt":178,"src":490},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501270327205.png",[],{"type":185,"tag":190,"props":493,"children":494},{},[495],{"type":194,"value":496},"节点的抽象层级应该符合用户的认知层级，过高过低都不行，所以产品设计上经常会有“表达式”这么一个用来描述公式化逻辑的节点。如果要用节点把公式写出来那就太麻烦了，比如黄金螺旋的公式很简单：$x=r\\cos(\\theta)$, $y=r\\sin(\\theta)$，但是如果用节点来表达就会变得很复杂，如下图：",{"type":185,"tag":190,"props":498,"children":499},{},[500],{"type":185,"tag":205,"props":501,"children":504},{"alt":502,"src":503},"Gold Spiral","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501270345013.png",[],{"type":185,"tag":190,"props":506,"children":507},{},[508],{"type":194,"value":509},"怎么处理混乱的输入？",{"type":185,"tag":190,"props":511,"children":512},{},[513],{"type":194,"value":514},"如图，有三种条件逻辑的表达方式，但是为了给这三个节点输入统一的值，输入连线处理得很难看：",{"type":185,"tag":190,"props":516,"children":517},{},[518],{"type":185,"tag":205,"props":519,"children":522},{"alt":520,"src":521},"three ways to express conditional logic","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501270349782.png",[],{"type":185,"tag":190,"props":524,"children":525},{},[526],{"type":194,"value":527},"应该创建“节点分身”之类的概念，或是“幽灵节点”？操作逻辑可以是：从一个非分身节点复制出一个分身，分身和节点的数据保持一致，两者都可以修改。然后可以将分身节点拖到任意地方使用，这样就解耦了输入和使用方。不过，这样似乎会导致新的混乱，em...",{"type":185,"tag":315,"props":529,"children":531},{"id":530},"几何体",[532],{"type":194,"value":530},{"type":185,"tag":190,"props":534,"children":535},{},[536],{"type":194,"value":537},"“维数是一种开始对几何图形进行分类的便捷方法，但它不一定是最佳方法。毕竟，我们不仅使用“点”、“线”、“平面”和“方框”建模 - 如果我想要弯曲，该怎么办？”",{"type":185,"tag":190,"props":539,"children":540},{},[541],{"type":194,"value":542},"正如游戏建模中接触的“网格”的概念，Dynamo 中自有一套几何体的数据类型（估计和 Autodesk 其他产品保持一致）：",{"type":185,"tag":190,"props":544,"children":545},{},[546],{"type":185,"tag":205,"props":547,"children":550},{"alt":548,"src":549},"Geometry Data Types","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501270420841.png",[],{"type":185,"tag":190,"props":552,"children":553},{},[554],{"type":194,"value":555},"之前用过 C4D 和 Blender，这些数据类型都和 Dynamo 的类似（或者说几乎一致？）",{"type":185,"tag":190,"props":557,"children":558},{},[559],{"type":185,"tag":205,"props":560,"children":563},{"alt":561,"src":562},"Geometry Types","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501270423147.png",[],{"type":185,"tag":190,"props":565,"children":566},{},[567],{"type":194,"value":568},"“抽象”的数据类型不能在屏幕上预览，这和“headless”的概念很类似，都是在界面底层通过操作数据结构来创建一种更基本的“逻辑”，可以没有界面。说“可以”是因为比如“平面”之类的数据类型尽管是抽象的，但（为了操作的便利性）仍可以在界面上预览。",{"type":185,"tag":190,"props":570,"children":571},{},[572],{"type":194,"value":573},"节点冻结用于禁用当前及下游节点，可以避免修改上游节点导致下游节点重新计算带来的巨大性能开销，如下图，冻结了圆和圆锥的 Union 操作。",{"type":185,"tag":190,"props":575,"children":576},{},[577],{"type":185,"tag":205,"props":578,"children":580},{"alt":178,"src":579},"https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501270450836.png",[],{"type":185,"tag":190,"props":582,"children":583},{},[584],{"type":194,"value":585},"Comfy UI 在跑流程时，节点上会有个进度条显示，暗示当前的执行进度。",{"type":185,"tag":190,"props":587,"children":588},{},[589],{"type":194,"value":590},"两种形式分别对应：实时预览和离线计算。鉴于 PRay 的代码编辑需要实时预览，但是节点的执行机制需要设计成离线式的，也就是全部走异步+防抖的形式。不过，这样的话又会碰到副作用的问题。.. 还是再考虑下。",{"type":185,"tag":315,"props":592,"children":594},{"id":593},"数据结构",[595],{"type":194,"value":593},{"type":185,"tag":190,"props":597,"children":598},{},[599],{"type":194,"value":600},"对于能接受列表的节点，比如 PolyCurve.ByPoints 和 Circle.ByCenterPointRadius，他们都能接受点列表作为输入，但是逻辑处理机制不同，前者按照点列表生成多段曲线，后者生成多个圆。也就是说，对于后者，似乎存在一个隐式的“循环”操作。",{"type":185,"tag":190,"props":602,"children":603},{},[604],{"type":194,"value":605},"当两个列表长度不匹配时，通过设置“连缀”选项来处理，可选“最短列表”、“笛卡尔积（叉积）”等。鉴于在非绘图绘表的 Web 数据处理一般是操作相同长度的列表，所以这个设计不能直接套用。",{"type":185,"tag":190,"props":607,"children":608},{},[609],{"type":194,"value":610},"因为用节点编排逻辑只是代码的某种子集，所以见到 Dynamo 中有“节点转换到代码”这种功能也不足为奇。在 Dynamo Primer 的“最佳实践”章节，甚至直接提到了可以使用节点到代码功能降低图形复杂度。只是，他还说节点到代码“无法轻松返回”？难道节点到代码丢失了除了节点位置之类的其他信息，或者只是单纯没有代码解析器所以提供这个功能。",{"type":185,"tag":190,"props":612,"children":613},{},[614],{"type":185,"tag":205,"props":615,"children":618},{"alt":616,"src":617},"dynamo nodes 2 codes","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501311638043.png",[],{"type":185,"tag":190,"props":620,"children":621},{},[622],{"type":194,"value":623},"至于在创建、操作数据和编排逻辑这块，代码的表达性要比节点强太多了，以条件逻辑举例，见下图。",{"type":185,"tag":190,"props":625,"children":626},{},[627],{"type":185,"tag":205,"props":628,"children":631},{"alt":629,"src":630},"condition expression","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202501311643375.png",[],{"type":185,"tag":190,"props":633,"children":634},{},[635],{"type":194,"value":636},"那么节点强在什么地方呢？举个例子，可视化变成的一个优势是可以直观的观察到数据流，并且提供了更强的人机交互。所以，如果代码块支持用模版语法自定义变量，再由节点作为可控输入，就可以二者的优势。这其实是“函数”，也就是说，代码块本身只是代码，并没有显示的切换成“表达式”、“语句”、“函数”等模式，而传统意义上的代码中的“函数”在可视化编程中是个外显的界面概念。",{"type":185,"tag":190,"props":638,"children":639},{},[640],{"type":194,"value":641},"实际上，在 Dynamo 的“代码块”可以声明“函数”。声明后，其他代码块可以直接调用函数而无需连线。在这里，节点的操作和代码创建函数共享了一整个空间，不过事情似乎会变得更难以理解。",{"type":185,"tag":190,"props":643,"children":644},{},[645],{"type":194,"value":646},"最后，一个节点的示例文档，介绍了输入输出、分类、使用案例，以及进阶使用方法。",{"type":185,"tag":190,"props":648,"children":649},{},[650],{"type":185,"tag":205,"props":651,"children":654},{"alt":652,"src":653},"https://dictionary.dynamobim.com/#/Core/Color/Create/Add","https://mgear-image.oss-cn-shanghai.aliyuncs.com/image/other/202503200342002.png",[],{"type":185,"tag":232,"props":656,"children":657},{},[658],{"type":185,"tag":236,"props":659,"children":660},{},[661],{"type":185,"tag":222,"props":662,"children":665},{"href":663,"rel":664},"https://dictionary.dynamobim.com",[226],[666],{"type":194,"value":667},"节点文档",{"type":185,"tag":315,"props":669,"children":671},{"id":670},"扩展",[672],{"type":194,"value":670},{"type":185,"tag":190,"props":674,"children":675},{},[676],{"type":194,"value":677},"关于 Dynamo 的自定义节点，找到几个有用的库：",{"type":185,"tag":232,"props":679,"children":680},{},[681,693,705],{"type":185,"tag":236,"props":682,"children":683},{},[684,691],{"type":185,"tag":222,"props":685,"children":688},{"href":686,"rel":687},"https://data-shapes.io/blog/",[226],[689],{"type":194,"value":690},"Data Shapes",{"type":194,"value":692},"：绘图和数据处理用的节点，包含了图表、表单、地图、表格、UI 构建（用户侧的表单等）。",{"type":185,"tag":236,"props":694,"children":695},{},[696,703],{"type":185,"tag":222,"props":697,"children":700},{"href":698,"rel":699},"https://bimorph.com/bimorph-nodes/",[226],[701],{"type":194,"value":702},"BIMORPH Nodes",{"type":194,"value":704},"：包含了碰撞检测等高级功能，主要面向 CAD、Curve、Revit 之类的数据结构。",{"type":185,"tag":236,"props":706,"children":707},{},[708,715],{"type":185,"tag":222,"props":709,"children":712},{"href":710,"rel":711},"https://github.com/ksobon/Bumblebee",[226],[713],{"type":194,"value":714},"Bumblebee",{"type":194,"value":716},"：用于操作 Excel，但是最近一次提交在 2019 年。",{"type":185,"tag":190,"props":718,"children":719},{},[720],{"type":194,"value":721},"Data Shapes 太棒了，可以用图表快速分析图中的数据。但是 Github 上只有 50+ 星星，看来 Dynamo 的用户中懂代码的群体还是太小了。其实就连 Dynamo 仓库本身的 Issue 数量也才 300+（未关闭的）。",{"title":178,"searchDepth":723,"depth":723,"links":724},2,[725,726,727,728],{"id":317,"depth":723,"text":317},{"id":530,"depth":723,"text":530},{"id":593,"depth":723,"text":593},{"id":670,"depth":723,"text":670},"markdown","content:6.maps:_products:dynamo.md","content","6.maps/_products/dynamo.md","6.maps/_products/dynamo","md",[736,739],{"_path":737,"title":738,"description":178},"/maps/_products/budibase","Budibase",{"_path":740,"title":741,"description":742},"/maps/_products/zapier","Zapier","Connectors for APP Ocean",1771696727399]