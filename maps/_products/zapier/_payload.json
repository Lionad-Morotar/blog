16,225],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"简介",[187],{"type":188,"value":185},"text",{"type":182,"tag":190,"props":191,"children":192},"ul",{},[193],{"type":182,"tag":194,"props":195,"children":196},"li",{},[197],{"type":182,"tag":198,"props":199,"children":203},"a",{"href":200,"rel":201},"https://tables.zapier.ceom/app/tables/home",[202],"nofollow",[204],{"type":188,"value":176},{"type":182,"tag":183,"props":206,"children":208},{"id":207},"评价",[209],{"type":188,"value":207},{"type":182,"tag":211,"props":212,"children":213},"p",{},[214],{"type":188,"value":215},"Herb Caudill 提到 Zapier（同样的，以及 q 相似的软件）在真实应用中可能缺乏可靠性。",{"type":182,"tag":217,"props":218,"children":219},"blockquote",{},[220],{"type":182,"tag":211,"props":221,"children":222},{},[223],{"type":188,"value":224},"Zapier lets you link one app to another via their public APIs: A trigger in one app results in an action in another. In some simple cases it works great. But the trigger/action model can be clumsy and brittle in practice. Getting two systems to maintain the same dataset in sync is a real challenge. Sometimes it just fails silently, and you don’t realize it until you go to look at your home-made dashboard and it doesn’t have any data for the last couple of months.",{"type":182,"tag":211,"props":226,"children":227},{},[228,230],{"type":188,"value":229},"见：",{"type":182,"tag":198,"props":231,"children":234},{"href":232,"rel":233},"https://herbcaudill.com/words/20180315-solving-the-software-puzzle",[202],[235],{"type":182,"tag":236,"props":237,"children":238},"i",{},[239],{"type":188,"value":240},"Solving the software puzzle",{"title":175,"searchDepth":242,"depth":242,"links":243},2,[244,245],{"id":185,"depth":242,"text":185},{"id":207,"depth":242,"text":207},"markdown","content:6.maps:_products:zapier.md","content","6.maps/_products/zapier.md","6.maps/_products/zapier","md",[253,257],{"_path":254,"title":255,"description":256},"/maps/_products/dynamo","Dynamo","Dynamo 原本是 Revit 中建筑信息模型 (BIM) 的附加模块，后来发展成熟，成为一个给设计师探索可视化编程、解决问题并自行制作工具的平台。",{"_path":258,"title":259,"description":260},"/maps/_programming/dx","Developer Experience（DX）","开发者体验（Developer Experience，DX）是指开发者在使用产品、工具、框架等过程中的感受和体验。它是用户体验（User Experience，UX）的一个子集，专注于开发者的需求和体验。",1771214207708]