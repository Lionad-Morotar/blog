es/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"original_path":181,"body":182,"_type":1098,"_id":1099,"_source":1100,"_file":1101,"_stem":1102,"_extension":1103},"/maps/_database/graphql/graphql-for-llm","graphql",false,true,"","GraphQL for LLM","将 GraphQL 作为大型语言模型（LLM）数据访问模式的实践","content/6.maps/_database/graphql/ai/graphql-for-llm.md",{"type":183,"children":184,"toc":1087},"root",[185,194,200,205,210,215,221,228,235,268,273,278,284,289,349,354,406,412,418,467,472,478,517,523,562,567,573,638,643,648,657,665,674,682,691,709,715,720,759,764,803,809,814,819,837,842,855,860,868,907,915,949,957,1001,1010,1044,1053,1082],{"type":186,"tag":187,"props":188,"children":190},"element","h2",{"id":189},"brief",[191],{"type":192,"value":193},"text","Brief",{"type":186,"tag":195,"props":196,"children":197},"p",{},[198],{"type":192,"value":199},"GraphQL 作为 LLM 的数据访问模式，是一种正在兴起的实践：通过统一、对模型友好的数据访问层来增强上下文工程能力，让团队可以向模型暴露结构化、可查询的数据，而无需给 LLM 直接数据库权限。",{"type":186,"tag":195,"props":201,"children":202},{},[203],{"type":192,"value":204},"相较 REST API 往往出现的「过度拉取」或为每个用例新增端点 / 过滤条件的问题，GraphQL 允许 LLM 只获取所需字段，降低无关噪音，提高上下文相关性，并减少 token 消耗。",{"type":186,"tag":195,"props":206,"children":207},{},[208],{"type":192,"value":209},"精心设计的 GraphQL Schema 还能为 LLM 提供实体及其关系的元数据，使模型可以进行动态、感知 Schema 的查询，对各类 Agent 场景尤其有价值。整体上，这种模式在 REST 和直接 SQL 之间提供了一个安全的中间层，在治理控制与访问灵活性之间取得平衡。",{"type":186,"tag":195,"props":211,"children":212},{},[213],{"type":192,"value":214},"但这种方法依赖于良好建模的 Schema 与有语义的字段命名。对复杂 Schema 的语义理解与结构导航本身就不容易——对人类难的事情，对 LLM 通常也不轻松。此外，还需要意识到：这种模式会增加潜在的 DoS 攻击向量，并继承 GraphQL 的常见挑战，例如缓存和版本管理问题。",{"type":186,"tag":187,"props":216,"children":218},{"id":217},"details",[219],{"type":192,"value":220},"Details",{"type":186,"tag":222,"props":223,"children":225},"h3",{"id":224},"背景与动机为什么考虑-graphql-llm",[226],{"type":192,"value":227},"背景与动机：为什么考虑 GraphQL + LLM",{"type":186,"tag":229,"props":230,"children":232},"h4",{"id":231},"llm-上下文工程的核心矛盾",[233],{"type":192,"value":234},"LLM 上下文工程的核心矛盾",{"type":186,"tag":236,"props":237,"children":238},"ul",{},[239,245,250],{"type":186,"tag":240,"props":241,"children":242},"li",{},[243],{"type":192,"value":244},"LLM 需要高质量、结构化且相关性强的上下文，以支撑检索增强、工具调用和 Agent 任务分解。",{"type":186,"tag":240,"props":246,"children":247},{},[248],{"type":192,"value":249},"直接开放数据库或 SQL 给 LLM 带来较大安全与治理风险；纯靠自然语言检索结构化数据又容易丢失精度。",{"type":186,"tag":240,"props":251,"children":252},{},[253,255],{"type":192,"value":254},"传统 REST API：\n",{"type":186,"tag":236,"props":256,"children":257},{},[258,263],{"type":186,"tag":240,"props":259,"children":260},{},[261],{"type":192,"value":262},"常常为前端 /特定用例定制，粒度不匹配 LLM 的动态需求；",{"type":186,"tag":240,"props":264,"children":265},{},[266],{"type":192,"value":267},"存在过度返回、字段不全、新用例需要新端点等问题，增加上下文噪音和 token 成本。",{"type":186,"tag":195,"props":269,"children":270},{},[271],{"type":192,"value":272},"在这种张力下，GraphQL 作为统一数据访问层，天然具备「按需组合、强类型 Schema、可浏览的实体关系」等特性，逐渐被视作一种更适配 LLM 的数据访问模式。",{"type":186,"tag":222,"props":274,"children":276},{"id":275},"核心模式与工作原理",[277],{"type":192,"value":275},{"type":186,"tag":229,"props":279,"children":281},{"id":280},"graphql-在-llm-场景中的角色",[282],{"type":192,"value":283},"GraphQL 在 LLM 场景中的角色",{"type":186,"tag":195,"props":285,"children":286},{},[287],{"type":192,"value":288},"可以把 GraphQL 看成「LLM 专用数据网关」，承担几件事：",{"type":186,"tag":236,"props":290,"children":291},{},[292,305,323,336],{"type":186,"tag":240,"props":293,"children":294},{},[295,297],{"type":192,"value":296},"统一入口：\n",{"type":186,"tag":236,"props":298,"children":299},{},[300],{"type":186,"tag":240,"props":301,"children":302},{},[303],{"type":192,"value":304},"各种后端服务、数据库、第三方 API 通过 GraphQL 聚合，对 LLM 只暴露一个逻辑端点。",{"type":186,"tag":240,"props":306,"children":307},{},[308,310],{"type":192,"value":309},"强类型 Schema：\n",{"type":186,"tag":236,"props":311,"children":312},{},[313,318],{"type":186,"tag":240,"props":314,"children":315},{},[316],{"type":192,"value":317},"$$\\text{Types}$$、$$\\text{Fields}$$、$$\\text{Relations}$$ 为 LLM 提供可机器理解的\"业务知识图谱\"；",{"type":186,"tag":240,"props":319,"children":320},{},[321],{"type":192,"value":322},"LLM 能基于 Schema 自动推理可用实体、字段和关联。",{"type":186,"tag":240,"props":324,"children":325},{},[326,328],{"type":192,"value":327},"按需查询：\n",{"type":186,"tag":236,"props":329,"children":330},{},[331],{"type":186,"tag":240,"props":332,"children":333},{},[334],{"type":192,"value":335},"LLM 可以生成只包含需要字段的查询，减少无关字段进入上下文，直接降低 token 使用和噪音。",{"type":186,"tag":240,"props":337,"children":338},{},[339,341],{"type":192,"value":340},"中间层治理：\n",{"type":186,"tag":236,"props":342,"children":343},{},[344],{"type":186,"tag":240,"props":345,"children":346},{},[347],{"type":192,"value":348},"请求审计、访问控制、速率限制、字段级权限等可以集中落在 GraphQL 层，而不是把数据库直接暴露给模型。",{"type":186,"tag":229,"props":350,"children":352},{"id":351},"对上下文工程的具体帮助",[353],{"type":192,"value":351},{"type":186,"tag":236,"props":355,"children":356},{},[357,375,393],{"type":186,"tag":240,"props":358,"children":359},{},[360,362],{"type":192,"value":361},"降噪与控长：\n",{"type":186,"tag":236,"props":363,"children":364},{},[365,370],{"type":186,"tag":240,"props":366,"children":367},{},[368],{"type":192,"value":369},"相比一个返回大 JSON 的 REST 端点，GraphQL 查询允许精确控制返回字段；",{"type":186,"tag":240,"props":371,"children":372},{},[373],{"type":192,"value":374},"在 RAG / Tool Calling 环节，可以针对一个工具 Schema 只拉最关键的字段，便于 Prompt 设计和压缩。",{"type":186,"tag":240,"props":376,"children":377},{},[378,380],{"type":192,"value":379},"Schema 作为隐式「API 文档」：\n",{"type":186,"tag":236,"props":381,"children":382},{},[383,388],{"type":186,"tag":240,"props":384,"children":385},{},[386],{"type":192,"value":387},"LLM 可以从 introspection 或预置 Schema 文本中自动构造查询，而不是依赖额外人类文档；",{"type":186,"tag":240,"props":389,"children":390},{},[391],{"type":192,"value":392},"对 Agent 类场景，模型可以动态探索 Schema 能力，而非硬编码所有 endpoint 组合。",{"type":186,"tag":240,"props":394,"children":395},{},[396,398],{"type":192,"value":397},"结构化关系推理：\n",{"type":186,"tag":236,"props":399,"children":400},{},[401],{"type":186,"tag":240,"props":402,"children":403},{},[404],{"type":192,"value":405},"实体间的一对多、多对多关系对 LLM 是显式可见的，便于构造跨实体的业务查询，而不用通过多轮 REST 调用\"猜\"关系。",{"type":186,"tag":222,"props":407,"children":409},{"id":408},"问题与风险graphql-llm-带来的新挑战",[410],{"type":192,"value":411},"问题与风险：GraphQL + LLM 带来的新挑战",{"type":186,"tag":229,"props":413,"children":415},{"id":414},"schema-设计成为瓶颈",[416],{"type":192,"value":417},"Schema 设计成为瓶颈",{"type":186,"tag":236,"props":419,"children":420},{},[421,444],{"type":186,"tag":240,"props":422,"children":423},{},[424,426],{"type":192,"value":425},"该模式强依赖于：\n",{"type":186,"tag":236,"props":427,"children":428},{},[429,434,439],{"type":186,"tag":240,"props":430,"children":431},{},[432],{"type":192,"value":433},"良好建模的类型体系；",{"type":186,"tag":240,"props":435,"children":436},{},[437],{"type":192,"value":438},"有语义的字段/类型命名；",{"type":186,"tag":240,"props":440,"children":441},{},[442],{"type":192,"value":443},"合理的嵌套与关系设计。",{"type":186,"tag":240,"props":445,"children":446},{},[447,449],{"type":192,"value":448},"典型风险：\n",{"type":186,"tag":236,"props":450,"children":451},{},[452,457,462],{"type":186,"tag":240,"props":453,"children":454},{},[455],{"type":192,"value":456},"过度通用或「面向前端 UI」的 Schema，让 LLM 很难推理字段用途；",{"type":186,"tag":240,"props":458,"children":459},{},[460],{"type":192,"value":461},"深度嵌套、过度抽象的类型层级增加模型导航难度；",{"type":186,"tag":240,"props":463,"children":464},{},[465],{"type":192,"value":466},"业务概念命名混乱时，模型可能选择错误实体/字段，引入逻辑错误而非语法错误。",{"type":186,"tag":195,"props":468,"children":469},{},[470],{"type":192,"value":471},"换言之，人类难以一眼看懂的 Schema，LLM 通常也难以正确使用，这一点在原文中特别被点出。",{"type":186,"tag":229,"props":473,"children":475},{"id":474},"安全与-dos-向量",[476],{"type":192,"value":477},"安全与 DoS 向量",{"type":186,"tag":236,"props":479,"children":480},{},[481,499],{"type":186,"tag":240,"props":482,"children":483},{},[484,486],{"type":192,"value":485},"动态查询能力同时带来：\n",{"type":186,"tag":236,"props":487,"children":488},{},[489,494],{"type":186,"tag":240,"props":490,"children":491},{},[492],{"type":192,"value":493},"深度嵌套查询、巨型响应对象导致后端负载飙升；",{"type":186,"tag":240,"props":495,"children":496},{},[497],{"type":192,"value":498},"恶意或错误构造的查询可能放大成本，形成 DoS 风险。",{"type":186,"tag":240,"props":500,"children":501},{},[502,504],{"type":192,"value":503},"在 LLM 场景中：\n",{"type":186,"tag":236,"props":505,"children":506},{},[507,512],{"type":186,"tag":240,"props":508,"children":509},{},[510],{"type":192,"value":511},"即便用户是\"善意\"的，LLM 生成的查询也可能组合出代价极高的路径（例如全表扫描 + 多层关联）。",{"type":186,"tag":240,"props":513,"children":514},{},[515],{"type":192,"value":516},"将 LLM 视为「不可信客户端」更为安全：需要限制其可用的字段、嵌套深度、分页大小。",{"type":186,"tag":229,"props":518,"children":520},{"id":519},"graphql-自身的老问题缓存与版本控制",[521],{"type":192,"value":522},"GraphQL 自身的老问题：缓存与版本控制",{"type":186,"tag":236,"props":524,"children":525},{},[526,544],{"type":186,"tag":240,"props":527,"children":528},{},[529,531],{"type":192,"value":530},"缓存：\n",{"type":186,"tag":236,"props":532,"children":533},{},[534,539],{"type":186,"tag":240,"props":535,"children":536},{},[537],{"type":192,"value":538},"GET/POST 混用、单一端点、复杂请求体，使传统基于 URL 的边缘缓存方案变得困难；",{"type":186,"tag":240,"props":540,"children":541},{},[542],{"type":192,"value":543},"在 LLM 高频调用场景中，如果没有策略性缓存，后台压力容易放大。",{"type":186,"tag":240,"props":545,"children":546},{},[547,549],{"type":192,"value":548},"版本控制：\n",{"type":186,"tag":236,"props":550,"children":551},{},[552,557],{"type":186,"tag":240,"props":553,"children":554},{},[555],{"type":192,"value":556},"GraphQL 传统主张「无版本、Schema 演进」，依赖字段弃用（deprecation）而非 v2/v3；",{"type":186,"tag":240,"props":558,"children":559},{},[560],{"type":192,"value":561},"但 LLM 通常会「记住」早期示例或旧 Schema，如果演进管理不当，可能继续生成已弃用字段，造成错误调用。",{"type":186,"tag":222,"props":563,"children":565},{"id":564},"与传统模式的对比与演进方向",[566],{"type":192,"value":564},{"type":186,"tag":229,"props":568,"children":570},{"id":569},"rest-sql-graphql-的定位对比",[571],{"type":192,"value":572},"REST / SQL / GraphQL 的定位对比",{"type":186,"tag":236,"props":574,"children":575},{},[576,594,612],{"type":186,"tag":240,"props":577,"children":578},{},[579,581],{"type":192,"value":580},"直接 SQL：\n",{"type":186,"tag":236,"props":582,"children":583},{},[584,589],{"type":186,"tag":240,"props":585,"children":586},{},[587],{"type":192,"value":588},"优点：最大灵活性、直接访问数据；",{"type":186,"tag":240,"props":590,"children":591},{},[592],{"type":192,"value":593},"缺点：安全风险大、易被注入、难治理，对 LLM 几乎不可接受作为直接外部接口。",{"type":186,"tag":240,"props":595,"children":596},{},[597,599],{"type":192,"value":598},"REST：\n",{"type":186,"tag":236,"props":600,"children":601},{},[602,607],{"type":186,"tag":240,"props":603,"children":604},{},[605],{"type":192,"value":606},"优点：缓存友好、易于面向具体用例建模；",{"type":186,"tag":240,"props":608,"children":609},{},[610],{"type":192,"value":611},"缺点：为每个新 LLM 用例加 endpoint 成本很高，且通常粒度不匹配 LLM 的动态数据组合需求。",{"type":186,"tag":240,"props":613,"children":614},{},[615,617],{"type":192,"value":616},"GraphQL：\n",{"type":186,"tag":236,"props":618,"children":619},{},[620],{"type":186,"tag":240,"props":621,"children":622},{},[623,625],{"type":192,"value":624},"在安全和灵活性之间提供中间点：\n",{"type":186,"tag":236,"props":626,"children":627},{},[628,633],{"type":186,"tag":240,"props":629,"children":630},{},[631],{"type":192,"value":632},"不暴露数据库内部细节；",{"type":186,"tag":240,"props":634,"children":635},{},[636],{"type":192,"value":637},"又允许 LLM 按需组合数据、做 schema-aware 查询。",{"type":186,"tag":229,"props":639,"children":641},{"id":640},"典型演进路线",[642],{"type":192,"value":640},{"type":186,"tag":195,"props":644,"children":645},{},[646],{"type":192,"value":647},"在已有 REST/数据库生态的团队中，较现实的演进路线通常是：",{"type":186,"tag":649,"props":650,"children":651},"ol",{},[652],{"type":186,"tag":240,"props":653,"children":654},{},[655],{"type":192,"value":656},"针对 LLM 使用场景，收口出一层「LLM Data Gateway」：",{"type":186,"tag":236,"props":658,"children":659},{},[660],{"type":186,"tag":240,"props":661,"children":662},{},[663],{"type":192,"value":664},"选用 GraphQL 作为统一模式，而不是让 LLM 调用大量异构 REST。",{"type":186,"tag":649,"props":666,"children":668},{"start":667},2,[669],{"type":186,"tag":240,"props":670,"children":671},{},[672],{"type":192,"value":673},"初始阶段只暴露相对稳定的领域（例如只读业务数据）：",{"type":186,"tag":236,"props":675,"children":676},{},[677],{"type":186,"tag":240,"props":678,"children":679},{},[680],{"type":192,"value":681},"避免一开始就覆盖高风险的写操作和状态变更。",{"type":186,"tag":649,"props":683,"children":685},{"start":684},3,[686],{"type":186,"tag":240,"props":687,"children":688},{},[689],{"type":192,"value":690},"在成型后逐步：",{"type":186,"tag":236,"props":692,"children":693},{},[694,699,704],{"type":186,"tag":240,"props":695,"children":696},{},[697],{"type":192,"value":698},"统一命名与 Schema 设计规范；",{"type":186,"tag":240,"props":700,"children":701},{},[702],{"type":192,"value":703},"将更多内部服务接入这层中台；",{"type":186,"tag":240,"props":705,"children":706},{},[707],{"type":192,"value":708},"对 Agent / Workflow 场景提供基于 Schema 的工具调用描述。",{"type":186,"tag":222,"props":710,"children":712},{"id":711},"系统级影响对架构与工程效率的作用",[713],{"type":192,"value":714},"系统级影响：对架构与工程效率的作用",{"type":186,"tag":229,"props":716,"children":718},{"id":717},"对整体架构的影响",[719],{"type":192,"value":717},{"type":186,"tag":236,"props":721,"children":722},{},[723,741],{"type":186,"tag":240,"props":724,"children":725},{},[726,728],{"type":192,"value":727},"API 层抽象重心右移：\n",{"type":186,"tag":236,"props":729,"children":730},{},[731,736],{"type":186,"tag":240,"props":732,"children":733},{},[734],{"type":192,"value":735},"GraphQL 由原本偏前端聚合层，变成「LLM/Agent 专用数据平面」；",{"type":186,"tag":240,"props":737,"children":738},{},[739],{"type":192,"value":740},"可能需要与现有 BFF 分层、API Gateway、Service Mesh 等组件重新划分职责。",{"type":186,"tag":240,"props":742,"children":743},{},[744,746],{"type":192,"value":745},"统一数据访问规范：\n",{"type":186,"tag":236,"props":747,"children":748},{},[749,754],{"type":186,"tag":240,"props":750,"children":751},{},[752],{"type":192,"value":753},"长期有助于减少曾经为各个业务线 / 前端定制的碎片化 REST；",{"type":186,"tag":240,"props":755,"children":756},{},[757],{"type":192,"value":758},"但也可能带来「大而全 Schema」的风险，弱化领域边界。",{"type":186,"tag":229,"props":760,"children":762},{"id":761},"对工程效率与协作的影响",[763],{"type":192,"value":761},{"type":186,"tag":236,"props":765,"children":766},{},[767,785],{"type":186,"tag":240,"props":768,"children":769},{},[770,772],{"type":192,"value":771},"提升：\n",{"type":186,"tag":236,"props":773,"children":774},{},[775,780],{"type":186,"tag":240,"props":776,"children":777},{},[778],{"type":192,"value":779},"后端团队不用为每个 LLM 用例反复加 endpoint，只要 Schema 足够通用；",{"type":186,"tag":240,"props":781,"children":782},{},[783],{"type":192,"value":784},"架构师可以通过 Schema 设计\"规划\"可被模型使用的数据边界。",{"type":186,"tag":240,"props":786,"children":787},{},[788,790],{"type":192,"value":789},"新负担：\n",{"type":186,"tag":236,"props":791,"children":792},{},[793,798],{"type":186,"tag":240,"props":794,"children":795},{},[796],{"type":192,"value":797},"需要明确谁负责 Schema 设计和演进：是领域团队、平台团队还是专门的「API 设计委员会」；",{"type":186,"tag":240,"props":799,"children":800},{},[801],{"type":192,"value":802},"测试策略要覆盖「模型生成 GraphQL 查询」这一层，而非只测单个 resolver。",{"type":186,"tag":222,"props":804,"children":806},{"id":805},"落地建议如何谨慎试点与扩展",[807],{"type":192,"value":808},"落地建议：如何谨慎试点与扩展",{"type":186,"tag":229,"props":810,"children":812},{"id":811},"适用与不适用的场景",[813],{"type":192,"value":811},{"type":186,"tag":195,"props":815,"children":816},{},[817],{"type":192,"value":818},"更适合：",{"type":186,"tag":236,"props":820,"children":821},{},[822,827,832],{"type":186,"tag":240,"props":823,"children":824},{},[825],{"type":192,"value":826},"有多个业务系统、数据源，需要统一被 LLM/Agent 访问的中大型组织；",{"type":186,"tag":240,"props":828,"children":829},{},[830],{"type":192,"value":831},"已有 GraphQL 经验或前端 GraphQL BFF，可扩展为「LLM 数据网关」；",{"type":186,"tag":240,"props":833,"children":834},{},[835],{"type":192,"value":836},"LLM 需求以「读多写少」为主，大量是查询、分析、汇总类任务。",{"type":186,"tag":195,"props":838,"children":839},{},[840],{"type":192,"value":841},"相对不适合直接上：",{"type":186,"tag":236,"props":843,"children":844},{},[845,850],{"type":186,"tag":240,"props":846,"children":847},{},[848],{"type":192,"value":849},"数据域强依赖复杂事务写操作、强一致性，且变更语义复杂；",{"type":186,"tag":240,"props":851,"children":852},{},[853],{"type":192,"value":854},"目前对 GraphQL 运维、缓存、安全控制没有任何经验的小团队，直接为 LLM 搭这层可能超负荷。",{"type":186,"tag":229,"props":856,"children":858},{"id":857},"实施要点与防坑建议",[859],{"type":192,"value":857},{"type":186,"tag":649,"props":861,"children":862},{},[863],{"type":186,"tag":240,"props":864,"children":865},{},[866],{"type":192,"value":867},"从只读、低风险域开始",{"type":186,"tag":236,"props":869,"children":870},{},[871,889],{"type":186,"tag":240,"props":872,"children":873},{},[874,876],{"type":192,"value":875},"首批 Schema 只暴露：\n",{"type":186,"tag":236,"props":877,"children":878},{},[879,884],{"type":186,"tag":240,"props":880,"children":881},{},[882],{"type":192,"value":883},"读操作，且带严格分页与过滤限制；",{"type":186,"tag":240,"props":885,"children":886},{},[887],{"type":192,"value":888},"已有清晰领域模型的实体；",{"type":186,"tag":240,"props":890,"children":891},{},[892,894],{"type":192,"value":893},"避免直接暴露：\n",{"type":186,"tag":236,"props":895,"children":896},{},[897,902],{"type":186,"tag":240,"props":898,"children":899},{},[900],{"type":192,"value":901},"高敏感数据；",{"type":186,"tag":240,"props":903,"children":904},{},[905],{"type":192,"value":906},"写操作和批量变更；如必须暴露，优先用强语义的 mutation 而不是「通用写接口」。",{"type":186,"tag":649,"props":908,"children":909},{"start":667},[910],{"type":186,"tag":240,"props":911,"children":912},{},[913],{"type":192,"value":914},"把「Schema 可读性」当一等公民",{"type":186,"tag":236,"props":916,"children":917},{},[918,931],{"type":186,"tag":240,"props":919,"children":920},{},[921,923],{"type":192,"value":922},"命名规范：\n",{"type":186,"tag":236,"props":924,"children":925},{},[926],{"type":186,"tag":240,"props":927,"children":928},{},[929],{"type":192,"value":930},"类型、字段使用业务语义清晰的英文名，避免缩写和「技术内脏」命名；",{"type":186,"tag":240,"props":932,"children":933},{},[934,936],{"type":192,"value":935},"结构控制：\n",{"type":186,"tag":236,"props":937,"children":938},{},[939,944],{"type":186,"tag":240,"props":940,"children":941},{},[942],{"type":192,"value":943},"限制嵌套深度，避免在单个类型下挂过多异质字段；",{"type":186,"tag":240,"props":945,"children":946},{},[947],{"type":192,"value":948},"把难以解释的多义字段拆开，让 LLM 更容易区分用途。",{"type":186,"tag":649,"props":950,"children":951},{"start":684},[952],{"type":186,"tag":240,"props":953,"children":954},{},[955],{"type":192,"value":956},"加强资源与安全防护",{"type":186,"tag":236,"props":958,"children":959},{},[960,983],{"type":186,"tag":240,"props":961,"children":962},{},[963,965],{"type":192,"value":964},"对 LLM 客户端启用：\n",{"type":186,"tag":236,"props":966,"children":967},{},[968,973,978],{"type":186,"tag":240,"props":969,"children":970},{},[971],{"type":192,"value":972},"查询复杂度限制（例如按字段数、嵌套层级、预估行数计费）；",{"type":186,"tag":240,"props":974,"children":975},{},[976],{"type":192,"value":977},"严格的分页（最大 $$\\text{limit}$$）和超时；",{"type":186,"tag":240,"props":979,"children":980},{},[981],{"type":192,"value":982},"字段级权限控制和审计日志。",{"type":186,"tag":240,"props":984,"children":985},{},[986,988],{"type":192,"value":987},"在平台层做：\n",{"type":186,"tag":236,"props":989,"children":990},{},[991,996],{"type":186,"tag":240,"props":992,"children":993},{},[994],{"type":192,"value":995},"对高成本查询增加人工审核或灰度字段开关；",{"type":186,"tag":240,"props":997,"children":998},{},[999],{"type":192,"value":1000},"持续采集查询模式，识别模型生成的「反模式查询」。",{"type":186,"tag":649,"props":1002,"children":1004},{"start":1003},4,[1005],{"type":186,"tag":240,"props":1006,"children":1007},{},[1008],{"type":192,"value":1009},"针对 LLM 做专用 Schema 与 Prompt 设计",{"type":186,"tag":236,"props":1011,"children":1012},{},[1013,1026],{"type":186,"tag":240,"props":1014,"children":1015},{},[1016,1018],{"type":192,"value":1017},"避免直接把面向前端的 Schema 暴露给 LLM：\n",{"type":186,"tag":236,"props":1019,"children":1020},{},[1021],{"type":186,"tag":240,"props":1022,"children":1023},{},[1024],{"type":192,"value":1025},"可以视情况设计「LLM 专用子 Schema」或命名空间，只保留对推理友好的实体与字段。",{"type":186,"tag":240,"props":1027,"children":1028},{},[1029,1031],{"type":192,"value":1030},"在系统提示 / 工具定义中：\n",{"type":186,"tag":236,"props":1032,"children":1033},{},[1034,1039],{"type":186,"tag":240,"props":1035,"children":1036},{},[1037],{"type":192,"value":1038},"明确示例查询；",{"type":186,"tag":240,"props":1040,"children":1041},{},[1042],{"type":192,"value":1043},"指导模型使用特定过滤条件、分页策略，减少无界扩展。",{"type":186,"tag":649,"props":1045,"children":1047},{"start":1046},5,[1048],{"type":186,"tag":240,"props":1049,"children":1050},{},[1051],{"type":192,"value":1052},"规划 Schema 演进策略",{"type":186,"tag":236,"props":1054,"children":1055},{},[1056,1069],{"type":186,"tag":240,"props":1057,"children":1058},{},[1059,1061],{"type":192,"value":1060},"在演进前：\n",{"type":186,"tag":236,"props":1062,"children":1063},{},[1064],{"type":186,"tag":240,"props":1065,"children":1066},{},[1067],{"type":192,"value":1068},"记录当前 Schema 的示例查询和最佳实践，为后续迁移 Prompt 提供基础；",{"type":186,"tag":240,"props":1070,"children":1071},{},[1072,1074],{"type":192,"value":1073},"变更时：\n",{"type":186,"tag":236,"props":1075,"children":1076},{},[1077],{"type":186,"tag":240,"props":1078,"children":1079},{},[1080],{"type":192,"value":1081},"对旧字段保持一段时间的兼容，并在系统层捕获模型对已弃用字段的使用，便于调整提示或更新工具定义。",{"type":186,"tag":195,"props":1083,"children":1084},{},[1085],{"type":192,"value":1086},"整体来看，把 GraphQL 作为 LLM 的数据访问模式，是一种在安全、灵活与上下文质量之间取得平衡的实践方向。它并不是银弹：成功与否高度依赖于 Schema 质量、治理能力与安全/资源控制。如果团队本身已有 GraphQL 能力，并且正面临「LLM 如何安全访问多源结构化数据」的问题，那么围绕一个小而清晰的领域试点，是较为稳妥的切入点。",{"title":178,"searchDepth":667,"depth":667,"links":1088},[1089,1090],{"id":189,"depth":667,"text":193},{"id":217,"depth":667,"text":220,"children":1091},[1092,1093,1094,1095,1096,1097],{"id":224,"depth":684,"text":227},{"id":275,"depth":684,"text":275},{"id":408,"depth":684,"text":411},{"id":564,"depth":684,"text":564},{"id":711,"depth":684,"text":714},{"id":805,"depth":684,"text":808},"markdown","content:6.maps:_database:graphql:graphql-for-llm.md","content","6.maps/_database/graphql/graphql-for-llm.md","6.maps/_database/graphql/graphql-for-llm","md",[1105,1109],{"_path":1106,"title":1107,"description":1108},"/maps/_database/graphql/graphql","GraphQL","一种用于 API 的查询语言和运行时环境，允许客户端精确地请求所需的数据，从而提高数据获取的效率和灵活性。",{"_path":1110,"title":1111,"description":1112},"/maps/_database/lakehouse/delta-sharing","Delta Sharing：跨平台安全数据共享的开放协议（Trial）","以开放协议在多云与本地间共享“在线数据”，集中治理与审计，避免复制；但须管控跨云外网成本。",1772504929031]