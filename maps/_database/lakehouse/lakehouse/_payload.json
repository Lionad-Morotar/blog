,"props":658,"children":659},{},[660],{"type":188,"value":661},"大数据离线分析、OLAP、云数仓",{"type":182,"tag":409,"props":663,"children":664},{},[665],{"type":188,"value":666},"Hive/Spark OLAP 场景",{"type":182,"tag":409,"props":668,"children":669},{},[670],{"type":188,"value":671},"分布式消息、跨服务数据交换",{"type":182,"tag":366,"props":673,"children":674},{},[675,683,688,693,697],{"type":182,"tag":409,"props":676,"children":677},{},[678],{"type":182,"tag":226,"props":679,"children":680},{},[681],{"type":188,"value":682},"ACID 事务 / 更新能力",{"type":182,"tag":409,"props":684,"children":685},{},[686],{"type":188,"value":687},"原生支持",{"type":182,"tag":409,"props":689,"children":690},{},[691],{"type":188,"value":692},"无（需第三方表格式或管理层）",{"type":182,"tag":409,"props":694,"children":695},{},[696],{"type":188,"value":692},{"type":182,"tag":409,"props":698,"children":699},{},[700],{"type":188,"value":701},"无（主要是行级序列化）",{"type":182,"tag":366,"props":703,"children":704},{},[705,713,718,723,727],{"type":182,"tag":409,"props":706,"children":707},{},[708],{"type":182,"tag":226,"props":709,"children":710},{},[711],{"type":188,"value":712},"实时/流式数据支持",{"type":182,"tag":409,"props":714,"children":715},{},[716],{"type":188,"value":717},"原生支持，对 Flink 有深度优化",{"type":182,"tag":409,"props":719,"children":720},{},[721],{"type":188,"value":722},"不直接支持，需要额外框架封装",{"type":182,"tag":409,"props":724,"children":725},{},[726],{"type":188,"value":722},{"type":182,"tag":409,"props":728,"children":729},{},[730],{"type":188,"value":731},"常用于消息流，但无列式存储优势",{"type":182,"tag":366,"props":733,"children":734},{},[735,743,748,753,758],{"type":182,"tag":409,"props":736,"children":737},{},[738],{"type":182,"tag":226,"props":739,"children":740},{},[741],{"type":188,"value":742},"生态与兼容性",{"type":182,"tag":409,"props":744,"children":745},{},[746],{"type":188,"value":747},"成熟度上升中，与 Flink 紧密结合",{"type":182,"tag":409,"props":749,"children":750},{},[751],{"type":188,"value":752},"非常成熟，Spark/Hive/Presto 等均支持",{"type":182,"tag":409,"props":754,"children":755},{},[756],{"type":188,"value":757},"主要在 Hadoop/Hive/Tez/Spark 等生态",{"type":182,"tag":409,"props":759,"children":760},{},[761],{"type":188,"value":762},"与 Kafka/Schema Registry 兼容性佳",{"type":182,"tag":366,"props":764,"children":765},{},[766,774,779,784,788],{"type":182,"tag":409,"props":767,"children":768},{},[769],{"type":182,"tag":226,"props":770,"children":771},{},[772],{"type":188,"value":773},"适用数据规模",{"type":182,"tag":409,"props":775,"children":776},{},[777],{"type":188,"value":778},"TB ~ PB 级，实时 & 离线融合",{"type":182,"tag":409,"props":780,"children":781},{},[782],{"type":188,"value":783},"TB ~ PB 级，主要面向批处理",{"type":182,"tag":409,"props":785,"children":786},{},[787],{"type":188,"value":783},{"type":182,"tag":409,"props":789,"children":790},{},[791],{"type":188,"value":792},"MB ~ GB 级，消息或中小规模数据",{"type":182,"tag":366,"props":794,"children":795},{},[796,804,809,814,819],{"type":182,"tag":409,"props":797,"children":798},{},[799],{"type":182,"tag":226,"props":800,"children":801},{},[802],{"type":188,"value":803},"谓词下推 / 索引",{"type":182,"tag":409,"props":805,"children":806},{},[807],{"type":188,"value":808},"内置索引机制，支持高并发写入",{"type":182,"tag":409,"props":810,"children":811},{},[812],{"type":188,"value":813},"支持列级统计与谓词下推",{"type":182,"tag":409,"props":815,"children":816},{},[817],{"type":188,"value":818},"强大的谓词下推与统计信息",{"type":182,"tag":409,"props":820,"children":821},{},[822],{"type":188,"value":823},"无列式谓词下推",{"type":182,"tag":212,"props":825,"children":827},{"id":826},"ai-agent-怎么利用-lakehouse-里面的数据",[828],{"type":188,"value":829},"AI Agent 怎么利用 Lakehouse 里面的数据？",{"type":182,"tag":547,"props":831,"children":832},{},[833],{"type":188,"value":834},"通用做法是多模态数据放到 OSS，结构化数据放数仓。但就链路细节上而言目前还不是很成熟。",{"type":182,"tag":191,"props":836,"children":837},{},[838,843,848],{"type":182,"tag":195,"props":839,"children":840},{},[841],{"type":188,"value":842},"对非结构化数据的量的占比较大，甚至达到 80% 以上。",{"type":182,"tag":195,"props":844,"children":845},{},[846],{"type":188,"value":847},"目前观察到的是对大量元数据实时的请求、解析受到挑战。探索方向仍处于聚合、预聚合和如何利用缓存。",{"type":182,"tag":195,"props":849,"children":850},{},[851],{"type":188,"value":852},"如何高效检索非结构化数据。",{"type":182,"tag":212,"props":854,"children":856},{"id":855},"paimon-logsystem-时数据新鲜度分析",[857],{"type":188,"value":858},"Paimon + LogSystem 时数据新鲜度分析？",{"type":182,"tag":547,"props":860,"children":861},{},[862],{"type":188,"value":863},"分钟级新鲜度。秒级新鲜度可选择 Kafka + 流存储。",{"type":182,"tag":547,"props":865,"children":866},{},[867],{"type":188,"value":868},"Paimon 在流式更新的同时，仍然保证数据一致性。由于实时不断写入小文件不可避免。Paimon 提供了小文件合并（Compaction）功能，用于周期性合并文件，避免数据查询时过多文件带来的延迟。在实际生产环境中，一般会设定一个合并周期（例如几分钟或更长），在保证最新数据能被快速查询的同时，又兼顾查询性能。如果要求极致的实时性，可适当缩短合并周期，但要平衡对写入性能和资源消耗的影响。",{"type":182,"tag":212,"props":870,"children":872},{"id":871},"湖仓常见的数据分层方式",[873],{"type":188,"value":874},"湖仓常见的数据分层方式？",{"type":182,"tag":219,"props":876,"children":877},{},[878],{"type":182,"tag":195,"props":879,"children":880},{},[881],{"type":182,"tag":226,"props":882,"children":883},{},[884],{"type":188,"value":885},"ODS（Operational Data Store） / 原始层",{"type":182,"tag":191,"props":887,"children":888},{},[889,894],{"type":182,"tag":195,"props":890,"children":891},{},[892],{"type":188,"value":893},"存放原始数据，通常与源系统保持一致或仅做简单的去重、清洗。",{"type":182,"tag":195,"props":895,"children":896},{},[897],{"type":188,"value":898},"特点：保持冗余和完整，保证数据的新鲜度，方便后续处理时“回溯”。",{"type":182,"tag":219,"props":900,"children":901},{"start":248},[902],{"type":182,"tag":195,"props":903,"children":904},{},[905],{"type":182,"tag":226,"props":906,"children":907},{},[908],{"type":188,"value":909},"DWD（Data Warehouse Detail） / 明细层",{"type":182,"tag":191,"props":911,"children":912},{},[913,918],{"type":182,"tag":195,"props":914,"children":915},{},[916],{"type":188,"value":917},"在原始数据的基础上进行标准化、去重、关联、补充字段等处理，主要保持“明细级”的完整信息。",{"type":182,"tag":195,"props":919,"children":920},{},[921],{"type":188,"value":922},"特点：数据质量更高，表结构优化，适合详细分析或为上层聚合提供基础。",{"type":182,"tag":219,"props":924,"children":925},{"start":269},[926],{"type":182,"tag":195,"props":927,"children":928},{},[929],{"type":182,"tag":226,"props":930,"children":931},{},[932],{"type":188,"value":933},"DWS（Data Warehouse Summary） / 汇总层",{"type":182,"tag":191,"props":935,"children":936},{},[937,942],{"type":182,"tag":195,"props":938,"children":939},{},[940],{"type":188,"value":941},"将明细层的数据按照一定主题或指标进行聚合、汇总。",{"type":182,"tag":195,"props":943,"children":944},{},[945],{"type":188,"value":946},"特点：进一步降低数据粒度，高效支持常见的聚合查询、指标分析等。",{"type":182,"tag":219,"props":948,"children":949},{"start":290},[950],{"type":182,"tag":195,"props":951,"children":952},{},[953],{"type":182,"tag":226,"props":954,"children":955},{},[956],{"type":188,"value":957},"ADS（Application Data Store） / 应用层",{"type":182,"tag":191,"props":959,"children":960},{},[961,966],{"type":182,"tag":195,"props":962,"children":963},{},[964],{"type":188,"value":965},"面向特定应用或报表需求，对数据进行定制化加工，通常是对特定主题或指标的深度加工或计算结果。",{"type":182,"tag":195,"props":967,"children":968},{},[969],{"type":188,"value":970},"特点：业务访问速度快、查询逻辑简单，但一般复用性较低。",{"type":182,"tag":219,"props":972,"children":973},{"start":311},[974],{"type":182,"tag":195,"props":975,"children":976},{},[977],{"type":182,"tag":226,"props":978,"children":979},{},[980],{"type":188,"value":981},"DIM（Dimension Table） / 维表层",{"type":182,"tag":191,"props":983,"children":984},{},[985,990],{"type":182,"tag":195,"props":986,"children":987},{},[988],{"type":188,"value":989},"存放企业常用的维度或参考表，例如用户信息维表、商品信息维表、地理区域维表等。",{"type":182,"tag":195,"props":991,"children":992},{},[993],{"type":188,"value":994},"特点：在各个层的 ETL 过程中被频繁连接或关联，用于补充或映射数据属性。",{"type":182,"tag":219,"props":996,"children":997},{"start":332},[998],{"type":182,"tag":195,"props":999,"children":1000},{},[1001],{"type":182,"tag":226,"props":1002,"children":1003},{},[1004],{"type":188,"value":1005},"DM（Data Mart） / 数据集市层",{"type":182,"tag":191,"props":1007,"children":1008},{},[1009],{"type":182,"tag":195,"props":1010,"children":1011},{},[1012],{"type":188,"value":1013},"有些企业还会将面向特定部门或特定业务主题的数据称为“数据集市”。与 ADS 类似，主要服务于某类精细化分析或应用。",{"type":182,"tag":547,"props":1015,"children":1016},{},[1017],{"type":188,"value":1018},"实际应用场景：",{"type":182,"tag":219,"props":1020,"children":1021},{},[1022],{"type":182,"tag":195,"props":1023,"children":1024},{},[1025],{"type":182,"tag":226,"props":1026,"children":1027},{},[1028],{"type":188,"value":1029},"离线分析与商业智能",{"type":182,"tag":191,"props":1031,"children":1032},{},[1033],{"type":182,"tag":195,"props":1034,"children":1035},{},[1036],{"type":188,"value":1037},"通过 ODS → DWD → DWS → ADS 的方式，先保证原始数据的完整性，然后逐层进行聚合，在应用层直接服务于 BI 报表、管理仪表盘等。",{"type":182,"tag":219,"props":1039,"children":1040},{"start":248},[1041],{"type":182,"tag":195,"props":1042,"children":1043},{},[1044],{"type":182,"tag":226,"props":1045,"children":1046},{},[1047],{"type":188,"value":1048},"实时数据分析",{"type":182,"tag":191,"props":1050,"children":1051},{},[1052,1057],{"type":182,"tag":195,"props":1053,"children":1054},{},[1055],{"type":188,"value":1056},"有些分层架构中会增加流数据的处理层（Streaming Layer），如存储在 Kafka、Flink 等流式平台，结合实时湖仓（如 Paimon、Kafka + Iceberg、Delta Lake 等）实现实时更新。",{"type":182,"tag":195,"props":1058,"children":1059},{},[1060],{"type":188,"value":1061},"分层思路同样适用，只不过在流处理场景下，数据处理频率更高、延迟更低。",{"type":182,"tag":219,"props":1063,"children":1064},{"start":269},[1065],{"type":182,"tag":195,"props":1066,"children":1067},{},[1068],{"type":182,"tag":226,"props":1069,"children":1070},{},[1071],{"type":188,"value":1072},"数据挖掘与机器学习",{"type":182,"tag":191,"props":1074,"children":1075},{},[1076,1081],{"type":182,"tag":195,"props":1077,"children":1078},{},[1079],{"type":188,"value":1080},"通过维度和事实数据的明细层（DWD）获取丰富、干净的特征数据，为机器学习训练集提供持续更新的基础；",{"type":182,"tag":195,"props":1082,"children":1083},{},[1084],{"type":188,"value":1085},"也可将挖掘后的结果或特征输出到应用层（ADS）或其他平台，供下游使用。",{"title":175,"searchDepth":248,"depth":248,"links":1087},[1088,1089],{"id":185,"depth":248,"text":189},{"id":207,"depth":248,"text":210},"markdown","content:6.maps:_database:lakehouse:lakehouse.md","content","6.maps/_database/lakehouse/lakehouse.md","6.maps/_database/lakehouse/lakehouse","md",[1097,1100],{"_path":201,"title":1098,"description":1099},"Delta Sharing：跨平台安全数据共享的开放协议（Trial）","以开放协议在多云与本地间共享“在线数据”，集中治理与审计，避免复制；但须管控跨云外网成本。",{"_path":1101,"title":1102,"description":1103},"/maps/_database/redis","Redis","About Redis",1771071677228]