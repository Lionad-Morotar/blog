 Parquet、Apache ORC 和 Avro，这些格式通常被广泛用于支持现代的数据架构，例如数据湖和 Lakehouse。作为开放标准，Open Format 需要保证标准化、平台无关、易于扩展和高性能等特性。",{"type":185,"tag":362,"props":567,"children":568},{},[569,612],{"type":185,"tag":366,"props":570,"children":571},{},[572],{"type":185,"tag":370,"props":573,"children":574},{},[575,580,588,596,604],{"type":185,"tag":374,"props":576,"children":577},{},[578],{"type":191,"value":579},"格式 / 特性",{"type":185,"tag":374,"props":581,"children":582},{},[583],{"type":185,"tag":230,"props":584,"children":585},{},[586],{"type":191,"value":587},"Apache Paimon",{"type":185,"tag":374,"props":589,"children":590},{},[591],{"type":185,"tag":230,"props":592,"children":593},{},[594],{"type":191,"value":595},"Apache Parquet",{"type":185,"tag":374,"props":597,"children":598},{},[599],{"type":185,"tag":230,"props":600,"children":601},{},[602],{"type":191,"value":603},"Apache ORC",{"type":185,"tag":374,"props":605,"children":606},{},[607],{"type":185,"tag":230,"props":608,"children":609},{},[610],{"type":191,"value":611},"Avro",{"type":185,"tag":406,"props":613,"children":614},{},[615,645,676,706,736,767,797],{"type":185,"tag":370,"props":616,"children":617},{},[618,626,631,636,640],{"type":185,"tag":413,"props":619,"children":620},{},[621],{"type":185,"tag":230,"props":622,"children":623},{},[624],{"type":191,"value":625},"存储方式",{"type":185,"tag":413,"props":627,"children":628},{},[629],{"type":191,"value":630},"表格式 （基于文件存储 + 索引）",{"type":185,"tag":413,"props":632,"children":633},{},[634],{"type":191,"value":635},"列式文件存储",{"type":185,"tag":413,"props":637,"children":638},{},[639],{"type":191,"value":635},{"type":185,"tag":413,"props":641,"children":642},{},[643],{"type":191,"value":644},"行式文件存储",{"type":185,"tag":370,"props":646,"children":647},{},[648,656,661,666,671],{"type":185,"tag":413,"props":649,"children":650},{},[651],{"type":185,"tag":230,"props":652,"children":653},{},[654],{"type":191,"value":655},"主要应用场景",{"type":185,"tag":413,"props":657,"children":658},{},[659],{"type":191,"value":660},"流批一体、实时数据湖/数仓，ACID 表管理",{"type":185,"tag":413,"props":662,"children":663},{},[664],{"type":191,"value":665},"大数据离线分析、OLAP、云数仓",{"type":185,"tag":413,"props":667,"children":668},{},[669],{"type":191,"value":670},"Hive/Spark OLAP 场景",{"type":185,"tag":413,"props":672,"children":673},{},[674],{"type":191,"value":675},"分布式消息、跨服务数据交换",{"type":185,"tag":370,"props":677,"children":678},{},[679,687,692,697,701],{"type":185,"tag":413,"props":680,"children":681},{},[682],{"type":185,"tag":230,"props":683,"children":684},{},[685],{"type":191,"value":686},"ACID 事务 / 更新能力",{"type":185,"tag":413,"props":688,"children":689},{},[690],{"type":191,"value":691},"原生支持",{"type":185,"tag":413,"props":693,"children":694},{},[695],{"type":191,"value":696},"无（需第三方表格式或管理层）",{"type":185,"tag":413,"props":698,"children":699},{},[700],{"type":191,"value":696},{"type":185,"tag":413,"props":702,"children":703},{},[704],{"type":191,"value":705},"无（主要是行级序列化）",{"type":185,"tag":370,"props":707,"children":708},{},[709,717,722,727,731],{"type":185,"tag":413,"props":710,"children":711},{},[712],{"type":185,"tag":230,"props":713,"children":714},{},[715],{"type":191,"value":716},"实时/流式数据支持",{"type":185,"tag":413,"props":718,"children":719},{},[720],{"type":191,"value":721},"原生支持，对 Flink 有深度优化",{"type":185,"tag":413,"props":723,"children":724},{},[725],{"type":191,"value":726},"不直接支持，需要额外框架封装",{"type":185,"tag":413,"props":728,"children":729},{},[730],{"type":191,"value":726},{"type":185,"tag":413,"props":732,"children":733},{},[734],{"type":191,"value":735},"常用于消息流，但无列式存储优势",{"type":185,"tag":370,"props":737,"children":738},{},[739,747,752,757,762],{"type":185,"tag":413,"props":740,"children":741},{},[742],{"type":185,"tag":230,"props":743,"children":744},{},[745],{"type":191,"value":746},"生态与兼容性",{"type":185,"tag":413,"props":748,"children":749},{},[750],{"type":191,"value":751},"成熟度上升中，与 Flink 紧密结合",{"type":185,"tag":413,"props":753,"children":754},{},[755],{"type":191,"value":756},"非常成熟，Spark/Hive/Presto 等均支持",{"type":185,"tag":413,"props":758,"children":759},{},[760],{"type":191,"value":761},"主要在 Hadoop/Hive/Tez/Spark 等生态",{"type":185,"tag":413,"props":763,"children":764},{},[765],{"type":191,"value":766},"与 Kafka/Schema Registry 兼容性佳",{"type":185,"tag":370,"props":768,"children":769},{},[770,778,783,788,792],{"type":185,"tag":413,"props":771,"children":772},{},[773],{"type":185,"tag":230,"props":774,"children":775},{},[776],{"type":191,"value":777},"适用数据规模",{"type":185,"tag":413,"props":779,"children":780},{},[781],{"type":191,"value":782},"TB ~ PB 级，实时 & 离线融合",{"type":185,"tag":413,"props":784,"children":785},{},[786],{"type":191,"value":787},"TB ~ PB 级，主要面向批处理",{"type":185,"tag":413,"props":789,"children":790},{},[791],{"type":191,"value":787},{"type":185,"tag":413,"props":793,"children":794},{},[795],{"type":191,"value":796},"MB ~ GB 级，消息或中小规模数据",{"type":185,"tag":370,"props":798,"children":799},{},[800,808,813,818,823],{"type":185,"tag":413,"props":801,"children":802},{},[803],{"type":185,"tag":230,"props":804,"children":805},{},[806],{"type":191,"value":807},"谓词下推 / 索引",{"type":185,"tag":413,"props":809,"children":810},{},[811],{"type":191,"value":812},"内置索引机制，支持高并发写入",{"type":185,"tag":413,"props":814,"children":815},{},[816],{"type":191,"value":817},"支持列级统计与谓词下推",{"type":185,"tag":413,"props":819,"children":820},{},[821],{"type":191,"value":822},"强大的谓词下推与统计信息",{"type":185,"tag":413,"props":824,"children":825},{},[826],{"type":191,"value":827},"无列式谓词下推",{"type":185,"tag":216,"props":829,"children":831},{"id":830},"ai-agent-怎么利用-lakehouse-里面的数据",[832],{"type":191,"value":833},"AI Agent 怎么利用 Lakehouse 里面的数据？",{"type":185,"tag":551,"props":835,"children":836},{},[837],{"type":191,"value":838},"通用做法是多模态数据放到 OSS，结构化数据放数仓。但就链路细节上而言目前还不是很成熟。",{"type":185,"tag":193,"props":840,"children":841},{},[842,847,852],{"type":185,"tag":197,"props":843,"children":844},{},[845],{"type":191,"value":846},"对非结构化数据的量的占比较大，甚至达到 80% 以上。",{"type":185,"tag":197,"props":848,"children":849},{},[850],{"type":191,"value":851},"目前观察到的是对大量元数据实时的请求、解析受到挑战。探索方向仍处于聚合、预聚合和如何利用缓存。",{"type":185,"tag":197,"props":853,"children":854},{},[855],{"type":191,"value":856},"如何高效检索非结构化数据。",{"type":185,"tag":216,"props":858,"children":860},{"id":859},"paimon-logsystem-时数据新鲜度分析",[861],{"type":191,"value":862},"Paimon + LogSystem 时数据新鲜度分析？",{"type":185,"tag":551,"props":864,"children":865},{},[866],{"type":191,"value":867},"分钟级新鲜度。秒级新鲜度可选择 Kafka + 流存储。",{"type":185,"tag":551,"props":869,"children":870},{},[871],{"type":191,"value":872},"Paimon 在流式更新的同时，仍然保证数据一致性。由于实时不断写入小文件不可避免。Paimon 提供了小文件合并（Compaction）功能，用于周期性合并文件，避免数据查询时过多文件带来的延迟。在实际生产环境中，一般会设定一个合并周期（例如几分钟或更长），在保证最新数据能被快速查询的同时，又兼顾查询性能。如果要求极致的实时性，可适当缩短合并周期，但要平衡对写入性能和资源消耗的影响。",{"type":185,"tag":216,"props":874,"children":876},{"id":875},"湖仓常见的数据分层方式",[877],{"type":191,"value":878},"湖仓常见的数据分层方式？",{"type":185,"tag":223,"props":880,"children":881},{},[882],{"type":185,"tag":197,"props":883,"children":884},{},[885],{"type":185,"tag":230,"props":886,"children":887},{},[888],{"type":191,"value":889},"ODS（Operational Data Store） / 原始层",{"type":185,"tag":193,"props":891,"children":892},{},[893,898],{"type":185,"tag":197,"props":894,"children":895},{},[896],{"type":191,"value":897},"存放原始数据，通常与源系统保持一致或仅做简单的去重、清洗。",{"type":185,"tag":197,"props":899,"children":900},{},[901],{"type":191,"value":902},"特点：保持冗余和完整，保证数据的新鲜度，方便后续处理时“回溯”。",{"type":185,"tag":223,"props":904,"children":905},{"start":252},[906],{"type":185,"tag":197,"props":907,"children":908},{},[909],{"type":185,"tag":230,"props":910,"children":911},{},[912],{"type":191,"value":913},"DWD（Data Warehouse Detail） / 明细层",{"type":185,"tag":193,"props":915,"children":916},{},[917,922],{"type":185,"tag":197,"props":918,"children":919},{},[920],{"type":191,"value":921},"在原始数据的基础上进行标准化、去重、关联、补充字段等处理，主要保持“明细级”的完整信息。",{"type":185,"tag":197,"props":923,"children":924},{},[925],{"type":191,"value":926},"特点：数据质量更高，表结构优化，适合详细分析或为上层聚合提供基础。",{"type":185,"tag":223,"props":928,"children":929},{"start":273},[930],{"type":185,"tag":197,"props":931,"children":932},{},[933],{"type":185,"tag":230,"props":934,"children":935},{},[936],{"type":191,"value":937},"DWS（Data Warehouse Summary） / 汇总层",{"type":185,"tag":193,"props":939,"children":940},{},[941,946],{"type":185,"tag":197,"props":942,"children":943},{},[944],{"type":191,"value":945},"将明细层的数据按照一定主题或指标进行聚合、汇总。",{"type":185,"tag":197,"props":947,"children":948},{},[949],{"type":191,"value":950},"特点：进一步降低数据粒度，高效支持常见的聚合查询、指标分析等。",{"type":185,"tag":223,"props":952,"children":953},{"start":294},[954],{"type":185,"tag":197,"props":955,"children":956},{},[957],{"type":185,"tag":230,"props":958,"children":959},{},[960],{"type":191,"value":961},"ADS（Application Data Store） / 应用层",{"type":185,"tag":193,"props":963,"children":964},{},[965,970],{"type":185,"tag":197,"props":966,"children":967},{},[968],{"type":191,"value":969},"面向特定应用或报表需求，对数据进行定制化加工，通常是对特定主题或指标的深度加工或计算结果。",{"type":185,"tag":197,"props":971,"children":972},{},[973],{"type":191,"value":974},"特点：业务访问速度快、查询逻辑简单，但一般复用性较低。",{"type":185,"tag":223,"props":976,"children":977},{"start":315},[978],{"type":185,"tag":197,"props":979,"children":980},{},[981],{"type":185,"tag":230,"props":982,"children":983},{},[984],{"type":191,"value":985},"DIM（Dimension Table） / 维表层",{"type":185,"tag":193,"props":987,"children":988},{},[989,994],{"type":185,"tag":197,"props":990,"children":991},{},[992],{"type":191,"value":993},"存放企业常用的维度或参考表，例如用户信息维表、商品信息维表、地理区域维表等。",{"type":185,"tag":197,"props":995,"children":996},{},[997],{"type":191,"value":998},"特点：在各个层的 ETL 过程中被频繁连接或关联，用于补充或映射数据属性。",{"type":185,"tag":223,"props":1000,"children":1001},{"start":336},[1002],{"type":185,"tag":197,"props":1003,"children":1004},{},[1005],{"type":185,"tag":230,"props":1006,"children":1007},{},[1008],{"type":191,"value":1009},"DM（Data Mart） / 数据集市层",{"type":185,"tag":193,"props":1011,"children":1012},{},[1013],{"type":185,"tag":197,"props":1014,"children":1015},{},[1016],{"type":191,"value":1017},"有些企业还会将面向特定部门或特定业务主题的数据称为“数据集市”。与 ADS 类似，主要服务于某类精细化分析或应用。",{"type":185,"tag":551,"props":1019,"children":1020},{},[1021],{"type":191,"value":1022},"实际应用场景：",{"type":185,"tag":223,"props":1024,"children":1025},{},[1026],{"type":185,"tag":197,"props":1027,"children":1028},{},[1029],{"type":185,"tag":230,"props":1030,"children":1031},{},[1032],{"type":191,"value":1033},"离线分析与商业智能",{"type":185,"tag":193,"props":1035,"children":1036},{},[1037],{"type":185,"tag":197,"props":1038,"children":1039},{},[1040],{"type":191,"value":1041},"通过 ODS → DWD → DWS → ADS 的方式，先保证原始数据的完整性，然后逐层进行聚合，在应用层直接服务于 BI 报表、管理仪表盘等。",{"type":185,"tag":223,"props":1043,"children":1044},{"start":252},[1045],{"type":185,"tag":197,"props":1046,"children":1047},{},[1048],{"type":185,"tag":230,"props":1049,"children":1050},{},[1051],{"type":191,"value":1052},"实时数据分析",{"type":185,"tag":193,"props":1054,"children":1055},{},[1056,1061],{"type":185,"tag":197,"props":1057,"children":1058},{},[1059],{"type":191,"value":1060},"有些分层架构中会增加流数据的处理层（Streaming Layer），如存储在 Kafka、Flink 等流式平台，结合实时湖仓（如 Paimon、Kafka + Iceberg、Delta Lake 等）实现实时更新。",{"type":185,"tag":197,"props":1062,"children":1063},{},[1064],{"type":191,"value":1065},"分层思路同样适用，只不过在流处理场景下，数据处理频率更高、延迟更低。",{"type":185,"tag":223,"props":1067,"children":1068},{"start":273},[1069],{"type":185,"tag":197,"props":1070,"children":1071},{},[1072],{"type":185,"tag":230,"props":1073,"children":1074},{},[1075],{"type":191,"value":1076},"数据挖掘与机器学习",{"type":185,"tag":193,"props":1078,"children":1079},{},[1080,1085],{"type":185,"tag":197,"props":1081,"children":1082},{},[1083],{"type":191,"value":1084},"通过维度和事实数据的明细层（DWD）获取丰富、干净的特征数据，为机器学习训练集提供持续更新的基础；",{"type":185,"tag":197,"props":1086,"children":1087},{},[1088],{"type":191,"value":1089},"也可将挖掘后的结果或特征输出到应用层（ADS）或其他平台，供下游使用。",{"title":178,"searchDepth":252,"depth":252,"links":1091},[1092,1093],{"id":188,"depth":252,"text":188},{"id":211,"depth":252,"text":214},"markdown","content:6.maps:_database:lakehouse:lakehouse.md","content","6.maps/_database/lakehouse/lakehouse.md","6.maps/_database/lakehouse/lakehouse","md",[1101,1105],{"_path":1102,"title":1103,"description":1104},"/maps/_database/lakehouse/delta-sharing","Delta Sharing：跨平台安全数据共享的开放协议（Trial）","以开放协议在多云与本地间共享“在线数据”，集中治理与审计，避免复制；但须管控跨云外网成本。",{"_path":1106,"title":1107,"description":1108},"/maps/_database/nosql/nosql","NoSQL","非关系型数据库技术，包括 Redis 缓存与数据结构",1772504903662]