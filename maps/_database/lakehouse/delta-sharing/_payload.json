[{"data":1,"prerenderedAt":625},["ShallowReactive",2],{"navigation":3,"/maps/_database/lakehouse/delta-sharing":170,"/maps/_database/lakehouse/delta-sharing-surround":616},[4,35,92,98,125,131,155,161],{"title":5,"_path":6,"children":7},"心流思绪 / Heart Flows","/flows",[8,11,14,17,20,23,26,29,32],{"title":9,"_path":10},"📕 狮子的书单推荐","/flows/books",{"title":12,"_path":13},"🚝 四十二篇系列","/flows/forty-two",{"title":15,"_path":16},"🌃 长夜梦","/flows/long-night-dream",{"title":18,"_path":19},"🌌 万物联结与幸福感","/flows/everything",{"title":21,"_path":22},"⌛ 偷取时间","/flows/stealing-time-from-god",{"title":24,"_path":25},"🌆 表达和孤独","/flows/expression-and-loneliness",{"title":27,"_path":28},"🌧️ 我的腼腆","/flows/shy",{"title":30,"_path":31},"🥛 新工作，喝新饮料","/flows/drinking-while-thinking",{"title":33,"_path":34},"📝 心流归档","/flows/archive",{"title":36,"_path":37,"children":38},"技术博客 / Coder","/articles",[39,41,44,47,50,53,56,59,62,65,68,71,74,77,80,83,86,89],{"title":40,"_path":37},"🦁 欢迎",{"title":42,"_path":43},"📦 一个简单有效的端口命名策略：","/articles/simple-naming-method",{"title":45,"_path":46},"🌪️ Tailwind v4 如何兼容预处理器","/articles/tailwind4-with-sass",{"title":48,"_path":49},"🥞 在 tailwind 中使用现代化 CSS Layers","/articles/tailwind-sass-and-css-layer",{"title":51,"_path":52},"💻 本地部署 Qwen 翻译网页","/articles/local-translator",{"title":54,"_path":55},"🧊 模板解析器轻考古","/articles/micro-templating",{"title":57,"_path":58},"Ⓜ️ Mini CSS Parser","/articles/mini-css-parser",{"title":60,"_path":61},"🚩 向AI咨询前端问题","/articles/use-gpt-learn-complex-frontend",{"title":63,"_path":64},"⛸️ 怎样定制复杂组件的自定义滚动条？","/articles/use-scrollbars",{"title":66,"_path":67},"⚖️ 统一多组件库的层叠顺序","/articles/zindex-manager",{"title":69,"_path":70},"🕷️ 滑动验证码破解思路","/articles/crack-the-slider",{"title":72,"_path":73},"🌟 探秘 CSS 光影效果","/articles/css-light-travel",{"title":75,"_path":76},"🍲 设计模式与 JS 魔法锅","/articles/design-patterns-and-js-magic-pot",{"title":78,"_path":79},"🌐 Anysort：灵活、优雅的多属性排序","/articles/anysort-2th",{"title":81,"_path":82},"💫 CSS 幻术 | 抗锯齿","/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133,"children":134},"造物 / Make","/tools",[135,137,140,143,146,149,152],{"title":136,"_path":133},"🧰 工具收集",{"title":138,"_path":139},"📕 博客","/tools/blog",{"title":141,"_path":142},"🥥 Coconut","/tools/coconut",{"title":144,"_path":145},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":147,"_path":148},"🌐 AnySort","/tools/anysort",{"title":150,"_path":151},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":153,"_path":154},"👓 Crapto","/tools/crypto-inline",{"title":156,"_path":157,"children":158},"我 / About","/hire",[159],{"title":160,"_path":157},"📬 技术简历",{"title":162,"_path":163,"children":164},"En","/en",[165],{"title":166,"_path":167,"children":168},"🦁 Welcome","/en/articles",[169],{"title":166,"_path":167},{"_path":171,"_dir":172,"_draft":173,"_partial":174,"_locale":175,"title":176,"description":177,"body":178,"_type":610,"_id":611,"_source":612,"_file":613,"_stem":614,"_extension":615},"/maps/_database/lakehouse/delta-sharing","lakehouse",false,true,"","Delta Sharing：跨平台安全数据共享的开放协议（Trial）","以开放协议在多云与本地间共享“在线数据”，集中治理与审计，避免复制；但须管控跨云外网成本。",{"type":179,"children":180,"toc":597},"root",[181,190,196,201,207,213,219,234,239,257,262,267,285,290,303,308,321,326,332,345,350,363,369,382,387,392,405,410,423,428,441,446,451,474,479,492,497,502,515,521,555,560,578,584],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"brief",[187],{"type":188,"value":189},"text","Brief",{"type":182,"tag":191,"props":192,"children":193},"p",{},[194],{"type":188,"value":195},"Delta Sharing 是一个用于安全、跨平台数据共享的开放标准与协议，由 Databricks 与 Linux 基金会共同推动。它与云平台无关，使组织能够在不同云供应商与本地环境之间共享“在线数据”，无需拷贝或复制，从而保持数据新鲜度并消除重复成本。我们曾看到某电商公司用 Delta Sharing 将割裂的伙伴数据共享系统替换为集中化、实时且安全的平台，显著提升了协作。该协议通过简单的 REST API 下发短期有效的预签名 URL，接收方可用 pandas、Spark 或 Power BI 等工具拉取大规模数据集。它支持共享数据表、视图、AI 模型与笔记本。尽管它提供强大的集中治理与审计能力，用户仍需注意云外网（egress）费用；若缺乏管理，这类成本可能成为显著的运营风险。",{"type":182,"tag":191,"props":197,"children":198},{},[199],{"type":188,"value":200},"来源：技术雷达",{"type":182,"tag":183,"props":202,"children":204},{"id":203},"details",[205],{"type":188,"value":206},"Details",{"type":182,"tag":208,"props":209,"children":211},"h3",{"id":210},"背景与现状",[212],{"type":188,"value":210},{"type":182,"tag":214,"props":215,"children":217},"h4",{"id":216},"为什么现在要谈",[218],{"type":188,"value":216},{"type":182,"tag":220,"props":221,"children":222},"ul",{},[223,229],{"type":182,"tag":224,"props":225,"children":226},"li",{},[227],{"type":188,"value":228},"多云与跨组织协作增多，复制式数据分发带来时效性下降、版本漂移与高存储/运维成本。",{"type":182,"tag":224,"props":230,"children":231},{},[232],{"type":188,"value":233},"合规与可审计要求上升，点对点管道难以统一治理与撤销访问。",{"type":182,"tag":214,"props":235,"children":237},{"id":236},"典型适用场景",[238],{"type":188,"value":236},{"type":182,"tag":220,"props":240,"children":241},{},[242,247,252],{"type":182,"tag":224,"props":243,"children":244},{},[245],{"type":188,"value":246},"与外部伙伴、子公司、区域团队共享近实时数据。",{"type":182,"tag":224,"props":248,"children":249},{},[250],{"type":188,"value":251},"多云/跨账体系下的统一数据出口，避免专有平台锁定。",{"type":182,"tag":224,"props":253,"children":254},{},[255],{"type":188,"value":256},"BI/数据科学工具直接消费共享数据，无需额外落地副本。",{"type":182,"tag":208,"props":258,"children":260},{"id":259},"模式与原理",[261],{"type":188,"value":259},{"type":182,"tag":214,"props":263,"children":265},{"id":264},"架构与角色",[266],{"type":188,"value":264},{"type":182,"tag":220,"props":268,"children":269},{},[270,275,280],{"type":182,"tag":224,"props":271,"children":272},{},[273],{"type":188,"value":274},"Provider 发布 Share（表/视图/模型/笔记本），Recipient 通过客户端读取。",{"type":182,"tag":224,"props":276,"children":277},{},[278],{"type":188,"value":279},"以简单 REST API 发放短期预签名 URL，按需直读对象存储数据文件。",{"type":182,"tag":224,"props":281,"children":282},{},[283],{"type":188,"value":284},"治理与审计集中在目录/权限层，实现可撤销、可追踪访问。",{"type":182,"tag":214,"props":286,"children":288},{"id":287},"访问机制与生态",[289],{"type":188,"value":287},{"type":182,"tag":220,"props":291,"children":292},{},[293,298],{"type":182,"tag":224,"props":294,"children":295},{},[296],{"type":188,"value":297},"客户端：pandas、Spark、Power BI 等常见分析工具直接拉取。",{"type":182,"tag":224,"props":299,"children":300},{},[301],{"type":188,"value":302},"实质是“零复制共享”：计算在接收方，存储留在提供方，减少数据流转链路。",{"type":182,"tag":214,"props":304,"children":306},{"id":305},"能力边界与注意",[307],{"type":188,"value":305},{"type":182,"tag":220,"props":309,"children":310},{},[311,316],{"type":182,"tag":224,"props":312,"children":313},{},[314],{"type":188,"value":315},"读通路为主，写入通常不开放；细粒度控制常通过视图实现行/列裁剪。",{"type":182,"tag":224,"props":317,"children":318},{},[319],{"type":188,"value":320},"性能受网络与对象存储布局影响；跨区域/跨云引发 egress 成本。",{"type":182,"tag":208,"props":322,"children":324},{"id":323},"对比与演进",[325],{"type":188,"value":323},{"type":182,"tag":214,"props":327,"children":329},{"id":328},"相对复制式共享etl文件投递",[330],{"type":188,"value":331},"相对复制式共享（ETL/文件投递）",{"type":182,"tag":220,"props":333,"children":334},{},[335,340],{"type":182,"tag":224,"props":336,"children":337},{},[338],{"type":188,"value":339},"优势：单一事实源、近实时、集中治理、撤销敏捷。",{"type":182,"tag":224,"props":341,"children":342},{},[343],{"type":188,"value":344},"代价：网络带宽与 egress 成本外显；对目录治理与Schema稳定性要求更高。",{"type":182,"tag":214,"props":346,"children":348},{"id":347},"相对专有数据共享产品",[349],{"type":188,"value":347},{"type":182,"tag":220,"props":351,"children":352},{},[353,358],{"type":182,"tag":224,"props":354,"children":355},{},[356],{"type":188,"value":357},"优势：开放协议与多工具互通，降低平台绑定。",{"type":182,"tag":224,"props":359,"children":360},{},[361],{"type":188,"value":362},"局限：生态成熟度与高级特性可能不如深度集成的专有方案。",{"type":182,"tag":214,"props":364,"children":366},{"id":365},"相对查询联邦虚拟化",[367],{"type":188,"value":368},"相对查询联邦/虚拟化",{"type":182,"tag":220,"props":370,"children":371},{},[372,377],{"type":182,"tag":224,"props":373,"children":374},{},[375],{"type":188,"value":376},"优势：简化跨源查询路径与权限整合，减少跨系统优化耦合。",{"type":182,"tag":224,"props":378,"children":379},{},[380],{"type":188,"value":381},"局限：主要面向数据分发消费，不替代复杂的跨源联邦优化。",{"type":182,"tag":208,"props":383,"children":385},{"id":384},"系统影响",[386],{"type":188,"value":384},{"type":182,"tag":214,"props":388,"children":390},{"id":389},"架构一致性",[391],{"type":188,"value":389},{"type":182,"tag":220,"props":393,"children":394},{},[395,400],{"type":182,"tag":224,"props":396,"children":397},{},[398],{"type":188,"value":399},"将“数据出口”标准化，减少私建管道与影子副本，稳定数据血缘与SLA。",{"type":182,"tag":224,"props":401,"children":402},{},[403],{"type":188,"value":404},"数据契约化：通过视图与Schema版本约束管理外部可见接口。",{"type":182,"tag":214,"props":406,"children":408},{"id":407},"工程与治理",[409],{"type":188,"value":407},{"type":182,"tag":220,"props":411,"children":412},{},[413,418],{"type":182,"tag":224,"props":414,"children":415},{},[416],{"type":188,"value":417},"统一审计、密钥轮换与访问撤销，便于合规核查。",{"type":182,"tag":224,"props":419,"children":420},{},[421],{"type":188,"value":422},"需要数据分级、脱敏与最小权限策略；对外共享界面尽量以视图抽象。",{"type":182,"tag":214,"props":424,"children":426},{"id":425},"成本与性能",[427],{"type":188,"value":425},{"type":182,"tag":220,"props":429,"children":430},{},[431,436],{"type":182,"tag":224,"props":432,"children":433},{},[434],{"type":188,"value":435},"主要成本从存储转向网络；需按区域/伙伴制定限额与预算。",{"type":182,"tag":224,"props":437,"children":438},{},[439],{"type":188,"value":440},"建议就近部署、缓存冷热分层、批量化读取以优化吞吐与费用。",{"type":182,"tag":208,"props":442,"children":444},{"id":443},"问题与风险",[445],{"type":188,"value":443},{"type":182,"tag":214,"props":447,"children":449},{"id":448},"主要风险",[450],{"type":188,"value":448},{"type":182,"tag":220,"props":452,"children":453},{},[454,459,464,469],{"type":182,"tag":224,"props":455,"children":456},{},[457],{"type":188,"value":458},"Egress 成本不可控、跨区域传输拉高费用。",{"type":182,"tag":224,"props":460,"children":461},{},[462],{"type":188,"value":463},"架构泄露与过度暴露：视图/元数据不当暴露造成侧信道风险。",{"type":182,"tag":224,"props":465,"children":466},{},[467],{"type":188,"value":468},"Schema 演进破坏兼容性，导致接收方作业失败。",{"type":182,"tag":224,"props":470,"children":471},{},[472],{"type":188,"value":473},"客户端异构导致行为差异与支持边界不一致。",{"type":182,"tag":214,"props":475,"children":477},{"id":476},"根因与结构性矛盾",[478],{"type":188,"value":476},{"type":182,"tag":220,"props":480,"children":481},{},[482,487],{"type":182,"tag":224,"props":483,"children":484},{},[485],{"type":188,"value":486},"“零复制共享”的便捷与“网络/合规成本”的增长存在张力。",{"type":182,"tag":224,"props":488,"children":489},{},[490],{"type":188,"value":491},"统一治理需要强约束，而业务协作追求灵活，需用视图与契约折中。",{"type":182,"tag":208,"props":493,"children":495},{"id":494},"落地建议",[496],{"type":188,"value":494},{"type":182,"tag":214,"props":498,"children":500},{"id":499},"适用边界",[501],{"type":188,"value":499},{"type":182,"tag":220,"props":503,"children":504},{},[505,510],{"type":182,"tag":224,"props":506,"children":507},{},[508],{"type":188,"value":509},"倾向采用：多云/多组织共享、对近实时有要求、复制成本高的场景。",{"type":182,"tag":224,"props":511,"children":512},{},[513],{"type":188,"value":514},"谨慎采用：跨洲跨区域高频大流量、Schema 变动频繁、无法落实目录治理。",{"type":182,"tag":214,"props":516,"children":518},{"id":517},"试点路径小步快跑",[519],{"type":188,"value":520},"试点路径（小步快跑）",{"type":182,"tag":522,"props":523,"children":524},"ol",{},[525,530,535,540,545,550],{"type":182,"tag":224,"props":526,"children":527},{},[528],{"type":188,"value":529},"选2–3张高价值、稳定Schema的表，以视图对外暴露。",{"type":182,"tag":224,"props":531,"children":532},{},[533],{"type":188,"value":534},"定义对外接口契约：列级/行级裁剪、数据新鲜度与可用性SLO。",{"type":182,"tag":224,"props":536,"children":537},{},[538],{"type":188,"value":539},"建立访问审计与成本监控（按消费方/区域/数据集维度）。",{"type":182,"tag":224,"props":541,"children":542},{},[543],{"type":188,"value":544},"设限与熔断：带宽/请求速率/总费用阈值与自动告警。",{"type":182,"tag":224,"props":546,"children":547},{},[548],{"type":188,"value":549},"演练撤销与轮换：密钥、共享撤销、回滚预案。",{"type":182,"tag":224,"props":551,"children":552},{},[553],{"type":188,"value":554},"扩面到模型/笔记本等资产，统一在目录层治理。",{"type":182,"tag":214,"props":556,"children":558},{"id":557},"实施要点",[559],{"type":188,"value":557},{"type":182,"tag":220,"props":561,"children":562},{},[563,568,573],{"type":182,"tag":224,"props":564,"children":565},{},[566],{"type":188,"value":567},"用视图实现脱敏与行列级策略；敏感数据默认不出域。",{"type":182,"tag":224,"props":569,"children":570},{},[571],{"type":188,"value":572},"版本化Schema：兼容演进，提供弃用周期与变更公告。",{"type":182,"tag":224,"props":574,"children":575},{},[576],{"type":188,"value":577},"就近策略：优先同区域共享，必要时部署边缘缓存/落地中转。",{"type":182,"tag":214,"props":579,"children":581},{"id":580},"观测与slo",[582],{"type":188,"value":583},"观测与SLO",{"type":182,"tag":220,"props":585,"children":586},{},[587,592],{"type":182,"tag":224,"props":588,"children":589},{},[590],{"type":188,"value":591},"关键指标：数据新鲜度、端到端读取延迟、成功率、单位消费成本（GB/消费方）、撤销生效时间。",{"type":182,"tag":224,"props":593,"children":594},{},[595],{"type":188,"value":596},"周期性审计：共享清单、最小权限偏差、异常访问与成本尖峰。",{"title":175,"searchDepth":598,"depth":598,"links":599},2,[600,601],{"id":185,"depth":598,"text":189},{"id":203,"depth":598,"text":206,"children":602},[603,605,606,607,608,609],{"id":210,"depth":604,"text":210},3,{"id":259,"depth":604,"text":259},{"id":323,"depth":604,"text":323},{"id":384,"depth":604,"text":384},{"id":443,"depth":604,"text":443},{"id":494,"depth":604,"text":494},"markdown","content:6.maps:_database:lakehouse:delta-sharing.md","content","6.maps/_database/lakehouse/delta-sharing.md","6.maps/_database/lakehouse/delta-sharing","md",[617,621],{"_path":618,"title":619,"description":620},"/maps/_database/graphql/ai/graphql-for-llm","GraphQL for LLM","将 GraphQL 作为大型语言模型（LLM）数据访问模式的实践",{"_path":622,"title":623,"description":624},"/maps/_database/lakehouse/lakehouse","Lakehouse","一种新型的数据管理架构，它结合了数据湖（Data Lake）和数据仓库（Data Warehouse）的优点，为现代数据分析和管理提供了一个统一的平台。",1771264666766]