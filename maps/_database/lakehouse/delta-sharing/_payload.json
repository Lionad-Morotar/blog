/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"body":181,"_type":613,"_id":614,"_source":615,"_file":616,"_stem":617,"_extension":618},"/maps/_database/lakehouse/delta-sharing","lakehouse",false,true,"","Delta Sharing：跨平台安全数据共享的开放协议（Trial）","以开放协议在多云与本地间共享“在线数据”，集中治理与审计，避免复制；但须管控跨云外网成本。",{"type":182,"children":183,"toc":600},"root",[184,193,199,204,210,216,222,237,242,260,265,270,288,293,306,311,324,329,335,348,353,366,372,385,390,395,408,413,426,431,444,449,454,477,482,495,500,505,518,524,558,563,581,587],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"brief",[190],{"type":191,"value":192},"text","Brief",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"Delta Sharing 是一个用于安全、跨平台数据共享的开放标准与协议，由 Databricks 与 Linux 基金会共同推动。它与云平台无关，使组织能够在不同云供应商与本地环境之间共享“在线数据”，无需拷贝或复制，从而保持数据新鲜度并消除重复成本。我们曾看到某电商公司用 Delta Sharing 将割裂的伙伴数据共享系统替换为集中化、实时且安全的平台，显著提升了协作。该协议通过简单的 REST API 下发短期有效的预签名 URL，接收方可用 pandas、Spark 或 Power BI 等工具拉取大规模数据集。它支持共享数据表、视图、AI 模型与笔记本。尽管它提供强大的集中治理与审计能力，用户仍需注意云外网（egress）费用；若缺乏管理，这类成本可能成为显著的运营风险。",{"type":185,"tag":194,"props":200,"children":201},{},[202],{"type":191,"value":203},"来源：技术雷达",{"type":185,"tag":186,"props":205,"children":207},{"id":206},"details",[208],{"type":191,"value":209},"Details",{"type":185,"tag":211,"props":212,"children":214},"h3",{"id":213},"背景与现状",[215],{"type":191,"value":213},{"type":185,"tag":217,"props":218,"children":220},"h4",{"id":219},"为什么现在要谈",[221],{"type":191,"value":219},{"type":185,"tag":223,"props":224,"children":225},"ul",{},[226,232],{"type":185,"tag":227,"props":228,"children":229},"li",{},[230],{"type":191,"value":231},"多云与跨组织协作增多，复制式数据分发带来时效性下降、版本漂移与高存储/运维成本。",{"type":185,"tag":227,"props":233,"children":234},{},[235],{"type":191,"value":236},"合规与可审计要求上升，点对点管道难以统一治理与撤销访问。",{"type":185,"tag":217,"props":238,"children":240},{"id":239},"典型适用场景",[241],{"type":191,"value":239},{"type":185,"tag":223,"props":243,"children":244},{},[245,250,255],{"type":185,"tag":227,"props":246,"children":247},{},[248],{"type":191,"value":249},"与外部伙伴、子公司、区域团队共享近实时数据。",{"type":185,"tag":227,"props":251,"children":252},{},[253],{"type":191,"value":254},"多云/跨账体系下的统一数据出口，避免专有平台锁定。",{"type":185,"tag":227,"props":256,"children":257},{},[258],{"type":191,"value":259},"BI/数据科学工具直接消费共享数据，无需额外落地副本。",{"type":185,"tag":211,"props":261,"children":263},{"id":262},"模式与原理",[264],{"type":191,"value":262},{"type":185,"tag":217,"props":266,"children":268},{"id":267},"架构与角色",[269],{"type":191,"value":267},{"type":185,"tag":223,"props":271,"children":272},{},[273,278,283],{"type":185,"tag":227,"props":274,"children":275},{},[276],{"type":191,"value":277},"Provider 发布 Share（表/视图/模型/笔记本），Recipient 通过客户端读取。",{"type":185,"tag":227,"props":279,"children":280},{},[281],{"type":191,"value":282},"以简单 REST API 发放短期预签名 URL，按需直读对象存储数据文件。",{"type":185,"tag":227,"props":284,"children":285},{},[286],{"type":191,"value":287},"治理与审计集中在目录/权限层，实现可撤销、可追踪访问。",{"type":185,"tag":217,"props":289,"children":291},{"id":290},"访问机制与生态",[292],{"type":191,"value":290},{"type":185,"tag":223,"props":294,"children":295},{},[296,301],{"type":185,"tag":227,"props":297,"children":298},{},[299],{"type":191,"value":300},"客户端：pandas、Spark、Power BI 等常见分析工具直接拉取。",{"type":185,"tag":227,"props":302,"children":303},{},[304],{"type":191,"value":305},"实质是“零复制共享”：计算在接收方，存储留在提供方，减少数据流转链路。",{"type":185,"tag":217,"props":307,"children":309},{"id":308},"能力边界与注意",[310],{"type":191,"value":308},{"type":185,"tag":223,"props":312,"children":313},{},[314,319],{"type":185,"tag":227,"props":315,"children":316},{},[317],{"type":191,"value":318},"读通路为主，写入通常不开放；细粒度控制常通过视图实现行/列裁剪。",{"type":185,"tag":227,"props":320,"children":321},{},[322],{"type":191,"value":323},"性能受网络与对象存储布局影响；跨区域/跨云引发 egress 成本。",{"type":185,"tag":211,"props":325,"children":327},{"id":326},"对比与演进",[328],{"type":191,"value":326},{"type":185,"tag":217,"props":330,"children":332},{"id":331},"相对复制式共享etl文件投递",[333],{"type":191,"value":334},"相对复制式共享（ETL/文件投递）",{"type":185,"tag":223,"props":336,"children":337},{},[338,343],{"type":185,"tag":227,"props":339,"children":340},{},[341],{"type":191,"value":342},"优势：单一事实源、近实时、集中治理、撤销敏捷。",{"type":185,"tag":227,"props":344,"children":345},{},[346],{"type":191,"value":347},"代价：网络带宽与 egress 成本外显；对目录治理与Schema稳定性要求更高。",{"type":185,"tag":217,"props":349,"children":351},{"id":350},"相对专有数据共享产品",[352],{"type":191,"value":350},{"type":185,"tag":223,"props":354,"children":355},{},[356,361],{"type":185,"tag":227,"props":357,"children":358},{},[359],{"type":191,"value":360},"优势：开放协议与多工具互通，降低平台绑定。",{"type":185,"tag":227,"props":362,"children":363},{},[364],{"type":191,"value":365},"局限：生态成熟度与高级特性可能不如深度集成的专有方案。",{"type":185,"tag":217,"props":367,"children":369},{"id":368},"相对查询联邦虚拟化",[370],{"type":191,"value":371},"相对查询联邦/虚拟化",{"type":185,"tag":223,"props":373,"children":374},{},[375,380],{"type":185,"tag":227,"props":376,"children":377},{},[378],{"type":191,"value":379},"优势：简化跨源查询路径与权限整合，减少跨系统优化耦合。",{"type":185,"tag":227,"props":381,"children":382},{},[383],{"type":191,"value":384},"局限：主要面向数据分发消费，不替代复杂的跨源联邦优化。",{"type":185,"tag":211,"props":386,"children":388},{"id":387},"系统影响",[389],{"type":191,"value":387},{"type":185,"tag":217,"props":391,"children":393},{"id":392},"架构一致性",[394],{"type":191,"value":392},{"type":185,"tag":223,"props":396,"children":397},{},[398,403],{"type":185,"tag":227,"props":399,"children":400},{},[401],{"type":191,"value":402},"将“数据出口”标准化，减少私建管道与影子副本，稳定数据血缘与SLA。",{"type":185,"tag":227,"props":404,"children":405},{},[406],{"type":191,"value":407},"数据契约化：通过视图与Schema版本约束管理外部可见接口。",{"type":185,"tag":217,"props":409,"children":411},{"id":410},"工程与治理",[412],{"type":191,"value":410},{"type":185,"tag":223,"props":414,"children":415},{},[416,421],{"type":185,"tag":227,"props":417,"children":418},{},[419],{"type":191,"value":420},"统一审计、密钥轮换与访问撤销，便于合规核查。",{"type":185,"tag":227,"props":422,"children":423},{},[424],{"type":191,"value":425},"需要数据分级、脱敏与最小权限策略；对外共享界面尽量以视图抽象。",{"type":185,"tag":217,"props":427,"children":429},{"id":428},"成本与性能",[430],{"type":191,"value":428},{"type":185,"tag":223,"props":432,"children":433},{},[434,439],{"type":185,"tag":227,"props":435,"children":436},{},[437],{"type":191,"value":438},"主要成本从存储转向网络；需按区域/伙伴制定限额与预算。",{"type":185,"tag":227,"props":440,"children":441},{},[442],{"type":191,"value":443},"建议就近部署、缓存冷热分层、批量化读取以优化吞吐与费用。",{"type":185,"tag":211,"props":445,"children":447},{"id":446},"问题与风险",[448],{"type":191,"value":446},{"type":185,"tag":217,"props":450,"children":452},{"id":451},"主要风险",[453],{"type":191,"value":451},{"type":185,"tag":223,"props":455,"children":456},{},[457,462,467,472],{"type":185,"tag":227,"props":458,"children":459},{},[460],{"type":191,"value":461},"Egress 成本不可控、跨区域传输拉高费用。",{"type":185,"tag":227,"props":463,"children":464},{},[465],{"type":191,"value":466},"架构泄露与过度暴露：视图/元数据不当暴露造成侧信道风险。",{"type":185,"tag":227,"props":468,"children":469},{},[470],{"type":191,"value":471},"Schema 演进破坏兼容性，导致接收方作业失败。",{"type":185,"tag":227,"props":473,"children":474},{},[475],{"type":191,"value":476},"客户端异构导致行为差异与支持边界不一致。",{"type":185,"tag":217,"props":478,"children":480},{"id":479},"根因与结构性矛盾",[481],{"type":191,"value":479},{"type":185,"tag":223,"props":483,"children":484},{},[485,490],{"type":185,"tag":227,"props":486,"children":487},{},[488],{"type":191,"value":489},"“零复制共享”的便捷与“网络/合规成本”的增长存在张力。",{"type":185,"tag":227,"props":491,"children":492},{},[493],{"type":191,"value":494},"统一治理需要强约束，而业务协作追求灵活，需用视图与契约折中。",{"type":185,"tag":211,"props":496,"children":498},{"id":497},"落地建议",[499],{"type":191,"value":497},{"type":185,"tag":217,"props":501,"children":503},{"id":502},"适用边界",[504],{"type":191,"value":502},{"type":185,"tag":223,"props":506,"children":507},{},[508,513],{"type":185,"tag":227,"props":509,"children":510},{},[511],{"type":191,"value":512},"倾向采用：多云/多组织共享、对近实时有要求、复制成本高的场景。",{"type":185,"tag":227,"props":514,"children":515},{},[516],{"type":191,"value":517},"谨慎采用：跨洲跨区域高频大流量、Schema 变动频繁、无法落实目录治理。",{"type":185,"tag":217,"props":519,"children":521},{"id":520},"试点路径小步快跑",[522],{"type":191,"value":523},"试点路径（小步快跑）",{"type":185,"tag":525,"props":526,"children":527},"ol",{},[528,533,538,543,548,553],{"type":185,"tag":227,"props":529,"children":530},{},[531],{"type":191,"value":532},"选2–3张高价值、稳定Schema的表，以视图对外暴露。",{"type":185,"tag":227,"props":534,"children":535},{},[536],{"type":191,"value":537},"定义对外接口契约：列级/行级裁剪、数据新鲜度与可用性SLO。",{"type":185,"tag":227,"props":539,"children":540},{},[541],{"type":191,"value":542},"建立访问审计与成本监控（按消费方/区域/数据集维度）。",{"type":185,"tag":227,"props":544,"children":545},{},[546],{"type":191,"value":547},"设限与熔断：带宽/请求速率/总费用阈值与自动告警。",{"type":185,"tag":227,"props":549,"children":550},{},[551],{"type":191,"value":552},"演练撤销与轮换：密钥、共享撤销、回滚预案。",{"type":185,"tag":227,"props":554,"children":555},{},[556],{"type":191,"value":557},"扩面到模型/笔记本等资产，统一在目录层治理。",{"type":185,"tag":217,"props":559,"children":561},{"id":560},"实施要点",[562],{"type":191,"value":560},{"type":185,"tag":223,"props":564,"children":565},{},[566,571,576],{"type":185,"tag":227,"props":567,"children":568},{},[569],{"type":191,"value":570},"用视图实现脱敏与行列级策略；敏感数据默认不出域。",{"type":185,"tag":227,"props":572,"children":573},{},[574],{"type":191,"value":575},"版本化Schema：兼容演进，提供弃用周期与变更公告。",{"type":185,"tag":227,"props":577,"children":578},{},[579],{"type":191,"value":580},"就近策略：优先同区域共享，必要时部署边缘缓存/落地中转。",{"type":185,"tag":217,"props":582,"children":584},{"id":583},"观测与slo",[585],{"type":191,"value":586},"观测与SLO",{"type":185,"tag":223,"props":588,"children":589},{},[590,595],{"type":185,"tag":227,"props":591,"children":592},{},[593],{"type":191,"value":594},"关键指标：数据新鲜度、端到端读取延迟、成功率、单位消费成本（GB/消费方）、撤销生效时间。",{"type":185,"tag":227,"props":596,"children":597},{},[598],{"type":191,"value":599},"周期性审计：共享清单、最小权限偏差、异常访问与成本尖峰。",{"title":178,"searchDepth":601,"depth":601,"links":602},2,[603,604],{"id":188,"depth":601,"text":192},{"id":206,"depth":601,"text":209,"children":605},[606,608,609,610,611,612],{"id":213,"depth":607,"text":213},3,{"id":262,"depth":607,"text":262},{"id":326,"depth":607,"text":326},{"id":387,"depth":607,"text":387},{"id":446,"depth":607,"text":446},{"id":497,"depth":607,"text":497},"markdown","content:6.maps:_database:lakehouse:delta-sharing.md","content","6.maps/_database/lakehouse/delta-sharing.md","6.maps/_database/lakehouse/delta-sharing","md",[620,624],{"_path":621,"title":622,"description":623},"/maps/_database/graphql/ai/graphql-for-llm","GraphQL for LLM","将 GraphQL 作为大型语言模型（LLM）数据访问模式的实践",{"_path":625,"title":626,"description":627},"/maps/_database/lakehouse/lakehouse","Lakehouse","一种新型的数据管理架构，它结合了数据湖（Data Lake）和数据仓库（Data Warehouse）的优点，为现代数据分析和管理提供了一个统一的平台。",1771695818315]