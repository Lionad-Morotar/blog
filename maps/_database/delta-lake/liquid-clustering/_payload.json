"/articles/css-poaa",{"title":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":180,"body":181,"_type":511,"_id":512,"_source":513,"_file":514,"_stem":515,"_extension":516},"/maps/_database/delta-lake/liquid-clustering","delta-lake",false,true,"","Delta Lake Liquid Clustering","Delta Lake 液体聚类是一种动态数据布局优化技术，通过增量调整数据分布以提升查询性能，适应多变的查询模式，降低维护成本",{"type":182,"children":183,"toc":499},"root",[184,193,199,205,211,216,221,227,232,237,257,263,350,355,390,395,400,423,428,461,466],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"brief",[190],{"type":191,"value":192},"text","Brief",{"type":185,"tag":194,"props":195,"children":196},"p",{},[197],{"type":191,"value":198},"Delta Lake 液体聚类是一种针对 Delta Lake 表的优化技术，作为分区和 Z-ordering 的替代方案。其核心机制通过树状算法动态调整数据布局，支持指定键的增量聚类更改而无需全量重写数据。这提升了查询模式多样性的适应能力，降低计算成本并增强读取性能。Databricks Runtime 支持自动分析查询负载以优化聚类，适用于独立 Delta Lake 和 Databricks Runtime 用户。",{"type":185,"tag":186,"props":200,"children":202},{"id":201},"details",[203],{"type":191,"value":204},"Details",{"type":185,"tag":206,"props":207,"children":209},"h3",{"id":208},"背景与痛点",[210],{"type":191,"value":208},{"type":185,"tag":194,"props":212,"children":213},{},[214],{"type":191,"value":215},"传统 Delta Lake 优化依赖静态分区和 Z-ordering，需在表创建时预定义键。修改配置时必须全量重写数据，导致高成本、长停机时间。当查询模式频繁变化（如 Ad-hoc 分析需求增加），静态设计难以响应，形成结构性矛盾：读性能优化与动态业务需求无法兼顾。长期看，这会累积技术债，拖累数据平台敏捷性。",{"type":185,"tag":206,"props":217,"children":219},{"id":218},"核心原理",[220],{"type":191,"value":218},{"type":185,"tag":222,"props":223,"children":225},"h4",{"id":224},"机制本质",[226],{"type":191,"value":224},{"type":185,"tag":194,"props":228,"children":229},{},[230],{"type":191,"value":231},"液体聚类采用树状结构动态管理数据分布，核心是增量元数据更新。通过维护聚集群组的树状索引（如 B+ 树），仅需移动少量数据块即可调整布局，避免全表重写。关键组件包含：聚类决策引擎（分析查询负载）、增量更新服务、以及高效元数据存储。工作机制上，系统实时识别高频查询列，动态调整数据物理布局以优化读取路径。",{"type":185,"tag":222,"props":233,"children":235},{"id":234},"工作流程",[236],{"type":191,"value":234},{"type":185,"tag":238,"props":239,"children":240},"ol",{},[241,247,252],{"type":185,"tag":242,"props":243,"children":244},"li",{},[245],{"type":191,"value":246},"分析历史查询负载，识别高频访问列作为聚类键。",{"type":185,"tag":242,"props":248,"children":249},{},[250],{"type":191,"value":251},"增量更新元数据：仅移动相关数据块，而非全表操作。",{"type":185,"tag":242,"props":253,"children":254},{},[255],{"type":191,"value":256},"查询时直接利用聚类索引跳过无关数据，减少 I/O 开销。",{"type":185,"tag":206,"props":258,"children":260},{"id":259},"传统-vs-新模式对比",[261],{"type":191,"value":262},"传统 vs 新模式对比",{"type":185,"tag":264,"props":265,"children":266},"table",{},[267,291],{"type":185,"tag":268,"props":269,"children":270},"thead",{},[271],{"type":185,"tag":272,"props":273,"children":274},"tr",{},[275,281,286],{"type":185,"tag":276,"props":277,"children":278},"th",{},[279],{"type":191,"value":280},"维度",{"type":185,"tag":276,"props":282,"children":283},{},[284],{"type":191,"value":285},"传统分区/Z-ordering",{"type":185,"tag":276,"props":287,"children":288},{},[289],{"type":191,"value":290},"液体聚类",{"type":185,"tag":292,"props":293,"children":294},"tbody",{},[295,314,332],{"type":185,"tag":272,"props":296,"children":297},{},[298,304,309],{"type":185,"tag":299,"props":300,"children":301},"td",{},[302],{"type":191,"value":303},"修改成本",{"type":185,"tag":299,"props":305,"children":306},{},[307],{"type":191,"value":308},"全表重写，高计算/存储开销",{"type":185,"tag":299,"props":310,"children":311},{},[312],{"type":191,"value":313},"增量更新，低开销",{"type":185,"tag":272,"props":315,"children":316},{},[317,322,327],{"type":185,"tag":299,"props":318,"children":319},{},[320],{"type":191,"value":321},"灵活性",{"type":185,"tag":299,"props":323,"children":324},{},[325],{"type":191,"value":326},"仅预定义键有效，修改需停机",{"type":185,"tag":299,"props":328,"children":329},{},[330],{"type":191,"value":331},"动态适应查询变化，零停机调整",{"type":185,"tag":272,"props":333,"children":334},{},[335,340,345],{"type":185,"tag":299,"props":336,"children":337},{},[338],{"type":191,"value":339},"适用场景",{"type":185,"tag":299,"props":341,"children":342},{},[343],{"type":191,"value":344},"固定查询模式（如定期报表）",{"type":185,"tag":299,"props":346,"children":347},{},[348],{"type":191,"value":349},"多变查询负载（如 Ad-hoc 分析）",{"type":185,"tag":206,"props":351,"children":353},{"id":352},"系统影响",[354],{"type":191,"value":352},{"type":185,"tag":356,"props":357,"children":358},"ul",{},[359,370,380],{"type":185,"tag":242,"props":360,"children":361},{},[362,368],{"type":185,"tag":363,"props":364,"children":365},"strong",{},[366],{"type":191,"value":367},"架构弹性",{"type":191,"value":369},"：减少对静态索引的依赖，提升系统应对变化的能力；但元数据管理复杂度增加，可能引入单点故障风险。",{"type":185,"tag":242,"props":371,"children":372},{},[373,378],{"type":185,"tag":363,"props":374,"children":375},{},[376],{"type":191,"value":377},"工程效率",{"type":191,"value":379},"：降低数据维护成本（如避免全量重写），但团队需掌握动态优化机制，培训成本上升。",{"type":185,"tag":242,"props":381,"children":382},{},[383,388],{"type":185,"tag":363,"props":384,"children":385},{},[386],{"type":191,"value":387},"治理挑战",{"type":191,"value":389},"：查询负载分析需统一监控体系；聚类策略若分散管理，可能与数据血缘、合规性冲突。",{"type":185,"tag":206,"props":391,"children":393},{"id":392},"落地建议",[394],{"type":191,"value":392},{"type":185,"tag":222,"props":396,"children":398},{"id":397},"适用边界",[399],{"type":191,"value":397},{"type":185,"tag":356,"props":401,"children":402},{},[403,413],{"type":185,"tag":242,"props":404,"children":405},{},[406,411],{"type":185,"tag":363,"props":407,"children":408},{},[409],{"type":191,"value":410},"推荐场景",{"type":191,"value":412},"：数据量大（TB 级以上）、查询模式多变的分析型工作负载；例如，交互式 BI 或探索性数据分析表。",{"type":185,"tag":242,"props":414,"children":415},{},[416,421],{"type":185,"tag":363,"props":417,"children":418},{},[419],{"type":191,"value":420},"不适用场景",{"type":191,"value":422},"：简单固定查询（如只读报表）、小规模数据集（全量重写开销低于增量更新成本），或需严格强一致性的场景。",{"type":185,"tag":222,"props":424,"children":426},{"id":425},"实施路径",[427],{"type":191,"value":425},{"type":185,"tag":238,"props":429,"children":430},{},[431,441,451],{"type":185,"tag":242,"props":432,"children":433},{},[434,439],{"type":185,"tag":363,"props":435,"children":436},{},[437],{"type":191,"value":438},"试点阶段",{"type":191,"value":440},"：选择单个高频查询表，启用自动聚类并设置阈值（如仅当查询变化率 >20% 时触发）。",{"type":185,"tag":242,"props":442,"children":443},{},[444,449],{"type":185,"tag":363,"props":445,"children":446},{},[447],{"type":191,"value":448},"监控指标",{"type":191,"value":450},"：跟踪查询延迟、存储成本变化、元数据大小增长；通过观测工具（如 Databricks 作业日志）实时验证效果。",{"type":185,"tag":242,"props":452,"children":453},{},[454,459],{"type":185,"tag":363,"props":455,"children":456},{},[457],{"type":191,"value":458},"推广策略",{"type":191,"value":460},"：基于试点结果逐步扩展到其他表；关键改动需人工审核，避免全自动化。",{"type":185,"tag":222,"props":462,"children":464},{"id":463},"风险管控",[465],{"type":191,"value":463},{"type":185,"tag":356,"props":467,"children":468},{},[469,479,489],{"type":185,"tag":242,"props":470,"children":471},{},[472,477],{"type":185,"tag":363,"props":473,"children":474},{},[475],{"type":191,"value":476},"误判风险",{"type":191,"value":478},"：自动分析可能忽略冷查询或噪声数据，导致聚类低效。防范措施：配置人工审核点，设置性能回滚机制。",{"type":185,"tag":242,"props":480,"children":481},{},[482,487],{"type":185,"tag":363,"props":483,"children":484},{},[485],{"type":191,"value":486},"元数据膨胀",{"type":191,"value":488},"：频繁聚类更新可能增大元数据存储。防范策略：定期清理历史元数据，限制自动聚类频率（如每 24 小时一次）。",{"type":185,"tag":242,"props":490,"children":491},{},[492,497],{"type":185,"tag":363,"props":493,"children":494},{},[495],{"type":191,"value":496},"安全合规",{"type":191,"value":498},"：聚类可能暴露敏感字段分布。防范措施：在策略中加入数据脱敏检查，确保聚类键符合隐私规范。",{"title":178,"searchDepth":500,"depth":500,"links":501},2,[502,503],{"id":188,"depth":500,"text":192},{"id":201,"depth":500,"text":204,"children":504},[505,507,508,509,510],{"id":208,"depth":506,"text":208},3,{"id":218,"depth":506,"text":218},{"id":259,"depth":506,"text":262},{"id":352,"depth":506,"text":352},{"id":392,"depth":506,"text":392},"markdown","content:6.maps:_database:delta-lake:liquid-clustering.md","content","6.maps/_database/delta-lake/liquid-clustering.md","6.maps/_database/delta-lake/liquid-clustering","md",[518,522],{"_path":519,"title":520,"description":521},"/maps/_database/delta-lake/delta-lake","Delta Lake","一个开源的存储层，旨在为数据湖提供 ACID 事务支持、可扩展的元数据处理和统一的批处理与流处理能力。",{"_path":523,"title":524,"description":525},"/maps/_database/graphql","GraphQL","一种用于 API 的查询语言和运行时环境，允许客户端精确地请求所需的数据，从而提高数据获取的效率和灵活性。",1771696720999]