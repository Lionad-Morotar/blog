le":84,"_path":85},"❓ 用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133,"children":134},"造物 / Make","/tools",[135,137,140,143,146,149,152],{"title":136,"_path":133},"🧰 工具收集",{"title":138,"_path":139},"📕 博客","/tools/blog",{"title":141,"_path":142},"🥥 Coconut","/tools/coconut",{"title":144,"_path":145},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":147,"_path":148},"🌐 AnySort","/tools/anysort",{"title":150,"_path":151},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":153,"_path":154},"👓 Crapto","/tools/crypto-inline",{"title":156,"_path":157,"children":158},"我 / About","/hire",[159],{"title":160,"_path":157},"📬 技术简历",{"title":162,"_path":163,"children":164},"En","/en",[165],{"title":166,"_path":167,"children":168},"🦁 Welcome","/en/articles",[169],{"title":166,"_path":167},{"_path":171,"_dir":172,"_draft":173,"_partial":174,"_locale":175,"title":176,"description":177,"body":178,"_type":509,"_id":510,"_source":511,"_file":512,"_stem":513,"_extension":514},"/maps/_database/datalake/paimon","datalake",false,true,"","Apache Paimon：湖仓一体中的可变数据与实时更新","将数据湖格式与 LSM 融合，面向高吞吐更新与低延迟读的实时湖仓存储与管理。",{"type":179,"children":180,"toc":496},"root",[181,190,196,201,207,213,233,238,256,262,269,282,287,300,305,318,324,329,342,348,361,367,372,385,390,403,409,414,427,432,445,450,468,473],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"brief",[187],{"type":188,"value":189},"text","Brief",{"type":182,"tag":191,"props":192,"children":193},"p",{},[194],{"type":188,"value":195},"Apache Paimon 是一个开源的数据湖格式，旨在支持湖仓架构。它与 Flink 和 Spark 等处理引擎无缝集成，同时支持流式与批处理。Paimon 的架构优势在于将标准数据湖格式与 LSM（日志结构合并树）相结合。这种组合解决了数据湖在高性能更新和低延迟读取方面的传统难题。Paimon 支持主键表以实现高吞吐的实时更新，并提供可定制的合并引擎，用于去重、部分更新和聚合。该设计使得在湖中直接进行高效的流式数据摄入和可变状态管理成为可能。Paimon 还提供成熟的数据湖能力，如可扩展的元数据、ACID 事务、时光回溯、模式演进，以及通过压缩与 Z-ordering 优化的数据布局。对于需要统一存储层，既要高效处理大规模追加写数据，又要应对复杂的实时流式更新的项目，我们建议评估 Paimon。",{"type":182,"tag":191,"props":197,"children":198},{},[199],{"type":188,"value":200},"来源：技术雷达",{"type":182,"tag":183,"props":202,"children":204},{"id":203},"details",[205],{"type":188,"value":206},"Details",{"type":182,"tag":208,"props":209,"children":211},"h3",{"id":210},"背景与现状",[212],{"type":188,"value":210},{"type":182,"tag":214,"props":215,"children":216},"ul",{},[217,223,228],{"type":182,"tag":218,"props":219,"children":220},"li",{},[221],{"type":188,"value":222},"常见湖仓更多面向追加写与批量分析，对高频 upsert/去重/部分更新支持薄弱。",{"type":182,"tag":218,"props":224,"children":225},{},[226],{"type":188,"value":227},"业务流式化、CDC 普及，使“实时更新 + 低延迟读”的统一存储成为刚需。",{"type":182,"tag":218,"props":229,"children":230},{},[231],{"type":188,"value":232},"Paimon以“数据湖格式 + LSM”应对可变数据与流批一体的工程化落地。",{"type":182,"tag":208,"props":234,"children":236},{"id":235},"问题与风险",[237],{"type":188,"value":235},{"type":182,"tag":214,"props":239,"children":240},{},[241,246,251],{"type":182,"tag":218,"props":242,"children":243},{},[244],{"type":188,"value":245},"传统湖以列式文件为主，更新常需重写大文件，延迟与成本高。",{"type":182,"tag":218,"props":247,"children":248},{},[249],{"type":188,"value":250},"实时摄入带来小文件与元数据膨胀，影响扫描与规划。",{"type":182,"tag":218,"props":252,"children":253},{},[254],{"type":188,"value":255},"Upsert 语义与去重规则易引入一致性歧义；主键设计与倾斜风险并存。",{"type":182,"tag":208,"props":257,"children":259},{"id":258},"模式与原理核心抽象",[260],{"type":188,"value":261},"模式与原理（核心抽象）",{"type":182,"tag":263,"props":264,"children":266},"h4",{"id":265},"lsm-融合的数据布局",[267],{"type":188,"value":268},"LSM 融合的数据布局",{"type":182,"tag":214,"props":270,"children":271},{},[272,277],{"type":182,"tag":218,"props":273,"children":274},{},[275],{"type":188,"value":276},"将变更先写入增量层，后台合并压实，平衡写入吞吐与读放大。",{"type":182,"tag":218,"props":278,"children":279},{},[280],{"type":188,"value":281},"通过压缩、Z-ordering 与分区/排序，减少范围扫描与冷热混读。",{"type":182,"tag":263,"props":283,"children":285},{"id":284},"主键表与合并引擎",[286],{"type":188,"value":284},{"type":182,"tag":214,"props":288,"children":289},{},[290,295],{"type":182,"tag":218,"props":291,"children":292},{},[293],{"type":188,"value":294},"主键表支持高吞吐实时更新；可定制的合并逻辑用于去重、部分列更新与聚合。",{"type":182,"tag":218,"props":296,"children":297},{},[298],{"type":188,"value":299},"适配 CDC/日志流，直接在湖内管理可变状态，降低外部状态存储复杂度。",{"type":182,"tag":263,"props":301,"children":303},{"id":302},"湖仓能力完备性",[304],{"type":188,"value":302},{"type":182,"tag":214,"props":306,"children":307},{},[308,313],{"type":182,"tag":218,"props":309,"children":310},{},[311],{"type":188,"value":312},"提供 ACID、时光回溯、模式演进、可扩展元数据等，满足治理与合规。",{"type":182,"tag":218,"props":314,"children":315},{},[316],{"type":188,"value":317},"与 Flink、Spark 集成，覆盖流/批处理路径，利于统一编排。",{"type":182,"tag":208,"props":319,"children":321},{"id":320},"对比与演进旧法-vs-新法",[322],{"type":188,"value":323},"对比与演进（旧法 vs 新法）",{"type":182,"tag":263,"props":325,"children":327},{"id":326},"传统湖格式的更新路径",[328],{"type":188,"value":326},{"type":182,"tag":214,"props":330,"children":331},{},[332,337],{"type":182,"tag":218,"props":333,"children":334},{},[335],{"type":188,"value":336},"以 COW/MOR 思路处理更新，往往在高并发 upsert 下成本上升、读写冲突明显。",{"type":182,"tag":218,"props":338,"children":339},{},[340],{"type":188,"value":341},"小文件治理与实时-离线一致性需要额外平台化能力兜底。",{"type":182,"tag":263,"props":343,"children":345},{"id":344},"paimon-的演进方向",[346],{"type":188,"value":347},"Paimon 的演进方向",{"type":182,"tag":214,"props":349,"children":350},{},[351,356],{"type":182,"tag":218,"props":352,"children":353},{},[354],{"type":188,"value":355},"以 LSM 为核心处理可变数据，通常在高频更新、低延迟查询的组合场景更稳态。",{"type":182,"tag":218,"props":357,"children":358},{},[359],{"type":188,"value":360},"在纯追加、长批分析主导的负载下，优势不明显，应按负载结构取舍。",{"type":182,"tag":208,"props":362,"children":364},{"id":363},"系统影响架构与工程",[365],{"type":188,"value":366},"系统影响（架构与工程）",{"type":182,"tag":263,"props":368,"children":370},{"id":369},"架构层面的变化",[371],{"type":188,"value":369},{"type":182,"tag":214,"props":373,"children":374},{},[375,380],{"type":182,"tag":218,"props":376,"children":377},{},[378],{"type":188,"value":379},"推动“流优先”的数据生产与消费模型，减少多层落地与拷贝。",{"type":182,"tag":218,"props":381,"children":382},{},[383],{"type":188,"value":384},"统一存储承载可变与追加两类数据，提升数据血缘与治理一致性。",{"type":182,"tag":263,"props":386,"children":388},{"id":387},"工程效率与治理",[389],{"type":188,"value":387},{"type":182,"tag":214,"props":391,"children":392},{},[393,398],{"type":182,"tag":218,"props":394,"children":395},{},[396],{"type":188,"value":397},"合并策略、主键与分区规划前置成设计事项；测试需覆盖时光回溯与模式演进。",{"type":182,"tag":218,"props":399,"children":400},{},[401],{"type":188,"value":402},"观测需聚焦写放大、压实积压、热点倾斜与查询尾延迟。",{"type":182,"tag":208,"props":404,"children":406},{"id":405},"落地建议边界路径与注意点",[407],{"type":188,"value":408},"落地建议（边界、路径与注意点）",{"type":182,"tag":263,"props":410,"children":412},{"id":411},"适用边界",[413],{"type":188,"value":411},{"type":182,"tag":214,"props":415,"children":416},{},[417,422],{"type":182,"tag":218,"props":418,"children":419},{},[420],{"type":188,"value":421},"适合：CDC 驱动的事实/维表、实时去重与部分更新、需要近实时分析的场景。",{"type":182,"tag":218,"props":423,"children":424},{},[425],{"type":188,"value":426},"谨慎：超大规模纯扫描型 BI、极端宽表且更新稀疏的场景，收益可能有限。",{"type":182,"tag":263,"props":428,"children":430},{"id":429},"前置条件",[431],{"type":188,"value":429},{"type":182,"tag":214,"props":433,"children":434},{},[435,440],{"type":182,"tag":218,"props":436,"children":437},{},[438],{"type":188,"value":439},"计算引擎以 Flink/Spark 为主，确保 Connector 与 Catalog 版本匹配。",{"type":182,"tag":218,"props":441,"children":442},{},[443],{"type":188,"value":444},"存储具备足够的带宽与后台压实资源；完善的指标与告警体系。",{"type":182,"tag":263,"props":446,"children":448},{"id":447},"试点路径",[449],{"type":188,"value":447},{"type":182,"tag":214,"props":451,"children":452},{},[453,458,463],{"type":182,"tag":218,"props":454,"children":455},{},[456],{"type":188,"value":457},"从高变更、强一致性诉求的中等规模表切入（如 CDC 维表）。",{"type":182,"tag":218,"props":459,"children":460},{},[461],{"type":188,"value":462},"明确定义主键与合并语义；设置分区/排序与 Z-order 试点策略。",{"type":182,"tag":218,"props":464,"children":465},{},[466],{"type":188,"value":467},"建立对照读路径（实时/离线）与数据校验，逐步扩大表与工作负载。",{"type":182,"tag":263,"props":469,"children":471},{"id":470},"典型风险与防范",[472],{"type":188,"value":470},{"type":182,"tag":214,"props":474,"children":475},{},[476,481,486,491],{"type":182,"tag":218,"props":477,"children":478},{},[479],{"type":188,"value":480},"写/读放大与压实积压：限速与分级压实，监控 backlog 与文件大小分布。",{"type":182,"tag":218,"props":482,"children":483},{},[484],{"type":188,"value":485},"主键热点与倾斜：分桶/范围分区与预分区；必要时引入随机盐。",{"type":182,"tag":218,"props":487,"children":488},{},[489],{"type":188,"value":490},"语义误配（去重/部分更新）：将业务规则配置化并加审计校验。",{"type":182,"tag":218,"props":492,"children":493},{},[494],{"type":188,"value":495},"生态兼容性：验证查询引擎与元数据工具链的读取行为与代价模型。",{"title":175,"searchDepth":497,"depth":497,"links":498},2,[499,500],{"id":185,"depth":497,"text":189},{"id":203,"depth":497,"text":206,"children":501},[502,504,505,506,507,508],{"id":210,"depth":503,"text":210},3,{"id":235,"depth":503,"text":235},{"id":258,"depth":503,"text":261},{"id":320,"depth":503,"text":323},{"id":363,"depth":503,"text":366},{"id":405,"depth":503,"text":408},"markdown","content:6.maps:_database:datalake:paimon.md","content","6.maps/_database/datalake/paimon.md","6.maps/_database/datalake/paimon","md",[516,520],{"_path":517,"title":518,"description":519},"/maps/_database/datalake/datalake","Data Lake","一种用于存储大量原始数据的系统，支持多种数据格式和类型，适用于大数据分析和处理。",{"_path":521,"title":522,"description":523},"/maps/_database/delta-lake/delta-lake","Delta Lake","一个开源的存储层，旨在为数据湖提供 ACID 事务支持、可扩展的元数据处理和统一的批处理与流处理能力。",1771214950231]