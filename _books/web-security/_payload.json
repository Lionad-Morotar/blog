用纯CSS判断鼠标进入的方向","/articles/css-judge-direction",{"title":87,"_path":88},"📝 你本可以少写些 if-else","/articles/no-more-if-else",{"title":90,"_path":91},"📝 技术博客归档","/articles/archive",{"title":93,"_path":94,"children":95},"读书笔记 / Notes","/books",[96],{"title":97,"_path":94},"📕 读书笔记",{"title":99,"_path":100,"children":101},"吉他剧场 / Music","/music",[102,104,107,110,113,116,119,122],{"title":103,"_path":100},"🎸 FingerStyle！",{"title":105,"_path":106},"🌬️ 等待的风","/music/wind",{"title":108,"_path":109},"💕 约定的海洋","/music/ocean",{"title":111,"_path":112},"🎼 Wings~You are the Hero！","/music/wings-you-are-the-hero",{"title":114,"_path":115},"🌏 残酷天使的行动纲领","/music/eva",{"title":117,"_path":118},"🏔️ 奇跡の山","/music/miracle-mountain",{"title":120,"_path":121},"🍷 Wu Wei","/music/wu-wei",{"title":123,"_path":124},"🌅 无题","/music/untitled",{"title":126,"_path":127,"children":128},"知识地图 / Maps","/maps",[129,131],{"title":130,"_path":127},"🏁 知识地图",{"title":132,"_path":133},"Agents","/maps/agents",{"title":135,"_path":136,"children":137},"造物 / Make","/tools",[138,140,143,146,149,152,155],{"title":139,"_path":136},"🧰 工具收集",{"title":141,"_path":142},"📕 博客","/tools/blog",{"title":144,"_path":145},"🥥 Coconut","/tools/coconut",{"title":147,"_path":148},"🧶 网易云音乐歌单排序","/tools/netease-sorter",{"title":150,"_path":151},"🌐 AnySort","/tools/anysort",{"title":153,"_path":154},"⛸️ UseScrollbar","/tools/use-scrollbar",{"title":156,"_path":157},"👓 Crapto","/tools/crypto-inline",{"title":159,"_path":160,"children":161},"我 / About","/hire",[162],{"title":163,"_path":160},"📬 技术简历",{"title":165,"_path":166,"children":167},"En","/en",[168],{"title":169,"_path":170,"children":171},"🦁 Welcome","/en/articles",[172],{"title":169,"_path":170},{"_path":174,"_dir":175,"_draft":176,"_partial":177,"_locale":178,"title":179,"description":178,"body":180,"_type":262,"_id":263,"_source":264,"_file":265,"_stem":266,"_extension":267},"/_books/web-security","_books",false,true,"","Web 之困",{"type":181,"children":182,"toc":254},"root",[183,192,198,204,209,214,219,224,229,234],{"type":184,"tag":185,"props":186,"children":188},"element","h2",{"id":187},"web-应用安全",[189],{"type":190,"value":191},"text","Web 应用安全",{"type":184,"tag":193,"props":194,"children":196},"h3",{"id":195},"简明历史",[197],{"type":190,"value":195},{"type":184,"tag":199,"props":200,"children":201},"p",{},[202],{"type":190,"value":203},"计算机历史学家常以 Bush 在 1945 年虚构出来的 Memex 桌面设备作为 Web 最早期原型。Memex 用于在微缩胶卷上创建和标注跨文档连接，使用方式类似于现在的书签和超链接。1960 年左右，IBM 推出 GML。GML 经过 20 余年发展为 SGML。人们一直尝试使 SGML 结合 Bush 的链接的形式，很多项目都失败了，知道 Timber Berners-Lee 和 Don Connolly 草拟出 HTML 规范。",{"type":184,"tag":199,"props":205,"children":206},{},[207],{"type":190,"value":208},"Timber Berners-Lee 不仅草拟 HTML 规范，他们还开发出 HTTP 协议，并在此基础上完成了 WWW 浏览器项目。1993 年，Mosaic 登场了，它带来了图片以及表单功能，也是后来 Netscape 以及 IE 的前身。",{"type":184,"tag":199,"props":210,"children":211},{},[212],{"type":190,"value":213},"自微软 1996 年在 Windows 操作系统中捆绑 IE 开始，算正式挑起了浏览器大战。各类竞品竞相开发迭代，增加新功能，也就无暇顾及各类标准的建立。W3C、ECMA 和 IETF（Internet Engineering Task Force）都企图对 HTTP、JavaScript 的规范做标准化和改进的工作，但结果不甚理想。W3C 实现的 HTML 2.0 和 HTML 3.2 标准仅在发布之日就沦为了过时的标准。好在进入 2000 年后，浏览器大战逐渐落下帷幕，W3C 涉及的 HTML 4.0 以及 DOM、CSS 规范才逐渐赶了上来。",{"type":184,"tag":199,"props":215,"children":216},{},[217],{"type":190,"value":218},"没有了竞争对手，IE 一度更新缓慢，直到 2004 年针对 IE 安全性以及不良的标准兼容性杀入市场的 Firefox，以及接连在手机端领先的 Safari 和 Opera 让微软重新加大对 IE 的投入，升级到了 IE9。微软 XMLHttpRequest 出乎意料的成功，让人们开始思考更新的，同时也不是那么成熟的设计，比如 Firefox 的 globalStorage 和 IE 的 httponly Cookie；一群参与者甚至因不满 W3C 在 HTML 标准上的创新性，创建了全新的 WHATWG（Web Hypertext Application Technolofy） 组织以主导 HTML5 协议的开发。",{"type":184,"tag":199,"props":220,"children":221},{},[222],{"type":190,"value":223},"总的来说，在 Web 整个发展历程中，由于缺乏统一的远景目标和完整的安全规范，其整个发展过程竞争激烈、变幻莫测，与政治牵扯过多，结果错漏百出。这些问题在可见的将来也不会有什么改变。",{"type":184,"tag":193,"props":225,"children":227},{"id":226},"风险演化",[228],{"type":190,"value":226},{"type":184,"tag":199,"props":230,"children":231},{},[232],{"type":190,"value":233},"Web 领域中一些具有影响力的风险要素：",{"type":184,"tag":235,"props":236,"children":237},"ul",{},[238,244,249],{"type":184,"tag":239,"props":240,"children":241},"li",{},[242],{"type":190,"value":243},"用户作为安全风险的一个环节：Web 对用户的计算机水平没有要求。",{"type":184,"tag":239,"props":245,"children":246},{},[247],{"type":190,"value":248},"难以隔离的环境：传统模式中应用层数据、用户层应用和操作系统内核之间的边界非常清晰，但是浏览器中不存在这种边界。",{"type":184,"tag":239,"props":250,"children":251},{},[252],{"type":190,"value":253},"缺乏统一的格局：没有通用的整体性安全模型，至于同源策略只是跨域交互中的一个小的子集。",{"title":178,"searchDepth":255,"depth":255,"links":256},2,[257],{"id":187,"depth":255,"text":191,"children":258},[259,261],{"id":195,"depth":260,"text":195},3,{"id":226,"depth":260,"text":226},"markdown","content:_books:web-security.md","content","_books/web-security.md","_books/web-security","md",[269,272],{"_path":270,"title":271,"description":178},"/_books/the-read-world-of-techs","技术的真相",{"_path":273,"title":274,"description":275},"/_paint/archive","🎨 画画归档","这里会收录几乎不再更新的内容，请注意其时效性",1771304557300]