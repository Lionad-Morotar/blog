228],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"四十二篇是什么",[187],{"type":188,"value":185},"text",{"type":182,"tag":190,"props":191,"children":193},"h4",{"id":192},"增订-2025-年-02-月-14-日",[194],{"type":188,"value":195},"增订 | 2025 年 02 月 14 日",{"type":182,"tag":197,"props":198,"children":199},"p",{},[200],{"type":188,"value":201},"100 毫克讽刺，肌肉注射。",{"type":182,"tag":190,"props":203,"children":205},{"id":204},"增订-2024-年-06-月-12-日",[206],{"type":188,"value":207},"增订 | 2024 年 06 月 12 日",{"type":182,"tag":197,"props":209,"children":210},{},[211],{"type":188,"value":212},"四十二篇曾经的定位是记录工作相关的碎片化的灵感，但这样太过局限，所以现在用于记录灵感闪现（暴论警告）。写作方法是先起个标题，然后想到哪里就写到哪里。文章也许有主线，也许全是无厘头内容。",{"type":182,"tag":190,"props":214,"children":216},{"id":215},"原文",[217],{"type":188,"value":215},{"type":182,"tag":197,"props":219,"children":220},{},[221],{"type":188,"value":222},"工作中每天都要写日报，将每日工作相关的 3P1T（Progress、Plan、Problems、Thinking）记录下来。写日报这个制度其实本身平平淡淡，就像在上家公司时，日报制度基本等同于和主管对齐一下进度。我相信如果有合适的方法论的指导，任何事的运作都会变得更高效，那就从日报开始改变！为了使日报的效比更高，我在探索某些奇奇怪怪的方法论。比如说尝试把 Thinking 当作灵感闪现的记录，这样就不会陷入每日无思考，导致 Thinking 项空缺的境地。每三个月左右的时间，我将这些碎片化的灵感重新整理一番，看看其中有哪些值得记录进笔记或详细阐述的东西，这就是我的《四十二篇》。等《四十二篇》系列完结时，也就是再过十年，等我成我别人口中的佬的时候，那会儿再重新翻翻这个系列，也许能从里面找到点别的东西。",{"type":182,"tag":183,"props":224,"children":226},{"id":225},"四十二篇归档",[227],{"type":188,"value":225},{"type":182,"tag":229,"props":230,"children":231},"ul",{},[232,245,256,267],{"type":182,"tag":233,"props":234,"children":235},"li",{},[236,238],{"type":188,"value":237},"第四篇：",{"type":182,"tag":239,"props":240,"children":242},"a",{"href":241},"/flows/_forty-two/blind-sight",[243],{"type":188,"value":244},"盲视",{"type":182,"tag":233,"props":246,"children":247},{},[248,250],{"type":188,"value":249},"第三篇：",{"type":182,"tag":239,"props":251,"children":253},{"href":252},"/flows/_forty-two/as-human",[254],{"type":188,"value":255},"人之为人",{"type":182,"tag":233,"props":257,"children":258},{},[259,261],{"type":188,"value":260},"第二篇：",{"type":182,"tag":239,"props":262,"children":264},{"href":263},"/flows/_forty-two/mature-child",[265],{"type":188,"value":266},"成熟的小孩子",{"type":182,"tag":233,"props":268,"children":269},{},[270,272],{"type":188,"value":271},"第一篇：",{"type":182,"tag":239,"props":273,"children":275},{"href":274},"/flows/_forty-two/dark-room",[276],{"type":188,"value":277},"有关新项目的方法论",{"title":176,"searchDepth":279,"depth":279,"links":280},2,[281,282],{"id":185,"depth":279,"text":185},{"id":225,"depth":279,"text":225},"markdown","content:1.flows:1.forty-two.md","content","1.flows/1.forty-two.md","1.flows/1.forty-two","md",[290,292],{"_path":10,"title":9,"description":291},"2024 年开始用微信读书",{"_path":16,"title":15,"description":293},"最近总是梦到自己站在冰天雪地里吹冷风，让我想起了刚开始弹吉他的那段日子。",1771693679596]