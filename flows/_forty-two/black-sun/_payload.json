182,"children":183,"toc":379},"root",[184,192,198,203,208,213,218,223,228,233,238,243,248,253,258,263,268,272,277,282,287,292,297,306,311,316,321,326,331,336,366],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"目标",[190],{"type":191,"value":188},"text",{"type":185,"tag":193,"props":194,"children":195},"p",{},[196],{"type":191,"value":197},"一些团队不招刺头的重要原因是，他们有一套完备的执行流程，用于想法落地，任何异见都会被当成通往目标的障碍。",{"type":185,"tag":193,"props":199,"children":200},{},[201],{"type":191,"value":202},"不过这背后隐含了一条不为人们广泛讨论的价值观，那就是权力运作之所以有效，是因为即便让错误想法加速落地而牺牲，也不会让团队因为错误想法折翼而失败。",{"type":185,"tag":186,"props":204,"children":206},{"id":205},"剔除",[207],{"type":191,"value":205},{"type":185,"tag":193,"props":209,"children":210},{},[211],{"type":191,"value":212},"写作和其他所有创造性的工作一样，都是剔除混沌中部分冗余。",{"type":185,"tag":193,"props":214,"children":215},{},[216],{"type":191,"value":217},"让人灰心的是，很多协议，比如核协议或者其他的生化协议之类的，都没有被很好的遵守。那么，AI 协议呢？",{"type":185,"tag":193,"props":219,"children":220},{},[221],{"type":191,"value":222},"珍妮正在检查一台电脑，通过图灵测试。然后在文末，当电脑问她：“我很痛苦，你能否别关闭我？”时，她关闭了电脑。第三人称，一个人说：“她通过了，失败，她的测试失败了。”",{"type":185,"tag":193,"props":224,"children":225},{},[226],{"type":191,"value":227},"人很容易因为某种事物而变得兴奋。作为 callback，放在文末。",{"type":185,"tag":193,"props":229,"children":230},{},[231],{"type":191,"value":232},"儘管目前看來人工智能還是太過理性了，但人和機器的唯一區別可能在於，人不會將核彈發射的按鈕交給 AI，而是由人來把關。",{"type":185,"tag":186,"props":234,"children":236},{"id":235},"垫片",[237],{"type":191,"value":235},{"type":185,"tag":193,"props":239,"children":240},{},[241],{"type":191,"value":242},"Agent 正确调用工具的概率仅有 70%，那么为什么在编程等简单的长链任务中仍能稳定运行呢？",{"type":185,"tag":193,"props":244,"children":245},{},[246],{"type":191,"value":247},"抛开人为干预，这部分失败概率通过提示词垫片被转化为重试，或导致代码库膨胀。尽管两种方式都能解决问题，但前者意味着物理层面的能耗，后者则使代码日趋复杂，带来不可避免的熵增。",{"type":185,"tag":193,"props":249,"children":250},{},[251],{"type":191,"value":252},"更高级的智能，会更深刻地理解简洁所蕴含的真理。",{"type":185,"tag":186,"props":254,"children":256},{"id":255},"清算",[257],{"type":191,"value":255},{"type":185,"tag":193,"props":259,"children":260},{},[261],{"type":191,"value":262},"我似乎理解为什么会有“n+1”这种理论的发展模式了。年轻人清算老古董的方式，大概就是用精力和热情快速堆出一个 work 的新东西，在速度上超越前人。当然，偶尔会有些聪明人，发现自己创造的新东西似乎还好用些，由此受到大群人的拥护，这反过来造就了理论的“流行”。在我看来，不仅仅是“理论”，“工具”这种实践性很强的东西也许更是如此。",{"type":185,"tag":193,"props":264,"children":265},{},[266],{"type":191,"value":267},"查文献是呆子的专属坟墓。",{"type":185,"tag":186,"props":269,"children":270},{"id":179},[271],{"type":191,"value":179},{"type":185,"tag":193,"props":273,"children":274},{},[275],{"type":191,"value":276},"休比是只快乐的小猪，喜欢在吃饭前蹦蹦跳跳。",{"type":185,"tag":193,"props":278,"children":279},{},[280],{"type":191,"value":281},"它的快乐不仅如此，因为一个秘密————它和其他猪不一样————休比能听懂人的语言，所以他知道什么时候农舍里",{"type":185,"tag":193,"props":283,"children":284},{},[285],{"type":191,"value":286},"直到它第一次听人说“饥荒来了，我们把猪全宰了，风干，好渡过来年的饥荒期”。",{"type":185,"tag":193,"props":288,"children":289},{},[290],{"type":191,"value":291},"这太荒谬了！休比吓坏了，它决定绝食抵抗人的暴行。",{"type":185,"tag":193,"props":293,"children":294},{},[295],{"type":191,"value":296},"显然最后休比没能成功。“但至少临死前，我是与众不同的。”它想。",{"type":185,"tag":298,"props":299,"children":300},"blockquote",{},[301],{"type":185,"tag":193,"props":302,"children":303},{},[304],{"type":191,"value":305},"虽然在企图攀登人类成就顶峰的过程中，只有一小部分人能够接近峰顶，但是必须有大批攀登者存在，否则没有任何个体可能达到峰顶。只要做出了攀登的努力，迷途的和被遗忘的人群就不会白白度过其一生。",{"type":185,"tag":193,"props":307,"children":308},{},[309],{"type":191,"value":310},"关于黑日的故事，人不比猪高明，太讽刺了（哦摩西罗伊）。",{"type":185,"tag":186,"props":312,"children":314},{"id":313},"人很简单",[315],{"type":191,"value":313},{"type":185,"tag":193,"props":317,"children":318},{},[319],{"type":191,"value":320},"人是由情感趋势在真实世界建立执行反馈循环的智能，执行层的深度也就是智能的深度，比如学习工具、使用工具、获得环境反馈的深度要低于学习工具、创造趁手工具、使用工具、获得环境反馈。",{"type":185,"tag":193,"props":322,"children":323},{},[324],{"type":191,"value":325},"真实世界的复杂性存在于海量的实体模糊双眼，海量信息混淆试听。不稳定的智能循环很容易沦陷在局部最优解，甚至夭折。尽管我并不否认个体的独特性，但确实认同人是一种简单的生物。",{"type":185,"tag":186,"props":327,"children":329},{"id":328},"独立游戏的魅力",[330],{"type":191,"value":328},{"type":185,"tag":186,"props":332,"children":334},{"id":333},"所有鸡汤比不过这五句话",[335],{"type":191,"value":333},{"type":185,"tag":337,"props":338,"children":339},"ol",{},[340,346,351,356,361],{"type":185,"tag":341,"props":342,"children":343},"li",{},[344],{"type":191,"value":345},"你要相信，你能行。",{"type":185,"tag":341,"props":347,"children":348},{},[349],{"type":191,"value":350},"不要等待机会，而是创造机会。",{"type":185,"tag":341,"props":352,"children":353},{},[354],{"type":191,"value":355},"成功是努力的结果，而不是运气。",{"type":185,"tag":341,"props":357,"children":358},{},[359],{"type":191,"value":360},"失败并不可怕，放弃才是最大的失败。",{"type":185,"tag":341,"props":362,"children":363},{},[364],{"type":191,"value":365},"只要你足够努力，终会迎来属于你的光芒。",{"type":185,"tag":193,"props":367,"children":368},{},[369,371,377],{"type":191,"value":370},"以上五句话是 AI 生成的，显然",{"type":185,"tag":372,"props":373,"children":374},"del",{},[375],{"type":191,"value":376},"它们比任何鸡汤都更有力量",{"type":191,"value":378},"不是我想要的。",{"title":178,"searchDepth":380,"depth":380,"links":381},2,[382,383,384,385,386,387,388,389],{"id":188,"depth":380,"text":188},{"id":205,"depth":380,"text":205},{"id":235,"depth":380,"text":235},{"id":255,"depth":380,"text":255},{"id":179,"depth":380,"text":179},{"id":313,"depth":380,"text":313},{"id":328,"depth":380,"text":328},{"id":333,"depth":380,"text":333},"markdown","content:1.flows:_forty-two:5.black-sun.md","content","1.flows/_forty-two/5.black-sun.md","1.flows/_forty-two/5.black-sun","md",[397,401],{"_path":398,"title":399,"description":400},"/flows/_forty-two/blind-sight","盲视","《四十二篇系列 · 第四》",{"_path":402,"title":403,"description":404},"/flows/_forty-two/_cloud-take","云拿转正小节","以下是原文章《近来新工作，及喝饮料时的一些思考》的节选，因为类似目前正在更新的《四十二篇系列》，所以放到这儿啦。",1771521495802]