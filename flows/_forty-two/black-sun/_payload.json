205,210,215,220,225,230,235,240,245,250,255,260,265,269,274,279,284,289,294,303,308,313,318,323,328,333,363],{"type":182,"tag":183,"props":184,"children":186},"element","h2",{"id":185},"目标",[187],{"type":188,"value":185},"text",{"type":182,"tag":190,"props":191,"children":192},"p",{},[193],{"type":188,"value":194},"一些团队不招刺头的重要原因是，他们有一套完备的执行流程，用于想法落地，任何异见都会被当成通往目标的障碍。",{"type":182,"tag":190,"props":196,"children":197},{},[198],{"type":188,"value":199},"不过这背后隐含了一条不为人们广泛讨论的价值观，那就是权力运作之所以有效，是因为即便让错误想法加速落地而牺牲，也不会让团队因为错误想法折翼而失败。",{"type":182,"tag":183,"props":201,"children":203},{"id":202},"剔除",[204],{"type":188,"value":202},{"type":182,"tag":190,"props":206,"children":207},{},[208],{"type":188,"value":209},"写作和其他所有创造性的工作一样，都是剔除混沌中部分冗余。",{"type":182,"tag":190,"props":211,"children":212},{},[213],{"type":188,"value":214},"让人灰心的是，很多协议，比如核协议或者其他的生化协议之类的，都没有被很好的遵守。那么，AI 协议呢？",{"type":182,"tag":190,"props":216,"children":217},{},[218],{"type":188,"value":219},"珍妮正在检查一台电脑，通过图灵测试。然后在文末，当电脑问她：“我很痛苦，你能否别关闭我？”时，她关闭了电脑。第三人称，一个人说：“她通过了，失败，她的测试失败了。”",{"type":182,"tag":190,"props":221,"children":222},{},[223],{"type":188,"value":224},"人很容易因为某种事物而变得兴奋。作为 callback，放在文末。",{"type":182,"tag":190,"props":226,"children":227},{},[228],{"type":188,"value":229},"儘管目前看來人工智能還是太過理性了，但人和機器的唯一區別可能在於，人不會將核彈發射的按鈕交給 AI，而是由人來把關。",{"type":182,"tag":183,"props":231,"children":233},{"id":232},"垫片",[234],{"type":188,"value":232},{"type":182,"tag":190,"props":236,"children":237},{},[238],{"type":188,"value":239},"Agent 正确调用工具的概率仅有 70%，那么为什么在编程等简单的长链任务中仍能稳定运行呢？",{"type":182,"tag":190,"props":241,"children":242},{},[243],{"type":188,"value":244},"抛开人为干预，这部分失败概率通过提示词垫片被转化为重试，或导致代码库膨胀。尽管两种方式都能解决问题，但前者意味着物理层面的能耗，后者则使代码日趋复杂，带来不可避免的熵增。",{"type":182,"tag":190,"props":246,"children":247},{},[248],{"type":188,"value":249},"更高级的智能，会更深刻地理解简洁所蕴含的真理。",{"type":182,"tag":183,"props":251,"children":253},{"id":252},"清算",[254],{"type":188,"value":252},{"type":182,"tag":190,"props":256,"children":257},{},[258],{"type":188,"value":259},"我似乎理解为什么会有“n+1”这种理论的发展模式了。年轻人清算老古董的方式，大概就是用精力和热情快速堆出一个 work 的新东西，在速度上超越前人。当然，偶尔会有些聪明人，发现自己创造的新东西似乎还好用些，由此受到大群人的拥护，这反过来造就了理论的“流行”。在我看来，不仅仅是“理论”，“工具”这种实践性很强的东西也许更是如此。",{"type":182,"tag":190,"props":261,"children":262},{},[263],{"type":188,"value":264},"查文献是呆子的专属坟墓。",{"type":182,"tag":183,"props":266,"children":267},{"id":176},[268],{"type":188,"value":176},{"type":182,"tag":190,"props":270,"children":271},{},[272],{"type":188,"value":273},"休比是只快乐的小猪，喜欢在吃饭前蹦蹦跳跳。",{"type":182,"tag":190,"props":275,"children":276},{},[277],{"type":188,"value":278},"它的快乐不仅如此，因为一个秘密————它和其他猪不一样————休比能听懂人的语言，所以他知道什么时候农舍里",{"type":182,"tag":190,"props":280,"children":281},{},[282],{"type":188,"value":283},"直到它第一次听人说“饥荒来了，我们把猪全宰了，风干，好渡过来年的饥荒期”。",{"type":182,"tag":190,"props":285,"children":286},{},[287],{"type":188,"value":288},"这太荒谬了！休比吓坏了，它决定绝食抵抗人的暴行。",{"type":182,"tag":190,"props":290,"children":291},{},[292],{"type":188,"value":293},"显然最后休比没能成功。“但至少临死前，我是与众不同的。”它想。",{"type":182,"tag":295,"props":296,"children":297},"blockquote",{},[298],{"type":182,"tag":190,"props":299,"children":300},{},[301],{"type":188,"value":302},"虽然在企图攀登人类成就顶峰的过程中，只有一小部分人能够接近峰顶，但是必须有大批攀登者存在，否则没有任何个体可能达到峰顶。只要做出了攀登的努力，迷途的和被遗忘的人群就不会白白度过其一生。",{"type":182,"tag":190,"props":304,"children":305},{},[306],{"type":188,"value":307},"关于黑日的故事，人不比猪高明，太讽刺了（哦摩西罗伊）。",{"type":182,"tag":183,"props":309,"children":311},{"id":310},"人很简单",[312],{"type":188,"value":310},{"type":182,"tag":190,"props":314,"children":315},{},[316],{"type":188,"value":317},"人是由情感趋势在真实世界建立执行反馈循环的智能，执行层的深度也就是智能的深度，比如学习工具、使用工具、获得环境反馈的深度要低于学习工具、创造趁手工具、使用工具、获得环境反馈。",{"type":182,"tag":190,"props":319,"children":320},{},[321],{"type":188,"value":322},"真实世界的复杂性存在于海量的实体模糊双眼，海量信息混淆试听。不稳定的智能循环很容易沦陷在局部最优解，甚至夭折。尽管我并不否认个体的独特性，但确实认同人是一种简单的生物。",{"type":182,"tag":183,"props":324,"children":326},{"id":325},"独立游戏的魅力",[327],{"type":188,"value":325},{"type":182,"tag":183,"props":329,"children":331},{"id":330},"所有鸡汤比不过这五句话",[332],{"type":188,"value":330},{"type":182,"tag":334,"props":335,"children":336},"ol",{},[337,343,348,353,358],{"type":182,"tag":338,"props":339,"children":340},"li",{},[341],{"type":188,"value":342},"你要相信，你能行。",{"type":182,"tag":338,"props":344,"children":345},{},[346],{"type":188,"value":347},"不要等待机会，而是创造机会。",{"type":182,"tag":338,"props":349,"children":350},{},[351],{"type":188,"value":352},"成功是努力的结果，而不是运气。",{"type":182,"tag":338,"props":354,"children":355},{},[356],{"type":188,"value":357},"失败并不可怕，放弃才是最大的失败。",{"type":182,"tag":338,"props":359,"children":360},{},[361],{"type":188,"value":362},"只要你足够努力，终会迎来属于你的光芒。",{"type":182,"tag":190,"props":364,"children":365},{},[366,368,374],{"type":188,"value":367},"以上五句话是 AI 生成的，显然",{"type":182,"tag":369,"props":370,"children":371},"del",{},[372],{"type":188,"value":373},"它们比任何鸡汤都更有力量",{"type":188,"value":375},"不是我想要的。",{"title":175,"searchDepth":377,"depth":377,"links":378},2,[379,380,381,382,383,384,385,386],{"id":185,"depth":377,"text":185},{"id":202,"depth":377,"text":202},{"id":232,"depth":377,"text":232},{"id":252,"depth":377,"text":252},{"id":176,"depth":377,"text":176},{"id":310,"depth":377,"text":310},{"id":325,"depth":377,"text":325},{"id":330,"depth":377,"text":330},"markdown","content:1.flows:_forty-two:5.black-sun.md","content","1.flows/_forty-two/5.black-sun.md","1.flows/_forty-two/5.black-sun","md",[394,398],{"_path":395,"title":396,"description":397},"/flows/_forty-two/blind-sight","盲视","《四十二篇系列 · 第四》",{"_path":399,"title":400,"description":401},"/flows/_forty-two/_cloud-take","云拿转正小节","以下是原文章《近来新工作，及喝饮料时的一些思考》的节选，因为类似目前正在更新的《四十二篇系列》，所以放到这儿啦。",1771214939359]