ps":182,"children":184},"element","h2",{"id":183},"我的设备",[185],{"type":186,"value":183},"text",{"type":180,"tag":188,"props":189,"children":190},"p",{},[191],{"type":186,"value":192},"截至 2022，手头的主力设备清单：",{"type":180,"tag":194,"props":195,"children":196},"ul",{},[197,203,208,213,218,223],{"type":180,"tag":198,"props":199,"children":200},"li",{},[201],{"type":186,"value":202},"吉他：曼森 MS5 ce",{"type":180,"tag":198,"props":204,"children":205},{},[206],{"type":186,"value":207},"MIC：罗德 NT-5 pair",{"type":180,"tag":198,"props":209,"children":210},{},[211],{"type":186,"value":212},"录像：iPhone 12 & 卡色人像镜",{"type":180,"tag":198,"props":214,"children":215},{},[216],{"type":186,"value":217},"声卡：Yamaha UR44C",{"type":180,"tag":198,"props":219,"children":220},{},[221],{"type":186,"value":222},"后期：Audition",{"type":180,"tag":198,"props":224,"children":225},{},[226],{"type":186,"value":227},"监听：ACG K701 & WH-1000XM4",{"type":180,"tag":181,"props":229,"children":231},{"id":230},"常见问题",[232],{"type":186,"value":230},{"type":180,"tag":234,"props":235,"children":237},"details",{"open":236},true,[238,240,246,247],{"type":186,"value":239},"\n  ",{"type":180,"tag":241,"props":242,"children":243},"summary",{},[244],{"type":186,"value":245},"有xxx的谱子吗？",{"type":186,"value":239},{"type":180,"tag":188,"props":248,"children":249},{},[250],{"type":186,"value":251},"很遗憾，没有。我弹琴大部分时候会按原版谱学习，不过等左右手熟练以后就会把谱子扔掉。这时我可能会进行一些我不在意的改动。这样做显然会带来明显的坏处，请大家不要模仿。",{"type":180,"tag":234,"props":253,"children":254},{"open":236},[255,256,261,262],{"type":186,"value":239},{"type":180,"tag":241,"props":257,"children":258},{},[259],{"type":186,"value":260},"目前手上就一把琴？",{"type":186,"value":239},{"type":180,"tag":188,"props":263,"children":264},{},[265],{"type":186,"value":266},"是的，目前我所有视频都是用这把琴录制的。这把曼森是在大学时某比赛中拿的，至于其它琴，我好像不怎么能回忆起它们的下落了。以后存了钱我想再入手一把 Headway Sakura，我觉得它非常漂亮，无论是外观还是音色。不过目前来说这把曼森已经能满足我当前的外录需求，私底下我认为换琴弦对琴音色的提升其性价比会比换琴高得多。",{"type":180,"tag":234,"props":268,"children":269},{"open":236},[270,271,276,277],{"type":186,"value":239},{"type":180,"tag":241,"props":272,"children":273},{},[274],{"type":186,"value":275},"有推荐的录音设备吗？",{"type":186,"value":239},{"type":180,"tag":188,"props":278,"children":279},{},[280],{"type":186,"value":281},"麦克风我曾用过两年的 Line6 Sonic Port VX。从各个角度（除了动态）我都觉得比我现在手上的 NT-5 要好一些，只是不知怎么就坏掉了，才换新款。至于声卡，我觉得 UR44C 对我来说刚刚好，因为他有 4 个入口，能满足我一对 NT-5 以及吉他拾音器三个通道的录制。",{"type":180,"tag":234,"props":283,"children":284},{"open":236},[285,286,291,292],{"type":186,"value":239},{"type":180,"tag":241,"props":287,"children":288},{},[289],{"type":186,"value":290},"能讲讲怎么做后期吗？",{"type":186,"value":239},{"type":180,"tag":188,"props":293,"children":294},{},[295],{"type":186,"value":296},"鉴于后期我非常业余，这里简单介绍一下我的后期思路，仅供参考：首先录制一段非常长的音频，一直重复弹一首曲子，直到满意为止。其中如果有明显的瑕疵，这时看心情考虑重录或者后期修复。拿到录音素材后，先粗剪成一首曲子。然后是降噪，一般关掉吉他拾音器然后用一段空白的录音捕获室内噪音，再用 Audition 的噪音模型降噪；接着调 EQ，依喜好调成想要的音色；再是立体声扩展，把低中高频分离出来，创造环绕效果；最后是加混响。由于我觉得 ACG K701 的听感和市面上大部分耳机相比有非常大的差异，所以我一般只在录音时使用 K701 而在后期时使用 WH-1000XM4。",{"type":180,"tag":234,"props":298,"children":299},{"open":236},[300,301,306,307],{"type":186,"value":239},{"type":180,"tag":241,"props":302,"children":303},{},[304],{"type":186,"value":305},"还会继续更新么？",{"type":186,"value":239},{"type":180,"tag":188,"props":308,"children":309},{},[310],{"type":186,"value":311},"我花了很长的时间来思考我和吉他的关系，得到的结论之一是：掌握一门技艺是一件美好的事情，但精进它却需要投入充足的精力与财力。鉴于我的时间和热情在近几年逐渐下放到编程中，所以，在可预见的五年内，我不会继续练习吉他以及其它乐器。如果有的话，em，我是说如果，那一定会是非常简单的曲子。",{"type":180,"tag":181,"props":313,"children":315},{"id":314},"回忆",[316],{"type":186,"value":314},{"type":180,"tag":188,"props":318,"children":319},{},[320,322],{"type":186,"value":321},"有关吉他的一些回忆：",{"type":180,"tag":323,"props":324,"children":325},"a",{"href":16},[326],{"type":186,"value":327},"《长夜梦》",{"title":174,"searchDepth":329,"depth":329,"links":330},2,[331,332,333],{"id":183,"depth":329,"text":183},{"id":230,"depth":329,"text":230},{"id":314,"depth":329,"text":314},"markdown","content:4.music:0.index.md","content","4.music/0.index.md","4.music/0.index","md",[341,343],{"_path":94,"title":97,"description":342},"读书笔记以及短评。希望能逐步摆脱豆瓣。",{"_path":106,"title":105,"description":344},"Le vent se lève, il faut tenter de vivre",1771214142783]