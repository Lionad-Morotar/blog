36,255,270,285,300,315,320],{"type":183,"tag":184,"props":185,"children":187},"element","h2",{"id":186},"我的设备",[188],{"type":189,"value":186},"text",{"type":183,"tag":191,"props":192,"children":193},"p",{},[194],{"type":189,"value":195},"截至 2022，手头的主力设备清单：",{"type":183,"tag":197,"props":198,"children":199},"ul",{},[200,206,211,216,221,226],{"type":183,"tag":201,"props":202,"children":203},"li",{},[204],{"type":189,"value":205},"吉他：曼森 MS5 ce",{"type":183,"tag":201,"props":207,"children":208},{},[209],{"type":189,"value":210},"MIC：罗德 NT-5 pair",{"type":183,"tag":201,"props":212,"children":213},{},[214],{"type":189,"value":215},"录像：iPhone 12 & 卡色人像镜",{"type":183,"tag":201,"props":217,"children":218},{},[219],{"type":189,"value":220},"声卡：Yamaha UR44C",{"type":183,"tag":201,"props":222,"children":223},{},[224],{"type":189,"value":225},"后期：Audition",{"type":183,"tag":201,"props":227,"children":228},{},[229],{"type":189,"value":230},"监听：ACG K701 & WH-1000XM4",{"type":183,"tag":184,"props":232,"children":234},{"id":233},"常见问题",[235],{"type":189,"value":233},{"type":183,"tag":237,"props":238,"children":240},"details",{"open":239},true,[241,243,249,250],{"type":189,"value":242},"\n  ",{"type":183,"tag":244,"props":245,"children":246},"summary",{},[247],{"type":189,"value":248},"有xxx的谱子吗？",{"type":189,"value":242},{"type":183,"tag":191,"props":251,"children":252},{},[253],{"type":189,"value":254},"很遗憾，没有。我弹琴大部分时候会按原版谱学习，不过等左右手熟练以后就会把谱子扔掉。这时我可能会进行一些我不在意的改动。这样做显然会带来明显的坏处，请大家不要模仿。",{"type":183,"tag":237,"props":256,"children":257},{"open":239},[258,259,264,265],{"type":189,"value":242},{"type":183,"tag":244,"props":260,"children":261},{},[262],{"type":189,"value":263},"目前手上就一把琴？",{"type":189,"value":242},{"type":183,"tag":191,"props":266,"children":267},{},[268],{"type":189,"value":269},"是的，目前我所有视频都是用这把琴录制的。这把曼森是在大学时某比赛中拿的，至于其它琴，我好像不怎么能回忆起它们的下落了。以后存了钱我想再入手一把 Headway Sakura，我觉得它非常漂亮，无论是外观还是音色。不过目前来说这把曼森已经能满足我当前的外录需求，私底下我认为换琴弦对琴音色的提升其性价比会比换琴高得多。",{"type":183,"tag":237,"props":271,"children":272},{"open":239},[273,274,279,280],{"type":189,"value":242},{"type":183,"tag":244,"props":275,"children":276},{},[277],{"type":189,"value":278},"有推荐的录音设备吗？",{"type":189,"value":242},{"type":183,"tag":191,"props":281,"children":282},{},[283],{"type":189,"value":284},"麦克风我曾用过两年的 Line6 Sonic Port VX。从各个角度（除了动态）我都觉得比我现在手上的 NT-5 要好一些，只是不知怎么就坏掉了，才换新款。至于声卡，我觉得 UR44C 对我来说刚刚好，因为他有 4 个入口，能满足我一对 NT-5 以及吉他拾音器三个通道的录制。",{"type":183,"tag":237,"props":286,"children":287},{"open":239},[288,289,294,295],{"type":189,"value":242},{"type":183,"tag":244,"props":290,"children":291},{},[292],{"type":189,"value":293},"能讲讲怎么做后期吗？",{"type":189,"value":242},{"type":183,"tag":191,"props":296,"children":297},{},[298],{"type":189,"value":299},"鉴于后期我非常业余，这里简单介绍一下我的后期思路，仅供参考：首先录制一段非常长的音频，一直重复弹一首曲子，直到满意为止。其中如果有明显的瑕疵，这时看心情考虑重录或者后期修复。拿到录音素材后，先粗剪成一首曲子。然后是降噪，一般关掉吉他拾音器然后用一段空白的录音捕获室内噪音，再用 Audition 的噪音模型降噪；接着调 EQ，依喜好调成想要的音色；再是立体声扩展，把低中高频分离出来，创造环绕效果；最后是加混响。由于我觉得 ACG K701 的听感和市面上大部分耳机相比有非常大的差异，所以我一般只在录音时使用 K701 而在后期时使用 WH-1000XM4。",{"type":183,"tag":237,"props":301,"children":302},{"open":239},[303,304,309,310],{"type":189,"value":242},{"type":183,"tag":244,"props":305,"children":306},{},[307],{"type":189,"value":308},"还会继续更新么？",{"type":189,"value":242},{"type":183,"tag":191,"props":311,"children":312},{},[313],{"type":189,"value":314},"我花了很长的时间来思考我和吉他的关系，得到的结论之一是：掌握一门技艺是一件美好的事情，但精进它却需要投入充足的精力与财力。鉴于我的时间和热情在近几年逐渐下放到编程中，所以，在可预见的五年内，我不会继续练习吉他以及其它乐器。如果有的话，em，我是说如果，那一定会是非常简单的曲子。",{"type":183,"tag":184,"props":316,"children":318},{"id":317},"回忆",[319],{"type":189,"value":317},{"type":183,"tag":191,"props":321,"children":322},{},[323,325],{"type":189,"value":324},"有关吉他的一些回忆：",{"type":183,"tag":326,"props":327,"children":328},"a",{"href":16},[329],{"type":189,"value":330},"《长夜梦》",{"title":177,"searchDepth":332,"depth":332,"links":333},2,[334,335,336],{"id":186,"depth":332,"text":186},{"id":233,"depth":332,"text":233},{"id":317,"depth":332,"text":317},"markdown","content:4.music:0.index.md","content","4.music/0.index.md","4.music/0.index","md",[344,346],{"_path":94,"title":97,"description":345},"读书笔记以及短评。希望能逐步摆脱豆瓣。",{"_path":106,"title":105,"description":347},"Le vent se lève, il faut tenter de vivre",1771693639676]