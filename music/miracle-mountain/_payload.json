"type":182,"tag":183,"props":184,"children":185},"element","center",{},[186,198,214,227,240,253,266,279,292],{"type":182,"tag":187,"props":188,"children":194},"iframe",{"frameBorder":189,"border":190,"marginWidth":190,"marginHeight":190,"width":191,"height":192,"src":193},"no",0,355,150,"//music.163.com/outchain/player?type=2&id=1323087576&auto=0",[195],{"type":196,"value":197},"text","\n\u003Cp style=\"text-align: center;\">\n  \u003Ca rel=\"nofollow\" href=\"https://music.163.com/#/song?id=1323087576\">网易云直达\u003C/a>\n\u003C/p>\n\u003C/center>\n\n\n正在学这首曲子，很好听，还有十多天中考了，加油❤\n\u003Cname>JX-Tiamo\u003C/name>",{"type":182,"tag":199,"props":200,"children":201},"blockquote",{},[202],{"type":182,"tag":203,"props":204,"children":205},"p",{},[206,208],{"type":196,"value":207},"听着觉得这版像凌晨，原版像黎明，矫情了\n",{"type":182,"tag":209,"props":210,"children":211},"name",{},[212],{"type":196,"value":213},"SunSunSunStar",{"type":182,"tag":199,"props":215,"children":216},{},[217],{"type":182,"tag":203,"props":218,"children":219},{},[220,222],{"type":196,"value":221},"打开电视，戴上耳机，声音充斥整个房间，我一个人听着，想了想，想睡觉。\n",{"type":182,"tag":209,"props":223,"children":224},{},[225],{"type":196,"value":226},"亚唐时代",{"type":182,"tag":199,"props":228,"children":229},{},[230],{"type":182,"tag":203,"props":231,"children":232},{},[233,235],{"type":196,"value":234},"忘记从哪个摇滚还是金属的群里关注的作者了??? 万万没想到，是个弹岸部的文艺青年\n",{"type":182,"tag":209,"props":236,"children":237},{},[238],{"type":196,"value":239},"帐号已注销",{"type":182,"tag":199,"props":241,"children":242},{},[243],{"type":182,"tag":203,"props":244,"children":245},{},[246,248],{"type":196,"value":247},"Lionad，我是北方死宅莱茵金属啊！借母上的手机来评论啦！支持你啊！\n",{"type":182,"tag":209,"props":249,"children":250},{},[251],{"type":196,"value":252},"威粘-米尔湿",{"type":182,"tag":199,"props":254,"children":255},{},[256],{"type":182,"tag":203,"props":257,"children":258},{},[259,261],{"type":196,"value":260},"来晚了，记得这首曲子是大一刚开学睡不着的时候经常会听的一首，非常感谢大佬再次让人想起那段日子。🏻\n",{"type":182,"tag":209,"props":262,"children":263},{},[264],{"type":196,"value":265},"新月之舞",{"type":182,"tag":199,"props":267,"children":268},{},[269],{"type":182,"tag":203,"props":270,"children":271},{},[272,274],{"type":196,"value":273},"是什么让我深夜不睡，啊，这位老弟\n",{"type":182,"tag":209,"props":275,"children":276},{},[277],{"type":196,"value":278},"雪雪患上拖延症了",{"type":182,"tag":199,"props":280,"children":281},{},[282],{"type":182,"tag":203,"props":283,"children":284},{},[285,287],{"type":196,"value":286},"每首曲子弹的都好好听，我都很喜欢耶\n",{"type":182,"tag":209,"props":288,"children":289},{},[290],{"type":196,"value":291},"越陌度阡cwl",{"type":182,"tag":199,"props":293,"children":294},{},[295],{"type":182,"tag":203,"props":296,"children":297},{},[298,300],{"type":196,"value":299},"音质变好了奈斯\n",{"type":182,"tag":209,"props":301,"children":302},{},[303],{"type":196,"value":304},"MX-LI",{"title":176,"searchDepth":306,"depth":306,"links":307},2,[],"markdown","content:4.music:5.miracle-mountain.md","content","4.music/5.miracle-mountain.md","4.music/5.miracle-mountain","md",[315,317],{"_path":115,"title":114,"description":316},"2018，使徒没有袭来。",{"_path":121,"title":120,"description":318},"原版无为我能听一万年",1771693381007]