crapto","_blank","i-simple-icons-github",{"type":182,"children":183,"toc":422},"root",[184,192,206,211,230,239,254,259,285,290,295,316,345,416],{"type":185,"tag":186,"props":187,"children":189},"element","h2",{"id":188},"简介",[190],{"type":191,"value":188},"text",{"type":185,"tag":193,"props":194,"children":195},"p",{},[196,204],{"type":185,"tag":197,"props":198,"children":201},"a",{"href":178,"rel":199},[200],"nofollow",[202],{"type":191,"value":203},"Crapto",{"type":191,"value":205},"，曾名为 file-text-crypto，以下简称 FTC，是一款可以给你的代码中部分内容或全文加密的插件。",{"type":185,"tag":193,"props":207,"children":208},{},[209],{"type":191,"value":210},"假设你想在开源的博客系统写了一些带有隐私的内容，FTC 允许你在本地编辑时查看加密内容，而项目上传时隐私仍然保持加密。",{"type":185,"tag":193,"props":212,"children":213},{},[214,216,228],{"type":191,"value":215},"比如，这是一段隐私内容：",{"type":185,"tag":217,"props":218,"children":219},"em",{},[220],{"type":185,"tag":217,"props":221,"children":222},{},[223],{"type":185,"tag":217,"props":224,"children":225},{},[226],{"type":191,"value":227},"U2FsdGVkX1+9tlp8UGxEcYpzalYpSLLh//b3GjwE4s0=",{"type":191,"value":229},"，只有当我使用 VSCode 本地编辑时才能看到其内容。",{"type":185,"tag":193,"props":231,"children":232},{},[233],{"type":185,"tag":234,"props":235,"children":236},"strong",{},[237],{"type":191,"value":238},"FTC 会把文件的密钥存在本地目录，所以请务必把密钥文件所在的文件夹（默认为 .ftc）加入 .gitignore（密钥默认储存在 .ftc 文件夹）防止 Git 系统把密钥传到了远端。",{"type":185,"tag":240,"props":241,"children":242},"ul",{},[243,249],{"type":185,"tag":244,"props":245,"children":246},"li",{},[247],{"type":191,"value":248},"目前仅支持加密 markdown 文件中的特定标识文本。",{"type":185,"tag":244,"props":250,"children":251},{},[252],{"type":191,"value":253},"Issues and Pull Request are Welcome！",{"type":185,"tag":186,"props":255,"children":257},{"id":256},"快捷键",[258],{"type":191,"value":256},{"type":185,"tag":240,"props":260,"children":261},{},[262,274],{"type":185,"tag":244,"props":263,"children":264},{},[265,272],{"type":185,"tag":266,"props":267,"children":269},"code",{"className":268},[],[270],{"type":191,"value":271